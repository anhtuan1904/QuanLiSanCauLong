{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=BadmintonBookingDB;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "SePay": {
    "WebhookSecret": "BoThienHa1904"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "SiteName": "Hệ thống Đặt sân Cầu lông",
    "SiteUrl": "https://localhost:7001",
    "AdminEmail": "admin@badminton.com",
    "SupportEmail": "support@badminton.com",
    "SupportPhone": "1900xxxx",
    "MaxUploadSizeMB": 10,
    "AllowedImageExtensions": [ ".jpg", ".jpeg", ".png", ".gif" ],
    "AllowedDocExtensions": [ ".pdf", ".doc", ".docx", ".xls", ".xlsx" ]
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "noreply@badminton.com",
    "FromName": "Badminton Booking System",
    "EnableSsl": true,
    "UseDefaultCredentials": false
  },
  "SmsSettings": {
    "Provider": "Twilio",
    "AccountSid": "your-account-sid",
    "AuthToken": "your-auth-token",
    "PhoneNumber": "+84xxxxxxxxx",
    "Enabled": false
  },
  "BookingSettings": {
    "MaxBookingDaysInAdvance": 30,
    "MinBookingHoursInAdvance": 1,
    "CancellationHoursBeforeStart": 2,
    "DefaultServiceFeePercent": 0,
    "AutoConfirmBooking": true,
    "SendConfirmationEmail": true,
    "SendReminderSms": false,
    "ReminderHoursBeforeStart": 2
  },
  "InventorySettings": {
    "EnableLowStockAlert": true,
    "LowStockThreshold": 10,
    "SendLowStockEmail": true,
    "AutoOrderWhenLowStock": false
  },
  "FileStorage": {
    "StorageType": "Local",
    "LocalPath": "wwwroot/uploads",
    "AzureBlobConnectionString": "",
    "AzureBlobContainer": "uploads",
    "MaxFileSizeMB": 10
  },
  "CacheSettings": {
    "EnableCaching": true,
    "DefaultCacheDurationMinutes": 30,
    "SlidingExpiration": true
  },
  "SecuritySettings": {
    "RequireHttps": true,
    "PasswordMinLength": 6,
    "PasswordRequireDigit": true,
    "PasswordRequireLowercase": true,
    "PasswordRequireUppercase": false,
    "PasswordRequireNonAlphanumeric": false,
    "LockoutDurationMinutes": 30,
    "MaxFailedAccessAttempts": 5,
    "EnableTwoFactorAuthentication": false
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "PermitLimit": 100,
    "Window": 60,
    "QueueLimit": 10
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "GoogleAnalytics": {
    "TrackingId": "UA-XXXXXXXXX-X",
    "Enabled": false
  },
  "Features": {
    "EnableVouchers": true,
    "EnableProductSales": true,
    "EnableInventoryManagement": true,
    "EnableReports": true,
    "EnableNotifications": true,
    "EnableActivityLog": true,
    "EnableQRCode": true
  }
}