@model QuanLiSanCauLong.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang Chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --gold: #d4a017;
        --gold2: #f5c842;
        --deep: #1a1209;
        --cream: #fdf8f0;
        --warm: #f5efe0;
        --muted: #8a7560;
        --border: #e8ddc8;
    }

    html {
        scroll-behavior: smooth;
    }

    * {
        box-sizing: border-box;
    }

    body, * {
        font-family: 'Outfit', sans-serif;
    }

    /* ── HERO ─────────────────────────────────────────── */
    .home-hero {
        background: var(--deep);
        min-height: 100vh;
        display: grid;
        grid-template-columns: 52% 48%;
        position: relative;
        overflow: hidden;
    }

    .hero-left {
        padding: 8rem 5rem 6rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
    }

    .hero-overline {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .hero-overline-line {
        width: 48px;
        height: 1px;
        background: var(--gold);
    }

    .hero-overline span {
        font-size: .72rem;
        letter-spacing: .25em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 500;
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(3.2rem, 6vw, 6.5rem);
        font-weight: 900;
        color: #fff;
        line-height: .95;
        margin-bottom: 2.5rem;
        letter-spacing: -.01em;
    }

        .hero-title em {
            font-style: italic;
            color: var(--gold2);
        }

        .hero-title .hero-title-sub {
            display: block;
            font-size: clamp(1.4rem, 2.5vw, 2.5rem);
            font-weight: 300;
            color: rgba(255,255,255,.45);
            font-style: normal;
            margin-top: .5rem;
            font-family: 'Outfit', sans-serif;
            letter-spacing: .02em;
        }

    .hero-subtitle {
        color: rgba(255,255,255,.5);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.85;
        max-width: 440px;
        margin-bottom: 3.5rem;
    }

    /* Search card */
    .search-card {
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 6px;
        padding: 1.75rem 2rem;
        backdrop-filter: blur(12px);
        margin-bottom: 3.5rem;
        max-width: 520px;
    }

    .search-card-label {
        font-size: .68rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 600;
        margin-bottom: 1.2rem;
    }

    .search-fields {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: .75rem;
        align-items: end;
    }

    .sf-group label {
        font-size: .7rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: rgba(255,255,255,.4);
        display: block;
        margin-bottom: .45rem;
    }

    .sf-group select,
    .sf-group input[type="date"] {
        width: 100%;
        padding: .7rem 1rem;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 3px;
        color: #fff;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        outline: none;
        transition: border-color .2s;
        cursor: pointer;
    }

        .sf-group select:focus,
        .sf-group input[type="date"]:focus {
            border-color: var(--gold);
        }

        .sf-group select option {
            background: var(--deep);
            color: #fff;
        }

        .sf-group input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1) opacity(.5);
            cursor: pointer;
        }

    .btn-search {
        padding: .7rem 1.5rem;
        background: var(--gold);
        color: var(--deep);
        border: none;
        font-family: 'Outfit', sans-serif;
        font-size: .82rem;
        font-weight: 700;
        letter-spacing: .06em;
        border-radius: 3px;
        cursor: pointer;
        transition: all .25s;
        display: flex;
        align-items: center;
        gap: .5rem;
        white-space: nowrap;
    }

        .btn-search:hover {
            background: var(--gold2);
            transform: translateY(-1px);
        }

    /* Stats row */
    .hero-stats {
        display: flex;
        gap: 0;
        border: 1px solid rgba(255,255,255,.1);
        width: fit-content;
        border-radius: 4px;
        overflow: hidden;
    }

    .hs-item {
        padding: 1rem 1.8rem;
        border-right: 1px solid rgba(255,255,255,.1);
        text-align: center;
    }

        .hs-item:last-child {
            border-right: none;
        }

    .hs-n {
        font-family: 'Playfair Display', serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .hs-l {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.3);
        margin-top: .3rem;
    }

    /* Hero right — facility cards carousel */
    .hero-right {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 0;
    }

    .hero-right-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1613918108466-292b78a8ef85?w=900&q=80');
        background-size: cover;
        background-position: center;
        filter: sepia(20%) contrast(1.05) brightness(.85);
    }

    .hero-right-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, var(--deep) 0%, rgba(26,18,9,.4) 40%, rgba(26,18,9,.1) 100%);
    }

    .hero-badge {
        position: absolute;
        top: 2.5rem;
        right: 2.5rem;
        background: rgba(255,255,255,.12);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,.2);
        border-radius: 4px;
        padding: 1rem 1.5rem;
        z-index: 2;
        text-align: center;
    }

    .hero-badge-n {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .hero-badge-l {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.5);
        margin-top: .3rem;
    }

    .hero-promo-tag {
        position: absolute;
        bottom: 2.5rem;
        right: 2.5rem;
        background: var(--gold);
        color: var(--deep);
        border-radius: 3px;
        padding: .7rem 1.2rem;
        z-index: 2;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .06em;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    /* ── WHY US ───────────────────────────────────── */
    .why-section {
        background: var(--cream);
        padding: 7rem 0;
    }

    .section-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 4rem;
    }

    .section-overline {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .section-overline-line {
        width: 40px;
        height: 1px;
        background: var(--gold);
    }

    .section-overline span {
        font-size: .72rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 600;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 3.5vw, 3rem);
        font-weight: 700;
        color: var(--deep);
        line-height: 1.1;
        margin-bottom: 4rem;
    }

        .section-title em {
            font-style: italic;
            color: var(--gold);
        }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
    }

    .why-card {
        background: #fff;
        padding: 2.5rem 2rem;
        transition: background .25s;
    }

        .why-card:hover {
            background: var(--warm);
        }

    .why-icon {
        width: 52px;
        height: 52px;
        background: var(--warm);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        font-size: 1.4rem;
        color: var(--gold);
        transition: background .25s;
    }

    .why-card:hover .why-icon {
        background: var(--gold);
        color: var(--deep);
    }

    .why-name {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .6rem;
    }

    .why-desc {
        font-size: .84rem;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.7;
    }

    /* ── FACILITIES ───────────────────────────────── */
    .facilities-section {
        background: var(--deep);
        padding: 7rem 0;
        position: relative;
        overflow: hidden;
    }

        .facilities-section::before {
            content: 'SÂN';
            position: absolute;
            right: -1rem;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Playfair Display', serif;
            font-size: 14rem;
            font-weight: 900;
            color: rgba(255,255,255,.02);
            pointer-events: none;
            line-height: 1;
            letter-spacing: -.05em;
        }

    .fac-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 4rem;
    }

    .fac-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 3.5vw, 3rem);
        font-weight: 700;
        color: #fff;
        line-height: 1.1;
    }

        .fac-title em {
            font-style: italic;
            color: var(--gold2);
        }

    .btn-view-all {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-size: .8rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--gold);
        text-decoration: none;
        border-bottom: 1px solid rgba(212,160,23,.3);
        padding-bottom: .2rem;
        transition: all .2s;
    }

        .btn-view-all:hover {
            color: var(--gold2);
            border-color: var(--gold2);
        }

    .fac-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1.5rem;
    }

    .fac-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 6px;
        overflow: hidden;
        transition: all .35s;
        text-decoration: none;
        display: block;
    }

        .fac-card:hover {
            border-color: rgba(212,160,23,.35);
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(0,0,0,.35);
        }

    .fac-img {
        position: relative;
        aspect-ratio: 16/10;
        overflow: hidden;
        background: rgba(255,255,255,.05);
    }

        .fac-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(.85);
            transition: transform .5s, filter .5s;
        }

    .fac-card:hover .fac-img img {
        transform: scale(1.05);
        filter: brightness(.95);
    }

    .fac-img-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        color: rgba(255,255,255,.1);
    }

    .fac-badge {
        position: absolute;
        top: .9rem;
        left: .9rem;
        background: var(--gold);
        color: var(--deep);
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        padding: .22rem .7rem;
        border-radius: 2px;
    }

    .fac-body {
        padding: 1.75rem 1.75rem 1.5rem;
    }

    .fac-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: .5rem;
        line-height: 1.2;
    }

    .fac-loc {
        font-size: .8rem;
        color: rgba(255,255,255,.4);
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-bottom: 1.2rem;
    }

        .fac-loc i {
            color: var(--gold);
            font-size: .7rem;
        }

    .fac-divider {
        height: 1px;
        background: rgba(255,255,255,.07);
        margin-bottom: 1.2rem;
    }

    .fac-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .fac-rating {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .8rem;
        color: rgba(255,255,255,.5);
    }

        .fac-rating i {
            color: var(--gold2);
            font-size: .75rem;
        }

        .fac-rating strong {
            color: #fff;
        }

    .fac-price {
        text-align: right;
    }

    .fac-price-from {
        font-size: .65rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: rgba(255,255,255,.3);
    }

    .fac-price-amount {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--gold2);
    }

    /* ── HOW IT WORKS ─────────────────────────────── */
    .how-section {
        background: var(--cream);
        padding: 7rem 0;
    }

    .how-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 0;
        position: relative;
        margin-top: 4rem;
    }

        .how-grid::before {
            content: '';
            position: absolute;
            top: 26px;
            left: calc(100%/3/2);
            right: calc(100%/3/2);
            height: 1px;
            background: linear-gradient(to right, var(--gold), var(--border), var(--gold));
            z-index: 0;
        }

    .how-step {
        padding: 0 3rem;
        text-align: center;
        position: relative;
        z-index: 1;
    }

        .how-step:first-child {
            padding-left: 0;
        }

        .how-step:last-child {
            padding-right: 0;
        }

    .how-number {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--deep);
        color: var(--gold2);
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        position: relative;
        z-index: 1;
        border: 3px solid var(--gold);
    }

    .how-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .75rem;
    }

    .how-desc {
        font-size: .88rem;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.75;
    }

    .how-cta {
        text-align: center;
        margin-top: 4rem;
    }

    .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: .75rem;
        background: var(--deep);
        color: var(--gold2);
        border: none;
        padding: 1rem 3rem;
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: .04em;
        border-radius: 3px;
        cursor: pointer;
        text-decoration: none;
        transition: all .3s;
    }

        .btn-cta:hover {
            background: var(--gold);
            color: var(--deep);
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(212,160,23,.35);
        }

    /* ── SERVICES STRIP ───────────────────────────── */
    .services-strip {
        background: var(--warm);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 5rem 0;
    }

    .svc-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        margin-top: 3.5rem;
    }

    .svc-card {
        background: var(--cream);
        padding: 2.5rem 2.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: background .25s;
        text-decoration: none;
    }

        .svc-card:hover {
            background: #fff;
        }

    .svc-icon-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .svc-icon {
        width: 48px;
        height: 48px;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--gold);
        transition: all .25s;
    }

    .svc-card:hover .svc-icon {
        background: var(--gold);
        color: var(--deep);
    }

    .svc-arrow {
        color: var(--muted);
        font-size: 1rem;
        transition: transform .25s;
    }

    .svc-card:hover .svc-arrow {
        transform: translate(3px,-3px);
        color: var(--gold);
    }

    .svc-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

    .svc-desc {
        font-size: .84rem;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.65;
    }

    .svc-tag {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(212,160,23,.3);
        padding: .2rem .7rem;
        border-radius: 2px;
        align-self: flex-start;
    }

    /* ── NEWS SECTION ─────────────────────────────── */
    .news-section {
        background: var(--cream);
        padding: 7rem 0;
    }

    .news-layout {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 2rem;
        margin-top: 3.5rem;
        align-items: start;
    }
    /* Featured news card (large left) */
    .news-featured {
        display: block;
        text-decoration: none;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        transition: all .35s;
        height: 100%;
    }

        .news-featured:hover {
            box-shadow: 0 14px 40px rgba(26,18,9,.1);
            transform: translateY(-3px);
        }

            .news-featured:hover .news-featured-img img {
                transform: scale(1.04);
            }

    .news-featured-img {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
        background: var(--warm);
    }

        .news-featured-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .6s;
        }

    .news-featured-img-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: rgba(26,18,9,.08);
    }

    .news-cat-tag {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        background: var(--deep);
        color: var(--gold2);
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        padding: .25rem .8rem;
        border-radius: 2px;
    }

    .news-featured-body {
        padding: 2rem 2.25rem 2.25rem;
    }

    .news-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .news-meta-item {
        font-size: .75rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .news-meta-item i {
            color: var(--gold);
            font-size: .7rem;
        }

    .news-featured-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.25;
        margin-bottom: .9rem;
    }

    .news-featured-excerpt {
        font-size: .9rem;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.75;
        margin-bottom: 1.5rem;
    }

    .news-read-link {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--gold);
        border-bottom: 1px solid rgba(212,160,23,.3);
        padding-bottom: .15rem;
        transition: all .2s;
    }

    .news-featured:hover .news-read-link {
        color: var(--deep);
        border-color: var(--deep);
    }

    /* Stack of small news cards (right) */
    .news-stack {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
    }

    .news-small {
        display: grid;
        grid-template-columns: 100px 1fr;
        background: #fff;
        text-decoration: none;
        transition: background .2s;
        min-height: 90px;
    }

        .news-small:hover {
            background: var(--warm);
        }

    .news-small-img {
        position: relative;
        overflow: hidden;
        background: var(--warm);
    }

        .news-small-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s;
        }

    .news-small:hover .news-small-img img {
        transform: scale(1.06);
    }

    .news-small-img-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: rgba(26,18,9,.12);
    }

    .news-small-body {
        padding: .9rem 1.1rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: .35rem;
    }

    .news-small-cat {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--gold);
    }

    .news-small-title {
        font-family: 'Playfair Display', serif;
        font-size: .88rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .news-small-date {
        font-size: .7rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .news-small-date i {
            color: var(--gold);
            font-size: .65rem;
        }

    .news-footer {
        display: flex;
        justify-content: center;
        margin-top: 2.5rem;
    }

    .btn-news-all {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1px solid var(--deep);
        color: var(--deep);
        background: none;
        padding: .8rem 2.5rem;
        font-size: .82rem;
        font-weight: 700;
        letter-spacing: .06em;
        border-radius: 3px;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-news-all:hover {
            background: var(--deep);
            color: var(--gold2);
        }

    /* ── RESPONSIVE ───────────────────────────────── */
    @@media (max-width: 1024px) {
        .fac-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .why-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .news-layout {
            grid-template-columns: 1fr;
        }

        .news-stack {
            display: grid;
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media (max-width: 900px) {
        .home-hero {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .hero-right {
            display: none;
        }

        .hero-left {
            padding: 5rem 2rem 4rem;
        }

        .search-fields {
            grid-template-columns: 1fr 1fr;
        }

        .btn-search {
            grid-column: span 2;
            justify-content: center;
        }

        .section-inner {
            padding: 0 1.5rem;
        }

        .why-section, .how-section, .services-strip, .news-section {
            padding: 5rem 0;
        }

        .facilities-section {
            padding: 5rem 0;
        }

        .svc-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .why-grid {
            grid-template-columns: 1fr;
        }

        .fac-grid {
            grid-template-columns: 1fr;
        }

        .how-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

            .how-grid::before {
                display: none;
            }

        .search-fields {
            grid-template-columns: 1fr;
        }

        .btn-search {
            grid-column: span 1;
        }

        .hero-counts {
            flex-direction: column;
            border-radius: 0;
        }

        .hs-item {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

            .hs-item:last-child {
                border-bottom: none;
            }

        .news-stack {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- ── HERO ──────────────────────────────────────────── -->
<section class="home-hero">
    <div class="hero-left">
        <div class="hero-overline">
            <div class="hero-overline-line"></div>
            <span>Badminton Platform</span>
        </div>
        <h1 class="hero-title">
            Đặt sân<br />
            <em>đơn giản.</em>
            <span class="hero-title-sub">Chơi không lo lắng.</span>
        </h1>
        <p class="hero-subtitle">
            Tìm và đặt sân cầu lông chất lượng cao gần bạn chỉ trong vài phút — mọi lúc, mọi nơi, không phức tạp.
        </p>

        <div class="search-card">
            <div class="search-card-label"><i class="bi bi-search me-1"></i> Tìm sân ngay</div>
            <form asp-controller="Booking" asp-action="Search" method="get">
                <div class="search-fields">
                    <div class="sf-group">
                        <label><i class="bi bi-geo-alt"></i> Khu vực</label>
                        <select name="city">
                            <option value="Hà Nội">Hà Nội</option>
                            <option value="TP.HCM">TP. Hồ Chí Minh</option>
                        </select>
                    </div>
                    <div class="sf-group">
                        <label><i class="bi bi-calendar3"></i> Ngày đặt</label>
                        <input type="date" name="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="sf-group">
                        <label class="opacity-0">.</label>
                        <button type="submit" class="btn-search">
                            <i class="bi bi-search"></i> Tìm sân
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="hero-stats">
            <div class="hs-item"><div class="hs-n">100+</div><div class="hs-l">Sân cầu lông</div></div>
            <div class="hs-item"><div class="hs-n">50k+</div><div class="hs-l">Lượt đặt sân</div></div>
            <div class="hs-item"><div class="hs-n">4.8★</div><div class="hs-l">Đánh giá</div></div>
        </div>
    </div>

    <div class="hero-right">
        <div class="hero-right-bg"></div>
        <div class="hero-right-overlay"></div>
        <div class="hero-badge">
            <div class="hero-badge-n">24/7</div>
            <div class="hero-badge-l">Đặt sân mọi lúc</div>
        </div>
        <div class="hero-promo-tag">
            <i class="bi bi-lightning-fill"></i> Đặt ngay — Giảm 20%
        </div>
    </div>
</section>

<!-- ── WHY US ─────────────────────────────────────────── -->
<section class="why-section">
    <div class="section-inner">
        <div class="section-overline">
            <div class="section-overline-line"></div>
            <span>Tại sao chọn chúng tôi</span>
        </div>
        <div class="section-title">Trải nghiệm đặt sân<br /><em>khác biệt.</em></div>
        <div class="why-grid">
            <div class="why-card">
                <div class="why-icon"><i class="bi bi-clock-history"></i></div>
                <div class="why-name">Đặt sân 24/7</div>
                <div class="why-desc">Đặt sân mọi lúc mọi nơi, kể cả ngoài giờ hành chính — không cần gọi điện.</div>
            </div>
            <div class="why-card">
                <div class="why-icon"><i class="bi bi-shield-check"></i></div>
                <div class="why-name">Thanh toán an toàn</div>
                <div class="why-desc">Bảo mật thông tin và giao dịch thanh toán với tiêu chuẩn bảo mật cao nhất.</div>
            </div>
            <div class="why-card">
                <div class="why-icon"><i class="bi bi-award"></i></div>
                <div class="why-name">Sân chất lượng</div>
                <div class="why-desc">Tất cả sân đều được kiểm duyệt nghiêm ngặt và nhận đánh giá cao từ người chơi.</div>
            </div>
            <div class="why-card">
                <div class="why-icon"><i class="bi bi-wallet2"></i></div>
                <div class="why-name">Giá tốt nhất</div>
                <div class="why-desc">Cam kết giá tốt nhất và nhiều ưu đãi hấp dẫn cho người chơi thường xuyên.</div>
            </div>
        </div>
    </div>
</section>

<!-- ── FEATURED FACILITIES ────────────────────────────── -->
<section class="facilities-section">
    <div class="section-inner">
        <div class="fac-header">
            <div>
                <div class="section-overline" style="margin-bottom:1rem;">
                    <div class="section-overline-line"></div>
                    <span style="color:rgba(255,255,255,.4);">Sân nổi bật</span>
                </div>
                <div class="fac-title">Sân cầu lông<br /><em>phổ biến nhất.</em></div>
            </div>
            <a asp-controller="Facility" asp-action="Index" class="btn-view-all">
                Xem tất cả <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="fac-grid">
            @foreach (var facility in Model.FeaturedFacilities)
            {
                <a asp-action="Details" asp-controller="Facility" asp-route-id="@facility.FacilityId" class="fac-card">
                    <div class="fac-img">
                        @if (!string.IsNullOrEmpty(facility.ImageUrl))
                        {
                            <img src="@facility.ImageUrl" alt="@facility.FacilityName" loading="lazy" />
                        }
                        else
                        {
                            <div class="fac-img-empty"><i class="bi bi-building"></i></div>
                        }
                        <div class="fac-badge">Phổ biến</div>
                    </div>
                    <div class="fac-body">
                        <div class="fac-name">@facility.FacilityName</div>
                        <div class="fac-loc">
                            <i class="bi bi-geo-alt-fill"></i>
                            @facility.District, @facility.City
                        </div>
                        <div class="fac-divider"></div>
                        <div class="fac-footer">
                            <div class="fac-rating">
                                <i class="bi bi-star-fill"></i>
                                <strong>4.9</strong>
                                <span>(89 đánh giá)</span>
                            </div>
                            <div class="fac-price">
                                <div class="fac-price-from">Chỉ từ</div>
                                <div class="fac-price-amount">80.000đ/giờ</div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- ── OUR SERVICES ───────────────────────────────────── -->
<section class="services-strip">
    <div class="section-inner">
        <div class="section-overline">
            <div class="section-overline-line"></div>
            <span>Dịch vụ của chúng tôi</span>
        </div>
        <div class="section-title">Đầy đủ dịch vụ<br /><em>dành cho bạn.</em></div>
        <div class="svc-grid">
            <a asp-controller="Service" asp-action="Training" class="svc-card">
                <div class="svc-icon-row">
                    <div class="svc-icon"><i class="bi bi-mortarboard-fill"></i></div>
                    <i class="bi bi-arrow-up-right svc-arrow"></i>
                </div>
                <div class="svc-name">Khóa học<br />cầu lông</div>
                <div class="svc-desc">Nâng cao kỹ năng cùng HLV chuyên nghiệp — từ cơ bản đến nâng cao.</div>
                <div class="svc-tag">Xem khóa học</div>
            </a>
            <a asp-controller="Service" asp-action="Stringing" class="svc-card">
                <div class="svc-icon-row">
                    <div class="svc-icon"><i class="bi bi-tools"></i></div>
                    <i class="bi bi-arrow-up-right svc-arrow"></i>
                </div>
                <div class="svc-name">Căng vợt<br />chuyên nghiệp</div>
                <div class="svc-desc">Dịch vụ căng vợt nhanh chóng, đúng tiêu chuẩn từ kỹ thuật viên có kinh nghiệm.</div>
                <div class="svc-tag">Xem dịch vụ</div>
            </a>
            <a asp-controller="Service" asp-action="Tournament" class="svc-card">
                <div class="svc-icon-row">
                    <div class="svc-icon"><i class="bi bi-trophy-fill"></i></div>
                    <i class="bi bi-arrow-up-right svc-arrow"></i>
                </div>
                <div class="svc-name">Giải đấu<br />cầu lông</div>
                <div class="svc-desc">Tham gia các giải đấu hấp dẫn — từ phong trào đến tranh tài chuyên nghiệp.</div>
                <div class="svc-tag">Xem giải đấu</div>
            </a>
        </div>
    </div>
</section>


<!-- ── TIN TỨC NỔI BẬT ───────────────────────────────── -->
@if (Model.LatestPosts != null && Model.LatestPosts.Any())
{
    <section class="news-section">
        <div class="section-inner">
            <div style="display:flex;align-items:flex-end;justify-content:space-between;">
                <div>
                    <div class="section-overline">
                        <div class="section-overline-line"></div>
                        <span>Tin tức &amp; bài viết</span>
                    </div>
                    <div class="section-title">Cập nhật mới<br /><em>nhất từ cộng đồng.</em></div>
                </div>
                <a asp-controller="Blog" asp-action="Index" class="btn-view-all" style="color:var(--muted);border-color:var(--border);margin-bottom:1rem;">
                    Xem tất cả <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            @{
                var featuredNews = Model.LatestPosts.FirstOrDefault(p => p.IsFeatured) ?? Model.LatestPosts.First();
                var otherNews = Model.LatestPosts.Where(p => p.PostId != featuredNews.PostId).Take(4).ToList();
            }
            <div class="news-layout">
                <a asp-controller="Blog" asp-action="Details"
                   asp-route-id="@featuredNews.PostId" asp-route-slug="@featuredNews.Slug"
                   class="news-featured">
                    <div class="news-featured-img">
                        @if (!string.IsNullOrEmpty(featuredNews.FeaturedImage))
                        {
                            <img src="@featuredNews.FeaturedImage" alt="@featuredNews.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="news-featured-img-empty"><i class="bi bi-newspaper"></i></div>
                        }
                        @if (!string.IsNullOrEmpty(featuredNews.Category?.CategoryName))
                        {
                            <div class="news-cat-tag">@featuredNews.Category.CategoryName</div>
                        }
                    </div>
                    <div class="news-featured-body">
                        <div class="news-meta">
                            <div class="news-meta-item"><i class="bi bi-calendar3"></i>@featuredNews.CreatedAt.ToString("dd/MM/yyyy")</div>
                            <div class="news-meta-item"><i class="bi bi-eye"></i>@featuredNews.ViewCount.ToString("N0") lượt xem</div>
                        </div>
                        <div class="news-featured-title">@featuredNews.Title</div>
                        @if (!string.IsNullOrEmpty(featuredNews.Excerpt))
                        {
                            <div class="news-featured-excerpt">@featuredNews.Excerpt</div>
                        }
                        <span class="news-read-link">Đọc bài viết <i class="bi bi-arrow-right"></i></span>
                    </div>
                </a>
                <div class="news-stack">
                    @foreach (var post in otherNews)
                    {
                        <a asp-controller="Blog" asp-action="Details"
                           asp-route-id="@post.PostId" asp-route-slug="@post.Slug"
                           class="news-small">
                            <div class="news-small-img">
                                @if (!string.IsNullOrEmpty(post.FeaturedImage))
                                {
                                    <img src="@post.FeaturedImage" alt="@post.Title" loading="lazy" />
                                }
                                else
                                {
                                    <div class="news-small-img-empty"><i class="bi bi-newspaper"></i></div>
                                }
                            </div>
                            <div class="news-small-body">
                                <div class="news-small-cat">@(post.Category?.CategoryName ?? "Tin tức")</div>
                                <div class="news-small-title">@post.Title</div>
                                <div class="news-small-date"><i class="bi bi-calendar3"></i>@post.CreatedAt.ToString("dd/MM/yyyy")</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
            <div class="news-footer">
                <a asp-controller="Blog" asp-action="Index" class="btn-news-all">
                    Xem tất cả bài viết <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>
}

<!-- ── HOW IT WORKS ───────────────────────────────────── -->
<section class="how-section">
    <div class="section-inner">
        <div class="section-overline">
            <div class="section-overline-line"></div>
            <span>Cách thức hoạt động</span>
        </div>
        <div class="section-title">Chỉ 3 bước<br /><em>đơn giản.</em></div>
        <div class="how-grid">
            <div class="how-step">
                <div class="how-number">1</div>
                <div class="how-name">Tìm sân</div>
                <div class="how-desc">Tìm kiếm sân cầu lông gần bạn theo khu vực và khung giờ phù hợp.</div>
            </div>
            <div class="how-step">
                <div class="how-number">2</div>
                <div class="how-name">Đặt &amp; thanh toán</div>
                <div class="how-desc">Chọn khung giờ và thanh toán trực tuyến nhanh chóng, an toàn, dễ dàng.</div>
            </div>
            <div class="how-step">
                <div class="how-number">3</div>
                <div class="how-name">Ra sân chơi</div>
                <div class="how-desc">Nhận mã xác nhận qua SMS/Email và đến sân vào giờ đã đặt — đơn giản vậy thôi!</div>
            </div>
        </div>
        <div class="how-cta">
            <a asp-action="Search" asp-controller="Booking" class="btn-cta">
                Đặt sân ngay hôm nay <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</section>
