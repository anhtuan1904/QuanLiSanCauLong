@model IEnumerable<QuanLiSanCauLong.Models.JobPosting>
@{
    ViewData["Title"] = "Tuyển Dụng";
    var allJobs = Model.ToList();
    var openCount = allJobs.Count;
    var totalVacancy = allJobs.Sum(j => j.VacancyCount);
    var featuredCount = allJobs.Count(j => j.IsFeatured);

    // Filter params từ query string
    string? qSearch   = Context.Request.Query["search"];
    string? qType     = Context.Request.Query["jobType"];
    string? qLevel    = Context.Request.Query["level"];
    string? qDept     = Context.Request.Query["dept"];

    // Distinct values cho filter dropdowns
    var jobTypes   = allJobs.Where(j => !string.IsNullOrEmpty(j.JobType)).Select(j => j.JobType!).Distinct().OrderBy(x => x).ToList();
    var levels     = allJobs.Where(j => !string.IsNullOrEmpty(j.Level)).Select(j => j.Level!).Distinct().OrderBy(x => x).ToList();
    var depts      = allJobs.Where(j => !string.IsNullOrEmpty(j.Department)).Select(j => j.Department!).Distinct().OrderBy(x => x).ToList();
}

<style>
    :root {
        --deep:   #1a1209;
        --deep2:  #231a0e;
        --deep3:  #2e2110;
        --gold:   #d4a017;
        --gold2:  #f5c842;
        --gold3:  rgba(212,160,23,.1);
        --warm:   #f5ede0;
        --cream:  #fdf8f0;
        --ink:    #1a1209;
        --border: rgba(212,160,23,.2);
        --muted:  rgba(255,255,255,.38);
    }

    .rec-page { background: var(--warm); min-height: 100vh; font-family: 'Outfit', sans-serif; color: var(--ink); }

    /* ── HERO ── */
    .rec-hero {
        background: var(--deep);
        position: relative;
        overflow: hidden;
        padding: 6rem 4rem 5rem;
    }
    .rec-hero::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--gold), var(--gold2), transparent);
    }
    .rec-deco {
        position: absolute; right: -1rem; bottom: -3rem;
        font-family: 'Playfair Display', serif;
        font-size: 18rem; font-weight: 700; font-style: italic;
        color: rgba(212,160,23,.04); line-height: 1; pointer-events: none;
    }
    .rec-eyebrow {
        display: inline-flex; align-items: center; gap: .6rem;
        font-size: .72rem; font-weight: 700; letter-spacing: .22em;
        text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem;
    }
    .rec-eyebrow::before { content: ''; width: 26px; height: 2px; background: var(--gold); display: block; }
    .rec-hero h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.8rem, 6vw, 5.5rem);
        font-weight: 700; color: #fff; line-height: .98;
        margin-bottom: 1.2rem; position: relative; z-index: 1;
    }
    .rec-hero h1 em { color: var(--gold2); font-style: italic; }
    .rec-hero p {
        font-size: .92rem; color: rgba(255,255,255,.4);
        max-width: 440px; line-height: 1.85; position: relative; z-index: 1;
    }

    /* ── STATS ── */
    .rec-stats { background: var(--gold); display: flex; }
    .rst {
        flex: 1; padding: 1.3rem 2rem;
        border-right: 1px solid rgba(26,18,9,.18); text-align: center;
    }
    .rst:last-child { border-right: none; }
    .rst-n {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem; font-weight: 700; color: var(--deep); line-height: 1;
    }
    .rst-l {
        font-size: .62rem; font-weight: 700; letter-spacing: .15em;
        text-transform: uppercase; color: rgba(26,18,9,.52); margin-top: .2rem;
    }

    /* ── BENEFITS ── */
    .rec-section { max-width: 1200px; margin: 0 auto; padding: 5rem 3rem; }
    .rec-sec-eyebrow {
        font-size: .7rem; font-weight: 700; letter-spacing: .2em;
        text-transform: uppercase; color: var(--gold); margin-bottom: 1rem;
        display: flex; align-items: center; gap: .5rem;
    }
    .rec-sec-eyebrow::before { content: ''; width: 22px; height: 2px; background: var(--gold); display: block; }
    .rec-sec-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.4rem; font-weight: 700; color: var(--ink); margin-bottom: .5rem;
    }
    .rec-sec-sub { font-size: .87rem; color: rgba(26,18,9,.45); margin-bottom: 3rem; }

    .benefits-grid {
        display: grid; grid-template-columns: repeat(3,1fr);
        gap: 1.5px; background: rgba(26,18,9,.1);
    }
    .benefit-card {
        background: var(--cream); padding: 2.5rem 2rem;
        position: relative; overflow: hidden; transition: background .2s;
    }
    .benefit-card::after {
        content: ''; position: absolute; bottom: 0; left: 0;
        width: 0; height: 3px;
        background: linear-gradient(90deg, var(--gold), var(--gold2));
        transition: width .35s;
    }
    .benefit-card:hover { background: #fff; }
    .benefit-card:hover::after { width: 100%; }
    .benefit-icon {
        width: 50px; height: 50px;
        background: var(--gold3); border: 1.5px solid var(--border);
        border-radius: 8px; display: flex; align-items: center;
        justify-content: center; font-size: 1.25rem; color: var(--gold);
        margin-bottom: 1.5rem;
    }
    .benefit-title { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 700; color: var(--ink); margin-bottom: .5rem; }
    .benefit-desc { font-size: .83rem; color: rgba(26,18,9,.55); line-height: 1.75; }

    /* ── JOBS SECTION ── */
    .rec-jobs-bg { background: var(--deep); }
    .rec-jobs-inner { max-width: 1000px; margin: 0 auto; padding: 5rem 3rem; }
    .rec-jobs-inner .rec-sec-title { color: #fff; }
    .rec-jobs-inner .rec-sec-sub { color: var(--muted); }

    /* Filter bar */
    .filter-bar {
        display: flex; flex-wrap: wrap; gap: .6rem;
        margin-bottom: 2rem;
        background: rgba(255,255,255,.04);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        align-items: center;
    }
    .filter-bar form { display: flex; flex-wrap: wrap; gap: .6rem; width: 100%; align-items: center; }
    .filter-search {
        flex: 1; min-width: 180px;
        position: relative;
    }
    .filter-search i {
        position: absolute; left: 10px; top: 50%;
        transform: translateY(-50%); color: rgba(255,255,255,.3); font-size: .8rem;
    }
    .filter-search input {
        width: 100%; padding: .5rem .75rem .5rem 2rem;
        background: rgba(255,255,255,.06); border: 1px solid var(--border);
        border-radius: 6px; color: #fff; font-size: .82rem; font-family: 'Outfit', sans-serif;
    }
    .filter-search input::placeholder { color: rgba(255,255,255,.28); }
    .filter-search input:focus { outline: none; border-color: var(--gold); background: rgba(212,160,23,.08); }
    .filter-select {
        padding: .5rem .75rem;
        background: rgba(255,255,255,.06); border: 1px solid var(--border);
        border-radius: 6px; color: rgba(255,255,255,.75); font-size: .82rem;
        font-family: 'Outfit', sans-serif; cursor: pointer; min-width: 130px;
    }
    .filter-select:focus { outline: none; border-color: var(--gold); }
    .filter-select option { background: var(--deep2); color: #fff; }
    .filter-btn {
        display: inline-flex; align-items: center; gap: .4rem;
        background: var(--gold); color: var(--deep);
        border: none; border-radius: 6px;
        padding: .5rem 1.1rem; font-family: 'Outfit', sans-serif;
        font-size: .8rem; font-weight: 800;
        letter-spacing: .06em; text-transform: uppercase;
        cursor: pointer; transition: .2s; white-space: nowrap;
    }
    .filter-btn:hover { background: var(--gold2); }
    .filter-reset {
        font-size: .78rem; color: rgba(255,255,255,.35);
        text-decoration: none; padding: .5rem .5rem;
        white-space: nowrap; transition: color .2s;
    }
    .filter-reset:hover { color: var(--gold); }
    .filter-count {
        font-size: .75rem; color: rgba(255,255,255,.35);
        margin-left: auto; white-space: nowrap; align-self: center;
    }

    /* Open badge */
    .open-badge {
        display: inline-flex; align-items: center; gap: .4rem;
        background: rgba(32,201,151,.15); border: 1px solid rgba(32,201,151,.3);
        border-radius: 3px; padding: .3rem .75rem;
        font-size: .7rem; font-weight: 700; letter-spacing: .1em;
        text-transform: uppercase; color: #20c997; margin-bottom: 2rem;
    }

    /* Job card */
    .job-card {
        background: var(--deep2); border: 1.5px solid var(--border);
        border-radius: 7px; padding: 2rem 2rem 1.75rem;
        margin-bottom: 1.25rem;
        transition: border-color .2s, background .2s, transform .2s;
    }
    .job-card:hover { border-color: var(--gold); background: var(--deep3); transform: translateY(-2px); }
    .job-card.is-featured { border-color: rgba(212,160,23,.45); }
    .job-card.is-urgent { border-left: 3px solid #f87171; }

    .job-top {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 1.5rem; margin-bottom: 1rem;
    }
    .job-badges { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .55rem; }
    .jb {
        display: inline-flex; align-items: center; gap: .3rem;
        border-radius: 3px; padding: .2rem .6rem;
        font-size: .65rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase;
    }
    .jb-featured { background: rgba(212,160,23,.18); border: 1px solid rgba(212,160,23,.4); color: var(--gold2); }
    .jb-urgent { background: rgba(248,113,113,.15); border: 1px solid rgba(248,113,113,.35); color: #fca5a5; }
    .jb-new { background: rgba(99,179,237,.13); border: 1px solid rgba(99,179,237,.3); color: #93c5fd; }
    .jb-deadline { background: rgba(251,146,60,.13); border: 1px solid rgba(251,146,60,.3); color: #fdba74; }

    .job-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem; font-weight: 700; color: #fff; margin-bottom: .55rem;
    }
    .job-tags { display: flex; flex-wrap: wrap; gap: .45rem; }
    .job-tag {
        display: inline-flex; align-items: center; gap: .3rem;
        background: var(--gold3); border: 1px solid var(--border);
        border-radius: 3px; padding: .25rem .65rem;
        font-size: .65rem; font-weight: 700; letter-spacing: .08em;
        text-transform: uppercase; color: rgba(255,255,255,.5);
    }
    .job-tag i { color: var(--gold); font-size: .65rem; }
    .job-tag.salary-tag { background: rgba(52,211,153,.1); border-color: rgba(52,211,153,.25); color: #6ee7b7; }
    .job-tag.salary-tag i { color: #6ee7b7; }

    .job-body { border-top: 1px solid var(--border); padding-top: 1rem; margin-top: .5rem; }
    .job-body p { font-size: .83rem; color: rgba(255,255,255,.45); line-height: 1.75; margin-bottom: .4rem; }
    .job-body strong { color: rgba(255,255,255,.65); }
    .job-body-desc {
        font-size: .83rem; color: rgba(255,255,255,.4); line-height: 1.75;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }

    .job-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; flex-wrap: wrap; gap: .75rem; }
    .job-meta-sm { font-size: .72rem; color: rgba(255,255,255,.25); display: flex; gap: 1rem; flex-wrap: wrap; }
    .job-meta-sm i { color: rgba(212,160,23,.4); margin-right: 3px; }

    .job-apply-btn {
        display: inline-flex; align-items: center; gap: .45rem;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        color: var(--deep); border: none; border-radius: 5px;
        padding: .65rem 1.4rem; font-family: 'Outfit', sans-serif;
        font-size: .8rem; font-weight: 800; letter-spacing: .07em;
        text-transform: uppercase; cursor: pointer;
        transition: all .22s; white-space: nowrap;
        text-decoration: none; flex-shrink: 0;
    }
    .job-apply-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 22px rgba(212,160,23,.35);
        color: var(--deep);
    }
    .btn-detail {
        display: inline-flex; align-items: center; gap: .4rem;
        background: transparent; color: rgba(255,255,255,.45);
        border: 1px solid var(--border); border-radius: 5px;
        padding: .62rem 1rem; font-family: 'Outfit', sans-serif;
        font-size: .78rem; font-weight: 700; letter-spacing: .05em;
        text-transform: uppercase; cursor: pointer;
        transition: all .22s; white-space: nowrap;
        text-decoration: none;
    }
    .btn-detail:hover { border-color: rgba(255,255,255,.3); color: rgba(255,255,255,.75); }

    /* No result */
    .no-jobs {
        text-align: center; padding: 4rem 2rem;
        color: rgba(255,255,255,.3); font-size: .92rem;
    }
    .no-jobs i { font-size: 3rem; display: block; margin-bottom: 1rem; color: rgba(212,160,23,.25); }

    /* ── CTA ── */
    .rec-cta { background: var(--gold); padding: 5rem 3rem; text-align: center; }
    .rec-cta h2 { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; color: var(--deep); margin-bottom: 1rem; }
    .rec-cta p { font-size: .92rem; color: rgba(26,18,9,.6); margin-bottom: 2rem; }
    .rec-cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .rec-cta-primary {
        display: inline-flex; align-items: center; gap: .5rem;
        background: var(--deep); color: var(--gold2); border: none; border-radius: 5px;
        padding: .85rem 2rem; font-family: 'Outfit', sans-serif;
        font-size: .88rem; font-weight: 800; letter-spacing: .07em;
        text-transform: uppercase; text-decoration: none; transition: all .25s;
    }
    .rec-cta-primary:hover { background: var(--deep2); color: var(--gold2); transform: translateY(-2px); }
    .rec-cta-secondary {
        display: inline-flex; align-items: center; gap: .5rem;
        background: transparent; color: var(--deep);
        border: 2px solid rgba(26,18,9,.3); border-radius: 5px;
        padding: .85rem 2rem; font-family: 'Outfit', sans-serif;
        font-size: .88rem; font-weight: 700; letter-spacing: .07em;
        text-transform: uppercase; text-decoration: none; transition: all .25s;
    }
    .rec-cta-secondary:hover { border-color: var(--deep); color: var(--deep); }

    /* ── RESPONSIVE ── */
    @@media(max-width:900px) {
        .rec-hero { padding: 5rem 1.5rem 4rem; }
        .rec-section, .rec-jobs-inner { padding: 3.5rem 1.5rem; }
        .benefits-grid { grid-template-columns: repeat(2,1fr); }
        .rec-stats { flex-wrap: wrap; }
        .rst { min-width: 50%; }
        .job-top { flex-direction: column; gap: .85rem; }
        .rec-cta { padding: 4rem 1.5rem; }
    }
    @@media(max-width:540px) {
        .benefits-grid { grid-template-columns: 1fr; }
        .filter-bar form { flex-direction: column; }
        .filter-search, .filter-select { width: 100%; }
    }
</style>

<div class="rec-page">

    <!-- ══════════════════════════════════════
         HERO
    ══════════════════════════════════════ -->
    <section class="rec-hero">
        <div class="rec-deco">T</div>
        <div class="rec-eyebrow">Cơ hội nghề nghiệp</div>
        <h1>Tham Gia<br><em>Đội Ngũ Chúng Tôi.</em></h1>
        <p>Nơi đam mê thể thao gặp gỡ cơ hội phát triển sự nghiệp trong môi trường năng động và chuyên nghiệp.</p>
    </section>

    <!-- ══════════════════════════════════════
         STATS – dữ liệu thật từ DB
    ══════════════════════════════════════ -->
    <div class="rec-stats">
        <div class="rst">
            <div class="rst-n">50+</div>
            <div class="rst-l">Nhân viên</div>
        </div>
        <div class="rst">
            <div class="rst-n">5</div>
            <div class="rst-l">Chi nhánh</div>
        </div>
        <div class="rst">
            <div class="rst-n">8+</div>
            <div class="rst-l">Năm phát triển</div>
        </div>
        <div class="rst">
            <div class="rst-n">@openCount</div>
            <div class="rst-l">Vị trí đang tuyển</div>
        </div>
        <div class="rst">
            <div class="rst-n">@totalVacancy</div>
            <div class="rst-l">Chỉ tiêu tuyển dụng</div>
        </div>
    </div>

    <!-- ══════════════════════════════════════
         BENEFITS
    ══════════════════════════════════════ -->
    <div class="rec-section">
        <div class="rec-sec-eyebrow">Vì sao chọn chúng tôi</div>
        <div class="rec-sec-title">Quyền lợi hấp dẫn.</div>
        <div class="rec-sec-sub">Những lý do để bạn trở thành thành viên của BadmintonPro</div>
        <div class="benefits-grid">
            @{
                var bens = new[] {
                    new { Icon="bi-cash-stack",    Title="Lương Cạnh Tranh",       Desc="Mức lương hấp dẫn, xét tăng định kỳ theo năng lực và đóng góp." },
                    new { Icon="bi-heart-pulse",   Title="Bảo Hiểm Đầy Đủ",       Desc="BHYT, BHXH theo quy định + bảo hiểm sức khỏe cao cấp cho gia đình." },
                    new { Icon="bi-trophy-fill",   Title="Thưởng Hiệu Quả",        Desc="Thưởng KPI, tháng 13, lễ tết và các dịp đặc biệt hàng năm." },
                    new { Icon="bi-mortarboard",   Title="Đào Tạo & Phát Triển",   Desc="Chương trình đào tạo nội bộ và hỗ trợ các khóa chuyên môn bên ngoài." },
                    new { Icon="bi-people-fill",   Title="Môi Trường Năng Động",   Desc="Văn hóa trẻ trung, sáng tạo, teamwork mạnh mẽ và thân thiện." },
                    new { Icon="bi-graph-up-arrow",Title="Cơ Hội Thăng Tiến",      Desc="Lộ trình thăng tiến rõ ràng, đánh giá công bằng và minh bạch." }
                };
            }
            @foreach (var b in bens)
            {
                <div class="benefit-card">
                    <div class="benefit-icon"><i class="bi @b.Icon"></i></div>
                    <div class="benefit-title">@b.Title</div>
                    <div class="benefit-desc">@b.Desc</div>
                </div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════
         JOBS – dữ liệu thật từ DB
    ══════════════════════════════════════ -->
    <div class="rec-jobs-bg">
        <div class="rec-jobs-inner">
            <div class="rec-sec-eyebrow">Vị trí tuyển dụng</div>
            <div class="rec-sec-title">Đang tuyển dụng.</div>
            <div class="open-badge">
                <i class="bi bi-circle-fill" style="font-size:.5rem;"></i>
                @openCount vị trí đang mở · @totalVacancy chỉ tiêu
            </div>

            <!-- Filter bar -->
            <div class="filter-bar">
                <form method="get" asp-controller="Job" asp-action="Index">
                    <div class="filter-search">
                        <i class="bi bi-search"></i>
                        <input name="search" type="text" placeholder="Tìm vị trí, bộ phận..."
                               value="@qSearch" autocomplete="off" />
                    </div>

                    @if (jobTypes.Any())
                    {
                        <select name="jobType" class="filter-select">
                            <option value="">Tất cả hình thức</option>
                            @foreach (var jt in jobTypes)
                            {
                                @* Sử dụng biểu thức so sánh trực tiếp cho thuộc tính selected *@
                                <option value="@jt" selected="@(qType == jt)">@jt</option>
                            }
                        </select>
                    }

                    @if (levels.Any())
                    {
                        <select name="level" class="filter-select">
                            <option value="">Tất cả cấp độ</option>
                            @foreach (var lv in levels)
                            {
                                @* Sử dụng logic boolean trực tiếp cho thuộc tính selected *@
                                <option value="@lv" selected="@(qLevel == lv)">@lv</option>
                            }
                        </select>
                    }

                    <button type="submit" class="filter-btn">
                        <i class="bi bi-funnel"></i> Lọc
                    </button>

                    @if (!string.IsNullOrEmpty(qSearch) || !string.IsNullOrEmpty(qType) || !string.IsNullOrEmpty(qLevel))
                    {
                        <a href="@Url.Action("Index", "Job")" class="filter-reset">
                            <i class="bi bi-x-circle me-1"></i>Xóa lọc
                        </a>
                    }

                    <span class="filter-count">@openCount kết quả</span>
                </form>
            </div>

            <!-- Job list -->
            @if (!allJobs.Any())
            {
                <div class="no-jobs">
                    <i class="bi bi-briefcase"></i>
                    <div>Không tìm thấy vị trí phù hợp.</div>
                    <a href="@Url.Action("Index", "Job")" style="color:var(--gold);font-size:.82rem;margin-top:.5rem;display:inline-block;">
                        Xem tất cả vị trí →
                    </a>
                </div>
            }
            else
            {
                @foreach (var j in allJobs)
                {
                    bool isNew      = j.CreatedAt >= DateTime.Now.AddDays(-7);
                    bool nearDeadline = j.Deadline.HasValue && j.Deadline.Value.Date <= DateTime.Today.AddDays(7) && j.Deadline.Value.Date >= DateTime.Today;
                    string descPreview = j.JobDescription.Length > 200 ? j.JobDescription.Substring(0, 200) + "..." : j.JobDescription;

                    <div class="job-card @(j.IsFeatured ? "is-featured" : "") @(j.IsUrgent ? "is-urgent" : "")">
                        <div class="job-top">
                            <div style="flex:1;min-width:0;">
                                <!-- Badges -->
                                <div class="job-badges">
                                    @if (j.IsFeatured)
                                    {
                                        <span class="jb jb-featured"><i class="bi bi-star-fill"></i> Nổi bật</span>
                                    }
                                    @if (j.IsUrgent)
                                    {
                                        <span class="jb jb-urgent"><i class="bi bi-lightning-fill"></i> Tuyển gấp</span>
                                    }
                                    @if (isNew)
                                    {
                                        <span class="jb jb-new"><i class="bi bi-clock-history"></i> Mới đăng</span>
                                    }
                                    @if (nearDeadline)
                                    {
                                        <span class="jb jb-deadline"><i class="bi bi-alarm"></i> Sắp hết hạn</span>
                                    }
                                </div>

                                <div class="job-name">@j.JobTitle</div>

                                <div class="job-tags">
                                    @if (!string.IsNullOrEmpty(j.Department))
                                    {
                                        <span class="job-tag"><i class="bi bi-briefcase"></i> @j.Department</span>
                                    }
                                    @if (!string.IsNullOrEmpty(j.Location))
                                    {
                                        <span class="job-tag"><i class="bi bi-geo-alt"></i> @j.Location</span>
                                    }
                                    @if (!string.IsNullOrEmpty(j.JobType))
                                    {
                                        <span class="job-tag"><i class="bi bi-clock"></i> @j.JobType</span>
                                    }
                                    @if (!string.IsNullOrEmpty(j.Level))
                                    {
                                        <span class="job-tag"><i class="bi bi-diagram-3"></i> @j.Level</span>
                                    }
                                    @{
                                        string salaryText = "";
                                        if (j.SalaryType == "Negotiable") salaryText = "Thương lượng";
                                        else if (j.SalaryType == "Competitive") salaryText = "Cạnh tranh";
                                        else if (j.SalaryMin.HasValue && j.SalaryMax.HasValue)
                                            salaryText = $"{j.SalaryMin.Value/1000000:0.#}M – {j.SalaryMax.Value/1000000:0.#}M";
                                        else if (j.SalaryMin.HasValue)
                                            salaryText = $"Từ {j.SalaryMin.Value/1000000:0.#}M";
                                        else if (j.SalaryMax.HasValue)
                                            salaryText = $"Đến {j.SalaryMax.Value/1000000:0.#}M";
                                    }
                                    @if (!string.IsNullOrEmpty(salaryText))
                                    {
                                        <span class="job-tag salary-tag"><i class="bi bi-cash-coin"></i> @salaryText</span>
                                    }
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div style="display:flex;flex-direction:column;gap:.5rem;flex-shrink:0;">
                                <a href="@Url.Action("Detail", "Job", new { id = j.JobId })" class="job-apply-btn">
                                    <i class="bi bi-send"></i> Ứng tuyển
                                </a>
                                <a href="@Url.Action("Detail", "Job", new { id = j.JobId })" class="btn-detail">
                                    <i class="bi bi-eye"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>

                        <div class="job-body">
                            <div class="job-body-desc">@descPreview</div>
                            <div class="job-footer">
                                <div class="job-meta-sm">
                                    <span><i class="bi bi-people"></i>@j.VacancyCount vị trí</span>
                                    @if (j.Deadline.HasValue)
                                    {
                                        <span><i class="bi bi-calendar-x"></i>Hạn: @j.Deadline.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    <span><i class="bi bi-eye"></i>@j.ViewCount lượt xem</span>
                                    <span><i class="bi bi-clock"></i>@j.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

        </div>
    </div>

    <!-- ══════════════════════════════════════
         CTA
    ══════════════════════════════════════ -->
    <div class="rec-cta">
        <h2>Sẵn sàng gia nhập?</h2>
        <p>Gửi CV của bạn hoặc liên hệ trực tiếp để biết thêm thông tin về các vị trí đang tuyển.</p>
        <div class="rec-cta-btns">
            <a href="mailto:careers@badmintonpro.vn" class="rec-cta-primary">
                <i class="bi bi-envelope-fill"></i> Gửi CV qua Email
            </a>
            <a asp-controller="Home" asp-action="Contact" class="rec-cta-secondary">
                <i class="bi bi-telephone"></i> Liên hệ với HR
            </a>
        </div>
        <p style="font-size:.8rem;color:rgba(26,18,9,.45);margin-top:1.25rem;">Hotline: (028) 1234 5678</p>
    </div>

</div>
