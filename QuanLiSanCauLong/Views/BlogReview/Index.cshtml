@model QuanLiSanCauLong.ViewModels.BlogReviewPageViewModel
@{
    ViewData["Title"] = $"Đánh Giá - {Model.BlogTitle}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --gold: #d4a017;
        --gold2: #f5c842;
        --deep: #1a1209;
        --cream: #fdf8f0;
        --warm: #f5efe0;
        --border: #e8ddc8;
        --muted: #8a7560;
    }

    .br-page {
        background: var(--cream);
        font-family: 'Outfit', sans-serif;
        color: var(--deep);
        min-height: 100vh;
    }

    /* ── HERO ─────────────────────────────────────── */
    .br-hero {
        background: var(--deep);
        position: relative;
        overflow: hidden;
        padding: 5rem 0 0;
    }

        .br-hero::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -100px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(212,160,23,.08) 0%, transparent 65%);
            pointer-events: none;
        }

    .br-hero-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 4rem;
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 4rem;
        align-items: end;
        padding-bottom: 3rem;
    }

    .br-hero-overline {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .br-hero-overline-line {
        width: 40px;
        height: 1px;
        background: var(--gold);
    }

    .br-hero-overline span {
        font-size: .72rem;
        letter-spacing: .22em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 500;
    }

    .br-hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        font-weight: 900;
        color: #fff;
        line-height: .95;
        margin-bottom: 1.25rem;
    }

        .br-hero-title em {
            font-style: italic;
            color: var(--gold2);
        }

    .br-hero-blog {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1px solid rgba(255,255,255,.12);
        padding: .5rem 1rem;
        border-radius: 3px;
        font-size: .82rem;
        color: rgba(255,255,255,.5);
        font-weight: 300;
    }

        .br-hero-blog i {
            color: var(--gold);
        }

    /* Score panel in hero right */
    .br-score-panel {
        text-align: center;
        padding: 2rem 2.5rem;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 6px;
        backdrop-filter: blur(8px);
        min-width: 200px;
    }

    .bsp-num {
        font-family: 'Playfair Display', serif;
        font-size: 5.5rem;
        font-weight: 900;
        color: var(--gold2);
        line-height: 1;
    }

    .bsp-stars {
        display: flex;
        justify-content: center;
        gap: .2rem;
        color: var(--gold);
        font-size: 1rem;
        margin: .6rem 0;
    }

    .bsp-total {
        font-size: .75rem;
        color: rgba(255,255,255,.35);
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .bsp-write {
        display: flex;
        align-items: center;
        gap: .5rem;
        justify-content: center;
        margin-top: 1.25rem;
        background: var(--gold);
        color: var(--deep);
        border: none;
        padding: .7rem 1.5rem;
        font-family: 'Outfit', sans-serif;
        font-size: .8rem;
        font-weight: 700;
        border-radius: 3px;
        cursor: pointer;
        transition: all .25s;
        width: 100%;
    }

        .bsp-write:hover {
            background: var(--gold2);
            transform: translateY(-1px);
        }

    /* Rating bars strip below hero */
    .br-bars-strip {
        background: #fff;
        border-bottom: 1px solid var(--border);
    }

    .br-bars-inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.5rem 4rem;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    .brs-bar-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .45rem;
    }

    .brs-bar-label {
        font-size: .72rem;
        width: 10px;
        color: var(--muted);
        text-align: right;
        flex-shrink: 0;
    }

    .brs-bar-track {
        flex: 1;
        height: 6px;
        background: var(--warm);
        border-radius: 3px;
        overflow: hidden;
    }

    .brs-bar-fill {
        height: 100%;
        background: var(--gold);
        border-radius: 3px;
        transition: width .8s;
    }

    .brs-bar-count {
        font-size: .7rem;
        color: var(--muted);
        width: 22px;
    }

    .brs-reactions-row {
        display: flex;
        gap: .75rem;
    }

    .react-chip {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .3rem;
        padding: .75rem .5rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 4px;
        text-align: center;
    }

    .react-chip-emoji {
        font-size: 1.4rem;
        line-height: 1;
    }

    .react-chip-n {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--deep);
    }

    .react-chip-l {
        font-size: .65rem;
        color: var(--muted);
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .brs-write-cta {
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .brs-write-cta-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--deep);
    }

    .brs-write-cta-sub {
        font-size: .78rem;
        color: var(--muted);
        font-weight: 300;
    }

    .brs-write-btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: var(--deep);
        color: var(--gold2);
        border: none;
        padding: .6rem 1.25rem;
        font-family: 'Outfit', sans-serif;
        font-size: .78rem;
        font-weight: 700;
        border-radius: 3px;
        cursor: pointer;
        transition: all .2s;
        width: fit-content;
        margin-top: .25rem;
    }

        .brs-write-btn:hover {
            background: var(--gold);
            color: var(--deep);
        }

    /* ── BODY ─────────────────────────────────────── */
    .br-body {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 4rem 6rem;
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 2.5rem;
        align-items: start;
    }

    /* Sidebar */
    .br-sidebar {
        position: sticky;
        top: 80px;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .sb-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 5px;
        overflow: hidden;
    }

    .sb-head {
        padding: .75rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--warm);
    }

    .sb-body {
        padding: .6rem;
    }

    .sf-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .4rem .6rem;
        border-radius: 3px;
        cursor: pointer;
        transition: background .15s;
        margin-bottom: .15rem;
    }

        .sf-row:hover {
            background: var(--warm);
        }

        .sf-row.active {
            background: rgba(212,160,23,.1);
            border: 1px solid rgba(212,160,23,.25);
        }

    .sf-stars {
        display: flex;
        gap: .1rem;
        font-size: .65rem;
        color: var(--gold);
    }

    .sf-bar-mini {
        flex: 1;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
    }

    .sf-bar-fill {
        height: 100%;
        background: var(--gold);
    }

    .sf-cnt {
        font-size: .68rem;
        color: var(--muted);
        width: 20px;
        text-align: right;
    }

    .sort-opt {
        padding: .45rem .75rem;
        border-radius: 3px;
        cursor: pointer;
        font-size: .8rem;
        font-weight: 500;
        color: var(--muted);
        transition: all .15s;
    }

        .sort-opt:hover {
            background: var(--warm);
            color: var(--deep);
        }

        .sort-opt.active {
            background: var(--deep);
            color: var(--gold2);
            border-radius: 3px;
        }

    /* Review list */
    .sort-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
    }

    .sort-count {
        font-size: .85rem;
        color: var(--muted);
    }

        .sort-count strong {
            color: var(--deep);
            font-weight: 700;
        }

    /* Pinned */
    .pinned-label {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .75rem;
    }

        .pinned-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(212,160,23,.2);
        }

    /* Review card */
    .rv-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 1.5rem;
        margin-bottom: .75rem;
        transition: box-shadow .25s;
        position: relative;
    }

        .rv-card:hover {
            box-shadow: 0 4px 18px rgba(26,18,9,.07);
        }

        .rv-card.pinned {
            border-color: rgba(212,160,23,.35);
            background: rgba(253,248,240,.6);
        }

            .rv-card.pinned::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, var(--gold), var(--gold2));
                border-radius: 5px 5px 0 0;
            }

    .rv-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: .9rem;
    }

    .rv-user {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .rv-av {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        flex-shrink: 0;
        font-family: 'Playfair Display', serif;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: .95rem;
    }

        .rv-av.guest {
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            color: var(--deep);
        }

        .rv-av.member {
            background: linear-gradient(135deg, var(--deep), #3d2a10);
            color: var(--gold2);
        }

    .rv-name {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
        line-height: 1.2;
    }

    .rv-meta {
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-top: .2rem;
        flex-wrap: wrap;
    }

    .rv-member-badge {
        background: rgba(212,160,23,.12);
        color: #92660a;
        font-size: .6rem;
        font-weight: 700;
        padding: .1rem .45rem;
        border-radius: 2px;
        letter-spacing: .04em;
    }

    .rv-time {
        font-size: .7rem;
        color: var(--muted);
    }

    .rv-reaction {
        font-size: .68rem;
        color: var(--muted);
        background: var(--warm);
        padding: .1rem .5rem;
        border-radius: 2px;
    }

    .rv-right {
        text-align: right;
        flex-shrink: 0;
    }

    .rv-stars {
        display: flex;
        gap: .1rem;
        justify-content: flex-end;
    }

        .rv-stars .f {
            color: var(--gold);
            font-size: .82rem;
        }

        .rv-stars .e {
            color: #d4ccc0;
            font-size: .82rem;
        }

    .rv-score {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--gold);
        margin-top: .15rem;
    }

    .rv-content {
        font-size: .88rem;
        line-height: 1.8;
        color: #4a3520;
        font-weight: 300;
        margin-bottom: 1rem;
    }

    .rv-reply {
        background: var(--warm);
        border-left: 3px solid var(--gold);
        padding: .8rem 1rem;
        border-radius: 0 4px 4px 0;
        margin-bottom: .9rem;
    }

    .rv-reply-head {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .72rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .3rem;
    }

        .rv-reply-head i {
            color: var(--gold);
        }

    .rv-reply-text {
        font-size: .82rem;
        color: #4a3520;
        font-weight: 300;
        line-height: 1.7;
    }

    .rv-bottom {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding-top: .8rem;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
    }

    .rv-helpful-label {
        font-size: .74rem;
        color: var(--muted);
    }

    .vote-btn {
        display: flex;
        align-items: center;
        gap: .3rem;
        padding: .3rem .75rem;
        border: 1px solid var(--border);
        border-radius: 3px;
        background: none;
        font-size: .74rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        font-family: 'Outfit', sans-serif;
    }

        .vote-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        .vote-btn.voted {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.07);
        }

        .vote-btn.disliked {
            border-color: #c94b2a;
            color: #c94b2a;
            background: rgba(201,75,42,.05);
        }

    .report-btn {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .7rem;
        color: var(--muted);
        cursor: pointer;
        background: none;
        border: none;
        font-family: 'Outfit', sans-serif;
        transition: color .2s;
    }

        .report-btn:hover {
            color: #c94b2a;
        }

    /* Load more */
    .load-more {
        display: block;
        width: 100%;
        padding: .9rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        text-align: center;
        transition: all .2s;
        margin-top: .75rem;
    }

        .load-more:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

    /* Empty */
    .rv-empty {
        text-align: center;
        padding: 4rem 2rem;
    }

        .rv-empty i {
            font-size: 3.5rem;
            color: rgba(26,18,9,.1);
            display: block;
            margin-bottom: 1.25rem;
        }

        .rv-empty h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--deep);
            margin-bottom: .5rem;
        }

        .rv-empty p {
            font-size: .86rem;
            color: var(--muted);
            font-weight: 300;
        }

    /* ── WRITE MODAL ──────────────────────────────── */
    .wr-overlay {
        position: fixed;
        inset: 0;
        background: rgba(26,18,9,.88);
        backdrop-filter: blur(14px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

        .wr-overlay.open {
            display: flex;
        }

    .wr-modal {
        background: var(--cream);
        width: 100%;
        max-width: 520px;
        border-radius: 6px;
        overflow: hidden;
        animation: wrIn .35s cubic-bezier(.25,.46,.45,.94);
    }

    @@keyframes wrIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .wr-head {
        background: var(--deep);
        padding: 1.75rem 2rem;
        position: relative;
        border-top: 2px solid var(--gold);
    }

    .wr-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: .2rem;
    }

    .wr-sub {
        font-size: .78rem;
        color: rgba(255,255,255,.4);
    }

    .wr-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(255,255,255,.1);
        border: none;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
    }

        .wr-close:hover {
            background: rgba(255,255,255,.2);
        }

    .wr-body {
        padding: 1.75rem 2rem;
        max-height: 70vh;
        overflow-y: auto;
    }

    .wf-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: .45rem;
    }

        .wf-label .req {
            color: #c94b2a;
        }

    .wf-input {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: .7rem .9rem;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .wf-input:focus {
            border-color: var(--gold);
        }

        .wf-input.error {
            border-color: #c94b2a;
        }

    .wf-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .wf-row {
        margin-bottom: 1rem;
    }

    .sp-star {
        font-size: 2rem;
        color: var(--border);
        cursor: pointer;
        transition: all .15s;
        line-height: 1;
    }

        .sp-star.lit {
            color: var(--gold);
            transform: scale(1.12);
        }

    .react-opt {
        padding: .4rem .85rem;
        border: 1px solid var(--border);
        border-radius: 3px;
        font-size: .76rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit', sans-serif;
    }

        .react-opt:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        .react-opt.selected {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.08);
        }

    .val-msg {
        font-size: .72rem;
        color: #c94b2a;
        margin-top: .3rem;
        display: none;
    }

    .wr-submit {
        width: 100%;
        background: var(--gold);
        color: var(--deep);
        border: none;
        padding: .9rem;
        font-family: 'Outfit', sans-serif;
        font-size: .88rem;
        font-weight: 700;
        border-radius: 3px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: all .25s;
        margin-top: 1.25rem;
    }

        .wr-submit:hover {
            background: var(--gold2);
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .wr-success {
        text-align: center;
        padding: 2.5rem 2rem;
    }

    .wr-success-icon {
        font-size: 3.5rem;
        color: var(--gold);
        margin-bottom: .75rem;
    }

    .wr-success-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .5rem;
    }

    .wr-success-text {
        font-size: .86rem;
        color: var(--muted);
        line-height: 1.7;
    }

    @@media (max-width: 900px) {
        .br-hero-inner {
            grid-template-columns: 1fr;
            gap: 2rem;
            padding: 0 2rem 2rem;
        }

        .br-score-panel {
            display: none;
        }

        .br-bars-inner {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            padding: 1.5rem 2rem;
        }

        .br-body {
            grid-template-columns: 1fr;
            padding: 2rem 1.5rem 4rem;
        }

        .br-sidebar {
            position: static;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 580px) {
        .br-sidebar {
            grid-template-columns: 1fr;
        }

        .brs-reactions-row {
            flex-wrap: wrap;
        }
    }
</style>

<div class="br-page">

    <!-- HERO -->
    <div class="br-hero">
        <div class="br-hero-inner">
            <div>
                <div class="br-hero-overline">
                    <div class="br-hero-overline-line"></div>
                    <span>Đánh giá bài viết</span>
                </div>
                <h1 class="br-hero-title">
                    Cộng đồng<br /><em>nhận xét.</em>
                </h1>
                <div class="br-hero-blog">
                    <i class="bi bi-newspaper"></i>
                    @Model.BlogTitle
                </div>
            </div>
            <div class="br-score-panel">
                <div class="bsp-num">@Model.AverageRating.ToString("F1")</div>
                <div class="bsp-stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        double f = Model.AverageRating - i + 1;
                        <i class="bi @(f >= 1 ? "bi-star-fill" : f >= 0.5 ? "bi-star-half" : "bi-star")"></i>
                    }
                </div>
                <div class="bsp-total">@Model.ApprovedCount đánh giá</div>
                <button class="bsp-write" onclick="openWriteModal()">
                    <i class="bi bi-pencil-square"></i> Viết đánh giá
                </button>
            </div>
        </div>
    </div>

    <!-- BARS STRIP -->
    <div class="br-bars-strip">
        <div class="br-bars-inner">
            <!-- Rating bars -->
            <div>
                @for (int s = 5; s >= 1; s--)
                {
                    <div class="brs-bar-row">
                        <span class="brs-bar-label">@s</span>
                        <i class="bi bi-star-fill" style="font-size:.6rem;color:var(--gold);flex-shrink:0;"></i>
                        <div class="brs-bar-track">
                            <div class="brs-bar-fill" style="width:@Model.StarPercent(s)%"></div>
                        </div>
                        <span class="brs-bar-count">@Model.StarDistribution.GetValueOrDefault(s, 0)</span>
                    </div>
                }
            </div>
            <!-- Reactions -->
            <div class="brs-reactions-row">
                <div class="react-chip">
                    <div class="react-chip-emoji">💡</div>
                    <div class="react-chip-n">@Model.HelpfulCount</div>
                    <div class="react-chip-l">Hữu ích</div>
                </div>
                <div class="react-chip">
                    <div class="react-chip-emoji">🔍</div>
                    <div class="react-chip-n">@Model.InsightfulCount</div>
                    <div class="react-chip-l">Sâu sắc</div>
                </div>
                <div class="react-chip">
                    <div class="react-chip-emoji">✍️</div>
                    <div class="react-chip-n">@Model.WellWrittenCount</div>
                    <div class="react-chip-l">Viết tốt</div>
                </div>
            </div>
            <!-- Write CTA -->
            <div class="brs-write-cta">
                <div class="brs-write-cta-title">Bạn đã đọc bài này?</div>
                <div class="brs-write-cta-sub">Chia sẻ cảm nhận để giúp cộng đồng lựa chọn nội dung phù hợp.</div>
                <button class="brs-write-btn" onclick="openWriteModal()">
                    <i class="bi bi-pencil-square"></i> Viết đánh giá
                </button>
            </div>
        </div>
    </div>

    <!-- BODY: SIDEBAR + REVIEWS -->
    <div class="br-body">

        <!-- SIDEBAR -->
        <div class="br-sidebar">
            <div class="sb-card">
                <div class="sb-head">Lọc theo sao</div>
                <div class="sb-body">
                    <div class="sf-row active" onclick="setFilter(null, this)">
                        <div class="sf-stars">★★★★★</div>
                        <span style="font-size:.73rem;color:var(--muted);flex:1;">Tất cả</span>
                        <span class="sf-cnt">@Model.ApprovedCount</span>
                    </div>
                    @for (int s = 5; s >= 1; s--)
                    {
                        <div class="sf-row" onclick="setFilter(@s, this)">
                            <div class="sf-stars">@(new string('★', s))</div>
                            <div class="sf-bar-mini"><div class="sf-bar-fill" style="width:@Model.StarPercent(s)%"></div></div>
                            <span class="sf-cnt">@Model.StarDistribution.GetValueOrDefault(s, 0)</span>
                        </div>
                    }
                </div>
            </div>
            <div class="sb-card">
                <div class="sb-head">Sắp xếp</div>
                <div class="sb-body">
                    <div class="sort-opt active" onclick="setSort('newest', this)">Mới nhất</div>
                    <div class="sort-opt" onclick="setSort('oldest', this)">Cũ nhất</div>
                    <div class="sort-opt" onclick="setSort('highest', this)">Sao cao nhất</div>
                    <div class="sort-opt" onclick="setSort('lowest', this)">Sao thấp nhất</div>
                    <div class="sort-opt" onclick="setSort('helpful', this)">Hữu ích nhất</div>
                </div>
            </div>
        </div>

        <!-- REVIEWS -->
        <div>
            <div class="sort-bar">
                <div class="sort-count">
                    Hiển thị <strong>@Model.Reviews.Count</strong> trong <strong>@Model.ApprovedCount</strong> đánh giá
                </div>
            </div>

            @if (Model.FeaturedReviews.Any())
            {
                <div style="margin-bottom:1.5rem;">
                    <div class="pinned-label"><i class="bi bi-pin-angle-fill"></i> Đánh giá nổi bật</div>
                    @foreach (var r in Model.FeaturedReviews)
                    {
                        <div class="rv-card pinned">
                            @await Html.PartialAsync("_ReviewCard", r)
                        </div>
                    }
                </div>
            }

            <div id="reviewList">
                @foreach (var r in Model.Reviews.Where(r => !r.IsPinned))
                {
                    <div class="rv-card" id="rcard-@r.ReviewId">
                        @await Html.PartialAsync("_ReviewCard", r)
                    </div>
                }
            </div>

            @if (!Model.Reviews.Any())
            {
                <div class="rv-empty">
                    <i class="bi bi-chat-square-text"></i>
                    <h4>Chưa có đánh giá nào</h4>
                    <p>Hãy là người đầu tiên chia sẻ cảm nhận về bài viết này.</p>
                </div>
            }

            @if (Model.HasMoreReviews)
            {
                <button class="load-more" id="loadMoreBtn"
                        onclick="loadMore(@Model.BlogId, @(Model.CurrentPage + 1), '@Model.SortBy', @(Model.FilterRating?.ToString() ?? "null"))">
                    <i class="bi bi-arrow-down-circle me-1"></i> Xem thêm đánh giá
                </button>
            }
        </div>

    </div>
</div>

<!-- WRITE MODAL -->
<div class="wr-overlay" id="writeModal" onclick="closeWriteModal(event)">
    <div class="wr-modal">
        <div class="wr-head">
            <div class="wr-title">Viết đánh giá</div>
            <div class="wr-sub">@Model.BlogTitle</div>
            <button class="wr-close" onclick="document.getElementById('writeModal').classList.remove('open');document.body.style.overflow=''">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="wr-body">
            <div id="writeFormBody">
                <input type="hidden" id="wf-blogId" value="@Model.BlogId" />
                <div class="wf-row">
                    <label class="wf-label">Đánh giá của bạn <span class="req">*</span></label>
                    <div id="starPicker" class="d-flex gap-1" style="gap:.3rem;display:flex;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="sp-star" data-val="@i">★</span>
                        }
                    </div>
                    <div class="val-msg" id="err-rating">Vui lòng chọn số sao</div>
                </div>
                <div class="wf-row">
                    <label class="wf-label">Cảm nhận <span style="font-weight:300;text-transform:none;letter-spacing:0;">(tuỳ chọn)</span></label>
                    <div class="d-flex gap-2 flex-wrap" style="display:flex;gap:.5rem;flex-wrap:wrap;">
                        <button class="react-opt" data-val="helpful" onclick="toggleReaction(this)">💡 Hữu ích</button>
                        <button class="react-opt" data-val="insightful" onclick="toggleReaction(this)">🔍 Sâu sắc</button>
                        <button class="react-opt" data-val="wellwritten" onclick="toggleReaction(this)">✍️ Viết tốt</button>
                    </div>
                </div>
                <div class="wf-row">
                    <label class="wf-label">Tên của bạn <span class="req">*</span></label>
                    <input type="text" class="wf-input" id="wf-name" placeholder="Nhập tên hiển thị..." />
                    <div class="val-msg" id="err-name">Vui lòng nhập tên</div>
                </div>
                <div class="wf-row">
                    <label class="wf-label">Email <span style="font-weight:300;text-transform:none;letter-spacing:0;">(tuỳ chọn)</span></label>
                    <input type="email" class="wf-input" id="wf-email" placeholder="email@example.com" />
                </div>
                <div class="wf-row">
                    <label class="wf-label">Nội dung đánh giá <span class="req">*</span></label>
                    <textarea class="wf-input wf-textarea" id="wf-content"
                              placeholder="Chia sẻ cảm nhận của bạn... (ít nhất 10 ký tự)"
                              maxlength="2000" oninput="updateCharCount(this)"></textarea>
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:.25rem;">
                        <div class="val-msg" id="err-content" style="position:static;display:inline;">Nội dung phải có ít nhất 10 ký tự</div>
                        <span style="font-size:.7rem;color:var(--muted);" id="charCount">0 / 2000</span>
                    </div>
                </div>
                <button class="wr-submit" onclick="submitReview()">
                    <i class="bi bi-send-fill"></i> Gửi đánh giá
                </button>
            </div>
            <div class="wr-success" id="writeSuccess" style="display:none;">
                <div class="wr-success-icon"><i class="bi bi-check-circle-fill"></i></div>
                <div class="wr-success-title">Cảm ơn bạn!</div>
                <div class="wr-success-text">Đánh giá đã được gửi thành công.<br />Sẽ hiển thị sau khi được kiểm duyệt.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedRating   = 0;
        let selectedReaction = '';
        let currentSort      = '@Model.SortBy';
        let currentFilter    = @(Model.FilterRating?.ToString() ?? "null");
        let isLoading        = false;

        // STAR PICKER
        const stars = document.querySelectorAll('.sp-star');
        stars.forEach(s => {
            s.addEventListener('mouseover', () => {
                const v = +s.dataset.val;
                stars.forEach(st => st.classList.toggle('lit', +st.dataset.val <= v));
            });
            s.addEventListener('click', () => {
                selectedRating = +s.dataset.val;
                stars.forEach(st => st.classList.toggle('lit', +st.dataset.val <= selectedRating));
            });
        });
        document.getElementById('starPicker').addEventListener('mouseleave', () => {
            stars.forEach(st => st.classList.toggle('lit', +st.dataset.val <= selectedRating));
        });

        // REACTION
        function toggleReaction(el) {
            const val = el.dataset.val;
            document.querySelectorAll('.react-opt').forEach(r => r.classList.remove('selected'));
            selectedReaction = (selectedReaction === val) ? '' : val;
            if (selectedReaction) el.classList.add('selected');
        }

        // MODAL
        function openWriteModal() {
            document.getElementById('writeModal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeWriteModal(e) {
            if (e.target === document.getElementById('writeModal')) {
                document.getElementById('writeModal').classList.remove('open');
                document.body.style.overflow = '';
            }
        }
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                document.getElementById('writeModal').classList.remove('open');
                document.body.style.overflow = '';
            }
        });

        function updateCharCount(el) {
            document.getElementById('charCount').textContent = el.value.length + ' / 2000';
        }

        // VALIDATE
        function validate() {
            let ok = true;
            document.getElementById('err-rating').style.display  = !selectedRating ? 'block' : 'none';
            if (!selectedRating) ok = false;
            const name = document.getElementById('wf-name').value.trim();
            document.getElementById('err-name').style.display = !name ? 'block' : 'none';
            document.getElementById('wf-name').classList.toggle('error', !name);
            if (!name) ok = false;
            const content = document.getElementById('wf-content').value.trim();
            const badContent = content.length < 10;
            document.getElementById('err-content').style.display = badContent ? 'block' : 'none';
            document.getElementById('wf-content').classList.toggle('error', badContent);
            if (badContent) ok = false;
            return ok;
        }

        // SUBMIT
        async function submitReview() {
            if (!validate()) return;
            const btn = document.querySelector('.wr-submit');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang gửi...';
            try {
                const fd = new FormData();
                fd.append('BlogId',        document.getElementById('wf-blogId').value);
                fd.append('ReviewerName',  document.getElementById('wf-name').value.trim());
                fd.append('ReviewerEmail', document.getElementById('wf-email').value.trim());
                fd.append('Content',       document.getElementById('wf-content').value.trim());
                fd.append('Rating',        selectedRating);
                fd.append('Reaction',      selectedReaction);
                fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
                const res  = await fetch('/BlogReview/Submit', { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('writeFormBody').style.display = 'none';
                    document.getElementById('writeSuccess').style.display  = 'block';
                    setTimeout(() => {
                        document.getElementById('writeModal').classList.remove('open');
                        document.body.style.overflow = '';
                        document.getElementById('writeFormBody').style.display = 'block';
                        document.getElementById('writeSuccess').style.display  = 'none';
                    }, 2800);
                } else {
                    alert(data.message || 'Có lỗi xảy ra. Vui lòng thử lại.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send-fill"></i> Gửi đánh giá';
                }
            } catch {
                alert('Lỗi kết nối. Vui lòng thử lại.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-send-fill"></i> Gửi đánh giá';
            }
        }

        // VOTE
        async function vote(reviewId, isLike) {
            const fd = new FormData();
            fd.append('reviewId', reviewId);
            fd.append('isLike',   isLike);
            fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
            const res  = await fetch('/BlogReview/Like', { method: 'POST', body: fd });
            const data = await res.json();
            if (data.success) {
                const card = document.getElementById('rcard-' + reviewId);
                const likeBtn = card?.querySelector('.like-btn');
                const disBtn  = card?.querySelector('.dislike-btn');
                if (likeBtn) { likeBtn.innerHTML = `<i class="bi bi-hand-thumbs-up${data.liked ? '-fill' : ''}"></i> ${data.likes}`; likeBtn.classList.toggle('voted', data.liked); }
                if (disBtn)  { disBtn.innerHTML  = `<i class="bi bi-hand-thumbs-down${data.disliked ? '-fill' : ''}"></i> ${data.dislikes}`; disBtn.classList.toggle('disliked', data.disliked); }
            }
        }

        // REPORT
        async function report(reviewId) {
            if (!confirm('Báo cáo đánh giá này là không phù hợp?')) return;
            const fd = new FormData();
            fd.append('reviewId', reviewId);
            fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
            const res  = await fetch('/BlogReview/Report', { method: 'POST', body: fd });
            const data = await res.json();
            if (data.success) alert(data.message);
        }

        // FILTER / SORT
        function setFilter(rating, el) {
            document.querySelectorAll('.sf-row').forEach(r => r.classList.remove('active'));
            el.classList.add('active');
            currentFilter = rating;
            reloadReviews();
        }
        function setSort(sort, el) {
            document.querySelectorAll('.sort-opt').forEach(s => s.classList.remove('active'));
            el.classList.add('active');
            currentSort = sort;
            reloadReviews();
        }
        async function reloadReviews() {
            const qs = new URLSearchParams({ blogId: @Model.BlogId, page: 1, sort: currentSort });
            if (currentFilter) qs.set('filterRating', currentFilter);
            const res  = await fetch('/BlogReview/LoadMore?' + qs, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            document.getElementById('reviewList').innerHTML = await res.text();
        }

        // LOAD MORE
        async function loadMore(blogId, page, sort, filterRating) {
            if (isLoading) return;
            isLoading = true;
            const btn = document.getElementById('loadMoreBtn');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang tải...';
            const qs = new URLSearchParams({ blogId, page, sort });
            if (filterRating) qs.set('filterRating', filterRating);
            const res  = await fetch('/BlogReview/LoadMore?' + qs, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const html = await res.text();
            const div  = document.createElement('div');
            div.innerHTML = html;
            document.getElementById('reviewList').insertAdjacentHTML('beforeend', div.querySelector('#reviewList')?.innerHTML || html);
            btn.remove();
            isLoading = false;
        }
    </script>
    @Html.AntiForgeryToken()
}
