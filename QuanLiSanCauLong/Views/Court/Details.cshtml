@{
    ViewData["Title"] = "Chi tiết sân";
}

@if (ViewBag.Court == null)
{
    <div style="max-width:600px;margin:4rem auto;text-align:center;padding:2rem;background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,.07)">
        <div style="font-size:3rem;margin-bottom:1rem">🏸</div>
        <h2 style="font-size:1.4rem;font-weight:700;color:#1a1209;margin-bottom:.5rem">Không tìm thấy thông tin sân</h2>
        <p style="color:#6b5744;font-size:.92rem;margin-bottom:1.5rem">Sân bạn tìm kiếm không tồn tại hoặc đã bị xoá.</p>
        <a href="/Facility" style="display:inline-block;padding:.75rem 2rem;background:linear-gradient(135deg,#d4a017,#f5c842);color:#1a1209;font-weight:700;border-radius:8px;text-decoration:none">
            <i class="bi bi-house me-1"></i> Về trang chủ
        </a>
    </div>
    return;
}

@{
    var court = ViewBag.Court;
    var facility = court.Facility;
    var images = ViewBag.CourtImages as List<string> ?? new List<string>();
    var priceSlots = ViewBag.PriceSlots as List<dynamic> ?? new List<dynamic>();
    var reviews = ViewBag.Reviews as List<dynamic> ?? new List<dynamic>();
    double avgRating = ViewBag.AverageRating ?? 0.0;
    int reviewCount = ViewBag.ReviewCount ?? 0;
    // Nếu chỉ có ImagePath trên court, thêm vào đầu list
    string primaryImg = court.ImagePath as string ?? "";
    if (!string.IsNullOrEmpty(primaryImg) && !images.Contains(primaryImg))
        images.Insert(0, primaryImg);
}

<style>
    :root {
        --cream: #f5ede0;
        --dark: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --green: #10b981;
        --red: #ef4444;
        --muted: #8c7a68;
        --card: #ffffff;
        --radius: 16px;
    }

    body {
        background: var(--cream);
        font-family: 'Outfit', sans-serif;
    }

    /* ── LAYOUT ── */
    .detail-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
    }

    /* ── GALLERY ── */
    .gallery-wrap {
        position: relative;
        border-radius: var(--radius);
        overflow: hidden;
        background: #111;
        aspect-ratio: 16/7;
        max-height: 480px;
        margin-bottom: 1.5rem;
    }

    .gallery-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity .45s ease;
    }

        .gallery-slide.active {
            opacity: 1;
        }

        .gallery-slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .gallery-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0,0,0,.5);
        border: none;
        color: #fff;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
        z-index: 5;
    }

        .gallery-nav:hover {
            background: rgba(0,0,0,.8);
        }

        .gallery-nav.prev {
            left: 14px;
        }

        .gallery-nav.next {
            right: 14px;
        }

    .gallery-dots {
        position: absolute;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 6px;
        z-index: 5;
    }

    .gallery-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,.45);
        cursor: pointer;
        border: none;
        transition: background .2s, transform .2s;
    }

        .gallery-dot.active {
            background: var(--gold2);
            transform: scale(1.3);
        }

    .gallery-thumbs {
        display: flex;
        gap: 8px;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 4px;
        margin-bottom: 1.5rem;
        scrollbar-width: thin;
    }

    .gallery-thumb {
        flex-shrink: 0;
        width: 90px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color .2s, opacity .2s;
        opacity: .6;
    }

        .gallery-thumb.active {
            border-color: var(--gold);
            opacity: 1;
        }

        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* ── TITLE ROW ── */
    .court-title {
        font-size: 1.9rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: .3rem;
    }

    .court-sub {
        color: var(--muted);
        font-size: .92rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* ── BADGE ── */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .28rem .75rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .04em;
    }

    .badge-indoor {
        background: #fff3cd;
        color: #856404;
    }

    .badge-outdoor {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-avail {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-busy {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-star {
        background: #fef3c7;
        color: #92400e;
    }

    /* ── GRID LAYOUT ── */
    .content-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.5rem;
        align-items: start;
    }
    @@media(max - width:768px) {
        .content-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── INFO CARD ── */
    .info-card {
        background: var(--card);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        margin-bottom: 1.25rem;
    }

        .info-card h3 {
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

    .spec-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .spec-item .lbl {
        font-size: .7rem;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: .2rem;
    }

    .spec-item .val {
        font-size: .9rem;
        font-weight: 600;
        color: var(--dark);
    }

    /* ── FACILITY CARD ── */
    .fac-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .fac-icon {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        background: var(--dark);
        color: var(--gold2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .fac-meta .name {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--dark);
    }

    .fac-meta .addr {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .fac-meta .hours {
        font-size: .8rem;
        color: var(--green);
        margin-top: .25rem;
        font-weight: 600;
    }

    /* ── AMENITIES ── */
    .amenity-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .3rem .8rem;
        border-radius: 20px;
        background: #fef9ec;
        border: 1px solid #e8d5a0;
        font-size: .78rem;
        font-weight: 600;
        color: var(--dark);
    }

    /* ── PRICE SLOTS ── */
    .price-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .85rem;
    }

        .price-table th {
            background: var(--dark);
            color: #fff;
            padding: .55rem .9rem;
            text-align: left;
            font-weight: 600;
        }

            .price-table th:first-child {
                border-radius: 8px 0 0 0;
            }

            .price-table th:last-child {
                border-radius: 0 8px 0 0;
            }

        .price-table td {
            padding: .55rem .9rem;
            border-bottom: 1px solid #f0e8d8;
        }

        .price-table tr:last-child td {
            border-bottom: none;
        }

        .price-table tr:hover td {
            background: #fef9ec;
        }

    .price-val {
        font-weight: 700;
        color: var(--gold);
    }

    /* ── REVIEWS ── */
    .rating-big {
        font-size: 3rem;
        font-weight: 800;
        color: var(--dark);
        line-height: 1;
    }

    .stars {
        color: var(--gold2);
        font-size: 1.1rem;
    }

    .review-item {
        padding: .9rem 0;
        border-bottom: 1px solid #f0e8d8;
    }

        .review-item:last-child {
            border-bottom: none;
        }

    .reviewer {
        font-weight: 700;
        font-size: .88rem;
        color: var(--dark);
    }

    .review-date {
        font-size: .75rem;
        color: var(--muted);
    }

    .review-body {
        font-size: .85rem;
        color: #4a3728;
        margin-top: .3rem;
        line-height: 1.5;
    }

    /* ── STICKY BOOKING ── */
    .sticky-book {
        position: sticky;
        top: 80px;
        background: var(--card);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: 0 4px 24px rgba(0,0,0,.1);
        border: 2px solid #f0e0b0;
    }

        .sticky-book .price-from {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--gold);
        }

            .sticky-book .price-from span {
                font-size: .9rem;
                font-weight: 500;
                color: var(--muted);
            }

    .btn-book {
        display: block;
        width: 100%;
        padding: .9rem;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        color: var(--dark);
        font-weight: 800;
        font-size: 1rem;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: transform .15s, box-shadow .15s;
        margin-top: 1rem;
    }

        .btn-book:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(212,160,23,.4);
            color: var(--dark);
        }

    .btn-back {
        display: block;
        width: 100%;
        padding: .7rem;
        background: transparent;
        border: 2px solid #ddd;
        border-radius: 10px;
        color: var(--muted);
        font-weight: 600;
        font-size: .88rem;
        text-align: center;
        text-decoration: none;
        margin-top: .75rem;
        transition: border-color .15s, color .15s;
    }

        .btn-back:hover {
            border-color: var(--dark);
            color: var(--dark);
        }

    .divider {
        border: none;
        border-top: 1px solid #f0e8d8;
        margin: 1rem 0;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        font-size: .83rem;
        margin-bottom: .5rem;
    }

        .stat-row .k {
            color: var(--muted);
        }

        .stat-row .v {
            font-weight: 700;
            color: var(--dark);
        }
</style>

<div class="detail-wrap">

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:1rem;margin-bottom:1rem;color:#991b1b">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        </div>
    }

    <!-- ── GALLERY ───────────────────────────────── -->
    @if (images.Any())
    {
        <div class="gallery-wrap" id="gallery">
            @for (int i = 0; i < images.Count; i++)
            {
                <div class="gallery-slide @(i == 0 ? "active" : "")" data-idx="@i">
                    <img src="@images[i]" alt="Ảnh sân @(i + 1)" loading="@(i == 0 ? "eager" : "lazy")" />
                </div>
            }
            @if (images.Count > 1)
            {
                <button class="gallery-nav prev" onclick="galleryNav(-1)" aria-label="Ảnh trước">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button class="gallery-nav next" onclick="galleryNav(1)" aria-label="Ảnh sau">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <div class="gallery-dots">
                    @for (int i = 0; i < images.Count; i++)
                    {
                        <button class="gallery-dot @(i == 0 ? "active" : "")" onclick="galleryGo(@i)" aria-label="Ảnh @(i + 1)"></button>
                    }
                </div>
            }
        </div>
        @if (images.Count > 1)
        {
            <div class="gallery-thumbs" id="thumbs">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div class="gallery-thumb @(i == 0 ? "active" : "")" onclick="galleryGo(@i)" data-tidx="@i">
                        <img src="@images[i]" alt="Thumb @(i + 1)" />
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div style="width:100%;height:260px;background:#e8ddd0;border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;color:var(--muted)">
            <i class="bi bi-image" style="font-size:2.5rem"></i>
        </div>
    }

    <!-- ── TITLE ── -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1.5rem">
        <div>
            <h1 class="court-title">
                <i class="bi bi-grid-3x3-gap me-2"></i>Sân @court.CourtNumber
                @if (!string.IsNullOrEmpty(court.CourtTypeLabel as string))
                {
                    <span style="color:var(--gold)">— @court.CourtTypeLabel</span>
                }
            </h1>
            <div class="court-sub">
                <i class="bi bi-geo-alt-fill" style="color:var(--gold)"></i>
                @(facility?.FacilityName ?? "") · @(facility?.Address ?? "")
                @if (!string.IsNullOrEmpty(facility?.District as string) || !string.IsNullOrEmpty(facility?.City as string))
                {
                    <span>, @(facility?.District ?? "") @(facility?.City ?? "")</span>
                }
            </div>
            <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                <span class="badge @(court.CourtType == "Indoor" ? "badge-indoor" : "badge-outdoor")">
                    <i class="bi bi-building"></i> @(court.CourtTypeLabel ?? court.CourtType)
                </span>
                <span class="badge @(court.Status == "Available" ? "badge-avail" : "badge-busy")">
                    <i class="bi bi-circle-fill" style="font-size:.5rem"></i>
                    @(court.Status == "Available" ? "Còn trống" : "Đang bận")
                </span>
                @if (!string.IsNullOrEmpty(court.SurfaceTypeLabel as string))
                {
                    <span class="badge" style="background:#e0f2fe;color:#0369a1">
                        <i class="bi bi-layers"></i> @court.SurfaceTypeLabel
                    </span>
                }
                @if (avgRating > 0)
                {
                    <span class="badge badge-star">
                        <i class="bi bi-star-fill"></i> @avgRating.ToString("0.0") (@reviewCount đánh giá)
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- ── MAIN GRID ── -->
    <div class="content-grid">

        <!-- LEFT COLUMN -->
        <div>

            <!-- THÔNG SỐ SÂN -->
            <div class="info-card">
                <h3><i class="bi bi-clipboard-data"></i> Thông số sân</h3>
                <div class="spec-grid">
                    <div class="spec-item">
                        <div class="lbl">Loại sân</div>
                        <div class="val">@(court.CourtTypeLabel ?? court.CourtType ?? "—")</div>
                    </div>
                    <div class="spec-item">
                        <div class="lbl">Mặt sân</div>
                        <div class="val">@(court.SurfaceTypeLabel ?? court.SurfaceType ?? "—")</div>
                    </div>
                    <div class="spec-item">
                        <div class="lbl">Tầng</div>
                        <div class="val">@(court.FloorNumber > 0 ? "Tầng " + court.FloorNumber : "Tầng trệt")</div>
                    </div>
                    <div class="spec-item">
                        <div class="lbl">Số sân</div>
                        <div class="val">@court.CourtNumber</div>
                    </div>
                    <div class="spec-item">
                        <div class="lbl">Đèn chiếu sáng</div>
                        <div class="val" style="color:@(court.HasLighting ? "var(--green)" : "var(--muted)")">
                            @(court.HasLighting ? "✅ Có" : "❌ Không")
                        </div>
                    </div>
                    <div class="spec-item">
                        <div class="lbl">Điều hoà</div>
                        <div class="val" style="color:@(court.HasAC ? "var(--green)" : "var(--muted)")">
                            @(court.HasAC ? "✅ Có" : "❌ Không")
                        </div>
                    </div>
                    @if (court.HourlyRate > 0)
                    {
                        <div class="spec-item" style="grid-column:span 2">
                            <div class="lbl">Giá theo giờ cơ bản</div>
                            <div class="val" style="color:var(--gold)">@string.Format("{0:N0}", court.HourlyRate)đ / giờ</div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(court.Description as string))
                {
                    <hr style="border:none;border-top:1px solid #f0e8d8;margin:1rem 0" />
                    <div>
                        <div style="font-size:.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.4rem">Mô tả sân</div>
                        <p style="font-size:.88rem;color:#4a3728;line-height:1.6;margin:0">@court.Description</p>
                    </div>
                }
            </div>

            <!-- THÔNG TIN CƠ SỞ -->
            @if (facility != null)
            {
                <div class="info-card">
                    <h3><i class="bi bi-building"></i> Thông tin cơ sở</h3>
                    <div class="fac-row" style="margin-bottom:1rem">
                        <div class="fac-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div class="fac-meta">
                            <div class="name">@facility.FacilityName</div>
                            <div class="addr">
                                <i class="bi bi-geo-alt" style="color:var(--gold)"></i>
                                @facility.Address
                                @if (!string.IsNullOrEmpty(facility.District as string))
                                {
                                    <text>, @facility.District</text>
                                }
                                @if (!string.IsNullOrEmpty(facility.City as string))
                                {
                                    <text>, @facility.City</text>
                                }
                            </div>
                            @if (facility.OpenTime != null && facility.CloseTime != null)
                            {
                                <div class="hours">
                                    <i class="bi bi-clock"></i>
                                    Mở cửa: @facility.OpenTime.ToString(@"hh\:mm") — @facility.CloseTime.ToString(@"hh\:mm")
                                </div>
                            }
                        </div>
                    </div>
                    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;font-size:.83rem;margin-bottom:.75rem">
                        @if (!string.IsNullOrEmpty(facility.Phone as string))
                        {
                            <div>
                                <i class="bi bi-telephone" style="color:var(--gold)"></i>
                                <a href="tel:@facility.Phone" style="color:var(--dark);font-weight:600;text-decoration:none"> @facility.Phone</a>
                            </div>
                        }
                        @if ((int)(facility.TotalCourts ?? 0) > 0)
                        {
                            <div>
                                <i class="bi bi-grid" style="color:var(--gold)"></i>
                                <span style="font-weight:600"> @facility.TotalCourts sân</span>
                            </div>
                        }
                        @if ((double)(facility.AverageRating ?? 0) > 0)
                        {
                            <div>
                                <i class="bi bi-star-fill" style="color:var(--gold2)"></i>
                                <span style="font-weight:600"> @((double)facility.AverageRating).ToString("0.0")</span>
                                <span style="color:var(--muted)"> (@facility.ReviewCount đánh giá)</span>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(facility.Amenities as string))
                    {
                        var amenityList = ((string)facility.Amenities).Split(',', System.StringSplitOptions.RemoveEmptyEntries);
                        var amenityIcons = new System.Collections.Generic.Dictionary<string, string>
                                {
                                {"Wifi","bi-wifi"}, {"wifi","bi-wifi"},
                                {"Bãi đỗ xe","bi-car-front"}, {"bãi đỗ xe","bi-car-front"},
                                {"Phòng tắm","bi-droplet"}, {"Căng tin","bi-cup-straw"},
                                {"Máy lạnh","bi-thermometer-snow"}, {"Điều hoà","bi-thermometer-snow"},
                                {"Camera","bi-camera"}, {"Cho thuê vợt","bi-activity"},
                                {"Bán nước","bi-cup"}, {"Ghế nghỉ","bi-person-check"}
                                };
                        <div class="amenity-chips" style="margin-top:.5rem">
                            @foreach (var a in amenityList)
                            {
                                var key = a.Trim();
                                var icon = amenityIcons.ContainsKey(key) ? amenityIcons[key] : "bi-check-circle";
                                <span class="chip"><i class="bi @icon" style="color:var(--gold)"></i> @key</span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(facility.Description as string))
                    {
                        <div style="margin-top:1rem;font-size:.85rem;color:#4a3728;line-height:1.6;border-top:1px solid #f0e8d8;padding-top:1rem">
                            @facility.Description
                        </div>
                    }
                </div>
            }

            <!-- BẢNG GIÁ -->
            @if (priceSlots.Any())
            {
                <div class="info-card">
                    <h3><i class="bi bi-tag"></i> Bảng giá theo khung giờ</h3>
                    <table class="price-table">
                        <thead>
                            <tr>
                                <th>Khung giờ</th>
                                <th>Ngày áp dụng</th>
                                <th style="text-align:right">Giá / giờ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ps in priceSlots)
                            {
                                <tr>
                                    <td>@ps.StartTime.ToString(@"hh\:mm") – @ps.EndTime.ToString(@"hh\:mm")</td>
                                    <td style="color:var(--muted);font-size:.8rem">@(ps.DayType ?? "Tất cả ngày")</td>
                                    <td style="text-align:right" class="price-val">@string.Format("{0:N0}", ps.Price)đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- ĐÁNH GIÁ -->
            @if (reviews.Any())
            {
                <div class="info-card">
                    <h3><i class="bi bi-chat-square-text"></i> Đánh giá từ người chơi</h3>
                    <div style="display:flex;align-items:center;gap:1.5rem;margin-bottom:1.25rem;padding-bottom:1rem;border-bottom:1px solid #f0e8d8">
                        <div style="text-align:center">
                            <div class="rating-big">@avgRating.ToString("0.0")</div>
                            <div class="stars">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi @(s <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                            <div style="font-size:.75rem;color:var(--muted);margin-top:.2rem">@reviewCount đánh giá</div>
                        </div>
                    </div>
                    @foreach (var rv in reviews)
                    {
                        <div class="review-item">
                            <div style="display:flex;justify-content:space-between;align-items:center">
                                <div class="reviewer">@(rv.UserName ?? "Người dùng ẩn danh")</div>
                                <div class="review-date">@(rv.CreatedAt != null ? ((DateTime)rv.CreatedAt).ToString("dd/MM/yyyy") : "")</div>
                            </div>
                            <div class="stars" style="font-size:.8rem;margin:.2rem 0">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi @(s <= (int)rv.Rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(rv.Comment as string))
                            {
                                <div class="review-body">@rv.Comment</div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- RIGHT COLUMN — STICKY BOOKING -->
        <div>
            <div class="sticky-book">
                @{
                    decimal minPrice = priceSlots.Any()
                    ? priceSlots.Min(p => (decimal)p.Price)
                    : (decimal)(court.HourlyRate ?? 0m);
                }
                @if (minPrice > 0)
                {
                    <div class="price-from">
                        @string.Format("{0:N0}", minPrice)đ
                        <span>/ giờ</span>
                    </div>
                    <div style="font-size:.75rem;color:var(--muted);margin-top:.15rem">Giá từ (chưa bao gồm khuyến mãi)</div>
                }
                else
                {
                    <div class="price-from" style="font-size:1.1rem;color:var(--muted)">Liên hệ để biết giá</div>
                }

                <hr class="divider" />

                <div class="stat-row">
                    <span class="k"><i class="bi bi-grid"></i> Mã sân</span>
                    <span class="v">@court.CourtNumber</span>
                </div>
                <div class="stat-row">
                    <span class="k"><i class="bi bi-circle-fill" style="font-size:.5rem;color:@(court.Status == "Available" ? "var(--green)" : "var(--red)")"></i> Trạng thái</span>
                    <span class="v" style="color:@(court.Status == "Available" ? "var(--green)" : "var(--red)")">
                        @(court.Status == "Available" ? "Còn trống" : "Đang bận")
                    </span>
                </div>
                @if (facility?.OpenTime != null && facility?.CloseTime != null)
                {
                    <div class="stat-row">
                        <span class="k"><i class="bi bi-clock"></i> Giờ mở</span>
                        <span class="v">@facility.OpenTime.ToString(@"hh\:mm")–@facility.CloseTime.ToString(@"hh\:mm")</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(facility?.Phone as string))
                {
                    <div class="stat-row">
                        <span class="k"><i class="bi bi-telephone"></i> Điện thoại</span>
                        <span class="v"><a href="tel:@facility.Phone" style="color:var(--dark);text-decoration:none">@facility.Phone</a></span>
                    </div>
                }

                <hr class="divider" />

                @if (court.Status == "Available")
                {
                    <a href="/Booking/Search?facilityId=@(court.FacilityId)&courtId=@(court.CourtId)" class="btn-book">
                        <i class="bi bi-calendar-check me-2"></i>Đặt sân ngay
                    </a>
                }
                else
                {
                    <button class="btn-book" disabled style="opacity:.5;cursor:not-allowed">
                        <i class="bi bi-calendar-x me-2"></i>Sân đang bận
                    </button>
                }
                <a href="javascript:history.back()" class="btn-back">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>

                @if (facility?.Latitude != null && facility?.Longitude != null &&
                                (double)facility.Latitude != 0 && (double)facility.Longitude != 0)
                {
                    <a href="https://www.google.com/maps?q=@facility.Latitude,@facility.Longitude"
                       target="_blank" rel="noopener"
                       class="btn-back" style="margin-top:.5rem">
                        <i class="bi bi-map me-1"></i> Xem trên bản đồ
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // ── Gallery JS ──
    let gIdx = 0;
    const slides = document.querySelectorAll('.gallery-slide');
    const dots   = document.querySelectorAll('.gallery-dot');
    const thumbs = document.querySelectorAll('.gallery-thumb');

    function galleryGo(i) {
        if (!slides.length) return;
        slides[gIdx].classList.remove('active');
        if (dots[gIdx])   dots[gIdx].classList.remove('active');
        if (thumbs[gIdx]) thumbs[gIdx].classList.remove('active');
        gIdx = (i + slides.length) % slides.length;
        slides[gIdx].classList.add('active');
        if (dots[gIdx])   dots[gIdx].classList.add('active');
        if (thumbs[gIdx]) {
            thumbs[gIdx].classList.add('active');
            thumbs[gIdx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
        }
    }

    function galleryNav(dir) { galleryGo(gIdx + dir); }

    // Auto-advance every 5s
    if (slides.length > 1) {
        setInterval(() => galleryNav(1), 5000);
    }

    // Keyboard navigation
    document.addEventListener('keydown', e => {
        if (e.key === 'ArrowLeft')  galleryNav(-1);
        if (e.key === 'ArrowRight') galleryNav(1);
    });
</script>
