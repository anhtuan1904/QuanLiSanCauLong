@model IEnumerable<QuanLiSanCauLong.ViewModels.OrderViewModel>
@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    body, * {
        font-family: 'Outfit',sans-serif;
    }

    .idx-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .idx-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .idx-title em {
            font-style: italic;
            color: var(--gold);
        }

    .export-btn {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .75rem 1.6rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        transition: all .25s;
    }

        .export-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
            color: var(--deep);
        }

    /* STATS */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .72rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    /* TOOLBAR */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .tab-group {
        display: flex;
        gap: .4rem;
    }

    .tab-btn {
        padding: .55rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-weight: 600;
        font-size: .82rem;
        color: var(--muted);
        cursor: pointer;
        transition: all .2s;
    }

        .tab-btn:hover {
            border-color: rgba(212,160,23,.5);
            color: var(--deep);
            background: var(--cream);
        }

        .tab-btn.active {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .tb-search {
        position: relative;
        min-width: 220px;
    }

        .tb-search input {
            width: 100%;
            padding: .65rem 1rem .65rem 2.3rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .84rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
            }

        .tb-search i {
            position: absolute;
            left: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .85rem;
        }

    .tb-sel {
        padding: .65rem 1rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    /* TABLE */
    .idx-table-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .idx-table {
        width: 100%;
        border-collapse: collapse;
    }

        .idx-table th {
            background: var(--warm);
            padding: .85rem 1rem;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .idx-table td {
            padding: .95rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .86rem;
            vertical-align: middle;
            color: var(--deep);
        }

        .idx-table tr:last-child td {
            border-bottom: none;
        }

        .idx-table tr:hover td {
            background: var(--cream);
        }

    .tbl-footer {
        padding: .85rem 1.25rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        font-size: .78rem;
        color: var(--muted);
    }

    /* ORDER TYPE ICON */
    .ot-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .ot-booking {
        background: rgba(212,160,23,.14);
        color: #92660a;
    }

    .ot-product {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .ot-package {
        background: rgba(236,72,153,.08);
        color: #be185d;
    }

    /* CHIPS */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .68rem;
        font-weight: 700;
        padding: .28rem .7rem;
        border-radius: 4px;
        letter-spacing: .04em;
        white-space: nowrap;
    }

    .chip-paid {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-unpaid {
        background: rgba(212,160,23,.13);
        color: #92660a;
    }

    .chip-refunded {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-pending {
        background: rgba(212,160,23,.13);
        color: #92660a;
    }

    .chip-confirmed {
        background: rgba(79,70,229,.09);
        color: #4f46e5;
    }

    .chip-shipping {
        background: rgba(139,92,246,.1);
        color: #7c3aed;
    }

    .chip-completed {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-cancelled {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    /* ACTION */
    .act-g {
        display: flex;
        gap: .3rem;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        font-size: .78rem;
        text-decoration: none;
    }

        .act-b:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    /* ALERTS */
    .sys-alert {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #16a34a;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .3;
        }
</style>

<div>

    <!-- HEADER -->
    <div class="idx-head">
        <div>
            <h1 class="idx-title">Quản Lý <em>Đơn Hàng</em></h1>
            <div style="font-size:.82rem;color:var(--muted);margin-top:.25rem;">
                Tổng cộng @(Model?.Count() ?? 0) đơn hàng trong hệ thống
            </div>
        </div>
        <button class="export-btn" onclick="Swal.fire({icon:'info',title:'Tính năng đang phát triển',text:'Xuất Excel sẽ có trong phiên bản tới.',timer:2000,showConfirmButton:false})">
            <i class="bi bi-download"></i> Xuất Excel
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i>@TempData["ErrorMessage"]</div>
    }

    <!-- STATS STRIP -->
    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@(ViewBag.TotalOrders ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng Đơn Hàng</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#92660a;">@(ViewBag.PendingOrders ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#92660a;"></span>Chờ Xử Lý</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#7c3aed;">@(ViewBag.ShippingOrders ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#7c3aed;"></span>Đang Giao</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@(ViewBag.CompletedOrders ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Hoàn Thành</div>
        </div>
    </div>

    <!-- DATE FILTER FORM -->
    <form method="get" id="filterForm" style="margin-bottom:1.25rem;">
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:flex-end;">
            <div>
                <label style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);display:block;margin-bottom:.3rem;">Từ ngày</label>
                <input type="date" name="fromDate" class="tb-sel"
                       value="@(Context.Request.Query["fromDate"].ToString())" />
            </div>
            <div>
                <label style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);display:block;margin-bottom:.3rem;">Đến ngày</label>
                <input type="date" name="toDate" class="tb-sel"
                       value="@(Context.Request.Query["toDate"].ToString())" />
            </div>
            <div>
                <label style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);display:block;margin-bottom:.3rem;">Loại đơn</label>
                @{
                    var curOrderType = Context.Request.Query["orderType"].ToString();
                    var curStatus = Context.Request.Query["status"].ToString();
                }
                <select name="orderType" class="tb-sel" onchange="this.form.submit()">
                    <option value="">Tất cả loại</option>
                    <option value="booking" selected="@(curOrderType == "booking" ? "selected" : null)">Đặt Sân</option>
                    <option value="product" selected="@(curOrderType == "product" ? "selected" : null)">Sản Phẩm</option>
                </select>
            </div>
            <div>
                <label style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);display:block;margin-bottom:.3rem;">Trạng thái</label>
                <select name="status" class="tb-sel" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    <option value="Pending" selected="@(curStatus == "Pending" ? "selected" : null)">Chờ xử lý</option>
                    <option value="Confirmed" selected="@(curStatus == "Confirmed" ? "selected" : null)">Đã xác nhận</option>
                    <option value="Shipping" selected="@(curStatus == "Shipping" ? "selected" : null)">Đang giao</option>
                    <option value="Completed" selected="@(curStatus == "Completed" ? "selected" : null)">Hoàn thành</option>
                    <option value="Cancelled" selected="@(curStatus == "Cancelled" ? "selected" : null)">Đã hủy</option>
                </select>
            </div>
            <button type="submit" class="export-btn" style="padding:.65rem 1.2rem;">
                <i class="bi bi-funnel"></i> Lọc
            </button>
            <a href="@Url.Action("Index")" class="export-btn" style="padding:.65rem 1.2rem;background:#fff;color:var(--muted);border:1px solid var(--border);">
                <i class="bi bi-x-circle"></i> Xóa lọc
            </a>
        </div>
    </form>

    <!-- TOOLBAR (client-side search) -->
    <div class="toolbar">
        <div class="tab-group">
            <button class="tab-btn active" data-filter="all">Tất Cả</button>
            <button class="tab-btn" data-filter="product">Sản Phẩm</button>
            <button class="tab-btn" data-filter="booking">Đặt Sân</button>
        </div>

        <div class="tb-search" style="margin-left:auto;">
            <i class="bi bi-search"></i>
            <input type="text" id="orderSearch" placeholder="Tìm mã đơn..." oninput="filterOrders()" />
        </div>

        <select id="statusFilter" class="tb-sel" onchange="filterOrders()">
            <option value="">Tình trạng</option>
            <option value="Pending">Chờ xử lý</option>
            <option value="Confirmed">Đã xác nhận</option>
            <option value="Shipping">Đang giao</option>
            <option value="Completed">Hoàn thành</option>
            <option value="Cancelled">Đã hủy</option>
        </select>
    </div>

    <!-- TABLE -->
    <div class="idx-table-wrap">
        <table class="idx-table">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Khách Hàng</th>
                    <th>Sản Phẩm / Dịch Vụ</th>
                    <th>Tổng Tiền</th>
                    <th>Ngày Đặt</th>
                    <th>Thanh Toán</th>
                    <th>Trạng Thái</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody id="orderTableBody">
                @if (Model != null && Model.Any())
                {
                    foreach (var order in Model)
                    {
                        var typeKey = order.OrderType ?? "product";
                        <tr data-filter="@typeKey"
                            data-status="@order.OrderStatus"
                            data-search="@(order.OrderCode + " " + order.OrderStatus)">

                            <!-- Mã đơn -->
                            <td>
                                <div style="display:flex;align-items:center;gap:.7rem;">
                                    @if (order.OrderType == "booking")
                                    {
                                        <span class="ot-icon ot-booking"><i class="bi bi-calendar-check"></i></span>
                                    }
                                    else
                                    {
                                        <span class="ot-icon ot-product"><i class="bi bi-bag"></i></span>
                                    }
                                    <div>
                                        <div style="font-weight:700;font-size:.88rem;color:var(--deep);">@order.OrderCode</div>
                                        <div style="font-size:.69rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;">
                                            @(order.OrderType == "booking" ? "Đặt Sân" : "Sản Phẩm")
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <!-- Khách hàng -->
                            <td>
                                <div style="font-weight:600;font-size:.86rem;">Khách hàng</div>
                                <div style="font-size:.73rem;color:var(--muted);">
                                    <i class="bi bi-telephone" style="color:var(--gold);margin-right:.25rem;"></i>0123 456 789
                                </div>
                            </td>

                            <!-- Sản phẩm -->
                            <td>
                                <div style="font-size:.84rem;max-width:175px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @string.Join(", ", order.OrderDetails.Take(2).Select(d => d.ProductName))
                                    @(order.OrderDetails.Count > 2 ? "…" : "")
                                </div>
                                <div style="font-size:.71rem;color:var(--muted);margin-top:.1rem;">
                                    @order.OrderDetails.Count sản phẩm
                                </div>
                            </td>

                            <!-- Tổng tiền -->
                            <td>
                                <span style="font-weight:700;color:#16a34a;">₫@order.TotalAmount.ToString("N0")</span>
                            </td>

                            <!-- Ngày đặt -->
                            <td>
                                <div style="font-size:.84rem;">@order.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div style="font-size:.72rem;color:var(--muted);">@order.CreatedAt.ToString("HH:mm")</div>
                            </td>

                            <!-- Thanh toán -->
                            <td>
                                @if (order.PaymentStatus == "Paid")
                                {
                                    <span class="chip chip-paid">✓ Đã TT</span>
                                }
                                else if (order.PaymentStatus == "Refunded")
                                {
                                    <span class="chip chip-refunded">↩ Hoàn Tiền</span>
                                }
                                else
                                {
                                    <span class="chip chip-unpaid">⏳ Chờ TT</span>
                                }
                            </td>

                            <!-- Trạng thái -->
                            <td>
                                @switch (order.OrderStatus)
                                {
                                    case "Pending":
                                        <span class="chip chip-pending">● Chờ Xử Lý</span>
                                        break;
                                    case "Confirmed":
                                        <span class="chip chip-confirmed">✓ Xác Nhận</span>
                                        break;
                                    case "Shipping":
                                        <span class="chip chip-shipping">🚚 Đang Giao</span>
                                        break;
                                    case "Completed":
                                        <span class="chip chip-completed">✓ Hoàn Thành</span>
                                        break;
                                    case "Cancelled":
                                        <span class="chip chip-cancelled">✕ Đã Hủy</span>
                                        break;
                                    default:
                                        <span class="chip chip-pending">@order.OrderStatus</span>
                                        break;
                                }
                            </td>

                            <!-- Thao tác -->
                            <td>
                                <div class="act-g">
                                    <a asp-action="Details" asp-route-id="@order.OrderId"
                                       class="act-b" title="Xem chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (Model?.Any() != true)
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <div>Không có đơn hàng nào</div>
            </div>
        }

        <div class="tbl-footer">
            Hiển thị <strong>@(Model?.Count() ?? 0)</strong> đơn hàng
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                filterOrders();
            });
        });

        function filterOrders() {
            const tabFilter    = document.querySelector('.tab-btn.active')?.dataset.filter ?? 'all';
            const statusFilter = document.getElementById('statusFilter').value;
            const searchVal    = document.getElementById('orderSearch').value.toLowerCase();

            let visible = 0;
            document.querySelectorAll('#orderTableBody tr[data-filter]').forEach(row => {
                const matchTab    = tabFilter === 'all' || row.dataset.filter === tabFilter;
                const matchStatus = !statusFilter || row.dataset.status === statusFilter;
                const matchSearch = !searchVal
                    || row.dataset.search.toLowerCase().includes(searchVal)
                    || row.textContent.toLowerCase().includes(searchVal);
                const show = matchTab && matchStatus && matchSearch;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            // Cập nhật footer count
            const footer = document.querySelector('.tbl-footer strong');
            if (footer) footer.textContent = visible;
        }
    </script>
}
