@model QuanLiSanCauLong.ViewModels.OrderViewModel
@{
    ViewData["Title"] = "Chi Tiết Đơn #" + Model.OrderCode;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var (stCls, stLbl) = Model.OrderStatus switch
    {
        "Pending" => ("chip-pending", "Chờ Xử Lý"),
        "Confirmed" => ("chip-confirmed", "Đã Xác Nhận"),
        "Shipping" => ("chip-shipping", "Đang Giao"),
        "Completed" => ("chip-completed", "Hoàn Thành"),
        "Cancelled" => ("chip-cancelled", "Đã Hủy"),
        _ => ("chip-pending", Model.OrderStatus)
    };

    var (payCls, payLbl) = Model.PaymentStatus switch
    {
        "Paid" => ("chip-paid", "Đã Thanh Toán"),
        "Refunded" => ("chip-refunded", "Đã Hoàn Tiền"),
        _ => ("chip-unpaid", "Chưa Thanh Toán")
    };

    bool canAct = Model.OrderStatus is "Pending" or "Confirmed" or "Shipping";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    *, body {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .det-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1.5px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        font-size: .95rem;
        flex-shrink: 0;
    }

        .back-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

    .det-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--deep);
    }

        .det-title em {
            font-style: italic;
            color: var(--gold);
        }

    .det-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .head-acts {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .type-banner {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .85rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        font-weight: 600;
    }

        .type-banner.booking {
            background: rgba(212,160,23,.1);
            border: 1px solid rgba(212,160,23,.25);
            color: #92660a;
        }

        .type-banner.product {
            background: rgba(79,70,229,.07);
            border: 1px solid rgba(79,70,229,.2);
            color: #4f46e5;
        }

    .cf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .cf-card-head {
        padding: .9rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cf-card-title {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .cf-card-body {
        padding: 1.4rem;
    }

    .prod-table {
        width: 100%;
        border-collapse: collapse;
    }

        .prod-table th {
            background: var(--warm);
            padding: .75rem 1rem;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .prod-table td {
            padding: .9rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .85rem;
            vertical-align: middle;
        }

        .prod-table tr:last-child td {
            border-bottom: none;
        }

        .prod-table tr:hover td {
            background: var(--cream);
        }

    .prod-icon {
        width: 42px;
        height: 42px;
        border-radius: 9px;
        background: rgba(212,160,23,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .qty-badge {
        background: var(--warm);
        border: 1px solid var(--border);
        color: var(--deep);
        font-size: .78rem;
        font-weight: 700;
        padding: .2rem .65rem;
        border-radius: 4px;
    }

    .sum-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .75rem 0;
        border-bottom: 1px solid var(--border);
        font-size: .88rem;
    }

        .sum-row:last-child {
            border-bottom: none;
        }

    .sum-lbl {
        color: var(--muted);
    }

    .sum-val {
        font-weight: 600;
        color: var(--deep);
    }

    .sum-disc {
        color: #c94b2a;
        font-weight: 600;
    }

    .sum-total-lbl {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--deep);
    }

    .sum-total-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: #16a34a;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .6rem 0;
        border-bottom: 1px solid var(--border);
        font-size: .85rem;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-lbl {
        color: var(--muted);
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .07em;
        font-weight: 600;
    }

    .info-val {
        font-weight: 600;
        color: var(--deep);
        text-align: right;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .72rem;
        font-weight: 700;
        padding: .35rem .8rem;
        border-radius: 5px;
        letter-spacing: .04em;
    }

    .chip-paid {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-unpaid {
        background: rgba(212,160,23,.13);
        color: #92660a;
    }

    .chip-refunded {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-pending {
        background: rgba(212,160,23,.13);
        color: #92660a;
    }

    .chip-confirmed {
        background: rgba(79,70,229,.09);
        color: #4f46e5;
    }

    .chip-shipping {
        background: rgba(139,92,246,.1);
        color: #7c3aed;
    }

    .chip-completed {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-cancelled {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .cust-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--deep);
        font-size: 1.1rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .contact-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .45rem 0;
        font-size: .84rem;
        color: var(--deep);
    }

        .contact-row i {
            color: var(--gold);
            font-size: .85rem;
            width: 16px;
        }

    .timeline {
        position: relative;
        padding-left: 28px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 7px;
            top: 8px;
            bottom: 8px;
            width: 2px;
            background: var(--border);
            border-radius: 1px;
        }

    .tl-item {
        position: relative;
        margin-bottom: 1.2rem;
    }

        .tl-item:last-child {
            margin-bottom: 0;
        }

    .tl-dot {
        position: absolute;
        left: -24px;
        top: 3px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 3px solid #fff;
    }

    .tl-title {
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
    }

    .tl-time {
        font-size: .73rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .note-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-left: 3px solid var(--gold);
        border-radius: 0 8px 8px 0;
        padding: .9rem 1.1rem;
        font-size: .84rem;
        color: var(--muted);
        font-style: italic;
        line-height: 1.6;
    }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .85rem;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: all .25s;
        width: 100%;
        margin-bottom: .65rem;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .btn-dark {
        background: var(--deep);
        color: var(--gold2);
        border: none;
        padding: .85rem;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: all .25s;
        width: 100%;
        margin-bottom: .65rem;
    }

        .btn-dark:hover {
            background: #2d1f0e;
        }

    .btn-purple {
        background: #7c3aed;
        color: #fff;
        border: none;
        padding: .85rem;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: all .25s;
        width: 100%;
        margin-bottom: .65rem;
    }

        .btn-purple:hover {
            background: #6d28d9;
        }

    .btn-danger {
        background: #fff;
        border: 1.5px solid rgba(201,75,42,.4);
        color: #c94b2a;
        padding: .8rem;
        font-family: 'Outfit',sans-serif;
        font-size: .87rem;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: all .2s;
        width: 100%;
    }

        .btn-danger:hover {
            background: rgba(201,75,42,.06);
            border-color: #c94b2a;
        }

    .btn-print {
        padding: .7rem 1.3rem;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .2s;
    }

        .btn-print:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    .btn-hd {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .7rem 1.4rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
    }

        .btn-hd:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .sys-alert {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #16a34a;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    @@media print {
        .det-head .head-acts, .cf-card:last-child {
            display: none !important;
        }
    }

    @@media(max-width:900px) {
        .layout-cols {
            grid-template-columns: 1fr !important;
        }
    }
</style>

<div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i> @Html.Raw(TempData["SuccessMessage"])</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]</div>
    }

    <!-- HEADER -->
    <div class="det-head">
        <div style="display:flex;align-items:center;gap:1rem;">
            <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i></a>
            <div>
                <div class="det-title">Chi Tiết <em>Đơn Hàng</em></div>
                <div class="det-sub">
                    Mã: <strong>@Model.OrderCode</strong>
                    &nbsp;·&nbsp; @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    &nbsp;·&nbsp; <span class="chip @stCls">@stLbl</span>
                </div>
            </div>
        </div>
        <div class="head-acts">
            <button class="btn-print" onclick="window.print()">
                <i class="bi bi-printer"></i> In Hóa Đơn
            </button>
            @if (Model.OrderStatus == "Pending")
            {
                <button class="btn-hd" onclick="doAction('Confirmed')">
                    <i class="bi bi-check-circle"></i> Xác Nhận Đơn
                </button>
            }
            else if (Model.OrderStatus is "Confirmed" or "Shipping")
            {
                <button class="btn-hd" style="background:var(--deep);color:var(--gold2);"
                        onclick="doAction('Completed')">
                    <i class="bi bi-check2-circle"></i> Hoàn Thành
                </button>
            }
        </div>
    </div>

    <!-- TYPE BANNER -->
    @if (Model.OrderType == "booking")
    {
        <div class="type-banner booking">
            <i class="bi bi-link-45deg" style="font-size:1.1rem;"></i>
            Đơn hàng kèm đặt sân
            @if (Model.BookingId.HasValue && !string.IsNullOrEmpty(Model.BookingCode))
            {
                <a asp-controller="AdminBooking" asp-action="Details"
                   asp-route-id="@Model.BookingId"
                   style="margin-left:.5rem;font-size:.8rem;font-weight:700;text-decoration:underline;color:inherit;opacity:.75;">
                    <i class="bi bi-arrow-right-circle"></i> Xem đặt sân @Model.BookingCode
                </a>
            }
        </div>
    }
    else
    {
        <div class="type-banner product">
            <i class="bi bi-bag" style="font-size:1rem;"></i>
            Đơn hàng sản phẩm độc lập
        </div>
    }

    <div class="layout-cols" style="display:grid;grid-template-columns:1fr 340px;gap:1.25rem;align-items:start;">

        <!-- LEFT -->
        <div>
            <!-- Sản phẩm -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-bag cf-card-icon"></i>
                    <span class="cf-card-title">Sản Phẩm Đã Đặt</span>
                    <span style="margin-left:auto;font-size:.72rem;color:var(--muted);">@Model.OrderDetails.Count dòng</span>
                </div>
                <div style="padding:0;">
                    <table class="prod-table">
                        <thead>
                            <tr>
                                <th>Sản Phẩm</th>
                                <th style="text-align:center;">Đơn Giá</th>
                                <th style="text-align:center;">SL</th>
                                <th style="text-align:center;">Giảm</th>
                                <th style="text-align:right;padding-right:1.4rem;">Thành Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:.85rem;">
                                            <div class="prod-icon"><i class="bi bi-box-seam"></i></div>
                                            <div>
                                                <div style="font-weight:700;font-size:.88rem;">@item.ProductName</div>
                                                @if (!string.IsNullOrEmpty(item.VariantDisplay))
                                                {
                                                    <div style="font-size:.73rem;color:#4f46e5;margin-top:.1rem;font-weight:600;">
                                                        <i class="bi bi-grid-3x3-gap" style="font-size:.65rem;"></i> @item.VariantDisplay
                                                    </div>
                                                }
                                                <div style="font-size:.73rem;color:var(--muted);margin-top:.1rem;">ĐVT: @(item.Unit ?? "—")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="text-align:center;color:var(--muted);font-size:.84rem;">₫@item.UnitPrice.ToString("N0")</td>
                                    <td style="text-align:center;"><span class="qty-badge">×@item.Quantity</span></td>
                                    <td style="text-align:center;">
                                        @if (item.DiscountAmount > 0)
                                        {
                                            <span style="color:#c94b2a;font-weight:600;font-size:.84rem;">-₫@item.DiscountAmount.ToString("N0")</span>
                                        }
                                        else
                                        {

                                            <span style="color:var(--muted);">—</span>
                                        }
                                    </td>
                                    <td style="text-align:right;padding-right:1.4rem;">
                                        <span style="font-weight:700;color:#16a34a;">₫@item.TotalPrice.ToString("N0")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tổng kết -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-receipt cf-card-icon"></i>
                    <span class="cf-card-title">Tổng Kết Đơn Hàng</span>
                </div>
                <div class="cf-card-body" style="max-width:380px;">
                    <div class="sum-row">
                        <span class="sum-lbl">Tạm tính (@Model.OrderDetails.Count sp)</span>
                        <span class="sum-val">₫@Model.SubTotal.ToString("N0")</span>
                    </div>
                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="sum-row">
                            <span class="sum-lbl">Giảm giá</span>
                            <span class="sum-disc">-₫@Model.DiscountAmount.ToString("N0")</span>
                        </div>
                    }
                    <div class="sum-row" style="padding-top:1rem;">
                        <span class="sum-total-lbl">Tổng Cộng</span>
                        <span class="sum-total-val">₫@Model.TotalAmount.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div>
            <!-- Khách hàng -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-person cf-card-icon"></i>
                    <span class="cf-card-title">Thông Tin Khách Hàng</span>
                </div>
                <div class="cf-card-body">
                    <div style="display:flex;align-items:center;gap:.9rem;margin-bottom:1rem;">
                        <div class="cust-avatar">
                            @(Model.CustomerName?.Length > 0 ? Model.CustomerName[0].ToString().ToUpper() : "K")
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:.92rem;">@(Model.CustomerName ?? "Khách vãng lai")</div>
                            <div style="font-size:.75rem;color:var(--muted);">
                                @(Model.OrderType == "booking" ? "Qua đặt sân" : "Thành viên")
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                    {
                        <div class="contact-row"><i class="bi bi-telephone"></i><span>@Model.CustomerPhone</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.CustomerEmail))
                    {
                        <div class="contact-row"><i class="bi bi-envelope"></i><span>@Model.CustomerEmail</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.FacilityName))
                    {
                        <div class="contact-row"><i class="bi bi-building"></i><span>@Model.FacilityName</span></div>
                    }
                </div>
            </div>

            <!-- Thanh toán & trạng thái -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-credit-card cf-card-icon"></i>
                    <span class="cf-card-title">Thanh Toán & Trạng Thái</span>
                </div>
                <div class="cf-card-body">
                    <div class="info-row">
                        <span class="info-lbl">Trạng thái</span>
                        <span class="chip @stCls">@stLbl</span>
                    </div>
                    <div class="info-row">
                        <span class="info-lbl">Thanh toán</span>
                        <span class="chip @payCls">@payLbl</span>
                    </div>
                    <div class="info-row" style="border-bottom:none;">
                        <span class="info-lbl">Loại đơn</span>
                        <span class="info-val">@(Model.OrderType == "booking" ? "Kèm đặt sân" : "Sản phẩm")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);">
                            <div style="font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:.5rem;font-weight:700;">Ghi Chú</div>
                            <div class="note-box">@Model.Note</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Timeline -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-clock-history cf-card-icon"></i>
                    <span class="cf-card-title">Lịch Sử Đơn Hàng</span>
                </div>
                <div class="cf-card-body">
                    <div class="timeline">
                        <div class="tl-item">
                            <div class="tl-dot" style="background:#16a34a;"></div>
                            <div class="tl-title">Đơn hàng được tạo</div>
                            <div class="tl-time">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        @if (Model.OrderStatus is "Confirmed" or "Shipping" or "Completed" or "Cancelled")
                        {
                            <div class="tl-item">
                                <div class="tl-dot" style="background:#4f46e5;"></div>
                                <div class="tl-title">Đã xác nhận đơn</div>
                                <div class="tl-time">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                            </div>
                        }
                        @if (Model.OrderStatus is "Shipping" or "Completed")
                        {
                            <div class="tl-item">
                                <div class="tl-dot" style="background:#7c3aed;"></div>
                                <div class="tl-title">Đang giao hàng</div>
                                <div class="tl-time">—</div>
                            </div>
                        }
                        @if (Model.OrderStatus == "Completed")
                        {
                            <div class="tl-item">
                                <div class="tl-dot" style="background:var(--gold);"></div>
                                <div class="tl-title">Hoàn thành đơn hàng</div>
                                <div class="tl-time">@((Model.CompletedAt ?? Model.UpdatedAt)?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                            </div>
                        }
                        @if (Model.OrderStatus == "Cancelled")
                        {
                            <div class="tl-item">
                                <div class="tl-dot" style="background:#c94b2a;"></div>
                                <div class="tl-title">Đã hủy đơn</div>
                                <div class="tl-time">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Thao tác -->
            @if (canAct)
            {
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-gear cf-card-icon"></i>
                        <span class="cf-card-title">Thao Tác</span>
                    </div>
                    <div class="cf-card-body">
                        @if (Model.OrderStatus == "Pending")
                        {
                            <button class="btn-gold" onclick="doAction('Confirmed')">
                                <i class="bi bi-check-circle"></i> Xác Nhận Đơn Hàng
                            </button>
                        }
                        @if (Model.OrderStatus == "Confirmed")
                        {
                            <button class="btn-purple" onclick="doAction('Shipping')">
                                <i class="bi bi-truck"></i> Chuyển Đang Giao
                            </button>
                            <button class="btn-dark" onclick="doAction('Completed')">
                                <i class="bi bi-check2-circle"></i> Hoàn Thành Đơn
                            </button>
                        }
                        @if (Model.OrderStatus == "Shipping")
                        {
                            <button class="btn-dark" onclick="doAction('Completed')">
                                <i class="bi bi-check2-circle"></i> Hoàn Thành Đơn
                            </button>
                        }
                        <button class="btn-danger" onclick="doAction('Cancelled')">
                            <i class="bi bi-x-circle"></i> Hủy Đơn Hàng
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function doAction(newStatus) {
            const cfg = {
                Confirmed: { title:'Xác nhận đơn hàng?', text:'Đơn chuyển sang Đã Xác Nhận, tồn kho được giữ chỗ.', icon:'question', btnColor:'#d4a017', btnText:'Xác nhận' },
                Shipping:  { title:'Chuyển sang Đang giao?', text:'', icon:'question', btnColor:'#7c3aed', btnText:'Đang giao' },
                Completed: { title:'Hoàn thành đơn hàng?', text:'Tồn kho sẽ được trừ thật và đơn đánh Đã thanh toán.', icon:'question', btnColor:'#1a1209', btnText:'Hoàn thành' },
                Cancelled: { title:'Hủy đơn hàng?', icon:'warning', btnColor:'#c94b2a', btnText:'Xác nhận hủy', needReason:true }
            }[newStatus];

            if (!cfg) return;

            const opts = {
                title: cfg.title, icon: cfg.icon,
                showCancelButton: true,
                confirmButtonColor: cfg.btnColor,
                cancelButtonColor:  '#8a7560',
                confirmButtonText:  cfg.btnText,
                cancelButtonText:   'Quay lại',
                reverseButtons: true
            };
            if (cfg.text) opts.text = cfg.text;
            if (cfg.needReason) {
                opts.input = 'textarea';
                opts.inputLabel = 'Lý do hủy *';
                opts.inputPlaceholder = 'Nhập lý do hủy đơn...';
                opts.inputValidator = v => { if (!v?.trim()) return 'Vui lòng nhập lý do!'; };
            }

            Swal.fire(opts).then(r => {
                if (!r.isConfirmed) return;

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const fd = new FormData();
                fd.append('id',        '@Model.OrderId');
                fd.append('newStatus', newStatus);
                if (cfg.needReason) fd.append('reason', r.value ?? '');
                if (token) fd.append('__RequestVerificationToken', token);

                fetch('@Url.Action("SetStatus", "AdminOrder")', { method:'POST', body:fd })
                    .then(res => res.json())
                    .then(res => {
                        if (res.success)
                            Swal.fire({ icon:'success', title:'Thành công!', text:res.message, timer:1400, showConfirmButton:false })
                                .then(() => location.reload());
                        else
                            Swal.fire('Lỗi!', res.message, 'error');
                    })
                    .catch(() => Swal.fire('Lỗi!', 'Không thể kết nối server.', 'error'));
            });
        }
    </script>
}
