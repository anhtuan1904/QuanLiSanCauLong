@model QuanLiSanCauLong.ViewModels.InventoryListViewModel

@{
    ViewData["Title"] = "Quản lý Kho hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #ffffff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --green: #15803d;
        --green-soft: #dcfce7;
        --red: #dc2626;
        --red-soft: #fef2f2;
        --yellow: #92600a;
        --yellow-soft: #fef9ec;
    }

    body, .container-fluid {
        font-family: 'Outfit', sans-serif;
        background: var(--cream);
    }

    .page-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.8rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .page-label {
        font-size: .68rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .35rem;
    }

        .page-label::before {
            content: '';
            width: 16px;
            height: 1px;
            background: var(--gold);
        }

    .page-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        margin: 0;
        line-height: 1.15;
    }

        .page-title em {
            font-style: italic;
            color: var(--gold);
        }

    .page-sub {
        font-size: .83rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .6rem 1.3rem;
        border: none;
        border-radius: 10px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: .2s;
        white-space: nowrap;
    }

    .btn-in {
        background: var(--gold2);
        color: var(--deep);
        box-shadow: 0 2px 8px rgba(212,160,23,.3);
    }

        .btn-in:hover {
            background: var(--gold);
            color: #fff;
        }

    .btn-out {
        background: #fef2f2;
        color: var(--red);
        border: 1px solid #fecaca;
    }

        .btn-out:hover {
            background: var(--red);
            color: #fff;
        }

    .btn-warn {
        background: var(--yellow-soft);
        color: var(--yellow);
        border: 1px solid #f0dea0;
    }

        .btn-warn:hover {
            background: #92600a;
            color: #fff;
        }

    /* Stats row */
    .stats-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .stat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem 1.4rem;
        flex: 1;
        min-width: 160px;
        box-shadow: 0 1px 6px rgba(26,18,9,.05);
    }

        .stat-card .sc-lbl {
            font-size: .7rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            font-weight: 700;
        }

        .stat-card .sc-val {
            font-size: 1.7rem;
            font-weight: 800;
            color: var(--deep);
            line-height: 1.1;
            margin-top: .2rem;
        }

        .stat-card.warn .sc-val {
            color: var(--yellow);
        }

        .stat-card.danger .sc-val {
            color: var(--red);
        }

    /* Filter row */
    .filter-row {
        display: flex;
        gap: .75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .filter-select {
        padding: .5rem 1rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: var(--card);
        cursor: pointer;
        outline: none;
        min-width: 180px;
        box-shadow: 0 1px 6px rgba(26,18,9,.05);
    }

    .btn-search {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem 1.2rem;
        background: var(--deep);
        color: var(--gold2);
        border: none;
        border-radius: 10px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
    }

        .btn-search:hover {
            background: #2d200a;
        }

    /* Table */
    .table-wrap {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(26,18,9,.05);
    }

    .inv-table {
        width: 100%;
        border-collapse: collapse;
    }

        .inv-table th {
            background: var(--warm);
            padding: .75rem 1rem;
            text-align: left;
            font-size: .72rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            font-weight: 700;
            border-bottom: 1px solid var(--border);
        }

        .inv-table td {
            padding: .75rem 1rem;
            font-size: .86rem;
            color: var(--deep);
            border-bottom: 1px solid #f5f0e8;
            vertical-align: middle;
        }

        .inv-table tr:last-child td {
            border-bottom: none;
        }

        .inv-table tr:hover td {
            background: #fdfcf8;
        }

    .badge-ok {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .22rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        background: var(--green-soft);
        color: var(--green);
        border: 1px solid #a7f3d0;
    }

    .badge-low {
        background: var(--yellow-soft);
        color: var(--yellow);
        border: 1px solid #f0dea0;
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .22rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .badge-out {
        background: var(--red-soft);
        color: var(--red);
        border: 1px solid #fecaca;
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .22rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .btn-adj {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .35rem .8rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        text-decoration: none;
        transition: .15s;
    }

        .btn-adj:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.show {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 18px;
        width: 90%;
        max-width: 680px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }

    .modal-hd {
        padding: 1.3rem 1.6rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .modal-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--deep);
        margin: 0;
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 1.3rem;
        color: var(--muted);
        cursor: pointer;
        padding: .2rem .5rem;
        border-radius: 6px;
    }

        .modal-close:hover {
            background: var(--warm);
        }

    .modal-body {
        padding: 1.4rem 1.6rem;
    }

    /* Toast */
    .toast-wrap {
        position: fixed;
        top: 1.2rem;
        right: 1.2rem;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        pointer-events: none;
    }

    .toast-msg {
        padding: .75rem 1.2rem;
        border-radius: 10px;
        font-size: .84rem;
        font-weight: 600;
        box-shadow: 0 8px 24px rgba(0,0,0,.14);
        pointer-events: all;
        display: flex;
        align-items: center;
        gap: .5rem;
        animation: slideIn .22s ease;
        background: #fff;
    }

    .toast-success {
        border-left: 4px solid var(--green);
        color: var(--green);
    }

    .toast-error {
        border-left: 4px solid var(--red);
        color: var(--red);
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(20px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            color: var(--gold);
            opacity: .3;
        }
</style>

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="page-hd">
        <div>
            <div class="page-label">Kho Hàng</div>
            <div class="page-title">Quản lý <em>Kho Hàng</em></div>
            <div class="page-sub">@Model.FacilityName — theo dõi tồn kho, nhập xuất và cảnh báo</div>
        </div>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
            @if (ViewBag.LowStockCount > 0)
            {
                <button class="btn-action btn-warn" onclick="openModal('lowStockModal')">
                    <i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo (@ViewBag.LowStockCount)
                </button>
            }
            <button class="btn-action btn-out" onclick="openModal('stockOutModal')">
                <i class="bi bi-box-arrow-up"></i> Xuất Kho
            </button>
            <button class="btn-action btn-in" onclick="openModal('stockInModal')">
                <i class="bi bi-box-arrow-in-down"></i> Nhập Kho
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="sc-lbl">Tổng sản phẩm</div>
            <div class="sc-val">@Model.Items.Count</div>
        </div>
        <div class="stat-card warn">
            <div class="sc-lbl">Sắp hết hàng</div>
            <div class="sc-val">@ViewBag.LowStockCount</div>
        </div>
        <div class="stat-card danger">
            <div class="sc-lbl">Hết hàng</div>
            <div class="sc-val">@ViewBag.OutOfStockCount</div>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" id="filterForm">
        <div class="filter-row">
            <select class="filter-select" name="facilityId" onchange="document.getElementById('filterForm').submit()">
                <option value="">Tất cả cơ sở</option>
                @foreach (var f in ViewBag.Facilities)
                {
                    <option value="@f.FacilityId" selected="@(Model.FacilityId == f.FacilityId)">@f.FacilityName</option>
                }
            </select>
            <select class="filter-select" name="categoryId" onchange="document.getElementById('filterForm').submit()">
                <option value="">Tất cả danh mục</option>
                @foreach (var c in ViewBag.Categories)
                {
                    <option value="@c.CategoryId">@c.CategoryName</option>
                }
            </select>
            <select class="filter-select" name="stockStatus" onchange="document.getElementById('filterForm').submit()">
                <option value="">Tất cả trạng thái</option>
                <option value="low">Sắp hết</option>
                <option value="out">Hết hàng</option>
                <option value="normal">Bình thường</option>
            </select>
            <button type="submit" class="btn-search">
                <i class="bi bi-funnel"></i> Lọc
            </button>
        </div>
    </form>

    <!-- Table -->
    <div class="table-wrap">
        @if (Model.Items != null && Model.Items.Any())
        {
            <table class="inv-table">
                <thead>
                    <tr>
                        <th>Sản Phẩm</th>
                        <th>Danh Mục</th>
                        <th>Cơ Sở</th>
                        <th>Tồn Kho</th>
                        <th>Min / Max</th>
                        <th>Trạng Thái</th>
                        <th>Cập Nhật</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:700;">@item.ProductName</div>
                                <div style="font-size:.72rem;color:var(--muted);font-family:'Courier New',monospace;">@item.ProductCode</div>
                            </td>
                            <td>
                                <span style="font-size:.78rem;color:var(--gold);font-weight:700;">@item.CategoryName</span>
                            </td>
                            <td style="font-size:.82rem;">@item.FacilityName</td>
                            <td>
                                <span style="font-weight:800;font-size:1rem;">@item.Quantity</span>
                                <span style="font-size:.75rem;color:var(--muted);"> @item.Unit</span>
                            </td>
                            <td style="font-size:.82rem;color:var(--muted);">@item.MinQuantity / @item.MaxQuantity</td>
                            <td>
                                @if (item.Quantity == 0)
                                {
                                    <span class="badge-out"><i class="bi bi-x-circle-fill"></i> Hết hàng</span>
                                }
                                else if (item.IsLowStock)
                                {
                                    <span class="badge-low"><i class="bi bi-exclamation-triangle-fill"></i> Sắp hết</span>
                                }
                                else
                                {
                                    <span class="badge-ok"><i class="bi bi-check-circle-fill"></i> Bình thường</span>
                                }
                            </td>
                            <td style="font-size:.78rem;color:var(--muted);">@item.LastUpdated.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <button class="btn-adj" onclick="openAdjModal(@item.InventoryId)">
                                    <i class="bi bi-sliders"></i> Điều chỉnh
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <p>Không tìm thấy dữ liệu kho</p>
            </div>
        }
    </div>
</div>

<!-- StockIn Modal -->
<div class="modal-overlay" id="stockInModal">
    <div class="modal-box">
        <div class="modal-hd">
            <h5 class="modal-title"><i class="bi bi-box-arrow-in-down"></i> Nhập Kho</h5>
            <button class="modal-close" onclick="closeModal('stockInModal')">&times;</button>
        </div>
        <div class="modal-body" id="stockInBody">
            <div style="text-align:center;padding:2rem;color:var(--muted);">
                <div class="spinner-border spinner-border-sm" role="status"></div> Đang tải...
            </div>
        </div>
    </div>
</div>

<!-- StockOut Modal -->
<div class="modal-overlay" id="stockOutModal">
    <div class="modal-box">
        <div class="modal-hd">
            <h5 class="modal-title"><i class="bi bi-box-arrow-up"></i> Xuất Kho</h5>
            <button class="modal-close" onclick="closeModal('stockOutModal')">&times;</button>
        </div>
        <div class="modal-body" id="stockOutBody">
            <div style="text-align:center;padding:2rem;color:var(--muted);">
                <div class="spinner-border spinner-border-sm" role="status"></div> Đang tải...
            </div>
        </div>
    </div>
</div>

<!-- Adjustment Modal -->
<div class="modal-overlay" id="adjModal">
    <div class="modal-box">
        <div class="modal-hd">
            <h5 class="modal-title"><i class="bi bi-sliders"></i> Điều Chỉnh Kho</h5>
            <button class="modal-close" onclick="closeModal('adjModal')">&times;</button>
        </div>
        <div class="modal-body" id="adjBody">
            <div style="text-align:center;padding:2rem;color:var(--muted);">
                <div class="spinner-border spinner-border-sm" role="status"></div> Đang tải...
            </div>
        </div>
    </div>
</div>

<div class="toast-wrap" id="toastWrap"></div>

@section Scripts {
    <script>
        function openModal(id) {
            document.getElementById(id).classList.add('show');
            if (id === 'stockInModal' && document.getElementById('stockInBody').innerHTML.includes('Đang tải')) {
                loadPartial('/AdminInventory/StockIn', 'stockInBody');
            }
            if (id === 'stockOutModal' && document.getElementById('stockOutBody').innerHTML.includes('Đang tải')) {
                loadPartial('/AdminInventory/StockOut', 'stockOutBody');
            }
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
        }

        function openAdjModal(inventoryId) {
            document.getElementById('adjBody').innerHTML = '<div style="text-align:center;padding:2rem;color:var(--muted);"><div class="spinner-border spinner-border-sm" role="status"></div> Đang tải...</div>';
            document.getElementById('adjModal').classList.add('show');
            loadPartial('/AdminInventory/Adjustment?inventoryId=' + inventoryId, 'adjBody');
        }

        function loadPartial(url, targetId) {
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.text())
                .then(html => {
                    const container = document.getElementById(targetId);
                    container.innerHTML = html;
                    // Re-execute any <script> tags injected via innerHTML
                    container.querySelectorAll('script').forEach(oldScript => {
                        const newScript = document.createElement('script');
                        newScript.textContent = oldScript.textContent;
                        oldScript.parentNode.replaceChild(newScript, oldScript);
                    });
                    attachFormSubmit(targetId);
                })
                .catch(() => {
                    document.getElementById(targetId).innerHTML = '<p class="text-danger">Lỗi tải dữ liệu.</p>';
                });
        }

        function attachFormSubmit(containerId) {
            const container = document.getElementById(containerId);
            const form = container.querySelector('form');
            if (!form) return;
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                const data = new FormData(form);
                fetch(form.action, { method: 'POST', body: data })
                    .then(r => r.json())
                    .then(json => {
                        showToast(json.success, json.message);
                        if (json.success) {
                            // close all modals and reload
                            document.querySelectorAll('.modal-overlay').forEach(m => m.classList.remove('show'));
                            setTimeout(() => location.reload(), 900);
                        }
                    })
                    .catch(() => showToast(false, 'Đã xảy ra lỗi!'));
            });
        }

        function showToast(success, message) {
            const wrap = document.getElementById('toastWrap');
            const el = document.createElement('div');
            el.className = 'toast-msg ' + (success ? 'toast-success' : 'toast-error');
            el.innerHTML = (success ? '<i class="bi bi-check-circle-fill"></i> ' : '<i class="bi bi-exclamation-circle-fill"></i> ') + message;
            wrap.appendChild(el);
            setTimeout(() => el.remove(), 3500);
        }

        // Close modal on overlay click
        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', function (e) {
                if (e.target === overlay) overlay.classList.remove('show');
            });
        });
    </script>
}
