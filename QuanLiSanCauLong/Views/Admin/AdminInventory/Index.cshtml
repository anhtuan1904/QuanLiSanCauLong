@model QuanLiSanCauLong.ViewModels.InventoryListViewModel

@{
    ViewData["Title"] = "Quản lý Kho hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');
    :root {
        --deep:#1a1209; --gold:#d4a017; --gold2:#f5c842;
        --cream:#f5f4ec; --warm:#f0ead8; --card:#ffffff; --border:#e4d9c8; --muted:#8a7560;
        --green:#15803d; --green-soft:#dcfce7;
        --red:#dc2626; --red-soft:#fef2f2;
        --yellow:#92600a; --yellow-soft:#fef9ec;
        --blue:#1d4ed8; --blue-soft:#eff6ff;
        --purple:#7c3aed; --purple-soft:#f5f3ff;
        --orange:#c2410c; --orange-soft:#fff7ed;
    }
    body,.container-fluid{font-family:'Outfit',sans-serif;background:var(--cream);}
    .page-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.8rem;gap:1rem;flex-wrap:wrap;}
    .page-label{font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.6rem;margin-bottom:.35rem;}
    .page-label::before{content:'';width:16px;height:1px;background:var(--gold);}
    .page-title{font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:700;color:var(--deep);margin:0;line-height:1.15;}
    .page-title em{font-style:italic;color:var(--gold);}
    .page-sub{font-size:.83rem;color:var(--muted);margin-top:.3rem;}
    .btn-action{display:inline-flex;align-items:center;gap:.5rem;padding:.6rem 1.3rem;border:none;border-radius:10px;font-family:'Outfit',sans-serif;font-size:.86rem;font-weight:700;cursor:pointer;text-decoration:none;transition:.2s;white-space:nowrap;}
    .btn-in{background:var(--gold2);color:var(--deep);box-shadow:0 2px 8px rgba(212,160,23,.3);}
    .btn-in:hover{background:var(--gold);color:#fff;}
    .btn-out{background:var(--red-soft);color:var(--red);border:1px solid #fecaca;}
    .btn-out:hover{background:var(--red);color:#fff;}
    .btn-warn{background:var(--yellow-soft);color:var(--yellow);border:1px solid #f0dea0;}
    .btn-warn:hover{background:#92600a;color:#fff;}
    .btn-rental{background:var(--blue-soft);color:var(--blue);border:1px solid #93c5fd;}
    .btn-rental:hover{background:var(--blue);color:#fff;}
    /* Stats */
    .stats-row{display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;}
    .stat-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1rem 1.4rem;flex:1;min-width:130px;box-shadow:0 1px 6px rgba(26,18,9,.05);cursor:pointer;transition:.15s;}
    .stat-card:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(26,18,9,.1);}
    .stat-card .sc-lbl{font-size:.68rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:700;}
    .stat-card .sc-val{font-size:1.6rem;font-weight:800;color:var(--deep);line-height:1.1;margin-top:.2rem;}
    .stat-card.warn .sc-val{color:var(--yellow);}
    .stat-card.danger .sc-val{color:var(--red);}
    .stat-card.hold .sc-val{color:var(--orange);}
    .stat-card.rented .sc-val{color:var(--blue);}
    .stat-card.damaged .sc-val{color:var(--purple);}
    /* Hold Alert Banner */
    .hold-alert-banner{background:linear-gradient(90deg,#fff7ed,#fef3c7);border:1.5px solid #fcd34d;border-radius:12px;padding:.85rem 1.2rem;margin-bottom:1.2rem;display:none;align-items:center;gap:.75rem;font-size:.83rem;}
    .hold-alert-banner.show{display:flex;}
    .hold-alert-banner i{font-size:1.2rem;color:var(--yellow);flex-shrink:0;}
    .hold-alert-banner a{color:var(--blue);text-decoration:none;font-weight:700;margin-left:auto;white-space:nowrap;}
    /* Filters */
    .filter-row{display:flex;gap:.75rem;margin-bottom:1.5rem;flex-wrap:wrap;}
    .filter-select{padding:.5rem 1rem;border:1px solid var(--border);border-radius:10px;font-family:'Outfit',sans-serif;font-size:.84rem;color:var(--deep);background:var(--card);cursor:pointer;outline:none;min-width:155px;box-shadow:0 1px 6px rgba(26,18,9,.05);}
    .btn-search{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.2rem;background:var(--deep);color:var(--gold2);border:none;border-radius:10px;font-family:'Outfit',sans-serif;font-size:.84rem;font-weight:700;cursor:pointer;transition:.18s;}
    .btn-search:hover{background:#2d200a;}
    /* Table */
    .table-wrap{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 2px 10px rgba(26,18,9,.05);}
    .inv-table{width:100%;border-collapse:collapse;}
    .inv-table th{background:var(--warm);padding:.75rem 1rem;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);text-align:left;border-bottom:2px solid var(--border);white-space:nowrap;}
    .inv-table td{padding:.7rem 1rem;border-bottom:1px solid #f5f0e8;font-size:.84rem;vertical-align:middle;}
    .inv-table tr:last-child td{border:none;}
    .inv-table tr:hover td{background:#fdf9f0;}
    /* Stock cell */
    .stock-cell{display:flex;flex-direction:column;gap:2px;}
    .stock-total{font-weight:800;font-size:.95rem;color:var(--deep);}
    .stock-avail{font-size:.75rem;font-weight:700;color:var(--green);}
    .stock-breakdown{display:flex;gap:.3rem;flex-wrap:wrap;margin-top:2px;}
    .stock-tag{font-size:.62rem;font-weight:700;padding:.1rem .45rem;border-radius:10px;white-space:nowrap;}
    .tag-hold{background:var(--orange-soft);color:var(--orange);}
    .tag-rented{background:var(--blue-soft);color:var(--blue);}
    .tag-damaged{background:var(--purple-soft);color:var(--purple);}
    /* Badges */
    .badge-ok{background:var(--green-soft);color:var(--green);font-size:.73rem;font-weight:700;padding:.25rem .75rem;border-radius:20px;display:inline-flex;align-items:center;gap:.3rem;}
    .badge-low{background:var(--yellow-soft);color:var(--yellow);font-size:.73rem;font-weight:700;padding:.25rem .75rem;border-radius:20px;display:inline-flex;align-items:center;gap:.3rem;}
    .badge-out{background:var(--red-soft);color:var(--red);font-size:.73rem;font-weight:700;padding:.25rem .75rem;border-radius:20px;display:inline-flex;align-items:center;gap:.3rem;}
    .badge-hold{background:var(--orange-soft);color:var(--orange);font-size:.73rem;font-weight:700;padding:.25rem .75rem;border-radius:20px;display:inline-flex;align-items:center;gap:.3rem;}
    .badge-rented{background:var(--blue-soft);color:var(--blue);font-size:.73rem;font-weight:700;padding:.25rem .75rem;border-radius:20px;display:inline-flex;align-items:center;gap:.3rem;}
    .btn-adj{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .65rem;border:1.5px solid var(--border);border-radius:8px;background:transparent;color:var(--deep);font-size:.72rem;font-weight:700;cursor:pointer;transition:.15s;}
    .btn-adj:hover{background:var(--warm);}
    .btn-hist{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .65rem;border:1.5px solid #bae6fd;border-radius:8px;background:#f0f9ff;color:#0369a1;font-size:.72rem;font-weight:700;cursor:pointer;transition:.15s;}
    .btn-hist:hover{background:#0369a1;color:#fff;}
    /* Modal */
    .modal-overlay{position:fixed;inset:0;background:rgba(26,18,9,.55);display:none;align-items:center;justify-content:center;z-index:1050;backdrop-filter:blur(4px);}
    .modal-overlay.show{display:flex;}
    .modal-box{background:var(--card);border-radius:16px;width:100%;max-width:580px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.25);}
    .modal-box.wide{max-width:840px;}
    .modal-hd{background:var(--deep);color:#fff;border-radius:16px 16px 0 0;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;align-items:center;}
    .modal-title{font-size:1rem;font-weight:800;margin:0;color:#fff;display:flex;align-items:center;gap:.6rem;}
    .modal-close{background:none;border:none;color:rgba(255,255,255,.6);font-size:1.4rem;cursor:pointer;padding:.15rem .4rem;border-radius:5px;}
    .modal-close:hover{color:#fff;background:rgba(255,255,255,.1);}
    .empty-state{text-align:center;padding:3.5rem 2rem;color:var(--muted);}
    .empty-state i{font-size:2.5rem;display:block;margin-bottom:.75rem;opacity:.4;}
    /* Toast */
    .toast-wrap{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:flex;flex-direction:column;gap:.5rem;}
    .toast-msg{background:var(--deep);color:#fff;padding:.75rem 1.25rem;border-radius:10px;font-size:.84rem;display:flex;align-items:center;gap:.5rem;animation:slideIn .3s ease;min-width:260px;}
    .toast-success{background:var(--green);}
    .toast-error{background:var(--red);}
    @@keyframes slideIn{from{opacity:0;transform:translateX(40px);}to{opacity:1;transform:translateX(0);}}
</style>

<div class="container-fluid py-4 px-4">
    <form id="__AntiForgeryForm" style="display:none;">@Html.AntiForgeryToken()</form>

    <!-- Header -->
    <div class="page-hd">
        <div>
            <div class="page-label"><i class="bi bi-boxes"></i> Quản lý kho</div>
            <h1 class="page-title">Kho <em>Hàng Hoá</em></h1>
            <p class="page-sub">Tồn thực tế · Khả dụng · Đang treo · Đang thuê · Hàng hỏng</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn-action btn-in" onclick="openModal('stockInModal')"><i class="bi bi-box-arrow-in-down"></i> Nhập Kho</button>
            <button class="btn-action btn-out" onclick="openModal('stockOutModal')"><i class="bi bi-box-arrow-up"></i> Xuất Kho</button>
            <button class="btn-action btn-rental" onclick="openModal('activeRentalModal')">
                <i class="bi bi-arrow-repeat"></i> Đang Thuê
                @if ((int)(ViewBag.RentedCount ?? 0) > 0)
                { <span style="background:var(--blue);color:#fff;border-radius:20px;padding:0 7px;font-size:.7rem;">@ViewBag.RentedCount</span> }
            </button>
            <button class="btn-action btn-warn" onclick="openModal('lowStockModal')">
                <i class="bi bi-exclamation-triangle"></i> Sắp Hết
                @if ((int)(ViewBag.LowStockCount ?? 0) > 0)
                { <span style="background:var(--yellow);color:#fff;border-radius:20px;padding:0 7px;font-size:.7rem;">@ViewBag.LowStockCount</span> }
            </button>
        </div>
    </div>

    <!-- Hold Alert Banner -->
    <div class="hold-alert-banner" id="holdAlertBanner">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>Có <strong id="holdAlertCount">0</strong> sản phẩm đang <strong>treo ở đơn chưa thanh toán</strong> quá 2 giờ!</span>
        <a href="#" onclick="loadHoldAlerts(); return false;">Xem chi tiết →</a>
    </div>

    <!-- Stats (clickable to filter) -->
    <div class="stats-row">
        <div class="stat-card" onclick="filterByStatus('')"><div class="sc-lbl">Tổng mặt hàng</div><div class="sc-val">@(Model.Items?.Count ?? 0)</div></div>
        <div class="stat-card rented" onclick="filterByStatus('rented')"><div class="sc-lbl">Đang cho thuê</div><div class="sc-val">@ViewBag.RentedCount</div></div>
        <div class="stat-card hold" onclick="filterByStatus('hold')"><div class="sc-lbl">Hàng treo đơn</div><div class="sc-val">@ViewBag.HoldCount</div></div>
        <div class="stat-card warn" onclick="filterByStatus('low')"><div class="sc-lbl">Sắp hết hàng</div><div class="sc-val">@ViewBag.LowStockCount</div></div>
        <div class="stat-card danger" onclick="filterByStatus('out')"><div class="sc-lbl">Hết hàng</div><div class="sc-val">@ViewBag.OutOfStockCount</div></div>
        <div class="stat-card damaged" onclick="filterByStatus('damaged')"><div class="sc-lbl">Hàng hỏng</div><div class="sc-val">@ViewBag.DamagedCount</div></div>
    </div>

    <!-- Filters -->
    <form method="get" id="filterForm">
        <div class="filter-row">
            <select class="filter-select" name="facilityId" onchange="this.form.submit()">
                <option value="">Tất cả cơ sở</option>
                @foreach (var f in ViewBag.Facilities)
                {
                    <option value="@f.FacilityId" selected="@(Model.FacilityId == f.FacilityId)">
                        @f.FacilityName
                    </option>
                }
            </select>
            <select class="filter-select" name="categoryId" onchange="this.form.submit()">
                <option value="">Tất cả danh mục</option>
                @foreach (var c in ViewBag.Categories) { <option value="@c.CategoryId">@c.CategoryName</option> }
            </select>
            <select class="filter-select" name="behaviorType" onchange="this.form.submit()">
                <option value="">Tất cả hành vi</option>
                <option value="Retail">🛒 Bán lẻ</option>
                <option value="Rental">🔄 Cho thuê</option>
            </select>
            <select class="filter-select" name="stockStatus" id="stockStatusSel" onchange="this.form.submit()">
                <option value="">Tất cả trạng thái</option>
                <option value="low">⚠️ Sắp hết</option>
                <option value="out">🚫 Hết hàng</option>
                <option value="hold">🔒 Đang treo đơn</option>
                <option value="rented">🔄 Đang cho thuê</option>
                <option value="damaged">💔 Hàng hỏng</option>
            </select>
            <button type="submit" class="btn-search"><i class="bi bi-funnel"></i> Lọc</button>
        </div>
    </form>

    <!-- Table -->
    <div class="table-wrap">
        @if (Model.Items != null && Model.Items.Any())
        {
            <table class="inv-table">
                <thead>
                    <tr>
                        <th>Sản Phẩm</th>
                        <th>Danh Mục</th>
                        <th>Cơ Sở</th>
                        <th>Tồn / Khả Dụng</th>
                        <th>Trạng Thái</th>
                        <th>Min / Max</th>
                        <th>Cập Nhật</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:700;">@item.ProductName</div>
                                <div style="font-size:.72rem;color:var(--muted);font-family:'Courier New',monospace;">@item.ProductCode</div>
                            </td>
                            <td>
                                <span style="font-size:.78rem;color:var(--gold);font-weight:700;">@item.CategoryName</span>
                                @if (!string.IsNullOrEmpty(item.BehaviorType) && item.BehaviorType != "Retail")
                                { <div style="font-size:.65rem;color:var(--muted);">@(item.BehaviorType=="Rental"?"🔄 Cho thuê":"🔧 Dịch vụ")</div> }
                            </td>
                            <td style="font-size:.82rem;">@item.FacilityName</td>
                            <td>
                                <div class="stock-cell">
                                    <span class="stock-total">@item.Quantity <span style="font-size:.72rem;font-weight:400;color:var(--muted);">@item.Unit</span></span>
                                    <span class="stock-avail">✓ KD: @item.AvailableQuantity</span>
                                    <div class="stock-breakdown">
                                        @if (item.HoldQuantity > 0)    { <span class="stock-tag tag-hold">🔒 @item.HoldQuantity</span> }
                                        @if (item.RentedQuantity > 0)  { <span class="stock-tag tag-rented">🔄 @item.RentedQuantity</span> }
                                        @if (item.DamagedQuantity > 0) { <span class="stock-tag tag-damaged">💔 @item.DamagedQuantity</span> }
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (item.AvailableQuantity == 0)    { <span class="badge-out"><i class="bi bi-x-circle-fill"></i> Hết KD</span> }
                                else if (item.IsLowStock)            { <span class="badge-low"><i class="bi bi-exclamation-triangle-fill"></i> Sắp hết</span> }
                                else if (item.RentedQuantity > 0)   { <span class="badge-rented"><i class="bi bi-arrow-repeat"></i> Đang thuê</span> }
                                else if (item.HoldQuantity > 0)     { <span class="badge-hold"><i class="bi bi-lock-fill"></i> Treo đơn</span> }
                                else                                 { <span class="badge-ok"><i class="bi bi-check-circle-fill"></i> Bình thường</span> }
                            </td>
                            <td style="font-size:.82rem;color:var(--muted);">@item.MinQuantity / @item.MaxQuantity</td>
                            <td style="font-size:.78rem;color:var(--muted);">@item.LastUpdated.ToString("dd/MM HH:mm")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <button class="btn-adj" onclick="openAdjModal(@item.InventoryId)" title="Điều chỉnh"><i class="bi bi-sliders"></i></button>
                                    <button class="btn-hist" onclick="openHistoryModal(@item.ProductId)" title="Lịch sử"><i class="bi bi-clock-history"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state"><i class="bi bi-box-seam"></i><p>Không tìm thấy dữ liệu kho</p></div>
        }
    </div>
</div>

<!-- Modals -->
<div class="modal-overlay" id="stockInModal">
    <div class="modal-box"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-box-arrow-in-down"></i> Nhập Kho</h5><button class="modal-close" onclick="closeModal('stockInModal')">&times;</button></div><div id="stockInBody" style="padding:0;"><div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div></div></div>
</div>
<div class="modal-overlay" id="stockOutModal">
    <div class="modal-box"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-box-arrow-up"></i> Xuất Kho</h5><button class="modal-close" onclick="closeModal('stockOutModal')">&times;</button></div><div id="stockOutBody"><div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div></div></div>
</div>
<div class="modal-overlay" id="adjModal">
    <div class="modal-box"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-sliders"></i> Điều Chỉnh Kho</h5><button class="modal-close" onclick="closeModal('adjModal')">&times;</button></div><div id="adjBody"><div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div></div></div>
</div>
<div class="modal-overlay" id="lowStockModal">
    <div class="modal-box wide"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Hàng Sắp Hết / Hết</h5><button class="modal-close" onclick="closeModal('lowStockModal')">&times;</button></div><div id="lowStockBody"><div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div></div></div>
</div>
<div class="modal-overlay" id="activeRentalModal">
    <div class="modal-box wide"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-arrow-repeat"></i> Hàng Đang Cho Thuê</h5><button class="modal-close" onclick="closeModal('activeRentalModal')">&times;</button></div><div id="activeRentalBody" style="padding:1.25rem;"><div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div></div></div>
</div>
<div class="modal-overlay" id="holdAlertModal">
    <div class="modal-box"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-lock-fill"></i> Hàng Treo Quá Lâu</h5><button class="modal-close" onclick="closeModal('holdAlertModal')">&times;</button></div><div id="holdAlertBody" style="padding:1.25rem;"></div></div>
</div>
<div class="modal-overlay" id="historyModal">
    <div class="modal-box wide"><div class="modal-hd"><h5 class="modal-title"><i class="bi bi-clock-history"></i> Lịch Sử Giao Dịch</h5><button class="modal-close" onclick="closeModal('historyModal')">&times;</button></div><div id="historyBody"><div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div></div></div>
</div>

<div class="toast-wrap" id="toastWrap"></div>

@section Scripts {
<script>
    function openModal(id) {
        document.getElementById(id).classList.add('show');
        const bodyMap = { stockInModal:['StockIn','stockInBody'], stockOutModal:['StockOut','stockOutBody'], lowStockModal:['LowStock','lowStockBody'], activeRentalModal:['ActiveRentals','activeRentalBody'] };
        if (bodyMap[id]) {
            const [action, bodyId] = bodyMap[id];
            const el = document.getElementById(bodyId);
            if (!el.dataset.loaded) { loadPartial('/AdminInventory/'+action, bodyId); el.dataset.loaded='1'; }
        }
    }
    function closeModal(id) { document.getElementById(id).classList.remove('show'); }
    function openAdjModal(invId) {
        const el = document.getElementById('adjBody'); el.dataset.loaded=''; el.innerHTML='<div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div>';
        document.getElementById('adjModal').classList.add('show');
        loadPartial('/AdminInventory/Adjustment?inventoryId='+invId,'adjBody');
    }
    function openHistoryModal(pid) {
        const el = document.getElementById('historyBody'); el.innerHTML='<div style="text-align:center;padding:2rem;"><div class="spinner-border spinner-border-sm"></div></div>';
        document.getElementById('historyModal').classList.add('show');
        loadPartial('/AdminInventory/History?productId='+pid,'historyBody');
    }
    function loadPartial(url, targetId) {
        fetch(url, {headers:{'X-Requested-With':'XMLHttpRequest'}})
            .then(r=>r.text()).then(html=>{
                const c = document.getElementById(targetId);
                c.innerHTML=html;
                c.querySelectorAll('script').forEach(s=>{const ns=document.createElement('script');ns.textContent=s.textContent;s.parentNode.replaceChild(ns,s);});
                attachFormSubmit(targetId);
            }).catch(()=>{ document.getElementById(targetId).innerHTML='<p class="text-danger p-3">Lỗi tải dữ liệu.</p>'; });
    }
    function attachFormSubmit(cid) {
        const form = document.getElementById(cid)?.querySelector('form');
        if (!form) return;
        form.addEventListener('submit', function(e){
            e.preventDefault();
            fetch(form.action,{method:'POST',body:new FormData(form)}).then(r=>r.json()).then(json=>{
                showToast(json.success,json.message);
                if(json.success){document.querySelectorAll('.modal-overlay').forEach(m=>m.classList.remove('show'));setTimeout(()=>location.reload(),900);}
            }).catch(()=>showToast(false,'Đã xảy ra lỗi!'));
        });
    }
    function filterByStatus(status) {
        document.getElementById('stockStatusSel').value=status;
        document.getElementById('filterForm').submit();
    }
    async function checkHoldAlerts() {
        try {
            const data=await fetch('/AdminInventory/HoldAlerts').then(r=>r.json());
            if(data.length>0){document.getElementById('holdAlertCount').textContent=data.length;document.getElementById('holdAlertBanner').classList.add('show');window._holdAlerts=data;}
        } catch{}
    }
    function loadHoldAlerts() {
        const data=window._holdAlerts||[];
        document.getElementById('holdAlertBody').innerHTML=!data.length?'<p class="p-3 text-muted">Không có cảnh báo.</p>':data.map(a=>`<div style="background:#fff7ed;border:1px solid #fcd34d;border-radius:10px;padding:.85rem 1rem;margin-bottom:.6rem;"><div style="font-weight:800;font-size:.88rem;">${a.productName}</div><div style="font-size:.75rem;color:#92600a;margin-top:.2rem;">SL: ${a.quantity} · ${a.facilityName} · Đơn #${a.orderId||'—'} · Treo ${a.hoursAgo}h trước</div></div>`).join('');
        document.getElementById('holdAlertModal').classList.add('show');
    }
    function showToast(ok,msg){const el=document.createElement('div');el.className='toast-msg '+(ok?'toast-success':'toast-error');el.innerHTML=(ok?'<i class="bi bi-check-circle-fill"></i> ':'<i class="bi bi-exclamation-circle-fill"></i> ')+msg;document.getElementById('toastWrap').appendChild(el);setTimeout(()=>el.remove(),3500);}
    document.querySelectorAll('.modal-overlay').forEach(o=>{o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('show');});});
    checkHoldAlerts();
</script>
}
