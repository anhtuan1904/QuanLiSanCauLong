@model QuanLiSanCauLong.ViewModels.InventoryListViewModel
@{
    ViewData["Title"] = "Quản lý Kho";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    int lowCnt = ViewBag.LowStockCount ?? 0;
    int outCnt = ViewBag.OutOfStockCount ?? 0;
    int holdCnt = ViewBag.HoldCount ?? 0;
    int rentedCnt = ViewBag.RentedCount ?? 0;
    int damagedCnt = ViewBag.DamagedCount ?? 0;
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
    var categories = ViewBag.Categories as IEnumerable<QuanLiSanCauLong.Models.ProductCategory> ?? Enumerable.Empty<QuanLiSanCauLong.Models.ProductCategory>();
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
        --purple: #7c3aed;
        --orange: #c2410c;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }
    /* Header */
    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .hd-btns {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .btn-in {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .65rem 1.2rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
        text-decoration: none;
    }

        .btn-in:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
            color: var(--deep);
        }

    .btn-out {
        background: rgba(201,75,42,.07);
        color: var(--red);
        border: 1.5px solid rgba(201,75,42,.25);
        padding: .62rem 1.15rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-out:hover {
            background: var(--red);
            color: #fff;
            border-color: var(--red);
        }

    .btn-sec {
        padding: .62rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        transition: all .18s;
        text-decoration: none;
    }

        .btn-sec:hover {
            border-color: var(--deep);
            color: var(--deep);
        }
    /* Alerts */
    .alert-banner {
        padding: .75rem 1.1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: .82rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        display: none;
    }

        .alert-banner.show {
            display: flex;
        }

    .ab-warn {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        color: #c2410c;
    }
    /* Stats strip */
    .stats {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.4rem;
    }

    .sb {
        background: #fff;
        padding: .82rem 1.1rem;
        flex: 1;
        min-width: 0;
        cursor: pointer;
        transition: background .15s;
    }

        .sb:hover {
            background: var(--cream);
        }

        .sb.on {
            background: var(--deep);
        }

            .sb.on .sn {
                color: var(--gold2);
            }

            .sb.on .sl {
                color: rgba(255,255,255,.45);
            }

    .sn {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1;
        color: var(--deep);
    }

    .sl {
        font-size: .62rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .18rem;
        display: flex;
        align-items: center;
        gap: .25rem;
    }

    .sdot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    /* Toolbar */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .srch {
        flex: 1;
        min-width: 220px;
        position: relative;
    }

        .srch i {
            position: absolute;
            left: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

        .srch input {
            width: 100%;
            padding: .58rem .85rem .58rem 2.2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .83rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .srch input:focus {
                border-color: var(--gold);
            }

    .sel {
        padding: .58rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .sel:focus {
            border-color: var(--gold);
        }
    /* Table */
    .tbl-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .itbl {
        width: 100%;
        border-collapse: collapse;
    }

        .itbl th {
            padding: .72rem 1rem;
            background: var(--warm);
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .itbl td {
            padding: .78rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .83rem;
            color: var(--deep);
            vertical-align: middle;
        }

        .itbl tr:last-child td {
            border-bottom: none;
        }

        .itbl tr:hover td {
            background: var(--cream);
        }
    /* Product cell */
    .p-cell {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .p-thumb {
        width: 34px;
        height: 34px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .p-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 6px;
        }

        .p-thumb i {
            font-size: .8rem;
            color: var(--muted);
        }

    .p-name {
        font-weight: 700;
        font-size: .84rem;
        color: var(--deep);
        line-height: 1.2;
    }

    .p-sku {
        font-size: .66rem;
        color: var(--muted);
        font-family: monospace;
    }
    /* Badges */
    .bh-b {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .18rem .55rem;
        border-radius: 4px;
        font-size: .64rem;
        font-weight: 700;
    }
    /* Stock numbers */
    .stk-main {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
    }

    .stk-ok {
        color: var(--green);
    }

    .stk-low {
        color: #c2410c;
    }

    .stk-zero {
        color: var(--red);
    }

    .stk-sub {
        font-size: .66rem;
        color: var(--muted);
        margin-top: .1rem;
    }
    /* Progress bar */
    .stk-bar {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        width: 70px;
        margin-top: .3rem;
    }

    .stk-bar-fill {
        height: 100%;
        border-radius: 2px;
        transition: width .3s;
    }
    /* Rent indicator */
    .rent-chip {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        padding: .12rem .42rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 4px;
        font-size: .62rem;
        font-weight: 700;
        color: var(--blue);
    }

    .dmg-chip {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        padding: .12rem .42rem;
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        border-radius: 4px;
        font-size: .62rem;
        font-weight: 700;
        color: var(--purple);
    }
    /* Quick actions */
    .qa {
        display: flex;
        gap: .25rem;
        justify-content: flex-end;
    }

    .qa-b {
        width: 28px;
        height: 28px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
        font-size: .72rem;
    }

        .qa-b.qin:hover {
            border-color: var(--gold);
            color: var(--deep);
            background: rgba(212,160,23,.07);
        }

        .qa-b.qout:hover {
            border-color: var(--red);
            color: var(--red);
            background: rgba(201,75,42,.07);
        }

        .qa-b.qhist:hover {
            border-color: var(--blue);
            color: var(--blue);
            background: rgba(29,78,216,.07);
        }

        .qa-b.qadj:hover {
            border-color: var(--purple);
            color: var(--purple);
            background: rgba(124,58,237,.07);
        }
    /* Empty */
    .empty-row td {
        text-align: center;
        padding: 4rem;
        color: var(--muted);
    }

    .empty-row i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: .75rem;
        opacity: .2;
    }
    /* Pager */
    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.2rem;
        border-top: 1px solid var(--border);
        font-size: .78rem;
        color: var(--muted);
    }

    .pg-btns {
        display: flex;
        gap: .3rem;
    }

    .pg-b {
        min-width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        font-size: .76rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .15s;
    }

        .pg-b:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

        .pg-b.on {
            background: var(--deep);
            border-color: var(--deep);
            color: var(--gold2);
        }
</style>

<div class="pg">
    <!-- HEADER -->
    <div class="pg-hd">
        <div>
            <h1 class="pg-title">Kho <em>Hàng Hóa</em></h1>
            <div class="pg-sub">Quản lý tồn kho, nhập xuất, cho thuê toàn cơ sở</div>
        </div>
        <div class="hd-btns">
            <button class="btn-in" onclick="openModal('StockIn')">
                <i class="bi bi-box-arrow-in-down"></i> Nhập kho
            </button>
            <button class="btn-out" onclick="openModal('StockOut')">
                <i class="bi bi-box-arrow-up"></i> Xuất kho
            </button>
            <a href="@Url.Action("ActiveRentals", "AdminInventory")" class="btn-sec">
                <i class="bi bi-arrow-repeat"></i> Đang thuê
            </a>
            <a href="@Url.Action("LowStock", "AdminInventory")" class="btn-sec" @(outCnt + lowCnt > 0 ? "style=\"border-color:#c2410c;color:#c2410c;\"" : "")>
                <i class="bi bi-exclamation-triangle"></i> Cảnh báo @(outCnt + lowCnt > 0 ? $"({outCnt + lowCnt})" : "")
            </a>
        </div>
    </div>

    <!-- HOLD ALERT -->
    <div class="alert-banner ab-warn" id="holdBanner">
        <i class="bi bi-clock-fill"></i>
        <span id="holdBannerText">Có đơn hold quá lâu</span>
        <a href="#" style="margin-left:auto;color:var(--blue);font-weight:700;font-size:.78rem;" onclick="clearOldHolds()">Xem chi tiết</a>
    </div>

    <!-- STATS STRIP -->
    <div class="stats">
        <div class="sb" id="sbAll" onclick="filterBy('all')">
            <div class="sn">@Model.Items.Count</div>
            <div class="sl"><span class="sdot" style="background:var(--gold)"></span>Tổng mục</div>
        </div>
        <div class="sb" id="sbOut" onclick="filterBy('out')">
            <div class="sn" style="color:var(--red)">@outCnt</div>
            <div class="sl"><span class="sdot" style="background:var(--red)"></span>Hết hàng</div>
        </div>
        <div class="sb" id="sbLow" onclick="filterBy('low')">
            <div class="sn" style="color:#c2410c">@lowCnt</div>
            <div class="sl"><span class="sdot" style="background:#c2410c"></span>Sắp hết</div>
        </div>
        <div class="sb" id="sbHold" onclick="filterBy('hold')">
            <div class="sn" style="color:var(--orange)">@holdCnt</div>
            <div class="sl"><span class="sdot" style="background:var(--orange)"></span>Đang giữ</div>
        </div>
        <div class="sb" id="sbRented" onclick="filterBy('rented')">
            <div class="sn" style="color:var(--blue)">@rentedCnt</div>
            <div class="sl"><span class="sdot" style="background:var(--blue)"></span>Đang thuê</div>
        </div>
        <div class="sb" id="sbDamaged" onclick="filterBy('damaged')">
            <div class="sn" style="color:var(--purple)">@damagedCnt</div>
            <div class="sl"><span class="sdot" style="background:var(--purple)"></span>Hư hỏng</div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="srch">
            <i class="bi bi-search"></i>
            <input type="text" id="srchIn" placeholder="Tên sản phẩm, SKU..." oninput="filterTable()" />
        </div>
        <select class="sel" id="fFac" onchange="filterTable()">
            <option value="">Tất cả cơ sở</option>
            @foreach (var f in facilities)
            {
                <option value="@f.FacilityName" selected="@(Model.FacilityId == f.FacilityId)">@f.FacilityName</option>
            }
        </select>
        <select class="sel" id="fCat" onchange="filterTable()">
            <option value="">Tất cả danh mục</option>
            @foreach (var c in categories)
            {
                <option value="@c.CategoryName">@c.CategoryName</option>
            }
        </select>
        <select class="sel" id="fBh" onchange="filterTable()">
            <option value="">Tất cả nhóm</option>
            <option value="Retail">Bán lẻ</option>
            <option value="Rental">Cho thuê</option>
            <option value="Service">Dịch vụ</option>
        </select>
    </div>

    <!-- TABLE -->
    <div class="tbl-wrap">
        <table class="itbl">
            <thead>
                <tr>
                    <th style="width:40px"><input type="checkbox" id="chkAll" onchange="toggleAll(this)" /></th>
                    <th>Sản phẩm</th>
                    <th style="width:110px">Cơ sở</th>
                    <th style="width:100px">Nhóm</th>
                    <th style="width:130px;text-align:right">Tồn kho</th>
                    <th style="width:110px;text-align:center">Trạng thái</th>
                    <th style="width:120px;text-align:right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="invTbody">
                @if (!Model.Items.Any())
                {
                    <tr class="empty-row">
                        <td colspan="7">
                            <i class="bi bi-archive"></i>
                            <div style="font-weight:700;margin-bottom:.3rem;">Kho trống</div>
                            <div style="font-size:.8rem;">Nhấn <strong>Nhập kho</strong> để thêm hàng.</div>
                        </td>
                    </tr>
                }
                @foreach (var item in Model.Items)
                {
                    var bh = item.BehaviorType ?? "Retail";
                    var stkCls = item.AvailableQuantity <= 0 ? "stk-zero" : item.IsLowStock ? "stk-low" : "stk-ok";
                    var pct = item.MaxQuantity > 0 ? (int)((double)item.AvailableQuantity / item.MaxQuantity * 100) : 50;
                    var barClr = item.AvailableQuantity <= 0 ? "var(--red)" : item.IsLowStock ? "#c2410c" : "var(--green)";
                    <tr id="inv-@item.InventoryId"
                        data-name="@item.ProductName.ToLower()"
                        data-sku="@((item.ProductCode ?? "").ToLower())"
                        data-fac="@(item.FacilityName ?? "")"
                        data-cat="@(item.CategoryName ?? "")"
                        data-bh="@bh"
                        data-stock="@(item.AvailableQuantity <= 0 ? "out" : item.IsLowStock ? "low" : "ok")"
                        data-hold="@(item.HoldQuantity > 0 ? "hold" : "")"
                        data-rented="@(item.RentedQuantity > 0 ? "rented" : "")"
                        data-damaged="@(item.DamagedQuantity > 0 ? "damaged" : "")">
                        <td><input type="checkbox" class="row-cb" value="@item.InventoryId" /></td>
                        <td>
                            <div class="p-cell">
                                <div class="p-thumb"><i class="bi @(bh == "Service" ? "bi-wrench-adjustable" : bh == "Rental" ? "bi-arrow-repeat" : "bi-box-seam")"></i></div>
                                <div>
                                    <div class="p-name">@item.ProductName</div>
                                    <div class="p-sku">@(item.ProductCode ?? "—")</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-size:.78rem;color:var(--muted);">@(item.FacilityName ?? "—")</td>
                        <td>
                            <span class="bh-b" style="background:@(bh == "Rental" ? "#eff6ff" : bh == "Service" ? "#f5f3ff" : "#f0fdf4");color:@(bh == "Rental" ? "#1d4ed8" : bh == "Service" ? "#7c3aed" : "#166534");">
                                <i class="bi @(bh == "Rental" ? "bi-arrow-repeat" : bh == "Service" ? "bi-wrench-adjustable" : "bi-cart3")"></i>
                                @(bh == "Rental" ? "Cho thuê" : bh == "Service" ? "Dịch vụ" : "Bán lẻ")
                            </span>
                        </td>
                        <td style="text-align:right;">
                            @if (bh == "Service")
                            {
                                <span style="font-size:.78rem;color:var(--muted);">Không tồn kho</span>
                            }
                            else
                            {
                                <div class="@stkCls stk-main">@item.AvailableQuantity <span style="font-size:.65rem;font-weight:400;color:var(--muted);">@item.Unit</span></div>
                                @if (item.Quantity != item.AvailableQuantity)
                                {
                                    <div class="stk-sub">Tổng: @item.Quantity</div>
                                }
                                @if (item.MaxQuantity > 0)
                                {
                                    <div class="stk-bar">
                                        <div class="stk-bar-fill" style="width:@(Math.Min(pct, 100))%;background:@barClr;"></div>
                                    </div>
                                }
                                @if (item.RentedQuantity > 0)
                                {
                                    <span class="rent-chip"><i class="bi bi-person-fill"></i> @item.RentedQuantity thuê</span>
                                }
                                @if (item.DamagedQuantity > 0)
                                {
                                    <span class="dmg-chip"><i class="bi bi-tools"></i> @item.DamagedQuantity hỏng</span>
                                }
                            }
                        </td>
                        <td style="text-align:center;">
                            @if (item.AvailableQuantity <= 0 && bh != "Service")
                            {
                                <span style="display:inline-flex;align-items:center;gap:.22rem;padding:.18rem .55rem;border-radius:4px;font-size:.64rem;font-weight:700;background:#fee2e2;color:var(--red);">
                                    <i class="bi bi-x-circle-fill"></i> Hết hàng
                                </span>
                            }
                            else if (item.IsLowStock && bh != "Service")
                            {
                                <span style="display:inline-flex;align-items:center;gap:.22rem;padding:.18rem .55rem;border-radius:4px;font-size:.64rem;font-weight:700;background:#fff7ed;color:#c2410c;">
                                    <i class="bi bi-exclamation-triangle-fill"></i> Sắp hết
                                </span>
                            }
                            else
                            {
                                <span style="display:inline-flex;align-items:center;gap:.22rem;padding:.18rem .55rem;border-radius:4px;font-size:.64rem;font-weight:700;background:#f0fdf4;color:#15803d;">
                                    <i class="bi bi-check-circle-fill"></i> Bình thường
                                </span>
                            }
                        </td>
                        <td>
                            <div class="qa">
                                <button class="qa-b qin" onclick="openStockIn(@item.InventoryId,'@Html.Raw(item.ProductName.Replace("'", "\'"))',@(item.FacilityId),@(item.ProductId))" title="Nhập kho">
                                    <i class="bi bi-box-arrow-in-down"></i>
                                </button>
                                @if (bh != "Service")
                                {
                                    <button class="qa-b qout" onclick="openStockOut(@item.InventoryId,'@Html.Raw(item.ProductName.Replace("'", "\'"))',@(item.FacilityId),@(item.ProductId),@item.AvailableQuantity)" title="Xuất kho">
                                        <i class="bi bi-box-arrow-up"></i>
                                    </button>
                                }
                                <button class="qa-b qadj" onclick="openAdjust(@item.InventoryId)" title="Điều chỉnh tồn kho">
                                    <i class="bi bi-sliders"></i>
                                </button>
                                <button class="qa-b qhist" onclick="openHistory(@item.ProductId,'@Html.Raw(item.ProductName.Replace("'", "\'"))')" title="Lịch sử">
                                    <i class="bi bi-clock-history"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pager">
            <span id="rowCount">@Model.Items.Count mục</span>
            <div class="pg-btns" id="pagerBtns"></div>
        </div>
    </div>
</div>

<!-- MODAL SHELL -->
<div class="modal fade" id="invModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable" style="max-width:680px">
        <div class="modal-content" id="invModalBody" style="border-radius:14px;border:none;">
            <div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        let invModal;
        document.addEventListener('DOMContentLoaded', () => {
            invModal = new bootstrap.Modal(document.getElementById('invModal'));
            checkHoldAlerts();
        });

        function runScripts(el) {
            el.querySelectorAll('script').forEach(s => { const n = document.createElement('script'); n.text = s.text; s.replaceWith(n); });
        }

        async function openModal(action, params = '') {
            document.getElementById('invModalBody').innerHTML = '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            invModal.show();
            const url = `/AdminInventory/${action}${params ? '?' + params : ''}`;
            const r   = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            document.getElementById('invModalBody').innerHTML = await r.text();
            runScripts(document.getElementById('invModalBody'));
        }

        function openStockIn(invId, name, facilityId, productId) {
            openModal('StockIn', `facilityId=${facilityId}&preProductId=${productId}&invId=${invId}&preProductName=${encodeURIComponent(name)}`);
        }
        function openStockOut(invId, name, facilityId, productId, available) {
            openModal('StockOut', `facilityId=${facilityId}&preProductId=${productId}&invId=${invId}&preProductName=${encodeURIComponent(name)}&available=${available}`);
        }
        function openAdjust(invId) {
            openModal('Adjustment', `inventoryId=${invId}`);
        }
        function openHistory(productId, name) {
            openModal('History', `productId=${productId}`);
        }

        /* ── FILTER ── */
        let filterMode = 'all';
        function filterBy(mode) {
            filterMode = mode;
            document.querySelectorAll('.sb').forEach(b => b.classList.remove('on'));
            document.getElementById('sb' + mode.charAt(0).toUpperCase() + mode.slice(1).replace('all','All').replace('out','Out').replace('low','Low').replace('hold','Hold').replace('rented','Rented').replace('damaged','Damaged'))?.classList.add('on');
            if (mode === 'all') document.getElementById('sbAll')?.classList.add('on');
            filterTable();
        }

        function filterTable() {
            const q   = document.getElementById('srchIn').value.toLowerCase();
            const fac = document.getElementById('fFac').value;
            const cat = document.getElementById('fCat').value;
            const bh  = document.getElementById('fBh').value;
            let cnt = 0;
            document.querySelectorAll('#invTbody tr[id^="inv-"]').forEach(r => {
                const matchSearch = !q || r.dataset.name?.includes(q) || r.dataset.sku?.includes(q);
                const matchFac    = !fac || r.dataset.fac === fac;
                const matchCat    = !cat || r.dataset.cat === cat;
                const matchBh     = !bh  || r.dataset.bh  === bh;
                const matchMode   = filterMode === 'all' || r.dataset.stock === filterMode || r.dataset[filterMode];
                const show = matchSearch && matchFac && matchCat && matchBh && matchMode;
                r.style.display = show ? '' : 'none';
                if (show) cnt++;
            });
            document.getElementById('rowCount').textContent = cnt + ' mục';
        }

        /* ── HOLD ALERTS ── */
        async function checkHoldAlerts() {
            try {
                const data = await fetch('/AdminInventory/HoldAlerts').then(r => r.json());
                if (data.length > 0) {
                    document.getElementById('holdBannerText').textContent =
                        `⚠ Có ${data.length} đơn hold quá lâu (>${Math.round(data[0].hoursAgo)}h) — cần xử lý`;
                    document.getElementById('holdBanner').classList.add('show');
                }
            } catch(e) {}
        }

        function toggleAll(el) { document.querySelectorAll('.row-cb').forEach(c => c.checked = el.checked); }

        // Init filter stats
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('sbAll')?.classList.add('on');
        });
    </script>
}
