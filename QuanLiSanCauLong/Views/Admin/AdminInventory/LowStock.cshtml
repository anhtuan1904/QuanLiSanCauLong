@model QuanLiSanCauLong.ViewModels.LowStockViewModel
@{
    ViewData["Title"] = "Cảnh báo Tồn Kho";
    var isPartial = ViewContext.HttpContext.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isPartial ? null : "~/Views/Shared/_LayoutAdmin.cshtml";
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
}
<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }

    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .62rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        transition: all .18s;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep);
        }
    /* Stats strip */
    .stats {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.4rem;
    }

    .sb {
        background: #fff;
        padding: .82rem 1.1rem;
        flex: 1;
        min-width: 0;
        cursor: pointer;
        transition: background .15s;
    }

        .sb:hover {
            background: var(--cream);
        }

        .sb.on {
            background: var(--deep);
        }

            .sb.on .sn {
                color: var(--gold2);
            }

            .sb.on .sl {
                color: rgba(255,255,255,.45);
            }

    .sn {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1;
        color: var(--deep);
    }

    .sl {
        font-size: .62rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .18rem;
    }
    /* Toolbar */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .srch {
        flex: 1;
        min-width: 220px;
        position: relative;
    }

        .srch i {
            position: absolute;
            left: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

        .srch input {
            width: 100%;
            padding: .58rem .85rem .58rem 2.2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .83rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .srch input:focus {
                border-color: var(--gold);
            }

    .sel {
        padding: .58rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .sel:focus {
            border-color: var(--gold);
        }
    /* Table */
    .tbl-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        padding: .72rem 1rem;
        background: var(--warm);
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }

    td {
        padding: .78rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: .83rem;
        color: var(--deep);
        vertical-align: middle;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tr:hover td {
        background: var(--cream);
    }

    tr.row-danger td {
        background: #fef2f2;
    }
    /* Product cell */
    .p-cell {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .p-thumb {
        width: 34px;
        height: 34px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
    }

        .p-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .p-thumb i {
            font-size: .8rem;
            color: var(--muted);
        }

    .p-name {
        font-weight: 700;
        font-size: .84rem;
        color: var(--deep);
        line-height: 1.2;
    }

    .p-meta {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .1rem;
    }
    /* Stock */
    .stk-main {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
    }

    .stk-zero {
        color: var(--red);
    }

    .stk-low {
        color: var(--orange);
    }

    .stk-bar {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        width: 80px;
        margin-top: .3rem;
    }

    .stk-bar-fill {
        height: 100%;
        border-radius: 2px;
    }
    /* Badges */
    .fl-badge {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        padding: .16rem .5rem;
        border-radius: 4px;
        font-size: .62rem;
        font-weight: 700;
        margin: .1rem .1rem 0 0;
    }

    .fb-out {
        background: #fee2e2;
        color: var(--red);
    }

    .fb-low {
        background: #fff7ed;
        color: var(--orange);
    }

    .fb-exp {
        background: #fef9c3;
        color: #92600a;
    }

    .fb-xprd {
        background: #fef2f2;
        color: var(--red);
    }

    .fb-dmg {
        background: #f5f3ff;
        color: var(--purple);
    }
    /* Variant chips */
    .var-chip {
        display: inline-block;
        padding: .1rem .4rem;
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        border-radius: 4px;
        font-size: .6rem;
        color: var(--purple);
        margin: .1rem .1rem 0 0;
    }
    /* Expiry */
    .exp-ok {
        color: var(--muted);
        font-size: .76rem;
    }

    .exp-soon {
        color: #92600a;
        font-weight: 700;
        font-size: .76rem;
    }

    .exp-dead {
        color: var(--red);
        font-weight: 700;
        font-size: .76rem;
    }
    /* Actions */
    .act-g {
        display: flex;
        gap: .25rem;
        justify-content: flex-end;
    }

    .act-b {
        min-width: 28px;
        height: 28px;
        padding: 0 .5rem;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .72rem;
        font-weight: 600;
        transition: all .15s;
        white-space: nowrap;
        gap: .25rem;
        text-decoration: none;
        color: var(--muted);
    }

        .act-b.qin:hover {
            border-color: var(--gold);
            color: var(--deep);
            background: rgba(212,160,23,.07);
        }

        .act-b.qhist:hover {
            border-color: var(--blue);
            color: var(--blue);
            background: rgba(29,78,216,.07);
        }
    /* Misc */
    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.2rem;
        border-top: 1px solid var(--border);
        font-size: .78rem;
        color: var(--muted);
    }

    .all-clear {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem;
        text-align: center;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
    }

        .all-clear i {
            font-size: 3rem;
            color: var(--green);
            opacity: .4;
            margin-bottom: .75rem;
        }
</style>

<div class="pg">
    <div class="pg-hd">
        <div>
            <h1 class="pg-title">Cảnh Báo <em>Tồn Kho</em></h1>
            <div class="pg-sub">Hàng sắp hết · Hết hàng · Sắp hết hạn · Hàng hỏng</div>
        </div>
        <a href="@Url.Action("Index", "AdminInventory")" class="btn-back"><i class="bi bi-arrow-left"></i> Về kho</a>
    </div>

    <div class="stats">
        <div class="sb on" id="sbAll" onclick="setFilter('all')"><div class="sn">@Model.Items.Count</div><div class="sl">Tổng cảnh báo</div></div>
        <div class="sb" id="sbOut" onclick="setFilter('out')"><div class="sn" style="color:var(--red)">@Model.OutOfStockCount</div><div class="sl">Hết hàng</div></div>
        <div class="sb" id="sbLow" onclick="setFilter('low')"><div class="sn" style="color:var(--orange)">@Model.LowStockCount</div><div class="sl">Sắp hết</div></div>
        <div class="sb" id="sbExp" onclick="setFilter('expiring')"><div class="sn" style="color:#92600a">@Model.ExpiringCount</div><div class="sl">Sắp hết hạn</div></div>
        <div class="sb" id="sbXprd" onclick="setFilter('expired')"><div class="sn" style="color:var(--red)">@Model.ExpiredCount</div><div class="sl">Đã hết hạn</div></div>
        <div class="sb" id="sbDmg" onclick="setFilter('damaged')"><div class="sn" style="color:var(--purple)">@Model.DamagedCount</div><div class="sl">Hàng hỏng</div></div>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="all-clear">
            <i class="bi bi-check-circle-fill"></i>
            <div style="font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--deep);margin-bottom:.4rem">Kho đang ổn định!</div>
            <div style="font-size:.84rem;color:var(--muted)">Không có mặt hàng nào cần chú ý.</div>
        </div>
    }
    else
    {
        <div class="toolbar">
            <div class="srch"><i class="bi bi-search"></i><input type="text" id="srchIn" placeholder="Tên sản phẩm, SKU, cơ sở..." oninput="applyFilter()" /></div>
            <select class="sel" id="fFac" onchange="applyFilter()">
                <option value="">Tất cả cơ sở</option>
                @foreach (var f in facilities)
                {
                    <option value="@f.FacilityName">@f.FacilityName</option>
                }
            </select>
            <select class="sel" id="fBh" onchange="applyFilter()">
                <option value="">Tất cả nhóm</option>
                <option value="Retail">Bán lẻ</option>
                <option value="Rental">Cho thuê</option>
            </select>
            <span style="font-size:.78rem;color:var(--muted);white-space:nowrap" id="rowCount">@Model.Items.Count mặt hàng</span>
        </div>

        <div class="tbl-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th style="width:110px">Cơ sở</th>
                        <th style="width:130px;text-align:right">Tồn kho</th>
                        <th style="width:120px">Cảnh báo</th>
                        <th style="width:120px">Hạn sử dụng</th>
                        <th>Biến thể</th>
                        <th style="width:100px">Nhà cung cấp</th>
                        <th style="width:110px;text-align:right">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="lsTbody">
                    @foreach (var item in Model.Items)
                    {
                        var flags = new List<string>();
                        if (item.IsOutOfStock) flags.Add("out");
                        else if (item.IsLowStock) flags.Add("low");
                        if (item.IsExpired) flags.Add("expired");
                        else if (item.IsExpiringSoon) flags.Add("expiring");
                        if (item.HasDamaged) flags.Add("damaged");
                        var barPct = item.MinQuantity > 0 ? Math.Min(100, item.AvailableQuantity * 100 / item.MinQuantity) : 50;
                        var barClr = item.IsOutOfStock ? "var(--red)" : item.IsLowStock ? "var(--orange)" : "var(--green)";
                        var stkCls = item.IsOutOfStock ? "stk-zero" : "stk-low";
                        <tr id="ls-@item.InventoryId" class="@(item.IsOutOfStock || item.IsExpired ? "row-danger" : "")"
                            data-filter="@string.Join(" ", flags)" data-fac="@item.FacilityName"
                            data-bh="@item.BehaviorType"
                            data-search="@item.ProductName?.ToLower() @item.ProductCode?.ToLower() @item.FacilityName?.ToLower()">
                            <td>
                                <div class="p-cell">
                                    <div class="p-thumb">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" onerror="this.src='/images/no-image.png'" alt="" />
                                        }
                                        else
                                        {

                                            <i class="bi bi-box-seam"></i>
                                        }
                                    </div>
                                    <div><div class="p-name">@item.ProductName</div><div class="p-meta">@item.CategoryName · @(item.ProductCode ?? "—")</div></div>
                                </div>
                            </td>
                            <td style="font-size:.78rem;color:var(--muted)">@(item.FacilityName ?? "—")</td>
                            <td style="text-align:right">
                                <div class="@stkCls stk-main">@item.AvailableQuantity <span style="font-size:.65rem;font-weight:400;color:var(--muted)"> / @item.Quantity @item.Unit</span></div>
                                @if (item.MinQuantity > 0)
                                {
                                    <div class="stk-bar" style="margin-left:auto"><div class="stk-bar-fill" style="width:@(Math.Min(barPct, 100))%;background:@barClr"></div></div>
                                    <div style="font-size:.62rem;color:var(--muted);margin-top:.15rem;text-align:right">Min: @item.MinQuantity</div>
        }
                                @if (item.DamagedQuantity > 0)
                                {
                                    <div style="font-size:.66rem;color:var(--purple);margin-top:.1rem">@item.DamagedQuantity hỏng</div>
                                }
                            </td>
                            <td>
                                @if (item.IsOutOfStock)
                                {
                                    <span class="fl-badge fb-out"><i class="bi bi-x-circle-fill"></i> Hết hàng</span>
                                }
                                else if (item.IsLowStock)
                                {

                                    <span class="fl-badge fb-low"><i class="bi bi-exclamation-triangle-fill"></i> Sắp hết</span>
                                }
                                @if (item.IsExpired)
                                {
                                    <span class="fl-badge fb-xprd"><i class="bi bi-calendar-x-fill"></i> Hết hạn</span>
                                }
                                else if (item.IsExpiringSoon)
                                {

                                    <span class="fl-badge fb-exp"><i class="bi bi-clock-fill"></i> Sắp hết hạn</span>
                                }
                                @if (item.HasDamaged)
                                {
                                    <span class="fl-badge fb-dmg"><i class="bi bi-tools"></i> Hư hỏng</span>
                                }
                            </td>
                            <td>
                                @if (item.ExpiryDate.HasValue)
                                {
                                    var cls = item.IsExpired ? "exp-dead" : item.IsExpiringSoon ? "exp-soon" : "exp-ok";
                                    <div class="@cls">@item.ExpiryDate.Value.ToString("dd/MM/yyyy")</div>
                                    @if (item.DaysUntilExpiry.HasValue)
                                    {
                                        <div style="font-size:.64rem;color:var(--muted)">@(item.IsExpired ? $"Đã hết hạn {-item.DaysUntilExpiry} ngày" : $"Còn {item.DaysUntilExpiry} ngày")</div>
                                    }
                                }
                                else
                                {
                                    <span style="color:var(--muted);font-size:.76rem">—</span>
                                }
                            </td>
                            <td>
                                @if (item.LowVariants?.Any() == true)
                                {
                                    @foreach (var v in item.LowVariants.Take(3))
                                    {
                                        <span class="var-chip">@v.DisplayName: @v.AvailableQty</span>
                                    }
                                    @if (item.LowVariants.Count > 3)
                                    {
                                        <span class="var-chip">+@(item.LowVariants.Count - 3) khác</span>
                                    }
                                }
                                else
                                {
                                    <span style="color:var(--muted);font-size:.76rem">—</span>
                                }
                            </td>
                            <td style="font-size:.76rem;color:var(--muted)">
                                @if (!string.IsNullOrEmpty(item.SupplierName))
                                {
                                    <div>@item.SupplierName</div>
                                }
                                @if (!string.IsNullOrEmpty(item.BatchNumber))
                                {
                                    <div style="font-family:monospace;font-size:.66rem">@item.BatchNumber</div>
                                }
                                @if (string.IsNullOrEmpty(item.SupplierName) && string.IsNullOrEmpty(item.BatchNumber))
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td>
                                <div class="act-g">
                                    <button class="act-b qin" onclick="quickStockIn(@item.InventoryId,@item.ProductId,'@Html.Raw(item.ProductName?.Replace("'", "\\'"))')" title="Nhập kho ngay">
                                        <i class="bi bi-box-arrow-in-down"></i> Nhập
                                    </button>
                                    <a href="@Url.Action("History", "AdminInventory", new { productId = item.ProductId })" class="act-b qhist" title="Lịch sử">
                                        <i class="bi bi-clock-history"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="pager"><span id="countLabel">@Model.Items.Count mặt hàng</span></div>
        </div>
    }
</div>

<div class="modal fade" id="lsModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered" style="max-width:600px">
        <div class="modal-content" id="lsModalBody" style="border-radius:14px;border:none">
            <div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        let lsModal;
        document.addEventListener('DOMContentLoaded',()=>{
            lsModal=new bootstrap.Modal(document.getElementById('lsModal'));
            document.getElementById('sbAll')?.classList.add('on');
        });
        let activeFilter='all';
        function setFilter(f){
            activeFilter=f;
            const map={all:'sbAll',out:'sbOut',low:'sbLow',expiring:'sbExp',expired:'sbXprd',damaged:'sbDmg'};
            document.querySelectorAll('.sb').forEach(b=>b.classList.remove('on'));
            document.getElementById(map[f]||'sbAll')?.classList.add('on');
            applyFilter();
        }
        function applyFilter(){
            const q=document.getElementById('srchIn')?.value.toLowerCase()||'';
            const fac=document.getElementById('fFac')?.value||'';
            const bh=document.getElementById('fBh')?.value||'';
            let cnt=0;
            document.querySelectorAll('#lsTbody tr[id^="ls-"]').forEach(r=>{
                const show=(!q||r.dataset.search?.includes(q))&&(!fac||r.dataset.fac===fac)&&(!bh||r.dataset.bh===bh)&&(activeFilter==='all'||r.dataset.filter?.includes(activeFilter));
                r.style.display=show?'':'none'; if(show)cnt++;
            });
            document.getElementById('rowCount').textContent=cnt+' mặt hàng';
            document.getElementById('countLabel').textContent=cnt+' mặt hàng';
        }
        async function quickStockIn(invId,productId,productName){
            document.getElementById('lsModalBody').innerHTML='<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            lsModal.show();
            const r=await fetch(`/AdminInventory/StockIn?invId=${invId}&preProductId=${productId}&preProductName=${encodeURIComponent(productName)}`,{headers:{'X-Requested-With':'XMLHttpRequest'}});
            document.getElementById('lsModalBody').innerHTML=await r.text();
            document.getElementById('lsModalBody').querySelectorAll('script').forEach(s=>{const n=document.createElement('script');n.text=s.text;s.replaceWith(n);});
        }
    </script>
}
