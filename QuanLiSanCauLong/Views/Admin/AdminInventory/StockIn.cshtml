@model QuanLiSanCauLong.ViewModels.StockTransactionViewModel
@{
    Layout = null;
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-h: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
        --court-green: #166534;
        --court-green-bg: #f0fdf4;
    }

    .si-wrap { font-family: 'Outfit', sans-serif; }

    /* Header */
    .si-hd {
        background: var(--court-dark);
        color: #fff;
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: .85rem;
    }
    .si-hd-icon {
        width: 40px; height: 40px; border-radius: 10px;
        background: rgba(34,197,94,.25); color: #4ade80;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem; flex-shrink: 0;
    }
    .si-hd h5  { font-weight: 800; font-size: 1rem; margin: 0; }
    .si-hd p   { font-size: .75rem; color: rgba(255,255,255,.6); margin: 0; }
    .si-close  { margin-left: auto; background: none; border: none; color: rgba(255,255,255,.65); font-size: 1.35rem; cursor: pointer; line-height: 1; }

    /* Body */
    .si-body { padding: 1.25rem 1.5rem; background: #fff; }

    /* Section label */
    .si-section {
        font-size: .67rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: 1px; color: var(--court-dark);
        display: inline-block; padding-bottom: .3rem;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: .9rem;
    }

    /* Fields */
    .si-field { display: flex; flex-direction: column; gap: .28rem; margin-bottom: .8rem; }
    .si-field label {
        font-size: .71rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .5px; color: var(--court-muted);
    }
    .si-fc {
        border: 1.5px solid var(--court-border); border-radius: 8px;
        background: var(--court-bg); color: var(--court-text);
        font-size: .875rem; padding: .48rem .75rem; width: 100%;
        outline: none; transition: .18s; font-family: 'Outfit', sans-serif;
    }
    .si-fc:focus {
        border-color: var(--court-gold); background: #fff;
        box-shadow: 0 0 0 3px rgba(232,200,64,.2);
    }
    .si-two   { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
    .si-three { display: grid; grid-template-columns: 7fr 5fr; gap: .75rem; }

    /* FIFO info */
    .si-fifo-info {
        background: #eff6ff; border: 1px solid #93c5fd; border-radius: 8px;
        padding: .55rem .9rem; font-size: .78rem; color: #1d4ed8;
        display: flex; align-items: flex-start; gap: .5rem; margin-bottom: .85rem;
    }

    /* Product table */
    .si-tbl-wrap {
        border: 1px solid var(--court-border); border-radius: 10px;
        overflow: hidden; margin-bottom: .85rem;
    }
    .si-tbl { width: 100%; border-collapse: collapse; }
    .si-tbl thead tr { background: var(--court-dark); }
    .si-tbl th {
        color: rgba(255,255,255,.7); font-size: .67rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .7px; padding: .6rem .7rem;
        border: none; white-space: nowrap;
    }
    .si-tbl td { padding: .5rem .6rem; border-bottom: 1px solid var(--court-border); vertical-align: middle; }
    .si-tbl tr:last-child td { border-bottom: none; }
    .si-tbl tr:hover td { background: #fdf9f0; }

    .si-fc-sm {
        border: 1.5px solid var(--court-border); border-radius: 7px;
        background: var(--court-bg); font-size: .82rem; padding: .38rem .55rem;
        width: 100%; outline: none; font-family: 'Outfit', sans-serif;
    }
    .si-fc-sm:focus { border-color: var(--court-gold); background: #fff; }

    .row-meta { font-size: .7rem; color: var(--court-muted); margin-top: 2px; display: block; }

    .btn-add-row {
        display: inline-flex; align-items: center; gap: 4px;
        padding: .35rem .9rem; background: var(--court-green-bg);
        color: var(--court-green); border: 1.5px solid #86efac;
        border-radius: 8px; font-size: .75rem; font-weight: 700;
        cursor: pointer; transition: .18s; font-family: 'Outfit', sans-serif;
    }
    .btn-add-row:hover { background: #22c55e; color: #fff; border-color: #22c55e; }

    .btn-remove {
        background: none; border: none; color: #dc2626;
        cursor: pointer; padding: .2rem .4rem; font-size: .9rem;
        border-radius: 5px; transition: .15s;
    }
    .btn-remove:hover { background: #fef2f2; }

    /* Footer */
    .si-foot {
        background: var(--court-bg); border-top: 1px solid var(--court-border);
        padding: .9rem 1.5rem; display: flex; justify-content: flex-end;
        align-items: center; gap: .6rem;
    }
    .btn-si-cancel {
        background: var(--court-card); color: var(--court-text);
        border: 1.5px solid var(--court-border); border-radius: 9px;
        padding: .5rem 1.3rem; font-weight: 600; font-size: .875rem;
        cursor: pointer; transition: .18s; font-family: 'Outfit', sans-serif;
    }
    .btn-si-cancel:hover { background: #ede8de; }
    .btn-si-submit {
        background: var(--court-gold); color: var(--court-dark);
        border: none; border-radius: 9px; padding: .5rem 1.75rem;
        font-weight: 800; font-size: .875rem; cursor: pointer; transition: .18s;
        display: flex; align-items: center; gap: 6px;
        font-family: 'Outfit', sans-serif;
    }
    .btn-si-submit:hover { background: var(--court-gold-h); box-shadow: 0 4px 12px rgba(232,200,64,.4); }
    .btn-si-submit:disabled { opacity: .5; cursor: not-allowed; }
    .spinner-sm {
        width: 14px; height: 14px; border: 2px solid rgba(26,26,46,.2);
        border-top-color: var(--court-dark); border-radius: 50%;
        animation: spin .7s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="si-wrap">
    <div class="si-hd">
        <div class="si-hd-icon"><i class="bi bi-box-arrow-in-down"></i></div>
        <div>
            <h5>Tạo Phiếu Nhập Kho</h5>
            <p>Cập nhật hàng hoá và tồn kho thực tế</p>
        </div>
        <button class="si-close" onclick="$('#inventoryModal').modal('hide')">&times;</button>
    </div>

    <div class="si-body">
        <!-- Thông tin chứng từ -->
        <div class="si-section"><i class="bi bi-info-circle me-1"></i>Thông Tin Chứng Từ</div>

        <div class="si-two">
            <div class="si-field">
                <label>Cơ sở nhập hàng <span style="color:#dc2626">*</span></label>
                <select id="si_facilityId" class="si-fc">
                    <option value="">-- Chọn cơ sở --</option>
                    @foreach (var f in ViewBag.Facilities as List<QuanLiSanCauLong.Models.Facility> ?? new())
                    {
                        <!option value="@f.FacilityId" @(f.FacilityId == Model.FacilityId ? "selected" : "")>
                        @f.FacilityName
                        </!option>
                    }
                </select>
            </div>
            <div class="si-field">
                <label>Ngày nhập kho</label>
                <input type="date" id="si_txDate" class="si-fc" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="si-two">
            <div class="si-field">
                <label>Nhà cung cấp</label>
                <select id="si_supplierId" class="si-fc">
                    <option value="">-- Chọn nhà cung cấp --</option>
                    @foreach (var s in ViewBag.Suppliers as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>())
                    {
                        <option value="@s.SupplierId">@s.SupplierName</option>
                    }
                </select>
            </div>
            <div class="si-field">
                <label>Số phiếu / Chứng từ</label>
                <input type="text" id="si_docRef" class="si-fc" placeholder="VD: PN-2025-001" style="font-family:monospace;" />
            </div>
        </div>

        <div class="si-two">
            <div class="si-field">
                <label>
                    Số lô (Batch/Lot)
                    <span style="font-size:.63rem;background:#f0f9ff;color:#0369a1;border:1px solid #bae6fd;padding:1px 6px;border-radius:10px;margin-left:4px;font-weight:700;">FIFO</span>
                </label>
                <input type="text" id="si_batchNumber" class="si-fc" placeholder="LOT-2025-001 (nếu có)" style="font-family:monospace;" />
            </div>
            <div class="si-field">
                <label>
                    Hạn sử dụng (HSD)
                    <span style="font-size:.63rem;background:#fef2f2;color:#dc2626;border:1px solid #fca5a5;padding:1px 6px;border-radius:10px;margin-left:4px;font-weight:700;">Đồ ăn/uống</span>
                </label>
                <input type="date" id="si_expiryDate" class="si-fc" />
                <span style="font-size:.7rem;color:var(--court-muted);">Để trống nếu không có HSD</span>
            </div>
        </div>

        <!-- Chi tiết hàng nhập -->
        <div class="d-flex justify-content-between align-items-center mb-2" style="margin-top:.25rem;">
            <span class="si-section" style="margin-bottom:0;"><i class="bi bi-list-ul me-1"></i>Chi Tiết Hàng Nhập</span>
            <button type="button" class="btn-add-row" id="si_addRowBtn">
                <i class="bi bi-plus-circle"></i> Thêm dòng
            </button>
        </div>

        <div class="si-tbl-wrap">
            <table class="si-tbl">
                <thead>
                    <tr>
                        <th style="min-width:180px;">Sản phẩm</th>
                        <th style="min-width:130px;">Phân loại (Size/Màu)</th>
                        <th style="width:90px;text-align:center;">Số lượng</th>
                        <th style="width:70px;text-align:center;">ĐVT</th>
                        <th style="width:120px;text-align:right;">Giá nhập (₫)</th>
                        <th style="width:36px;"></th>
                    </tr>
                </thead>
                <tbody id="si_tableBody">
                    <tr class="si-product-row">
                        <td>
                            <select class="si-fc-sm si-product-sel" onchange="siFillUnit(this)">
                                <option value="">-- Chọn sản phẩm --</option>
                                @foreach (var p in ViewBag.Products as List<QuanLiSanCauLong.Models.Product> ?? new())
                                {
                                    <option value="@p.ProductId" data-unit="@(p.Unit ?? "")" data-sku="@(p.SKU ?? "")" data-stock="@p.StockQuantity">
                                        @p.ProductName @(!string.IsNullOrEmpty(p.SKU) ? $"({p.SKU})" : "")
                                    </option>
                                }
                            </select>
                            <small class="row-meta"></small>
                        </td>
                        <td>
                            <select class="si-fc-sm si-variant-sel" disabled>
                                <option value="">— Chọn SP trước —</option>
                            </select>
                        </td>
                        <td><input type="number" class="si-fc-sm si-qty" min="1" placeholder="0" style="text-align:center;" /></td>
                        <td><input type="text" class="si-fc-sm si-unit" readonly placeholder="—" style="text-align:center;" /></td>
                        <td><input type="number" class="si-fc-sm si-cost" min="0" step="1000" placeholder="0" style="text-align:right;" /></td>
                        <td><button type="button" class="btn-remove si-remove-btn"><i class="bi bi-trash3"></i></button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="si-field">
            <label>Ghi chú</label>
            <textarea id="si_note" class="si-fc" rows="2" placeholder="Ghi chú về lần nhập hàng này..."></textarea>
        </div>

        <div class="si-fifo-info">
            <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px;"></i>
            <span><strong>FIFO:</strong> Hàng nhập trước sẽ được xuất trước. Nhập đúng số lô và HSD để hệ thống kiểm soát chính xác.</span>
        </div>
    </div>

    <div class="si-foot">
        <button type="button" class="btn-si-cancel" onclick="$('#inventoryModal').modal('hide')">Hủy bỏ</button>
        <button type="button" class="btn-si-submit" id="si_submitBtn" onclick="submitStockIn()">
            <i class="bi bi-check-circle-fill"></i> Xác nhận nhập kho
        </button>
    </div>
</div>

<script>
// ── Serialize product data từ server ──
const _siProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (ViewBag.Products as List<QuanLiSanCauLong.Models.Product> ?? new()).Select(p => new {
        id    = p.ProductId,
        name  = p.ProductName ?? "",
        unit  = p.Unit  ?? "",
        sku   = p.SKU   ?? "",
        stock = p.StockQuantity
    })
));

// ── Fill unit + load variants khi chọn sản phẩm ──
async function siFillUnit(sel) {
    const row        = sel.closest('tr');
    const unitInput  = row.querySelector('.si-unit');
    const meta       = row.querySelector('.row-meta');
    const variantSel = row.querySelector('.si-variant-sel');
    const pid        = sel.value;
    const pData      = _siProducts.find(p => p.id == pid);

    if (!pid || !pData) {
        if (unitInput) unitInput.value = '';
        if (meta) meta.textContent = '';
        if (variantSel) { variantSel.innerHTML = '<option value="">— Chọn SP trước —</option>'; variantSel.disabled = true; }
        return;
    }

    if (unitInput) unitInput.value = pData.unit;
    if (meta) meta.textContent = `SKU: ${pData.sku || '—'} · Tồn: ${pData.stock}`;

    if (variantSel) {
        variantSel.innerHTML = '<option value="">Đang tải...</option>';
        variantSel.disabled = true;
        try {
            const res  = await fetch(`/Admin/AdminProduct/GetVariants?productId=${pid}`);
            const data = await res.json();
            if (Array.isArray(data) && data.length > 0) {
                variantSel.innerHTML = '<option value="">-- Không chọn size --</option>' +
                    data.map(v => `<option value="${v.variantId}">${v.displayName} (Tồn: ${v.availableQuantity ?? 0})</option>`).join('');
                variantSel.disabled = false;
            } else {
                variantSel.innerHTML = '<option value="">Không có phân loại</option>';
                variantSel.disabled = true;
            }
        } catch {
            variantSel.innerHTML = '<option value="">Lỗi tải phân loại</option>';
            variantSel.disabled  = false;
        }
    }
}

// ── Thêm dòng sản phẩm ──
let _siRowIdx = 1;
function siAddRow() {
    const opts = '<option value="">-- Chọn sản phẩm --</option>' +
        _siProducts.map(p => `<option value="${p.id}" data-unit="${p.unit}" data-sku="${p.sku}" data-stock="${p.stock}">${p.name}${p.sku ? ' (' + p.sku + ')' : ''}</option>`).join('');

    const tr = document.createElement('tr');
    tr.className = 'si-product-row';
    tr.innerHTML = `
        <td>
            <select class="si-fc-sm si-product-sel" onchange="siFillUnit(this)">${opts}</select>
            <small class="row-meta"></small>
        </td>
        <td><select class="si-fc-sm si-variant-sel" disabled><option value="">— Chọn SP trước —</option></select></td>
        <td><input type="number" class="si-fc-sm si-qty" min="1" placeholder="0" style="text-align:center;" /></td>
        <td><input type="text" class="si-fc-sm si-unit" readonly placeholder="—" style="text-align:center;" /></td>
        <td><input type="number" class="si-fc-sm si-cost" min="0" step="1000" placeholder="0" style="text-align:right;" /></td>
        <td><button type="button" class="btn-remove si-remove-btn" onclick="siRemoveRow(this)"><i class="bi bi-trash3"></i></button></td>
    `;
    document.getElementById('si_tableBody').appendChild(tr);
    _siRowIdx++;
}

function siRemoveRow(btn) {
    const rows = document.querySelectorAll('#si_tableBody .si-product-row');
    if (rows.length > 1) btn.closest('tr').remove();
}

document.getElementById('si_addRowBtn').addEventListener('click', siAddRow);

// ── Gắn sự kiện cho dòng đầu tiên ──
document.querySelectorAll('#si_tableBody .si-remove-btn').forEach(btn => {
    btn.addEventListener('click', () => siRemoveRow(btn));
});

// ── Submit AJAX ──
async function submitStockIn() {
    const btn = document.getElementById('si_submitBtn');
    const fid = document.getElementById('si_facilityId').value;
    if (!fid) { alert('Vui lòng chọn cơ sở!'); return; }

    // Collect items
    const items = [];
    document.querySelectorAll('#si_tableBody .si-product-row').forEach(row => {
        const pid  = row.querySelector('.si-product-sel').value;
        const vid  = row.querySelector('.si-variant-sel').value;
        const qty  = parseInt(row.querySelector('.si-qty').value);
        const unit = row.querySelector('.si-unit').value;
        const cost = parseFloat(row.querySelector('.si-cost').value) || 0;
        if (pid && qty > 0) items.push({ productId: parseInt(pid), variantId: vid ? parseInt(vid) : null, quantity: qty, unit, costPrice: cost });
    });

    if (!items.length) { alert('Vui lòng chọn ít nhất 1 sản phẩm với số lượng > 0!'); return; }

    btn.disabled = true;
    btn.innerHTML = '<div class="spinner-sm"></div> Đang xử lý...';

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const form  = new FormData();
    form.append('FacilityId',        fid);
    form.append('TransactionType',   'StockIn');
    form.append('TransactionDate',   document.getElementById('si_txDate').value);
    form.append('SupplierId',        document.getElementById('si_supplierId').value);
    form.append('DocumentReference', document.getElementById('si_docRef').value);
    form.append('BatchNumber',       document.getElementById('si_batchNumber').value);
    form.append('ExpiryDate',        document.getElementById('si_expiryDate').value);
    form.append('Note',              document.getElementById('si_note').value);
    items.forEach((it, i) => {
        form.append(`Items[${i}].ProductId`,  it.productId);
        form.append(`Items[${i}].VariantId`,  it.variantId ?? '');
        form.append(`Items[${i}].Quantity`,   it.quantity);
        form.append(`Items[${i}].Unit`,       it.unit);
        form.append(`Items[${i}].CostPrice`,  it.costPrice);
    });
    form.append('__RequestVerificationToken', token);

    try {
        const res  = await fetch('/AdminInventory/StockIn', { method: 'POST', body: form });
        const data = await res.json();
        if (data.success) {
            siShowToast(true, data.message || 'Nhập kho thành công!');
            setTimeout(() => { $('#inventoryModal').modal('hide'); location.reload(); }, 900);
        } else {
            siShowToast(false, data.message || 'Có lỗi xảy ra!');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Xác nhận nhập kho';
        }
    } catch {
        siShowToast(false, 'Lỗi kết nối. Vui lòng thử lại.');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Xác nhận nhập kho';
    }
}

function siShowToast(ok, msg) {
    const wrap = document.getElementById('invToastWrap');
    if (!wrap) return;
    const d = document.createElement('div');
    d.className = 'inv-toast ' + (ok ? 'inv-toast-ok' : 'inv-toast-err');
    d.textContent = msg;
    wrap.appendChild(d);
    setTimeout(() => d.remove(), 3500);
}
</script>
