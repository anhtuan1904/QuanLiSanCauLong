@model QuanLiSanCauLong.ViewModels.StockTransactionViewModel

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-h: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
    }

    .modal-hd-court {
        background: var(--court-dark);
        color: #fff;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

        .modal-hd-court h5 {
            font-weight: 800;
            font-size: 1.05rem;
            margin: 0 0 2px;
            color: #fff;
        }

        .modal-hd-court p {
            font-size: .78rem;
            color: rgba(255,255,255,.6);
            margin: 0;
        }

        .modal-hd-court .icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            background: rgba(34,197,94,.25);
            color: #4ade80;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-right: 1rem;
            flex-shrink: 0;
        }

        .modal-hd-court .btn-close {
            filter: invert(1);
            opacity: .7;
        }

    .fl label {
        display: block;
        font-size: .73rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--court-muted);
        margin-bottom: 5px;
    }

    .fc {
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        background: var(--court-bg);
        color: var(--court-text);
        font-size: .875rem;
        padding: .48rem .75rem;
        width: 100%;
        transition: .2s;
    }

        .fc:focus {
            outline: none;
            border-color: var(--court-gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(232,200,64,.2);
        }

    textarea.fc {
        resize: vertical;
        min-height: 70px;
    }

    .section-div {
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-dark);
        display: inline-block;
        padding-bottom: .35rem;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: .85rem;
    }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .three-col {
        display: grid;
        grid-template-columns: 7fr 5fr;
        gap: .85rem;
    }

    .info-note {
        background: #eff6ff;
        border: 1px solid #93c5fd;
        border-radius: 8px;
        padding: .6rem .9rem;
        font-size: .78rem;
        color: #1d4ed8;
        display: flex;
        align-items: flex-start;
        gap: .5rem;
    }
    /* Table */
    .prod-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .prod-tbl thead tr {
            background: var(--court-dark);
        }

        .prod-tbl thead th {
            color: rgba(255,255,255,.7);
            font-size: .67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            padding: .6rem .75rem;
            border: none;
        }

        .prod-tbl tbody tr {
            border-bottom: 1px solid var(--court-border);
        }

            .prod-tbl tbody tr:last-child {
                border-bottom: none;
            }

        .prod-tbl td {
            padding: .55rem .6rem;
            vertical-align: middle;
        }

    .btn-add-row {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: .35rem .9rem;
        background: #f0fdf4;
        color: #166534;
        border: 1.5px solid #86efac;
        border-radius: 8px;
        font-size: .75rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
    }

        .btn-add-row:hover {
            background: #22c55e;
            color: #fff;
            border-color: #22c55e;
        }

    .btn-remove {
        background: none;
        border: none;
        color: #dc2626;
        cursor: pointer;
        padding: .2rem .4rem;
        font-size: .9rem;
        transition: .15s;
    }

        .btn-remove:hover {
            background: #fef2f2;
            border-radius: 5px;
        }

    .row-meta {
        font-size: .72rem;
        color: var(--court-muted);
        margin-top: 3px;
        display: block;
    }

    .fw-mono {
        font-family: monospace;
        letter-spacing: .3px;
    }
    /* Footer */
    .modal-foot-court {
        background: var(--court-bg);
        border-top: 1px solid var(--court-border);
        border-radius: 0 0 16px 16px;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: .6rem;
    }

    .btn-cancel-modal {
        background: var(--court-card);
        color: var(--court-text);
        border: 1.5px solid var(--court-border);
        border-radius: 9px;
        padding: .55rem 1.3rem;
        font-weight: 600;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
    }

        .btn-cancel-modal:hover {
            background: #ede8de;
        }

    .btn-submit-modal {
        background: var(--court-gold);
        color: var(--court-dark);
        border: none;
        border-radius: 9px;
        padding: .55rem 1.75rem;
        font-weight: 800;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-submit-modal:hover {
            background: var(--court-gold-h);
            box-shadow: 0 4px 12px rgba(232,200,64,.4);
        }
</style>

<div class="modal-hd-court">
    <div class="d-flex align-items-center">
        <div class="icon-wrap"><i class="bi bi-box-arrow-in-down"></i></div>
        <div>
            <h5>Tạo Phiếu Nhập Kho</h5>
            <p>Cập nhật hàng hoá và tồn kho thực tế</p>
        </div>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
</div>

<form asp-action="StockIn" method="post" id="stockInForm">
    <div class="modal-body p-4" style="background:#fff;">

        <div class="section-div"><i class="bi bi-info-circle me-1"></i>Thông Tin Chứng Từ</div>
        <div class="row g-3 mb-3">
            <div class="col-md-7 fl">
                <label>Cơ sở nhập hàng</label>
                <select asp-for="FacilityId" class="fc">
                    <option value="">-- Chọn cơ sở --</option>
                    @if (ViewBag.Facilities != null)
                    {
                        foreach (var f in ViewBag.Facilities)
                        {
                            <option value="@f.FacilityId">@f.FacilityName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-5 fl">
                <label>Ngày nhập kho</label>
                <input asp-for="TransactionDate" type="date" class="fc" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6 fl">
                <label>Nhà cung cấp</label>
                <select asp-for="SupplierId" class="fc">
                    <option value="">-- Chọn nhà cung cấp --</option>
                    @if (ViewBag.Suppliers != null)
                    {
                        foreach (var s in ViewBag.Suppliers)
                        {
                            <option value="@s.SupplierId">@s.SupplierName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 fl">
                <label>Số phiếu / Chứng từ</label>
                <input asp-for="DocumentReference" class="fc fw-mono" placeholder="VD: PN-2025-001" />
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6 fl">
                <label>
                    Số lô (Batch/Lot)
                    <span style="font-size:.65rem;background:#f0f9ff;color:#0369a1;border:1px solid #bae6fd;padding:1px 6px;border-radius:10px;margin-left:4px;font-weight:700;">FIFO</span>
                </label>
                <input asp-for="BatchNumber" class="fc fw-mono" placeholder="LOT-2025-001 (nếu có)" />
            </div>
            <div class="col-md-6 fl">
                <label>
                    Hạn sử dụng (HSD)
                    <span style="font-size:.65rem;background:#fef2f2;color:#dc2626;border:1px solid #fca5a5;padding:1px 6px;border-radius:10px;margin-left:4px;font-weight:700;">Đồ ăn/uống</span>
                </label>
                <input asp-for="ExpiryDate" type="date" class="fc" />
                <span style="font-size:.72rem;color:var(--court-muted);">Để trống nếu không có HSD</span>
            </div>
        </div>

        <!-- Product table -->
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="section-div" style="margin-bottom:0;"><i class="bi bi-list-ul me-1"></i>Chi Tiết Hàng Nhập</span>
            <button type="button" class="btn-add-row" onclick="addRow()">
                <i class="bi bi-plus-circle"></i> Thêm dòng
            </button>
        </div>

        <div class="table-responsive mb-3">
            <table class="prod-tbl" id="productTable">
                <thead>
                    <tr>
                        <th style="min-width:200px;">Sản phẩm</th>
                        <th style="width:90px;">Số lượng</th>
                        <th style="width:80px;">ĐVT</th>
                        <th style="width:120px;">Giá nhập (đ)</th>
                        <th style="width:40px;text-align:center;">×</th>
                    </tr>
                </thead>
                <tbody id="productTableBody">
                    <tr class="product-row">
                        <td>
                            <select name="Items[0].ProductId" class="fc" onchange="fillUnit(this, 0)">
                                <option value="">-- Chọn sản phẩm --</option>
                                @if (ViewBag.Products != null)
                                {
                                    foreach (var p in ViewBag.Products)
                                    {
                                        <option value="@p.ProductId" data-unit="@p.Unit" data-sku="@p.SKU" data-stock="@p.StockQuantity">
                                            @p.ProductName @(!string.IsNullOrEmpty(p.SKU) ? $"({p.SKU})" : "")
                                        </option>
                                    }
                                }
                            </select>
                            <small class="row-meta"></small>
                        </td>
                        <td><input name="Items[0].Quantity" type="number" class="fc" placeholder="0" min="1" /></td>
                        <td><input name="Items[0].Unit" type="text" class="fc fw-mono" placeholder="—" readonly /></td>
                        <td><input name="Items[0].CostPrice" type="number" class="fc" placeholder="0" min="0" step="1000" /></td>
                        <td style="text-align:center;"><button type="button" class="btn-remove" onclick="removeRow(this)"><i class="bi bi-trash3"></i></button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="fl mb-3">
            <label>Ghi chú</label>
            <textarea asp-for="Note" class="fc" rows="2" placeholder="Ghi chú về lần nhập hàng này..."></textarea>
        </div>

        <div class="info-note">
            <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px;"></i>
            <span><strong>FIFO:</strong> Hàng nhập trước sẽ được xuất trước. Nhập đúng số lô và HSD để hệ thống kiểm soát chính xác.</span>
        </div>
    </div>

    <div class="modal-foot-court">
        <button type="button" class="btn-cancel-modal" data-bs-dismiss="modal">Hủy bỏ</button>
        <button type="submit" class="btn-submit-modal">
            <i class="bi bi-check-circle-fill"></i> Xác nhận nhập kho
        </button>
    </div>
</form>

<script>
    let rowIndex = 1;
    const productData = {};
    @if (ViewBag.Products != null)
    {
            foreach (var p in ViewBag.Products)
            {
                    @:productData[@p.ProductId] = { unit: '@(p.Unit ?? "")', sku: '@(p.SKU ?? "")', stock: @p.StockQuantity };
            }
    }

    function fillUnit(select, idx) {
        const id = select.value;
        const row = select.closest('tr');
        const unitInput = row.querySelector('input[name*=".Unit"]');
        const meta = row.querySelector('.row-meta');
        if (id && productData[id]) {
            if (unitInput) unitInput.value = productData[id].unit;
            if (meta) meta.textContent = `SKU: ${productData[id].sku || '—'} | Tồn: ${productData[id].stock}`;
        } else {
            if (unitInput) unitInput.value = '';
            if (meta) meta.textContent = '';
        }
    }

    function addRow() {
        const opts = Object.entries(productData).map(([id, d]) =>
            `<option value="${id}" data-unit="${d.unit}">${d.sku || 'SP-' + id}</option>`
        ).join('');
        const row = `
        <tr class="product-row">
            <td>
                <select name="Items[${rowIndex}].ProductId" class="fc" onchange="fillUnit(this,${rowIndex})">
                    <option value="">-- Chọn sản phẩm --</option>${opts}
                </select>
                <small class="row-meta"></small>
            </td>
            <td><input name="Items[${rowIndex}].Quantity" type="number" class="fc" placeholder="0" min="1" /></td>
            <td><input name="Items[${rowIndex}].Unit" type="text" class="fc fw-mono" placeholder="—" readonly /></td>
            <td><input name="Items[${rowIndex}].CostPrice" type="number" class="fc" placeholder="0" min="0" step="1000" /></td>
            <td style="text-align:center;"><button type="button" class="btn-remove" onclick="removeRow(this)"><i class="bi bi-trash3"></i></button></td>
        </tr>`;
        document.getElementById('productTableBody').insertAdjacentHTML('beforeend', row);
        rowIndex++;
    }

    function removeRow(btn) {
        if (document.querySelectorAll('.product-row').length > 1) btn.closest('tr').remove();
    }
</script>
