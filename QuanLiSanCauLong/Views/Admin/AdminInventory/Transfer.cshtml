@{
    Layout = null;
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
    var products = ViewBag.Products as IEnumerable<QuanLiSanCauLong.Models.Product> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Product>();
    int preInvId = ViewBag.FromInventoryId is int v ? v : 0;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --teal: #0d9488;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .md-hd {
        padding: 1rem 1.3rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #134e4a;
    }

    .md-title {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }

        .md-title em {
            color: #5eead4;
            font-style: italic;
        }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.4);
        font-size: 1rem;
        cursor: pointer;
    }

        .md-close:hover {
            color: #fff;
        }

    .md-body {
        padding: 1.2rem 1.3rem;
        max-height: 72vh;
        overflow-y: auto;
    }

    .md-ft {
        padding: .85rem 1.3rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        justify-content: flex-end;
        gap: .55rem;
    }

    .sec-hd {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted);
        padding: .5rem 0;
        margin-bottom: .75rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: .38rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .25rem;
        margin-bottom: .8rem;
    }

        .fg label {
            font-size: .72rem;
            font-weight: 700;
            color: var(--deep);
        }

        .fg .hint {
            font-size: .66rem;
            color: var(--muted);
        }

    .fi {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
    }

        .fi:focus {
            border-color: var(--teal);
        }
    /* Combo */
    .combo-w {
        position: relative;
    }

    .combo-list {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 7px;
        z-index: 100;
        box-shadow: 0 4px 16px rgba(0,0,0,.12);
        max-height: 200px;
        overflow-y: auto;
        display: none;
    }

        .combo-list.show {
            display: block;
        }

    .combo-opt {
        padding: .42rem .82rem;
        font-size: .82rem;
        cursor: pointer;
        color: var(--deep);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .combo-opt:hover {
            background: var(--warm);
        }

        .combo-opt .co-stk {
            font-size: .68rem;
            font-weight: 700;
            color: var(--muted);
        }
    /* Flow layout */
    .flow-grid {
        display: grid;
        grid-template-columns: 1fr 36px 1fr;
        gap: .6rem;
        align-items: end;
        margin-bottom: .85rem;
    }

    .flow-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: .55rem;
        color: var(--teal);
        font-size: 1.3rem;
    }
    /* Stock preview */
    .stk-preview {
        display: grid;
        grid-template-columns: 1fr 36px 1fr;
        gap: .6rem;
        margin-bottom: .85rem;
        display: none;
    }

        .stk-preview.show {
            display: grid;
        }

    .stk-c {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: .65rem .75rem;
        text-align: center;
    }

        .stk-c.src {
            border-top: 3px solid var(--red);
        }

        .stk-c.dst {
            border-top: 3px solid var(--teal);
        }

    .stk-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1;
    }

    .stk-l {
        font-size: .58rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .15rem;
    }

    .stk-after {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .25rem;
    }

        .stk-after.red {
            color: var(--red);
        }

        .stk-after.teal {
            color: var(--teal);
        }

    .flow-sep {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--teal);
        font-size: 1rem;
    }
    /* Qty presets */
    .qty-presets {
        display: flex;
        gap: .3rem;
        flex-wrap: wrap;
        margin-top: .35rem;
    }

    .qty-pill {
        padding: .18rem .55rem;
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: .7rem;
        cursor: pointer;
        background: #fff;
        transition: all .15s;
        color: var(--muted);
    }

        .qty-pill:hover {
            border-color: var(--teal);
            background: rgba(13,148,136,.07);
            color: var(--teal);
        }

        .qty-pill.max-pill {
            border-style: dashed;
        }
    /* Warn */
    .warn-box {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 7px;
        padding: .55rem .8rem;
        font-size: .75rem;
        color: #c2410c;
        display: none;
        align-items: center;
        gap: .4rem;
        margin-top: .4rem;
    }

        .warn-box.show {
            display: flex;
        }
    /* Buttons */
    .btn-teal {
        background: linear-gradient(135deg,#0d9488,#14b8a6);
        color: #fff;
        border: none;
        padding: .62rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        transition: all .2s;
    }

        .btn-teal:hover {
            box-shadow: 0 4px 14px rgba(13,148,136,.3);
            transform: translateY(-1px);
        }

        .btn-teal:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .btn-s {
        padding: .6rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: all .18s;
    }

        .btn-s:hover {
            border-color: var(--deep);
            color: var(--deep);
        }
</style>

<div class="md-hd">
    <span class="md-title"><i class="bi bi-arrow-left-right me-1" style="color:#5eead4"></i> Chuyển <em>Kho</em></span>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">

    <!-- SẢN PHẨM -->
    <div class="fg">
        <label>Sản phẩm cần chuyển <span style="color:var(--red)">*</span></label>
        <div class="combo-w">
            <input type="text" id="tr_prod_txt" class="fi" placeholder="Tìm sản phẩm..."
                   oninput="filterTrProd(this.value)" onfocus="showCombo('trProdList')" />
            <input type="hidden" id="tr_prod_id" />
            <input type="hidden" id="tr_from_inv" value="@preInvId" />
            <div class="combo-list" id="trProdList">
                @foreach (var p in products)
                {
                    <div class="combo-opt" onclick="pickTrProd('@Html.Raw(p.ProductName.Replace("'", "\'"))',@p.ProductId)">
                        <span>@p.ProductName <span style="font-size:.66rem;color:var(--muted);">@p.ProductCode</span></span>
                        <span class="co-stk">@p.Unit</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- FROM → TO -->
    <div class="sec-hd"><i class="bi bi-arrow-left-right"></i> Điểm xuất phát và điểm đến</div>
    <div class="flow-grid">
        <div class="fg" style="margin-bottom:0;">
            <label>Từ cơ sở <span style="color:var(--red)">*</span></label>
            <select id="tr_from" class="fi" onchange="onTrFacChange()">
                <option value="">-- Từ cơ sở --</option>
                @foreach (var f in facilities)
                {
                    <option value="@f.FacilityId">@f.FacilityName</option>
                }
            </select>
        </div>
        <div class="flow-arrow"><i class="bi bi-arrow-right"></i></div>
        <div class="fg" style="margin-bottom:0;">
            <label>Đến cơ sở <span style="color:var(--red)">*</span></label>
            <select id="tr_to" class="fi" onchange="onTrFacChange()">
                <option value="">-- Đến cơ sở --</option>
                @foreach (var f in facilities)
                {
                    <option value="@f.FacilityId">@f.FacilityName</option>
                }
            </select>
        </div>
    </div>

    <!-- STOCK PREVIEW -->
    <div class="stk-preview" id="trStkPreview">
        <div class="stk-c src">
            <div class="stk-l">Xuất từ</div>
            <div class="stk-n" id="trSrcQty" style="color:var(--red);">—</div>
            <div class="stk-after" id="trSrcAfter">Sau khi chuyển: —</div>
        </div>
        <div class="flow-sep"><i class="bi bi-arrow-right"></i></div>
        <div class="stk-c dst">
            <div class="stk-l">Nhập vào</div>
            <div class="stk-n" id="trDstQty" style="color:var(--teal);">—</div>
            <div class="stk-after" id="trDstAfter">Sau khi chuyển: —</div>
        </div>
    </div>

    <!-- SỐ LƯỢNG -->
    <div class="fg">
        <label>Số lượng chuyển <span style="color:var(--red)">*</span></label>
        <input type="number" id="tr_qty" class="fi" min="1" value="1" placeholder="SL" oninput="calcTrPreview()" />
        <div class="qty-presets">
            @foreach (var q in new[] { 1, 5, 10, 20, 50 })
            {
                <span class="qty-pill" onclick="document.getElementById('tr_qty').value=@q;calcTrPreview();">@q</span>
            }
            <span class="qty-pill max-pill" onclick="setTrMax()">Tất cả</span>
        </div>
        <div class="warn-box" id="trWarn"><i class="bi bi-exclamation-triangle-fill"></i> Vượt quá tồn kho khả dụng!</div>
    </div>

    <div class="fg">
        <label>Ghi chú</label>
        <textarea id="tr_note" class="fi" rows="2" placeholder="Lý do chuyển kho..."></textarea>
    </div>
</div>

<div class="md-ft">
    <button class="btn-s" data-bs-dismiss="modal">Hủy</button>
    <button class="btn-teal" id="trBtnSave" onclick="submitTransfer()">
        <i class="bi bi-arrow-left-right"></i> Xác nhận chuyển kho
    </button>
</div>

<script>
    const TR_PRODS  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products.Select(p => new { id = p.ProductId, name = p.ProductName, code = p.ProductCode ?? p.SKU ?? "" })));
    const TOKEN_TR  = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    let trFromAvail = 0, trDstAvail = 0, trFromInvId = 0, trDstInvId = 0;

    function showCombo(id) { document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); document.getElementById(id)?.classList.add('show'); }
    function filterTrProd(q) {
        const l = document.getElementById('trProdList'); if(!l)return;
        l.classList.add('show');
        l.querySelectorAll('.combo-opt').forEach(o=>{ o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none'; });
        document.getElementById('tr_prod_id').value = '';
    }
    function pickTrProd(name, id) {
        document.getElementById('tr_prod_txt').value = name;
        document.getElementById('tr_prod_id').value  = id;
        document.getElementById('trProdList').classList.remove('show');
        onTrFacChange();
    }
    document.addEventListener('click', e=>{ if(!e.target.closest('.combo-w')) document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); });

    async function onTrFacChange() {
        const prodId = document.getElementById('tr_prod_id').value;
        const fromId = document.getElementById('tr_from').value;
        const toId   = document.getElementById('tr_to').value;
        if(!prodId || !fromId) return;

        // Fetch from stock
        if(fromId) {
            const d = await fetch(`/AdminInventory/GetProductStock?facilityId=${fromId}&productId=${prodId}`).then(r=>r.json()).catch(()=>null);
            if(d?.success) {
                trFromAvail = d.availableQuantity;
                trFromInvId = 0; // server resolves inv ID
                document.getElementById('trSrcQty').textContent = d.availableQuantity;
                document.getElementById('trStkPreview').classList.add('show');
            }
        }
        // Fetch dst stock (may not exist yet)
        if(toId) {
            const d = await fetch(`/AdminInventory/GetProductStock?facilityId=${toId}&productId=${prodId}`).then(r=>r.json()).catch(()=>null);
            trDstAvail = d?.success ? d.availableQuantity : 0;
            document.getElementById('trDstQty').textContent = d?.success ? d.availableQuantity : '0 (mới)';
        }
        calcTrPreview();
    }

    function calcTrPreview() {
        const qty = parseInt(document.getElementById('tr_qty').value)||0;
        const srcAfter = trFromAvail - qty;
        const dstAfter = trDstAvail + qty;
        const srcEl = document.getElementById('trSrcAfter');
        const dstEl = document.getElementById('trDstAfter');
        srcEl.textContent = `Sau khi chuyển: ${srcAfter}`;
        srcEl.className   = 'stk-after ' + (srcAfter < 0 ? 'red' : '');
        dstEl.textContent = `Sau khi chuyển: ${dstAfter}`;
        dstEl.className   = 'stk-after teal';
        document.getElementById('trWarn').classList.toggle('show', qty > trFromAvail && trFromAvail > 0);
    }

    function setTrMax() {
        document.getElementById('tr_qty').value = trFromAvail > 0 ? trFromAvail : 1;
        calcTrPreview();
    }

    async function submitTransfer() {
        const prodId = document.getElementById('tr_prod_id').value;
        const fromId = document.getElementById('tr_from').value;
        const toId   = document.getElementById('tr_to').value;
        const qty    = parseInt(document.getElementById('tr_qty').value)||0;
        const note   = document.getElementById('tr_note').value;

        if(!prodId) { alert('Vui lòng chọn sản phẩm!'); return; }
        if(!fromId) { alert('Vui lòng chọn cơ sở xuất!'); return; }
        if(!toId)   { alert('Vui lòng chọn cơ sở nhận!'); return; }
        if(fromId === toId) { alert('Cơ sở xuất và nhận phải khác nhau!'); return; }
        if(qty <= 0) { alert('Số lượng phải lớn hơn 0!'); return; }
        if(qty > trFromAvail && trFromAvail > 0) {
            const ok = confirm(`Số lượng (${qty}) vượt tồn kho khả dụng (${trFromAvail}). Tiếp tục?`);
            if(!ok) return;
        }

        const btn = document.getElementById('trBtnSave');
        btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>...';

        const fd = new FormData();
        fd.append('fromInventoryId',  trFromInvId || 0);  // server will resolve by facilityId+productId
        fd.append('fromFacilityId',   fromId);
        fd.append('targetFacilityId', toId);
        fd.append('productId',        prodId);
        fd.append('quantity',         qty);
        fd.append('note',             note);

        try {
            const res = await fetch('/AdminInventory/Transfer', {
                method:'POST', headers:{'RequestVerificationToken':TOKEN_TR}, body:fd
            }).then(r=>r.json());
            if(res.success) {
                bootstrap.Modal.getInstance(document.getElementById('invModal'))?.hide();
                const t=document.createElement('div');
                t.style.cssText='position:fixed;bottom:1.5rem;right:1.5rem;background:#15803d;color:#fff;padding:.75rem 1.25rem;border-radius:8px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.2);';
                t.innerHTML=`<i class="bi bi-check-circle-fill"></i> ${res.message}`;
                document.body.appendChild(t);
                setTimeout(()=>{ t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>{t.remove();location.reload();},400);},1800);
            } else {
                alert(res.message||'Có lỗi xảy ra!');
                btn.disabled=false; btn.innerHTML='<i class="bi bi-arrow-left-right"></i> Xác nhận chuyển kho';
            }
        } catch(e) {
            alert('Lỗi kết nối!');
            btn.disabled=false; btn.innerHTML='<i class="bi bi-arrow-left-right"></i> Xác nhận chuyển kho';
        }
    }
</script>
