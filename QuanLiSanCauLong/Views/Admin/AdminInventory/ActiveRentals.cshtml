@model QuanLiSanCauLong.ViewModels.ActiveRentalsViewModel
@{
    ViewData["Title"] = "Hàng Đang Cho Thuê";
    var isPartial = ViewContext.HttpContext.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isPartial ? null : "~/Views/Shared/_LayoutAdmin.cshtml";
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
}
<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }

    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .62rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        transition: all .18s;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep);
        }
    /* Stats */
    .stats {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.4rem;
    }

    .sb {
        background: #fff;
        padding: .82rem 1.1rem;
        flex: 1;
        min-width: 0;
        cursor: pointer;
        transition: background .15s;
    }

        .sb:hover {
            background: var(--cream);
        }

        .sb.on {
            background: var(--deep);
        }

            .sb.on .sn {
                color: var(--gold2);
            }

            .sb.on .sl {
                color: rgba(255,255,255,.45);
            }

    .sn {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1;
        color: var(--deep);
    }

    .sl {
        font-size: .62rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .18rem;
    }
    /* Toolbar */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .srch {
        flex: 1;
        min-width: 220px;
        position: relative;
    }

        .srch i {
            position: absolute;
            left: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

        .srch input {
            width: 100%;
            padding: .58rem .85rem .58rem 2.2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .83rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .srch input:focus {
                border-color: var(--gold);
            }

    .sel {
        padding: .58rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .sel:focus {
            border-color: var(--gold);
        }
    /* Table */
    .tbl-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        padding: .72rem 1rem;
        background: var(--warm);
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }

    td {
        padding: .78rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: .83rem;
        color: var(--deep);
        vertical-align: middle;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tr:hover td {
        background: var(--cream);
    }

    tr.overdue-row td {
        background: #fff7ed;
    }

    .p-cell {
        display: flex;
        flex-direction: column;
    }

    .p-name {
        font-weight: 700;
        font-size: .84rem;
        color: var(--deep);
    }

    .p-meta {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .st-b {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .2rem .6rem;
        border-radius: 4px;
        font-size: .65rem;
        font-weight: 700;
    }

    .time-bar-wrap {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        width: 100px;
        margin-top: .3rem;
    }

    .time-bar-fill {
        height: 100%;
        border-radius: 2px;
        transition: width .3s;
    }

    .tbf-ok {
        background: var(--green);
    }

    .tbf-warn {
        background: #f59e0b;
    }

    .tbf-overdue {
        background: var(--red);
    }

    .time-label {
        font-size: .62rem;
        color: var(--muted);
        margin-top: .15rem;
    }

        .time-label.overdue {
            color: var(--red);
            font-weight: 700;
        }

    .cust-name {
        font-weight: 600;
        font-size: .83rem;
    }

    .cust-phone {
        font-size: .7rem;
        color: var(--muted);
    }

    .act-g {
        display: flex;
        gap: .28rem;
    }

    .act-b {
        min-width: 28px;
        height: 28px;
        padding: 0 .5rem;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .72rem;
        font-weight: 600;
        transition: all .15s;
        white-space: nowrap;
        gap: .25rem;
        color: var(--muted);
    }

        .act-b.ret:hover {
            border-color: var(--green);
            color: var(--green);
            background: rgba(21,128,61,.07);
        }

        .act-b.lost:hover {
            border-color: var(--red);
            color: var(--red);
            background: rgba(201,75,42,.07);
        }

    .empty-row td {
        text-align: center;
        padding: 4rem;
        color: var(--muted);
    }

    .empty-row i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: .75rem;
        opacity: .2;
    }

    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.2rem;
        border-top: 1px solid var(--border);
        font-size: .78rem;
        color: var(--muted);
    }
    /* Return/Lost overlays */
    .ov {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

        .ov.show {
            display: flex;
        }

    .ov-box {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        max-width: 480px;
        width: 100%;
        box-shadow: 0 16px 48px rgba(0,0,0,.22);
    }

    .ov-hd {
        background: var(--deep);
        padding: 1rem 1.3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .ov-title {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }

    .ov-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.4);
        font-size: 1rem;
        cursor: pointer;
    }

        .ov-close:hover {
            color: #fff;
        }

    .ov-body {
        padding: 1.2rem 1.3rem;
    }

    .ov-ft {
        padding: .85rem 1.3rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: .55rem;
    }

    .info-bar {
        padding: .6rem .85rem;
        border-radius: 7px;
        font-size: .76rem;
        line-height: 1.5;
        display: flex;
        align-items: flex-start;
        gap: .45rem;
        margin-bottom: .85rem;
    }

    .ib-blue {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: var(--blue);
    }

    .ib-red {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: var(--red);
    }

    .toggle-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        cursor: pointer;
        user-select: none;
        font-size: .84rem;
        font-weight: 600;
        margin-bottom: .75rem;
    }

        .toggle-row input {
            width: 16px;
            height: 16px;
            accent-color: var(--red);
            cursor: pointer;
        }

    .summary-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: .65rem .9rem;
        font-size: .8rem;
    }

    .sum-row {
        display: flex;
        justify-content: space-between;
        padding: .25rem 0;
        border-bottom: 1px solid var(--border);
    }

        .sum-row:last-child {
            border-bottom: none;
            font-weight: 700;
            font-size: .86rem;
            padding-top: .4rem;
        }

    .btn-green {
        background: linear-gradient(135deg,#16a34a,#22c55e);
        color: #fff;
        border: none;
        padding: .62rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        transition: all .2s;
    }

        .btn-green:hover {
            box-shadow: 0 4px 14px rgba(21,128,61,.3);
            transform: translateY(-1px);
        }

        .btn-green:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .btn-red {
        background: linear-gradient(135deg,#dc2626,#ef4444);
        color: #fff;
        border: none;
        padding: .62rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        transition: all .2s;
    }

        .btn-red:hover {
            box-shadow: 0 4px 14px rgba(220,38,38,.3);
            transform: translateY(-1px);
        }

        .btn-red:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<div class="pg">
    <div class="pg-hd">
        <div>
            <h1 class="pg-title">Đang Cho <em>Thuê</em></h1>
            <div class="pg-sub">Theo dõi trạng thái tất cả phiên thuê đang hoạt động</div>
        </div>
        <a href="@Url.Action("Index", "AdminInventory")" class="btn-back"><i class="bi bi-arrow-left"></i> Về kho</a>
    </div>

    <div class="stats">
        <div class="sb on" id="sbAll" onclick="filterRental('all')"><div class="sn">@Model.Items.Count</div><div class="sl">Tổng phiên</div></div>
        <div class="sb" id="sbActive" onclick="filterRental('Active')"><div class="sn" style="color:var(--blue)">@Model.TotalActive</div><div class="sl">Đang thuê</div></div>
        <div class="sb" id="sbOverdue" onclick="filterRental('Overdue')"><div class="sn" style="color:var(--red)">@Model.TotalOverdue</div><div class="sl">Quá hạn</div></div>
        <div class="sb" id="sbReturned" onclick="filterRental('Returned')"><div class="sn" style="color:var(--green)">@Model.TotalReturned</div><div class="sl">Đã trả hôm nay</div></div>
        <div class="sb" id="sbLost" onclick="filterRental('Lost')"><div class="sn" style="color:var(--purple)">@Model.TotalLost</div><div class="sl">Mất / không trả</div></div>
    </div>

    <div class="toolbar">
        <div class="srch"><i class="bi bi-search"></i><input type="text" id="srchIn" placeholder="Tên khách, sân, sản phẩm..." oninput="applyFilter()" /></div>
        <select class="sel" id="fFac" onchange="applyFilter()">
            <option value="">Tất cả cơ sở</option>
            @foreach (var f in facilities)
            {
                <option value="@f.FacilityName">@f.FacilityName</option>
            }
        </select>
        <span style="font-size:.78rem;color:var(--muted);white-space:nowrap" id="rowCount">@Model.Items.Count phiên</span>
    </div>

    <div class="tbl-wrap">
        <table>
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Khách thuê</th>
                    <th style="width:80px">Sân</th>
                    <th style="width:80px;text-align:center">SL</th>
                    <th style="width:110px">Thuê lúc</th>
                    <th style="width:140px">Thời gian / Trả</th>
                    <th style="width:110px">Trạng thái</th>
                    <th style="width:110px;text-align:right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="rentalTbody">
                @if (!Model.Items.Any())
                {
                    <tr class="empty-row"><td colspan="8"><i class="bi bi-arrow-repeat"></i><div style="font-weight:700;margin-bottom:.3rem">Không có phiên cho thuê nào</div><div style="font-size:.8rem">Khi khách thuê đồ, phiên thuê sẽ xuất hiện ở đây.</div></td></tr>
                }
                @foreach (var r in Model.Items)
                {
                    var isOverdue = r.IsOverdue;
                    var statusKey = isOverdue ? "Overdue" : r.Status;
                    double pct = 0; string barCls = "tbf-ok"; string timeLabel = "";
                    if (r.ExpectedReturnAt.HasValue && r.Status == "Active")
                    {
                        var total = (r.ExpectedReturnAt.Value - r.RentedAt).TotalMinutes;
                        var elapsed = (DateTime.Now - r.RentedAt).TotalMinutes;
                        pct = total > 0 ? Math.Min(100, elapsed / total * 100) : 100;
                        barCls = pct >= 100 ? "tbf-overdue" : pct >= 75 ? "tbf-warn" : "tbf-ok";
                        timeLabel = isOverdue ? $"Quá {(DateTime.Now - r.ExpectedReturnAt.Value).TotalMinutes:F0} phút" : $"Còn {(r.ExpectedReturnAt.Value - DateTime.Now).TotalMinutes:F0} phút";
                    }
                    <tr id="rr-@r.RentalItemId" class="@(isOverdue ? "overdue-row" : "")"
                        data-status="@statusKey" data-fac="@r.FacilityName"
                        data-search="@r.CustomerName?.ToLower() @r.CustomerPhone @r.CourtCode?.ToLower() @r.ProductName?.ToLower()">
                        <td><div class="p-cell"><div class="p-name">@r.ProductName @(!string.IsNullOrEmpty(r.Size) ? $"(Size {r.Size})" : "")</div><div class="p-meta">@r.CategoryName · @r.FacilityName</div></div></td>
                        <td><div class="cust-name">@(r.CustomerName ?? "—")</div>@if(!string.IsNullOrEmpty(r.CustomerPhone)){
                        <div class="cust-phone"><i class="bi bi-telephone"></i> @r.CustomerPhone</div>
                    }
</td>
                    <td style="font-size:.82rem;color:var(--muted)">@(r.CourtCode ?? "—")</td>
                    <td style="text-align:center;font-weight:700">@r.Quantity <span style="font-size:.7rem;color:var(--muted);font-weight:400">@r.Unit</span></td>
                    <td style="font-size:.78rem;color:var(--muted)">@r.RentedAt.ToString("HH:mm")<br />@r.RentedAt.ToString("dd/MM")</td>
                    <td>
                        @if (r.ExpectedReturnAt.HasValue && r.Status == "Active")
                        {
                            <div style="font-size:.76rem;color:@(isOverdue ? "var(--red)" : "var(--deep)");font-weight:@(isOverdue ? "700" : "400")">@r.ExpectedReturnAt.Value.ToString("HH:mm dd/MM")</div>
                            <div class="time-bar-wrap"><div class="time-bar-fill @barCls" style="width:@((int)pct)%"></div></div>
                            <div class="time-label @(isOverdue ? "overdue" : "")">@timeLabel</div>
                        }
                        else if (r.ReturnedAt.HasValue)
                        {
                            <div style="font-size:.76rem">Trả: @r.ReturnedAt.Value.ToString("HH:mm dd/MM")</div>
                            @if (r.CleaningFeeCharged > 0)
                            {
                                <div style="font-size:.66rem;color:var(--muted)">Phí VS: @r.CleaningFeeCharged.ToString("N0")đ</div>
                            }
                        }
                        else
                        {
                            <div style="font-size:.76rem;color:var(--muted)">@r.DurationHours.ToString("F1")h</div>
                        }
                    </td>
                    <td>
                        @if (r.Status == "Active" && isOverdue)
                        {
                            <span class="st-b" style="background:#fff7ed;color:var(--orange)"><i class="bi bi-exclamation-triangle-fill"></i> Quá hạn</span>
                        }
                        else if (r.Status == "Active")
                        {

                            <span class="st-b" style="background:#eff6ff;color:var(--blue)"><i class="bi bi-arrow-repeat"></i> Đang thuê</span>
                        }
                        else if (r.Status == "Returned")
                        {

                            <span class="st-b" style="background:#f0fdf4;color:var(--green)"><i class="bi bi-check-circle-fill"></i> Đã trả</span>
                        }
                        else if (r.Status == "Damaged")
                        {

                            <span class="st-b" style="background:#f5f3ff;color:var(--purple)"><i class="bi bi-tools"></i> Hư hỏng</span>
                        }
                        else
                        {

                            <span class="st-b" style="background:#fee2e2;color:var(--red)"><i class="bi bi-x-circle-fill"></i> Mất</span>
                        }
                    </td>
                    <td>
                        @if (r.Status == "Active")
                        {
                            <div class="act-g" style="justify-content:flex-end">
                                <button class="act-b ret" onclick="openReturn(@r.RentalItemId,'@Html.Raw(r.ProductName?.Replace("'", "\\'"))',@r.Quantity,'@r.Unit',@r.InventoryId)" title="Nhận lại đồ">
                                    <i class="bi bi-box-arrow-in-left"></i> Trả
                                </button>
                                <button class="act-b lost" onclick="openLost(@r.RentalItemId,'@Html.Raw(r.ProductName?.Replace("'", "\\'"))',@r.Quantity)" title="Báo mất">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        }
                    </td>
                </tr>
                                }
            </tbody>
        </table>
        <div class="pager"><span id="countLabel">@Model.Items.Count phiên thuê</span></div>
    </div>
</div>

<!-- Return overlay -->
<div class="ov" id="returnOv">
    <div class="ov-box">
        <div class="ov-hd">
            <span class="ov-title"><i class="bi bi-box-arrow-in-left me-1" style="color:#4ade80"></i> Nhận lại đồ thuê</span>
            <button class="ov-close" onclick="closeOv('returnOv')"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="ov-body">
            <div class="info-bar ib-blue"><i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px"></i><span>Đang nhận lại: <strong id="retProdName"></strong> — <strong id="retQtyLabel"></strong></span></div>
            <div class="row2">
                <div class="fg"><label>Số lượng nhận về</label><input type="number" id="retQty" class="fi" min="1" value="1" oninput="calcReturnTotal()" /></div>
                <div class="fg"><label>Phí vệ sinh (đ)</label><input type="number" id="retFee" class="fi" min="0" step="1000" value="0" oninput="calcReturnTotal()" /><span class="hint">Thu thêm nếu đồ bẩn</span></div>
            </div>
            <label class="toggle-row"><input type="checkbox" id="retDmg" onchange="toggleDmg(this.checked)" /><i class="bi bi-tools" style="color:var(--purple)"></i> Đồ bị hư hỏng khi trả về</label>
            <div class="fg" id="retDmgRow" style="display:none"><label>Mô tả hư hỏng</label><input type="text" id="retDmgNote" class="fi" placeholder="Mô tả tình trạng hư hỏng..." /></div>
            <div class="fg"><label>Ghi chú</label><textarea id="retNote" class="fi" rows="2" placeholder="Ghi chú thêm..."></textarea></div>
            <div class="summary-box" id="retSummary" style="display:none">
                <div class="sum-row"><span>Số lượng trả</span><span id="retSumQty">—</span></div>
                <div class="sum-row"><span>Phí vệ sinh</span><span id="retSumFee">—</span></div>
                <div class="sum-row"><span>Tổng thu thêm</span><span id="retSumTotal">—</span></div>
            </div>
        </div>
        <div class="ov-ft">
            <button class="btn-cancel" onclick="closeOv('returnOv')">Hủy</button>
            <button class="btn-green" id="retBtnSave" onclick="submitReturn()"><i class="bi bi-check-lg"></i> Xác nhận nhận lại</button>
        </div>
    </div>
</div>

<!-- Lost overlay -->
<div class="ov" id="lostOv">
    <div class="ov-box">
        <div class="ov-hd" style="background:#7f1d1d">
            <span class="ov-title"><i class="bi bi-x-circle-fill me-1" style="color:#fca5a5"></i> Báo mất đồ thuê</span>
            <button class="ov-close" onclick="closeOv('lostOv')"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="ov-body">
            <div class="info-bar ib-red"><i class="bi bi-exclamation-triangle-fill" style="flex-shrink:0;margin-top:1px"></i><span>Báo mất: <strong id="lostProdName"></strong> — <strong id="lostQtyLabel"></strong></span></div>
            <div class="fg"><label>Số lượng mất</label><input type="number" id="lostQty" class="fi" min="1" value="1" /></div>
            <div class="fg"><label>Ghi chú / lý do</label><textarea id="lostNote" class="fi" rows="2" placeholder="Khách mất, không tìm thấy..."></textarea></div>
            <div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:7px;padding:.6rem .85rem;font-size:.76rem;color:#c2410c"><i class="bi bi-exclamation-triangle-fill me-1"></i>Hành động này sẽ ghi nhận đồ là <strong>mất vĩnh viễn</strong> và trừ khỏi kho. Không thể hoàn tác.</div>
        </div>
        <div class="ov-ft">
            <button class="btn-cancel" onclick="closeOv('lostOv')">Hủy</button>
            <button class="btn-red" id="lostBtnSave" onclick="submitLost()"><i class="bi bi-x-circle-fill"></i> Xác nhận mất</button>
        </div>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        const TOKEN=document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';
        let curRetId=0,curLostId=0,curMaxQty=1;
        let activeFilter='all';

        function filterRental(mode){
            activeFilter=mode;
            document.querySelectorAll('.sb').forEach(b=>b.classList.remove('on'));
            const map={all:'sbAll',Active:'sbActive',Overdue:'sbOverdue',Returned:'sbReturned',Lost:'sbLost'};
            document.getElementById(map[mode]||'sbAll')?.classList.add('on');
            applyFilter();
        }
        function applyFilter(){
            const q=document.getElementById('srchIn').value.toLowerCase();
            const fac=document.getElementById('fFac').value;
            let cnt=0;
            document.querySelectorAll('#rentalTbody tr[id^="rr-"]').forEach(r=>{
                const show=(!q||r.dataset.search?.includes(q))&&(!fac||r.dataset.fac===fac)&&(activeFilter==='all'||r.dataset.status===activeFilter);
                r.style.display=show?'':'none'; if(show)cnt++;
            });
            document.getElementById('rowCount').textContent=cnt+' phiên';
            document.getElementById('countLabel').textContent=cnt+' phiên thuê';
        }

        function openReturn(id,name,qty,unit,invId){
            curRetId=id; curMaxQty=qty;
            document.getElementById('retProdName').textContent=name;
            document.getElementById('retQtyLabel').textContent=qty+' '+unit;
            document.getElementById('retQty').value=qty;
            document.getElementById('retQty').max=qty;
            document.getElementById('retFee').value='0';
            document.getElementById('retDmg').checked=false;
            document.getElementById('retDmgRow').style.display='none';
            document.getElementById('retNote').value='';
            calcReturnTotal();
            document.getElementById('returnOv').classList.add('show');
        }
        function toggleDmg(on){ document.getElementById('retDmgRow').style.display=on?'block':'none'; }
        function calcReturnTotal(){
            const qty=parseInt(document.getElementById('retQty').value)||0;
            const fee=parseFloat(document.getElementById('retFee').value)||0;
            const box=document.getElementById('retSummary');
            if(qty>0||fee>0){
                box.style.display='block';
                document.getElementById('retSumQty').textContent=qty;
                document.getElementById('retSumFee').textContent=fee>0?fee.toLocaleString('vi-VN')+'đ':'Không';
                document.getElementById('retSumTotal').textContent=fee>0?fee.toLocaleString('vi-VN')+'đ':'0đ';
            } else { box.style.display='none'; }
        }
        async function submitReturn(){
            const qty=parseInt(document.getElementById('retQty').value)||0;
            const fee=parseFloat(document.getElementById('retFee').value)||0;
            const isDmg=document.getElementById('retDmg').checked;
            const note=(isDmg?('[Hư hỏng] '+(document.getElementById('retDmgNote').value||'')):'')+(document.getElementById('retNote').value||'');
            if(qty<=0){alert('Số lượng phải lớn hơn 0!');return;}
            const btn=document.getElementById('retBtnSave');
            btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>...';
            try{
                const fd=new FormData();
                fd.append('rentalItemId',curRetId);fd.append('returnQuantity',qty);
                fd.append('isDamaged',isDmg);fd.append('cleaningFee',fee);fd.append('note',note);
                const res=await fetch('/AdminInventory/RentReturn',{method:'POST',headers:{'RequestVerificationToken':TOKEN},body:fd}).then(r=>r.json());
                if(res.success){closeOv('returnOv');toast(res.message,true);document.getElementById(`rr-${curRetId}`)?.remove();}
                else{alert(res.message||'Lỗi!');}
            }catch(e){alert('Lỗi kết nối!');}
            btn.disabled=false; btn.innerHTML='<i class="bi bi-check-lg"></i> Xác nhận nhận lại';
        }

        function openLost(id,name,qty){
            curLostId=id;
            document.getElementById('lostProdName').textContent=name;
            document.getElementById('lostQtyLabel').textContent=qty+' cái';
            document.getElementById('lostQty').value=qty; document.getElementById('lostQty').max=qty;
            document.getElementById('lostNote').value='';
            document.getElementById('lostOv').classList.add('show');
        }
        async function submitLost(){
            const qty=parseInt(document.getElementById('lostQty').value)||0;
            const note=document.getElementById('lostNote').value;
            if(qty<=0){alert('Số lượng phải lớn hơn 0!');return;}
            const btn=document.getElementById('lostBtnSave');
            btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>...';
            try{
                const fd=new FormData();
                fd.append('rentalItemId',curLostId);fd.append('lostQuantity',qty);fd.append('note',note);
                const res=await fetch('/AdminInventory/RentLost',{method:'POST',headers:{'RequestVerificationToken':TOKEN},body:fd}).then(r=>r.json());
                if(res.success){closeOv('lostOv');toast(res.message,true);document.getElementById(`rr-${curLostId}`)?.remove();}
                else{alert(res.message||'Lỗi!');}
            }catch(e){alert('Lỗi kết nối!');}
            btn.disabled=false; btn.innerHTML='<i class="bi bi-x-circle-fill"></i> Xác nhận mất';
        }

        function closeOv(id){document.getElementById(id).classList.remove('show');}
        document.querySelectorAll('.ov').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('show');}));

        function toast(msg,ok){
            const t=document.createElement('div');
            t.style.cssText=`position:fixed;bottom:1.5rem;right:1.5rem;background:${ok?'#15803d':'#c94b2a'};color:#fff;padding:.75rem 1.25rem;border-radius:8px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.2)`;
            t.innerHTML=`<i class="bi bi-${ok?'check-circle-fill':'exclamation-circle-fill'}"></i> ${msg}`;
            document.body.appendChild(t);
            setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>t.remove(),400);},2200);
        }
        document.addEventListener('DOMContentLoaded',()=>document.getElementById('sbAll')?.classList.add('on'));
    </script>
}
