@model QuanLiSanCauLong.ViewModels.ActiveRentalsViewModel

@{
    ViewData["Title"] = "Hàng Đang Cho Thuê";
    // Partial khi gọi qua AJAX, layout khi mở trang riêng
    if (ViewContext.HttpContext.Request.Headers["X-Requested-With"] == "XMLHttpRequest")
    {
        Layout = null;
    }
    else
    {
        Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    }
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #fff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --green: #15803d;
        --green-soft: #dcfce7;
        --red: #dc2626;
        --red-soft: #fef2f2;
        --blue: #1d4ed8;
        --blue-soft: #eff6ff;
        --orange: #c2410c;
        --orange-soft: #fff7ed;
        --purple: #7c3aed;
        --purple-soft: #f5f3ff;
    }

    .ar-wrapper {
        padding: 1.5rem;
        font-family: 'Outfit',sans-serif;
        background: var(--cream);
        min-height: 100%;
    }

    /* Stats strip */
    .ar-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .ar-stat {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: .85rem 1.1rem;
    }

    .ar-stat-val {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--deep);
        line-height: 1;
    }

    .ar-stat-lbl {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-top: 3px;
    }

    .ar-stat.active .ar-stat-val {
        color: var(--blue);
    }

    .ar-stat.overdue .ar-stat-val {
        color: var(--red);
    }

    /* Toolbar */
    .ar-toolbar {
        display: flex;
        gap: .65rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .ar-search {
        flex: 1;
        min-width: 180px;
        max-width: 280px;
        position: relative;
    }

        .ar-search input {
            padding: .45rem .75rem .45rem 2.1rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: .84rem;
            width: 100%;
            background: var(--card);
        }

        .ar-search i {
            position: absolute;
            left: .65rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

    .ar-filter {
        padding: .45rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: .82rem;
        background: var(--card);
        cursor: pointer;
    }

    .filter-count {
        font-size: .78rem;
        color: var(--muted);
        margin-left: auto;
        white-space: nowrap;
    }

    /* Cards grid */
    .ar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(320px,1fr));
        gap: 1rem;
    }

    .rental-card {
        background: var(--card);
        border: 1.5px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: .18s;
    }

        .rental-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26,18,9,.1);
        }

        .rental-card.overdue {
            border-color: #fca5a5;
        }

        .rental-card.returned {
            opacity: .5;
        }

    .rc-head {
        padding: .75rem 1rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: .5rem;
    }

    .rc-product {
        font-weight: 800;
        font-size: .92rem;
        color: var(--deep);
    }

    .rc-category {
        font-size: .72rem;
        color: var(--gold);
        font-weight: 700;
        margin-top: 2px;
    }

    .rc-status-badge {
        font-size: .68rem;
        font-weight: 800;
        padding: .2rem .65rem;
        border-radius: 20px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .st-active {
        background: var(--blue-soft);
        color: var(--blue);
    }

    .st-overdue {
        background: var(--red-soft);
        color: var(--red);
        animation: pulse 1.5s infinite;
    }

    .st-returned {
        background: var(--green-soft);
        color: var(--green);
    }

    .st-damaged {
        background: var(--purple-soft);
        color: var(--purple);
    }

    .st-lost {
        background: #f1f5f9;
        color: #64748b;
    }
    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .6;
        }
    }

    .rc-divider {
        height: 1px;
        background: var(--border);
        margin: 0;
    }

    .rc-body {
        padding: .8rem 1rem;
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .rc-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .8rem;
    }

    .rc-key {
        color: var(--muted);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .rc-val {
        font-weight: 700;
        color: var(--deep);
        text-align: right;
    }

        .rc-val.warn {
            color: var(--red);
        }

        .rc-val.ok {
            color: var(--green);
        }

    /* Progress bar for time */
    .time-bar-wrap {
        background: #f0ead8;
        border-radius: 4px;
        height: 5px;
        margin-top: 2px;
    }

    .time-bar-fill {
        height: 5px;
        border-radius: 4px;
        transition: .3s;
    }

    .tbf-ok {
        background: var(--green);
    }

    .tbf-warn {
        background: #f59e0b;
    }

    .tbf-overdue {
        background: var(--red);
    }

    /* Footer actions */
    .rc-foot {
        padding: .65rem 1rem;
        border-top: 1px solid var(--border);
        display: flex;
        gap: .4rem;
    }

    .rc-btn {
        flex: 1;
        padding: .38rem 0;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--deep);
        font-size: .72rem;
        font-weight: 700;
        cursor: pointer;
        transition: .15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .25rem;
        font-family: 'Outfit',sans-serif;
    }

        .rc-btn:hover {
            background: var(--warm);
        }

        .rc-btn.ret {
            border-color: #86efac;
            color: var(--green);
        }

            .rc-btn.ret:hover {
                background: var(--green);
                color: #fff;
            }

        .rc-btn.lost {
            border-color: #fca5a5;
            color: var(--red);
        }

            .rc-btn.lost:hover {
                background: var(--red);
                color: #fff;
            }

    /* Empty */
    .ar-empty {
        text-align: center;
        padding: 3rem 2rem;
        color: var(--muted);
    }

        .ar-empty i {
            font-size: 2.5rem;
            opacity: .35;
            display: block;
            margin-bottom: .75rem;
        }

    /* Return Modal */
    .ret-modal-body {
        padding: 1.25rem 1.5rem;
    }

    .ret-field {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        margin-bottom: .85rem;
    }

        .ret-field label {
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--muted);
        }

    .ret-fc {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .48rem .75rem;
        font-size: .875rem;
        width: 100%;
        background: var(--cream);
    }

        .ret-fc:focus {
            outline: none;
            border-color: var(--gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

    .ret-two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }

    .dmg-toggle {
        display: flex;
        align-items: center;
        gap: .6rem;
        cursor: pointer;
        user-select: none;
        font-size: .85rem;
        font-weight: 600;
    }

        .dmg-toggle input {
            width: 16px;
            height: 16px;
            accent-color: var(--red);
        }

    .ret-summary {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .85rem 1rem;
        font-size: .83rem;
    }

    .ret-sum-row {
        display: flex;
        justify-content: space-between;
        padding: .2rem 0;
    }

        .ret-sum-row.total {
            font-weight: 800;
            font-size: .95rem;
            border-top: 1px solid var(--border);
            margin-top: .3rem;
            padding-top: .5rem;
        }

    .ret-foot {
        padding: 1rem 1.5rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        display: flex;
        gap: .6rem;
        justify-content: flex-end;
    }

    .btn-cancel-sm {
        padding: .5rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        background: transparent;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
    }

    .btn-confirm {
        padding: .5rem 1.5rem;
        border: none;
        border-radius: 9px;
        background: var(--green);
        color: #fff;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-confirm:hover {
            background: #166534;
        }

    .btn-confirm-red {
        background: var(--red);
    }

        .btn-confirm-red:hover {
            background: #b91c1c;
        }

    .toast-wrap {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .toast-msg {
        background: var(--deep);
        color: #fff;
        padding: .7rem 1.1rem;
        border-radius: 9px;
        font-size: .82rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        animation: tsIn .25s ease;
    }

    .toast-ok {
        background: var(--green);
    }

    .toast-err {
        background: var(--red);
    }
    @@keyframes tsIn {
        from {
            opacity: 0;
            transform: translateX(30px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .inner-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1060;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }

        .inner-modal-overlay.show {
            display: flex;
        }

    .inner-modal-box {
        background: var(--card);
        border-radius: 14px;
        width: 100%;
        max-width: 460px;
        overflow: hidden;
        box-shadow: 0 16px 48px rgba(0,0,0,.22);
    }

    .inner-modal-hd {
        background: var(--deep);
        color: #fff;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .inner-modal-hd h5 {
            font-size: .95rem;
            font-weight: 800;
            margin: 0;
        }

    .inner-modal-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.6);
        font-size: 1.3rem;
        cursor: pointer;
    }
</style>

<div class="ar-wrapper">

    <!-- Stats -->
    <div class="ar-stats">
        <div class="ar-stat active">
            <div class="ar-stat-val">@Model.TotalActive</div>
            <div class="ar-stat-lbl">🔄 Đang thuê</div>
        </div>
        <div class="ar-stat overdue">
            <div class="ar-stat-val">@Model.TotalOverdue</div>
            <div class="ar-stat-lbl">⚠️ Quá hạn trả</div>
        </div>
        <div class="ar-stat">
            <div class="ar-stat-val" style="color:var(--green);">@Model.TotalReturned</div>
            <div class="ar-stat-lbl">✅ Đã trả hôm nay</div>
        </div>
        <div class="ar-stat">
            <div class="ar-stat-val" style="color:var(--purple);">@Model.TotalLost</div>
            <div class="ar-stat-lbl">❌ Mất / không trả</div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="ar-toolbar">
        <div class="ar-search">
            <i class="bi bi-search"></i>
            <input type="text" id="arSearch" placeholder="Tìm khách, sân, sản phẩm..." oninput="applyArFilter()" />
        </div>
        <select class="ar-filter" id="arStatusFilter" onchange="applyArFilter()">
            <option value="">Tất cả trạng thái</option>
            <option value="Active">🔄 Đang thuê</option>
            <option value="Overdue">⚠️ Quá hạn</option>
            <option value="Returned">✅ Đã trả</option>
            <option value="Damaged">💔 Hàng hỏng</option>
            <option value="Lost">❌ Mất</option>
        </select>
        <select class="ar-filter" id="arFacilityFilter" onchange="applyArFilter()">
            <option value="">Tất cả cơ sở</option>
            @foreach (var f in (ViewBag.Facilities as List<QuanLiSanCauLong.Models.Facility>) ?? new())
            {
                <option value="@f.FacilityName">@f.FacilityName</option>
            }
        </select>
        <span class="filter-count" id="arCount">@Model.Items.Count phiên thuê</span>
    </div>

    <!-- Cards -->
    @if (Model.Items.Any())
    {
        <div class="ar-grid" id="arGrid">
            @foreach (var r in Model.Items)
            {
                var isOverdue = r.IsOverdue;
                var statusCls = r.Status switch
                {
                                "Active" when isOverdue => "overdue",
                                "Active" => "active",
                                "Returned" => "returned",
                                "Damaged" => "damaged",
                    _ => "lost"
                };
                var cardCls = isOverdue ? "overdue" : r.Status != "Active" ? "returned" : "";

                // Time progress
                double pct = 0;
                string barCls = "tbf-ok";
                if (r.ExpectedReturnAt.HasValue && r.Status == "Active")
                {
                    var total = (r.ExpectedReturnAt.Value - r.RentedAt).TotalMinutes;
                    var elapsed = (DateTime.Now - r.RentedAt).TotalMinutes;
                    pct = total > 0 ? Math.Min(100, elapsed / total * 100) : 100;
                    barCls = pct >= 100 ? "tbf-overdue" : pct >= 75 ? "tbf-warn" : "tbf-ok";
                }

                <div class="rental-card @cardCls"
                     data-name="@r.CustomerName?.ToLower() @r.CustomerPhone @r.CourtCode?.ToLower() @r.ProductName?.ToLower()"
                     data-status="@(isOverdue ? "Overdue" : r.Status)"
                     data-facility="@r.FacilityName">
                    <div class="rc-head">
                        <div>
                            <div class="rc-product">@r.ProductName @(!string.IsNullOrEmpty(r.Size) ? $"(Size {r.Size})" : "")</div>
                            <div class="rc-category">@r.CategoryName · @r.FacilityName</div>
                        </div>
                        <span class="rc-status-badge st-@statusCls">
                            @(r.Status switch { "Active" when isOverdue => "⚠️ Quá hạn", "Active" => "🔄 Đang thuê", "Returned" => "✅ Đã trả", "Damaged" => "💔 Hỏng", _ => "❌ Mất" })
                        </span>
                    </div>
                    <div class="rc-divider"></div>
                    <div class="rc-body">
                        <div class="rc-row">
                            <span class="rc-key"><i class="bi bi-person"></i>Khách thuê</span>
                            <span class="rc-val">@(r.CustomerName ?? "—") @(!string.IsNullOrEmpty(r.CustomerPhone) ? $"· {r.CustomerPhone}" : "")</span>
                        </div>
                        <div class="rc-row">
                            <span class="rc-key"><i class="bi bi-geo-alt"></i>Sân</span>
                            <span class="rc-val">@(r.CourtCode ?? "—")</span>
                        </div>
                        <div class="rc-row">
                            <span class="rc-key"><i class="bi bi-boxes"></i>Số lượng</span>
                            <span class="rc-val">@r.Quantity @r.Unit</span>
                        </div>
                        <div class="rc-row">
                            <span class="rc-key"><i class="bi bi-clock"></i>Từ lúc</span>
                            <span class="rc-val">@r.RentedAt.ToString("HH:mm dd/MM")</span>
                        </div>
                        @if (r.ExpectedReturnAt.HasValue)
                        {
                            <div class="rc-row">
                                <span class="rc-key"><i class="bi bi-alarm"></i>Trả trước</span>
                                <span class="rc-val @(isOverdue ? "warn" : "")">@r.ExpectedReturnAt.Value.ToString("HH:mm dd/MM")</span>
                            </div>
                            if (r.Status == "Active")
                            {
                                <div>
                                    <div class="time-bar-wrap">
                                        <div class="time-bar-fill @barCls" style="width:@pct.ToString("F0")%;"></div>
                                    </div>
                                    <div style="font-size:.65rem;color:var(--muted);margin-top:2px;text-align:right;">
                                        @(isOverdue ? $"Quá {(DateTime.Now - r.ExpectedReturnAt.Value).TotalMinutes:F0} phút" : $"{r.DurationHours:F1}h / còn {(r.ExpectedReturnAt.Value - DateTime.Now).TotalMinutes:F0} phút")
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="rc-row">
                                <span class="rc-key"><i class="bi bi-hourglass-split"></i>Thời gian</span>
                                <span class="rc-val">@r.DurationHours.ToString("F1")h</span>
                            </div>
                        }
                    </div>
                    @if (r.Status == "Active")
                    {
                        <div class="rc-foot">
                            <button class="rc-btn ret" onclick="openReturnModal(@r.RentalItemId, '@r.ProductName?.Replace("'", "\\'")', @r.Quantity, '@r.Unit', @r.InventoryId)">
                                <i class="bi bi-box-arrow-in-left"></i> Trả đồ
                            </button>
                            <button class="rc-btn lost" onclick="openLostModal(@r.RentalItemId, '@r.ProductName?.Replace("'", "\\'")', @r.Quantity)">
                                <i class="bi bi-x-circle"></i> Mất
                            </button>
                        </div>
                    }
                    else if (r.ReturnedAt.HasValue)
                    {
                        <div style="padding:.5rem 1rem; font-size:.72rem; color:var(--muted); border-top:1px solid var(--border);">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            Trả lúc @r.ReturnedAt.Value.ToString("HH:mm dd/MM")
                            @if (r.CleaningFeeCharged > 0)
                            {
                                <span>· Phí VS: @r.CleaningFeeCharged.ToString("N0")₫</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="ar-empty">
            <i class="bi bi-arrow-repeat"></i>
            <p style="font-weight:700;font-size:1rem;color:var(--deep);">Không có phiên cho thuê nào</p>
            <p style="font-size:.82rem;">Khi khách thuê vợt, giày hoặc đồ dùng sẽ hiển thị ở đây</p>
        </div>
    }
</div>

<!-- Return Modal -->
<div class="inner-modal-overlay" id="returnModal">
    <div class="inner-modal-box">
        <div class="inner-modal-hd">
            <h5><i class="bi bi-box-arrow-in-left me-2"></i>Xác nhận trả đồ thuê</h5>
            <button class="inner-modal-close" onclick="closeInnerModal('returnModal')">&times;</button>
        </div>
        <div class="ret-modal-body">
            <div style="background:var(--blue-soft);border:1px solid #93c5fd;border-radius:9px;padding:.75rem 1rem;margin-bottom:1rem;font-size:.83rem;color:var(--blue);">
                <i class="bi bi-info-circle-fill me-1"></i>
                Đang trả: <strong id="retProductName"></strong> · <strong id="retQuantityLabel"></strong>
            </div>
            <div class="ret-two">
                <div class="ret-field">
                    <label>Số lượng trả</label>
                    <input type="number" id="retQty" class="ret-fc" min="1" value="1" oninput="updateRetSummary()" />
                </div>
                <div class="ret-field">
                    <label>Phí vệ sinh / giặt ủi</label>
                    <input type="number" id="retCleanFee" class="ret-fc" min="0" step="5000" value="0" placeholder="0₫" oninput="updateRetSummary()" />
                </div>
            </div>
            <div class="ret-field">
                <label class="dmg-toggle">
                    <input type="checkbox" id="retDamaged" onchange="updateRetSummary()" />
                    Hàng trả về bị hỏng (chuyển sang kho hỏng)
                </label>
            </div>
            <div class="ret-field">
                <label>Ghi chú</label>
                <textarea id="retNote" class="ret-fc" rows="2" placeholder="Tình trạng hàng khi trả..."></textarea>
            </div>
            <div class="ret-summary">
                <div class="ret-sum-row"><span>Số lượng trả</span><span id="sumQty">—</span></div>
                <div class="ret-sum-row"><span>Tình trạng</span><span id="sumCondition">Bình thường</span></div>
                <div class="ret-sum-row total"><span>Phí vệ sinh</span><span id="sumFee">0₫</span></div>
            </div>
        </div>
        <div class="ret-foot">
            <button class="btn-cancel-sm" onclick="closeInnerModal('returnModal')">Huỷ</button>
            <button class="btn-confirm" onclick="submitReturn()"><i class="bi bi-check-circle-fill me-1"></i>Xác nhận trả</button>
        </div>
    </div>
</div>

<!-- Lost Modal -->
<div class="inner-modal-overlay" id="lostModal">
    <div class="inner-modal-box">
        <div class="inner-modal-hd" style="background:var(--red);">
            <h5><i class="bi bi-x-circle-fill me-2"></i>Ghi nhận mất hàng</h5>
            <button class="inner-modal-close" onclick="closeInnerModal('lostModal')">&times;</button>
        </div>
        <div class="ret-modal-body">
            <div style="background:var(--red-soft);border:1px solid #fca5a5;border-radius:9px;padding:.75rem 1rem;margin-bottom:1rem;font-size:.83rem;color:var(--red);">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                Xác nhận mất: <strong id="lostProductName"></strong>. Kho sẽ bị trừ vĩnh viễn.
            </div>
            <div class="ret-field">
                <label>Số lượng mất</label>
                <input type="number" id="lostQty" class="ret-fc" min="1" value="1" />
            </div>
            <div class="ret-field">
                <label>Ghi chú / lý do</label>
                <textarea id="lostNote" class="ret-fc" rows="2" placeholder="Khách không trả, không liên lạc được..."></textarea>
            </div>
        </div>
        <div class="ret-foot">
            <button class="btn-cancel-sm" onclick="closeInnerModal('lostModal')">Huỷ</button>
            <button class="btn-confirm btn-confirm-red" onclick="submitLost()"><i class="bi bi-x-circle-fill me-1"></i>Ghi nhận mất</button>
        </div>
    </div>
</div>

<div class="toast-wrap" id="toastWrapAR"></div>

<script>
    let _currentRentalId = 0;
    let _currentMaxQty   = 1;
    let _currentLostId   = 0;

    // ── Filter ──
    function applyArFilter() {
        const q  = document.getElementById('arSearch').value.toLowerCase();
        const st = document.getElementById('arStatusFilter').value;
        const fc = document.getElementById('arFacilityFilter').value;
        let cnt = 0;
        document.querySelectorAll('#arGrid .rental-card').forEach(c => {
            const ok = (!q  || c.dataset.name.includes(q))
                    && (!st || c.dataset.status === st)
                    && (!fc || c.dataset.facility === fc);
            c.style.display = ok ? '' : 'none';
            if (ok) cnt++;
        });
        document.getElementById('arCount').textContent = cnt + ' phiên thuê';
    }

    // ── Return Modal ──
    function openReturnModal(rentalId, productName, maxQty, unit, invId) {
        _currentRentalId = rentalId;
        _currentMaxQty   = maxQty;
        document.getElementById('retProductName').textContent   = productName;
        document.getElementById('retQuantityLabel').textContent = maxQty + ' ' + unit;
        document.getElementById('retQty').max   = maxQty;
        document.getElementById('retQty').value = maxQty;
        document.getElementById('retDamaged').checked = false;
        document.getElementById('retNote').value     = '';
        document.getElementById('retCleanFee').value = '0';
        updateRetSummary();
        document.getElementById('returnModal').classList.add('show');
    }

    function updateRetSummary() {
        const qty  = parseInt(document.getElementById('retQty').value) || 0;
        const fee  = parseInt(document.getElementById('retCleanFee').value) || 0;
        const dmg  = document.getElementById('retDamaged').checked;
        document.getElementById('sumQty').textContent       = qty;
        document.getElementById('sumCondition').textContent = dmg ? '⚠️ Hàng hỏng' : '✅ Bình thường';
        document.getElementById('sumCondition').style.color = dmg ? 'var(--red)' : 'var(--green)';
        document.getElementById('sumFee').textContent       = fee.toLocaleString('vi-VN') + '₫';
    }

    async function submitReturn() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const body  = new FormData();
        body.append('rentalItemId',  _currentRentalId);
        body.append('returnQuantity', document.getElementById('retQty').value);
        body.append('isDamaged',      document.getElementById('retDamaged').checked);
        body.append('cleaningFee',    document.getElementById('retCleanFee').value);
        body.append('note',           document.getElementById('retNote').value);
        body.append('__RequestVerificationToken', token);

        const res  = await fetch('/AdminInventory/RentReturn', { method:'POST', body });
        const json = await res.json();
        closeInnerModal('returnModal');
        showARToast(json.success, json.message);
        if (json.success) setTimeout(() => location.reload(), 1000);
    }

    // ── Lost Modal ──
    function openLostModal(rentalId, productName, maxQty) {
        _currentLostId = rentalId;
        document.getElementById('lostProductName').textContent = productName;
        document.getElementById('lostQty').max   = maxQty;
        document.getElementById('lostQty').value = maxQty;
        document.getElementById('lostNote').value = '';
        document.getElementById('lostModal').classList.add('show');
    }

    async function submitLost() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const body  = new FormData();
        body.append('rentalItemId',  _currentLostId);
        body.append('lostQuantity',  document.getElementById('lostQty').value);
        body.append('note',          document.getElementById('lostNote').value);
        body.append('__RequestVerificationToken', token);

        const res  = await fetch('/AdminInventory/RentLost', { method:'POST', body });
        const json = await res.json();
        closeInnerModal('lostModal');
        showARToast(json.success, json.message);
        if (json.success) setTimeout(() => location.reload(), 1000);
    }

    function closeInnerModal(id) { document.getElementById(id).classList.remove('show'); }

    function showARToast(ok, msg) {
        const el = document.createElement('div');
        el.className = 'toast-msg ' + (ok ? 'toast-ok' : 'toast-err');
        el.innerHTML = (ok ? '<i class="bi bi-check-circle-fill"></i> ' : '<i class="bi bi-x-circle-fill"></i> ') + msg;
        document.getElementById('toastWrapAR').appendChild(el);
        setTimeout(() => el.remove(), 3500);
    }

    document.querySelectorAll('.inner-modal-overlay').forEach(o => {
        o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); });
    });
</script>
