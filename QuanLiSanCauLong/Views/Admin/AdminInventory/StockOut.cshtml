@model QuanLiSanCauLong.ViewModels.StockTransactionViewModel
@{
    Layout = null;
}

<style>
    :root {
        --deep:#1a1209;--gold:#d4a017;--gold2:#f5c842;
        --cream:#f5f4ec;--warm:#f0ead8;--card:#fff;--border:#e4d9c8;--muted:#8a7560;
        --red:#dc2626;--red-soft:#fef2f2;
    }
    .so-wrap { font-family:'Outfit',sans-serif; }
    .so-hd {
        background:linear-gradient(135deg,#7f1d1d,#991b1b);
        color:#fff; padding:1.1rem 1.5rem;
        display:flex; align-items:center; gap:.85rem;
    }
    .so-hd-icon { width:38px;height:38px;border-radius:9px;background:rgba(255,255,255,.15);
        display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0; }
    .so-hd h5 { font-weight:800;font-size:1rem;margin:0; }
    .so-hd p  { font-size:.75rem;color:rgba(255,255,255,.65);margin:0; }
    .so-close { margin-left:auto;background:none;border:none;color:rgba(255,255,255,.7);font-size:1.3rem;cursor:pointer; }

    .so-body { padding:1.25rem 1.5rem; background:var(--cream); }
    .so-field { display:flex;flex-direction:column;gap:.3rem;margin-bottom:.85rem; }
    .so-field label { font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted); }
    .so-fc { border:1.5px solid var(--border);border-radius:9px;padding:.5rem .8rem;
        font-size:.875rem;width:100%;background:var(--card);outline:none;font-family:'Outfit',sans-serif; }
    .so-fc:focus { border-color:var(--red);box-shadow:0 0 0 3px rgba(220,38,38,.12); }
    .so-two { display:grid;grid-template-columns:1fr 1fr;gap:.75rem; }

    /* Items table */
    .so-items { background:var(--card);border:1px solid var(--border);border-radius:11px;overflow:hidden;margin-bottom:.85rem; }
    .so-items-hd { background:var(--warm);padding:.5rem 1rem;display:grid;
        grid-template-columns:2fr 1fr 1fr;gap:.5rem;
        font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--muted); }
    .so-item-row { display:grid;grid-template-columns:2fr 1fr 1fr;gap:.5rem;padding:.55rem 1rem;
        border-top:1px solid var(--border);align-items:center; }
    .so-item-row:first-of-type { border-top:none; }
    .so-fc-sm { border:1.5px solid var(--border);border-radius:7px;padding:.35rem .6rem;
        font-size:.82rem;width:100%;background:var(--cream);outline:none;font-family:'Outfit',sans-serif; }
    .so-fc-sm:focus { border-color:var(--red);background:#fff; }
    .so-add-row { display:block;width:100%;padding:.5rem;border:1.5px dashed var(--border);
        border-radius:8px;background:transparent;font-size:.78rem;font-weight:700;color:var(--muted);
        cursor:pointer;transition:.15s;margin-top:.5rem;font-family:'Outfit',sans-serif; }
    .so-add-row:hover { border-color:var(--red);color:var(--red); }

    /* Stock availability chip */
    .avail-chip { font-size:.68rem;font-weight:700;padding:.12rem .45rem;border-radius:6px;
        background:var(--red-soft);color:var(--red);margin-left:.35rem;white-space:nowrap; }
    .avail-chip.ok { background:#dcfce7;color:#15803d; }

    /* Warning banner */
    .so-warn { background:var(--red-soft);border:1px solid #fca5a5;border-radius:9px;
        padding:.7rem 1rem;margin-bottom:.85rem;font-size:.82rem;color:var(--red);
        display:flex;align-items:flex-start;gap:.5rem; }

    .so-foot { padding:.9rem 1.5rem;background:var(--warm);border-top:1px solid var(--border);
        display:flex;gap:.6rem;justify-content:flex-end; }
    .btn-cancel { padding:.5rem 1.2rem;border:1.5px solid var(--border);border-radius:9px;
        background:transparent;font-size:.84rem;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif; }
    .btn-submit { padding:.5rem 1.5rem;border:none;border-radius:9px;background:var(--red);
        color:#fff;font-size:.84rem;font-weight:700;cursor:pointer;transition:.18s;font-family:'Outfit',sans-serif;
        display:flex;align-items:center;gap:.4rem; }
    .btn-submit:hover { background:#b91c1c; }
    .btn-submit:disabled { opacity:.5;cursor:not-allowed; }
    .spinner-sm { width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;
        border-radius:50%;animation:spin .7s linear infinite; }
    @@keyframes spin { to { transform:rotate(360deg); } }
</style>

<div class="so-wrap">
    <div class="so-hd">
        <div class="so-hd-icon"><i class="bi bi-box-arrow-up"></i></div>
        <div>
            <h5>Xuất Kho Thủ Công</h5>
            <p>Hàng hao hụt, thanh lý, nội bộ dùng</p>
        </div>
        <button class="so-close" onclick="$('#inventoryModal').modal('hide')">&times;</button>
    </div>

    <div class="so-body">
        <div class="so-warn">
            <i class="bi bi-exclamation-triangle-fill" style="margin-top:1px;flex-shrink:0;"></i>
            <span>Xuất kho thủ công sẽ <strong>trừ kho vĩnh viễn</strong>. Chỉ dùng khi kiểm kê phát hiện hao hụt, thanh lý hàng cũ hoặc xuất nội bộ không qua đơn hàng.</span>
        </div>

        <div class="so-two">
            <div class="so-field">
                <label>Cơ sở <span style="color:var(--red)">*</span></label>
                <select id="so_facilityId" class="so-fc" onchange="loadAvailability()">
                    @foreach (var f in ViewBag.Facilities as List<QuanLiSanCauLong.Models.Facility> ?? new())
                    {
                        <!option value="@f.FacilityId" @(f.FacilityId == Model.FacilityId ? "selected" : "")>
                        @f.FacilityName
                        </!option>
                    }
                </select>
            </div>
            <div class="so-field">
                <label>Lý do xuất <span style="color:var(--red)">*</span></label>
                <select id="so_reason" class="so-fc">
                    <option value="Hao hụt / thất thoát">Hao hụt / thất thoát</option>
                    <option value="Thanh lý hàng cũ">Thanh lý hàng cũ</option>
                    <option value="Xuất nội bộ">Xuất nội bộ</option>
                    <option value="Hỏng / không dùng được">Hỏng / không dùng được</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>
        </div>

        <div class="so-field">
            <label>Ghi chú</label>
            <input type="text" id="so_note" class="so-fc" placeholder="Mô tả thêm lý do xuất kho..." />
        </div>

        <!-- Items -->
        <div class="so-field">
            <label>Danh sách sản phẩm xuất</label>
        </div>
        <div class="so-items">
            <div class="so-items-hd">
                <span>Sản phẩm</span>
                <span style="text-align:center;">Số lượng xuất</span>
                <span style="text-align:center;">Khả dụng</span>
            </div>
            <div id="so_itemList">
                <div class="so-item-row">
                    <select class="so-fc-sm so-product-sel" onchange="fetchAvail(this)">
                        <option value="">— Chọn sản phẩm —</option>
                        @foreach (var p in ViewBag.Products as List<QuanLiSanCauLong.Models.Product> ?? new())
                        {
                            <option value="@p.ProductId" data-unit="@p.Unit">@p.ProductName</option>
                        }
                    </select>
                    <input type="number" class="so-fc-sm so-qty" min="1" value="1" placeholder="SL" />
                    <div class="so-avail-cell" style="text-align:center;font-size:.78rem;color:var(--muted);">—</div>
                </div>
            </div>
            <button class="so-add-row" type="button" onclick="addSoRow()">
                <i class="bi bi-plus-circle me-1"></i>Thêm sản phẩm
            </button>
        </div>
    </div>

    <div class="so-foot">
        <button class="btn-cancel" onclick="$('#inventoryModal').modal('hide')">Huỷ</button>
        <button class="btn-submit" id="soSubmitBtn" onclick="submitStockOut()">
            <i class="bi bi-box-arrow-up"></i> Xuất kho
        </button>
    </div>
</div>

<script>
const _soProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (ViewBag.Products as List<QuanLiSanCauLong.Models.Product> ?? new()).Select(p => new { p.ProductId, p.ProductName, p.Unit })
));

async function fetchAvail(sel) {
    const row   = sel.closest('.so-item-row');
    const cell  = row.querySelector('.so-avail-cell');
    const pid   = sel.value;
    const fid   = document.getElementById('so_facilityId').value;
    if (!pid) { cell.innerHTML = '—'; return; }
    cell.innerHTML = '<span style="font-size:.7rem;color:var(--muted);">...</span>';
    try {
        const r = await fetch(`/AdminInventory/GetProductStock?facilityId=${fid}&productId=${pid}`);
        const d = await r.json();
        if (d.success) {
            const cls = d.availableQuantity > 0 ? 'ok' : '';
            cell.innerHTML = `<span class="avail-chip ${cls}">${d.availableQuantity} ${d.unit}</span>`;
            row.querySelector('.so-qty').max = d.availableQuantity;
        } else {
            cell.innerHTML = '<span class="avail-chip">Chưa có kho</span>';
        }
    } catch { cell.innerHTML = '<span class="avail-chip">Lỗi</span>'; }
}

async function loadAvailability() {
    document.querySelectorAll('.so-product-sel').forEach(sel => {
        if (sel.value) fetchAvail(sel);
    });
}

let _soRowCount = 1;
function addSoRow() {
    _soRowCount++;
    const opts = _soProducts.map(p => `<option value="${p.productId}" data-unit="${p.unit}">${p.productName}</option>`).join('');
    const div = document.createElement('div');
    div.className = 'so-item-row';
    div.innerHTML = `
        <select class="so-fc-sm so-product-sel" onchange="fetchAvail(this)">
            <option value="">— Chọn sản phẩm —</option>${opts}
        </select>
        <input type="number" class="so-fc-sm so-qty" min="1" value="1" placeholder="SL" />
        <div class="so-avail-cell" style="text-align:center;">
            <button onclick="this.closest('.so-item-row').remove()" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:.85rem;" title="Xoá dòng">
                <i class="bi bi-x-circle"></i>
            </button>
        </div>`;
    document.getElementById('so_itemList').appendChild(div);
}

async function submitStockOut() {
    const btn = document.getElementById('soSubmitBtn');
    const rows = document.querySelectorAll('#so_itemList .so-item-row');
    const items = [];
    let valid = true;

    rows.forEach(row => {
        const pid = row.querySelector('.so-product-sel').value;
        const qty = parseInt(row.querySelector('.so-qty').value);
        if (pid && qty > 0) items.push({ productId: parseInt(pid), quantity: qty });
    });

    if (!items.length) { alert('Vui lòng chọn ít nhất 1 sản phẩm!'); return; }

    btn.disabled = true;
    btn.innerHTML = '<div class="spinner-sm"></div> Đang xử lý...';

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    const form  = new FormData();
    form.append('FacilityId',      document.getElementById('so_facilityId').value);
    form.append('TransactionType', 'StockOut');
    form.append('Reason',          document.getElementById('so_reason').value);
    form.append('Note',            document.getElementById('so_note').value);
    items.forEach((it, i) => {
        form.append(`Items[${i}].ProductId`, it.productId);
        form.append(`Items[${i}].Quantity`,  it.quantity);
    });
    form.append('__RequestVerificationToken', token);

    try {
        const res  = await fetch('/AdminInventory/StockOut', { method: 'POST', body: form });
        const data = await res.json();
        if (data.success) {
            showToast(true, data.message);
            setTimeout(() => { $('#inventoryModal').modal('hide'); location.reload(); }, 900);
        } else {
            showToast(false, data.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-box-arrow-up"></i> Xuất kho';
        }
    } catch {
        showToast(false, 'Lỗi kết nối. Vui lòng thử lại.');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-box-arrow-up"></i> Xuất kho';
    }
}

function showToast(ok, msg) {
    const el = document.getElementById('invToastWrap');
    if (!el) return;
    const d = document.createElement('div');
    d.className = 'inv-toast ' + (ok ? 'inv-toast-ok' : 'inv-toast-err');
    d.textContent = msg;
    el.appendChild(d);
    setTimeout(() => d.remove(), 3500);
}
</script>
