@model QuanLiSanCauLong.ViewModels.StockTransactionViewModel
@{
    Layout = null;
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
    var products   = ViewBag.Products   as IEnumerable<QuanLiSanCauLong.Models.Product>  ?? Enumerable.Empty<QuanLiSanCauLong.Models.Product>();

    // ✅ FIX: dùng Context.Request thay vì Request (không tồn tại trong partial view context)
    int    preProductId   = 0;
    int.TryParse(Context.Request.Query["preProductId"], out preProductId);
    string preProductName = Context.Request.Query["preProductName"].ToString() ?? "";
    int    preFacilityId  = Model.FacilityId > 0 ? Model.FacilityId : 0;
    int    preAvailable   = 0;
    int.TryParse(Context.Request.Query["available"], out preAvailable);
}

<style>
:root{--deep:#1a1209;--gold:#d4a017;--gold2:#f5c842;--warm:#f5ede0;--border:#e8ddd0;--muted:#8a7560;--red:#c94b2a;--green:#15803d;}
*,*::before,*::after{box-sizing:border-box;}*{font-family:'Outfit',sans-serif;}
.md-hd{padding:1rem 1.3rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--deep);}
.md-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#fff;}
.md-title em{color:#fca5a5;font-style:italic;}
.md-close{background:none;border:none;color:rgba(255,255,255,.4);font-size:1rem;cursor:pointer;}
.md-close:hover{color:#fff;}
.md-body{padding:1.2rem 1.3rem;max-height:72vh;overflow-y:auto;}
.md-ft{padding:.85rem 1.3rem;border-top:1px solid var(--border);background:var(--warm);display:flex;justify-content:flex-end;gap:.55rem;}
.sec-hd{font-size:.62rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);padding:.5rem 0;margin-bottom:.75rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.38rem;}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;}
.fg{display:flex;flex-direction:column;gap:.25rem;margin-bottom:.8rem;}
.fg label{font-size:.72rem;font-weight:700;color:var(--deep);}
.fg .req{color:var(--red);}
.fg .hint{font-size:.66rem;color:var(--muted);}
.fi{padding:.58rem .82rem;border:1px solid var(--border);border-radius:7px;font-family:'Outfit',sans-serif;font-size:.83rem;color:var(--deep);background:#fff;outline:none;transition:border-color .2s;width:100%;}
.fi:focus{border-color:var(--gold);}
.combo-w{position:relative;}
.combo-list{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid var(--border);border-radius:7px;z-index:100;box-shadow:0 4px 16px rgba(0,0,0,.12);max-height:200px;overflow-y:auto;display:none;}
.combo-list.show{display:block;}
.combo-opt{padding:.45rem .82rem;font-size:.82rem;cursor:pointer;color:var(--deep);}
.combo-opt:hover{background:var(--warm);}
.stk-bar-box{background:var(--warm);border:1px solid var(--border);border-radius:7px;padding:.65rem .9rem;margin-bottom:.85rem;display:none;}
.stk-bar-box.show{display:block;}
.stk-num{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;}
.stk-num.ok{color:var(--green);}
.stk-num.low{color:#c2410c;}
.stk-num.zero{color:var(--red);}
.stk-bar-w{height:5px;background:var(--border);border-radius:3px;overflow:hidden;margin-top:.4rem;}
.stk-bar-f{height:100%;border-radius:3px;transition:width .3s;}
.qty-presets{display:flex;gap:.3rem;flex-wrap:wrap;margin-top:.35rem;}
.qty-pill{padding:.18rem .55rem;border:1px solid var(--border);border-radius:4px;font-size:.7rem;cursor:pointer;background:#fff;transition:all .15s;color:var(--muted);}
.qty-pill:hover{border-color:var(--red);background:rgba(201,75,42,.06);color:var(--red);}
.warn-pill{background:#fff7ed;border:1px solid #fed7aa;border-radius:7px;padding:.5rem .75rem;font-size:.76rem;color:#c2410c;display:none;align-items:center;gap:.4rem;margin-top:.4rem;}
.warn-pill.show{display:flex;}
.btn-p{background:linear-gradient(135deg,#dc4040,#ef5a5a);color:#fff;border:none;padding:.62rem 1.3rem;font-size:.84rem;font-weight:700;border-radius:7px;cursor:pointer;display:inline-flex;align-items:center;gap:.38rem;transition:all .2s;}
.btn-p:hover{box-shadow:0 4px 14px rgba(201,75,42,.35);transform:translateY(-1px);}
.btn-p:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.btn-s{padding:.6rem 1.1rem;border:1.5px solid var(--border);border-radius:7px;background:#fff;font-size:.82rem;font-weight:600;cursor:pointer;color:var(--muted);transition:all .18s;}
.btn-s:hover{border-color:var(--deep);color:var(--deep);}
</style>

<div class="md-hd">
    <span class="md-title"><i class="bi bi-box-arrow-up me-1" style="color:#fca5a5"></i> Xuất <em>Kho</em></span>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">

    <!-- CƠ SỞ + SẢN PHẨM -->
    <div class="row2">
        <div class="fg">
            <label>Cơ sở <span class="req">*</span></label>
            <select id="so_fac" class="fi" onchange="onSoFacChange()">
                <option value="">-- Chọn cơ sở --</option>
                @foreach (var f in facilities)
                {
                    @Html.Raw($"<option value=\"{f.FacilityId}\"{(preFacilityId==f.FacilityId?" selected":"")}>{f.FacilityName}</option>")
                }
            </select>
        </div>
        <div class="fg">
            <label>Sản phẩm <span class="req">*</span></label>
            <div class="combo-w">
                <input type="text" id="so_prod_txt" class="fi" placeholder="Tìm sản phẩm..."
                       value="@preProductName"
                       oninput="filterSoProd(this.value)" onfocus="showCombo('soProdList')" />
                <input type="hidden" id="so_prod_id" value="@(preProductId > 0 ? preProductId.ToString() : "")" />
                <div class="combo-list" id="soProdList">
                    @foreach (var p in products)
                    {
                        <div class="combo-opt" onclick="pickSoProd('@Html.Raw(p.ProductName.Replace("'","\'"))',@p.ProductId)">
                            @p.ProductName <span style="font-size:.66rem;color:var(--muted);">@p.ProductCode</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- STOCK INDICATOR -->
    <div class="stk-bar-box @(preProductId > 0 && preAvailable >= 0 ? "show" : "")" id="soStkBox">
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:.72rem;color:var(--muted);">Tồn kho khả dụng</span>
            <span class="stk-num @(preAvailable <= 0 ? "zero" : preAvailable <= 5 ? "low" : "ok")" id="soStkNum">
                @(preAvailable > 0 ? preAvailable.ToString() : "0")
            </span>
        </div>
        <div class="stk-bar-w">
            <div class="stk-bar-f" id="soStkBar" style="width:60%;background:var(--green);"></div>
        </div>
    </div>

    <!-- SỐ LƯỢNG + LÝ DO -->
    <div class="row2">
        <div class="fg">
            <label>Số lượng xuất <span class="req">*</span></label>
            <input type="number" id="so_qty" class="fi" min="1" value="1" placeholder="SL" oninput="checkSoQty()" />
            <div class="qty-presets">
                @foreach (var q in new[]{1,2,5,10,20})
                {
                    <span class="qty-pill" onclick="document.getElementById('so_qty').value=@q;checkSoQty();">@q</span>
                }
                <span class="qty-pill" onclick="setSoAll()" style="border-style:dashed;">Tất cả</span>
            </div>
            <div class="warn-pill" id="soWarn"><i class="bi bi-exclamation-triangle-fill"></i> Vượt quá tồn kho!</div>
        </div>
        <div class="fg">
            <label>Lý do xuất kho <span class="req">*</span></label>
            <div class="combo-w">
                <input type="text" id="so_reason" class="fi" placeholder="Chọn hoặc nhập lý do..."
                       onfocus="showCombo('soReasonList')" oninput="filterCombo('soReasonList',this.value)" />
                <div class="combo-list" id="soReasonList">
                    @foreach (var r in new[]{"Bán hàng","Hư hỏng — viết sổ","Hàng mẫu / marketing","Kiểm kê thực tế","Xuất hủy hết hạn","Xuất nội bộ","Trả nhà cung cấp","Khác"})
                    {
                        <div class="combo-opt" onclick="pickCombo2('so_reason','@r')">@r</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="fg">
        <label>Ghi chú</label>
        <textarea id="so_note" class="fi" rows="2" placeholder="Ghi chú thêm..."></textarea>
    </div>
</div>

<div class="md-ft">
    <button class="btn-s" data-bs-dismiss="modal">Hủy</button>
    <button class="btn-p" id="soBtnSave" onclick="submitStockOut()">
        <i class="bi bi-box-arrow-up"></i> Xác nhận xuất kho
    </button>
</div>

<script>
const SO_PRODS_ALL = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products.Select(p => new {
    id = p.ProductId,
    name = p.ProductName,
    code = p.ProductCode ?? p.SKU ?? ""
})));
const TOKEN_SO = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
let soMaxAvailable = @preAvailable;

function showCombo(id) { document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); document.getElementById(id)?.classList.add('show'); }
function filterCombo(listId, q) { const l=document.getElementById(listId); if(!l)return; l.classList.add('show'); l.querySelectorAll('.combo-opt').forEach(o=>{ o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none'; }); }
function pickCombo2(id, val) { document.getElementById(id).value=val; document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); }
document.addEventListener('click', e=>{ if(!e.target.closest('.combo-w')) document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); });

function filterSoProd(q) {
    const l = document.getElementById('soProdList'); if(!l)return;
    l.classList.add('show');
    l.querySelectorAll('.combo-opt').forEach(o=>{ o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none'; });
    document.getElementById('so_prod_id').value='';
}

async function pickSoProd(name, id) {
    document.getElementById('so_prod_txt').value = name;
    document.getElementById('so_prod_id').value  = id;
    document.getElementById('soProdList').classList.remove('show');
    await updateStkBox();
}

async function onSoFacChange() { await updateStkBox(); }

async function updateStkBox() {
    const facId  = document.getElementById('so_fac').value;
    const prodId = document.getElementById('so_prod_id').value;
    if(!facId || !prodId) return;
    try {
        const data = await fetch(`/AdminInventory/GetProductStock?facilityId=${facId}&productId=${prodId}`).then(r=>r.json());
        if(data.success) {
            soMaxAvailable = data.availableQuantity;
            const box = document.getElementById('soStkBox');
            const num = document.getElementById('soStkNum');
            const bar = document.getElementById('soStkBar');
            box.classList.add('show');
            num.textContent = soMaxAvailable;
            num.className = 'stk-num ' + (soMaxAvailable<=0?'zero':soMaxAvailable<=5?'low':'ok');
            const pct = data.maxQuantity>0?Math.min(soMaxAvailable/data.maxQuantity*100,100):soMaxAvailable>0?60:0;
            bar.style.width = pct+'%';
            bar.style.background = soMaxAvailable<=0?'var(--red)':soMaxAvailable<=5?'#c2410c':'var(--green)';
        }
    } catch(e){}
}

function checkSoQty() {
    const qty = parseInt(document.getElementById('so_qty').value)||0;
    document.getElementById('soWarn').classList.toggle('show', qty > soMaxAvailable && soMaxAvailable > 0);
}

function setSoAll() {
    document.getElementById('so_qty').value = soMaxAvailable > 0 ? soMaxAvailable : 1;
    checkSoQty();
}

async function submitStockOut() {
    const facId  = document.getElementById('so_fac').value;
    const prodId = document.getElementById('so_prod_id').value;
    const qty    = parseInt(document.getElementById('so_qty').value)||0;
    const reason = document.getElementById('so_reason').value.trim();

    if(!facId)  { alert('Vui lòng chọn cơ sở!'); return; }
    if(!prodId) { alert('Vui lòng chọn sản phẩm!'); return; }
    if(qty<=0)  { alert('Số lượng phải lớn hơn 0!'); return; }
    if(!reason) { alert('Vui lòng nhập lý do xuất kho!'); return; }
    if(qty > soMaxAvailable && soMaxAvailable > 0) {
        const ok = confirm(`Số lượng xuất (${qty}) vượt quá tồn kho khả dụng (${soMaxAvailable}). Tiếp tục?`);
        if(!ok) return;
    }

    const btn = document.getElementById('soBtnSave');
    btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...';

    const payload = {
        facilityId: parseInt(facId),
        reason: reason,
        note: document.getElementById('so_note').value,
        items: [{ productId: parseInt(prodId), quantity: qty }]
    };

    try {
        const res = await fetch('/AdminInventory/StockOut', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN_SO },
            body: JSON.stringify(payload)
        }).then(r=>r.json());

        if(res.success) {
            bootstrap.Modal.getInstance(document.getElementById('invModal'))?.hide();
            const t=document.createElement('div');
            t.style.cssText='position:fixed;bottom:1.5rem;right:1.5rem;background:#15803d;color:#fff;padding:.75rem 1.25rem;border-radius:8px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.2);';
            t.innerHTML=`<i class="bi bi-check-circle-fill"></i> ${res.message}`;
            document.body.appendChild(t);
            setTimeout(()=>{ t.style.opacity='0'; t.style.transition='opacity .4s'; setTimeout(()=>{ t.remove(); location.reload(); },400); },1800);
        } else {
            alert(res.message||'Có lỗi xảy ra!');
            btn.disabled=false; btn.innerHTML='<i class="bi bi-box-arrow-up"></i> Xác nhận xuất kho';
        }
    } catch(e) {
        alert('Lỗi kết nối!');
        btn.disabled=false; btn.innerHTML='<i class="bi bi-box-arrow-up"></i> Xác nhận xuất kho';
    }
}
</script>
