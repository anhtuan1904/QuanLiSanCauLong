@model QuanLiSanCauLong.ViewModels.StockTransactionViewModel

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-h: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
    }

    .modal-hd-court {
        background: var(--court-dark);
        color: #fff;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

        .modal-hd-court h5 {
            font-weight: 800;
            font-size: 1.05rem;
            margin: 0 0 2px;
            color: #fff;
        }

        .modal-hd-court p {
            font-size: .78rem;
            color: rgba(255,255,255,.6);
            margin: 0;
        }

        .modal-hd-court .icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            background: rgba(245,158,11,.25);
            color: #fbbf24;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-right: 1rem;
            flex-shrink: 0;
        }

        .modal-hd-court .btn-close {
            filter: invert(1);
            opacity: .7;
        }

    .fl label {
        display: block;
        font-size: .73rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--court-muted);
        margin-bottom: 5px;
    }

    .fc {
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        background: var(--court-bg);
        color: var(--court-text);
        font-size: .875rem;
        padding: .48rem .75rem;
        width: 100%;
        transition: .2s;
    }

        .fc:focus {
            outline: none;
            border-color: var(--court-gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(232,200,64,.2);
        }

    textarea.fc {
        resize: vertical;
        min-height: 70px;
    }

    .section-div {
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-dark);
        display: inline-block;
        padding-bottom: .35rem;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: .85rem;
    }

    .fw-mono {
        font-family: monospace;
        letter-spacing: .3px;
    }

    .prod-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .prod-tbl thead tr {
            background: var(--court-dark);
        }

        .prod-tbl thead th {
            color: rgba(255,255,255,.7);
            font-size: .67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            padding: .6rem .75rem;
            border: none;
        }

        .prod-tbl tbody tr {
            border-bottom: 1px solid var(--court-border);
        }

            .prod-tbl tbody tr:last-child {
                border-bottom: none;
            }

        .prod-tbl td {
            padding: .55rem .6rem;
            vertical-align: middle;
        }

    .btn-add-row {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: .35rem .9rem;
        background: #fffbeb;
        color: #b45309;
        border: 1.5px solid #fcd34d;
        border-radius: 8px;
        font-size: .75rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
    }

        .btn-add-row:hover {
            background: #f59e0b;
            color: #fff;
            border-color: #f59e0b;
        }

    .btn-remove {
        background: none;
        border: none;
        color: #dc2626;
        cursor: pointer;
        padding: .2rem .4rem;
        font-size: .9rem;
    }

        .btn-remove:hover {
            background: #fef2f2;
            border-radius: 5px;
        }

    .row-meta {
        font-size: .72rem;
        color: var(--court-muted);
        margin-top: 3px;
        display: block;
    }

    .warn-note {
        background: #fffbeb;
        border: 1px solid #fcd34d;
        border-radius: 8px;
        padding: .65rem .9rem;
        font-size: .78rem;
        color: #b45309;
        display: flex;
        align-items: flex-start;
        gap: .5rem;
    }

    .modal-foot-court {
        background: var(--court-bg);
        border-top: 1px solid var(--court-border);
        border-radius: 0 0 16px 16px;
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: .6rem;
    }

    .btn-cancel-modal {
        background: var(--court-card);
        color: var(--court-text);
        border: 1.5px solid var(--court-border);
        border-radius: 9px;
        padding: .55rem 1.3rem;
        font-weight: 600;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
    }

        .btn-cancel-modal:hover {
            background: #ede8de;
        }

    .btn-submit-out {
        background: #f59e0b;
        color: #1a1a2e;
        border: none;
        border-radius: 9px;
        padding: .55rem 1.75rem;
        font-weight: 800;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-submit-out:hover {
            background: #d97706;
            box-shadow: 0 4px 12px rgba(245,158,11,.4);
        }
</style>

<div class="modal-hd-court">
    <div class="d-flex align-items-center">
        <div class="icon-wrap"><i class="bi bi-box-arrow-up"></i></div>
        <div>
            <h5>Tạo Phiếu Xuất Kho</h5>
            <p>Xuất hàng bán lẻ, hỏng, điều chuyển hoặc trả nhà cung cấp</p>
        </div>
    </div>
    <button type="button" class="btn-close shadow-none" onclick="this.closest('.modal-overlay').classList.remove('show')"></button>
</div>

<form asp-action="StockOut" method="post" id="stockOutForm">
    <div class="modal-body p-4" style="background:#fff;">

        <div class="section-div"><i class="bi bi-info-circle me-1"></i>Thông Tin Chứng Từ</div>
        <div class="row g-3 mb-3">
            <div class="col-md-7 fl">
                <label>Cơ sở xuất hàng</label>
                <select asp-for="FacilityId" class="fc">
                    <option value="">-- Chọn cơ sở --</option>
                    @if (ViewBag.Facilities != null)
                    {
                        foreach (var f in ViewBag.Facilities)
                        {
                            <option value="@f.FacilityId">@f.FacilityName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-5 fl">
                <label>Ngày xuất kho</label>
                <input asp-for="TransactionDate" type="date" class="fc" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6 fl">
                <label>Lý do xuất kho</label>
                <select asp-for="OutReason" class="fc" id="outReasonSelect">
                    <option value="Sale">🛒 Bán lẻ cho khách</option>
                    <option value="Defective">❌ Hàng lỗi / hư hỏng</option>
                    <option value="Transfer">🔄 Điều chuyển nội bộ</option>
                    <option value="Return">↩️ Trả nhà cung cấp</option>
                    <option value="Expired">📅 Hết hạn sử dụng</option>
                    <option value="Other">📝 Lý do khác</option>
                </select>
            </div>
            <div class="col-md-6 fl">
                <label>Số phiếu / Chứng từ</label>
                <input asp-for="DocumentReference" class="fc fw-mono" placeholder="VD: PX-2025-001" />
            </div>
        </div>

        <!-- Return supplier fields -->
        <div id="returnFields" class="row g-3 mb-3 d-none">
            <div class="col-12">
                <div class="warn-note">
                    <i class="bi bi-arrow-return-left" style="flex-shrink:0;margin-top:1px;"></i>
                    <span><strong>Trả nhà cung cấp:</strong> Vui lòng điền nhà cung cấp và số lô hàng cần trả.</span>
                </div>
            </div>
            <div class="col-md-6 fl">
                <label>Nhà cung cấp</label>
                <select asp-for="SupplierId" class="fc">
                    <option value="">-- Chọn nhà cung cấp --</option>
                    @if (ViewBag.Suppliers != null)
                    {
                        foreach (var s in ViewBag.Suppliers)
                        {
                            <option value="@s.SupplierId">@s.SupplierName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-6 fl">
                <label>Số lô trả lại</label>
                <input asp-for="BatchNumber" class="fc fw-mono" placeholder="LOT-2025-001" />
            </div>
        </div>

        <!-- Product table -->
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="section-div" style="margin-bottom:0;"><i class="bi bi-list-ul me-1"></i>Chi Tiết Hàng Xuất</span>
            <button type="button" class="btn-add-row" id="stockOutAddRowBtn">
                <i class="bi bi-plus-circle"></i> Thêm dòng
            </button>
        </div>

        <div class="table-responsive mb-3">
            <table class="prod-tbl" id="productTableOut">
                <thead>
                    <tr>
                        <th style="min-width:180px;">Sản phẩm</th>
                        <th style="min-width:130px;">Phân loại (Size)</th>
                        <th style="width:110px;">Số lượng xuất</th>
                        <th style="width:80px;">ĐVT</th>
                        <th style="width:40px;text-align:center;">×</th>
                    </tr>
                </thead>
                <tbody id="productTableOutBody">
                    <tr class="product-row-out">
                        <td>
                            <select name="Items[0].ProductId" class="fc stockout-product-sel">
                                <option value="">-- Chọn sản phẩm --</option>
                                @if (ViewBag.Products != null)
                                {
                                    foreach (var p in ViewBag.Products)
                                    {
                                        <option value="@p.ProductId" data-unit="@p.Unit" data-stock="@p.StockQuantity">
                                            @p.ProductName @(!string.IsNullOrEmpty(p.SKU) ? $"({p.SKU})" : "")
                                        </option>
                                    }
                                }
                            </select>
                            <small class="row-meta"></small>
                        </td>
                        <td>
                            <select name="Items[0].VariantId" class="fc variant-select-out" disabled>
                                <option value="">— Chọn SP trước —</option>
                            </select>
                        </td>
                        <td><input name="Items[0].Quantity" type="number" class="fc" placeholder="KD: 0" min="1" /></td>
                        <td><input name="Items[0].Unit" type="text" class="fc fw-mono" placeholder="—" readonly /></td>
                        <td style="text-align:center;"><button type="button" class="btn-remove stockout-remove-btn"><i class="bi bi-trash3"></i></button></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="fl">
            <label>Ghi chú bổ sung</label>
            <textarea asp-for="Note" class="fc" rows="2" placeholder="Thông tin thêm về lần xuất kho này..."></textarea>
        </div>
    </div>

    <div class="modal-foot-court">
        <button type="button" class="btn-cancel-modal" onclick="this.closest('.modal-overlay').classList.remove('show')">Hủy bỏ</button>
        <button type="submit" class="btn-submit-out">
            <i class="bi bi-box-arrow-up"></i> Xác nhận xuất kho
        </button>
    </div>
</form>

<script>
(function () {
    // Product data được serialize an toàn từ server
    const productDataRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ViewBag.Products == null
            ? new object[] {}
            : ((IEnumerable<QuanLiSanCauLong.Models.Product>)ViewBag.Products)
                .Select(p => new {
                    id    = p.ProductId,
                    unit  = p.Unit ?? "",
                    name  = p.ProductName ?? "",
                    stock = p.StockQuantity
                })
                .ToArray()
    ));
    const productDataOut = {};
    productDataRaw.forEach(p => { productDataOut[p.id] = { unit: p.unit, name: p.name, stock: p.stock }; });

    let rowIndexOut = 1;

    function buildProductOptsOut() {
        return '<option value="">-- Chọn sản phẩm --</option>' +
            Object.entries(productDataOut).map(([id, d]) =>
                `<option value="${id}" data-unit="${d.unit}" data-stock="${d.stock}">${d.name}</option>`
            ).join('');
    }

    async function fillUnitOut(select) {
        const id  = select.value;
        const row = select.closest('tr');
        const unitInput  = row.querySelector('input[name*=".Unit"]');
        const qtyInput   = row.querySelector('input[name*=".Quantity"]');
        const meta       = row.querySelector('.row-meta');
        const variantSel = row.querySelector('.variant-select-out');

        if (id && productDataOut[id]) {
            if (unitInput) unitInput.value = productDataOut[id].unit;

            if (variantSel) {
                variantSel.innerHTML = '<option value="">Đang tải...</option>';
                variantSel.disabled = true;
                try {
                    const res  = await fetch(`/Admin/AdminProduct/GetVariants?productId=${id}`);
                    const data = await res.json();
                    if (Array.isArray(data) && data.length > 0) {
                        variantSel.innerHTML = '<option value="">-- Chọn size/màu --</option>' +
                            data.map(v => {
                                const avail = v.availableQuantity;
                                const warn  = avail === 0 ? ' ⚠ Hết' : avail <= 2 ? ' ⚠ Sắp hết' : '';
                                return `<option value="${v.variantId}" data-avail="${avail}">${v.displayName} — KD: ${avail}${warn}</option>`;
                            }).join('');
                        variantSel.disabled = false;
                        variantSel.onchange = () => {
                            const opt   = variantSel.selectedOptions[0];
                            const avail = opt?.dataset?.avail ?? 0;
                            if (qtyInput) qtyInput.placeholder = `Tối đa: ${avail}`;
                            if (meta)     meta.textContent = `Khả dụng: ${avail} ${productDataOut[id].unit}`;
                        };
                    } else {
                        variantSel.innerHTML = '<option value="">Không có phân loại</option>';
                        variantSel.disabled = true;
                        const avail = productDataOut[id].stock;
                        if (qtyInput) qtyInput.placeholder = `Tối đa: ${avail}`;
                        if (meta) meta.textContent = `Tồn kho: ${avail} ${productDataOut[id].unit}`;
                    }
                } catch {
                    variantSel.innerHTML = '<option value="">Không tải được</option>';
                    variantSel.disabled = false;
                }
            }
        } else {
            if (unitInput) unitInput.value = '';
            if (qtyInput)  qtyInput.placeholder = 'KD: 0';
            if (meta)      meta.textContent = '';
            if (variantSel) { variantSel.innerHTML = '<option value="">— Chọn SP trước —</option>'; variantSel.disabled = true; }
        }
    }

    function addRowOut() {
        const idx = rowIndexOut;
        const row = `
        <tr class="product-row-out">
            <td>
                <select name="Items[${idx}].ProductId" class="fc stockout-product-sel">
                    ${buildProductOptsOut()}
                </select>
                <small class="row-meta"></small>
            </td>
            <td>
                <select name="Items[${idx}].VariantId" class="fc variant-select-out" disabled>
                    <option value="">— Chọn SP trước —</option>
                </select>
            </td>
            <td><input name="Items[${idx}].Quantity" type="number" class="fc" placeholder="KD: 0" min="1" /></td>
            <td><input name="Items[${idx}].Unit" type="text" class="fc fw-mono" placeholder="—" readonly /></td>
            <td style="text-align:center;"><button type="button" class="btn-remove stockout-remove-btn"><i class="bi bi-trash3"></i></button></td>
        </tr>`;
        const tbody = document.getElementById('productTableOutBody');
        tbody.insertAdjacentHTML('beforeend', row);
        attachRowEventsOut(tbody.lastElementChild);
        rowIndexOut++;
    }

    function removeRowOut(btn) {
        if (document.querySelectorAll('#productTableOutBody .product-row-out').length > 1)
            btn.closest('tr').remove();
    }

    function attachRowEventsOut(row) {
        const sel = row.querySelector('.stockout-product-sel');
        if (sel) sel.addEventListener('change', () => fillUnitOut(sel));
        const removeBtn = row.querySelector('.stockout-remove-btn');
        if (removeBtn) removeBtn.addEventListener('click', () => removeRowOut(removeBtn));
    }

    // Init first row
    document.querySelectorAll('#productTableOutBody .product-row-out').forEach(attachRowEventsOut);

    // Add row button
    const addBtn = document.getElementById('stockOutAddRowBtn');
    if (addBtn) addBtn.addEventListener('click', addRowOut);

    // Toggle return fields
    const outReason = document.getElementById('outReasonSelect');
    if (outReason) {
        outReason.addEventListener('change', function () {
            const rf = document.getElementById('returnFields');
            if (rf) rf.classList.toggle('d-none', this.value !== 'Return');
        });
    }
})();
</script>
