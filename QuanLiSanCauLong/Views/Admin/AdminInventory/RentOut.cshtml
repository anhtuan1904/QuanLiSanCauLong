@{
    Layout = null;
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
    var products = ViewBag.Products as IEnumerable<QuanLiSanCauLong.Models.Product> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Product>();
    var rentalProds = products.Where(p => p.Category?.BehaviorType == "Rental").ToList();
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --blue: #1d4ed8;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .md-hd {
        padding: 1rem 1.3rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg,#1e3a5f,#1d4ed8);
    }

    .md-title {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }

        .md-title em {
            color: #93c5fd;
            font-style: italic;
        }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.4);
        font-size: 1rem;
        cursor: pointer;
    }

        .md-close:hover {
            color: #fff;
        }

    .md-body {
        padding: 1.2rem 1.3rem;
        max-height: 72vh;
        overflow-y: auto;
    }

    .md-ft {
        padding: .85rem 1.3rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        justify-content: flex-end;
        gap: .55rem;
    }

    .row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .8rem;
    }

    .row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .25rem;
        margin-bottom: .8rem;
    }

        .fg label {
            font-size: .72rem;
            font-weight: 700;
            color: var(--deep);
        }

        .fg .req {
            color: var(--red);
        }

        .fg .hint {
            font-size: .66rem;
            color: var(--muted);
        }

    .fi {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
    }

        .fi:focus {
            border-color: var(--blue);
        }
    /* Combobox */
    .combo-w {
        position: relative;
    }

    .combo-list {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 7px;
        z-index: 100;
        box-shadow: 0 4px 16px rgba(0,0,0,.12);
        max-height: 200px;
        overflow-y: auto;
        display: none;
    }

        .combo-list.show {
            display: block;
        }

    .combo-opt {
        padding: .45rem .82rem;
        font-size: .82rem;
        cursor: pointer;
        color: var(--deep);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .combo-opt:hover {
            background: var(--warm);
        }

        .combo-opt .co-stk {
            font-size: .68rem;
            font-weight: 700;
        }

            .combo-opt .co-stk.ok {
                color: #15803d;
            }

            .combo-opt .co-stk.low {
                color: #c2410c;
            }

            .combo-opt .co-stk.zero {
                color: var(--red);
            }
    /* Stock bar */
    .stk-bar-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: .65rem .9rem;
        margin-bottom: .85rem;
        display: none;
    }

        .stk-bar-box.show {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
        }

    .stk-cell {
        text-align: center;
    }

        .stk-cell .sv {
            font-family: 'Playfair Display',serif;
            font-size: 1.1rem;
            font-weight: 700;
        }

        .stk-cell .sl {
            font-size: .58rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: .1rem;
        }

    .stk-sep {
        width: 1px;
        height: 28px;
        background: var(--border);
    }
    /* Time chips */
    .time-chips {
        display: flex;
        gap: .3rem;
        flex-wrap: wrap;
        margin-top: .3rem;
    }

    .tc {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .22rem .65rem;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: .74rem;
        font-weight: 700;
        cursor: pointer;
        transition: .15s;
    }

        .tc:hover, .tc.on {
            background: var(--blue);
            color: #fff;
            border-color: var(--blue);
        }
    /* Buttons */
    .btn-blue {
        background: linear-gradient(135deg,#1d4ed8,#2563eb);
        color: #fff;
        border: none;
        padding: .62rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        transition: all .2s;
    }

        .btn-blue:hover {
            box-shadow: 0 4px 14px rgba(29,78,216,.3);
            transform: translateY(-1px);
        }

        .btn-blue:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .btn-s {
        padding: .6rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: all .18s;
    }

        .btn-s:hover {
            border-color: var(--deep);
            color: var(--deep);
        }
</style>

<div class="md-hd">
    <span class="md-title"><i class="bi bi-arrow-right-circle me-1" style="color:#93c5fd"></i> Xuất <em>Cho Thuê</em></span>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">

    <div class="row2">
        <div class="fg">
            <label>Cơ sở <span class="req">*</span></label>
            <select id="ro_fac" class="fi" onchange="loadRoStock()">
                @foreach (var f in facilities)
                {
                    <option value="@f.FacilityId">@f.FacilityName</option>
                }
            </select>
        </div>
        <div class="fg">
            <label>Sản phẩm cho thuê <span class="req">*</span></label>
            <div class="combo-w">
                <input type="text" id="ro_prod_txt" class="fi" placeholder="Tìm vợt, giày, áo..."
                       oninput="filterRoProd(this.value)" onfocus="showCombo('roProdList')" />
                <input type="hidden" id="ro_prod_id" />
                <div class="combo-list" id="roProdList">
                    @if (!rentalProds.Any())
                    {
                        <div class="combo-opt" style="color:var(--muted);cursor:default;">Chưa có sản phẩm cho thuê</div>
                    }
                    @foreach (var p in rentalProds)
                    {
                        <div class="combo-opt" onclick="pickRoProd('@Html.Raw(p.ProductName.Replace("'", "\'"))',@p.ProductId,'@(p.Unit ?? "")')">
                            <span>@p.ProductName</span>
                            <span class="co-stk" id="roStk-@p.ProductId">@p.Unit</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Stock indicator -->
    <div class="stk-bar-box" id="roStkBox">
        <div class="stk-cell"><div class="sv" id="roStkAvail" style="color:#15803d">—</div><div class="sl">Khả dụng</div></div>
        <div class="stk-sep"></div>
        <div class="stk-cell"><div class="sv" id="roStkRented" style="color:var(--blue)">—</div><div class="sl">Đang thuê</div></div>
        <div class="stk-sep"></div>
        <div class="stk-cell"><div class="sv" id="roStkHold" style="color:#c2410c">—</div><div class="sl">Treo</div></div>
        <div style="margin-left:auto;font-size:.72rem;color:var(--muted);" id="roStkUnit"></div>
    </div>

    <!-- Khách + sân -->
    <div class="row2">
        <div class="fg">
            <label>Tên khách</label>
            <input type="text" id="ro_cname" class="fi" placeholder="Nguyễn Văn A" />
        </div>
        <div class="fg">
            <label>SĐT khách</label>
            <input type="tel" id="ro_cphone" class="fi" placeholder="09xx..." />
        </div>
    </div>

    <div class="row3">
        <div class="fg">
            <label>Sân <span class="req">*</span></label>
            <input type="text" id="ro_court" class="fi" placeholder="Sân 3" />
        </div>
        <div class="fg">
            <label>Số lượng <span class="req">*</span></label>
            <input type="number" id="ro_qty" class="fi" min="1" value="1" />
        </div>
        <div class="fg">
            <label>Size (nếu có)</label>
            <div class="combo-w">
                <input type="text" id="ro_size" class="fi" placeholder="40, M, XL..."
                       onfocus="showCombo('roSizeList')" oninput="filterCombo('roSizeList',this.value)" />
                <div class="combo-list" id="roSizeList">
                    @foreach (var s in new[] { "XS", "S", "M", "L", "XL", "XXL", "36", "37", "38", "39", "40", "41", "42", "43", "44" })
                    {
                        <div class="combo-opt" onclick="pickCombo('ro_size','@s')">@s</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="fg">
        <label>Thời gian thuê dự kiến</label>
        <div class="time-chips">
            @foreach (var h in new[] { 1, 2, 3, 4 })
            {
                <span class="tc" onclick="setRoHours(@h, this)">@h giờ</span>
            }
            <span class="tc" onclick="setRoHours(0, this)">Không giới hạn</span>
        </div>
        <input type="number" id="ro_hours" class="fi" style="margin-top:.4rem;" min="0" value="2" placeholder="0 = không giới hạn" />
    </div>

    <div class="fg">
        <label>Ghi chú</label>
        <input type="text" id="ro_note" class="fi" placeholder="Tình trạng hàng khi xuất, yêu cầu đặc biệt..." />
    </div>
</div>

<div class="md-ft">
    <button class="btn-s" data-bs-dismiss="modal">Hủy</button>
    <button class="btn-blue" id="roBtnSave" onclick="submitRentOut()">
        <i class="bi bi-arrow-right-circle"></i> Xuất cho thuê
    </button>
</div>

<script>
    const RO_TOKEN  = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    let roAvail = 0, roUnit = '';

    /* ── Combobox ── */
    function showCombo(id) { document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); document.getElementById(id)?.classList.add('show'); }
    function filterCombo(id, q) { const l=document.getElementById(id); if(!l)return; l.classList.add('show'); l.querySelectorAll('.combo-opt').forEach(o=>{ o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none'; }); }
    function pickCombo(inpId, val) { document.getElementById(inpId).value=val; document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); }
    document.addEventListener('click', e=>{ if(!e.target.closest('.combo-w')) document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show')); });

    function filterRoProd(q) {
        const l = document.getElementById('roProdList'); if(!l) return;
        l.classList.add('show');
        l.querySelectorAll('.combo-opt').forEach(o=>{ o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none'; });
        document.getElementById('ro_prod_id').value = '';
    }
    async function pickRoProd(name, id, unit) {
        document.getElementById('ro_prod_txt').value = name;
        document.getElementById('ro_prod_id').value  = id;
        document.getElementById('roProdList').classList.remove('show');
        await loadRoStock();
    }

    /* ── Load stock ── */
    async function loadRoStock() {
        const fac  = document.getElementById('ro_fac').value;
        const prod = document.getElementById('ro_prod_id').value;
        const box  = document.getElementById('roStkBox');
        if (!fac || !prod) { box.classList.remove('show'); return; }
        try {
            const d = await fetch(`/AdminInventory/GetProductStock?facilityId=${fac}&productId=${prod}`).then(r=>r.json());
            if (d.success) {
                roAvail = d.availableQuantity;
                roUnit  = d.unit;
                document.getElementById('roStkAvail').textContent  = d.availableQuantity;
                document.getElementById('roStkRented').textContent = d.rentedQuantity;
                document.getElementById('roStkHold').textContent   = d.holdQuantity;
                document.getElementById('roStkUnit').textContent   = d.unit;
                document.getElementById('ro_qty').max = d.availableQuantity;
                box.classList.add('show');
            } else { box.classList.remove('show'); }
        } catch { box.classList.remove('show'); }
    }

    /* ── Time chips ── */
    function setRoHours(h, el) {
        document.getElementById('ro_hours').value = h;
        document.querySelectorAll('.tc').forEach(c => c.classList.remove('on'));
        el.classList.add('on');
    }

    /* ── Submit ── */
    async function submitRentOut() {
        const prod  = document.getElementById('ro_prod_id').value;
        const qty   = parseInt(document.getElementById('ro_qty').value)||0;
        const court = document.getElementById('ro_court').value.trim();

        if (!prod)   { alert('Vui lòng chọn sản phẩm!'); return; }
        if (qty < 1) { alert('Số lượng phải lớn hơn 0!'); return; }
        if (!court)  { alert('Vui lòng nhập sân!'); return; }
        if (qty > roAvail && roAvail > 0) { alert(`Không đủ hàng khả dụng (còn ${roAvail})!`); return; }

        const btn = document.getElementById('roBtnSave');
        btn.disabled=true; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>...';

        const fd = new FormData();
        fd.append('facilityId',    document.getElementById('ro_fac').value);
        fd.append('productId',     prod);
        fd.append('quantity',      qty);
        fd.append('courtCode',     court);
        fd.append('customerName',  document.getElementById('ro_cname').value);
        fd.append('customerPhone', document.getElementById('ro_cphone').value);
        fd.append('size',          document.getElementById('ro_size').value);
        fd.append('maxHours',      document.getElementById('ro_hours').value);
        fd.append('note',          document.getElementById('ro_note').value);

        try {
            const res = await fetch('/AdminInventory/RentOut', {
                method:'POST', headers:{'RequestVerificationToken':RO_TOKEN}, body:fd
            }).then(r=>r.json());
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('invModal'))?.hide();
                const t=document.createElement('div');
                t.style.cssText='position:fixed;bottom:1.5rem;right:1.5rem;background:#15803d;color:#fff;padding:.75rem 1.25rem;border-radius:8px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.2);';
                t.innerHTML=`<i class="bi bi-check-circle-fill"></i> ${res.message}`;
                document.body.appendChild(t);
                setTimeout(()=>{ t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>{t.remove();location.reload();},400);},1800);
            } else {
                alert(res.message||'Có lỗi xảy ra!');
                btn.disabled=false; btn.innerHTML='<i class="bi bi-arrow-right-circle"></i> Xuất cho thuê';
            }
        } catch(e) {
            alert('Lỗi kết nối!');
            btn.disabled=false; btn.innerHTML='<i class="bi bi-arrow-right-circle"></i> Xuất cho thuê';
        }
    }
</script>
