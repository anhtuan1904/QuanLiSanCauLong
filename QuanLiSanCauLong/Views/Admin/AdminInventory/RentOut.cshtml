@{
    Layout = null;
    var facilities = ViewBag.Facilities as List<QuanLiSanCauLong.Models.Facility> ?? new();
    var products = ViewBag.Products as List<QuanLiSanCauLong.Models.Product> ?? new();
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #fff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --blue: #1d4ed8;
        --blue-soft: #eff6ff;
    }

    .ro-wrap {
        font-family: 'Outfit',sans-serif;
    }

    .ro-hd {
        background: linear-gradient(135deg,#1e3a5f,#1d4ed8);
        color: #fff;
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .ro-hd-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        background: rgba(255,255,255,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .ro-hd h5 {
        font-weight: 800;
        font-size: 1rem;
        margin: 0;
    }

    .ro-hd p {
        font-size: .75rem;
        color: rgba(255,255,255,.65);
        margin: 0;
    }

    .ro-close {
        margin-left: auto;
        background: none;
        border: none;
        color: rgba(255,255,255,.7);
        font-size: 1.3rem;
        cursor: pointer;
    }

    .ro-body {
        padding: 1.25rem 1.5rem;
        background: var(--cream);
    }

    .ro-field {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        margin-bottom: .85rem;
    }

        .ro-field label {
            font-size: .72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--muted);
        }

    .ro-fc {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .5rem .8rem;
        font-size: .875rem;
        width: 100%;
        background: var(--card);
        outline: none;
        font-family: 'Outfit',sans-serif;
    }

        .ro-fc:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(29,78,216,.12);
        }

    .ro-two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }

    .ro-three {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .65rem;
    }

    /* Stock preview */
    .ro-stock-bar {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .65rem 1rem;
        margin-bottom: .85rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .rsb-cell {
        text-align: center;
    }

    .rsb-val {
        font-size: 1rem;
        font-weight: 800;
    }

    .rsb-lbl {
        font-size: .62rem;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 700;
    }

    .rsb-avail .rsb-val {
        color: #15803d;
    }

    .rsb-hold .rsb-val {
        color: #c2410c;
    }

    .rsb-rent .rsb-val {
        color: var(--blue);
    }

    .rsb-sep {
        width: 1px;
        height: 30px;
        background: var(--border);
    }

    /* Time estimator */
    .ro-time-chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .75rem;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: var(--card);
        font-size: .75rem;
        font-weight: 700;
        cursor: pointer;
        transition: .15s;
        margin: .2rem;
    }

        .ro-time-chip:hover, .ro-time-chip.active {
            background: var(--blue);
            color: #fff;
            border-color: var(--blue);
        }

    .ro-foot {
        padding: .9rem 1.5rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        display: flex;
        gap: .6rem;
        justify-content: flex-end;
    }

    .btn-cancel {
        padding: .5rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        background: transparent;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Outfit',sans-serif;
    }

    .btn-rent {
        padding: .5rem 1.5rem;
        border: none;
        border-radius: 9px;
        background: var(--blue);
        color: #fff;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
        font-family: 'Outfit',sans-serif;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-rent:hover {
            background: #1e40af;
        }

        .btn-rent:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .spinner-sm {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .7s linear infinite;
    }
    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="ro-wrap">
    <div class="ro-hd">
        <div class="ro-hd-icon"><i class="bi bi-arrow-right-circle"></i></div>
        <div>
            <h5>Xuất Đồ Cho Thuê</h5>
            <p>Vợt, giày, áo – khách mượn lên sân</p>
        </div>
        <button class="ro-close" onclick="$('#inventoryModal').modal('hide')">&times;</button>
    </div>

    <div class="ro-body">
        <div class="ro-two">
            <div class="ro-field">
                <label>Cơ sở <span style="color:#dc2626">*</span></label>
                <select id="ro_facilityId" class="ro-fc" onchange="loadRoStock()">
                    @foreach (var f in facilities)
                    {
                        <option value="@f.FacilityId">@f.FacilityName</option>
                    }
                </select>
            </div>
            <div class="ro-field">
                <label>Sản phẩm cho thuê <span style="color:#dc2626">*</span></label>
                <select id="ro_productId" class="ro-fc" onchange="loadRoStock()">
                    <option value="">— Chọn sản phẩm —</option>
                    @foreach (var p in products.Where(p => p.Category?.BehaviorType == "Rental"))
                    {
                        <option value="@p.ProductId" data-unit="@p.Unit">@p.ProductName</option>
                    }
                </select>
            </div>
        </div>

        <!-- Stock bar -->
        <div class="ro-stock-bar" id="roStockBar" style="display:none;">
            <div class="rsb-cell rsb-avail">
                <div class="rsb-val" id="rsb_avail">—</div>
                <div class="rsb-lbl">Khả dụng</div>
            </div>
            <div class="rsb-sep"></div>
            <div class="rsb-cell rsb-hold">
                <div class="rsb-val" id="rsb_hold">—</div>
                <div class="rsb-lbl">Treo</div>
            </div>
            <div class="rsb-sep"></div>
            <div class="rsb-cell rsb-rent">
                <div class="rsb-val" id="rsb_rent">—</div>
                <div class="rsb-lbl">Đang thuê</div>
            </div>
            <div style="margin-left:auto;font-size:.72rem;color:var(--muted);" id="rsb_unit"></div>
        </div>

        <div class="ro-two">
            <div class="ro-field">
                <label>Tên khách</label>
                <input type="text" id="ro_customerName" class="ro-fc" placeholder="Nguyễn Văn A" />
            </div>
            <div class="ro-field">
                <label>SĐT khách</label>
                <input type="tel" id="ro_customerPhone" class="ro-fc" placeholder="09xx..." />
            </div>
        </div>

        <div class="ro-three">
            <div class="ro-field">
                <label>Sân <span style="color:#dc2626">*</span></label>
                <input type="text" id="ro_courtCode" class="ro-fc" placeholder="Sân 3" />
            </div>
            <div class="ro-field">
                <label>Số lượng <span style="color:#dc2626">*</span></label>
                <input type="number" id="ro_quantity" class="ro-fc" min="1" value="1" />
            </div>
            <div class="ro-field">
                <label>Size (nếu có)</label>
                <input type="text" id="ro_size" class="ro-fc" placeholder="40, M, XL..." />
            </div>
        </div>

        <div class="ro-field">
            <label>Thời gian thuê dự kiến</label>
            <div>
                <span class="ro-time-chip" onclick="setRoHours(1)">1 giờ</span>
                <span class="ro-time-chip" onclick="setRoHours(2)">2 giờ</span>
                <span class="ro-time-chip" onclick="setRoHours(3)">3 giờ</span>
                <span class="ro-time-chip" onclick="setRoHours(0)">Không giới hạn</span>
            </div>
            <input type="number" id="ro_maxHours" class="ro-fc" style="margin-top:.4rem;"
                   min="0" value="2" placeholder="0 = không giới hạn" />
        </div>

        <div class="ro-field">
            <label>Ghi chú</label>
            <input type="text" id="ro_note" class="ro-fc" placeholder="Tình trạng hàng khi xuất, yêu cầu đặc biệt..." />
        </div>
    </div>

    <div class="ro-foot">
        <button class="btn-cancel" onclick="$('#inventoryModal').modal('hide')">Huỷ</button>
        <button class="btn-rent" id="roSubmitBtn" onclick="submitRentOut()">
            <i class="bi bi-arrow-right-circle"></i> Xuất cho thuê
        </button>
    </div>
</div>

<script>
    let _roUnit = '';
    let _roAvail = 0;

    async function loadRoStock() {
        const fid = document.getElementById('ro_facilityId').value;
        const pid = document.getElementById('ro_productId').value;
        const bar = document.getElementById('roStockBar');
        if (!pid) { bar.style.display = 'none'; return; }

        try {
            const r = await fetch(`/AdminInventory/GetProductStock?facilityId=${fid}&productId=${pid}`);
            const d = await r.json();
            if (d.success) {
                _roUnit  = d.unit;
                _roAvail = d.availableQuantity;
                document.getElementById('rsb_avail').textContent = d.availableQuantity;
                document.getElementById('rsb_hold').textContent  = d.holdQuantity;
                document.getElementById('rsb_rent').textContent  = d.rentedQuantity;
                document.getElementById('rsb_unit').textContent  = d.unit;
                document.getElementById('ro_quantity').max       = d.availableQuantity;
                bar.style.display = 'flex';
            } else {
                bar.style.display = 'none';
            }
        } catch { bar.style.display = 'none'; }
    }

    function setRoHours(h) {
        document.getElementById('ro_maxHours').value = h;
        document.querySelectorAll('.ro-time-chip').forEach(c => c.classList.remove('active'));
        event.target.classList.add('active');
    }

    async function submitRentOut() {
        const btn = document.getElementById('roSubmitBtn');
        const pid = document.getElementById('ro_productId').value;
        const qty = parseInt(document.getElementById('ro_quantity').value);
        const court = document.getElementById('ro_courtCode').value.trim();

        if (!pid)    { alert('Vui lòng chọn sản phẩm!'); return; }
        if (!qty || qty < 1) { alert('Số lượng phải lớn hơn 0!'); return; }
        if (!court)  { alert('Vui lòng nhập sân!'); return; }
        if (qty > _roAvail) { alert(`Không đủ hàng khả dụng (${_roAvail})!`); return; }

        btn.disabled = true;
        btn.innerHTML = '<div class="spinner-sm"></div> Đang xử lý...';

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const form  = new FormData();
        form.append('facilityId',    document.getElementById('ro_facilityId').value);
        form.append('productId',     pid);
        form.append('quantity',      qty);
        form.append('courtCode',     court);
        form.append('customerName',  document.getElementById('ro_customerName').value);
        form.append('customerPhone', document.getElementById('ro_customerPhone').value);
        form.append('size',          document.getElementById('ro_size').value);
        form.append('maxHours',      document.getElementById('ro_maxHours').value);
        form.append('note',          document.getElementById('ro_note').value);
        form.append('__RequestVerificationToken', token);

        try {
            const res  = await fetch('/AdminInventory/RentOut', { method: 'POST', body: form });
            const data = await res.json();
            if (data.success) {
                showToast(true, `Đã xuất ${qty} cho thuê – Sân ${court}`);
                setTimeout(() => { $('#inventoryModal').modal('hide'); location.reload(); }, 900);
            } else {
                showToast(false, data.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-arrow-right-circle"></i> Xuất cho thuê';
            }
        } catch {
            showToast(false, 'Lỗi kết nối.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-right-circle"></i> Xuất cho thuê';
        }
    }

    function showToast(ok, msg) {
        const el = document.getElementById('invToastWrap');
        if (!el) return;
        const d = document.createElement('div');
        d.className = 'inv-toast ' + (ok ? 'inv-toast-ok' : 'inv-toast-err');
        d.textContent = msg;
        el.appendChild(d);
        setTimeout(() => d.remove(), 3500);
    }
</script>
