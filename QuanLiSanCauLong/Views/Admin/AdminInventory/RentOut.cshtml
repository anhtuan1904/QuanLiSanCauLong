@{
    Layout = null;
    var facilities = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Facility>();
    var products = ViewBag.Products as IEnumerable<QuanLiSanCauLong.Models.Product> ?? Enumerable.Empty<QuanLiSanCauLong.Models.Product>();
    var rentalProds = products.Where(p => p.Category?.BehaviorType == "Rental").ToList();
}
<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    .stk-bar-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: .65rem .9rem;
        margin-bottom: .85rem;
        display: none;
    }

        .stk-bar-box.show {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
        }

    .stk-cell {
        text-align: center;
    }

        .stk-cell .sv {
            font-family: 'Playfair Display',serif;
            font-size: 1.1rem;
            font-weight: 700;
        }

        .stk-cell .sl {
            font-size: .58rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            margin-top: .1rem;
        }

    .stk-sep {
        width: 1px;
        height: 28px;
        background: var(--border);
    }

    .time-chips {
        display: flex;
        gap: .3rem;
        flex-wrap: wrap;
        margin-top: .3rem;
    }

    .tc {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .22rem .65rem;
        border-radius: 20px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: .74rem;
        font-weight: 700;
        cursor: pointer;
        transition: .15s;
    }

        .tc:hover, .tc.on {
            background: var(--blue);
            color: #fff;
            border-color: var(--blue);
        }

    .btn-blue {
        background: linear-gradient(135deg,#1d4ed8,#2563eb);
        color: #fff;
        border: none;
        padding: .62rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        transition: all .2s;
    }

        .btn-blue:hover {
            box-shadow: 0 4px 14px rgba(29,78,216,.3);
            transform: translateY(-1px);
        }

        .btn-blue:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<div class="md-hd rental">
    <span class="md-title"><i class="bi bi-arrow-right-circle me-1" style="color:#93c5fd"></i> Xuất <em>Cho Thuê</em></span>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">
    <div class="row2">
        <div class="fg">
            <label>Cơ sở <span class="req">*</span></label>
            <select id="ro_fac" class="fi" onchange="loadRoStock()">
                @foreach (var f in facilities)
                {
                    <option value="@f.FacilityId">@f.FacilityName</option>
                }
            </select>
        </div>
        <div class="fg">
            <label>Sản phẩm cho thuê <span class="req">*</span></label>
            <div class="cmb-wrap">
                <input type="text" id="ro_prod_txt" class="fi" placeholder="Tìm vợt, giày, áo..."
                       oninput="filterRoProd(this.value)" onfocus="showCmb('roProdList')" />
                <input type="hidden" id="ro_prod_id" />
                <div class="cmb-list" id="roProdList">
                    @if (!rentalProds.Any())
                    {
                        <div class="cmb-item" style="color:var(--muted);cursor:default">Chưa có sản phẩm cho thuê</div>
                    }
                    @foreach (var p in rentalProds)
                    {
                        <div class="cmb-item" onclick="pickRoProd('@Html.Raw(p.ProductName.Replace("'", "\\'"))',@p.ProductId)"><span>@p.ProductName</span><small>@p.Unit</small></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="stk-bar-box" id="roStkBox">
        <div class="stk-cell"><div class="sv" id="roStkAvail" style="color:#15803d">—</div><div class="sl">Khả dụng</div></div>
        <div class="stk-sep"></div>
        <div class="stk-cell"><div class="sv" id="roStkRented" style="color:var(--blue)">—</div><div class="sl">Đang thuê</div></div>
        <div class="stk-sep"></div>
        <div class="stk-cell"><div class="sv" id="roStkHold" style="color:#c2410c">—</div><div class="sl">Treo</div></div>
        <div style="margin-left:auto;font-size:.72rem;color:var(--muted)" id="roStkUnit"></div>
    </div>

    <div class="row2">
        <div class="fg">
            <label>Tên khách</label>
            <input type="text" id="ro_cname" class="fi" placeholder="Nguyễn Văn A" />
        </div>
        <div class="fg">
            <label>SĐT khách</label>
            <input type="tel" id="ro_cphone" class="fi" placeholder="09xx..." />
        </div>
    </div>

    <div class="row3">
        <div class="fg">
            <label>Sân <span class="req">*</span></label>
            <input type="text" id="ro_court" class="fi" placeholder="Sân 3" />
        </div>
        <div class="fg">
            <label>Số lượng <span class="req">*</span></label>
            <input type="number" id="ro_qty" class="fi" min="1" value="1" />
        </div>
        <div class="fg">
            <label>Size (nếu có)</label>
            <div class="cmb-wrap">
                <input type="text" id="ro_size" class="fi" placeholder="40, M, XL..."
                       onfocus="showCmb('roSizeList')" oninput="filterCmbLocal('roSizeList',this.value)" />
                <div class="cmb-list" id="roSizeList">
                    @foreach (var s in new[] { "XS", "S", "M", "L", "XL", "XXL", "36", "37", "38", "39", "40", "41", "42", "43", "44" })
                    {
                        <div class="cmb-item" onclick="pickCmbLocal('ro_size','@s')">@s</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="fg">
        <label>Thời gian thuê dự kiến</label>
        <div class="time-chips">
            @foreach (var h in new[] { 1, 2, 3, 4 })
            {
                <span class="tc" onclick="setRoHours(@h,this)">@h giờ</span>
            }
            <span class="tc" onclick="setRoHours(0,this)">Không giới hạn</span>
        </div>
        <input type="number" id="ro_hours" class="fi" style="margin-top:.4rem" min="0" value="2" placeholder="0 = không giới hạn" />
    </div>

    <div class="fg">
        <label>Ghi chú</label>
        <input type="text" id="ro_note" class="fi" placeholder="Tình trạng hàng khi xuất, yêu cầu đặc biệt..." />
    </div>
</div>

<div class="md-ft">
    <button class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button class="btn-blue" id="roBtnSave" onclick="submitRentOut()">
        <i class="bi bi-arrow-right-circle"></i> Xuất cho thuê
    </button>
</div>

<script>
    const RO_TOKEN=document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';
    let roAvail=0;

    function showCmb(id){document.querySelectorAll('.cmb-list').forEach(l=>l.classList.remove('open'));document.getElementById(id)?.classList.add('open');}
    function filterCmbLocal(id,q){const l=document.getElementById(id);if(!l)return;l.classList.add('open');l.querySelectorAll('.cmb-item').forEach(o=>{o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none';});}
    function pickCmbLocal(inpId,val){document.getElementById(inpId).value=val;document.querySelectorAll('.cmb-list').forEach(l=>l.classList.remove('open'));}
    document.addEventListener('click',e=>{if(!e.target.closest('.cmb-wrap'))document.querySelectorAll('.cmb-list').forEach(l=>l.classList.remove('open'));});
    function filterRoProd(q){const l=document.getElementById('roProdList');if(!l)return;l.classList.add('open');l.querySelectorAll('.cmb-item').forEach(o=>{o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none';});document.getElementById('ro_prod_id').value='';}
    async function pickRoProd(name,id){document.getElementById('ro_prod_txt').value=name;document.getElementById('ro_prod_id').value=id;document.getElementById('roProdList').classList.remove('open');await loadRoStock();}

    async function loadRoStock(){
        const fac=document.getElementById('ro_fac').value,prod=document.getElementById('ro_prod_id').value;
        const box=document.getElementById('roStkBox');
        if(!fac||!prod){box.classList.remove('show');return;}
        try{
            const d=await fetch(`/AdminInventory/GetProductStock?facilityId=${fac}&productId=${prod}`).then(r=>r.json());
            if(d.success){roAvail=d.availableQuantity;document.getElementById('roStkAvail').textContent=d.availableQuantity;document.getElementById('roStkRented').textContent=d.rentedQuantity;document.getElementById('roStkHold').textContent=d.holdQuantity;document.getElementById('roStkUnit').textContent=d.unit;document.getElementById('ro_qty').max=d.availableQuantity;box.classList.add('show');}
            else box.classList.remove('show');
        }catch{box.classList.remove('show');}
    }
    function setRoHours(h,el){document.getElementById('ro_hours').value=h;document.querySelectorAll('.tc').forEach(c=>c.classList.remove('on'));el.classList.add('on');}

    async function submitRentOut(){
        const prod=document.getElementById('ro_prod_id').value;
        const qty=parseInt(document.getElementById('ro_qty').value)||0;
        const court=document.getElementById('ro_court').value.trim();
        if(!prod){alert('Vui lòng chọn sản phẩm!');return;}
        if(qty<1){alert('Số lượng phải lớn hơn 0!');return;}
        if(!court){alert('Vui lòng nhập sân!');return;}
        if(qty>roAvail&&roAvail>0){alert(`Không đủ hàng khả dụng (còn ${roAvail})!`);return;}
        const btn=document.getElementById('roBtnSave');
        btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>...';
        const fd=new FormData();
        fd.append('facilityId',document.getElementById('ro_fac').value);
        fd.append('productId',prod);fd.append('quantity',qty);fd.append('courtCode',court);
        fd.append('customerName',document.getElementById('ro_cname').value);
        fd.append('customerPhone',document.getElementById('ro_cphone').value);
        fd.append('size',document.getElementById('ro_size').value);
        fd.append('maxHours',document.getElementById('ro_hours').value);
        fd.append('note',document.getElementById('ro_note').value);
        try{
            const res=await fetch('/AdminInventory/RentOut',{method:'POST',headers:{'RequestVerificationToken':RO_TOKEN},body:fd}).then(r=>r.json());
            if(res.success){bootstrap.Modal.getInstance(document.getElementById('invModal'))?.hide();showToast(res.message,true);setTimeout(()=>location.reload(),1500);}
            else{alert(res.message||'Có lỗi!');btn.disabled=false;btn.innerHTML='<i class="bi bi-arrow-right-circle"></i> Xuất cho thuê';}
        }catch(e){alert('Lỗi kết nối!');btn.disabled=false;btn.innerHTML='<i class="bi bi-arrow-right-circle"></i> Xuất cho thuê';}
    }
    function showToast(msg,ok){const t=document.createElement('div');t.style.cssText=`position:fixed;bottom:1.5rem;right:1.5rem;background:${ok?'#15803d':'#c94b2a'};color:#fff;padding:.75rem 1.25rem;border-radius:8px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.2)`;t.innerHTML=`<i class="bi bi-${ok?'check-circle-fill':'exclamation-circle-fill'}"></i> ${msg}`;document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>t.remove(),400);},2200);}
</script>
