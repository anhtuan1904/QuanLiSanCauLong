@model QuanLiSanCauLong.Models.Inventory
@{
    Layout = null;
    var committed = Model.HoldQuantity + Model.RentedQuantity + Model.DamagedQuantity;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #fff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --orange: #c2410c;
        --orange-soft: #fff7ed;
    }

    .adj-wrap {
        font-family: 'Outfit',sans-serif;
    }

    .adj-hd {
        background: linear-gradient(135deg,#78350f,#92400e);
        color: #fff;
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .adj-hd-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        background: rgba(255,255,255,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .adj-hd h5 {
        font-weight: 800;
        font-size: 1rem;
        margin: 0;
    }

    .adj-hd p {
        font-size: .75rem;
        color: rgba(255,255,255,.65);
        margin: 0;
    }

    .adj-close {
        margin-left: auto;
        background: none;
        border: none;
        color: rgba(255,255,255,.7);
        font-size: 1.3rem;
        cursor: pointer;
    }

    .adj-body {
        padding: 1.25rem 1.5rem;
        background: var(--cream);
    }

    /* Current stock snapshot */
    .adj-snapshot {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .5rem;
        margin-bottom: 1.1rem;
    }

    .snap-cell {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .6rem .75rem;
        text-align: center;
    }

    .snap-val {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--deep);
        line-height: 1;
    }

    .snap-lbl {
        font-size: .63rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: 2px;
    }

    .snap-cell.avail .snap-val {
        color: #15803d;
    }

    .snap-cell.hold .snap-val {
        color: #c2410c;
    }

    .snap-cell.rent .snap-val {
        color: #1d4ed8;
    }

    .snap-cell.dmg .snap-val {
        color: #7c3aed;
    }

    .adj-field {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        margin-bottom: .85rem;
    }

        .adj-field label {
            font-size: .72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--muted);
        }

    .adj-fc {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .5rem .8rem;
        font-size: .875rem;
        width: 100%;
        background: var(--card);
        outline: none;
        font-family: 'Outfit',sans-serif;
    }

        .adj-fc:focus {
            border-color: var(--gold2);
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

    /* Live diff indicator */
    .adj-diff-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .75rem;
        padding: .65rem 1rem;
        border-radius: 10px;
        border: 1.5px solid var(--border);
        background: var(--card);
        margin-bottom: .85rem;
        font-size: .85rem;
        font-weight: 700;
    }

    .diff-before {
        color: var(--muted);
    }

    .diff-arrow {
        font-size: 1rem;
    }

    .diff-after {
        color: var(--deep);
        font-size: 1.05rem;
    }

    .diff-badge {
        font-size: .75rem;
        padding: .15rem .55rem;
        border-radius: 20px;
        font-weight: 800;
        margin-left: .35rem;
    }

    .diff-plus {
        background: #dcfce7;
        color: #15803d;
    }

    .diff-minus {
        background: #fef2f2;
        color: #dc2626;
    }

    .diff-zero {
        background: var(--warm);
        color: var(--muted);
    }

    /* Min constraint warning */
    .adj-min-warn {
        background: var(--orange-soft);
        border: 1px solid #fed7aa;
        border-radius: 8px;
        padding: .6rem .9rem;
        font-size: .78rem;
        color: var(--orange);
        margin-bottom: .75rem;
        display: none;
        align-items: center;
        gap: .4rem;
    }

        .adj-min-warn.show {
            display: flex;
        }

    .adj-foot {
        padding: .9rem 1.5rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        display: flex;
        gap: .6rem;
        justify-content: flex-end;
    }

    .btn-cancel {
        padding: .5rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        background: transparent;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Outfit',sans-serif;
    }

    .btn-adj {
        padding: .5rem 1.5rem;
        border: none;
        border-radius: 9px;
        background: var(--gold2);
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
        font-family: 'Outfit',sans-serif;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-adj:hover {
            background: var(--gold);
        }

        .btn-adj:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .spinner-sm {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(0,0,0,.2);
        border-top-color: var(--deep);
        border-radius: 50%;
        animation: spin .7s linear infinite;
    }
    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="adj-wrap">
    <div class="adj-hd">
        <div class="adj-hd-icon"><i class="bi bi-sliders"></i></div>
        <div>
            <h5>Điều Chỉnh Kiểm Kê</h5>
            <p>@Model.Product?.ProductName · @Model.Facility?.FacilityName</p>
        </div>
        <button class="adj-close" onclick="$('#inventoryModal').modal('hide')">&times;</button>
    </div>

    <div class="adj-body">
        <!-- Snapshot -->
        <div class="adj-snapshot">
            <div class="snap-cell">
                <div class="snap-val">@Model.Quantity</div>
                <div class="snap-lbl">📦 Tổng kho</div>
            </div>
            <div class="snap-cell avail">
                <div class="snap-val">@Model.AvailableQuantity</div>
                <div class="snap-lbl">✅ Khả dụng</div>
            </div>
            <div class="snap-cell hold">
                <div class="snap-val">@Model.HoldQuantity</div>
                <div class="snap-lbl">🔒 Treo</div>
            </div>
            <div class="snap-cell rent">
                <div class="snap-val">@Model.RentedQuantity</div>
                <div class="snap-lbl">🔄 Thuê</div>
            </div>
        </div>

        @if (committed > 0)
        {
            <div class="adj-min-warn show">
                <i class="bi bi-info-circle-fill"></i>
                Số lượng mới phải ≥ <strong>@committed</strong> (treo @Model.HoldQuantity + thuê @Model.RentedQuantity + hỏng @Model.DamagedQuantity đang được cam kết)
            </div>
        }

        <!-- Diff bar -->
        <div class="adj-diff-bar" id="adjDiffBar">
            <span class="diff-before">Hiện: <strong>@Model.Quantity</strong></span>
            <span class="diff-arrow">→</span>
            <span class="diff-after" id="adjAfterVal">@Model.Quantity</span>
            <span class="diff-badge diff-zero" id="adjDiffBadge">±0</span>
        </div>

        <div class="adj-field">
            <label>Số lượng tồn kho thực tế (sau kiểm kê) <span style="color:#dc2626">*</span></label>
            <input type="number" id="adjNewQty" class="adj-fc" min="@committed"
                   value="@Model.Quantity" oninput="updateAdjDiff()" />
        </div>

        <div class="adj-field">
            <label>Ghi chú kiểm kê</label>
            <textarea id="adjNote" class="adj-fc" rows="2"
                      placeholder="Lý do chênh lệch: hao hụt tự nhiên, nhầm lẫn nhập liệu..."></textarea>
        </div>
    </div>

    <div class="adj-foot">
        <button class="btn-cancel" onclick="$('#inventoryModal').modal('hide')">Huỷ</button>
        <button class="btn-adj" id="adjSubmitBtn" onclick="submitAdjustment()">
            <i class="bi bi-sliders"></i> Xác nhận điều chỉnh
        </button>
    </div>
</div>

<input type="hidden" id="adjInventoryId" value="@Model.InventoryId" />
<input type="hidden" id="adjOldQty" value="@Model.Quantity" />
<input type="hidden" id="adjCommitted" value="@committed" />

<script>
    function updateAdjDiff() {
        const newQty   = parseInt(document.getElementById('adjNewQty').value) || 0;
        const oldQty   = parseInt(document.getElementById('adjOldQty').value);
        const committed = parseInt(document.getElementById('adjCommitted').value);
        const diff     = newQty - oldQty;
        const btn      = document.getElementById('adjSubmitBtn');
        const warn     = document.querySelector('.adj-min-warn');

        document.getElementById('adjAfterVal').textContent = newQty;

        const badge = document.getElementById('adjDiffBadge');
        if (diff > 0) {
            badge.textContent = '+' + diff;
            badge.className   = 'diff-badge diff-plus';
        } else if (diff < 0) {
            badge.textContent = diff;
            badge.className   = 'diff-badge diff-minus';
        } else {
            badge.textContent = '±0';
            badge.className   = 'diff-badge diff-zero';
        }

        if (newQty < committed) {
            if (warn) warn.classList.add('show');
            btn.disabled = true;
        } else {
            if (warn) warn.classList.remove('show');
            btn.disabled = false;
        }
    }

    async function submitAdjustment() {
        const btn    = document.getElementById('adjSubmitBtn');
        const invId  = document.getElementById('adjInventoryId').value;
        const newQty = document.getElementById('adjNewQty').value;
        const note   = document.getElementById('adjNote').value;
        const token  = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        btn.disabled = true;
        btn.innerHTML = '<div class="spinner-sm"></div> Đang lưu...';

        const form = new FormData();
        form.append('inventoryId', invId);
        form.append('newQuantity', newQty);
        form.append('note', note);
        form.append('__RequestVerificationToken', token);

        try {
            const res  = await fetch('/AdminInventory/Adjustment', { method: 'POST', body: form });
            const data = await res.json();
            if (data.success) {
                showToast(true, data.message);
                setTimeout(() => { $('#inventoryModal').modal('hide'); location.reload(); }, 900);
            } else {
                showToast(false, data.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-sliders"></i> Xác nhận điều chỉnh';
            }
        } catch {
            showToast(false, 'Lỗi kết nối.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-sliders"></i> Xác nhận điều chỉnh';
        }
    }

    function showToast(ok, msg) {
        const el = document.getElementById('invToastWrap');
        if (!el) return;
        const d = document.createElement('div');
        d.className = 'inv-toast ' + (ok ? 'inv-toast-ok' : 'inv-toast-err');
        d.textContent = msg;
        el.appendChild(d);
        setTimeout(() => d.remove(), 3500);
    }
</script>
