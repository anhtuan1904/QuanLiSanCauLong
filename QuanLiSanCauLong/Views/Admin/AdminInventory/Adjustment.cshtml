@model QuanLiSanCauLong.Models.Inventory
@{
    Layout = null;
    var committed = Model.HoldQuantity + Model.RentedQuantity + Model.DamagedQuantity;
}
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --orange: #c2410c;
        --purple: #7c3aed;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .md-hd {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg,#4c1d95,#6d28d9);
    }

    .md-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: .55rem;
    }

    .md-title-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: rgba(255,255,255,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
    }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.5);
        font-size: .95rem;
        cursor: pointer;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .15s;
    }

        .md-close:hover {
            background: rgba(255,255,255,.15);
            color: #fff;
        }

    .md-body {
        padding: 1.3rem 1.5rem;
        max-height: 72vh;
        overflow-y: auto;
    }

        .md-body::-webkit-scrollbar {
            width: 4px;
        }

        .md-body::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 4px;
        }

    .md-ft {
        padding: .9rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--cream);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .sec {
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: var(--muted);
        padding: .45rem 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: .85rem;
        display: flex;
        align-items: center;
        gap: .38rem;
    }

    .row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .8rem;
    }

    .row4 {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .6rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .28rem;
        margin-bottom: .82rem;
    }

        .fg label {
            font-size: .73rem;
            font-weight: 700;
            color: var(--deep);
        }

    .hint {
        font-size: .67rem;
        color: var(--muted);
    }

    .fi {
        padding: .58rem .85rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        width: 100%;
        transition: all .2s;
    }

        .fi:focus {
            border-color: var(--purple);
            box-shadow: 0 0 0 3px rgba(109,40,217,.1);
        }

    textarea.fi {
        resize: vertical;
        min-height: 60px;
    }

    /* current stock cards */
    .stk-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .6rem;
        margin-bottom: 1.1rem;
    }

    .stk-c {
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .7rem .85rem;
        text-align: center;
    }

        .stk-c.main {
            border-top: 3px solid var(--gold);
        }

        .stk-c.committed {
            border-top: 3px solid var(--orange);
        }

        .stk-c.avail {
            border-top: 3px solid var(--green);
        }

        .stk-c.info {
            border-top: 3px solid var(--purple);
        }

    .stk-c-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stk-c-l {
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .2rem;
    }

    /* mode switcher */
    .mode-sw {
        display: flex;
        background: var(--warm);
        border-radius: 9px;
        padding: .25rem;
        gap: .25rem;
        margin-bottom: 1rem;
    }

    .mode-btn {
        flex: 1;
        text-align: center;
        padding: .5rem;
        border-radius: 7px;
        font-size: .8rem;
        font-weight: 700;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        border: none;
        background: transparent;
    }

        .mode-btn.on {
            background: #fff;
            color: var(--purple);
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
        }

    /* diff preview */
    .diff-box {
        background: linear-gradient(135deg,#f5f3ff,#ede9fe);
        border: 1.5px solid #c4b5fd;
        border-radius: 10px;
        padding: .9rem 1.1rem;
        margin-bottom: 1rem;
        display: none;
    }

        .diff-box.show {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

    .diff-item {
        text-align: center;
    }

    .diff-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
    }

    .diff-lbl {
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--purple);
        margin-top: .12rem;
    }

    .diff-arrow {
        font-size: 1.2rem;
        color: var(--purple);
        opacity: .5;
    }

    .diff-delta {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        padding: .18rem .6rem;
        border-radius: 8px;
    }

        .diff-delta.up {
            color: #15803d;
            background: #f0fdf4;
        }

        .diff-delta.down {
            color: var(--red);
            background: #fef2f2;
        }

        .diff-delta.same {
            color: var(--muted);
            background: var(--warm);
        }

    /* quick reasons */
    .reason-pills {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        margin-bottom: .6rem;
    }

    .r-pill {
        padding: .22rem .65rem;
        border: 1.5px solid var(--border);
        border-radius: 20px;
        font-size: .74rem;
        cursor: pointer;
        background: #fff;
        color: var(--muted);
        transition: .15s;
    }

        .r-pill:hover {
            border-color: var(--purple);
            color: var(--purple);
        }

        .r-pill.on {
            border-color: var(--purple);
            background: #ede9fe;
            color: var(--purple);
        }

    /* delta inputs */
    .delta-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: .7rem;
    }

    .delta-sep {
        font-size: .8rem;
        color: var(--muted);
        text-align: center;
        padding-top: 1.4rem;
    }

    /* buttons */
    .btn-cancel {
        padding: .6rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        font-size: .83rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: .18s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .62rem 1.4rem;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg,#4c1d95,#6d28d9);
        font-size: .83rem;
        font-weight: 700;
        color: #fff;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: .2s;
        box-shadow: 0 2px 8px rgba(76,29,149,.3);
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(76,29,149,.4);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

    .footer-note {
        font-size: .72rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .3rem;
    }
</style>

<div class="md-hd">
    <div class="md-title">
        <span class="md-title-icon"><i class="bi bi-sliders" style="color:#c4b5fd"></i></span>
        Điều chỉnh <em style="color:#c4b5fd;font-style:italic">Tồn kho</em>
    </div>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">

    @* Product info *@
    <div style="display:flex;align-items:center;gap:.75rem;background:var(--cream);border:1px solid var(--border);border-radius:10px;padding:.75rem 1rem;margin-bottom:1rem">
        <div style="width:36px;height:36px;border-radius:8px;background:#ede9fe;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <i class="bi bi-boxes" style="color:var(--purple)"></i>
        </div>
        <div>
            <div style="font-weight:700;font-size:.9rem">@(Model.Product?.ProductName ?? "—")</div>
            <div style="font-size:.72rem;color:var(--muted)">@(Model.Facility?.FacilityName ?? "—") · #@Model.InventoryId</div>
        </div>
    </div>

    @* Current stock *@
    <div class="sec"><i class="bi bi-bar-chart-line"></i> Tồn kho hiện tại</div>
    <div class="stk-grid">
        <div class="stk-c main">
            <div class="stk-c-n">@Model.Quantity</div>
            <div class="stk-c-l">Tổng</div>
        </div>
        <div class="stk-c committed">
            <div class="stk-c-n" style="color:var(--orange)">@committed</div>
            <div class="stk-c-l">Đang dùng</div>
        </div>
        <div class="stk-c avail">
            <div class="stk-c-n" style="color:var(--green)">@(Model.AvailableQuantity)</div>
            <div class="stk-c-l">Khả dụng</div>
        </div>
        <div class="stk-c info">
            <div class="stk-c-n" style="color:var(--purple)">@Model.MinQuantity</div>
            <div class="stk-c-l">Min stock</div>
        </div>
    </div>

    @* Mode switcher *@
    <div class="sec"><i class="bi bi-pencil-square"></i> Điều chỉnh</div>
    <div class="mode-sw">
        <button class="mode-btn on" id="modeAbs" onclick="setMode('abs')">
            <i class="bi bi-input-cursor-text me-1"></i> Đặt số tuyệt đối
        </button>
        <button class="mode-btn" id="modeDelta" onclick="setMode('delta')">
            <i class="bi bi-plus-slash-minus me-1"></i> Tăng / Giảm
        </button>
    </div>

    @* Absolute mode *@
    <div id="panelAbs">
        <div class="fg">
            <label>Số lượng mới <span style="color:var(--red)">*</span></label>
            <input type="number" id="adjNewQty" class="fi" min="@committed" value="@Model.Quantity" oninput="calcAbsDiff()" />
            <span class="hint">Tối thiểu @committed (phần đang được sử dụng)</span>
        </div>
    </div>

    @* Delta mode *@
    <div id="panelDelta" style="display:none">
        <div class="delta-grid">
            <div class="fg" style="margin-bottom:0">
                <label><i class="bi bi-plus-circle me-1" style="color:var(--green)"></i>Thêm vào</label>
                <input type="number" id="adjDeltaPlus" class="fi" min="0" value="0" oninput="calcDeltaDiff()" />
            </div>
            <div class="delta-sep">—</div>
            <div class="fg" style="margin-bottom:0">
                <label><i class="bi bi-dash-circle me-1" style="color:var(--red)"></i>Bớt đi</label>
                <input type="number" id="adjDeltaMinus" class="fi" min="0" value="0" oninput="calcDeltaDiff()" />
            </div>
        </div>
    </div>

    @* Diff preview *@
    <div class="diff-box" id="diffPreview">
        <div class="diff-item">
            <div class="diff-val" id="dpOld">@Model.Quantity</div>
            <div class="diff-lbl">Trước</div>
        </div>
        <div class="diff-arrow"><i class="bi bi-arrow-right"></i></div>
        <div class="diff-item">
            <div class="diff-val" id="dpNew">@Model.Quantity</div>
            <div class="diff-lbl">Sau</div>
        </div>
        <div class="diff-item">
            <div class="diff-delta same" id="dpDelta">±0</div>
            <div class="diff-lbl">Thay đổi</div>
        </div>
    </div>

    @* Lý do *@
    <div class="sec"><i class="bi bi-chat-left-text"></i> Lý do điều chỉnh <span style="color:var(--red)">*</span></div>
    <div class="reason-pills">
        @foreach (var r in new[] { "Kiểm kê thực tế", "Hàng hỏng/mất", "Nhầm lẫn nhập liệu", "Điều chỉnh FIFO", "Khác" })
        {
            <span class="r-pill" onclick="pickReason(this,'@r')">@r</span>
        }
    </div>
    <div class="fg">
        <textarea id="adjNote" class="fi" rows="2" placeholder="Nhập lý do điều chỉnh..."></textarea>
    </div>

</div>

<div class="md-ft">
    <span class="footer-note"><i class="bi bi-lock-fill"></i> Tối thiểu @committed (đang dùng)</span>
    <div style="display:flex;gap:.55rem">
        <button class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
        <button class="btn-save" id="adjBtnSave" onclick="submitAdj()">
            <i class="bi bi-check-lg"></i> Xác nhận điều chỉnh
        </button>
    </div>
</div>

<script>
    const ADJ_INV_ID=@Model.InventoryId;
    const ADJ_CURRENT=@Model.Quantity;
    const ADJ_MIN=@committed;
    const TOKEN_ADJ=document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';
    let adjMode='abs';

    function setMode(m){
        adjMode=m;
        document.getElementById('modeAbs').classList.toggle('on',m==='abs');
        document.getElementById('modeDelta').classList.toggle('on',m==='delta');
        document.getElementById('panelAbs').style.display=m==='abs'?'block':'none';
        document.getElementById('panelDelta').style.display=m==='delta'?'block':'none';
        m==='abs'?calcAbsDiff():calcDeltaDiff();
    }
    function calcAbsDiff(){
        const nv=parseInt(document.getElementById('adjNewQty').value)||0;
        showDiff(ADJ_CURRENT,nv);
    }
    function calcDeltaDiff(){
        const plus=parseInt(document.getElementById('adjDeltaPlus').value)||0;
        const minus=parseInt(document.getElementById('adjDeltaMinus').value)||0;
        showDiff(ADJ_CURRENT,ADJ_CURRENT+plus-minus);
    }
    function showDiff(old,nv){
        const box=document.getElementById('diffPreview');
        const delta=nv-old;
        document.getElementById('dpOld').textContent=old;
        document.getElementById('dpNew').textContent=nv;
        const d=document.getElementById('dpDelta');
        d.textContent=delta>0?'+'+delta:String(delta);
        d.className='diff-delta '+(delta>0?'up':delta<0?'down':'same');
        box.classList.toggle('show',true);
    }
    function pickReason(el,val){
        document.querySelectorAll('.r-pill').forEach(p=>p.classList.remove('on'));
        el.classList.add('on');
        document.getElementById('adjNote').value=val;
    }
    calcAbsDiff();

    async function submitAdj(){
        const note=document.getElementById('adjNote').value.trim();
        if(!note){alert('Vui lòng nhập lý do điều chỉnh!');return;}
        let newQty;
        if(adjMode==='abs'){newQty=parseInt(document.getElementById('adjNewQty').value);}
        else{newQty=ADJ_CURRENT+(parseInt(document.getElementById('adjDeltaPlus').value)||0)-(parseInt(document.getElementById('adjDeltaMinus').value)||0);}
        if(isNaN(newQty)||newQty<ADJ_MIN){alert(`Số lượng tối thiểu là ${ADJ_MIN} (phần đang được sử dụng).`);return;}
        if(newQty===ADJ_CURRENT){alert('Số lượng không thay đổi!');return;}
        const btn=document.getElementById('adjBtnSave');
        btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>...';
        const fd=new FormData();fd.append('inventoryId',ADJ_INV_ID);fd.append('newQuantity',newQty);fd.append('note',note);
        try{
            const res=await fetch('/AdminInventory/Adjustment',{method:'POST',headers:{'RequestVerificationToken':TOKEN_ADJ},body:fd}).then(r=>r.json());
            if(res.success){
                bootstrap.Modal.getInstance(document.getElementById('invModal'))?.hide();
                const t=document.createElement('div');t.style.cssText='position:fixed;bottom:1.5rem;right:1.5rem;background:#15803d;color:#fff;padding:.75rem 1.3rem;border-radius:10px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 6px 24px rgba(0,0,0,.2)';t.innerHTML=`<i class="bi bi-check-circle-fill"></i> ${res.message}`;document.body.appendChild(t);
                setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>{t.remove();location.reload();},400);},1800);
            }else{alert(res.message||'Có lỗi xảy ra!');btn.disabled=false;btn.innerHTML='<i class="bi bi-check-lg"></i> Xác nhận điều chỉnh';}
        }catch(e){alert('Lỗi kết nối!');btn.disabled=false;btn.innerHTML='<i class="bi bi-check-lg"></i> Xác nhận điều chỉnh';}
    }
</script>
