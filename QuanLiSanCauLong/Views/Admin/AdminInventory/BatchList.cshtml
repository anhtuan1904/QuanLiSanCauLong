@model IEnumerable<QuanLiSanCauLong.Models.InventoryBatch>
@{
    ViewData["Title"] = "Quản Lý Lô Hàng (FIFO)";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var now = DateTime.Now;
    var soon7 = now.AddDays(7);
    var soon30 = now.AddDays(30);
    var productName = ViewBag.ProductName as string ?? "—";
    var productCode = ViewBag.ProductCode as string ?? "";
    var facilityName = ViewBag.FacilityName as string ?? "Tất cả cơ sở";
    var batches = Model.ToList();
    int totalRem = batches.Where(b => b.Status == "Active").Sum(b => b.RemainingQuantity);
    var sorted = batches
        .OrderBy(b => b.Status == "Depleted" ? 1 : 0)
        .ThenBy(b => b.ExpiryDate ?? DateTime.MaxValue)
        .ThenBy(b => b.ReceivedDate).ToList();
    var nextId = sorted.FirstOrDefault(b => b.Status == "Active" && !b.IsDepleted)?.BatchId;
}

<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    /* soft color aliases — local to BatchList */
    .bl-green {
        background: #dcfce7;
    }

    .bl-red {
        background: #fef2f2;
    }

    .bl-orange {
        background: #fff7ed;
    }

    .bl-purple {
        background: #f5f3ff;
    }

    .bl-blue {
        background: #eff6ff;
    }

    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 1.75rem 2rem;
    }

    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            color: var(--gold);
            font-style: italic;
        }

    .pg-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .52rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .8rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        transition: all .18s;
    }

        .back-btn:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .fifo-banner {
        background: #fff;
        border: 1px solid var(--border);
        border-left: 4px solid var(--gold);
        border-radius: 8px;
        padding: .75rem 1rem;
        font-size: .8rem;
        color: var(--deep);
        display: flex;
        align-items: flex-start;
        gap: .65rem;
        margin-bottom: 1.25rem;
    }

    .stats {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .sb {
        background: #fff;
        padding: .7rem 1rem;
        flex: 1;
        text-align: center;
    }

    .sb-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
    }

    .sb-lbl {
        font-size: .62rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .12rem;
    }

    .toolbar {
        display: flex;
        gap: .5rem;
        align-items: center;
        margin-bottom: .9rem;
        flex-wrap: wrap;
    }

    .srch-wrap {
        position: relative;
        flex: 1;
        min-width: 180px;
    }

        .srch-wrap i {
            position: absolute;
            left: .65rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .75rem;
        }

        .srch-wrap input {
            width: 100%;
            padding: .52rem .75rem .52rem 2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .8rem;
            color: var(--deep);
            background: #fff;
            outline: none;
        }

            .srch-wrap input:focus {
                border-color: var(--gold);
            }

    .sel {
        padding: .52rem .75rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: .8rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .sel:focus {
            border-color: var(--gold);
        }

    .cnt-lbl {
        font-size: .76rem;
        color: var(--muted);
        white-space: nowrap;
    }

    .tbl-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        padding: .65rem 1rem;
        font-size: .67rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--muted);
        background: var(--warm);
        border-bottom: 2px solid var(--border);
        white-space: nowrap;
    }

    td {
        padding: .75rem 1rem;
        border-bottom: 1px solid #f5f0e8;
        font-size: .82rem;
        vertical-align: middle;
    }

    tr:last-child td {
        border: none;
    }

    tr:hover td {
        background: #fdf9f0;
    }

    .fifo-badge {
        display: inline-flex;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--gold2);
        color: var(--deep);
        font-weight: 800;
        font-size: .75rem;
        align-items: center;
        justify-content: center;
    }

        .fifo-badge.next {
            background: var(--deep);
            color: var(--gold2);
            animation: pulse 1.5s infinite;
        }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1)
        }

        50% {
            transform: scale(1.1)
        }
    }

    .bar-wrap {
        background: var(--warm);
        border-radius: 4px;
        height: 6px;
        width: 80px;
        display: inline-block;
        margin-left: .5rem;
        vertical-align: middle;
    }

    .bar {
        height: 6px;
        border-radius: 4px;
    }

    .bar-ok {
        background: var(--green);
    }

    .bar-low {
        background: #f59e0b;
    }

    .bar-empty {
        background: var(--border);
    }

    .bbadge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .65rem;
        border-radius: 20px;
        font-size: .7rem;
        font-weight: 700;
    }

    .bb-active {
        background: #dcfce7;
        color: var(--green);
    }

    .bb-depleted {
        background: #f1f5f9;
        color: #64748b;
    }

    .bb-expired {
        background: #fef2f2;
        color: var(--red);
    }

    .bb-expiring {
        background: #fff7ed;
        color: #c2410c;
    }

    .hsd-dead, .hsd-soon7 {
        color: var(--red);
        font-weight: 700;
        font-size: .8rem;
    }

    .hsd-soon30 {
        color: var(--orange);
        font-weight: 700;
        font-size: .8rem;
    }

    .hsd-ok {
        color: var(--green);
        font-size: .8rem;
    }

    .hsd-sub {
        font-size: .68rem;
        color: var(--muted);
        margin-top: 1px;
    }

    .empty {
        text-align: center;
        padding: 3rem;
        color: var(--muted);
    }

        .empty i {
            font-size: 2.2rem;
            opacity: .3;
            display: block;
            margin-bottom: .75rem;
        }
</style>

<div class="pg">
    <div class="pg-hd">
        <div>
            <h1 class="pg-title">Lô hàng <em>FIFO</em></h1>
            <p class="pg-sub"><strong>@productName</strong> @(!string.IsNullOrEmpty(productCode) ? $"· {productCode}" : "") · @facilityName</p>
        </div>
        <a href="/Admin/AdminInventory/Index" class="back-btn"><i class="bi bi-arrow-left"></i> Về tổng kho</a>
    </div>

    <div class="fifo-banner">
        <i class="bi bi-info-circle-fill" style="color:var(--gold);flex-shrink:0;margin-top:.1rem"></i>
        <div><strong>Nguyên tắc FIFO:</strong> Khi xuất hàng, hệ thống tự động trừ từ lô <strong>nhập sớm nhất</strong> (hoặc HSD gần nhất) trước. Lô có huy hiệu <strong style="background:#1a1209;color:#f5c842;padding:1px 6px;border-radius:4px;font-size:.7rem">NEXT</strong> sẽ được xuất tiếp theo.</div>
    </div>

    <div class="stats">
        <div class="sb"><div class="sb-val">@totalRem</div><div class="sb-lbl">📦 Còn lại</div></div>
        <div class="sb"><div class="sb-val" style="color:var(--green)">@batches.Count(b => b.Status == "Active")</div><div class="sb-lbl">✅ Đang dùng</div></div>
        <div class="sb"><div class="sb-val" style="color:var(--muted)">@batches.Count(b => b.Status == "Depleted")</div><div class="sb-lbl">🗑️ Hết</div></div>
        <div class="sb"><div class="sb-val" style="color:var(--orange)">@batches.Count(b => b.ExpiryDate.HasValue && b.ExpiryDate > now && b.ExpiryDate <= soon30)</div><div class="sb-lbl">⏳ Sắp hết hạn</div></div>
        <div class="sb"><div class="sb-val" style="color:var(--red)">@batches.Count(b => b.IsExpired)</div><div class="sb-lbl">🚫 Hết hạn</div></div>
    </div>

    <div class="toolbar">
        <div class="srch-wrap"><i class="bi bi-search"></i><input id="blSearch" placeholder="Tìm số lô, chứng từ..." oninput="applyFilter()" /></div>
        <select class="sel" id="blStatus" onchange="applyFilter()">
            <option value="">Tất cả trạng thái</option>
            <option value="Active">✅ Đang dùng</option>
            <option value="Depleted">🗑️ Hết</option>
            <option value="expiring">⏳ Sắp hết hạn</option>
            <option value="expired">🚫 Đã hết hạn</option>
        </select>
        <span class="cnt-lbl" id="blCount">@batches.Count lô hàng</span>
    </div>

    <div class="tbl-card">
        @if (!batches.Any())
        {
            <div class="empty"><i class="bi bi-layers"></i><p>Chưa có lô hàng nào</p><p style="font-size:.78rem">Nhập kho lần đầu sẽ tự động tạo lô</p></div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table id="blTable">
                    <thead>
                        <tr>
                            <th style="padding-left:1.25rem;width:50px">FIFO</th>
                            <th>Số lô</th>
                            <th style="text-align:center">Nhập / Còn</th>
                            <th>Ngày nhập</th>
                            <th>Hạn sử dụng</th>
                            <th style="text-align:right">Giá vốn</th>
                            <th>Chứng từ</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int fifoOrder = 0;
                        }
                        @foreach (var b in sorted)
                        {
                            if (b.Status == "Active") fifoOrder++;
                            var isNext = b.BatchId == nextId;
                            var isExpired = b.IsExpired;
                            var isExp7 = !isExpired && b.ExpiryDate.HasValue && b.ExpiryDate <= soon7;
                            var isExp30 = !isExpired && !isExp7 && b.ExpiryDate.HasValue && b.ExpiryDate <= soon30;
                            var pct = b.OriginalQuantity > 0 ? (double)b.RemainingQuantity / b.OriginalQuantity * 100 : 0;
                            var barCls = b.IsDepleted ? "bar-empty" : pct < 20 ? "bar-low" : "bar-ok";
                            var fStatus = b.Status == "Depleted" ? "Depleted" : isExpired ? "expired" : (isExp7 || isExp30) ? "expiring" : "Active";
                            <tr data-status="@fStatus" data-search="@b.BatchNumber?.ToLower() @b.DocumentReference?.ToLower()">
                                <td style="padding-left:1.25rem">
                                    @if (b.Status == "Active")
                                    {
                                        <span class="fifo-badge @(isNext ? "next" : "")">@fifoOrder</span>
                                    }
                                    else
                                    {

                                        <span style="color:var(--border);font-size:.8rem">—</span>
                                    }
                                </td>
                                <td><div style="font-weight:700;font-family:monospace;font-size:.82rem">@(b.BatchNumber ?? "—")</div></td>
                                <td style="text-align:center">
                                    <div style="font-weight:700;font-size:.88rem">@b.RemainingQuantity <span style="color:var(--muted);font-weight:400">/ @b.OriginalQuantity</span></div>
                                    <span class="bar-wrap"><span class="bar @barCls" style="width:@pct.ToString("F0")%;display:block"></span></span>
                                </td>
                                <td><div style="font-size:.8rem">@b.ReceivedDate.ToString("dd/MM/yyyy")</div><div style="font-size:.68rem;color:var(--muted)">@b.ReceivedDate.ToString("HH:mm")</div></td>
                                <td>
                                    @if (b.ExpiryDate.HasValue)
                                    {
                                        var dLeft = (b.ExpiryDate.Value - now).Days;
                                        var cls = isExpired ? "hsd-dead" : isExp7 ? "hsd-soon7" : isExp30 ? "hsd-soon30" : "hsd-ok";
                                        <div class="@cls">@b.ExpiryDate.Value.ToString("dd/MM/yyyy")</div>
                                        <div class="hsd-sub">@(isExpired ? $"Quá {-dLeft} ngày" : $"Còn {dLeft} ngày")</div>
                                    }
                                    else
                                    {

                                        <span style="color:var(--muted)">Không có HSD</span>
                                    }
                                </td>
                                <td style="text-align:right">
                                    @if (b.CostPrice > 0)
                                    {
                                        <div style="font-weight:700;font-size:.85rem">@b.CostPrice.ToString("N0")₫</div>
                                    }
                                    else
                                    {

                                        <span style="color:var(--muted)">—</span>
                                    }
                                </td>
                                <td><div style="font-size:.78rem;color:var(--muted)">@(string.IsNullOrEmpty(b.DocumentReference) ? "—" : b.DocumentReference)</div></td>
                                <td>
                                    @if (isExpired)
                                    {
                                        <span class="bbadge bb-expired"><i class="bi bi-slash-circle"></i> Hết hạn</span>
                                    }
                                    else if (isExp7)
                                    {

                                        <span class="bbadge bb-expiring"><i class="bi bi-exclamation-triangle-fill"></i> HSD còn @b.DaysUntilExpiry ngày</span>
                                    }
                                    else if (isExp30)
                                    {

                                        <span class="bbadge bb-expiring"><i class="bi bi-clock"></i> Sắp hết hạn</span>
                                    }
                                    else if (b.IsDepleted)
                                    {

                                        <span class="bbadge bb-depleted"><i class="bi bi-check2-all"></i> Đã xuất hết</span>
                                    }
                                    else
                                    {

                                        <span class="bbadge bb-active"><i class="bi bi-circle-fill" style="font-size:.4rem"></i> Đang dùng</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function applyFilter(){
            const q=document.getElementById('blSearch').value.toLowerCase();
            const st=document.getElementById('blStatus').value;
            let cnt=0;
            document.querySelectorAll('#blTable tbody tr').forEach(r=>{
                const ok=(!q||(r.dataset.search??'').includes(q))&&(!st||r.dataset.status===st);
                r.style.display=ok?'':'none'; if(ok)cnt++;
            });
            document.getElementById('blCount').textContent=cnt+' lô hàng';
        }
    </script>
}
