@model QuanLiSanCauLong.ViewModels.InventoryHistoryViewModel
@{
    Layout = null;
    var isPartial = ViewContext.HttpContext.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    int totalIn = Model.Transactions.Where(t => t.IsInbound).Sum(t => t.Quantity);
    int totalOut = Model.Transactions.Where(t => t.IsOutbound).Sum(t => t.Quantity);

    (string lbl, string ico, string bgClr, string txtClr, bool isPlus, bool isMinus) TxMeta(string type) => type switch
    {
        "StockIn" => ("Nhập kho", "bi-box-arrow-in-down", "#f0fdf4", "#15803d", true, false),
        "StockOut" => ("Xuất kho", "bi-box-arrow-up", "#fef2f2", "#c94b2a", false, true),
        "Sale" => ("Bán đứt", "bi-bag-check", "#fef2f2", "#c94b2a", false, true),
        "Hold" => ("Treo đơn", "bi-lock", "#fff7ed", "#c2410c", false, true),
        "ReleaseHold" => ("Huỷ treo", "bi-lock-open", "#f0fdf4", "#15803d", true, false),
        "RentOut" => ("Xuất thuê", "bi-arrow-right-circle", "#eff6ff", "#1d4ed8", false, true),
        "RentReturn" => ("Trả thuê", "bi-arrow-left-circle", "#f0fdf4", "#15803d", true, false),
        "RentLost" => ("Mất thuê", "bi-x-circle", "#fef2f2", "#c94b2a", false, true),
        "Adjustment" => ("Điều chỉnh", "bi-sliders", "#fff7ed", "#c2410c", false, false),
        "Damaged" => ("Hàng hỏng", "bi-tools", "#f5f3ff", "#7c3aed", false, false),
        "DamagedWrite" => ("Xoá sổ hỏng", "bi-trash3", "#fef2f2", "#c94b2a", false, true),
        "Transfer" => ("Chuyển kho", "bi-arrow-left-right", "#f0f9ff", "#0369a1", false, false),
        _ => (type, "bi-clock-history", "#f5f0e8", "#8a7560", false, false),
    };
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .md-hd {
        padding: 1rem 1.3rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--deep);
    }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.4);
        font-size: 1rem;
        cursor: pointer;
    }

        .md-close:hover {
            color: #fff;
        }

    .md-body {
        padding: 1.2rem 1.3rem;
        max-height: 75vh;
        overflow-y: auto;
    }
    /* Summary strip */
    .sum-strip {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .ss-b {
        background: #fff;
        padding: .6rem .9rem;
        flex: 1;
        text-align: center;
    }

    .ss-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1;
        color: var(--deep);
    }

    .ss-l {
        font-size: .58rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .15rem;
    }
    /* Toolbar */
    .toolbar {
        display: flex;
        gap: .5rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .srch {
        flex: 1;
        min-width: 160px;
        position: relative;
    }

        .srch i {
            position: absolute;
            left: .65rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .75rem;
        }

        .srch input {
            width: 100%;
            padding: .5rem .75rem .5rem 2rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-family: 'Outfit',sans-serif;
            font-size: .8rem;
            color: var(--deep);
            background: #fff;
            outline: none;
        }

            .srch input:focus {
                border-color: var(--gold);
            }

    .sel {
        padding: .5rem .75rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-family: 'Outfit',sans-serif;
        font-size: .8rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .sel:focus {
            border-color: var(--gold);
        }
    /* Timeline */
    .timeline {
        position: relative;
        padding-left: 32px;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: 11px;
            top: 0;
            bottom: 0;
            width: 1.5px;
            background: var(--border);
        }

    .tx-row {
        position: relative;
        margin-bottom: .7rem;
        display: flex;
        flex-direction: column;
        gap: .1rem;
    }

    .tx-dot {
        position: absolute;
        left: -26px;
        top: 4px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .5rem;
        flex-shrink: 0;
    }

    .tx-main {
        display: flex;
        align-items: center;
        gap: .55rem;
        flex-wrap: wrap;
    }

    .tx-badge {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .18rem .55rem;
        border-radius: 4px;
        font-size: .65rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .tx-qty {
        font-family: 'Playfair Display',serif;
        font-size: .95rem;
        font-weight: 700;
        margin-left: auto;
        white-space: nowrap;
    }

        .tx-qty.plus {
            color: var(--green);
        }

        .tx-qty.minus {
            color: var(--red);
        }

        .tx-qty.neutral {
            color: #c2410c;
        }

    .tx-meta {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        font-size: .68rem;
        color: var(--muted);
        align-items: center;
    }

        .tx-meta i {
            font-size: .62rem;
        }

    .tx-after {
        margin-left: auto;
        font-size: .68rem;
        color: var(--muted);
        white-space: nowrap;
    }

        .tx-after strong {
            color: var(--deep);
        }

    .tx-note {
        display: inline-block;
        padding: .12rem .5rem;
        background: var(--warm);
        border-radius: 4px;
        font-size: .7rem;
        color: var(--deep);
        max-width: 280px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    /* Day separator */
    .day-sep {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        padding: .5rem 0 .35rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: .6rem;
        margin-top: .4rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }
    /* Empty */
    .empty-hist {
        text-align: center;
        padding: 3rem;
        color: var(--muted);
    }

        .empty-hist i {
            font-size: 2rem;
            display: block;
            opacity: .2;
            margin-bottom: .5rem;
        }
</style>

<!-- HEADER -->
<div class="md-hd">
    <div style="display:flex;align-items:center;gap:.65rem;">
        <i class="bi bi-clock-history" style="color:var(--gold2);font-size:.95rem;"></i>
        <div>
            <div style="font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700;color:#fff;">@Model.ProductName</div>
            @if (!string.IsNullOrEmpty(Model.ProductCode))
            {
                <div style="font-size:.66rem;color:rgba(255,255,255,.35);font-family:monospace;">@Model.ProductCode</div>
            }
        </div>
    </div>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">
    <!-- SUMMARY -->
    <div class="sum-strip">
        <div class="ss-b">
            <div class="ss-n">@Model.Transactions.Count</div>
            <div class="ss-l">Giao dịch</div>
        </div>
        <div class="ss-b">
            <div class="ss-n" style="color:var(--green)">+@totalIn</div>
            <div class="ss-l">Tổng nhập</div>
        </div>
        <div class="ss-b">
            <div class="ss-n" style="color:var(--red)">-@totalOut</div>
            <div class="ss-l">Tổng xuất</div>
        </div>
        <div class="ss-b">
            <div class="ss-n" style="color:var(--blue)">@(totalIn - totalOut)</div>
            <div class="ss-l">Chênh lệch</div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="srch">
            <i class="bi bi-search"></i>
            <input type="text" id="htSrch" placeholder="Ghi chú, người dùng..." oninput="htFilter()" />
        </div>
        <select class="sel" id="htType" onchange="htFilter()">
            <option value="">Tất cả loại</option>
            <option value="StockIn">Nhập kho</option>
            <option value="StockOut">Xuất kho</option>
            <option value="Sale">Bán đứt</option>
            <option value="Hold">Treo đơn</option>
            <option value="ReleaseHold">Huỷ treo</option>
            <option value="RentOut">Xuất thuê</option>
            <option value="RentReturn">Trả thuê</option>
            <option value="RentLost">Mất thuê</option>
            <option value="Adjustment">Điều chỉnh</option>
            <option value="Damaged">Hàng hỏng</option>
            <option value="Transfer">Chuyển kho</option>
        </select>
        <select class="sel" id="htDir" onchange="htFilter()">
            <option value="">Tất cả chiều</option>
            <option value="plus">Tăng kho</option>
            <option value="minus">Giảm kho</option>
            <option value="neutral">Trung tính</option>
        </select>
        <span style="font-size:.76rem;color:var(--muted);white-space:nowrap;" id="htCount">@Model.Transactions.Count giao dịch</span>
    </div>

    <!-- TIMELINE -->
    @if (!Model.Transactions.Any())
    {
        <div class="empty-hist"><i class="bi bi-clock-history"></i>Chưa có giao dịch nào</div>
    }
    else
    {
        <div class="timeline" id="htTimeline">
            @{
                string? lastDay = null;
                foreach (var tx in Model.Transactions)
                {
                    var (lbl, ico, bgClr, txtClr, isPlus, isMinus) = TxMeta(tx.Type);
                    var qtySign = isPlus ? "+" : isMinus ? "−" : "~";
                    var qtyCls = isPlus ? "plus" : isMinus ? "minus" : "neutral";
                    var dayStr = tx.TransactionDate.ToString("dd/MM/yyyy");
                    var dir = isPlus ? "plus" : isMinus ? "minus" : "neutral";
                    var search = $"{tx.Note} {tx.UserEmail} {lbl}".ToLower();
                }
            }
            @foreach (var tx in Model.Transactions)
            {
                var (lbl, ico, bgClr, txtClr, isPlus, isMinus) = TxMeta(tx.Type);
                var qtySign = isPlus ? "+" : isMinus ? "−" : "~";
                var qtyCls = isPlus ? "plus" : isMinus ? "minus" : "neutral";
                var dayStr = tx.TransactionDate.ToString("dd/MM/yyyy");
                var dir = isPlus ? "plus" : isMinus ? "minus" : "neutral";
                var searchStr = $"{(tx.Note ?? "").ToLower()} {(tx.UserEmail ?? "").ToLower()} {lbl.ToLower()}";

                if (dayStr != lastDay)
                {
                    lastDay = dayStr;
                    <div class="day-sep">
                        <i class="bi bi-calendar3"></i>
                        @tx.TransactionDate.ToString("dddd, dd/MM/yyyy")
                    </div>
                }
                <div class="tx-row" id="tx-@tx.TransactionId"
                     data-type="@tx.Type"
                     data-dir="@dir"
                     data-search="@searchStr">
                    <div class="tx-dot" style="background:@bgClr;border-color:@txtClr;">
                        <i class="bi @ico" style="color:@txtClr;font-size:.45rem;"></i>
                    </div>
                    <div class="tx-main">
                        <span class="tx-badge" style="background:@bgClr;color:@txtClr;">
                            <i class="bi @ico"></i> @lbl
                        </span>
                        <span style="font-size:.76rem;color:var(--muted);">@tx.TransactionDate.ToString("HH:mm")</span>
                        @if (!string.IsNullOrEmpty(tx.FacilityName))
                        {
                            <span style="font-size:.72rem;color:var(--muted);"><i class="bi bi-building"></i> @tx.FacilityName</span>
                        }
                        <span class="tx-qty @qtyCls">@qtySign@tx.Quantity</span>
                    </div>
                    <div class="tx-meta">
                        @if (!string.IsNullOrEmpty(tx.UserEmail))
                        {
                            <span><i class="bi bi-person"></i> @tx.UserEmail</span>
                        }
                        @if (tx.OrderId.HasValue)
                        {
                            <span><i class="bi bi-receipt"></i> Đơn #@tx.OrderId</span>
                        }
                        @if (!string.IsNullOrEmpty(tx.BatchNumber))
                        {
                            <span><i class="bi bi-upc"></i> @tx.BatchNumber</span>
                        }
                        @if (tx.CostPriceSnapshot.HasValue)
                        {
                            <span><i class="bi bi-currency-exchange"></i> @tx.CostPriceSnapshot.Value.ToString("N0")đ</span>
                        }
                        @if (tx.QuantityAfter > 0)
                        {
                            <span class="tx-after">Sau: <strong>@tx.QuantityAfter</strong></span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(tx.Note))
                    {
                        <div><span class="tx-note" title="@tx.Note"><i class="bi bi-chat-text" style="font-size:.62rem;color:var(--muted);"></i> @tx.Note</span></div>
                    }
                </div>
            }
        </div>
    }
</div>

<script>
    function htFilter() {
        const q    = document.getElementById('htSrch').value.toLowerCase();
        const type = document.getElementById('htType').value;
        const dir  = document.getElementById('htDir').value;
        let cnt = 0;
        document.querySelectorAll('#htTimeline .tx-row').forEach(r => {
            const show = (!q    || r.dataset.search?.includes(q))
                      && (!type || r.dataset.type  === type)
                      && (!dir  || r.dataset.dir   === dir);
            r.style.display = show ? '' : 'none';
            if (show) cnt++;
        });
        // Also hide day-sep with no visible children
        document.querySelectorAll('#htTimeline .day-sep').forEach(sep => {
            let next = sep.nextElementSibling;
            let hasVisible = false;
            while (next && !next.classList.contains('day-sep')) {
                if (next.style.display !== 'none') { hasVisible = true; break; }
                next = next.nextElementSibling;
            }
            sep.style.display = hasVisible ? '' : 'none';
        });
        document.getElementById('htCount').textContent = cnt + ' giao dịch';
    }
</script>
