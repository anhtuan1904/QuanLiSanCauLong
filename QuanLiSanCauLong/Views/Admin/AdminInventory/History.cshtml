@model QuanLiSanCauLong.ViewModels.InventoryHistoryViewModel
@{
    Layout = null;
    var isPartial = ViewContext.HttpContext.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    int totalIn = Model.Transactions.Where(t => t.IsInbound).Sum(t => t.Quantity);
    int totalOut = Model.Transactions.Where(t => t.IsOutbound).Sum(t => t.Quantity);

    (string lbl, string ico, string bg, string clr, bool isPlus, bool isMinus) TxMeta(string type) => type switch
    {
        "StockIn" => ("Nhập kho", "bi-box-arrow-in-down", "#f0fdf4", "#15803d", true, false),
        "StockOut" => ("Xuất kho", "bi-box-arrow-up", "#fef2f2", "#c94b2a", false, true),
        "Sale" => ("Bán đứt", "bi-bag-check", "#fef2f2", "#c94b2a", false, true),
        "Hold" => ("Treo đơn", "bi-lock", "#fff7ed", "#c2410c", false, true),
        "ReleaseHold" => ("Huỷ treo", "bi-lock-open", "#f0fdf4", "#15803d", true, false),
        "RentOut" => ("Xuất thuê", "bi-arrow-right-circle", "#eff6ff", "#1d4ed8", false, true),
        "RentReturn" => ("Trả thuê", "bi-arrow-left-circle", "#f0fdf4", "#15803d", true, false),
        "RentLost" => ("Mất thuê", "bi-x-circle", "#fef2f2", "#c94b2a", false, true),
        "Adjustment" => ("Điều chỉnh", "bi-sliders", "#fff7ed", "#c2410c", false, false),
        "Damaged" => ("Hàng hỏng", "bi-tools", "#f5f3ff", "#7c3aed", false, false),
        "DamagedWrite" => ("Xoá sổ hỏng", "bi-trash3", "#fef2f2", "#c94b2a", false, true),
        "Transfer" => ("Chuyển kho", "bi-arrow-left-right", "#f0f9ff", "#0369a1", false, false),
        _ => (type, "bi-clock-history", "#f5f0e8", "#8a7560", false, false),
    };
}
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .md-hd {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg,#1e3a5f,#1d4ed8);
    }

    .md-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: .55rem;
    }

    .md-title-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: rgba(255,255,255,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
    }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.5);
        font-size: .95rem;
        cursor: pointer;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .15s;
    }

        .md-close:hover {
            background: rgba(255,255,255,.15);
            color: #fff;
        }

    .hist-wrap {
        padding: 1.3rem 1.5rem;
        max-height: 78vh;
        overflow-y: auto;
    }

        .hist-wrap::-webkit-scrollbar {
            width: 4px;
        }

        .hist-wrap::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 4px;
        }

    /* product info */
    .prod-card {
        display: flex;
        align-items: center;
        gap: .75rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .75rem 1rem;
        margin-bottom: 1rem;
    }

    .prod-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: #dbeafe;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* summary strip */
    .sum-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .ss-b {
        background: #fff;
        padding: .68rem .75rem;
        text-align: center;
    }

    .ss-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .ss-l {
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .14rem;
    }

    /* toolbar */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .55rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .srch-w {
        flex: 1;
        min-width: 160px;
        position: relative;
    }

        .srch-w i {
            position: absolute;
            left: .68rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .78rem;
            pointer-events: none;
        }

        .srch-w input {
            width: 100%;
            padding: .54rem .85rem .54rem 2rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: .82rem;
            color: var(--deep);
            background: #fff;
            outline: none;
        }

            .srch-w input:focus {
                border-color: var(--blue);
            }

    .flt-sel {
        padding: .52rem .82rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: .8rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .flt-sel:focus {
            border-color: var(--blue);
        }

    /* timeline */
    .day-sep {
        font-size: .72rem;
        font-weight: 700;
        color: var(--muted);
        padding: .65rem 0 .45rem;
        display: flex;
        align-items: center;
        gap: .38rem;
        border-top: 1px dashed var(--border);
        margin-top: .5rem;
    }

        .day-sep:first-child {
            border-top: none;
            margin-top: 0;
        }

    .tx-row {
        display: flex;
        gap: .8rem;
        padding: .7rem 0;
        border-bottom: 1px solid #f5f0ea;
        align-items: flex-start;
    }

        .tx-row:last-child {
            border-bottom: none;
        }

    .tx-dot {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: 2px solid;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: .05rem;
    }

    .tx-content {
        flex: 1;
        min-width: 0;
    }

    .tx-top {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
        margin-bottom: .25rem;
    }

    .tx-badge {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .2rem .58rem;
        border-radius: 5px;
        font-size: .66rem;
        font-weight: 700;
    }

    .tx-time {
        font-size: .72rem;
        color: var(--muted);
    }

    .tx-fac {
        font-size: .71rem;
        color: var(--muted);
    }

    .tx-qty {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
        margin-left: auto;
        white-space: nowrap;
    }

        .tx-qty.plus {
            color: var(--green);
        }

        .tx-qty.minus {
            color: var(--red);
        }

        .tx-qty.neutral {
            color: #c2410c;
        }

    .tx-meta {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        font-size: .68rem;
        color: var(--muted);
        align-items: center;
    }

        .tx-meta i {
            font-size: .62rem;
        }

    .tx-after {
        margin-left: auto;
        font-size: .68rem;
        color: var(--muted);
        white-space: nowrap;
    }

        .tx-after strong {
            color: var(--deep);
        }

    .tx-note {
        font-size: .72rem;
        color: var(--muted);
        font-style: italic;
        display: block;
        margin-top: .2rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 340px;
    }

    .empty-wrap {
        padding: 3rem 2rem;
        text-align: center;
        color: var(--muted);
    }

        .empty-wrap i {
            font-size: 2.5rem;
            opacity: .15;
            display: block;
            margin-bottom: .75rem;
        }
</style>

<div class="md-hd">
    <div class="md-title">
        <span class="md-title-icon"><i class="bi bi-clock-history" style="color:#93c5fd"></i></span>
        Lịch sử <em style="color:#93c5fd;font-style:italic">Giao dịch</em>
    </div>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="hist-wrap">
    <div class="prod-card">
        <div class="prod-icon"><i class="bi bi-box-seam" style="color:var(--blue)"></i></div>
        <div>
            <div style="font-weight:700;font-size:.9rem">@Model.ProductName</div>
            <div style="font-size:.72rem;color:var(--muted)">@Model.ProductCode · #@Model.ProductId</div>
        </div>
        <span style="margin-left:auto;font-size:.72rem;font-weight:700;color:var(--muted);background:var(--warm);border:1px solid var(--border);border-radius:6px;padding:.2rem .55rem">@Model.Transactions.Count giao dịch</span>
    </div>

    <div class="sum-strip">
        <div class="ss-b"><div class="ss-n">@Model.Transactions.Count</div><div class="ss-l">Giao dịch</div></div>
        <div class="ss-b"><div class="ss-n" style="color:var(--green)">+@totalIn</div><div class="ss-l">Tổng nhập</div></div>
        <div class="ss-b"><div class="ss-n" style="color:var(--red)">−@totalOut</div><div class="ss-l">Tổng xuất</div></div>
        <div class="ss-b"><div class="ss-n" style="color:var(--blue)">@(totalIn - totalOut)</div><div class="ss-l">Chênh lệch</div></div>
    </div>

    <div class="toolbar">
        <div class="srch-w">
            <i class="bi bi-search"></i>
            <input type="text" id="htSrch" placeholder="Tìm ghi chú, người dùng..." oninput="htFilter()" />
        </div>
        <select class="flt-sel" id="htType" onchange="htFilter()">
            <option value="">Tất cả loại</option>
            <option value="StockIn">Nhập kho</option>
            <option value="StockOut">Xuất kho</option>
            <option value="Sale">Bán đứt</option>
            <option value="Hold">Treo đơn</option>
            <option value="ReleaseHold">Huỷ treo</option>
            <option value="RentOut">Xuất thuê</option>
            <option value="RentReturn">Trả thuê</option>
            <option value="Adjustment">Điều chỉnh</option>
            <option value="Transfer">Chuyển kho</option>
        </select>
        <select class="flt-sel" id="htDir" onchange="htFilter()">
            <option value="">Tất cả chiều</option>
            <option value="plus">↑ Tăng kho</option>
            <option value="minus">↓ Giảm kho</option>
            <option value="neutral">~ Trung tính</option>
        </select>
    </div>

    @if (!Model.Transactions.Any())
    {
        <div class="empty-wrap"><i class="bi bi-clock-history"></i><p>Chưa có giao dịch nào</p></div>
    }
    else
    {
        <div id="htTimeline">
            @{
                string? lastDay = null;
            }
            @foreach (var tx in Model.Transactions)
            {
                var (lbl, ico, bg, clr, isPlus, isMinus) = TxMeta(tx.Type);
                var sign = isPlus ? "+" : isMinus ? "−" : "~";
                var qtyCls = isPlus ? "plus" : isMinus ? "minus" : "neutral";
                var dir = isPlus ? "plus" : isMinus ? "minus" : "neutral";
                var dayStr = tx.TransactionDate.ToString("dd/MM/yyyy");
                var srch = $"{tx.Note ?? ""} {tx.UserEmail ?? ""} {lbl}".ToLower();
                if (dayStr != lastDay)
                {
                    lastDay = dayStr;
                    <div class="day-sep"><i class="bi bi-calendar3"></i>@tx.TransactionDate.ToString("dddd, dd/MM/yyyy")</div>
                }
                <div class="tx-row" data-type="@tx.Type" data-dir="@dir" data-search="@srch">
                    <div class="tx-dot" style="background:@bg;border-color:@clr">
                        <i class="bi @ico" style="color:@clr;font-size:.5rem"></i>
                    </div>
                    <div class="tx-content">
                        <div class="tx-top">
                            <span class="tx-badge" style="background:@bg;color:@clr"><i class="bi @ico"></i> @lbl</span>
                            <span class="tx-time">@tx.TransactionDate.ToString("HH:mm")</span>
                            @if (!string.IsNullOrEmpty(tx.FacilityName))
                            {
                                <span class="tx-fac"><i class="bi bi-building"></i> @tx.FacilityName</span>
                            }
                            <span class="tx-qty @qtyCls">@sign@tx.Quantity</span>
                        </div>
                        <div class="tx-meta">
                            @if (!string.IsNullOrEmpty(tx.UserEmail))
                            {
                                <span><i class="bi bi-person"></i> @tx.UserEmail</span>
                            }
                            @if (tx.OrderId.HasValue)
                            {
                                <span><i class="bi bi-receipt"></i> Đơn #@tx.OrderId</span>
                            }
                            @if (!string.IsNullOrEmpty(tx.BatchNumber))
                            {
                                <span><i class="bi bi-upc"></i> @tx.BatchNumber</span>
                            }
                            @if (tx.CostPriceSnapshot.HasValue)
                            {
                                <span><i class="bi bi-currency-exchange"></i> @tx.CostPriceSnapshot.Value.ToString("N0")đ</span>
                            }
                            @if (tx.QuantityAfter > 0)
                            {
                                <span class="tx-after">Sau: <strong>@tx.QuantityAfter</strong></span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(tx.Note))
                        {
                            <span class="tx-note"><i class="bi bi-chat-text"></i> @tx.Note</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    function htFilter(){
        const q=document.getElementById('htSrch').value.toLowerCase();
        const type=document.getElementById('htType').value;
        const dir=document.getElementById('htDir').value;
        let cnt=0;
        document.querySelectorAll('#htTimeline .tx-row').forEach(r=>{
            const show=(!q||r.dataset.search?.includes(q))&&(!type||r.dataset.type===type)&&(!dir||r.dataset.dir===dir);
            r.style.display=show?'':'none';if(show)cnt++;
        });
        document.querySelectorAll('#htTimeline .day-sep').forEach(sep=>{
            let next=sep.nextElementSibling,has=false;
            while(next&&!next.classList.contains('day-sep')){if(next.style.display!=='none'){has=true;break;}next=next.nextElementSibling;}
            sep.style.display=has?'':'none';
        });
    }
</script>
