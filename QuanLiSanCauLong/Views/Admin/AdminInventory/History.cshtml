@model QuanLiSanCauLong.ViewModels.InventoryHistoryViewModel

@{
    Layout = null; // luôn là partial
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #fff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --green: #15803d;
        --green-soft: #dcfce7;
        --red: #dc2626;
        --red-soft: #fef2f2;
        --blue: #1d4ed8;
        --blue-soft: #eff6ff;
        --orange: #c2410c;
        --orange-soft: #fff7ed;
        --purple: #7c3aed;
        --purple-soft: #f5f3ff;
        --yellow: #92600a;
        --yellow-soft: #fef9ec;
    }

    .hist-wrap {
        padding: 0;
        font-family: 'Outfit',sans-serif;
    }

    /* Product header */
    .hist-prod-hd {
        padding: 1rem 1.5rem;
        background: linear-gradient(135deg,#1a1a2e,#2d1a4e);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .hist-prod-name {
        font-weight: 800;
        font-size: 1rem;
        color: #fff;
    }

    .hist-prod-code {
        font-size: .72rem;
        color: rgba(255,255,255,.55);
        font-family: 'Courier New',monospace;
        margin-top: 2px;
    }

    .hist-prod-badges {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .hpb {
        font-size: .68rem;
        font-weight: 700;
        padding: .18rem .6rem;
        border-radius: 10px;
        white-space: nowrap;
    }

    .hpb-total {
        background: rgba(255,255,255,.12);
        color: rgba(255,255,255,.85);
    }

    .hpb-in {
        background: #dcfce7;
        color: var(--green);
    }

    .hpb-out {
        background: #fef2f2;
        color: var(--red);
    }

    /* Toolbar */
    .hist-toolbar {
        padding: .75rem 1.25rem;
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
        background: var(--warm);
        border-bottom: 1px solid var(--border);
    }

    .ht-search {
        position: relative;
        flex: 1;
        min-width: 160px;
        max-width: 240px;
    }

        .ht-search i {
            position: absolute;
            left: .6rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .78rem;
            pointer-events: none;
        }

        .ht-search input {
            padding: .38rem .65rem .38rem 1.9rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: .82rem;
            width: 100%;
            background: var(--card);
            outline: none;
        }

            .ht-search input:focus {
                border-color: var(--gold);
            }

    .ht-sel {
        padding: .38rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: .8rem;
        background: var(--card);
        cursor: pointer;
        outline: none;
    }

    .ht-count {
        font-size: .75rem;
        color: var(--muted);
        margin-left: auto;
    }

    /* Timeline */
    .hist-timeline {
        padding: 1.1rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: .55rem;
        max-height: 60vh;
        overflow-y: auto;
    }

        .hist-timeline::-webkit-scrollbar {
            width: 5px;
        }

        .hist-timeline::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }

    .ht-item {
        display: flex;
        gap: .85rem;
        align-items: flex-start;
        padding: .7rem .9rem;
        border-radius: 11px;
        border: 1.5px solid var(--border);
        background: var(--card);
        transition: .15s;
        cursor: default;
    }

        .ht-item:hover {
            background: #fdf9f2;
            border-color: var(--gold2);
        }

    /* Icon */
    .ht-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .ico-in {
        background: var(--green-soft);
        color: var(--green);
    }

    .ico-out {
        background: var(--red-soft);
        color: var(--red);
    }

    .ico-neutral {
        background: var(--yellow-soft);
        color: var(--yellow);
    }

    .ico-hold {
        background: var(--orange-soft);
        color: var(--orange);
    }

    .ico-rent {
        background: var(--blue-soft);
        color: var(--blue);
    }

    .ico-damage {
        background: var(--purple-soft);
        color: var(--purple);
    }

    .ico-transfer {
        background: #f0f9ff;
        color: #0369a1;
    }

    /* Content */
    .ht-content {
        flex: 1;
        min-width: 0;
    }

    .ht-row1 {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .ht-type-badge {
        font-size: .68rem;
        font-weight: 800;
        padding: .15rem .6rem;
        border-radius: 10px;
        white-space: nowrap;
    }

    .tb-in {
        background: var(--green-soft);
        color: var(--green);
    }

    .tb-out {
        background: var(--red-soft);
        color: var(--red);
    }

    .tb-neutral {
        background: var(--yellow-soft);
        color: var(--yellow);
    }

    .tb-hold {
        background: var(--orange-soft);
        color: var(--orange);
    }

    .tb-rent {
        background: var(--blue-soft);
        color: var(--blue);
    }

    .tb-damage {
        background: var(--purple-soft);
        color: var(--purple);
    }

    .tb-transfer {
        background: #f0f9ff;
        color: #0369a1;
    }

    .ht-qty {
        font-size: .88rem;
        font-weight: 800;
        margin-left: auto;
        white-space: nowrap;
    }

        .ht-qty.plus {
            color: var(--green);
        }

        .ht-qty.minus {
            color: var(--red);
        }

        .ht-qty.neutral {
            color: var(--yellow);
        }

    .ht-row2 {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        margin-top: .25rem;
        align-items: center;
    }

    .ht-meta {
        font-size: .72rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .2rem;
    }

    .ht-note {
        font-size: .75rem;
        color: var(--deep);
        background: var(--warm);
        border-radius: 6px;
        padding: .15rem .5rem;
        max-width: 260px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ht-after {
        font-size: .7rem;
        color: var(--muted);
        margin-left: auto;
        white-space: nowrap;
    }

        .ht-after strong {
            color: var(--deep);
        }

    /* Empty */
    .hist-empty {
        text-align: center;
        padding: 2.5rem 1.5rem;
        color: var(--muted);
    }

        .hist-empty i {
            font-size: 2rem;
            opacity: .3;
            display: block;
            margin-bottom: .6rem;
        }
</style>

@{
    // Tính summary
    int totalIn = Model.Transactions.Where(t => t.IsInbound).Sum(t => t.Quantity);
    int totalOut = Model.Transactions.Where(t => t.IsOutbound).Sum(t => t.Quantity);

    // Helper: map type → label, icon, css
    (string label, string icon, string iconCss, string badgeCss, string qtyCss, bool isPlus, bool isMinus) GetTypeMeta(string type) => type switch
    {
        "StockIn" => ("Nhập kho", "bi-box-arrow-in-down", "ico-in", "tb-in", "plus", true, false),
        "StockOut" => ("Xuất kho", "bi-box-arrow-up", "ico-out", "tb-out", "minus", false, true),
        "Sale" => ("Bán đứt", "bi-bag-check", "ico-out", "tb-out", "minus", false, true),
        "Hold" => ("Treo đơn", "bi-lock", "ico-hold", "tb-hold", "minus", false, true),
        "ReleaseHold" => ("Huỷ treo", "bi-lock-fill", "ico-in", "tb-in", "plus", true, false),
        "RentOut" => ("Xuất thuê", "bi-arrow-right-circle", "ico-rent", "tb-rent", "minus", false, true),
        "RentReturn" => ("Trả thuê", "bi-arrow-left-circle", "ico-in", "tb-in", "plus", true, false),
        "RentLost" => ("Mất thuê", "bi-x-circle", "ico-out", "tb-out", "minus", false, true),
        "Adjustment" => ("Điều chỉnh", "bi-sliders", "ico-neutral", "tb-neutral", "neutral", false, false),
        "Damaged" => ("Hàng hỏng", "bi-tools", "ico-damage", "tb-damage", "neutral", false, false),
        "DamagedWrite" => ("Xoá sổ hỏng", "bi-trash3", "ico-damage", "tb-damage", "minus", false, true),
        "Transfer" => ("Chuyển kho", "bi-arrow-left-right", "ico-transfer", "tb-transfer", "neutral", false, false),
        _ => (type, "bi-clock-history", "ico-neutral", "tb-neutral", "neutral", false, false),
    };
}

<div class="hist-wrap">

    <!-- Product header -->
    <div class="hist-prod-hd">
        <div>
            <div class="hist-prod-name">@Model.ProductName</div>
            <div class="hist-prod-code">@Model.ProductCode</div>
        </div>
        <div class="hist-prod-badges">
            <span class="hpb hpb-total">@Model.Transactions.Count giao dịch</span>
            <span class="hpb hpb-in">+@totalIn nhập</span>
            <span class="hpb hpb-out">-@totalOut xuất</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="hist-toolbar">
        <div class="ht-search">
            <i class="bi bi-search"></i>
            <input type="text" id="htSearch" placeholder="Tìm ghi chú, người dùng..." oninput="applyHtFilter()" />
        </div>
        <select class="ht-sel" id="htTypeSel" onchange="applyHtFilter()">
            <option value="">Tất cả loại</option>
            <option value="StockIn">📥 Nhập kho</option>
            <option value="StockOut">📤 Xuất kho</option>
            <option value="Sale">🛒 Bán đứt</option>
            <option value="Hold">🔒 Treo đơn</option>
            <option value="ReleaseHold">🔓 Huỷ treo</option>
            <option value="RentOut">🔄 Xuất thuê</option>
            <option value="RentReturn">↩️ Trả thuê</option>
            <option value="RentLost">❌ Mất thuê</option>
            <option value="Adjustment">⚙️ Điều chỉnh</option>
            <option value="Damaged">💔 Hàng hỏng</option>
            <option value="DamagedWrite">🗑️ Xoá sổ hỏng</option>
            <option value="Transfer">↔️ Chuyển kho</option>
        </select>
        <select class="ht-sel" id="htDirSel" onchange="applyHtFilter()">
            <option value="">Tất cả chiều</option>
            <option value="in">📥 Tăng kho</option>
            <option value="out">📤 Giảm kho</option>
            <option value="neutral">⚙️ Trung tính</option>
        </select>
        <span class="ht-count" id="htCount">@Model.Transactions.Count giao dịch</span>
    </div>

    <!-- Timeline -->
    @if (Model.Transactions.Any())
    {
        <div class="hist-timeline" id="htTimeline">
            @foreach (var t in Model.Transactions)
            {
                var (label, icon, iconCss, badgeCss, qtyCss, isPlus, isMinus) = GetTypeMeta(t.Type);
                var qtySign = isPlus ? "+" : isMinus ? "−" : "±";
                var dirData = isPlus ? "in" : isMinus ? "out" : "neutral";
                var searchData = $"{t.Type.ToLower()} {t.Note?.ToLower()} {t.UserEmail?.ToLower()} {t.FacilityName?.ToLower()} {t.BatchNumber?.ToLower()}";

                <div class="ht-item"
                     data-type="@t.Type"
                     data-dir="@dirData"
                     data-search="@searchData">
                    <div class="ht-icon @iconCss">
                        <i class="bi @icon"></i>
                    </div>
                    <div class="ht-content">
                        <div class="ht-row1">
                            <span class="ht-type-badge @badgeCss">@label</span>
                            @if (t.OrderId.HasValue)
                            {
                                <span style="font-size:.66rem;color:var(--blue);font-weight:700;">Đơn #@t.OrderId</span>
                            }
                            @if (!string.IsNullOrEmpty(t.BatchNumber))
                            {
                                <span style="font-size:.66rem;font-family:monospace;color:var(--muted);">@t.BatchNumber</span>
                            }
                            <span class="ht-qty @qtyCss">@qtySign@t.Quantity</span>
                        </div>
                        <div class="ht-row2">
                            <span class="ht-meta"><i class="bi bi-geo-alt"></i>@(t.FacilityName ?? "—")</span>
                            @if (t.TargetFacilityId.HasValue)
                            {
                                <span class="ht-meta"><i class="bi bi-arrow-right"></i> CS #@t.TargetFacilityId</span>
                            }
                            <span class="ht-meta"><i class="bi bi-person"></i>@(t.UserEmail?.Split('@')[0] ?? "—")</span>
                            <span class="ht-meta"><i class="bi bi-calendar3"></i>@t.TransactionDate.ToString("HH:mm dd/MM/yy")</span>
                            @if (t.ExpiryDate.HasValue)
                            {
                                <span class="ht-meta" style="color:var(--orange);"><i class="bi bi-calendar-x"></i>HSD: @t.ExpiryDate.Value.ToString("dd/MM/yy")</span>
                            }
                            @if (t.CostPriceSnapshot.HasValue && t.CostPriceSnapshot > 0)
                            {
                                <span class="ht-meta" style="color:var(--green);"><i class="bi bi-coin"></i>@t.CostPriceSnapshot.Value.ToString("N0")₫</span>
                            }
                            @if (!string.IsNullOrEmpty(t.Note))
                            {
                                <span class="ht-note" title="@t.Note"><i class="bi bi-chat-left-text me-1"></i>@t.Note</span>
                            }
                            <span class="ht-after">Sau GD: <strong>@t.QuantityAfter</strong></span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="hist-empty">
            <i class="bi bi-clock-history"></i>
            <p>Chưa có giao dịch nào được ghi nhận</p>
        </div>
    }
</div>

<script>
    (function () {
        function applyHtFilter() {
            const q   = document.getElementById('htSearch')?.value.toLowerCase() ?? '';
            const tp  = document.getElementById('htTypeSel')?.value ?? '';
            const dir = document.getElementById('htDirSel')?.value ?? '';
            let cnt = 0;
            document.querySelectorAll('#htTimeline .ht-item').forEach(row => {
                const ok = (!q   || (row.dataset.search ?? '').includes(q))
                        && (!tp  || row.dataset.type === tp)
                        && (!dir || row.dataset.dir  === dir);
                row.style.display = ok ? '' : 'none';
                if (ok) cnt++;
            });
            const el = document.getElementById('htCount');
            if (el) el.textContent = cnt + ' giao dịch';
        }
        window.applyHtFilter = applyHtFilter;
    })();
</script>
