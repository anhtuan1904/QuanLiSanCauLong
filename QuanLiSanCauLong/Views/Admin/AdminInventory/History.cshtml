@model IEnumerable<dynamic>

@{
    var product = ViewBag.Product;
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
    }

    .modal-hd-court {
        background: var(--court-dark);
        color: #fff;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

        .modal-hd-court h5 {
            font-weight: 800;
            font-size: 1.05rem;
            margin: 0 0 2px;
            color: #fff;
        }

        .modal-hd-court p {
            font-size: .78rem;
            color: rgba(255,255,255,.6);
            margin: 0;
        }

    .icon-wrap-hist {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        background: rgba(255,255,255,.12);
        color: rgba(255,255,255,.8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-right: 1rem;
        flex-shrink: 0;
    }

    .btn-close-inv {
        filter: invert(1);
        opacity: .7;
    }

    /* Product header */
    .prod-header {
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .prod-thumb-hist {
        width: 52px;
        height: 52px;
        border-radius: 9px;
        overflow: hidden;
        border: 1px solid var(--court-border);
        flex-shrink: 0;
    }

        .prod-thumb-hist img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .pi-tag {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
    }

    .pi-sku {
        background: var(--court-bg);
        color: var(--court-muted);
        border: 1px solid var(--court-border);
    }

    .pi-cat {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #93c5fd;
    }

    .pi-batch {
        background: #f9fafb;
        color: #374151;
        border: 1px solid #d1d5db;
    }

    .fw-mono {
        font-family: monospace;
        letter-spacing: .3px;
    }

    /* Current stock highlight */
    .stock-badge-hist {
        background: var(--court-dark);
        color: var(--court-gold);
        border-radius: 9px;
        padding: .4rem .85rem;
        text-align: center;
        white-space: nowrap;
    }

        .stock-badge-hist .sv {
            font-size: 1.3rem;
            font-weight: 800;
            line-height: 1;
        }

        .stock-badge-hist .sl {
            font-size: .62rem;
            font-weight: 700;
            text-transform: uppercase;
            opacity: .6;
        }

    /* Summary mini stats */
    .mini-summary {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .6rem;
        margin-bottom: 1rem;
    }

    .ms-card {
        border-radius: 10px;
        padding: .65rem;
        text-align: center;
    }

    .ms-val {
        font-size: 1.2rem;
        font-weight: 800;
        line-height: 1;
    }

    .ms-lbl {
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-top: 3px;
    }

    .ms-in {
        background: #f0fdf4;
    }

        .ms-in .ms-val {
            color: #166534;
        }

        .ms-in .ms-lbl {
            color: #4ade80;
        }

    .ms-out {
        background: #fef2f2;
    }

        .ms-out .ms-val {
            color: #dc2626;
        }

        .ms-out .ms-lbl {
            color: #fca5a5;
        }

    .ms-adj {
        background: #fffbeb;
    }

        .ms-adj .ms-val {
            color: #b45309;
        }

        .ms-adj .ms-lbl {
            color: #fcd34d;
        }

    /* Table */
    .hist-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .hist-tbl thead {
            position: sticky;
            top: 0;
            z-index: 1;
        }

            .hist-tbl thead tr {
                background: var(--court-dark);
            }

            .hist-tbl thead th {
                color: rgba(255,255,255,.65);
                font-size: .66rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .8px;
                padding: .65rem .9rem;
                border: none;
                white-space: nowrap;
            }

        .hist-tbl tbody tr {
            border-bottom: 1px solid var(--court-border);
            transition: background .12s;
        }

            .hist-tbl tbody tr:last-child {
                border-bottom: none;
            }

            .hist-tbl tbody tr:hover {
                background: #faf8f0;
            }

        .hist-tbl td {
            padding: .65rem .9rem;
            vertical-align: middle;
            font-size: .84rem;
        }

    /* Type badges */
    .tbadge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 9px;
        border-radius: 20px;
        font-size: .7rem;
        font-weight: 700;
    }

    .tb-in {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #86efac;
    }

    .tb-out {
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fcd34d;
    }

    .tb-adj {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #93c5fd;
    }

    .tb-oth {
        background: var(--court-bg);
        color: var(--court-muted);
        border: 1px solid var(--court-border);
    }

    /* Qty cell */
    .qty-cell {
        font-weight: 800;
        font-size: .95rem;
    }

    .qty-in {
        color: #166534;
    }

    .qty-out {
        color: #dc2626;
    }

    .qty-adj {
        color: #1d4ed8;
    }

    /* Empty */
    .hist-empty {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--court-muted);
    }

        .hist-empty i {
            font-size: 2.5rem;
            opacity: .2;
            display: block;
            margin-bottom: .75rem;
        }

    /* Footer */
    .modal-foot-court {
        background: var(--court-bg);
        border-top: 1px solid var(--court-border);
        border-radius: 0 0 16px 16px;
        padding: 1rem 1.5rem;
    }

    .btn-close-full {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        width: 100%;
        padding: .6rem;
        background: var(--court-dark);
        color: #fff;
        border: none;
        border-radius: 9px;
        font-weight: 700;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
    }

        .btn-close-full:hover {
            background: #2a2a4a;
        }
</style>

<div class="modal-hd-court">
    <div class="d-flex align-items-center">
        <div class="icon-wrap-hist"><i class="bi bi-clock-history"></i></div>
        <div>
            <h5>Lịch Sử Kho</h5>
            <p>Toàn bộ biến động nhập / xuất / điều chỉnh</p>
        </div>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body p-4" style="background:#fff;">

    <!-- Product header -->
    <div class="prod-header">
        <div class="prod-thumb-hist">
            <img src="@(product?.ImageUrl ?? "/images/no-image.png")"
                 onerror="this.src='/images/no-image.png'" />
        </div>
        <div style="flex:1;min-width:0;">
            <div style="font-size:.95rem;font-weight:800;color:var(--court-dark);margin-bottom:4px;">
                @(product?.ProductName ?? "Sản phẩm")
            </div>
            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                @if (product?.SKU != null)
                {
                    <span class="pi-tag pi-sku fw-mono"><i class="bi bi-upc"></i>@product.SKU</span>
                }
                @if (product?.Category?.CategoryName != null)
                {
                    <span class="pi-tag pi-cat"><i class="bi bi-tag"></i>@product.Category.CategoryName</span>
                }
                @if (product?.BatchNumber != null)
                {
                    <span class="pi-tag pi-batch"><i class="bi bi-layers"></i>Lô: @product.BatchNumber</span>
                }
            </div>
        </div>
        <div class="stock-badge-hist">
            <div class="sv">@ViewBag.CurrentStock</div>
            <div class="sl">@product?.Unit hiện tồn</div>
        </div>
    </div>

    <!-- Summary stats -->
    @if (Model != null && Model.Any())
    {
        <div class="mini-summary">
            <div class="ms-card ms-in">
                <div class="ms-val">@Model.Where(l => l.Type == "StockIn").Sum(l => (int)l.Quantity)</div>
                <div class="ms-lbl">Tổng Nhập</div>
            </div>
            <div class="ms-card ms-out">
                <div class="ms-val">@Model.Where(l => l.Type == "StockOut").Sum(l => (int)l.Quantity)</div>
                <div class="ms-lbl">Tổng Xuất</div>
            </div>
            <div class="ms-card ms-adj">
                <div class="ms-val">@Model.Count(l => l.Type == "Adjustment")</div>
                <div class="ms-lbl">Điều Chỉnh</div>
            </div>
        </div>
    }

    <!-- History table -->
    <div style="max-height:360px;overflow-y:auto;border-radius:10px;border:1px solid var(--court-border);overflow:hidden;">
        <table class="hist-tbl">
            <thead>
                <tr>
                    <th style="width:90px;">Ngày</th>
                    <th style="width:100px;">Loại</th>
                    <th style="width:60px;text-align:center;">SL</th>
                    <th style="width:90px;">Số lô</th>
                    <th style="width:100px;">Chứng từ</th>
                    <th>Người thực hiện / Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var log in Model)
                    {
                        <tr>
                            <td>
                                <div style="font-size:.82rem;font-weight:700;color:var(--court-dark);">
                                    @log.TransactionDate.ToString("dd/MM/yyyy")
                                </div>
                                <div style="font-size:.72rem;color:var(--court-muted);">
                                    @log.TransactionDate.ToString("HH:mm")
                                </div>
                            </td>
                            <td>
                                @if (log.Type == "StockIn")
                                {
                                    <span class="tbadge tb-in"><i class="bi bi-box-arrow-in-down"></i>Nhập</span>
                                }
                                else if (log.Type == "StockOut")
                                {

                                    <span class="tbadge tb-out"><i class="bi bi-box-arrow-up"></i>Xuất</span>
                                }
                                else if (log.Type == "Adjustment")
                                {

                                    <span class="tbadge tb-adj"><i class="bi bi-pencil-square"></i>Điều chỉnh</span>
                                }
                                else
                                {

                                    <span class="tbadge tb-oth">@log.Type</span>
                                }
                            </td>
                            <td style="text-align:center;">
                                <span class="qty-cell @(log.Type == "StockIn" ? "qty-in" : log.Type == "StockOut" ? "qty-out" : "qty-adj")">
                                    @(log.Type == "StockIn" ? "+" : log.Type == "StockOut" ? "−" : "~")@log.Quantity
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty((string)log.BatchNumber))
                                {
                                    <span class="fw-mono" style="font-size:.75rem;color:var(--court-muted);">@log.BatchNumber</span>
                                }
                                else
                                {

                                    <span style="color:var(--court-muted);">—</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty((string)log.DocumentReference))
                                {
                                    <span class="fw-mono" style="font-size:.75rem;color:var(--court-muted);">@log.DocumentReference</span>
                                }
                                else
                                {

                                    <span style="color:var(--court-muted);">—</span>
                                }
                            </td>
                            <td>
                                <div style="font-size:.82rem;font-weight:700;color:var(--court-dark);">@log.UserEmail</div>
                                @if (!string.IsNullOrEmpty((string)log.Note))
                                {
                                    <div style="font-size:.72rem;color:var(--court-muted);">@log.Note</div>
                                }
                                @if (!string.IsNullOrEmpty((string)log.SupplierName))
                                {
                                    <div style="font-size:.72rem;color:var(--court-muted);"><i class="bi bi-building me-1"></i>@log.SupplierName</div>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="hist-empty">
                                <i class="bi bi-inbox"></i>
                                Chưa có giao dịch nào được ghi nhận.
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-foot-court">
    <button type="button" class="btn-close-full" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Đóng
    </button>
</div>
