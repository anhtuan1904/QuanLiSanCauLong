@model QuanLiSanCauLong.ViewModels.BookingHistoryViewModel
@{
    ViewData["Title"] = "Chi tiết đặt sân #" + Model.BookingCode;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #ffffff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --text: #1a1209;
        --green: #15803d;
        --green-soft: #dcfce7;
        --red: #dc2626;
        --red-soft: #fef2f2;
        --blue: #0284c7;
        --blue-soft: #e0f2fe;
        --purple: #7c3aed;
        --purple-soft: #f5f3ff;
    }

    body, .container-fluid {
        font-family: 'Outfit', sans-serif;
        background: var(--cream);
    }

    /* ── Breadcrumb ── */
    .bc {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        color: var(--muted);
        margin-bottom: 1.4rem;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .3rem;
            transition: .15s;
        }

            .bc a:hover {
                color: var(--deep);
            }

    .bc-sep {
        opacity: .5;
    }

    .bc-cur {
        color: var(--deep);
        font-weight: 700;
        font-family: 'Courier New', monospace;
    }

    /* ── Page top row ── */
    .pgtop {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .page-label {
        font-size: .68rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .55rem;
        margin-bottom: .35rem;
    }

        .page-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .pg-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.65rem;
        font-weight: 700;
        color: var(--deep);
        margin: 0;
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-meta {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .25rem;
        font-family: 'Courier New', monospace;
    }

    /* ── Action Buttons ── */
    .action-btns {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
    }

    .btn-act {
        display: inline-flex;
        align-items: center;
        gap: .42rem;
        padding: .55rem 1.15rem;
        border-radius: 9px;
        border: none;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
        text-decoration: none;
        white-space: nowrap;
    }

    .btn-print {
        background: var(--warm);
        color: var(--muted);
        border: 1px solid var(--border);
    }

        .btn-print:hover {
            background: var(--cream);
            color: var(--deep);
        }

    .btn-confirm {
        background: var(--gold2);
        color: var(--deep);
        box-shadow: 0 2px 8px rgba(212,160,23,.3);
    }

        .btn-confirm:hover {
            background: var(--gold);
            color: #fff;
        }

    .btn-checkin {
        background: var(--blue);
        color: #fff;
    }

        .btn-checkin:hover {
            background: #0369a1;
        }

    .btn-complete {
        background: var(--green-soft);
        color: var(--green);
        border: 1px solid #a7f3d0;
    }

        .btn-complete:hover {
            background: var(--green);
            color: #fff;
            border-color: var(--green);
        }

    .btn-cancel {
        background: var(--red-soft);
        color: var(--red);
        border: 1px solid #fecaca;
    }

        .btn-cancel:hover {
            background: var(--red);
            color: #fff;
            border-color: var(--red);
        }

    /* ── Timeline ── */
    .timeline-wrap {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem 2rem;
        margin-bottom: 1.3rem;
        box-shadow: 0 2px 10px rgba(26,18,9,.05);
    }

    .timeline {
        display: flex;
        align-items: center;
    }

    .tl-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        min-width: 64px;
    }

    .tl-icon {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        border: 2px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: var(--muted);
        transition: .3s;
    }

    .tl-step.done .tl-icon {
        background: var(--green);
        border-color: var(--green);
        color: #fff;
    }

    .tl-step.active .tl-icon {
        background: var(--gold2);
        border-color: var(--gold);
        color: var(--deep);
        box-shadow: 0 0 0 4px rgba(245,200,66,.2);
    }

    .tl-step.cancelled .tl-icon {
        background: var(--red);
        border-color: var(--red);
        color: #fff;
    }

    .tl-label {
        margin-top: .6rem;
        font-size: .72rem;
        font-weight: 700;
        color: var(--muted);
        text-align: center;
        white-space: nowrap;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .tl-step.done .tl-label {
        color: var(--green);
    }

    .tl-step.active .tl-label {
        color: var(--gold);
    }

    .tl-step.cancelled .tl-label {
        color: var(--red);
    }

    .tl-line {
        flex: 1;
        height: 2px;
        background: var(--border);
        margin: 0 .5rem;
        position: relative;
        top: -14px;
    }

        .tl-line.done {
            background: var(--green);
        }

    /* ── Layout ── */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.3rem;
        align-items: start;
    }

    @@media (max-width: 992px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── Section Cards ── */
    .dc {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.2rem;
        box-shadow: 0 2px 10px rgba(26,18,9,.05);
    }

    .dc-hd {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .dc-hd i {
            color: var(--gold);
            font-size: .95rem;
        }

    .dc-hd-title {
        font-weight: 700;
        font-size: .92rem;
        color: var(--deep);
        letter-spacing: .02em;
    }

    .dc-bd {
        padding: 1.4rem 1.5rem;
    }

    /* Court block */
    .court-block {
        display: flex;
        align-items: flex-start;
        gap: 1.1rem;
    }

    .court-icon {
        width: 60px;
        height: 60px;
        border-radius: 13px;
        background: #fef9ec;
        border: 1px solid #f0dea0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--gold);
        flex-shrink: 0;
    }

    .court-name {
        font-size: 1rem;
        font-weight: 800;
        color: var(--deep);
    }

    .court-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .court-price {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--green);
        margin-left: auto;
    }

    .time-chips {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .time-chip {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .4rem .9rem;
        border-radius: 8px;
        font-size: .8rem;
        font-weight: 600;
        background: var(--warm);
        border: 1px solid var(--border);
        color: var(--deep);
    }

        .time-chip i {
            color: var(--gold);
            font-size: .82rem;
        }

    /* Products */
    .prod-row {
        display: flex;
        align-items: center;
        gap: .85rem;
        padding: .75rem 0;
        border-bottom: 1px solid var(--warm);
    }

        .prod-row:last-child {
            border-bottom: none;
        }

    .prod-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        background: #fef9ec;
        border: 1px solid #f0dea0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .92rem;
        color: var(--gold);
        flex-shrink: 0;
    }

    .prod-name {
        font-weight: 700;
        font-size: .86rem;
        color: var(--deep);
    }

    .prod-meta {
        font-size: .76rem;
        color: var(--muted);
    }

    .prod-price {
        margin-left: auto;
        font-weight: 800;
        font-size: .88rem;
        color: var(--deep);
    }

    /* Summary */
    .sum-row {
        display: flex;
        justify-content: space-between;
        padding: .45rem 0;
        font-size: .85rem;
    }

        .sum-row .lbl {
            color: var(--muted);
        }

        .sum-row .val {
            font-weight: 700;
            color: var(--deep);
        }

    .sum-total {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding-top: .9rem;
        margin-top: .7rem;
        border-top: 2px solid var(--border);
    }

        .sum-total .lbl {
            font-size: .95rem;
            font-weight: 800;
            color: var(--deep);
        }

        .sum-total .val {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            font-weight: 700;
            color: var(--green);
        }

    /* Customer avatar */
    .cust-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: #fef9ec;
        border: 2px solid #f0dea0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: var(--gold);
        flex-shrink: 0;
    }

    .cust-name-lg {
        font-weight: 800;
        font-size: .95rem;
        color: var(--deep);
    }

    .cust-role {
        font-size: .74rem;
        color: var(--muted);
    }

    .contact-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .4rem 0;
        font-size: .85rem;
        color: var(--deep);
        border-bottom: 1px solid var(--warm);
    }

        .contact-row:last-child {
            border-bottom: none;
        }

        .contact-row i {
            color: var(--gold);
            width: 16px;
            text-align: center;
        }

    /* Info rows */
    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: .55rem 0;
        font-size: .84rem;
    }

        .info-row + .info-row {
            border-top: 1px solid var(--warm);
        }

    .info-lbl {
        color: var(--muted);
        flex-shrink: 0;
    }

    .info-val {
        font-weight: 700;
        color: var(--deep);
        text-align: right;
    }

    /* Badges */
    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .3rem .8rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
    }

    .bp-paid {
        background: var(--green-soft);
        color: var(--green);
    }

    .bp-unpaid {
        background: #fef9ec;
        color: #92600a;
        border: 1px solid #f0dea0;
    }

    .bp-pending {
        background: #fef9ec;
        color: #92600a;
        border: 1px solid #f0dea0;
    }

    .bp-confirmed {
        background: var(--blue-soft);
        color: var(--blue);
    }

    .bp-playing {
        background: var(--purple-soft);
        color: var(--purple);
    }

    .bp-completed {
        background: var(--green-soft);
        color: var(--green);
    }

    .bp-cancelled {
        background: var(--red-soft);
        color: var(--red);
    }

    /* Act grid */
    .act-grid {
        display: grid;
        gap: .55rem;
    }

    /* Toast */
    .toast-wrap {
        position: fixed;
        top: 1.2rem;
        right: 1.2rem;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        pointer-events: none;
    }

    .toast-msg {
        padding: .75rem 1.2rem;
        border-radius: 10px;
        font-size: .84rem;
        font-weight: 600;
        box-shadow: 0 8px 24px rgba(0,0,0,.14);
        pointer-events: all;
        display: flex;
        align-items: center;
        gap: .5rem;
        animation: slideIn .22s ease;
    }

    .toast-success {
        background: #fff;
        border-left: 4px solid var(--green);
        color: var(--green);
    }

    .toast-error {
        background: #fff;
        border-left: 4px solid var(--red);
        color: var(--red);
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(20px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@media print {
        .action-btns, .act-grid, .bc, .pgtop .btn-print {
            display: none !important;
        }

        .detail-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid px-4 py-4">

    <!-- Breadcrumb -->
    <div class="bc">
        <a asp-action="Index"><i class="bi bi-house"></i> Quản lý đặt sân</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <span class="bc-cur">@Model.BookingCode</span>
    </div>

    <!-- Page top -->
    <div class="pgtop">
        <div>
            <div class="page-label">Chi tiết đơn đặt</div>
            <div class="pg-title">Đơn sân <em>#@Model.BookingCode</em></div>
            <div class="pg-meta">Tạo lúc @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="action-btns">
            <button class="btn-act btn-print" onclick="window.print()">
                <i class="bi bi-printer"></i> In hoá đơn
            </button>
            @if (Model.Status == "Pending")
            {
                <button class="btn-act btn-confirm" onclick="doAction('confirm', @Model.BookingId, 'Xác nhận đơn này?')">
                    <i class="bi bi-check-circle"></i> Xác nhận đơn
                </button>
            }
            @if (Model.Status == "Confirmed")
            {
                <button class="btn-act btn-checkin" onclick="doAction('checkin', @Model.BookingId, 'Check-in cho khách hàng?')">
                    <i class="bi bi-box-arrow-in-right"></i> Check-in
                </button>
            }
            @if (Model.Status == "Playing")
            {
                <button class="btn-act btn-complete" onclick="doAction('complete', @Model.BookingId, 'Đánh dấu hoàn thành?')">
                    <i class="bi bi-flag-fill"></i> Hoàn thành
                </button>
            }
        </div>
    </div>

    <!-- Timeline -->
    <div class="timeline-wrap">
        @{
            bool isCancelled = Model.Status == "Cancelled";
            bool step1 = true;
            bool step2 = new[] { "Confirmed", "Playing", "Completed" }.Contains(Model.Status);
            bool step3 = new[] { "Playing", "Completed" }.Contains(Model.Status);
            bool step4 = Model.Status == "Completed";
        }
        <div class="timeline">
            <div class="tl-step @(isCancelled ? "cancelled" : "done")">
                <div class="tl-icon"><i class="bi bi-@(isCancelled ? "x-lg" : "file-earmark-check")"></i></div>
                <div class="tl-label">Đã đặt</div>
            </div>
            <div class="tl-line @(step2 && !isCancelled ? "done" : "")"></div>
            <div class="tl-step @(!isCancelled && step2 ? (step3 ? "done" : "active") : "")">
                <div class="tl-icon"><i class="bi bi-check2"></i></div>
                <div class="tl-label">Xác nhận</div>
            </div>
            <div class="tl-line @(step3 && !isCancelled ? "done" : "")"></div>
            <div class="tl-step @(!isCancelled && step3 ? (step4 ? "done" : "active") : "")">
                <div class="tl-icon"><i class="bi bi-box-arrow-in-right"></i></div>
                <div class="tl-label">Check-in</div>
            </div>
            <div class="tl-line @(step4 ? "done" : "")"></div>
            <div class="tl-step @(!isCancelled && step4 ? "done" : "")">
                <div class="tl-icon"><i class="bi bi-flag-fill"></i></div>
                <div class="tl-label">Hoàn thành</div>
            </div>
        </div>
    </div>

    <div class="detail-grid">
        <!-- LEFT -->
        <div>
            <!-- Court info -->
            <div class="dc">
                <div class="dc-hd"><i class="bi bi-calendar-event-fill"></i><span class="dc-hd-title">Thông tin đặt sân</span></div>
                <div class="dc-bd">
                    <div class="court-block">
                        <div class="court-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                        <div style="flex:1">
                            <div class="court-name">@Model.FacilityName</div>
                            <div class="court-sub">Sân @Model.CourtNumber · @Model.CourtType</div>
                        </div>
                        <div class="court-price">₫@Model.GrandTotal.ToString("N0")</div>
                    </div>
                    <div class="time-chips">
                        <span class="time-chip"><i class="bi bi-calendar3"></i> @Model.BookingDate.ToString("dd/MM/yyyy") (@Model.BookingDate.ToString("ddd"))</span>
                        <span class="time-chip"><i class="bi bi-clock"></i> @Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</span>
                        <span class="time-chip"><i class="bi bi-hourglass"></i> @Model.Duration phút</span>
                    </div>
                </div>
            </div>

            <!-- Products -->
            @if (Model.RelatedOrders != null && Model.RelatedOrders.Any())
            {
                <div class="dc">
                    <div class="dc-hd"><i class="bi bi-box-seam-fill"></i><span class="dc-hd-title">Sản phẩm & Dịch vụ đi kèm</span></div>
                    <div class="dc-bd">
                        @foreach (var order in Model.RelatedOrders)
                        {
                            @foreach (var od in order.OrderDetails)
                            {
                                <div class="prod-row">
                                    <div class="prod-icon"><i class="bi bi-bag-fill"></i></div>
                                    <div>
                                        <div class="prod-name">@od.ProductName</div>
                                        <div class="prod-meta">@od.Quantity @od.Unit × ₫@od.UnitPrice.ToString("N0")</div>
                                    </div>
                                    <div class="prod-price">₫@od.TotalPrice.ToString("N0")</div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            <!-- Summary -->
            <div class="dc">
                <div class="dc-hd"><i class="bi bi-receipt-cutoff"></i><span class="dc-hd-title">Chi tiết thanh toán</span></div>
                <div class="dc-bd">
                    <div class="sum-row"><span class="lbl">Tiền sân</span><span class="val">₫@Model.TotalPrice.ToString("N0")</span></div>
                    @if (Model.RelatedOrders != null && Model.RelatedOrders.Any())
                    {
                        <div class="sum-row">
                            <span class="lbl">Sản phẩm đi kèm</span>
                            <span class="val">₫@Model.RelatedOrders.Sum(o => o.TotalAmount).ToString("N0")</span>
                        </div>
                    }
                    <div class="sum-row"><span class="lbl">Giảm giá</span><span class="val" style="color:var(--red)">-₫0</span></div>
                    <div class="sum-total">
                        <span class="lbl">Tổng cộng</span>
                        <span class="val">₫@Model.GrandTotal.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div>
            <!-- Customer -->
            <div class="dc">
                <div class="dc-hd"><i class="bi bi-person-fill"></i><span class="dc-hd-title">Thông tin khách hàng</span></div>
                <div class="dc-bd">
                    <div style="display:flex;align-items:center;gap:.9rem;margin-bottom:1rem">
                        <div class="cust-avatar"><i class="bi bi-person-fill"></i></div>
                        <div>
                            <div class="cust-name-lg">@Model.CustomerName</div>
                            <div class="cust-role">Khách hàng</div>
                        </div>
                    </div>
                    <div class="contact-row"><i class="bi bi-telephone"></i> @Model.Phone</div>
                    <div class="contact-row"><i class="bi bi-envelope"></i> @Model.Email</div>
                </div>
            </div>

            <!-- Payment & Status -->
            <div class="dc">
                <div class="dc-hd"><i class="bi bi-credit-card-fill"></i><span class="dc-hd-title">Thanh toán & Trạng thái</span></div>
                <div class="dc-bd">
                    <div class="info-row">
                        <span class="info-lbl">Phương thức</span>
                        <span class="info-val">@Model.PaymentMethod</span>
                    </div>
                    <div class="info-row">
                        <span class="info-lbl">Thanh toán</span>
                        <span class="info-val">
                            @if (Model.PaymentStatus == "Paid")
                            {
                                <span class="badge-pill bp-paid"><i class="bi bi-check-circle-fill"></i> Đã thanh toán</span>
                            }
                            else
                            {
                                <span class="badge-pill bp-unpaid"><i class="bi bi-clock"></i> Chưa thanh toán</span>
                            }
                        </span>
                    </div>
                    <div class="info-row">
                        <span class="info-lbl">Trạng thái</span>
                        <span class="info-val">
                            @switch (Model.Status)
                            {
                                case "Pending":
                                    <span class="badge-pill bp-pending"><i class="bi bi-clock-history"></i> Chờ xác nhận</span>
                                    break;
                                case "Confirmed":
                                    <span class="badge-pill bp-confirmed"><i class="bi bi-check-circle"></i> Đã xác nhận</span>
                                    break;
                                case "Playing":
                                    <span class="badge-pill bp-playing"><i class="bi bi-controller"></i> Đang chơi</span>
                                    break;
                                case "Completed":
                                    <span class="badge-pill bp-completed"><i class="bi bi-check2-circle"></i> Hoàn thành</span>
                                    break;
                                case "Cancelled":
                                    <span class="badge-pill bp-cancelled"><i class="bi bi-x-circle"></i> Đã hủy</span>
                                    break;
                            }
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="info-row" style="display:block;margin-top:.5rem">
                            <span class="info-lbl" style="display:block;margin-bottom:.3rem">Ghi chú</span>
                            <p style="font-size:.82rem;color:var(--muted);font-style:italic;margin:0;background:var(--warm);padding:.6rem .8rem;border-radius:7px;border-left:3px solid var(--gold)">@Model.Note</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Admin Actions -->
            @if (Model.Status != "Cancelled" && Model.Status != "Completed")
            {
                <div class="dc">
                    <div class="dc-hd"><i class="bi bi-sliders2"></i><span class="dc-hd-title">Thao tác Admin</span></div>
                    <div class="dc-bd">
                        <div class="act-grid">
                            @if (Model.Status == "Pending")
                            {
                                <button class="btn-act btn-confirm" onclick="doAction('confirm', @Model.BookingId, 'Xác nhận đơn này?')" style="justify-content:center">
                                    <i class="bi bi-check-circle"></i> Xác nhận đơn
                                </button>
                            }
                            @if (Model.Status == "Confirmed")
                            {
                                <button class="btn-act btn-checkin" onclick="doAction('checkin', @Model.BookingId, 'Check-in cho khách hàng?')" style="justify-content:center">
                                    <i class="bi bi-box-arrow-in-right"></i> Check-in
                                </button>
                            }
                            @if (Model.Status == "Playing")
                            {
                                <button class="btn-act btn-complete" onclick="doAction('complete', @Model.BookingId, 'Đánh dấu hoàn thành?')" style="justify-content:center">
                                    <i class="bi bi-flag-fill"></i> Hoàn thành
                                </button>
                            }
                            @if (Model.PaymentStatus == "Unpaid")
                            {
                                <button class="btn-act btn-complete" onclick="updatePayment(@Model.BookingId,'Paid')" style="justify-content:center">
                                    <i class="bi bi-cash-coin"></i> Đánh dấu đã TT
                                </button>
                            }
                            <button class="btn-act btn-cancel" onclick="cancelBooking(@Model.BookingId)" style="justify-content:center">
                                <i class="bi bi-x-circle"></i> Hủy đơn
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Toast -->
<div class="toast-wrap" id="toastWrap"></div>

@section Scripts {
    <script>
        const URLS = {
            confirm:  '@Url.Action("Confirm", "AdminBooking")',
            checkin:  '@Url.Action("CheckIn", "AdminBooking")',
            complete: '@Url.Action("Complete", "AdminBooking")',
            cancel:   '@Url.Action("Cancel", "AdminBooking")',
            payment:  '@Url.Action("UpdatePayment", "AdminBooking")'
        };

        function doAction(action, bookingId, msg) {
            if (!confirm(msg)) return;
            postAjax(URLS[action], { bookingId });
        }

        function cancelBooking(bookingId) {
            const reason = prompt('Lý do hủy đơn:');
            if (!reason) return;
            postAjax(URLS.cancel, { bookingId, reason });
        }

        function updatePayment(bookingId, paymentStatus) {
            postAjax(URLS.payment, { bookingId, paymentStatus });
        }

        function postAjax(url, data) {
            const body = Object.entries(data)
                .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
                .join('&');

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                },
                body
            })
            .then(r => r.json())
            .then(result => {
                showToast(result.message, result.success ? 'success' : 'error');
                if (result.success) setTimeout(() => location.reload(), 1000);
            })
            .catch(() => showToast('Lỗi kết nối máy chủ', 'error'));
        }

        function showToast(msg, type = 'success') {
            const wrap = document.getElementById('toastWrap');
            const el   = document.createElement('div');
            el.className = `toast-msg toast-${type}`;
            el.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle-fill' : 'exclamation-circle-fill'}"></i> ${msg}`;
            wrap.appendChild(el);
            setTimeout(() => el.remove(), 3200);
        }
    </script>
}
