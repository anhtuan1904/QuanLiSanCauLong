@model IEnumerable<QuanLiSanCauLong.ViewModels.BookingHistoryViewModel>
@{
    ViewData["Title"] = "Admin · Quản lý đặt sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    string currentFilter = ViewBag.FilterType as string ?? "";
}

<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --G: #d4a017;
        --G2: #f5c842;
        --W: #f5ede0;
        --S: #ede5d8;
        --GN: #10b981;
        --BL: #1d4ed8;
        --M: rgba(255,255,255,.38);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: var(--W);
        font-family: 'Outfit', sans-serif;
    }

    /* Page header */
    .pg-hd {
        background: var(--D);
        border-bottom: 1px solid rgba(212,160,23,.18);
        padding: 1.8rem 2.2rem;
        position: relative;
        overflow: hidden;
    }

        .pg-hd::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 50% 120% at 80% 50%,rgba(212,160,23,.06),transparent);
        }

    .pg-hd-in {
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        position: relative;
        z-index: 1;
    }

    .pg-eyebrow {
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--G);
        margin-bottom: .35rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: #fff;
        margin: 0;
    }

    .pg-sub {
        font-size: .78rem;
        color: var(--M);
        margin-top: .25rem;
    }

    /* Tab nav */
    .tab-nav {
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        gap: 0;
        border-bottom: 2px solid var(--S);
        padding: 0 2.2rem;
        background: #fff;
        overflow-x: auto;
    }

    .tab-item {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .85rem 1.3rem;
        font-size: .8rem;
        font-weight: 700;
        color: #8c7a68;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all .2s;
        white-space: nowrap;
        cursor: pointer;
    }

        .tab-item:hover {
            color: var(--D);
            border-bottom-color: var(--S);
        }

        .tab-item.active {
            color: var(--D);
            border-bottom-color: var(--G);
        }

    .tab-badge {
        font-size: .6rem;
        font-weight: 800;
        letter-spacing: .04em;
        padding: .15rem .55rem;
        border-radius: 10px;
    }

        .tab-badge.orange {
            background: #fef3c7;
            color: #92400e;
        }

        .tab-badge.blue {
            background: #eff6ff;
            color: #1d4ed8;
        }

        .tab-badge.gray {
            background: var(--S);
            color: #4a3728;
        }

        .tab-badge.green {
            background: #d1fae5;
            color: #065f46;
        }

        .tab-badge.pulse {
            animation: pulse-badge 2s ease-in-out infinite;
        }

    @@keyframes pulse-badge {
        0%, 100% {
            opacity: 1
        }

        50% {
            opacity: .6
        }
    }

    /* Wrap */
    .wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 2rem 2.2rem;
    }

    /* Filter card */
    .fc {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.8rem;
    }

    .fc-hd {
        background: var(--D);
        padding: .85rem 1.4rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .fc-hd i {
            color: var(--G);
        }

    .fc-title {
        font-family: 'Playfair Display',serif;
        font-style: italic;
        font-size: .9rem;
        font-weight: 700;
        color: #fff;
    }

    .fc-bd {
        padding: 1.2rem 1.4rem;
    }

    .filter-g {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: .9rem;
        align-items: end;
    }

    .fl {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #8c7a68;
        margin-bottom: .3rem;
    }

    .fi {
        width: 100%;
        padding: .6rem .85rem;
        border: 1.5px solid var(--S);
        border-radius: 6px;
        font-size: .82rem;
        color: var(--D);
        outline: none;
        background: #fff;
        transition: border-color .2s;
        font-family: 'Outfit',sans-serif;
    }

        .fi:focus {
            border-color: var(--G);
        }

    .btn-filter {
        width: 100%;
        padding: .6rem;
        background: var(--D);
        color: var(--G2);
        border: none;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: background .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-filter:hover {
            background: var(--D2);
        }

    .btn-reset {
        width: 100%;
        padding: .6rem;
        background: none;
        color: #8c7a68;
        border: 1.5px solid var(--S);
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        text-decoration: none;
        font-family: 'Outfit',sans-serif;
    }

        .btn-reset:hover {
            border-color: var(--D);
            color: var(--D);
        }

    /* Transfer pending banner */
    .ck-banner {
        background: #eff6ff;
        border: 1.5px solid #93c5fd;
        border-radius: 10px;
        padding: 1rem 1.4rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        font-size: .82rem;
        color: #1d4ed8;
    }

        .ck-banner i {
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .ck-banner strong {
            color: #1e40af;
        }

    /* Table */
    .tbl-card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 10px;
        overflow: hidden;
    }

    .tbl-hd {
        background: var(--D);
        padding: .85rem 1.4rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .tbl-hd i {
            color: var(--G);
        }

    .tbl-title {
        font-family: 'Playfair Display',serif;
        font-style: italic;
        font-size: .9rem;
        font-weight: 700;
        color: #fff;
    }

    .tbl-count {
        margin-left: auto;
        font-size: .7rem;
        font-weight: 700;
        color: var(--G2);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        background: var(--D2);
        padding: .75rem 1rem;
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--G);
        text-align: left;
        border: none;
    }

    tbody td {
        padding: .75rem 1rem;
        font-size: .84rem;
        border-bottom: 1px solid #f5f0ea;
        vertical-align: middle;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover {
        background: #fdfcfa;
    }

    .tr-ck {
        background: #f0f7ff !important;
    }

        .tr-ck:hover {
            background: #e8f2ff !important;
        }

    /* Status / Pay badges */
    .sb {
        padding: .22rem .7rem;
        border-radius: 4px;
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: .25rem;
    }

        .sb.confirmed {
            background: #d1fae5;
            color: #065f46;
        }

        .sb.pending {
            background: #fef3c7;
            color: #92400e;
        }

        .sb.cancelled {
            background: #fee2e2;
            color: #991b1b;
        }

        .sb.playing {
            background: #dbeafe;
            color: #1e40af;
        }

        .sb.completed {
            background: #f0fdf4;
            color: #166534;
        }

        .sb.awaiting-ck {
            background: #eff6ff;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
            animation: pulse-badge 2.2s ease-in-out infinite;
        }

        .sb.paid {
            background: #d1fae5;
            color: #065f46;
        }

        .sb.unpaid {
            background: #fef3c7;
            color: #92400e;
        }

    .method-tag {
        font-size: .65rem;
        font-weight: 700;
        padding: .18rem .55rem;
        border-radius: 3px;
        background: var(--S);
        color: #4a3728;
    }

        .method-tag.transfer {
            background: #eff6ff;
            color: #1d4ed8;
        }

    /* Action buttons */
    .btn-tbl {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .36rem .8rem;
        border-radius: 5px;
        font-size: .72rem;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-tbl.det {
            background: var(--D);
            color: var(--G2);
        }

            .btn-tbl.det:hover {
                background: var(--G);
                color: var(--D);
            }

        .btn-tbl.ck {
            background: linear-gradient(135deg,#1d4ed8,#3b82f6);
            color: #fff;
        }

            .btn-tbl.ck:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(29,78,216,.3);
            }

    /* Empty */
    .empty {
        text-align: center;
        padding: 4rem 2rem;
    }

        .empty i {
            font-size: 3rem;
            color: var(--S);
            display: block;
            margin-bottom: 1rem;
        }

        .empty h5 {
            font-family: 'Playfair Display',serif;
            font-style: italic;
            font-size: 1.1rem;
            color: var(--D);
            margin-bottom: .4rem;
        }

        .empty p {
            font-size: .82rem;
            color: #8c7a68;
        }

    /* Pagination */
    .pagi {
        display: flex;
        justify-content: center;
        gap: .4rem;
        margin-top: 1.5rem;
    }

    .page-btn {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        border: 1.5px solid var(--S);
        background: #fff;
        font-size: .8rem;
        font-weight: 700;
        color: #4a3728;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

        .page-btn.on {
            background: var(--D);
            border-color: var(--D);
            color: var(--G2);
        }

        .page-btn:hover:not(.on) {
            border-color: var(--G);
            color: var(--G);
        }

    /* Alerts */
    .sys-alert {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #16a34a;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    @@media(max-width:900px) {
        .filter-g {
            grid-template-columns: 1fr 1fr;
        }

        .pg-hd-in {
            flex-direction: column;
            align-items: flex-start;
        }

        .tab-nav, .wrap, .pg-hd {
            padding-left: 1.2rem;
            padding-right: 1.2rem;
        }
    }

    @@media(max-width:600px) {
        .filter-g {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- Page Header -->
<div class="pg-hd">
    <div class="pg-hd-in">
        <div>
            <div class="pg-eyebrow"><i class="bi bi-shield-fill me-1"></i> Admin · Quản lý</div>
            <h1 class="pg-title">Danh sách đặt sân</h1>
            <div class="pg-sub">Quản lý toàn bộ đơn đặt sân — xác nhận, theo dõi &amp; hủy</div>
        </div>
    </div>
</div>

<!-- Tab Navigation -->
<div style="background:#fff;border-bottom:1px solid var(--S)">
    <div class="tab-nav">
        <a class="tab-item @(currentFilter == "" ? "active" : "")"
           href="@Url.Action("Index", "AdminBooking")">
            <i class="bi bi-list-ul"></i> Tất cả
            <span class="tab-badge gray">@ViewBag.TotalCount</span>
        </a>
        <a class="tab-item @(currentFilter == "Confirmed" ? "active" : "")"
           href="@Url.Action("Index", "AdminBooking", new { filter = "Confirmed" })">
            <i class="bi bi-check-circle"></i> Đã xác nhận
            <span class="tab-badge green">@ViewBag.ConfirmedCount</span>
        </a>
        <a class="tab-item @(currentFilter == "Playing" ? "active" : "")"
           href="@Url.Action("Index", "AdminBooking", new { filter = "Playing" })">
            <i class="bi bi-controller"></i> Đang chơi
        </a>
        <a class="tab-item @(currentFilter == "Completed" ? "active" : "")"
           href="@Url.Action("Index", "AdminBooking", new { filter = "Completed" })">
            <i class="bi bi-trophy"></i> Hoàn thành
        </a>
        <a class="tab-item @(currentFilter == "Cancelled" ? "active" : "")"
           href="@Url.Action("Index", "AdminBooking", new { filter = "Cancelled" })">
            <i class="bi bi-x-circle"></i> Đã hủy
        </a>
    </div>
</div>

<div class="wrap">

    @* Alerts *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i> @Html.Raw(TempData["SuccessMessage"])</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]</div>
    }
    <!-- Filter Form -->
    <div class="fc">
        <div class="fc-hd"><i class="bi bi-funnel"></i><span class="fc-title">Bộ lọc nâng cao</span></div>
        <div class="fc-bd">
            <form asp-action="Index" method="get">
                <input type="hidden" name="filter" value="@currentFilter" />
                <div class="filter-g">
                    <div>
                        <div class="fl">Tìm kiếm</div>
                        <input type="text" name="search" class="fi"
                               placeholder="Mã đơn, tên khách..."
                               value="@ViewBag.Search" />
                    </div>
            </form>
        </div>
    </div>

    <!-- Results Table -->
    <div class="tbl-card">
        <div class="tbl-hd">
            <i class="bi bi-table"></i>
            <span class="tbl-title">
                @(currentFilter != "" ? $"Lọc: {currentFilter}" : "Tất cả đơn đặt sân")
            </span>
            <span class="tbl-count">@Model.Count() đơn</span>
        </div>
        <div style="overflow-x:auto">
            @if (!Model.Any())
            {
                <div class="empty">
                    <i class="bi bi-inbox"></i>
                    <h5>Không có đơn nào</h5>
                    <p>Thử thay đổi bộ lọc hoặc chọn tab khác.</p>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Sân / Cơ sở</th>
                            <th>Ngày chơi</th>
                            <th>Khung giờ</th>
                            <th>Phương thức TT</th>
                            <th>Trạng thái</th>
                            <th>Tổng tiền</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            string stClass = b.Status.ToLower();
                            string stLabel = b.Status switch
                            {
                                                        "Pending" => "Chờ xác nhận",
                                                        "Confirmed" => "Đã xác nhận",
                                                        "Playing" => "Đang chơi",
                                                        "Completed" => "Hoàn thành",
                                                        "Cancelled" => "Đã hủy",
                                _ => b.Status
                            };

                            string payClass, payLabel;
                            if (b.PaymentStatus?.ToLower() == "paid")
                            { payClass = "paid"; payLabel = "Đã TT"; }
                            else if (b.PaymentMethod == "Transfer")
                            { payClass = "awaiting-ck"; payLabel = "Chờ CK"; }
                            else
                            { payClass = "unpaid"; payLabel = "Chưa TT"; }

                            <tr>
                                <td>
                                    <div style="font-weight:700;font-size:.82rem;color:var(--D)">@b.BookingCode</div>
                                    <div style="font-size:.7rem;color:#8c7a68">@b.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>
                                <td>
                                    <div style="font-weight:600;font-size:.84rem;">@(b.CustomerName ?? "—")</div>
                                    @if (!string.IsNullOrEmpty(b.Phone))
                                    {
                                        <div style="font-size:.72rem;color:#8c7a68;">@b.Phone</div>
                                    }
                                </td>
                                <td>
                                    <div style="font-weight:600;font-size:.84rem">@b.FacilityName</div>
                                    <div style="font-size:.72rem;color:#8c7a68">Sân @b.CourtNumber · @b.CourtType</div>
                                </td>
                                <td>
                                    <strong>@b.BookingDate.ToString("dd/MM/yyyy")</strong>
                                    <div style="font-size:.7rem;color:#8c7a68">
                                        @b.BookingDate.ToString("ddd", new System.Globalization.CultureInfo("vi-VN"))
                                    </div>
                                </td>
                                <td style="font-size:.82rem">
                                    @b.StartTime.ToString(@"hh\:mm") – @b.EndTime.ToString(@"hh\:mm")
                                </td>
                                <td>
                                    <span class="method-tag @(b.PaymentMethod == "Transfer" ? "transfer" : "")">
                                        @(b.PaymentMethod == "Transfer" ? "CK" : b.PaymentMethod == "Cash" ? "Tiền mặt" : b.PaymentMethod)
                                    </span>
                                    <br />
                                    <span class="sb @payClass" style="margin-top:.25rem;font-size:.58rem">@payLabel</span>
                                </td>
                                <td>
                                    <span class="sb @stClass">@stLabel</span>
                                </td>
                                <td style="font-weight:700;font-size:.9rem">
                                    @b.GrandTotal.ToString("N0")đ
                                </td>
                                <td>
                                    <div style="display:flex;gap:.4rem;flex-wrap:wrap">
                                        <a asp-controller="AdminBooking" asp-action="Details"
                                           asp-route-id="@b.BookingId" class="btn-tbl det">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* Pagination *@
    @{
        int curPage = ViewBag.Page ?? 1;
        int totalPage = ViewBag.TotalPage ?? 1;
    }
    @if (totalPage > 1)
    {
        <div class="pagi">
            @if (curPage > 1)
            {
                <a href="@Url.Action("Index", "AdminBooking", new { filter = currentFilter, page = curPage - 1 })"
                   class="page-btn"><i class="bi bi-chevron-left"></i></a>
            }
            @for (int i = Math.Max(1, curPage - 2); i <= Math.Min(totalPage, curPage + 2); i++)
            {
                if (i == curPage)
                {
                    <span class="page-btn on">@i</span>
                }
                else
                {
                    <a href="@Url.Action("Index", "AdminBooking", new { filter = currentFilter, page = i })"
                       class="page-btn">@i</a>
                }
            }
            @if (curPage < totalPage)
            {
                <a href="@Url.Action("Index", "AdminBooking", new { filter = currentFilter, page = curPage + 1 })"
                   class="page-btn"><i class="bi bi-chevron-right"></i></a>
            }
        </div>
    }

</div>
