@model IEnumerable<QuanLiSanCauLong.Models.PriceSlot>
@{
    ViewData["Title"] = "Quản Lý Khung Giờ & Giá";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@functions {
    string FormatDays(QuanLiSanCauLong.Models.PriceSlot slot)
    {
        var src = slot.AppliedDays;
        if (string.IsNullOrEmpty(src) && slot.DayOfWeek.HasValue)
            src = ((int)slot.DayOfWeek.Value).ToString();
        if (string.IsNullOrEmpty(src)) return "—";
        var map = new Dictionary<int, string> { { 1, "T2" }, { 2, "T3" }, { 3, "T4" }, { 4, "T5" }, { 5, "T6" }, { 6, "T7" }, { 0, "CN" } };
        var parts = src.Split(',')
            .Select(d => int.TryParse(d.Trim(), out var n) && map.ContainsKey(n) ? map[n] : "")
            .Where(s => s != "").ToList();
        if (parts.Count == 5 && new[] { 1, 2, 3, 4, 5 }.All(d => src.Contains(d.ToString()))) return "T2 – T6";
        if (parts.Count == 2 && src.Contains("6") && src.Contains("0")) return "T7 & CN";
        if (parts.Count == 7) return "Tất cả";
        return string.Join(", ", parts);
    }
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    body, * {
        font-family: 'Outfit',sans-serif;
    }

    /* HEADER */
    .idx-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .idx-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .idx-title em {
            font-style: italic;
            color: var(--gold);
        }

    .head-btns {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .btn-primary-g {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .72rem 1.4rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-primary-g:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
            color: var(--deep);
        }

    .btn-outline-g {
        background: #fff;
        color: var(--deep);
        border: 1.5px solid var(--border);
        padding: .7rem 1.3rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        transition: all .2s;
    }

        .btn-outline-g:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: var(--cream);
        }

    /* STAT STRIP */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .72rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    /* TOOLBAR */
    .toolbar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: flex-end;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .tb-group {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        flex: 1;
        min-width: 140px;
    }

    .tb-label {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .tb-sel, .tb-input {
        padding: .6rem .9rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
        transition: border-color .2s;
        width: 100%;
    }

        .tb-sel:focus, .tb-input:focus {
            border-color: var(--gold);
        }

    .tb-apply {
        background: var(--deep);
        color: var(--gold2);
        border: none;
        padding: .65rem 1.4rem;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

        .tb-apply:hover {
            background: #2e200e;
        }

    /* TABLE */
    .tbl-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .ps-table {
        width: 100%;
        border-collapse: collapse;
    }

        .ps-table th {
            background: var(--warm);
            padding: .85rem 1rem;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .ps-table td {
            padding: .9rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .86rem;
            vertical-align: middle;
            color: var(--deep);
        }

        .ps-table tr:last-child td {
            border-bottom: none;
        }

        .ps-table tr:hover td {
            background: var(--cream);
        }

    /* COURT CELL */
    .court-cell {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .court-badge {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display',serif;
        font-weight: 700;
        font-size: .85rem;
        color: var(--deep);
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        flex-shrink: 0;
    }

    .ct-name {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
        line-height: 1.2;
    }

    .ct-fac {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .12rem;
        display: flex;
        align-items: center;
        gap: .25rem;
    }

        .ct-fac i {
            color: var(--gold);
            font-size: .6rem;
        }

    /* TIME CELL */
    .time-cell {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .time-pill {
        background: rgba(26,18,9,.07);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: .2rem .65rem;
        font-weight: 700;
        font-size: .82rem;
        letter-spacing: .02em;
        color: var(--deep);
    }

    /* PRICE CELL */
    .price-main {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #16a34a;
    }

    .price-surcharge {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    /* CHIPS */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .68rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
    }

    .chip-active {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-inactive {
        background: rgba(138,117,96,.1);
        color: var(--muted);
    }

    .chip-peak {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-normal {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .chip-retail {
        background: rgba(6,182,212,.08);
        color: #0e7490;
    }

    .chip-member {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-all {
        background: rgba(138,117,96,.08);
        color: var(--muted);
    }

    .chip-days {
        background: rgba(212,160,23,.1);
        color: #92660a;
        border: 1px solid rgba(212,160,23,.2);
        border-radius: 20px;
        padding: .2rem .75rem;
    }

    /* ACTION BUTTONS */
    .act-g {
        display: flex;
        gap: .3rem;
        justify-content: flex-end;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        font-size: .78rem;
        text-decoration: none;
    }

        .act-b.edit:hover {
            border-color: #4f46e5;
            color: #4f46e5;
            background: rgba(79,70,229,.07);
        }

        .act-b.del:hover {
            border-color: #c94b2a;
            color: #c94b2a;
            background: rgba(201,75,42,.07);
        }

    /* ALERTS */
    .sys-alert {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #16a34a;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    /* EMPTY */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .3;
        }
</style>

<div>
    <!-- HEADER -->
    <div class="idx-head">
        <div>
            <h1 class="idx-title">Khung Giờ & <em>Bảng Giá</em></h1>
            <div style="font-size:.82rem;color:var(--muted);margin-top:.25rem;">
                Tổng cộng @(Model?.Count() ?? 0) cấu hình giá trong hệ thống
            </div>
        </div>
        <div class="head-btns">
            <a asp-action="BulkCreate" class="btn-outline-g">
                <i class="bi bi-lightning-charge-fill"></i> Tạo hàng loạt
            </a>
            <a asp-action="Create" class="btn-primary-g">
                <i class="bi bi-plus-circle"></i> Thêm Khung Giờ
            </a>
        </div>
    </div>

    <!-- ALERTS -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i>@TempData["ErrorMessage"]</div>
    }

    <!-- STATS -->
    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@(Model?.Count() ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold)"></span>Tổng Cấu Hình</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@(Model?.Count(s => s.IsActive) ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a"></span>Đang Kích Hoạt</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#c94b2a;">@(Model?.Count(s => s.IsPeakHour) ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#c94b2a"></span>Giờ Cao Điểm</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#4f46e5;">@(Model?.Count(s => !s.IsPeakHour) ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#4f46e5"></span>Giờ Thường</div>
        </div>
    </div>

    <!-- TOOLBAR / FILTER -->
    <form method="get">
        @Html.AntiForgeryToken()
        <div class="toolbar">
            <div class="tb-group">
                <span class="tb-label">Cơ sở</span>
                <select class="tb-sel" name="facilityId" id="FacilityFilter">
                    <option value="">Tất cả cơ sở</option>
                    @foreach (var f in ViewBag.Facilities)
                    {
                        <option value="@f.FacilityId"
                                selected="@(ViewBag.SelectedFacilityId?.ToString() == f.FacilityId.ToString())">
                            @f.FacilityName
                        </option>
                    }
                </select>
            </div>
            <div class="tb-group" style="min-width:150px;">
                <span class="tb-label">Sân cụ thể</span>
                <select class="tb-sel" name="courtId" id="CourtFilter">
                    <option value="">Tất cả sân</option>
                </select>
            </div>
            <div class="tb-group" style="min-width:140px;">
                <span class="tb-label">Loại giờ</span>
                <select class="tb-sel" name="peakHour">
                    <option value="">Tất cả</option>
                    <option value="true" selected="@(ViewBag.PeakFilter == "true")">Cao điểm</option>
                    <option value="false" selected="@(ViewBag.PeakFilter == "false")">Giờ thường</option>
                </select>
            </div>
            <div class="tb-group" style="min-width:140px;">
                <span class="tb-label">Loại khách</span>
                <select class="tb-sel" name="customerType">
                    <option value="">Tất cả</option>
                    <option value="Retail">Vãng lai</option>
                    <option value="Member">Cố định</option>
                    <option value="All">Mọi khách</option>
                </select>
            </div>
            <button type="submit" class="tb-apply">
                <i class="bi bi-funnel"></i> Lọc
            </button>
        </div>
    </form>

    <!-- TABLE -->
    <div class="tbl-wrap">
        <table class="ps-table">
            <thead>
                <tr>
                    <th>Sân</th>
                    <th>Tên Bảng Giá</th>
                    <th>Ngày Áp Dụng</th>
                    <th>Khung Giờ</th>
                    <th>Đơn Giá</th>
                    <th>Loại Khách</th>
                    <th>Trạng Thái</th>
                    <th style="text-align:right">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Any() == true)
                {
                    foreach (var slot in Model)
                    {
                        string custCls, custLabel;
                        switch (slot.CustomerType ?? "All")
                        {
                            case "Retail": custCls = "chip-retail"; custLabel = "Vãng lai"; break;
                            case "Member": custCls = "chip-member"; custLabel = "Cố định"; break;
                            default: custCls = "chip-all"; custLabel = "Tất cả"; break;
                        }

                        var abbr = slot.Court?.CourtNumber ?? "?";
                        abbr = abbr.Length > 0 ? abbr.Substring(abbr.Length - Math.Min(2, abbr.Length)) : "#";

                        <tr>
                            <td>
                                <div class="court-cell">
                                    <div class="court-badge">@abbr</div>
                                    <div>
                                        <div class="ct-name">@(slot.Court?.CourtNumber ?? "—")</div>
                                        <div class="ct-fac"><i class="bi bi-building-fill"></i>@(slot.Court?.Facility?.FacilityName ?? "—")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(slot.SlotName))
                                {
                                    <span style="font-weight:600;font-size:.88rem;color:var(--deep)">@slot.SlotName</span>
                                }
                                else
                                {
                                    <span style="color:var(--muted);font-style:italic;font-size:.82rem">—</span>
                                }
                            </td>
                            <td>
                                <span class="chip chip-days">@FormatDays(slot)</span>
                            </td>
                            <td>
                                <div class="time-cell">
                                    <span class="time-pill">@slot.StartTime.ToString(@"hh\:mm")</span>
                                    <span style="color:var(--muted);font-size:.72rem">→</span>
                                    <span class="time-pill">@slot.EndTime.ToString(@"hh\:mm")</span>
                                </div>
                                @if (slot.RoundingMinutes != 60)
                                {
                                    <div style="font-size:.68rem;color:var(--muted);margin-top:.25rem">
                                        <i class="bi bi-clock me-1"></i>Làm tròn @slot.RoundingMinutes phút
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="price-main">@slot.Price.ToString("N0")₫</div>
                                @if (slot.Surcharge > 0)
                                {
                                    <div class="price-surcharge">+ @slot.Surcharge.ToString("N0")₫ phụ phí</div>
                                }
                            </td>
                            <td>
                                <span class="chip @custCls">@custLabel</span>
                            </td>
                            <td>
                                @if (slot.IsPeakHour)
                                {
                                    <span class="chip chip-peak"><i class="bi bi-fire"></i> Cao điểm</span>
                                }
                                else
                                {
                                    <span class="chip chip-normal"><i class="bi bi-sun"></i> Thường</span>
                                }
                                @if (!slot.IsActive)
                                {
                                    <div style="margin-top:.3rem">
                                        <span class="chip chip-inactive">Tắt</span>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="act-g">
                                    <a asp-action="Edit" asp-route-id="@slot.PriceSlotId" class="act-b edit" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="act-b del" onclick="confirmDelete(@slot.PriceSlotId)" title="Xóa">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <i class="bi bi-currency-exchange"></i>
                                <div>Chưa có cấu hình giá nào</div>
                                <a asp-action="Create" style="color:var(--gold);margin-top:.75rem;display:inline-block;">+ Thêm ngay</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        // ── Load sân theo cơ sở (dùng endpoint AdminCourt/GetByFacility đã có sẵn) ──
        document.getElementById('FacilityFilter').addEventListener('change', function () {
            const fId = this.value;
            const sel = document.getElementById('CourtFilter');
            if (!fId) { sel.innerHTML = '<option value="">Tất cả sân</option>'; return; }
            sel.innerHTML = '<option value="">Đang tải...</option>';

            fetch(`/AdminCourt/GetByFacility?facilityId=${fId}`)
                .then(r => { if (!r.ok) throw new Error(r.status); return r.json(); })
                .then(data => {
                    const courts = data.courts ?? data; // hỗ trợ cả 2 format trả về
                    sel.innerHTML = '<option value="">Tất cả sân</option>';
                    if (!courts.length) { sel.innerHTML += '<option disabled>Cơ sở này chưa có sân</option>'; return; }
                    courts.forEach(c => {
                        const label = c.courtNumber ?? c.CourtNumber;
                        const type  = c.courtType  ?? c.CourtType;
                        sel.innerHTML += `<option value="${c.courtId ?? c.CourtId}">Sân ${label} (${type})</option>`;
                    });
                })
                .catch(() => { sel.innerHTML = '<option value="">Tất cả sân</option>'; });
        });

        // ── Xóa ──
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa khung giờ này?',
                text: 'Dữ liệu sẽ bị xóa vĩnh viễn!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c94b2a',
                cancelButtonColor:  '#8a7560',
                confirmButtonText:  'Xóa',
                cancelButtonText:   'Hủy',
                reverseButtons: true
            }).then(r => {
                if (!r.isConfirmed) return;
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                fetch(`/AdminPriceSlot/Delete/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: '__RequestVerificationToken=' + encodeURIComponent(token)
                })
                .then(r => r.json())
                .then(res => {
                    if (res.success) {
                        Swal.fire({ icon:'success', title:'Đã xóa!', timer:1200, showConfirmButton:false })
                            .then(() => location.reload());
                    } else {
                        Swal.fire('Lỗi!', res.message, 'error');
                    }
                })
                .catch(() => Swal.fire('Lỗi!', 'Không thể kết nối máy chủ', 'error'));
            });
        }
    </script>
}
