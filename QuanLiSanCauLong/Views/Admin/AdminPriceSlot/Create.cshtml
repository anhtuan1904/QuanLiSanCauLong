@model QuanLiSanCauLong.Models.PriceSlot
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-sub {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
        max-height: calc(85vh - 130px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .mbody::-webkit-scrollbar {
            width: 5px;
        }

        .mbody::-webkit-scrollbar-track {
            background: var(--warm);
            border-radius: 3px;
        }

        .mbody::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-req {
        color: #c94b2a;
        margin-left: .15rem;
    }

    .fg-input, .fg-select, .fg-textarea {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.08);
        }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .2rem;
    }
    /* Day selector */
    .day-btn-row {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        margin-bottom: .6rem;
    }

    .day-quick {
        padding: .3rem .7rem;
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        transition: all .2s;
    }

        .day-quick:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: var(--cream);
        }

    .day-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .5rem;
    }

    .day-item input {
        display: none;
    }

    .day-lbl {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: .5rem .3rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        background: #fff;
    }

        .day-lbl:hover {
            border-color: var(--gold);
            background: var(--cream);
        }

    .day-item input:checked + .day-lbl {
        background: var(--deep);
        color: var(--gold2);
        border-color: var(--deep);
    }

    .day-weekend .day-lbl {
        color: var(--red);
    }

    .day-item input:checked + .day-lbl {
        color: var(--gold2);
    }
    /* Price preview */
    .price-preview {
        background: linear-gradient(135deg,rgba(26,18,9,.04),rgba(212,160,23,.08));
        border: 1px solid rgba(212,160,23,.25);
        border-radius: 8px;
        padding: .8rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
    }

    .pp-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .pp-value {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--green);
        line-height: 1;
    }

    .pp-break {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .1rem;
    }
    /* Peak toggle */
    .peak-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .8rem 1rem;
        background: var(--cream);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

        .peak-toggle:hover {
            border-color: var(--gold);
        }

        .peak-toggle.active {
            background: rgba(201,75,42,.06);
            border-color: rgba(201,75,42,.3);
        }

    .peak-title {
        font-weight: 700;
        font-size: .84rem;
        color: var(--deep);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .peak-sub {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .toggle-sw {
        width: 40px;
        height: 22px;
        border-radius: 11px;
        background: var(--border);
        position: relative;
        transition: background .2s;
        flex-shrink: 0;
    }

        .toggle-sw::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #fff;
            top: 3px;
            left: 3px;
            transition: transform .2s;
        }

        .toggle-sw.on {
            background: var(--red);
        }

            .toggle-sw.on::after {
                transform: translateX(18px);
            }
    /* Price wrap */
    .price-wrap {
        position: relative;
    }

        .price-wrap .fg-input {
            padding-left: 1.8rem;
        }

    .price-sym {
        position: absolute;
        left: .7rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-weight: 700;
        font-size: .86rem;
    }
    /* Footer */
    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-save:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Khung Giờ & Giá</div>
        <div class="mh-title">Thêm Khung Giờ Mới</div>
        <div class="mh-sub">Thiết lập quy tắc giá và khung giờ cho sân</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng"><i class="bi bi-x-lg"></i></button>
</div>

<div class="mbody">
    <form id="createPSForm" asp-action="Create" asp-controller="AdminPriceSlot" method="post">
        @Html.AntiForgeryToken()

        <!-- 1. Đối tượng áp dụng -->
        <div class="sf-card">
            <div class="sf-card-head"><i class="bi bi-geo-alt sf-card-icon"></i><span class="sf-card-title">Đối Tượng Áp Dụng</span></div>
            <div class="sf-card-body">
                <div class="fg">
                    <label class="fg-label">Tên bảng giá <span style="font-weight:400;color:var(--muted)">(tuỳ chọn)</span></label>
                    <input asp-for="SlotName" class="fg-input" placeholder="Giá ngày thường, Giá cuối tuần..." />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                    <div class="fg">
                        <label class="fg-label">Cơ sở <span class="fg-req">*</span></label>
                        <select id="FacilitySelectC" asp-for="FacilityId" class="fg-select" required>
                            <option value="">— Chọn cơ sở —</option>
                            @if (ViewBag.Facilities != null)
                            {
                                foreach (var f in ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility>)
                                {
                                    <option value="@f.FacilityId">@f.FacilityName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Sân cụ thể <span class="fg-req">*</span></label>
                        <select asp-for="CourtId" id="CourtSelectC" class="fg-select" required>
                            <option value="">— Chọn cơ sở trước —</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                    <div class="fg">
                        <label class="fg-label">Loại sân</label>
                        <select asp-for="CourtType" class="fg-select">
                            <option value="Standard">Tiêu chuẩn</option>
                            <option value="Professional">Chuyên nghiệp</option>
                            <option value="Practice">Tập luyện</option>
                        </select>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Loại khách hàng</label>
                        <select asp-for="CustomerType" class="fg-select">
                            <option value="All">Tất cả</option>
                            <option value="Retail">Vãng lai</option>
                            <option value="Member">Cố định / Tháng</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Ngày áp dụng -->
        <div class="sf-card">
            <div class="sf-card-head"><i class="bi bi-calendar3 sf-card-icon"></i><span class="sf-card-title">Ngày Áp Dụng</span></div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="day-btn-row">
                    <button type="button" class="day-quick" onclick="selectDaysC([1,2,3,4,5])">T2–T6</button>
                    <button type="button" class="day-quick" onclick="selectDaysC([6,0])">T7 & CN</button>
                    <button type="button" class="day-quick" onclick="selectDaysC([0,1,2,3,4,5,6])">Tất cả</button>
                    <button type="button" class="day-quick" onclick="selectDaysC([])">Bỏ chọn</button>
                </div>
                <div class="day-grid">
                    @foreach (var (val, label, isWe) in new[] { (1, "Thứ Hai", false), (2, "Thứ Ba", false), (3, "Thứ Tư", false), (4, "Thứ Năm", false), (5, "Thứ Sáu", false), (6, "Thứ Bảy", true), (0, "Chủ Nhật", true) })
                    {
                        <div class="day-item @(isWe ? "day-weekend" : "")">
                            <input type="checkbox" class="day-check-c" id="dc@val" value="@val">
                            <label class="day-lbl" for="dc@val">@label</label>
                        </div>
                    }
                </div>
                <input type="hidden" name="AppliedDays" id="appliedDaysC" />
            </div>
        </div>

        <!-- 3. Khung giờ & Giá -->
        <div class="sf-card">
            <div class="sf-card-head"><i class="bi bi-clock sf-card-icon"></i><span class="sf-card-title">Khung Giờ & Đơn Giá</span></div>
            <div class="sf-card-body">
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;">
                    <div class="fg">
                        <label class="fg-label">Giờ bắt đầu <span class="fg-req">*</span></label>
                        <input asp-for="StartTime" class="fg-input" type="time" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Giờ kết thúc <span class="fg-req">*</span></label>
                        <input asp-for="EndTime" class="fg-input" type="time" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Làm tròn giờ</label>
                        <select asp-for="RoundingMinutes" class="fg-select">
                            <option value="15">15 phút</option>
                            <option value="30">30 phút</option>
                            <option value="60" selected>60 phút</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                    <div class="fg">
                        <label class="fg-label">Đơn giá (₫/giờ) <span class="fg-req">*</span></label>
                        <div class="price-wrap">
                            <span class="price-sym">₫</span>
                            <input asp-for="Price" class="fg-input" type="number" step="1000" id="priceInputC" placeholder="100000" oninput="calcTotalC()" />
                        </div>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Phụ phí (₫/giờ)</label>
                        <div class="price-wrap">
                            <span class="price-sym">₫</span>
                            <input asp-for="Surcharge" class="fg-input" type="number" step="1000" id="surInputC" placeholder="0" oninput="calcTotalC()" />
                        </div>
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Mô tả phụ phí <span style="font-weight:400;color:var(--muted)">(tuỳ chọn)</span></label>
                    <input asp-for="SurchargeNote" class="fg-input" placeholder="Phí bật đèn 30.000đ/giờ..." />
                </div>
                <div class="price-preview">
                    <div><div class="pp-label">Khách trả / giờ</div><div class="pp-value" id="totalPreviewC">0 ₫</div><div class="pp-break" id="priceBreakC"></div></div>
                    <i class="bi bi-calculator" style="font-size:1.5rem;color:rgba(212,160,23,.3)"></i>
                </div>
                <div class="peak-toggle" id="peakToggleC" onclick="togglePeakC()">
                    <div><div class="peak-title"><i class="bi bi-fire" style="color:var(--red)"></i> Giờ cao điểm</div><div class="peak-sub">Thường 17:00–22:00</div></div>
                    <div class="toggle-sw" id="peakSwC"></div>
                </div>
                <input asp-for="IsPeakHour" id="isPeakC" type="hidden" value="false" />

                <!-- Trạng thái -->
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.7rem .9rem;background:var(--cream);border:1px solid var(--border);border-radius:7px;">
                    <div><span style="font-weight:700;font-size:.84rem;color:var(--deep);">✓ Kích hoạt ngay</span><br><span style="font-size:.7rem;color:var(--muted);">Có hiệu lực ngay khi lưu</span></div>
                    <input asp-for="IsActive" type="checkbox" checked style="width:17px;height:17px;accent-color:var(--gold);cursor:pointer" />
                </div>
            </div>
        </div>
    </form>
</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="submit" form="createPSForm" class="btn-save" id="btnCreatePS" onclick="return prepareSubmitC()">
        <i class="bi bi-check-circle"></i> Lưu Cấu Hình Giá
    </button>
</div>

<script>
    (function(){
        // Load courts
        document.getElementById('FacilitySelectC').addEventListener('change', function(){
            const fId = this.value, sel = document.getElementById('CourtSelectC');
            if (!fId) { sel.innerHTML = '<option value="">— Chọn cơ sở trước —</option>'; return; }
            sel.innerHTML = '<option value="">Đang tải...</option>';
            fetch('/AdminCourt/GetByFacility?facilityId='+fId)
                .then(r=>r.json()).then(data=>{
                    const courts = data.courts ?? data;
                    sel.innerHTML = '<option value="">— Chọn sân —</option>';
                    courts.forEach(c=>{
                        sel.innerHTML += `<option value="${c.courtId??c.CourtId}">Sân ${c.courtNumber??c.CourtNumber} (${c.courtType??c.CourtType})</option>`;
                    });
                }).catch(()=>{ sel.innerHTML='<option value="">Lỗi tải sân</option>'; });
        });

        // Day selector
        window.selectDaysC = function(vals) {
            document.querySelectorAll('.day-check-c').forEach(cb=>{ cb.checked = vals.includes(parseInt(cb.value)); });
            syncDaysC();
        };
        function syncDaysC() {
            document.getElementById('appliedDaysC').value = Array.from(document.querySelectorAll('.day-check-c:checked')).map(c=>c.value).join(',');
        }
        document.querySelectorAll('.day-check-c').forEach(cb=>cb.addEventListener('change', syncDaysC));

        // Price calc
        window.calcTotalC = function() {
            const p = parseFloat(document.getElementById('priceInputC').value)||0;
            const s = parseFloat(document.getElementById('surInputC').value)||0;
            document.getElementById('totalPreviewC').textContent = (p+s).toLocaleString('vi-VN')+' ₫';
            document.getElementById('priceBreakC').textContent = s>0 ? `${p.toLocaleString('vi-VN')}₫ + ${s.toLocaleString('vi-VN')}₫ phụ phí` : '';
        };

        // Peak toggle
        let peakOnC = false;
        window.togglePeakC = function() {
            peakOnC = !peakOnC;
            document.getElementById('peakSwC').classList.toggle('on', peakOnC);
            document.getElementById('peakToggleC').classList.toggle('active', peakOnC);
            document.getElementById('isPeakC').value = peakOnC ? 'true' : 'false';
        };

        // Submit validation
        window.prepareSubmitC = function() {
            const checked = document.querySelectorAll('.day-check-c:checked');
            if (!checked.length) { alert('Vui lòng chọn ít nhất một ngày áp dụng!'); return false; }
            if (!document.getElementById('CourtSelectC').value) { alert('Vui lòng chọn sân!'); return false; }
            syncDaysC();
            return true;
        };
    })();
</script>
