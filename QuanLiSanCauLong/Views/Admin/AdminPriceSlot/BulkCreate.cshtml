@model QuanLiSanCauLong.Models.PriceSlot
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-sub {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
        max-height: calc(85vh - 130px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .mbody::-webkit-scrollbar {
            width: 5px;
        }

        .mbody::-webkit-scrollbar-track {
            background: var(--warm);
            border-radius: 3px;
        }

        .mbody::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-req {
        color: var(--red);
        margin-left: .15rem;
    }

    .fg-input, .fg-select {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.08);
        }

    .price-wrap {
        position: relative;
    }

        .price-wrap .fg-input {
            padding-left: 1.8rem;
        }

    .price-sym {
        position: absolute;
        left: .7rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-weight: 700;
        font-size: .86rem;
    }

    .court-list-wrap {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
    }

    .court-list-hd {
        background: var(--warm);
        padding: .6rem .9rem;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .court-scroll {
        max-height: 180px;
        overflow-y: auto;
        padding: .6rem .8rem;
    }

        .court-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .court-scroll::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 2px;
        }

    .court-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .4rem .5rem;
        border-radius: 6px;
        cursor: pointer;
        transition: background .15s;
    }

        .court-item:hover {
            background: var(--cream);
        }

        .court-item input {
            width: 15px;
            height: 15px;
            accent-color: var(--gold);
            cursor: pointer;
            flex-shrink: 0;
        }

    .ci-badge {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        flex-shrink: 0;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
        font-weight: 700;
        color: var(--deep);
    }

    .ci-name {
        font-weight: 600;
        font-size: .82rem;
        color: var(--deep);
    }

    .ci-type {
        font-size: .7rem;
        color: var(--muted);
    }

    .court-empty {
        text-align: center;
        padding: 1.2rem;
        color: var(--muted);
        font-size: .82rem;
    }

    .sel-btns {
        display: flex;
        gap: .4rem;
        padding: .5rem .8rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .sel-btn {
        padding: .3rem .7rem;
        border: 1.5px solid var(--border);
        border-radius: 5px;
        background: #fff;
        font-size: .72rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        transition: all .18s;
    }

        .sel-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: var(--cream);
        }

    .peak-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        margin-top: .25rem;
    }

        .peak-row input {
            width: 15px;
            height: 15px;
            accent-color: var(--red);
            cursor: pointer;
        }

    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-save:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

@Html.AntiForgeryToken()

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label"><i class="bi bi-lightning-charge-fill"></i> Tạo Hàng Loạt</div>
        <div class="mh-title">Thiết Lập Bảng Giá Nhanh</div>
        <div class="mh-sub">Chọn sân và nhập thông tin khung giờ để tạo nhanh</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng"><i class="bi bi-x-lg"></i></button>
</div>

<div class="mbody">

    <!-- 1. Chọn cơ sở & sân -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-building sf-card-icon"></i>
            <span class="sf-card-title">① Chọn Cơ Sở & Sân</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div class="fg">
                <label class="fg-label">Cơ sở <span class="fg-req">*</span></label>
                <select id="facSelB" class="fg-select" onchange="loadCourtsB(this.value)">
                    <option value="">— Chọn cơ sở —</option>
                    @foreach (var f in ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility>)
                    {
                        <option value="@f.FacilityId">@f.FacilityName</option>
                    }
                </select>
            </div>
            <div class="court-list-wrap">
                <div class="court-list-hd">
                    <span>Danh sách sân</span>
                    <span id="courtCountB" style="color:var(--deep);font-size:.76rem;font-weight:700">—</span>
                </div>
                <div class="court-scroll" id="courtListB">
                    <div class="court-empty">
                        <i class="bi bi-building" style="font-size:1.3rem;display:block;margin-bottom:.4rem;opacity:.3;"></i>
                        Chọn cơ sở để hiển thị sân
                    </div>
                </div>
                <div class="sel-btns">
                    <button type="button" class="sel-btn" onclick="toggleAllB(true)">Chọn tất cả</button>
                    <button type="button" class="sel-btn" onclick="toggleAllB(false)">Bỏ chọn</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Thông tin khung giờ -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-clock sf-card-icon"></i>
            <span class="sf-card-title">② Thông Tin Khung Giờ & Đơn Giá</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.65rem;">
                <div class="fg">
                    <label class="fg-label">Tên bảng giá</label>
                    <input type="text" class="fg-input" id="nNameB" placeholder="Giá thường..." />
                </div>
                <div class="fg">
                    <label class="fg-label">Loại khách</label>
                    <select class="fg-select" id="nCustB">
                        <option value="All">Tất cả</option>
                        <option value="Retail">Vãng lai</option>
                        <option value="Member">Cố định</option>
                    </select>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.65rem;">
                <div class="fg">
                    <label class="fg-label">Bắt đầu <span class="fg-req">*</span></label>
                    <input type="time" class="fg-input" id="nStartB" />
                </div>
                <div class="fg">
                    <label class="fg-label">Kết thúc <span class="fg-req">*</span></label>
                    <input type="time" class="fg-input" id="nEndB" />
                </div>
                <div class="fg">
                    <label class="fg-label">Đơn giá (₫) <span class="fg-req">*</span></label>
                    <div class="price-wrap">
                        <span class="price-sym">₫</span>
                        <input type="number" class="fg-input" id="nPriceB" step="1000" placeholder="100000" />
                    </div>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.65rem;">
                <div class="fg">
                    <label class="fg-label">Phụ phí (₫)</label>
                    <div class="price-wrap">
                        <span class="price-sym">₫</span>
                        <input type="number" class="fg-input" id="nSurB" step="1000" placeholder="0" />
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Mô tả phụ phí</label>
                    <input type="text" class="fg-input" id="nSurNoteB" placeholder="Phí bật đèn..." />
                </div>
            </div>

            <label class="peak-row">
                <input type="checkbox" id="nPeakB">
                <i class="bi bi-fire" style="color:var(--red)"></i> Cao điểm
            </label>

        </div>
    </div>

</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="button" class="btn-save" id="btnBulkSubmit" onclick="doSubmitB()">
        <i class="bi bi-cloud-upload-fill"></i> Xác nhận tạo
    </button>
</div>

<script>
    (function () {
        function getCsrf() { return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''; }

        window.loadCourtsB = function (fId) {
            const list = document.getElementById('courtListB');
            document.getElementById('courtCountB').textContent = '—';
            if (!fId) { list.innerHTML = '<div class="court-empty">Chọn cơ sở</div>'; return; }
            list.innerHTML = '<div class="court-empty"><span class="spinner-border spinner-border-sm"></span> Đang tải...</div>';
            fetch('/AdminCourt/GetByFacility?facilityId=' + fId)
                .then(r => r.json()).then(data => {
                    const courts = data.courts ?? data;
                    document.getElementById('courtCountB').textContent = courts.length + ' sân';
                    if (!courts.length) { list.innerHTML = '<div class="court-empty">Chưa có sân</div>'; return; }
                    list.innerHTML = courts.map(c => {
                        const num = c.courtNumber ?? c.CourtNumber;
                        const type = c.courtType ?? c.CourtType;
                        const id = c.courtId ?? c.CourtId;
                        return `<div class="court-item" onclick="this.querySelector('input').checked=!this.querySelector('input').checked">
                            <input type="checkbox" class="court-cb-b" value="${id}">
                            <div class="ci-badge">${num.slice(-2)}</div>
                            <div><div class="ci-name">Sân ${num}</div><div class="ci-type">${type === 'Indoor' ? '🏠 Trong nhà' : '☀️ Ngoài trời'}</div></div>
                        </div>`;
                    }).join('');
                }).catch(() => {
                    list.innerHTML = '<div class="court-empty" style="color:var(--red)">Lỗi tải sân</div>';
                });
        };

        window.toggleAllB = function (checked) {
            document.querySelectorAll('.court-cb-b').forEach(cb => cb.checked = checked);
        };

        window.doSubmitB = function () {
            const courtIds = Array.from(document.querySelectorAll('.court-cb-b:checked')).map(cb => cb.value);
            const start = document.getElementById('nStartB').value;
            const end = document.getElementById('nEndB').value;
            const price = document.getElementById('nPriceB').value;

            if (!courtIds.length) { alert('Vui lòng chọn ít nhất một sân!'); return; }
            if (!start || !end || !price) { alert('Vui lòng nhập đầy đủ giờ bắt đầu, kết thúc và đơn giá!'); return; }
            if (start >= end) { alert('Giờ bắt đầu phải nhỏ hơn giờ kết thúc!'); return; }

            const payload = {
                courtIds: courtIds,
                days: [],
                timeSlots: [{
                    startTimeStr: start,
                    endTimeStr: end,
                    price: parseFloat(price),
                    surcharge: parseFloat(document.getElementById('nSurB').value) || 0,
                    slotName: document.getElementById('nNameB').value.trim(),
                    custType: document.getElementById('nCustB').value,
                    surNote: document.getElementById('nSurNoteB').value.trim(),
                    isPeakHour: document.getElementById('nPeakB').checked
                }]
            };

            const btn = document.getElementById('btnBulkSubmit');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';

            fetch('/Admin/PriceSlot/BulkCreate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getCsrf() },
                body: JSON.stringify(payload)
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    alert(res.message || 'Tạo thành công!');
                    window.location.reload();
                } else {
                    alert('Lỗi: ' + (res.message || 'Không xác định'));
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-cloud-upload-fill"></i> Xác nhận tạo';
                }
            })
            .catch(err => {
                alert('Lỗi kết nối: ' + err.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-cloud-upload-fill"></i> Xác nhận tạo';
            });
        };
    })();
</script>
