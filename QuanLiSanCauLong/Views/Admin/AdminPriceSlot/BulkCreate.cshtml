@model QuanLiSanCauLong.Models.PriceSlot
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
        --peak: #fff3cd;
        --peak-b: #e6a817;
        --normal: #e8f5e9;
        --normal-b: #2e7d32;
        --member: #e3f2fd;
        --member-b: #1565c0;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-sub {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
        max-height: calc(90vh - 130px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .mbody::-webkit-scrollbar {
            width: 5px;
        }

        .mbody::-webkit-scrollbar-track {
            background: var(--warm);
            border-radius: 3px;
        }

        .mbody::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    /* STEP CARDS */
    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-req {
        color: var(--red);
        margin-left: .15rem;
    }

    .fg-input, .fg-select {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
    }

        .fg-input:focus, .fg-select:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.08);
        }

    .price-wrap {
        position: relative;
    }

        .price-wrap .fg-input {
            padding-left: 1.8rem;
        }

    .price-sym {
        position: absolute;
        left: .7rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-weight: 700;
        font-size: .86rem;
    }

    /* COURT LIST */
    .court-list-wrap {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
    }

    .court-list-hd {
        background: var(--warm);
        padding: .6rem .9rem;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .court-scroll {
        max-height: 160px;
        overflow-y: auto;
        padding: .6rem .8rem;
    }

        .court-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .court-scroll::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 2px;
        }

    .court-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .4rem .5rem;
        border-radius: 6px;
        cursor: pointer;
        transition: background .15s;
    }

        .court-item:hover {
            background: var(--cream);
        }

        .court-item input {
            width: 15px;
            height: 15px;
            accent-color: var(--gold);
            cursor: pointer;
            flex-shrink: 0;
        }

    .ci-badge {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        flex-shrink: 0;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
        font-weight: 700;
        color: var(--deep);
    }

    .ci-name {
        font-weight: 600;
        font-size: .82rem;
        color: var(--deep);
    }

    .ci-type {
        font-size: .7rem;
        color: var(--muted);
    }

    .court-empty {
        text-align: center;
        padding: 1.2rem;
        color: var(--muted);
        font-size: .82rem;
    }

    .sel-btns {
        display: flex;
        gap: .4rem;
        padding: .5rem .8rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .sel-btn {
        padding: .3rem .7rem;
        border: 1.5px solid var(--border);
        border-radius: 5px;
        background: #fff;
        font-size: .72rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        transition: all .18s;
    }

        .sel-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: var(--cream);
        }

    /* PRESET TEMPLATES */
    .preset-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .5rem;
    }

    .preset-btn {
        padding: .65rem .7rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        cursor: pointer;
        text-align: center;
        transition: all .18s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .2rem;
    }

        .preset-btn:hover {
            border-color: var(--gold);
            background: var(--cream);
        }

        .preset-btn.on {
            border-color: var(--gold);
            background: var(--cream);
            box-shadow: 0 2px 8px rgba(212,160,23,.2);
        }

    .pb-icon {
        font-size: 1.1rem;
    }

    .pb-name {
        font-size: .72rem;
        font-weight: 700;
        color: var(--deep);
    }

    .pb-desc {
        font-size: .62rem;
        color: var(--muted);
    }

    /* AUTO-GENERATE */
    .autogen-row {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .6rem;
        align-items: end;
    }

    .autogen-btn {
        padding: .6rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .8rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
        transition: all .2s;
        grid-column: span 1;
    }

        .autogen-btn:hover {
            box-shadow: 0 4px 12px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

    /* SLOT TABLE */
    .slot-table-wrap {
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        max-height: 320px;
        overflow-y: auto;
    }

        .slot-table-wrap::-webkit-scrollbar {
            width: 4px;
        }

        .slot-table-wrap::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 2px;
        }

    .slot-tbl {
        width: 100%;
        border-collapse: collapse;
        font-size: .8rem;
    }

        .slot-tbl thead tr {
            background: var(--warm);
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .slot-tbl th {
            padding: .55rem .7rem;
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .slot-tbl td {
            padding: .45rem .7rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .slot-tbl tbody tr:last-child td {
            border-bottom: none;
        }

        .slot-tbl tbody tr:hover {
            background: var(--cream);
        }

    .slot-row-peak td:first-child {
        border-left: 3px solid var(--peak-b);
    }

    .slot-row-normal td:first-child {
        border-left: 3px solid var(--normal-b);
    }

    .slot-row-member td:first-child {
        border-left: 3px solid var(--member-b);
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .15rem .5rem;
        border-radius: 4px;
        font-size: .62rem;
        font-weight: 700;
    }

    .badge-peak {
        background: var(--peak);
        color: var(--peak-b);
    }

    .badge-normal {
        background: var(--normal);
        color: var(--normal-b);
    }

    .badge-member {
        background: var(--member);
        color: var(--member-b);
    }

    .tbl-input {
        padding: .3rem .5rem;
        border: 1px solid var(--border);
        border-radius: 5px;
        font-size: .78rem;
        color: var(--deep);
        width: 100%;
        font-family: 'Outfit',sans-serif;
    }

        .tbl-input:focus {
            border-color: var(--gold);
            outline: none;
        }

    .del-btn {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .75rem;
        transition: all .15s;
    }

        .del-btn:hover {
            background: rgba(201,75,42,.08);
            border-color: var(--red);
            color: var(--red);
        }

    .add-row-btn {
        width: 100%;
        padding: .5rem;
        background: var(--warm);
        border: none;
        border-top: 1px solid var(--border);
        font-size: .78rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
    }

        .add-row-btn:hover {
            color: var(--gold);
            background: var(--cream);
        }

    /* PREVIEW */
    .preview-card {
        border: 1px solid var(--gold);
        border-radius: 8px;
        background: var(--cream);
        padding: .75rem 1rem;
        display: none;
    }

        .preview-card.show {
            display: block;
        }

    .preview-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .65rem;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .preview-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .preview-stats {
        display: flex;
        gap: .6rem;
    }

    .pstat {
        font-size: .72rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pstat span {
            color: var(--gold);
        }

    .preview-rows {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .prev-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .38rem .6rem;
        background: #fff;
        border-radius: 6px;
        border: 1px solid var(--border);
        font-size: .78rem;
    }

    .prev-time {
        font-weight: 700;
        color: var(--deep);
        min-width: 110px;
    }

    .prev-price {
        font-weight: 700;
        color: var(--gold);
        min-width: 90px;
    }

    .prev-courts {
        color: var(--muted);
        font-size: .72rem;
        flex: 1;
    }

    /* DAYS SELECTOR */
    .days-wrap {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .day-btn {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-size: .76rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .15s;
    }

        .day-btn.on {
            border-color: var(--gold);
            background: var(--cream);
            color: var(--deep);
        }

        .day-btn:hover {
            border-color: var(--gold);
        }

    .day-preset-btns {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        margin-top: .4rem;
    }

    .day-preset {
        padding: .28rem .7rem;
        border: 1px solid var(--border);
        border-radius: 5px;
        background: #fff;
        font-size: .7rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
    }

        .day-preset:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

    /* FOOTER */
    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-preview {
        padding: .6rem 1.2rem;
        border: 1.5px solid var(--gold);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-preview:hover {
            background: var(--cream);
        }

    .btn-save {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-save:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .peak-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
    }

        .peak-row input {
            width: 15px;
            height: 15px;
            accent-color: var(--red);
            cursor: pointer;
        }
</style>

@Html.AntiForgeryToken()

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label"><i class="bi bi-lightning-charge-fill"></i> Tạo Hàng Loạt</div>
        <div class="mh-title">Thiết Lập Bảng Giá Thông Minh</div>
        <div class="mh-sub">Tạo nhiều khung giờ cùng lúc — có template sẵn &amp; tự động phân chia</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng"><i class="bi bi-x-lg"></i></button>
</div>

<div class="mbody">

    <!-- ① CHỌN CƠ SỞ & SÂN -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-building sf-card-icon"></i>
            <span class="sf-card-title">① Chọn Cơ Sở &amp; Sân</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div class="fg">
                <label class="fg-label">Cơ sở <span class="fg-req">*</span></label>
                <select id="facSelB" class="fg-select" onchange="loadCourtsB(this.value)">
                    <option value="">— Chọn cơ sở —</option>
                    @foreach (var f in ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility>)
                    {
                        <option value="@f.FacilityId">@f.FacilityName</option>
                    }
                </select>
            </div>
            <div class="court-list-wrap">
                <div class="court-list-hd">
                    <span>Danh sách sân</span>
                    <span id="courtCountB" style="color:var(--deep);font-size:.76rem;font-weight:700">—</span>
                </div>
                <div class="court-scroll" id="courtListB">
                    <div class="court-empty"><i class="bi bi-building" style="font-size:1.3rem;display:block;margin-bottom:.4rem;opacity:.3;"></i>Chọn cơ sở để hiển thị sân</div>
                </div>
                <div class="sel-btns">
                    <button type="button" class="sel-btn" onclick="toggleAllB(true)"><i class="bi bi-check-all me-1"></i>Chọn tất cả</button>
                    <button type="button" class="sel-btn" onclick="toggleAllB(false)">Bỏ chọn</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ② TEMPLATE NHANH -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-stars sf-card-icon"></i>
            <span class="sf-card-title">② Template Nhanh (tùy chọn)</span>
            <span style="margin-left:auto;font-size:.7rem;color:var(--muted)">Chọn để điền sẵn — vẫn chỉnh được sau</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div class="preset-grid">
                <button type="button" class="preset-btn" onclick="applyPreset('standard',this)">
                    <span class="pb-icon"><i class="bi bi-clock"></i></span>
                    <span class="pb-name">Giờ Thường</span>
                    <span class="pb-desc">5:00–17:00 · 70k/h</span>
                </button>
                <button type="button" class="preset-btn" onclick="applyPreset('peak',this)">
                    <span class="pb-icon"><i class="bi bi-fire"></i></span>
                    <span class="pb-name">Giờ Cao Điểm</span>
                    <span class="pb-desc">17:00–23:00 · 120k/h</span>
                </button>
                <button type="button" class="preset-btn" onclick="applyPreset('fullday',this)">
                    <span class="pb-icon"><i class="bi bi-calendar-check"></i></span>
                    <span class="pb-name">Cả Ngày</span>
                    <span class="pb-desc">5:00–23:00 · phân chia tự động</span>
                </button>
                <button type="button" class="preset-btn" onclick="applyPreset('weekend',this)">
                    <span class="pb-icon"><i class="bi bi-sun"></i></span>
                    <span class="pb-name">Cuối Tuần</span>
                    <span class="pb-desc">T7 &amp; CN · 90k/h cả ngày</span>
                </button>
                <button type="button" class="preset-btn" onclick="applyPreset('member',this)">
                    <span class="pb-icon"><i class="bi bi-person-badge"></i></span>
                    <span class="pb-name">Khách Cố Định</span>
                    <span class="pb-desc">Cả ngày · giảm 20%</span>
                </button>
                <button type="button" class="preset-btn" onclick="applyPreset('clear',this)">
                    <span class="pb-icon"><i class="bi bi-trash3"></i></span>
                    <span class="pb-name">Xóa Tất Cả</span>
                    <span class="pb-desc">Reset về trống</span>
                </button>
            </div>
        </div>
    </div>

    <!-- ③ TỰ ĐỘNG PHÂN CHIA -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-magic sf-card-icon"></i>
            <span class="sf-card-title">③ Tự Động Phân Chia Khung Giờ</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div class="autogen-row">
                <div class="fg">
                    <label class="fg-label">Từ giờ</label>
                    <input type="time" class="fg-input" id="agStart" value="05:00" />
                </div>
                <div class="fg">
                    <label class="fg-label">Đến giờ</label>
                    <input type="time" class="fg-input" id="agEnd" value="23:00" />
                </div>
                <div class="fg">
                    <label class="fg-label">Bước (phút)</label>
                    <select class="fg-select" id="agStep">
                        <option value="30">30 phút</option>
                        <option value="60" selected>60 phút</option>
                        <option value="90">90 phút</option>
                        <option value="120">2 giờ</option>
                    </select>
                </div>
                <div class="fg">
                    <label class="fg-label">Đơn giá (₫)</label>
                    <div class="price-wrap">
                        <span class="price-sym">₫</span>
                        <input type="number" class="fg-input" id="agPrice" value="70000" step="5000" />
                    </div>
                </div>
            </div>
            <div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;">
                <button type="button" class="autogen-btn" onclick="doAutoGen()" style="grid-column:unset;flex-shrink:0;padding:.55rem 1.1rem;">
                    <i class="bi bi-magic"></i> Tạo khung giờ tự động
                </button>
                <span style="font-size:.72rem;color:var(--muted);flex:1">
                    <i class="bi bi-info-circle me-1"></i>
                    Sẽ <strong>thêm vào</strong> danh sách bên dưới (không xóa slot cũ)
                </span>
            </div>
        </div>
    </div>

    <!-- ④ DANH SÁCH KHUNG GIỜ -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-table sf-card-icon"></i>
            <span class="sf-card-title">④ Danh Sách Khung Giờ</span>
            <span style="margin-left:auto;font-size:.7rem;color:var(--muted)" id="slotCountLabel">0 khung</span>
        </div>
        <div style="padding:0;">
            <div class="slot-table-wrap">
                <table class="slot-tbl">
                    <thead>
                        <tr>
                            <th style="width:95px">Bắt đầu</th>
                            <th style="width:95px">Kết thúc</th>
                            <th style="width:110px">Đơn giá (₫)</th>
                            <th style="width:80px">Loại</th>
                            <th>Tên / ghi chú</th>
                            <th style="width:40px"></th>
                        </tr>
                    </thead>
                    <tbody id="slotTableBody">
                        <tr id="noSlotRow">
                            <td colspan="6" style="text-align:center;padding:1.5rem;color:var(--muted)">
                                <i class="bi bi-inbox" style="font-size:1.3rem;display:block;margin-bottom:.4rem;opacity:.3;"></i>
                                Chọn template hoặc dùng tính năng "Tự động" bên trên
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <button type="button" class="add-row-btn" onclick="addSlotRow()">
                <i class="bi bi-plus-circle"></i> Thêm thủ công
            </button>
        </div>
    </div>

    <!-- ⑤ NGÀY ÁP DỤNG -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-calendar-week sf-card-icon"></i>
            <span class="sf-card-title">⑤ Ngày Áp Dụng</span>
            <span style="margin-left:auto;font-size:.7rem;color:var(--muted)">Để trống = áp dụng tất cả ngày</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div class="days-wrap" id="daysWrap">
                <button type="button" class="day-btn" data-d="1">T2</button>
                <button type="button" class="day-btn" data-d="2">T3</button>
                <button type="button" class="day-btn" data-d="3">T4</button>
                <button type="button" class="day-btn" data-d="4">T5</button>
                <button type="button" class="day-btn" data-d="5">T6</button>
                <button type="button" class="day-btn" data-d="6">T7</button>
                <button type="button" class="day-btn" data-d="0">CN</button>
            </div>
            <div class="day-preset-btns">
                <button type="button" class="day-preset" onclick="setDays([1,2,3,4,5])">T2–T6</button>
                <button type="button" class="day-preset" onclick="setDays([6,0])">T7 &amp; CN</button>
                <button type="button" class="day-preset" onclick="setDays([1,2,3,4,5,6,0])">Tất cả</button>
                <button type="button" class="day-preset" onclick="setDays([])">Xóa chọn</button>
            </div>
        </div>
    </div>

    <!-- ⑥ PREVIEW -->
    <div class="preview-card" id="previewCard">
        <div class="preview-hd">
            <span class="preview-title"><i class="bi bi-eye me-1"></i>Xem trước kết quả</span>
            <div class="preview-stats">
                <span class="pstat">Sân: <span id="pvCourtCnt">0</span></span>
                <span class="pstat">Khung giờ: <span id="pvSlotCnt">0</span></span>
                <span class="pstat">Tổng tạo: <span id="pvTotalCnt">0</span></span>
            </div>
        </div>
        <div class="preview-rows" id="pvRows"></div>
    </div>

</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="button" class="btn-preview" onclick="showPreview()">
        <i class="bi bi-eye"></i> Xem trước
    </button>
    <button type="button" class="btn-save" id="btnBulkSubmit" onclick="doSubmitB()">
        <i class="bi bi-cloud-upload-fill"></i> Xác nhận tạo
    </button>
</div>

<script>
    (function () {
        /* ── UTILS ── */
        function getCsrf() { return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''; }
        function p2(n) { return String(n).padStart(2,'0'); }
        function minToHHMM(m) { return p2(Math.floor(m/60))+':'+p2(m%60); }
        function hhmmToMin(s) { const [h,m]=s.split(':').map(Number); return h*60+(m||0); }

        /* ── SLOT ROWS STATE ── */
        let slotRows = [];   // [{id, st, et, price, isPeak, custType, name}]
        let rowIdSeed = 0;

        function nextId() { return ++rowIdSeed; }

        /* ── COURTS ── */
        window.loadCourtsB = function(fId) {
            const list = document.getElementById('courtListB');
            document.getElementById('courtCountB').textContent = '—';
            if (!fId) { list.innerHTML = '<div class="court-empty">Chọn cơ sở</div>'; return; }
            list.innerHTML = '<div class="court-empty"><span class="spinner-border spinner-border-sm"></span> Đang tải...</div>';
            fetch('/AdminCourt/GetByFacility?facilityId='+fId)
                .then(r=>r.json()).then(data=>{
                    const courts = data.courts ?? data;
                    document.getElementById('courtCountB').textContent = courts.length+' sân';
                    if(!courts.length){ list.innerHTML='<div class="court-empty">Chưa có sân</div>'; return; }
                    list.innerHTML = courts.map(c=>{
                        const num = c.courtNumber ?? c.CourtNumber;
                        const type = c.courtType ?? c.CourtType;
                        const id = c.courtId ?? c.CourtId;
                        return `<div class="court-item" onclick="this.querySelector('input').checked=!this.querySelector('input').checked">
                            <input type="checkbox" class="court-cb-b" value="${id}" checked>
                            <div class="ci-badge">${num.slice(-2)}</div>
                            <div><div class="ci-name">Sân ${num}</div><div class="ci-type">${type==='Indoor'?'<i class="bi bi-house-fill"></i> Trong nhà':'<i class="bi bi-brightness-high"></i> Ngoài trời'}</div></div>
                        </div>`;
                    }).join('');
                }).catch(()=>{ list.innerHTML='<div class="court-empty" style="color:var(--red)">Lỗi tải sân</div>'; });
        };

        window.toggleAllB = function(checked) {
            document.querySelectorAll('.court-cb-b').forEach(cb=>cb.checked=checked);
        };

        /* ── DAYS ── */
        document.querySelectorAll('.day-btn').forEach(btn=>{
            btn.addEventListener('click',()=>btn.classList.toggle('on'));
        });

        window.setDays = function(days) {
            document.querySelectorAll('.day-btn').forEach(b=>{
                b.classList.toggle('on', days.includes(+b.dataset.d));
            });
        };

        function getSelectedDays() {
            return Array.from(document.querySelectorAll('.day-btn.on')).map(b=>+b.dataset.d);
        }

        /* ── PRESETS ── */
        const PRESETS = {
            standard: [
                {st:'05:00',et:'07:00',price:50000,isPeak:false,custType:'All',name:'Sáng sớm'},
                {st:'07:00',et:'11:00',price:70000,isPeak:false,custType:'All',name:'Buổi sáng'},
                {st:'11:00',et:'13:00',price:60000,isPeak:false,custType:'All',name:'Buổi trưa'},
                {st:'13:00',et:'17:00',price:70000,isPeak:false,custType:'All',name:'Buổi chiều'},
            ],
            peak: [
                {st:'17:00',et:'20:00',price:120000,isPeak:true, custType:'All',name:'Cao điểm chiều'},
                {st:'20:00',et:'23:00',price:110000,isPeak:true, custType:'All',name:'Cao điểm tối'},
            ],
            fullday: [
                {st:'05:00',et:'07:00',price:50000, isPeak:false,custType:'All',name:'Sáng sớm'},
                {st:'07:00',et:'11:00',price:70000, isPeak:false,custType:'All',name:'Buổi sáng'},
                {st:'11:00',et:'13:00',price:60000, isPeak:false,custType:'All',name:'Buổi trưa'},
                {st:'13:00',et:'17:00',price:70000, isPeak:false,custType:'All',name:'Buổi chiều'},
                {st:'17:00',et:'20:00',price:120000,isPeak:true, custType:'All',name:'Cao điểm chiều'},
                {st:'20:00',et:'23:00',price:110000,isPeak:true, custType:'All',name:'Cao điểm tối'},
            ],
            weekend: [
                {st:'05:00',et:'12:00',price:90000,isPeak:false,custType:'All',name:'Sáng cuối tuần'},
                {st:'12:00',et:'17:00',price:90000,isPeak:false,custType:'All',name:'Trưa-chiều cuối tuần'},
                {st:'17:00',et:'23:00',price:120000,isPeak:true, custType:'All',name:'Tối cuối tuần'},
            ],
            member: [
                {st:'05:00',et:'11:00',price:56000,isPeak:false,custType:'Member',name:'Cố định sáng'},
                {st:'11:00',et:'17:00',price:56000,isPeak:false,custType:'Member',name:'Cố định chiều'},
                {st:'17:00',et:'23:00',price:96000,isPeak:true, custType:'Member',name:'Cố định tối'},
            ],
        };

        window.applyPreset = function(key, btnEl) {
            document.querySelectorAll('.preset-btn').forEach(b=>b.classList.remove('on'));
            if(key==='clear'){ slotRows=[]; renderSlotTable(); return; }

            const preset = PRESETS[key];
            if(!preset) return;

            if(btnEl) btnEl.classList.add('on');

            // Apply days presets too
            if(key==='weekend') setDays([6,0]);
            else if(key==='member') setDays([1,2,3,4,5]);
            else if(key!=='peak') setDays([]);

            // Replace with preset
            slotRows = preset.map(s=>({id:nextId(), ...s}));
            renderSlotTable();
        };

        /* ── AUTO GENERATE ── */
        window.doAutoGen = function() {
            const stMin = hhmmToMin(document.getElementById('agStart').value||'05:00');
            const etMin = hhmmToMin(document.getElementById('agEnd').value||'23:00');
            const step  = parseInt(document.getElementById('agStep').value)||60;
            const price = parseFloat(document.getElementById('agPrice').value)||70000;

            if(stMin>=etMin){ alert('Giờ bắt đầu phải nhỏ hơn giờ kết thúc!'); return; }

            let added=0;
            for(let m=stMin; m<etMin; m+=step){
                const st=minToHHMM(m), et=minToHHMM(Math.min(m+step,etMin));
                // Check no duplicate
                const dup = slotRows.some(r=>r.st===st&&r.et===et);
                if(!dup){ slotRows.push({id:nextId(), st, et, price, isPeak:false, custType:'All', name:''}); added++; }
            }
            renderSlotTable();
            if(added===0) alert('Tất cả khung giờ đã tồn tại trong danh sách!');
        };

        /* ── RENDER TABLE ── */
        function renderSlotTable() {
            const tbody = document.getElementById('slotTableBody');
            document.getElementById('slotCountLabel').textContent = slotRows.length+' khung';

            if(!slotRows.length){
                tbody.innerHTML = `<tr id="noSlotRow">
                    <td colspan="6" style="text-align:center;padding:1.5rem;color:var(--muted)">
                        <i class="bi bi-inbox" style="font-size:1.3rem;display:block;margin-bottom:.4rem;opacity:.3;"></i>
                        Chọn template hoặc dùng tính năng "Tự động" bên trên
                    </td></tr>`;
                return;
            }

            // Sort by start time
            slotRows.sort((a,b)=>a.st.localeCompare(b.st));

            tbody.innerHTML = slotRows.map(row=>{
                const cls = row.isPeak ? 'slot-row-peak' : (row.custType==='Member' ? 'slot-row-member' : 'slot-row-normal');
                const badge = row.isPeak
                    ? '<span class="type-badge badge-peak"><i class="bi bi-fire"></i> Peak</span>'
                    : (row.custType==='Member'
                        ? '<span class="type-badge badge-member"><i class="bi bi-person-badge"></i> CĐ</span>'
                        : '<span class="type-badge badge-normal"><i class="bi bi-check-lg"></i> TH</span>');
                return `<tr class="${cls}" data-rid="${row.id}">
                    <td><input class="tbl-input" type="time" value="${row.st}" onchange="updateRow(${row.id},'st',this.value)" /></td>
                    <td><input class="tbl-input" type="time" value="${row.et}" onchange="updateRow(${row.id},'et',this.value)" /></td>
                    <td>
                        <div class="price-wrap">
                            <span class="price-sym" style="font-size:.72rem">₫</span>
                            <input class="tbl-input" type="number" value="${row.price}" step="5000" style="padding-left:1.5rem" onchange="updateRow(${row.id},'price',this.value)" />
                        </div>
                    </td>
                    <td>
                        <select class="tbl-input" style="font-size:.72rem;padding:.3rem .4rem" onchange="updateRow(${row.id},'custType',this.value)">
                            <option value="All" ${row.custType==='All'?'selected':''}>Tất cả</option>
                            <option value="Retail" ${row.custType==='Retail'?'selected':''}>Vãng lai</option>
                            <option value="Member" ${row.custType==='Member'?'selected':''}>Cố định</option>
                        </select>
                    </td>
                    <td>
                        <div style="display:flex;align-items:center;gap:.35rem">
                            ${badge}
                            <input class="tbl-input" type="text" value="${row.name||''}" placeholder="Tên slot..." style="flex:1" onchange="updateRow(${row.id},'name',this.value)" />
                            <label style="display:flex;align-items:center;gap:.2rem;cursor:pointer;flex-shrink:0;font-size:.7rem;color:var(--muted)" title="Cao điểm">
                                <input type="checkbox" style="width:12px;height:12px;accent-color:var(--red);cursor:pointer" ${row.isPeak?'checked':''} onchange="updateRow(${row.id},'isPeak',this.checked)" /><i class="bi bi-fire" style="color:var(--red)"></i>
                            </label>
                        </div>
                    </td>
                    <td><button class="del-btn" onclick="delRow(${row.id})" title="Xóa"><i class="bi bi-trash3"></i></button></td>
                </tr>`;
            }).join('');
        }

        window.updateRow = function(id, field, val) {
            const row = slotRows.find(r=>r.id===id);
            if(!row) return;
            if(field==='price') row[field]=parseFloat(val)||0;
            else if(field==='isPeak') row[field]=val===true||val==='true';
            else row[field]=val;
        };

        window.delRow = function(id) {
            slotRows = slotRows.filter(r=>r.id!==id);
            renderSlotTable();
        };

        window.addSlotRow = function() {
            // Find last end time or default 05:00
            const lastEnd = slotRows.length ? slotRows[slotRows.length-1].et : '05:00';
            const stMin = hhmmToMin(lastEnd);
            const etMin = Math.min(stMin+60, 23*60);
            slotRows.push({id:nextId(), st:minToHHMM(stMin), et:minToHHMM(etMin), price:70000, isPeak:false, custType:'All', name:''});
            renderSlotTable();
            // Scroll to bottom of table
            setTimeout(()=>{ const w=document.querySelector('.slot-table-wrap'); if(w) w.scrollTop=w.scrollHeight; },50);
        };

        /* ── PREVIEW ── */
        window.showPreview = function() {
            const courtIds = Array.from(document.querySelectorAll('.court-cb-b:checked')).map(cb=>parseInt(cb.value,10));
            const card = document.getElementById('previewCard');

            if(!courtIds.length||!slotRows.length){ card.classList.remove('show'); alert('Vui lòng chọn sân và ít nhất 1 khung giờ!'); return; }

            document.getElementById('pvCourtCnt').textContent = courtIds.length;
            document.getElementById('pvSlotCnt').textContent  = slotRows.length;
            document.getElementById('pvTotalCnt').textContent = courtIds.length * slotRows.length;

            const courtNames = {};
            document.querySelectorAll('.court-cb-b:checked').forEach(cb=>{
                const item = cb.closest('.court-item');
                const name = item?.querySelector('.ci-name')?.textContent||('Sân #'+cb.value);
                courtNames[cb.value]=name;
            });
            const courtLabel = courtIds.slice(0,3).map(id=>courtNames[id]||id).join(', ')+(courtIds.length>3?` +${courtIds.length-3}`:'' );

            const sorted = [...slotRows].sort((a,b)=>a.st.localeCompare(b.st));
            document.getElementById('pvRows').innerHTML = sorted.map(row=>{
                const badge = row.isPeak ? '<span class="type-badge badge-peak"><i class="bi bi-fire"></i> Peak</span>' : (row.custType==='Member'?'<span class="type-badge badge-member"><i class="bi bi-person-badge"></i></span>':'');
                return `<div class="prev-row">
                    <span class="prev-time"><i class="bi bi-clock me-1" style="color:var(--gold);font-size:.72rem"></i>${row.st}–${row.et}</span>
                    <span class="prev-price">${(row.price/1000).toFixed(0)}k/giờ</span>
                    ${badge}
                    <span class="prev-courts">${row.name||'—'} · ${courtLabel}</span>
                </div>`;
            }).join('');

            card.classList.add('show');
            card.scrollIntoView({behavior:'smooth',block:'nearest'});
        };

        /* ── SUBMIT ── */
        window.doSubmitB = function() {
            const courtIds = Array.from(document.querySelectorAll('.court-cb-b:checked')).map(cb=>parseInt(cb.value,10));
            if(!courtIds.length){ alert('Vui lòng chọn ít nhất một sân!'); return; }
            if(!slotRows.length){ alert('Vui lòng thêm ít nhất một khung giờ!'); return; }

            // Validate
            for(const r of slotRows){
                if(!r.st||!r.et){ alert('Có khung giờ chưa nhập đầy đủ giờ bắt đầu/kết thúc!'); return; }
                if(r.st>=r.et){ alert(`Khung ${r.st}–${r.et}: giờ bắt đầu phải nhỏ hơn giờ kết thúc!`); return; }
                if(!r.price||r.price<=0){ alert(`Khung ${r.st}–${r.et}: đơn giá phải lớn hơn 0!`); return; }
            }

            const days = getSelectedDays();
            const payload = {
                courtIds: courtIds,
                days: days,
                timeSlots: slotRows.map(r=>({
                    startTimeStr: r.st,
                    endTimeStr:   r.et,
                    startTime:    r.st,
                    endTime:      r.et,
                    price:        r.price,
                    surcharge:    0,
                    slotName:     r.name || '',
                    custType:     r.custType || 'All',
                    surNote:      '',
                    isPeakHour:   r.isPeak || false
                }))
            };

            const btn = document.getElementById('btnBulkSubmit');
            btn.disabled=true;
            btn.innerHTML='<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';

            console.log('BulkCreate payload:', JSON.stringify(payload));
            fetch('/Admin/PriceSlot/BulkCreate',{
                method:'POST',
                headers:{'Content-Type':'application/json','RequestVerificationToken':getCsrf()},
                body:JSON.stringify(payload)
            })
            .then(r=>r.json())
            .then(res=>{
                if(res.success){
                    // Success feedback
                    btn.innerHTML='<i class="bi bi-check-circle-fill"></i> Thành công!';
                    btn.style.background='linear-gradient(135deg,#16a34a,#22c55e)';
                    setTimeout(()=>{ window.location.reload(); }, 900);
                } else {
                    alert('Lỗi: '+(res.message||'Không xác định'));
                    btn.disabled=false;
                    btn.innerHTML='<i class="bi bi-cloud-upload-fill"></i> Xác nhận tạo';
                }
            })
            .catch(err=>{
                alert('Lỗi kết nối: '+err.message);
                btn.disabled=false;
                btn.innerHTML='<i class="bi bi-cloud-upload-fill"></i> Xác nhận tạo';
            });
        };

    })();
</script>
