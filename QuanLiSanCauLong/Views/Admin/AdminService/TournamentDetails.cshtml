@model QuanLiSanCauLong.Models.Tournament
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
    var pct = Model.MaxPlayers.HasValue && Model.MaxPlayers > 0
              ? Math.Min(100, (int)(Model.CurrentPlayers * 100.0 / Model.MaxPlayers.Value)) : 0;
    var pctColor = pct >= 90 ? "#c94b2a" : pct >= 70 ? "#d4a017" : "#16a34a";
    var isFull = Model.IsFull;
    var allImages = new List<string>();
    if (!string.IsNullOrEmpty(Model.FeaturedImage)) allImages.Add(Model.FeaturedImage);
    if (Model.TournamentImages != null)
        allImages.AddRange(Model.TournamentImages.OrderBy(i => i.DisplayOrder).Select(i => i.ImagePath));
    var sponsorList = new List<string>();
    if (!string.IsNullOrEmpty(Model.Sponsors))
    {
        try { sponsorList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Sponsors) ?? new(); } catch { }
    }
    var prizeLines = (Model.PrizeDescription ?? "").Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
    var statusColors = new Dictionary<string, string> { { "Upcoming", "#1d4ed8" }, { "Ongoing", "#16a34a" }, { "Finished", "#8a7560" }, { "Cancelled", "#c94b2a" } };
    var currentStatusColor = statusColors.ContainsKey(Model.Status) ? statusColors[Model.Status] : "#8a7560";
}
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
        --blue: #1d4ed8;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .td-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .td-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.25rem 1.75rem .9rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .td-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .3rem;
    }

        .td-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .td-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
        max-width: 560px;
    }

    .td-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .td-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .td-body {
        padding: 1.25rem 1.75rem 1.5rem;
        overflow-y: auto;
        flex: 1;
    }

    /* GALLERY */
    .gallery-slider {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
        background: var(--warm);
        border: 1px solid var(--border);
    }

    .gallery-main {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
        cursor: zoom-in;
        transition: opacity .3s;
    }

        .gallery-main.loading {
            opacity: .5;
        }

    .gallery-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,.85);
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--deep);
        font-size: .9rem;
        transition: all .2s;
    }

        .gallery-nav:hover {
            background: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,.15);
        }

        .gallery-nav.prev {
            left: 8px;
        }

        .gallery-nav.next {
            right: 8px;
        }

    .gallery-dots {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: .35rem;
    }

    .gallery-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: rgba(255,255,255,.55);
        cursor: pointer;
        transition: all .2s;
    }

        .gallery-dot.active {
            background: #fff;
            width: 20px;
            border-radius: 4px;
        }

    .gallery-counter {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,.5);
        color: #fff;
        font-size: .7rem;
        padding: .2rem .5rem;
        border-radius: 4px;
    }

    .gallery-thumbs {
        display: flex;
        gap: .4rem;
        overflow-x: auto;
        padding: .5rem 0;
        margin-bottom: 1rem;
        scrollbar-width: thin;
    }

        .gallery-thumbs::-webkit-scrollbar {
            height: 3px;
        }

        .gallery-thumbs::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 2px;
        }

    .thumb-item {
        flex-shrink: 0;
        width: 52px;
        height: 52px;
        border-radius: 6px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color .2s;
    }

        .thumb-item:hover {
            border-color: rgba(212,160,23,.5);
        }

        .thumb-item.active {
            border-color: var(--gold);
        }

        .thumb-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    /* INFO STRIP */
    .td-strip {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.1rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .cd-badges {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        margin-top: .5rem;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .badge-featured {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .td-prize-block {
        text-align: right;
        flex-shrink: 0;
    }

    .td-prize-label {
        font-size: .68rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .2rem;
    }

    .td-prize-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .td-prize-sub {
        font-size: .73rem;
        color: var(--muted);
    }

    /* DATE TIMELINE */
    .date-timeline {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .75rem;
        margin-bottom: 1.1rem;
    }

    .date-card {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: .85rem 1rem;
        text-align: center;
    }

        .date-card .dc-label {
            font-size: .65rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: .35rem;
        }

        .date-card .dc-val {
            font-size: .88rem;
            font-weight: 700;
            color: var(--deep);
        }

        .date-card .dc-time {
            font-size: .72rem;
            color: var(--muted);
            margin-top: .15rem;
        }

    /* VENUE CARD */
    .venue-card {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .venue-info .v-name {
        font-weight: 700;
        font-size: .92rem;
        color: var(--deep);
    }

    .venue-info .v-addr {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .btn-map {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem 1rem;
        background: var(--deep);
        border: none;
        border-radius: 7px;
        color: var(--gold);
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-map:hover {
            background: rgba(26,18,9,.85);
            color: var(--gold);
        }

    /* PROGRESS */
    .td-progress {
        margin-bottom: 1.1rem;
    }

    .td-progress-label {
        display: flex;
        justify-content: space-between;
        font-size: .72rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .td-progress-bg {
        height: 8px;
        background: var(--border);
        border-radius: 4px;
        overflow: hidden;
    }

    .td-progress-bar {
        height: 8px;
        border-radius: 4px;
        transition: width 1s;
    }

    /* PRIZE CARDS */
    .prize-podium {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .65rem;
        margin-bottom: 1.1rem;
    }

    .prize-card {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .9rem 1rem;
        text-align: center;
    }

        .prize-card.rank-1 {
            border-color: #ffd700;
            background: rgba(255,215,0,.07);
        }

        .prize-card.rank-2 {
            border-color: #c0c0c0;
            background: rgba(192,192,192,.07);
        }

        .prize-card.rank-3 {
            border-color: #cd7f32;
            background: rgba(205,127,50,.07);
        }

        .prize-card .p-medal {
            font-size: 1.75rem;
            margin-bottom: .4rem;
        }

        .prize-card .p-money {
            font-family: 'Playfair Display',serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--deep);
        }

        .prize-card .p-extra {
            font-size: .72rem;
            color: var(--muted);
            margin-top: .2rem;
        }

    /* SECTION */
    .td-section {
        margin-bottom: 1.1rem;
    }

    .td-section-label {
        font-size: .67rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-bottom: .6rem;
        padding-bottom: .4rem;
        border-bottom: 1px solid var(--border);
    }

    .td-text {
        font-size: .87rem;
        color: var(--deep);
        line-height: 1.65;
        white-space: pre-wrap;
    }

    .td-feature-list {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .td-feature-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        font-size: .85rem;
        color: var(--deep);
    }

        .td-feature-item i {
            color: var(--green);
            font-size: .9rem;
            flex-shrink: 0;
            margin-top: .1rem;
        }

    /* SPONSORS */
    .sponsor-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .sponsor-chip {
        background: rgba(29,78,216,.07);
        border: 1px solid rgba(29,78,216,.15);
        border-radius: 20px;
        padding: .3rem .75rem;
        font-size: .78rem;
        color: var(--deep);
    }

    /* VIDEO */
    .video-embed {
        margin-bottom: 1.1rem;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .video-embed iframe {
            width: 100%;
            height: 200px;
            display: block;
            border: none;
        }

    /* META */
    .td-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-top: .9rem;
        border-top: 1px solid var(--border);
    }

    .td-meta-item {
        font-size: .74rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .td-meta-item strong {
            color: var(--deep);
        }

        .td-meta-item i {
            color: var(--gold);
        }

    /* FOOTER */
    .td-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        flex-shrink: 0;
    }

    .btn-td-close {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-td-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-td-edit {
        padding: .65rem 1.6rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-td-edit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<div class="td-wrapper">
    <div class="td-header">
        <div>
            <div class="td-header-label"><i class="bi bi-trophy-fill"></i> Chi Tiết Giải Đấu</div>
            <div class="td-title">@Model.TournamentName</div>
        </div>
        <button type="button" class="td-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <div class="td-body">

        <!-- GALLERY -->
        @if (allImages.Any())
        {
            <div class="gallery-slider" id="sliderTD-@uid">
                <img class="gallery-main" id="mainImgTD-@uid" src="@allImages[0]" alt="@Model.TournamentName" />
                @if (allImages.Count > 1)
                {
                    <button class="gallery-nav prev" id="prevBtnTD-@uid"><i class="bi bi-chevron-left"></i></button>
                    <button class="gallery-nav next" id="nextBtnTD-@uid"><i class="bi bi-chevron-right"></i></button>
                    <div class="gallery-dots" id="dotsTD-@uid">
                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <div class="gallery-dot @(i == 0 ? "active" : "")" data-idx="@i"></div>
                        }
                    </div>
                    <div class="gallery-counter" id="counterTD-@uid">1 / @allImages.Count</div>
                }
            </div>
            @if (allImages.Count > 1)
            {
                <div class="gallery-thumbs" id="thumbsTD-@uid">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="thumb-item @(i == 0 ? "active" : "")" data-idx="@i"><img src="@allImages[i]" alt="" /></div>
                    }
                </div>
            }
        }
        else
        {
            <div style="background:var(--warm);border:1px solid var(--border);border-radius:12px;height:160px;display:flex;align-items:center;justify-content:center;color:var(--muted);margin-bottom:1rem;">
                <div style="text-align:center;"><i class="bi bi-trophy" style="font-size:3rem;opacity:.25;"></i><br /><span style="font-size:.8rem;">Chưa có banner</span></div>
            </div>
        }

        <!-- INFO STRIP -->
        <div class="td-strip">
            <div>
                <div style="font-weight:700;font-size:.96rem;color:var(--deep);">@Model.TournamentName</div>
                <div class="cd-badges">
                    <span class="badge-pill" style="background:rgba(0,0,0,.06);color:@currentStatusColor;">
                        ● @Model.StatusLabel
                    </span>
                    @if (!string.IsNullOrEmpty(Model.TournamentType))
                    {
                        var typeLabel = Model.TournamentType switch { "Singles" => "🏸 Đơn", "Doubles" => "👫 Đôi", "Mixed" => "🤝 Nam Nữ", "All" => "🏆 Đa Nội Dung", _ => Model.TournamentType };
                        <span class="badge-pill" style="background:rgba(79,70,229,.08);color:#4f46e5;">@typeLabel</span>
                    }
                    @if (Model.IsFeatured)
                    {
                        <span class="badge-pill badge-featured">⭐ Nổi bật</span>
                    }
                    @if (isFull)
                    {
                        <span class="badge-pill" style="background:rgba(201,75,42,.1);color:var(--red);">⊗ Đã đầy</span>
                    }
                </div>
            </div>
            @if (Model.PrizeMoney.HasValue)
            {
                <div class="td-prize-block">
                    <div class="td-prize-label">Tổng Giải Thưởng</div>
                    <div class="td-prize-val">@Model.PrizeMoney.Value.ToString("N0")đ</div>
                    @if (Model.EntryFee.HasValue)
                    {
                        <div class="td-prize-sub">Phí đăng ký: @Model.EntryFee.Value.ToString("N0")đ</div>
                    }
                </div>
            }
        </div>

        <!-- NGÀY THÁNG -->
        @if (Model.StartDate.HasValue || Model.RegistrationDeadline.HasValue)
        {
            <div class="date-timeline">
                @if (Model.RegistrationDeadline.HasValue)
                {
                    <div class="date-card">
                        <div class="dc-label">Hạn Đăng Ký</div>
                        <div class="dc-val">@Model.RegistrationDeadline.Value.ToString("dd/MM/yyyy")</div>
                        <div class="dc-time">@Model.RegistrationDeadline.Value.ToString("HH:mm")</div>
                    </div>
                }
                @if (Model.StartDate.HasValue)
                {
                    <div class="date-card">
                        <div class="dc-label">Bắt Đầu</div>
                        <div class="dc-val">@Model.StartDate.Value.ToString("dd/MM/yyyy")</div>
                        <div class="dc-time">@Model.StartDate.Value.ToString("HH:mm")</div>
                    </div>
                }
                @if (Model.EndDate.HasValue)
                {
                    <div class="date-card">
                        <div class="dc-label">Kết Thúc</div>
                        <div class="dc-val">@Model.EndDate.Value.ToString("dd/MM/yyyy")</div>
                        <div class="dc-time">@Model.EndDate.Value.ToString("HH:mm")</div>
                    </div>
                }
            </div>
        }

        <!-- ĐỊA ĐIỂM -->
        @if (!string.IsNullOrEmpty(Model.Venue))
        {
            <div class="venue-card">
                <div class="venue-info">
                    <div class="v-name"><i class="bi bi-geo-alt-fill me-1" style="color:var(--gold);"></i>@Model.Venue</div>
                    @if (!string.IsNullOrEmpty(Model.VenueAddress))
                    {
                        <div class="v-addr">@Model.VenueAddress</div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.MapUrl))
                {
                    <a href="@Model.MapUrl" target="_blank" class="btn-map">
                        <i class="bi bi-map"></i> Xem bản đồ
                    </a>
                }
            </div>
        }

        <!-- PROGRESS -->
        @if (Model.MaxPlayers.HasValue && Model.MaxPlayers > 0)
        {
            <div class="td-progress">
                <div class="td-progress-label">
                    <span><i class="bi bi-people me-1" style="color:var(--gold);"></i>VĐV đăng ký</span>
                    <span style="font-weight:700;color:var(--deep);">
                        @Model.CurrentPlayers / @Model.MaxPlayers
                        @if (isFull)
                        {
                            <span style="color:var(--red);"> — Đã đầy</span>
                        }
                        else
                        {

                            <span style="color:var(--muted);"> — Còn @Model.AvailableSlots suất</span>
                        }
                    </span>
                </div>
                <div class="td-progress-bg">
                    <div class="td-progress-bar" style="width:@pct%;background:@pctColor;"></div>
                </div>
            </div>
        }

        <!-- GIẢI THƯỞNG PODIUM -->
        @if (prizeLines.Any())
        {
            <div class="td-section">
                <div class="td-section-label"><i class="bi bi-trophy-fill"></i>Giải Thưởng</div>
                <div class="prize-podium">
                    @{
                        var medals = new[] { "🥇", "🥈", "🥉" };
                        var rankCls = new[] { "rank-1", "rank-2", "rank-3" };
                        for (int i = 0; i < Math.Min(3, prizeLines.Count); i++)
                        {
                            var line = prizeLines[i].Replace("🥇 ", "").Replace("🥈 ", "").Replace("🥉 ", "");
                            var parts = line.Split(" | ");
                            <div class="prize-card @rankCls[i]">
                                <div class="p-medal">@medals[i]</div>
                                <div class="p-money">@(parts.ElementAtOrDefault(0)?.Trim() ?? "—")</div>
                                @if (parts.Length > 1)
                                {
                                    <div class="p-extra">@parts[1].Trim()</div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <!-- VIDEO -->
        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            var ytM = System.Text.RegularExpressions.Regex.Match(Model.VideoUrl, @"(?:youtube\.com/watch\?v=|youtu\.be/)([^&?#]+)");
            if (ytM.Success)
            {
                <div class="td-section">
                    <div class="td-section-label"><i class="bi bi-play-circle-fill"></i>Video Highlight</div>
                    <div class="video-embed">
                        <iframe src="https://www.youtube.com/embed/@ytM.Groups[1].Value" allowfullscreen></iframe>
                    </div>
                </div>
            }
        }

        <!-- MÔ TẢ -->
        @if (!string.IsNullOrEmpty(Model.ShortDesc))
        {
            <div class="td-section">
                <div class="td-section-label"><i class="bi bi-chat-quote"></i>Mô Tả Ngắn</div>
                <div class="td-text" style="color:var(--muted);">@Model.ShortDesc</div>
            </div>
        }
        <div class="td-section">
            <div class="td-section-label"><i class="bi bi-file-text"></i>Mô Tả Chi Tiết</div>
            <div class="td-text">@Model.Description</div>
        </div>

        <!-- LỊCH TRÌNH -->
        @if (!string.IsNullOrEmpty(Model.Schedule))
        {
            <div class="td-section">
                <div class="td-section-label"><i class="bi bi-calendar-week"></i>Lịch Trình Thi Đấu</div>
                <div class="td-feature-list">
                    @foreach (var s in Model.Schedule.Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)))
                    {
                        <div class="td-feature-item"><i class="bi bi-arrow-right-circle-fill"></i><span>@s.Trim()</span></div>
                    }
                </div>
            </div>
        }

        <!-- THỂ LỆ -->
        @if (!string.IsNullOrEmpty(Model.Rules))
        {
            <div class="td-section">
                <div class="td-section-label"><i class="bi bi-clipboard-check"></i>Thể Lệ Thi Đấu</div>
                <div class="td-feature-list">
                    @foreach (var r in Model.Rules.Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)))
                    {
                        <div class="td-feature-item"><i class="bi bi-check-circle-fill"></i><span>@r.Trim().TrimStart('-').Trim()</span></div>
                    }
                </div>
            </div>
        }

        <!-- NHÀ TÀI TRỢ -->
        @if (sponsorList.Any())
        {
            <div class="td-section">
                <div class="td-section-label"><i class="bi bi-building"></i>Nhà Tài Trợ</div>
                <div class="sponsor-chips">
                    @foreach (var sp in sponsorList)
                    {
                        <span class="sponsor-chip">🏢 @sp</span>
                    }
                </div>
            </div>
        }

        <div class="td-meta">
            <div class="td-meta-item"><i class="bi bi-calendar-plus"></i>Tạo: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></div>
            <div class="td-meta-item"><i class="bi bi-pencil-square"></i>Cập nhật: <strong>@Model.UpdatedAt.ToString("dd/MM/yyyy")</strong></div>
            <div class="td-meta-item"><i class="bi bi-eye"></i>Lượt xem: <strong>@Model.ViewCount.ToString("N0")</strong></div>
            <div class="td-meta-item"><i class="bi bi-sort-numeric-down"></i>Thứ tự: <strong>#@Model.DisplayOrder</strong></div>
        </div>
    </div>

    <div class="td-footer">
        <button type="button" class="btn-td-close" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Đóng</button>
        <button type="button" class="btn-td-edit" onclick="openTournEditFromDetail(@Model.TournamentId)">
            <i class="bi bi-pencil"></i> Chỉnh Sửa
        </button>
    </div>
</div>

<script>
    (function(){
        var UID='@uid';
        var images=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(allImages));
        var current=0;
        function goTo(idx){
            if(images.length<=1)return;
            current=(idx+images.length)%images.length;
            var mi=document.getElementById('mainImgTD-'+UID);
            if(mi){mi.classList.add('loading');mi.src=images[current];mi.onload=function(){mi.classList.remove('loading');};}
            document.querySelectorAll('#dotsTD-'+UID+' .gallery-dot').forEach(function(d,i){d.classList.toggle('active',i===current);});
            var c=document.getElementById('counterTD-'+UID);if(c)c.textContent=(current+1)+' / '+images.length;
            document.querySelectorAll('#thumbsTD-'+UID+' .thumb-item').forEach(function(t,i){t.classList.toggle('active',i===current);});
        }
        var prev=document.getElementById('prevBtnTD-'+UID),next=document.getElementById('nextBtnTD-'+UID);
        if(prev)prev.addEventListener('click',function(){goTo(current-1);});
        if(next)next.addEventListener('click',function(){goTo(current+1);});
        document.querySelectorAll('#dotsTD-'+UID+' .gallery-dot').forEach(function(d){d.addEventListener('click',function(){goTo(parseInt(this.dataset.idx));});});
        document.querySelectorAll('#thumbsTD-'+UID+' .thumb-item').forEach(function(t){t.addEventListener('click',function(){goTo(parseInt(this.dataset.idx));});});
    })();
    function openTournEditFromDetail(id){
        var modal=bootstrap.Modal.getInstance(document.getElementById('modalService'));
        if(modal)modal.hide();
        setTimeout(function(){if(typeof openModal==='function')openModal('/AdminService/TournamentEdit/'+id);},300);
    }
</script>
