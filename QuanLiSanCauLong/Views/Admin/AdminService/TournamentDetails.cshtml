@model QuanLiSanCauLong.Models.Tournament
@{
    Layout = null;
    var pct = Model.MaxPlayers.HasValue && Model.MaxPlayers > 0
              ? Math.Min(100, (int)(Model.CurrentPlayers * 100.0 / Model.MaxPlayers.Value))
              : 0;
    var pctColor = pct >= 90 ? "#c94b2a" : pct >= 70 ? "#d4a017" : "#16a34a";
    var statusColor = Model.Status switch
    {
        "Ongoing" => "#0284c7",
        "Upcoming" => "#7c3aed",
        "Completed" => "#16a34a",
        "Cancelled" => "#dc2626",
        _ => "#8a7560"
    };
    var statusBg = Model.Status switch
    {
        "Ongoing" => "rgba(2,132,199,.1)",
        "Upcoming" => "rgba(124,58,237,.1)",
        "Completed" => "rgba(22,163,74,.1)",
        "Cancelled" => "rgba(220,38,38,.1)",
        _ => "var(--warm)"
    };
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .td-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 0;
    }

    .td-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .td-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .td-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.25;
        max-width: 520px;
    }

    .td-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .td-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .td-body {
        padding: 1.25rem 1.75rem 1.5rem;
        overflow-y: auto;
        max-height: calc(90vh - 80px);
    }

    .td-hero-img {
        width: 100%;
        height: 180px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
        margin-bottom: 1.25rem;
        background: var(--deep);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        .td-hero-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: .7;
        }

    .td-hero-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .5rem;
        color: rgba(255,255,255,.3);
    }

    .td-strip {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .td-prize-now {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    /* Progress */
    .td-progress-wrap {
        margin-bottom: 1.25rem;
    }

    .td-progress-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .72rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .td-progress-bar-bg {
        height: 8px;
        background: var(--border);
        border-radius: 4px;
        overflow: hidden;
    }

    .td-progress-bar {
        height: 8px;
        border-radius: 4px;
        transition: width 1s;
    }

    /* Grid */
    .td-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .td-grid-item {
        background: var(--warm);
        padding: 1rem 1.2rem;
        border-radius: 6px;
        border: 1px solid var(--border);
    }

    .td-grid-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: .4rem;
    }

    .td-grid-val {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
    }

    /* Prize breakdown */
    .td-prize-box {
        background: var(--deep);
        color: #fff;
        padding: 1.25rem 1.5rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
    }

    .td-prize-box-label {
        font-size: .68rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--gold2);
        margin-bottom: .6rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    /* Rules */
    .td-section {
        margin-bottom: 1.25rem;
    }

    .td-section-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .6rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .td-section-label i {
            color: var(--gold);
        }

    .td-text {
        font-size: .86rem;
        color: var(--deep);
        line-height: 1.75;
        white-space: pre-wrap;
    }

    .td-rules {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .td-rules li {
            display: flex;
            gap: .75rem;
            padding: .6rem 0;
            border-bottom: 1px solid var(--border);
            font-size: .88rem;
            color: var(--deep);
            font-weight: 300;
        }

            .td-rules li:last-child {
                border-bottom: none;
            }

    .td-rule-icon {
        color: var(--gold);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .td-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        margin-top: 1rem;
    }

    .td-meta-item {
        font-size: .75rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .td-meta-item strong {
            color: var(--deep);
        }

        .td-meta-item i {
            color: var(--gold);
        }

    .td-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .btn-td-close {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-td-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-td-edit {
        padding: .65rem 1.6rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-td-edit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="td-header">
    <div>
        <div class="td-header-label"><i class="bi bi-trophy"></i> Chi tiết giải đấu</div>
        <div class="td-title">@Model.TournamentName</div>
    </div>
    <button type="button" class="td-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="td-body">

    <!-- Hero image -->
    <div class="td-hero-img">
        @if (!string.IsNullOrEmpty(Model.FeaturedImage))
        {
            <img src="@Model.FeaturedImage" alt="@Model.TournamentName" />
        }
        else
        {
            <div class="td-hero-placeholder">
                <i class="bi bi-trophy-fill" style="font-size:4rem;"></i>
                <span style="font-size:.8rem;letter-spacing:.05em;">Chưa có ảnh</span>
            </div>
        }
    </div>

    <!-- Info strip -->
    <div class="td-strip">
        <div>
            <div style="font-weight:700;font-size:1rem;color:var(--deep);">@Model.TournamentName</div>
            @if (!string.IsNullOrEmpty(Model.TournamentType))
            {
                <div style="font-size:.82rem;color:var(--muted);margin-top:.2rem;">@Model.TournamentType</div>
            }
            <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.5rem;">
                <span class="badge-pill" style="background:@statusBg;color:@statusColor;">@Model.StatusLabel</span>
                @if (Model.IsFeatured)
                {
                    <span class="badge-pill" style="background:rgba(212,160,23,.12);color:#92660a;"><i class="bi bi-star-fill"></i> Nổi bật</span>
                }
                @if (Model.IsFull)
                {
                    <span class="badge-pill" style="background:rgba(201,75,42,.1);color:#c94b2a;">⊗ Đã đầy</span>
                }
            </div>
        </div>
        @if (Model.PrizeMoney.HasValue)
        {
            <div style="text-align:right;flex-shrink:0;">
                <div style="font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.3rem;">Tổng giải thưởng</div>
                <div class="td-prize-now">@Model.PrizeMoney.Value.ToString("N0")đ</div>
            </div>
        }
    </div>

    <!-- Progress VĐV -->
    @if (Model.MaxPlayers.HasValue && Model.MaxPlayers > 0)
    {
        <div class="td-progress-wrap">
            <div class="td-progress-label">
                <span><i class="bi bi-people me-1" style="color:var(--gold);"></i>Vận động viên đăng ký</span>
                <span style="font-weight:700;color:var(--deep);">@Model.CurrentPlayers / @Model.MaxPlayers người</span>
            </div>
            <div class="td-progress-bar-bg">
                <div class="td-progress-bar" style="width:@pct%;background:@pctColor;"></div>
            </div>
            @if (Model.IsFull)
            {
                <div style="font-size:.72rem;color:#c94b2a;margin-top:.3rem;"><i class="bi bi-lock-fill me-1"></i>Giải đấu đã đủ VĐV</div>
            }
            else
            {
                <div style="font-size:.72rem;color:var(--muted);margin-top:.3rem;">Còn <strong style="color:var(--deep);">@Model.AvailableSlots</strong> chỗ trống</div>
            }
        </div>
    }

    <!-- Grid thông tin -->
    <div class="td-grid">
        <div class="td-grid-item">
            <span class="td-grid-label"><i class="bi bi-calendar-event me-1"></i>Bắt Đầu</span>
            <span class="td-grid-val">@(Model.StartDate?.ToString("dd/MM/yyyy") ?? "—")</span>
        </div>
        <div class="td-grid-item">
            <span class="td-grid-label"><i class="bi bi-calendar-check me-1"></i>Kết Thúc</span>
            <span class="td-grid-val">@(Model.EndDate?.ToString("dd/MM/yyyy") ?? "—")</span>
        </div>
        <div class="td-grid-item">
            <span class="td-grid-label"><i class="bi bi-alarm me-1"></i>Hạn Đăng Ký</span>
            <span class="td-grid-val">@(Model.RegistrationDeadline?.ToString("dd/MM/yyyy") ?? "—")</span>
        </div>
        <div class="td-grid-item">
            <span class="td-grid-label"><i class="bi bi-geo-alt me-1"></i>Địa Điểm</span>
            <span class="td-grid-val" style="font-size:.84rem;">@(Model.Venue ?? "—")</span>
        </div>
        <div class="td-grid-item">
            <span class="td-grid-label"><i class="bi bi-ticket me-1"></i>Phí Đăng Ký</span>
            <span class="td-grid-val">@(Model.EntryFee?.ToString("N0") + "đ" ?? "—")</span>
        </div>
        <div class="td-grid-item">
            <span class="td-grid-label"><i class="bi bi-people me-1"></i>VĐV Tối Đa</span>
            <span class="td-grid-val">@(Model.MaxPlayers?.ToString() ?? "Không giới hạn")</span>
        </div>
    </div>

    <!-- Prize description -->
    @if (!string.IsNullOrEmpty(Model.PrizeDescription))
    {
        <div class="td-prize-box">
            <div class="td-prize-box-label"><i class="bi bi-trophy-fill"></i> Cơ Cấu Giải Thưởng</div>
            <div style="font-size:.88rem;line-height:1.8;white-space:pre-wrap;">@Model.PrizeDescription</div>
        </div>
    }

    <!-- Mô tả -->
    @if (!string.IsNullOrEmpty(Model.ShortDesc))
    {
        <div class="td-section">
            <div class="td-section-label"><i class="bi bi-chat-quote"></i> Mô tả ngắn</div>
            <div class="td-text" style="color:var(--muted);">@Model.ShortDesc</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="td-section">
            <div class="td-section-label"><i class="bi bi-file-text"></i> Mô tả chi tiết</div>
            <div class="td-text">@Model.Description</div>
        </div>
    }

    <!-- Thể lệ -->
    @if (!string.IsNullOrEmpty(Model.Rules))
    {
        <div class="td-section">
            <div class="td-section-label"><i class="bi bi-list-check"></i> Thể Lệ Thi Đấu</div>
            <ul class="td-rules">
                @foreach (var rule in Model.Rules.Split('\n').Where(r => !string.IsNullOrWhiteSpace(r)))
                {
                    <li>
                        <i class="bi bi-check-circle td-rule-icon"></i>
                        <span>@rule.Trim().TrimStart('-').Trim()</span>
                    </li>
                }
            </ul>
        </div>
    }

    <div class="td-meta">
        <div class="td-meta-item"><i class="bi bi-calendar-plus"></i> Tạo: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></div>
        <div class="td-meta-item"><i class="bi bi-eye"></i> Lượt xem: <strong>@Model.ViewCount.ToString("N0")</strong></div>
        <div class="td-meta-item"><i class="bi bi-sort-numeric-down"></i> Thứ tự: <strong>#@Model.DisplayOrder</strong></div>
    </div>
</div>

<!-- FOOTER -->
<div class="td-footer">
    <button type="button" class="btn-td-close" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Đóng
    </button>
    <button type="button" class="btn-td-edit" onclick="openTournamentEdit(@Model.TournamentId)">
        <i class="bi bi-pencil"></i> Chỉnh Sửa
    </button>
</div>

<script>
    function openTournamentEdit(id) {
        var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
        if (modal) modal.hide();
        setTimeout(function() {
            if (typeof openModal === 'function') openModal('/AdminService/TournamentEdit/' + id);
        }, 300);
    }
</script>
