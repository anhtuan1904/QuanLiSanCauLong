@model QuanLiSanCauLong.Models.Course
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .ce-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 0;
    }

    .ce-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .ce-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .ce-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
    }

        .ce-title em {
            font-style: italic;
            color: var(--gold);
        }

    .ce-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .ce-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .ce-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .ce-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        max-height: calc(90vh - 130px);
    }

    .ce-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .ce-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .ce-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .ce-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .ce-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 80px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* Level cards */
    .lv-card {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 1rem .75rem;
        text-align: center;
        cursor: pointer;
        transition: all .22s;
        user-select: none;
        background: #fff;
    }

        .lv-card:hover {
            border-color: rgba(212,160,23,.5);
            background: var(--cream);
        }

        .lv-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .lv-card-icon {
        font-size: 1.8rem;
        margin-bottom: .5rem;
    }

    .lv-card-name {
        font-size: .8rem;
        font-weight: 700;
        color: var(--deep);
    }

    .lv-card-sub {
        font-size: .68rem;
        color: var(--muted);
    }

    /* Status opts */
    .status-opts-ce {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt-ce {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
        user-select: none;
    }

        .status-opt-ce:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt-ce.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
            color: var(--deep);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* Toggles */
    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* Image upload */
    .img-upload-zone-ce {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--cream);
        cursor: pointer;
        transition: all .25s;
        min-height: 110px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: 1.25rem;
        position: relative;
    }

        .img-upload-zone-ce:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

        .img-upload-zone-ce.has-preview {
            border-color: var(--gold);
            padding: 0;
        }

    .img-preview-ce {
        width: 100%;
        height: 130px;
        object-fit: cover;
        display: none;
        border-radius: 8px;
    }

        .img-preview-ce.show {
            display: block;
        }

    .img-upload-icon {
        font-size: 1.8rem;
        color: var(--muted);
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }

        .img-url-row .fg-input {
            border-radius: 7px;
        }

    .ce-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .btn-ce-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-ce-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-ce-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-ce-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }

        .btn-ce-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="ce-header">
    <div>
        <div class="ce-header-label"><i class="bi bi-pencil-square"></i> Chỉnh sửa khóa học</div>
        <div class="ce-title">Cập Nhật <em>Khóa Học</em></div>
        <div class="ce-subtitle">Đang chỉnh sửa: <strong>@Model.CourseName</strong></div>
    </div>
    <button type="button" class="ce-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="ce-body">
    <form id="frmCourseEdit-@uid" method="post" enctype="multipart/form-data"
          action="/AdminService/CourseEdit">
        @Html.AntiForgeryToken()
        <input type="hidden" name="CourseId" value="@Model.CourseId" />
        <input type="hidden" name="CreatedAt" value="@Model.CreatedAt.ToString("o")" />
        <input type="hidden" name="ViewCount" value="@Model.ViewCount" />
        <input type="hidden" name="Slug" value="@Model.Slug" />
        <input type="hidden" name="CurrentStudents" value="@Model.CurrentStudents" />
        <input type="hidden" id="levelInputCE-@uid" name="Level" value="@Model.Level" />
        <input type="hidden" id="statusInputCE-@uid" name="Status" value="@Model.Status" />

        <!-- 1. THÔNG TIN CƠ BẢN -->
        <div class="ce-card">
            <div class="ce-card-head"><i class="bi bi-mortarboard"></i><span class="ce-card-title">Thông Tin Khóa Học</span></div>
            <div class="ce-card-body">
                <div class="fg">
                    <label class="fg-label">Tên Khóa Học <span class="req">*</span></label>
                    <input name="CourseName" value="@Model.CourseName" class="fg-input" required />
                </div>
                <div class="fg-row2 fg">
                    <div>
                        <label class="fg-label">Huấn Luyện Viên</label>
                        <input name="Instructor" value="@Model.Instructor" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Lịch Học</label>
                        <input name="Schedule" value="@Model.Schedule" class="fg-input" placeholder="VD: Thứ 2,4,6 - 18h" />
                    </div>
                </div>
                <div class="fg-row3 fg" style="margin-bottom:0;">
                    <div>
                        <label class="fg-label">Thời Lượng (tuần)</label>
                        <input name="DurationWeeks" type="number" value="@Model.DurationWeeks" class="fg-input" min="1" />
                    </div>
                    <div>
                        <label class="fg-label">Sĩ Số Tối Đa</label>
                        <input name="MaxStudents" type="number" value="@Model.MaxStudents" class="fg-input" min="1" />
                    </div>
                    <div>
                        <label class="fg-label">Thứ Tự Hiển Thị</label>
                        <input name="DisplayOrder" type="number" value="@Model.DisplayOrder" class="fg-input" />
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. TRÌNH ĐỘ -->
        <div class="ce-card">
            <div class="ce-card-head"><i class="bi bi-bar-chart-steps"></i><span class="ce-card-title">Trình Độ Học Viên</span></div>
            <div class="ce-card-body">
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;" id="levelCardsCE-@uid">
                    <div class="lv-card @(Model.Level == "Beginner" ? "selected" : "")" data-level="Beginner">
                        <div class="lv-card-icon">🌱</div>
                        <div class="lv-card-name">Cơ Bản</div>
                        <div class="lv-card-sub">Beginner</div>
                    </div>
                    <div class="lv-card @(Model.Level == "Intermediate" ? "selected" : "")" data-level="Intermediate">
                        <div class="lv-card-icon">⚡</div>
                        <div class="lv-card-name">Trung Cấp</div>
                        <div class="lv-card-sub">Intermediate</div>
                    </div>
                    <div class="lv-card @(Model.Level == "Advanced" ? "selected" : "")" data-level="Advanced">
                        <div class="lv-card-icon">🏆</div>
                        <div class="lv-card-name">Nâng Cao</div>
                        <div class="lv-card-sub">Advanced</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. MÔ TẢ -->
        <div class="ce-card">
            <div class="ce-card-head"><i class="bi bi-file-text"></i><span class="ce-card-title">Mô Tả & Nội Dung</span></div>
            <div class="ce-card-body">
                <div class="fg">
                    <label class="fg-label">Mô Tả Ngắn</label>
                    <textarea name="ShortDesc" class="fg-textarea" rows="2">@Model.ShortDesc</textarea>
                </div>
                <div class="fg">
                    <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                    <textarea name="Description" class="fg-textarea" rows="4" required>@Model.Description</textarea>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Nội Dung / Tính Năng</label>
                    <textarea name="Features" class="fg-textarea" rows="3" placeholder="- Tính năng 1&#10;- Tính năng 2">@Model.Features</textarea>
                </div>
            </div>
        </div>

        <!-- 4. HỌC PHÍ -->
        <div class="ce-card">
            <div class="ce-card-head"><i class="bi bi-currency-exchange"></i><span class="ce-card-title">Học Phí</span></div>
            <div class="ce-card-body">
                <div class="fg-row2" style="margin-bottom:0;">
                    <div>
                        <label class="fg-label">Học Phí Gốc (VNĐ)</label>
                        <input name="TuitionFee" type="number" value="@Model.TuitionFee" class="fg-input" step="1000" min="0" />
                    </div>
                    <div>
                        <label class="fg-label">Học Phí Ưu Đãi (VNĐ)</label>
                        <input name="DiscountFee" type="number" value="@Model.DiscountFee" class="fg-input" step="1000" min="0" />
                    </div>
                </div>
            </div>
        </div>

        <!-- 5. HÌNH ẢNH -->
        <div class="ce-card">
            <div class="ce-card-head"><i class="bi bi-image"></i><span class="ce-card-title">Hình Ảnh Đại Diện</span></div>
            <div class="ce-card-body">
                <div class="img-upload-zone-ce" id="ceUploadZone-@uid">
                    <img class="img-preview-ce @(!string.IsNullOrEmpty(Model.FeaturedImage) ? "show" : "")"
                         id="ceImgPreview-@uid"
                         src="@(Model.FeaturedImage ?? "")" alt="Preview" />
                    <div id="cePlaceholder-@uid" style="@(!string.IsNullOrEmpty(Model.FeaturedImage) ? "display:none;" : "")display:flex;flex-direction:column;align-items:center;gap:.5rem;">
                        <i class="bi bi-cloud-arrow-up img-upload-icon"></i>
                        <span style="font-size:.84rem;font-weight:600;">Click để tải ảnh lên</span>
                        <span style="font-size:.74rem;color:var(--muted);">hoặc kéo thả</span>
                    </div>
                    <input type="file" id="ceImgInput-@uid" name="featuredImage" accept="image/*" style="display:none" />
                </div>
                <div class="img-url-row">
                    <input type="text" id="ceImgUrl-@uid" name="FeaturedImage"
                           value="@Model.FeaturedImage"
                           class="fg-input" placeholder="Hoặc nhập URL ảnh: https://..." />
                    <button type="button" id="ceBtnUrl-@uid"
                            style="padding:.65rem 1.2rem;border:none;border-radius:7px;background:var(--gold);color:var(--deep);font-weight:700;cursor:pointer;white-space:nowrap;font-family:'Outfit',sans-serif;">
                        ✓ Áp dụng
                    </button>
                </div>
                <div class="fg-hint"><i class="bi bi-info-circle me-1"></i>Upload file hoặc nhập URL rồi nhấn Áp dụng</div>
            </div>
        </div>

        <!-- 6. TRẠNG THÁI -->
        <div class="ce-card">
            <div class="ce-card-head"><i class="bi bi-toggles"></i><span class="ce-card-title">Trạng Thái & Cài Đặt</span></div>
            <div class="ce-card-body">
                <div class="fg">
                    <label class="fg-label">Trạng Thái</label>
                    <div class="status-opts-ce" id="ceStatusOpts-@uid">
                        <div class="status-opt-ce @(Model.Status == "Active" ? "selected" : "")" data-status="Active">
                            <span class="status-dot" style="background:#16a34a;"></span> Hoạt Động
                        </div>
                        <div class="status-opt-ce @(Model.Status == "Inactive" ? "selected" : "")" data-status="Inactive">
                            <span class="status-dot" style="background:#c94b2a;"></span> Ngừng Hoạt Động
                        </div>
                        <div class="status-opt-ce @(Model.Status == "Full" ? "selected" : "")" data-status="Full">
                            <span class="status-dot" style="background:#7c3aed;"></span> Đã Đầy
                        </div>
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Cài Đặt Hiển Thị</label>
                    <div class="toggle-row">
                        <label class="toggle-item">
                            <input type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") />
                            <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

<!-- FOOTER -->
<div class="ce-footer">
    <button type="button" class="btn-ce-cancel" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Hủy
    </button>
    <button type="button" class="btn-ce-save" id="btnCourseEditSave-@uid">
        <i class="bi bi-check-circle"></i> Lưu Thay Đổi
    </button>
</div>

<script>
    (function() {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // Level cards
        var levelCards = el('levelCardsCE');
        if (levelCards) {
            levelCards.querySelectorAll('.lv-card').forEach(function(card) {
                card.addEventListener('click', function() {
                    levelCards.querySelectorAll('.lv-card').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('levelInputCE').value = this.dataset.level;
                });
            });
        }

        // Status opts
        var statusOpts = el('ceStatusOpts');
        if (statusOpts) {
            statusOpts.querySelectorAll('.status-opt-ce').forEach(function(opt) {
                opt.addEventListener('click', function() {
                    statusOpts.querySelectorAll('.status-opt-ce').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputCE').value = this.dataset.status;
                });
            });
        }

        // Image upload
        var zone = el('ceUploadZone');
        var input = el('ceImgInput');
        var preview = el('ceImgPreview');
        var placeholder = el('cePlaceholder');
        var urlInput = el('ceImgUrl');
        var btnUrl = el('ceBtnUrl');

        function showPreview(src) {
            preview.src = src;
            preview.classList.add('show');
            placeholder.style.display = 'none';
            zone.classList.add('has-preview');
        }
        function resetPreview() {
            preview.src = '';
            preview.classList.remove('show');
            placeholder.style.display = 'flex';
            zone.classList.remove('has-preview');
            input.value = '';
            urlInput.value = '';
        }

        zone.addEventListener('click', function(e) {
            if (!preview.classList.contains('show')) input.click();
            else resetPreview();
        });

        input.addEventListener('change', function() {
            if (!this.files[0]) return;
            var reader = new FileReader();
            reader.onload = function(ev) {
                showPreview(ev.target.result);
                urlInput.value = ''; // clear URL when file chosen
            };
            reader.readAsDataURL(this.files[0]);
        });

        btnUrl.addEventListener('click', function() {
            var url = urlInput.value.trim();
            if (url) {
                showPreview(url);
                input.value = ''; // clear file when URL chosen
            }
        });

        // Submit
        var btnSave = el('btnCourseEditSave');
        var form = document.getElementById('frmCourseEdit-' + UID);
        btnSave.addEventListener('click', function() {
            if (!form.checkValidity()) { form.reportValidity(); return; }
            var level = el('levelInputCE').value;
            if (!level) {
                alert('Vui lòng chọn trình độ học viên'); return;
            }
            btnSave.disabled = true;
            btnSave.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
            var fd = new FormData(form);
            fetch('/AdminService/CourseEdit', { method:'POST', body:fd })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('modalService'))?.hide();
                        location.reload();
                    } else {
                        alert(res.message || 'Có lỗi xảy ra');
                        btnSave.disabled = false;
                        btnSave.innerHTML = '<i class="bi bi-check-circle"></i> Lưu Thay Đổi';
                    }
                })
                .catch(function() {
                    alert('Lỗi kết nối server');
                    btnSave.disabled = false;
                    btnSave.innerHTML = '<i class="bi bi-check-circle"></i> Lưu Thay Đổi';
                });
        });
    })();
</script>
