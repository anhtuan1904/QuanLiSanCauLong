@model QuanLiSanCauLong.Models.Course
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .ce-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .ce-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .ce-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .ce-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .ce-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
    }

        .ce-title em {
            font-style: italic;
            color: var(--gold);
        }

    .ce-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .ce-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .ce-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .ce-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .ce-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .ce-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .ce-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .ce-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .ce-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: var(--red);
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* LEVEL CARDS */
    .level-cards {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .65rem;
    }

    .lv-card {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .8rem 1rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
        user-select: none;
    }

        .lv-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .lv-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

        .lv-card .lv-icon {
            font-size: 1.4rem;
            margin-bottom: .3rem;
        }

        .lv-card .lv-name {
            font-size: .78rem;
            font-weight: 700;
            color: var(--deep);
        }

        .lv-card .lv-sub {
            font-size: .65rem;
            color: var(--muted);
            margin-top: .15rem;
        }

    /* STATUS */
    .status-opts {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 500;
        transition: all .2s;
        user-select: none;
    }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            font-weight: 700;
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        cursor: pointer;
    }

    .toggle-label {
        font-size: .84rem;
        color: var(--deep);
    }

    /* INSTRUCTOR */
    .instructor-row {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .instructor-fields {
        flex: 1;
    }

    .avatar-zone {
        border: 2px dashed var(--border);
        border-radius: 50%;
        width: 90px;
        height: 90px;
        cursor: pointer;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--warm);
        transition: border-color .2s;
        flex-shrink: 0;
    }

        .avatar-zone:hover {
            border-color: var(--gold);
        }

        .avatar-zone img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

            .avatar-zone img.show {
                display: block;
            }

        .avatar-zone .av-icon {
            font-size: 1.5rem;
            color: var(--muted);
            pointer-events: none;
        }

    /* FEATURED IMAGE */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        min-height: 160px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: border-color .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
        }

        .img-upload-zone.has-preview {
            border-style: solid;
            border-color: var(--gold);
        }

    .img-preview {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

        .img-preview.show {
            display: block;
        }

    .img-upload-inner {
        text-align: center;
        padding: 2rem 1rem;
        pointer-events: none;
    }

    .upload-icon {
        font-size: 2rem;
        color: var(--gold);
        margin-bottom: .5rem;
    }

    .upload-text {
        font-size: .84rem;
        color: var(--muted);
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .65rem;
    }

        .img-url-row .fg-input {
            flex: 1;
        }

    .btn-url-confirm {
        padding: .65rem 1rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-url-confirm:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
        }

    /* GALLERY */
    .gallery-drop-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        padding: 1.2rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        margin-bottom: .75rem;
    }

        .gallery-drop-zone:hover, .gallery-drop-zone.drag-over {
            border-color: var(--gold);
            background: rgba(212,160,23,.05);
        }

        .gallery-drop-zone .dz-icon {
            font-size: 1.5rem;
            color: var(--gold);
        }

        .gallery-drop-zone .dz-text {
            font-size: .82rem;
            color: var(--muted);
            margin-top: .3rem;
        }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: .5rem;
    }

    .gallery-thumb {
        position: relative;
        aspect-ratio: 1;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid var(--border);
        background: var(--warm);
    }

        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .gallery-thumb .thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.5);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
            opacity: 0;
            transition: opacity .2s;
        }

        .gallery-thumb:hover .thumb-overlay {
            opacity: 1;
        }

    .thumb-btn {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .72rem;
    }

        .thumb-btn.del {
            background: var(--red);
            color: #fff;
        }

        .thumb-btn.primary {
            background: var(--gold);
            color: var(--deep);
        }

    .gallery-thumb.is-primary::after {
        content: '★';
        position: absolute;
        top: 3px;
        left: 3px;
        background: var(--gold);
        color: var(--deep);
        font-size: .6rem;
        font-weight: 700;
        padding: .1rem .3rem;
        border-radius: 3px;
    }
    /* existing images in edit mode */
    .gallery-thumb.existing .del-existing {
        position: absolute;
        top: 3px;
        right: 3px;
        background: var(--red);
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
    }

    /* VIDEO */
    .video-preview {
        margin-top: .65rem;
        border-radius: 8px;
        overflow: hidden;
        display: none;
    }

        .video-preview.show {
            display: block;
        }

        .video-preview iframe {
            width: 100%;
            height: 175px;
            border: none;
            border-radius: 8px;
        }

    /* HIGHLIGHTS */
    .hl-input-row {
        display: flex;
        gap: .5rem;
    }

        .hl-input-row .fg-input {
            flex: 1;
        }

    .btn-hl-add {
        padding: .65rem .9rem;
        background: var(--deep);
        border: none;
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--gold);
        cursor: pointer;
        white-space: nowrap;
    }

    .highlight-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        margin-top: .5rem;
    }

    .hl-tag {
        display: flex;
        align-items: center;
        gap: .35rem;
        background: rgba(212,160,23,.12);
        border: 1px solid rgba(212,160,23,.3);
        border-radius: 20px;
        padding: .3rem .75rem;
        font-size: .78rem;
        color: var(--deep);
    }

        .hl-tag .hl-remove {
            cursor: pointer;
            color: var(--muted);
            font-size: .7rem;
            background: none;
            border: none;
            padding: 0;
            line-height: 1;
        }

            .hl-tag .hl-remove:hover {
                color: var(--red);
            }

    /* FOOTER */
    .ce-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .75rem;
        padding: 1rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        flex-shrink: 0;
    }

    .btn-ce-cancel {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-ce-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    .btn-ce-save {
        padding: .7rem 1.75rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
    }

        .btn-ce-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

        .btn-ce-save:disabled {
            opacity: .6;
            transform: none;
            cursor: not-allowed;
        }

    .spin {
        width: 26px;
        height: 26px;
        border: 3px solid var(--warm);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin .7s linear infinite;
        margin: 0 auto .75rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="ce-wrapper">
    <!-- HEADER -->
    <div class="ce-header">
        <div>
            <div class="ce-header-label"><i class="bi bi-mortarboard-fill"></i> Chỉnh Sửa Khóa Học</div>
            <div class="ce-title">Sửa: <em>@Model.CourseName.Substring(0, Math.Min(40, Model.CourseName.Length))@(Model.CourseName.Length > 40 ? "…" : "")</em></div>
            <div class="ce-subtitle">ID: #@Model.CourseId · Tạo @Model.CreatedAt.ToString("dd/MM/yyyy")</div>
        </div>
        <button class="ce-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- BODY -->
    <div class="ce-body">
        <form id="frmCourseEdit-@uid" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" name="CourseId" value="@Model.CourseId" />

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-info-circle-fill"></i><span class="ce-card-title">Thông Tin Cơ Bản</span></div>
                <div class="ce-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Khóa Học <span class="req">*</span></label>
                        <input name="CourseName" class="fg-input" required maxlength="200" value="@Model.CourseName" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <input name="ShortDesc" class="fg-input" maxlength="300" value="@Model.ShortDesc" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="4" required>@Model.Description</textarea>
                    </div>
                </div>
            </div>

            <!-- 2. TRÌNH ĐỘ -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-bar-chart-fill"></i><span class="ce-card-title">Trình Độ Học Viên</span></div>
                <div class="ce-card-body">
                    <div class="level-cards" id="levelCardsCE-@uid">
                        <div class="lv-card @(Model.Level == "Beginner" ? "selected" : "")" data-level="Beginner">
                            <div class="lv-icon">🌱</div><div class="lv-name">Mới Bắt Đầu</div><div class="lv-sub">Chưa biết đánh</div>
                        </div>
                        <div class="lv-card @(Model.Level == "Intermediate" ? "selected" : "")" data-level="Intermediate">
                            <div class="lv-icon">🏸</div><div class="lv-name">Trung Cấp</div><div class="lv-sub">Đánh được cơ bản</div>
                        </div>
                        <div class="lv-card @(Model.Level == "Advanced" ? "selected" : "")" data-level="Advanced">
                            <div class="lv-icon">🏆</div><div class="lv-name">Nâng Cao</div><div class="lv-sub">Thi đấu phong trào</div>
                        </div>
                        <div class="lv-card @(Model.Level == "All" ? "selected" : "")" data-level="All">
                            <div class="lv-icon">👥</div><div class="lv-name">Tất Cả</div><div class="lv-sub">Mọi trình độ</div>
                        </div>
                    </div>
                    <input type="hidden" name="Level" id="levelInputCE-@uid" value="@Model.Level" />
                </div>
            </div>

            <!-- 3. CHI TIẾT & GIÁ -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-calendar3"></i><span class="ce-card-title">Chi Tiết & Học Phí</span></div>
                <div class="ce-card-body">
                    <div class="fg fg-row4">
                        <div>
                            <label class="fg-label">Lịch Học</label>
                            <input name="Schedule" class="fg-input" value="@Model.Schedule" placeholder="T2,T4,T6 — 18:00~20:00" />
                        </div>
                        <div>
                            <label class="fg-label">Số Tuần</label>
                            <input name="DurationWeeks" type="number" class="fg-input" value="@Model.DurationWeeks" min="1" max="52" />
                        </div>
                        <div>
                            <label class="fg-label">Sĩ Số TĐ</label>
                            <input name="MaxStudents" type="number" class="fg-input" value="@Model.MaxStudents" min="1" />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="@Model.DisplayOrder" min="0" />
                        </div>
                    </div>
                    <div class="fg fg-row3" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Học Phí Gốc (VNĐ)</label>
                            <input name="TuitionFee" type="number" class="fg-input" value="@Model.TuitionFee" min="0" step="10000" />
                        </div>
                        <div>
                            <label class="fg-label">Giá Khuyến Mãi</label>
                            <input name="DiscountFee" type="number" class="fg-input" value="@Model.DiscountFee" min="0" step="10000" />
                        </div>
                        <div>
                            <label class="fg-label">Học Viên Hiện Tại</label>
                            <input name="CurrentStudents" type="number" class="fg-input" value="@Model.CurrentStudents" min="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. HUẤN LUYỆN VIÊN -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-person-badge-fill"></i><span class="ce-card-title">Huấn Luyện Viên</span></div>
                <div class="ce-card-body">
                    <div class="instructor-row">
                        <div>
                            <div class="avatar-zone" id="avatarZoneCE-@uid" title="Click để đổi ảnh HLV">
                                <img id="avatarPreviewCE-@uid" src="@Model.InstructorAvatar" alt="Avatar"
                                     class="@(!string.IsNullOrEmpty(Model.InstructorAvatar) ? "show" : "")" />
                                <i class="bi bi-person-fill av-icon" id="avatarIconCE-@uid"
                                   style="@(!string.IsNullOrEmpty(Model.InstructorAvatar) ? "display:none;" : "")"></i>
                            </div>
                            <input type="file" id="avatarFileCE-@uid" name="InstructorAvatarFile" accept="image/*" style="display:none" />
                            <div style="font-size:.65rem;color:var(--muted);text-align:center;margin-top:.3rem;">Ảnh HLV</div>
                        </div>
                        <div class="instructor-fields">
                            <div class="fg">
                                <label class="fg-label">Tên Huấn Luyện Viên</label>
                                <input name="Instructor" class="fg-input" value="@Model.Instructor" maxlength="100" placeholder="Nguyễn Văn A" />
                            </div>
                            <div class="fg" style="margin-bottom:0;">
                                <label class="fg-label">Chức Danh / Kinh Nghiệm</label>
                                <input name="InstructorTitle" class="fg-input" value="@Model.InstructorTitle" maxlength="150"
                                       placeholder="HLV quốc gia — 10 năm kinh nghiệm" />
                            </div>
                        </div>
                    </div>
                    <input type="hidden" name="InstructorAvatar" id="instructorAvatarPathCE-@uid" value="@Model.InstructorAvatar" />
                </div>
            </div>

            <!-- 5. NỘI DUNG THU HÚT -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-stars"></i><span class="ce-card-title">Nội Dung Thu Hút Học Viên</span></div>
                <div class="ce-card-body">
                    <div class="fg">
                        <label class="fg-label">⚡ Điểm Nổi Bật (Badges)</label>
                        <div class="hl-input-row">
                            <input type="text" id="hlInputCE-@uid" class="fg-input" placeholder="VD: Cam kết hoàn tiền, Lớp ≤10 người..." maxlength="80" />
                            <button type="button" class="btn-hl-add" id="btnAddHlCE-@uid"><i class="bi bi-plus-lg"></i> Thêm</button>
                        </div>
                        <div class="highlight-tags" id="hlTagsCE-@uid"></div>
                        <input type="hidden" name="Highlights" id="highlightsInputCE-@uid" value="@Model.Highlights" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">✅ Tính Năng & Ưu Điểm</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Mỗi dòng một điểm nổi bật...">@Model.Features</textarea>
                    </div>
                    <div class="fg">
                        <label class="fg-label">📋 Yêu Cầu Đầu Vào</label>
                        <textarea name="Requirements" class="fg-textarea" rows="2"
                                  placeholder="- Không yêu cầu kinh nghiệm...">@Model.Requirements</textarea>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">🎯 Sau Khóa Học Đạt Được</label>
                        <textarea name="Outcomes" class="fg-textarea" rows="3"
                                  placeholder="- Học viên sẽ đạt được...">@Model.Outcomes</textarea>
                    </div>
                </div>
            </div>

            <!-- 6. HÌNH ẢNH & VIDEO -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-images"></i><span class="ce-card-title">Hình Ảnh & Video</span></div>
                <div class="ce-card-body">
                    <!-- ẢNH ĐẠI DIỆN -->
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone @(!string.IsNullOrEmpty(Model.FeaturedImage) ? "has-preview" : "")" id="ceUploadZone-@uid">
                            <img class="img-preview @(!string.IsNullOrEmpty(Model.FeaturedImage) ? "show" : "")"
                                 id="ceImgPreview-@uid" src="@(Model.FeaturedImage ?? "")" alt="Preview" />
                            <div class="img-upload-inner" id="ceUploadInner-@uid"
                                 style="@(!string.IsNullOrEmpty(Model.FeaturedImage) ? "display:none;" : "")">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để đổi ảnh</strong> hoặc kéo thả</div>
                            </div>
                        </div>
                        <input type="file" id="ceImgInput-@uid" name="featuredImage" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="ceImgUrl-@uid" name="FeaturedImage" class="fg-input"
                                   value="@Model.FeaturedImage" placeholder="Hoặc nhập URL ảnh mới..." />
                            <button type="button" class="btn-url-confirm" id="ceBtnUrl-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                    </div>

                    <!-- GALLERY HIỆN TẠI -->
                    @if (Model.CourseImages != null && Model.CourseImages.Any())
                    {
                        <div class="fg">
                            <label class="fg-label">Ảnh Gallery Hiện Tại</label>
                            <div class="gallery-grid" id="existingGallery-@uid">
                                @foreach (var img in Model.CourseImages.OrderBy(i => i.DisplayOrder))
                                {
                                    <div class="gallery-thumb existing @(img.IsPrimary ? "is-primary" : "")" data-img-id="@img.ImageId">
                                        <img src="@img.ImagePath" alt="Gallery" />
                                        <button type="button" class="del-existing" title="Xóa ảnh này"
                                                onclick="deleteGalleryImage(@img.ImageId, this)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                            <div class="fg-hint">Click X để xóa ảnh. Xóa được thực hiện ngay lập tức.</div>
                        </div>
                    }

                    <!-- THÊM ẢNH MỚI -->
                    <div class="fg">
                        <label class="fg-label"><i class="bi bi-plus-circle me-1"></i>Thêm Ảnh Mới Vào Gallery</label>
                        <div class="gallery-drop-zone" id="galleryDropCE-@uid">
                            <div class="dz-icon"><i class="bi bi-images"></i></div>
                            <div class="dz-text">Click hoặc kéo thả ảnh vào đây · tối đa 5MB/ảnh</div>
                        </div>
                        <input type="file" id="galleryFileInputCE-@uid" name="galleryImages" accept="image/*" multiple style="display:none" />
                        <div class="gallery-grid" id="galleryGridCE-@uid"></div>
                        <div id="galleryCountCE-@uid" style="font-size:.72rem;color:var(--muted);margin-top:.3rem;"></div>
                    </div>

                    <!-- VIDEO -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-play-circle-fill me-1"></i>Video Giới Thiệu</label>
                        <div style="display:flex;gap:.5rem;">
                            <input type="text" name="VideoUrl" id="videoUrlInputCE-@uid" class="fg-input"
                                   value="@Model.VideoUrl" placeholder="https://www.youtube.com/watch?v=..." />
                            <button type="button" class="btn-url-confirm" id="btnVideoPreviewCE-@uid">
                                <i class="bi bi-play"></i> Xem thử
                            </button>
                        </div>
                        <div class="video-preview @(!string.IsNullOrEmpty(Model.VideoUrl) ? "show" : "")" id="videoPreviewCE-@uid">
                            @if (!string.IsNullOrEmpty(Model.VideoUrl))
                            {
                                var ytMatch = System.Text.RegularExpressions.Regex.Match(Model.VideoUrl, @"(?:youtube\.com/watch\?v=|youtu\.be/)([^&?#]+)");
                                if (ytMatch.Success)
                                {
                                    <iframe id="videoIframeCE-@uid" src="https://www.youtube.com/embed/@ytMatch.Groups[1].Value" allowfullscreen></iframe>
                                }
                                else
                                {
                                    <iframe id="videoIframeCE-@uid" src="" allowfullscreen></iframe>
                                }
                            }
                            else
                            {
                                <iframe id="videoIframeCE-@uid" src="" allowfullscreen></iframe>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- 7. TRẠNG THÁI -->
            <div class="ce-card">
                <div class="ce-card-head"><i class="bi bi-toggles"></i><span class="ce-card-title">Trạng Thái & Hiển Thị</span></div>
                <div class="ce-card-body">
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="ceStatusOpts-@uid">
                            <div class="status-opt @(Model.Status == "Active" ? "selected" : "")" data-status="Active">
                                <span class="status-dot" style="background:var(--green);"></span> Đang Hoạt Động
                            </div>
                            <div class="status-opt @(Model.Status == "Inactive" ? "selected" : "")" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng
                            </div>
                            <div class="status-opt @(Model.Status == "Full" ? "selected" : "")" data-status="Full">
                                <span class="status-dot" style="background:var(--red);"></span> Đã Đầy
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInputCE-@uid" value="@Model.Status" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <div class="toggle-row">
                            <label class="toggle-item">
                                <input type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") />
                                <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Khóa học nổi bật</span>
                            </label>
                            <label class="toggle-item">
                                <input type="checkbox" name="IsPopular" value="true" @(Model.IsPopular ? "checked" : "") />
                                <span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Đang hot</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="ce-footer">
        <button type="button" class="btn-ce-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-ce-save" id="btnCourseEditSave-@uid">
            <i class="bi bi-check-circle"></i> Lưu Thay Đổi
        </button>
    </div>
</div>

<script>
    (function () {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // LEVEL CARDS
        var levelCards = el('levelCardsCE');
        if (levelCards) {
            levelCards.querySelectorAll('.lv-card').forEach(function (c) {
                c.addEventListener('click', function () {
                    levelCards.querySelectorAll('.lv-card').forEach(function (x) { x.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('levelInputCE').value = this.dataset.level;
                });
            });
        }

        // STATUS
        var statusOpts = el('ceStatusOpts');
        if (statusOpts) {
            statusOpts.querySelectorAll('.status-opt').forEach(function (o) {
                o.addEventListener('click', function () {
                    statusOpts.querySelectorAll('.status-opt').forEach(function (x) { x.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputCE').value = this.dataset.status;
                });
            });
        }

        // AVATAR
        var avatarZone = el('avatarZoneCE'), avatarFile = el('avatarFileCE');
        var avatarPreview = el('avatarPreviewCE'), avatarIcon = el('avatarIconCE');
        if (avatarZone && avatarFile) {
            avatarZone.addEventListener('click', function () { avatarFile.click(); });
            avatarFile.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                var reader = new FileReader();
                reader.onload = function (ev) {
                    avatarPreview.src = ev.target.result; avatarPreview.classList.add('show');
                    if (avatarIcon) avatarIcon.style.display = 'none';
                };
                reader.readAsDataURL(this.files[0]);
            });
        }

        // FEATURED IMAGE
        var zone = el('ceUploadZone'), fileInput = el('ceImgInput');
        var preview = el('ceImgPreview'), uploadInner = el('ceUploadInner');
        function showPreview(src) {
            preview.src = src; preview.classList.add('show');
            if (uploadInner) uploadInner.style.display = 'none';
            zone.classList.add('has-preview');
        }
        function resetPreview() {
            preview.src = ''; preview.classList.remove('show');
            if (uploadInner) uploadInner.style.display = '';
            zone.classList.remove('has-preview');
        }
        if (zone && fileInput) {
            zone.addEventListener('click', function (e) {
                if (e.target === preview) { resetPreview(); fileInput.value = ''; return; }
                fileInput.click();
            });
            fileInput.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                var reader = new FileReader();
                reader.onload = function (ev) { showPreview(ev.target.result); };
                reader.readAsDataURL(this.files[0]);
            });
        }
        var ceBtnUrl = el('ceBtnUrl'), ceImgUrl = el('ceImgUrl');
        if (ceBtnUrl && ceImgUrl) {
            ceBtnUrl.addEventListener('click', function () {
                var url = ceImgUrl.value.trim();
                if (url) { showPreview(url); if (fileInput) fileInput.value = ''; }
                else resetPreview();
            });
        }

        // NEW GALLERY
        var galleryDrop = el('galleryDropCE'), galleryInput = el('galleryFileInputCE');
        var galleryGrid = el('galleryGridCE'), galleryCount = el('galleryCountCE');
        var galleryFiles = [], MAX_G = 10;
        function renderNewGallery() {
            if (!galleryGrid) return;
            galleryGrid.innerHTML = '';
            galleryFiles.forEach(function (f, idx) {
                var t = document.createElement('div'); t.className = 'gallery-thumb';
                t.innerHTML = '<img src="" alt=""><div class="thumb-overlay"><button type="button" class="thumb-btn del"><i class="bi bi-trash3-fill"></i></button></div>';
                var reader = new FileReader(); reader.onload = function (ev) { t.querySelector('img').src = ev.target.result; }; reader.readAsDataURL(f);
                t.querySelector('.thumb-btn.del').addEventListener('click', function () { galleryFiles.splice(idx, 1); renderNewGallery(); rebuildInput(); });
                galleryGrid.appendChild(t);
            });
            if (galleryCount) galleryCount.textContent = galleryFiles.length > 0 ? 'Sẽ thêm ' + galleryFiles.length + ' ảnh' : '';
        }
        function addFiles(files) {
            Array.from(files).forEach(function (f) {
                if (!f.type.startsWith('image/')) return;
                if (f.size > 5 * 1024 * 1024) { alert(f.name + ' quá 5MB'); return; }
                if (galleryFiles.length >= MAX_G) { alert('Tối đa ' + MAX_G + ' ảnh'); return; }
                galleryFiles.push(f);
            });
            renderNewGallery(); rebuildInput();
        }
        function rebuildInput() {
            if (!galleryInput) return;
            var dt = new DataTransfer(); galleryFiles.forEach(function (f) { dt.items.add(f); }); galleryInput.files = dt.files;
        }
        if (galleryDrop && galleryInput) {
            galleryDrop.addEventListener('click', function () { galleryInput.click(); });
            galleryInput.addEventListener('change', function () { addFiles(this.files); this.value = ''; });
            galleryDrop.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('drag-over'); });
            galleryDrop.addEventListener('dragleave', function () { this.classList.remove('drag-over'); });
            galleryDrop.addEventListener('drop', function (e) { e.preventDefault(); this.classList.remove('drag-over'); addFiles(e.dataTransfer.files); });
        }

        // VIDEO
        var btnVid = el('btnVideoPreviewCE'), vidUrl = el('videoUrlInputCE');
        var vidPrev = el('videoPreviewCE'), vidFrame = el('videoIframeCE');
        if (btnVid && vidFrame) {
            btnVid.addEventListener('click', function () {
                var url = vidUrl ? vidUrl.value.trim() : '';
                if (!url) { vidPrev && vidPrev.classList.remove('show'); return; }
                var m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);
                if (m) { vidFrame.src = 'https://www.youtube.com/embed/' + m[1]; vidPrev && vidPrev.classList.add('show'); }
                else alert('Chỉ hỗ trợ xem thử YouTube.');
            });
        }

        // HIGHLIGHTS — parse existing JSON
        var hlInput = el('hlInputCE'), btnAddHl = el('btnAddHlCE');
        var hlTagsDiv = el('hlTagsCE'), hlHidden = el('highlightsInputCE');
        var highlights = [];
        try { highlights = JSON.parse(hlHidden ? hlHidden.value : '[]') || []; } catch(e) { highlights = []; }
        function renderHighlights() {
            if (!hlTagsDiv) return;
            hlTagsDiv.innerHTML = '';
            highlights.forEach(function (hl, idx) {
                var tag = document.createElement('div'); tag.className = 'hl-tag';
                tag.innerHTML = hl + '<button type="button" class="hl-remove">✕</button>';
                tag.querySelector('.hl-remove').addEventListener('click', function () { highlights.splice(idx, 1); renderHighlights(); });
                hlTagsDiv.appendChild(tag);
            });
            if (hlHidden) hlHidden.value = JSON.stringify(highlights);
        }
        renderHighlights();
        function addHighlight() {
            var val = hlInput ? hlInput.value.trim() : '';
            if (!val || highlights.includes(val) || highlights.length >= 8) return;
            highlights.push(val); if (hlInput) hlInput.value = ''; renderHighlights();
        }
        if (btnAddHl) btnAddHl.addEventListener('click', addHighlight);
        if (hlInput) hlInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); addHighlight(); } });

        // DELETE existing gallery image
        window.deleteGalleryImage = function (imageId, btn) {
            if (!confirm('Xóa ảnh này?')) return;
            var fd = new FormData();
            fd.append('imageId', imageId);
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) fd.append('__RequestVerificationToken', token.value);
            fetch('/AdminService/CourseImageDelete', { method: 'POST', body: fd })
                .then(function (r) { return r.json(); })
                .then(function (res) {
                    if (res.success) {
                        var thumb = btn.closest('.gallery-thumb');
                        if (thumb) thumb.remove();
                    } else alert('Không thể xóa ảnh.');
                })
                .catch(function () { alert('Lỗi kết nối.'); });
        };

        // SUBMIT
        var btnSave = el('btnCourseEditSave');
        var form = document.getElementById('frmCourseEdit-' + UID);
        if (btnSave && form) {
            btnSave.addEventListener('click', function () {
                if (!form.checkValidity()) { form.reportValidity(); return; }
                var level = el('levelInputCE') ? el('levelInputCE').value : '';
                if (!level) { alert('Vui lòng chọn trình độ học viên'); return; }
                btnSave.disabled = true;
                btnSave.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
                fetch('/AdminService/CourseEdit', { method: 'POST', body: new FormData(form) })
                    .then(function (r) { return r.json(); })
                    .then(function (res) {
                        if (res.success) {
                            var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                            if (modal) modal.hide();
                            location.reload();
                        } else {
                            alert(res.message || 'Có lỗi xảy ra');
                            btnSave.disabled = false;
                            btnSave.innerHTML = '<i class="bi bi-check-circle"></i> Lưu Thay Đổi';
                        }
                    })
                    .catch(function () {
                        alert('Lỗi kết nối server');
                        btnSave.disabled = false;
                        btnSave.innerHTML = '<i class="bi bi-check-circle"></i> Lưu Thay Đổi';
                    });
            });
        }
    })();
</script>
