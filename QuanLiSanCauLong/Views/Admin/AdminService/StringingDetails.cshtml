@model QuanLiSanCauLong.Models.StringingService
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .sd2-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 0;
    }

    .sd2-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .sd2-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .sd2-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.25;
        max-width: 520px;
    }

    .sd2-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .sd2-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .sd2-body {
        padding: 1.25rem 1.75rem 1.5rem;
        overflow-y: auto;
        max-height: calc(90vh - 80px);
    }

    .sd2-hero-img {
        width: 100%;
        height: 180px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
        margin-bottom: 1.25rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .sd2-hero-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .sd2-strip {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .badge-active {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .badge-inactive {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .badge-featured {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .badge-popular {
        background: rgba(6,182,212,.08);
        color: #0e7490;
    }

    .sd2-price-now {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .sd2-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .sd2-grid-item {
        background: var(--warm);
        padding: 1rem 1.2rem;
        border-radius: 6px;
        border: 1px solid var(--border);
    }

    .sd2-grid-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: .4rem;
    }

    .sd2-grid-val {
        font-weight: 700;
        font-size: .92rem;
        color: var(--deep);
    }

    .sd2-section {
        margin-bottom: 1.25rem;
    }

    .sd2-section-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .6rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .sd2-section-label i {
            color: var(--gold);
        }

    .sd2-text {
        font-size: .86rem;
        color: var(--deep);
        line-height: 1.75;
        white-space: pre-wrap;
    }

    .sd2-features {
        display: grid;
        gap: .4rem;
    }

    .sd2-feature-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        font-size: .85rem;
        color: var(--deep);
    }

        .sd2-feature-item i {
            color: #16a34a;
            margin-top: .15rem;
            flex-shrink: 0;
        }

    .sd2-stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .sd2-stat-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: .9rem 1rem;
        text-align: center;
    }

    .sd2-stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .sd2-stat-l {
        font-size: .68rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
    }

    .sd2-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        margin-top: 1rem;
    }

    .sd2-meta-item {
        font-size: .75rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .sd2-meta-item strong {
            color: var(--deep);
        }

        .sd2-meta-item i {
            color: var(--gold);
        }

    .sd2-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .btn-sd2-close {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sd2-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-sd2-edit {
        padding: .65rem 1.6rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sd2-edit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="sd2-header">
    <div>
        <div class="sd2-header-label"><i class="bi bi-tools"></i> Chi tiết căng vợt</div>
        <div class="sd2-title">@Model.ServiceName</div>
    </div>
    <button type="button" class="sd2-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="sd2-body">

    @if (!string.IsNullOrEmpty(Model.FeaturedImage))
    {
        <div class="sd2-hero-img"><img src="@Model.FeaturedImage" alt="@Model.ServiceName" /></div>
    }
    else
    {
        <div class="sd2-hero-img">
            <div style="display:flex;flex-direction:column;align-items:center;gap:.5rem;color:var(--muted);">
                <i class="bi bi-tools" style="font-size:3rem;opacity:.25;"></i>
                <span style="font-size:.8rem;">Chưa có ảnh đại diện</span>
            </div>
        </div>
    }

    <!-- Info strip -->
    <div class="sd2-strip">
        <div>
            <div style="font-weight:700;font-size:1rem;color:var(--deep);">@Model.ServiceName</div>
            @if (!string.IsNullOrEmpty(Model.Brand) || !string.IsNullOrEmpty(Model.StringModel))
            {
                <div style="font-size:.82rem;color:var(--muted);margin-top:.25rem;">
                    @(Model.Brand ?? "") @(Model.StringModel ?? "")
                </div>
            }
            <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.5rem;">
                @if (Model.Status == "Active")
                {
                    <span class="badge-pill badge-active">● Hoạt động</span>
                }
                else
                {
                    <span class="badge-pill badge-inactive">○ Ngừng hoạt động</span>
                }
                @if (Model.IsFeatured)
                {
                    <span class="badge-pill badge-featured"><i class="bi bi-star-fill"></i> Nổi bật</span>
                }
                @if (Model.IsPopular)
                {
                    <span class="badge-pill badge-popular"><i class="bi bi-fire"></i> Phổ biến</span>
                }
            </div>
        </div>
        @if (Model.Price.HasValue)
        {
            <div style="text-align:right;flex-shrink:0;">
                <div class="sd2-price-now">@Model.Price.Value.ToString("N0")đ</div>
                <div style="font-size:.75rem;color:var(--muted);">/lần căng</div>
            </div>
        }
    </div>

    <!-- Stats -->
    <div class="sd2-stats">
        <div class="sd2-stat-box">
            <div class="sd2-stat-n" style="color:var(--gold);">@Model.TotalOrders.ToString("N0")</div>
            <div class="sd2-stat-l">Tổng đơn</div>
        </div>
        <div class="sd2-stat-box">
            <div class="sd2-stat-n">@(Model.DurationMinutes != null ? Model.DurationMinutes + " phút" : "—")</div>
            <div class="sd2-stat-l">Thời gian</div>
        </div>
        <div class="sd2-stat-box">
            <div class="sd2-stat-n">@(Model.WarrantyDays != null ? Model.WarrantyDays + " ngày" : "—")</div>
            <div class="sd2-stat-l">Bảo hành</div>
        </div>
    </div>

    <!-- Grid thông tin -->
    <div class="sd2-grid">
        <div class="sd2-grid-item">
            <span class="sd2-grid-label"><i class="bi bi-patch-check me-1"></i>Thương Hiệu</span>
            <span class="sd2-grid-val">@(Model.Brand ?? "—")</span>
        </div>
        <div class="sd2-grid-item">
            <span class="sd2-grid-label"><i class="bi bi-tag me-1"></i>Model Dây</span>
            <span class="sd2-grid-val">@(Model.StringModel ?? "—")</span>
        </div>
        <div class="sd2-grid-item">
            <span class="sd2-grid-label"><i class="bi bi-speedometer2 me-1"></i>Lực Căng</span>
            <span class="sd2-grid-val">@(Model.Tension ?? "—")</span>
        </div>
        <div class="sd2-grid-item">
            <span class="sd2-grid-label"><i class="bi bi-sort-numeric-down me-1"></i>Thứ Tự</span>
            <span class="sd2-grid-val">#@Model.DisplayOrder</span>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ShortDesc))
    {
        <div class="sd2-section">
            <div class="sd2-section-label"><i class="bi bi-chat-quote"></i> Mô tả ngắn</div>
            <div class="sd2-text" style="color:var(--muted);">@Model.ShortDesc</div>
        </div>
    }

    <div class="sd2-section">
        <div class="sd2-section-label"><i class="bi bi-file-text"></i> Mô tả chi tiết</div>
        <div class="sd2-text">@Model.Description</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Features))
    {
        <div class="sd2-section">
            <div class="sd2-section-label"><i class="bi bi-check2-all"></i> Tính năng nổi bật</div>
            <div class="sd2-features">
                @foreach (var f in Model.Features.Split('\n').Where(f => !string.IsNullOrWhiteSpace(f)))
                {
                    <div class="sd2-feature-item">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@f.Trim().TrimStart('-').Trim()</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="sd2-meta">
        <div class="sd2-meta-item"><i class="bi bi-calendar-plus"></i> Tạo: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></div>
        <div class="sd2-meta-item"><i class="bi bi-eye"></i> Lượt xem: <strong>@Model.ViewCount.ToString("N0")</strong></div>
    </div>
</div>

<!-- FOOTER -->
<div class="sd2-footer">
    <button type="button" class="btn-sd2-close" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Đóng
    </button>
    <button type="button" class="btn-sd2-edit" onclick="openStringingEdit(@Model.StringingId)">
        <i class="bi bi-pencil"></i> Chỉnh Sửa
    </button>
</div>

<script>
    function openStringingEdit(id) {
        var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
        if (modal) modal.hide();
        setTimeout(function() {
            if (typeof openModal === 'function') openModal('/AdminService/StringingEdit/' + id);
        }, 300);
    }
</script>
