@model QuanLiSanCauLong.Models.Tournament
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .st-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .st-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .st-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .st-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .st-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .st-title em {
            font-style: italic;
            color: var(--gold);
        }

    .st-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .st-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .st-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .st-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .st-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .st-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .st-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .st-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .st-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row23 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* TYPE CARDS */
    .type-cards {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .55rem;
    }

    .ty-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .65rem .5rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .ty-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .ty-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .ty-icon {
        font-size: 1.2rem;
        display: block;
        margin-bottom: .2rem;
    }

    .ty-name {
        font-size: .73rem;
        font-weight: 700;
        color: var(--deep);
    }

    /* STATUS OPTS */
    .status-opts {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
    }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
            color: var(--deep);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* DATE STRIP */
    .date-strip {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .date-field {
        position: relative;
    }

        .date-field i {
            position: absolute;
            right: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
            font-size: .85rem;
        }

    /* PRIZE HIGHLIGHT */
    .prize-note {
        background: rgba(212,160,23,.08);
        border: 1px solid rgba(212,160,23,.25);
        border-radius: 8px;
        padding: .75rem 1rem;
        font-size: .8rem;
        color: #92660a;
        display: flex;
        align-items: flex-start;
        gap: .5rem;
        margin-top: .5rem;
    }

        .prize-note i {
            margin-top: .1rem;
            flex-shrink: 0;
        }

    /* TOGGLE */
    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* IMAGE UPLOAD */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 1.5rem;
        background: var(--cream);
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        position: relative;
        overflow: hidden;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

        .img-upload-zone.has-preview {
            border-color: var(--gold);
            padding: 0;
        }

    .img-preview-st {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        display: none;
    }

        .img-preview-st.show {
            display: block;
        }

    .img-upload-inner-st {
        padding: 1.5rem;
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }

        .img-url-row .fg-input {
            flex: 1;
            font-size: .8rem;
        }

    .btn-url-confirm {
        padding: .5rem .9rem;
        background: var(--gold);
        border: none;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        font-family: 'Outfit',sans-serif;
    }

    .upload-icon {
        font-size: 1.8rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .upload-text {
        font-size: .82rem;
        color: var(--muted);
    }

        .upload-text strong {
            color: var(--deep);
        }

    /* FOOTER */
    .st-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
    }

    .btn-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- WRAPPER -->
<div class="st-wrapper">

    <!-- HEADER -->
    <div class="st-header">
        <div>
            <div class="st-header-label"><i class="bi bi-trophy"></i> Giải đấu mới</div>
            <div class="st-title">Tạo <em>Giải Đấu</em></div>
            <div class="st-subtitle">Tổ chức giải đấu cầu lông nội bộ</div>
        </div>
        <button type="button" class="st-close" data-bs-dismiss="modal">
            <i class="bi bi-x" style="font-size:1.1rem;"></i>
        </button>
    </div>

    <div class="st-body">
        <form id="frmTournamentCreate-@uid" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="st-card">
                <div class="st-card-head">
                    <i class="bi bi-info-circle"></i>
                    <span class="st-card-title">Thông Tin Giải Đấu</span>
                </div>
                <div class="st-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Giải Đấu <span class="req">*</span></label>
                        <input name="TournamentName" class="fg-input" placeholder="VD: Giải Đấu Mùa Xuân 2026" required />
                    </div>
                    <div class="fg fg-row2">
                        <div>
                            <label class="fg-label">Địa Điểm Tổ Chức</label>
                            <input name="Venue" class="fg-input" placeholder="VD: Cơ Sở Hoàng Mai" />
                        </div>
                        <div>
                            <label class="fg-label">Mô Tả Ngắn</label>
                            <input name="ShortDesc" class="fg-input" placeholder="Giải đấu nội bộ chào mừng..." />
                        </div>
                    </div>
                    <div class="fg fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Số VĐV Tối Đa</label>
                            <input name="MaxPlayers" type="number" class="fg-input" placeholder="32" />
                        </div>
                        <div>
                            <label class="fg-label">Phí Đăng Ký (VNĐ)</label>
                            <input name="EntryFee" type="number" class="fg-input" placeholder="200.000" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. LOẠI GIẢI ĐẤU -->
            <div class="st-card">
                <div class="st-card-head">
                    <i class="bi bi-people"></i>
                    <span class="st-card-title">Hình Thức Thi Đấu</span>
                </div>
                <div class="st-card-body">
                    <input name="TournamentType" type="hidden" id="typeInput-@uid" value="" />
                    <div class="type-cards" id="typeCards-@uid">
                        <div class="ty-card" data-type="Đơn Nam">
                            <span class="ty-icon">🏃</span>
                            <div class="ty-name">Đơn Nam</div>
                        </div>
                        <div class="ty-card" data-type="Đơn Nữ">
                            <span class="ty-icon">🏃‍♀️</span>
                            <div class="ty-name">Đơn Nữ</div>
                        </div>
                        <div class="ty-card" data-type="Đôi Nam">
                            <span class="ty-icon">👬</span>
                            <div class="ty-name">Đôi Nam</div>
                        </div>
                        <div class="ty-card" data-type="Đôi Nữ">
                            <span class="ty-icon">👭</span>
                            <div class="ty-name">Đôi Nữ</div>
                        </div>
                        <div class="ty-card" data-type="Đôi Mix">
                            <span class="ty-icon">👫</span>
                            <div class="ty-name">Đôi Mix</div>
                        </div>
                        <div class="ty-card" data-type="Đơn Nam/Nữ">
                            <span class="ty-icon">⚡</span>
                            <div class="ty-name">Đơn Nam/Nữ</div>
                        </div>
                        <div class="ty-card" data-type="Đôi Nam/Nữ/Mix">
                            <span class="ty-icon">🏆</span>
                            <div class="ty-name">Đôi Tổng Hợp</div>
                        </div>
                        <div class="ty-card" data-type="Khác">
                            <span class="ty-icon">📋</span>
                            <div class="ty-name">Khác</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. THỜI GIAN -->
            <div class="st-card">
                <div class="st-card-head">
                    <i class="bi bi-calendar3"></i>
                    <span class="st-card-title">Thời Gian Tổ Chức</span>
                </div>
                <div class="st-card-body">
                    <div class="date-strip fg" style="margin-bottom:0;">
                        <div class="date-field">
                            <label class="fg-label">Ngày Bắt Đầu</label>
                            <input name="StartDate" type="date" class="fg-input" />
                        </div>
                        <div class="date-field">
                            <label class="fg-label">Ngày Kết Thúc</label>
                            <input name="EndDate" type="date" class="fg-input" />
                        </div>
                        <div class="date-field">
                            <label class="fg-label">Hạn Đăng Ký</label>
                            <input name="RegistrationDeadline" type="date" class="fg-input" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. GIẢI THƯỞNG -->
            <div class="st-card">
                <div class="st-card-head">
                    <i class="bi bi-currency-exchange"></i>
                    <span class="st-card-title">Giải Thưởng</span>
                </div>
                <div class="st-card-body">
                    <div class="fg">
                        <label class="fg-label">Tổng Giải Thưởng (VNĐ)</label>
                        <input name="PrizeMoney" type="number" class="fg-input" placeholder="10.000.000" />
                        <div class="prize-note">
                            <i class="bi bi-lightbulb"></i>
                            <span>Mô tả chi tiết cơ cấu giải thưởng ở ô bên dưới để khuyến khích người tham gia.</span>
                        </div>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Chi Tiết Cơ Cấu Giải Thưởng</label>
                        <textarea name="PrizeDescription" class="fg-textarea" rows="2"
                                  placeholder="Giải Nhất: 5.000.000đ | Giải Nhì: 3.000.000đ | Giải Ba: 1.000.000đ × 2"></textarea>
                    </div>
                </div>
            </div>

            <!-- 5. NỘI DUNG & THỂ LỆ -->
            <div class="st-card">
                <div class="st-card-head">
                    <i class="bi bi-file-text"></i>
                    <span class="st-card-title">Nội Dung & Thể Lệ</span>
                </div>
                <div class="st-card-body">
                    <div class="fg">
                        <label class="fg-label">Mô Tả Chi Tiết</label>
                        <textarea name="Description" class="fg-textarea" rows="3"
                                  placeholder="Thông tin chi tiết về giải đấu..."></textarea>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Thể Lệ Giải Đấu</label>
                        <textarea name="Rules" class="fg-textarea" rows="4"
                                  placeholder="- Thi đấu theo thể thức vòng tròn&#10;- Mỗi trận 3 séc, thắng 2 séc thắng trận&#10;- Mỗi séc 21 điểm"></textarea>
                        <div class="fg-hint">Mỗi dòng một điều khoản, bắt đầu bằng dấu "-"</div>
                    </div>
                </div>
            </div>

            <!-- 6. HÌNH ẢNH & TRẠNG THÁI -->
            <div class="st-card">
                <div class="st-card-head">
                    <i class="bi bi-toggles"></i>
                    <span class="st-card-title">Hình Ảnh & Trạng Thái</span>
                </div>
                <div class="st-card-body">
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone" id="stUploadZone-@uid">
                            <img class="img-preview-st" id="imgPreviewST-@uid" src="" alt="Preview" />
                            <div class="img-upload-inner-st" id="uploadInnerST-@uid">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để tải ảnh lên</strong> hoặc kéo thả</div>
                                <div id="imgNameST-@uid" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                            </div><!-- /upload-inner -->
                        </div>
                        <input type="file" id="imgInputST-@uid" name="featuredImageFile" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="imgUrlST-@uid" name="FeaturedImage" class="fg-input"
                                   placeholder="Hoặc nhập URL ảnh: https://..." />
                            <button type="button" class="btn-url-confirm" id="btnUrlST-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                        <div class="fg-hint">Upload file hoặc nhập URL rồi nhấn Áp dụng</div>
                        <div class="fg">
                            <label class="fg-label">Trạng Thái</label>
                            <div class="status-opts" id="stStatusOpts-@uid">
                                <div class="status-opt selected" data-status="Upcoming">
                                    <span class="status-dot" style="background:#4f46e5;"></span> Sắp Diễn Ra
                                </div>
                                <div class="status-opt" data-status="Ongoing">
                                    <span class="status-dot" style="background:#16a34a;"></span> Đang Diễn Ra
                                </div>
                                <div class="status-opt" data-status="Completed">
                                    <span class="status-dot" style="background:var(--muted);"></span> Hoàn Thành
                                </div>
                                <div class="status-opt" data-status="Cancelled">
                                    <span class="status-dot" style="background:#c94b2a;"></span> Đã Hủy
                                </div>
                            </div>
                            <input name="Status" type="hidden" id="statusInputST-@uid" value="Upcoming" />
                        </div>
                        <div class="fg" style="margin-bottom:0;">
                            <label class="toggle-item">
                                <input name="IsFeatured" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Giải đấu nổi bật</span>
                            </label>
                        </div>
                    </div>
                </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="st-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-save" id="btnTournamentSubmit-@uid"
                data-form="frmTournamentCreate-@uid" data-url="/AdminService/TournamentCreate">
            <i class="bi bi-trophy"></i> Tạo Giải Đấu
        </button>
    </div>

</div><!-- /st-wrapper -->

<script>
    (function() {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // ── TYPE CARDS ────────────────────────────────────────
        var typeCards = el('typeCards');
        if (typeCards) {
            typeCards.querySelectorAll('.ty-card').forEach(function(card) {
                card.addEventListener('click', function() {
                    typeCards.querySelectorAll('.ty-card').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('typeInput').value = this.dataset.type;
                });
            });
        }

        // ── STATUS OPTS ──────────────────────────────────────
        var stStatusOpts = el('stStatusOpts');
        if (stStatusOpts) {
            stStatusOpts.querySelectorAll('.status-opt').forEach(function(opt) {
                opt.addEventListener('click', function() {
                    stStatusOpts.querySelectorAll('.status-opt').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputST').value = this.dataset.status;
                });
            });
        }

        // ── IMAGE UPLOAD (file) ───────────────────────────────
        var uploadZone  = el('stUploadZone');
        var fileInput   = el('imgInputST');
        var imgPreview  = el('imgPreviewST');
        var uploadInner = el('uploadInnerST');

        function showPreview(src) {
            if (!imgPreview) return;
            imgPreview.src = src;
            imgPreview.classList.add('show');
            if (uploadInner) uploadInner.style.display = 'none';
            if (uploadZone)  uploadZone.classList.add('has-preview');
        }
        function resetPreview() {
            if (!imgPreview) return;
            imgPreview.src = '';
            imgPreview.classList.remove('show');
            if (uploadInner) uploadInner.style.display = '';
            if (uploadZone)  uploadZone.classList.remove('has-preview');
        }

        if (uploadZone && fileInput) {
            uploadZone.addEventListener('click', function(e) {
                if (e.target === imgPreview) { resetPreview(); fileInput.value = ''; return; }
                fileInput.click();
            });
            fileInput.addEventListener('change', function() {
                if (!this.files || !this.files[0]) return;
                var nameEl = el('imgNameST');
                if (nameEl) nameEl.textContent = this.files[0].name;
                var reader = new FileReader();
                reader.onload = function(ev) { showPreview(ev.target.result); };
                reader.readAsDataURL(this.files[0]);
            });
        }

        // ── IMAGE URL ─────────────────────────────────────────
        var btnUrlST    = el('btnUrlST');
        var imgUrlInput = el('imgUrlST');
        if (btnUrlST && imgUrlInput) {
            btnUrlST.addEventListener('click', function() {
                var url = imgUrlInput.value.trim();
                if (!url) { resetPreview(); return; }
                showPreview(url);
                if (fileInput) fileInput.value = '';
            });
            imgUrlInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); btnUrlST.click(); }
            });
        }

        // ── SUBMIT ────────────────────────────────────────────
        var btnSubmit = el('btnTournamentSubmit');
        if (btnSubmit) {
            btnSubmit.addEventListener('click', function() {
                var formId = this.dataset.form;
                var url    = this.dataset.url;
                var form   = document.getElementById(formId);
                if (!form) return;
                if (!form.checkValidity()) { form.reportValidity(); return; }
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
                if (typeof submitServiceForm === 'function') {
                    submitServiceForm(formId, url);
                } else {
                    fetch(url, { method: 'POST', body: new FormData(form) })
                        .then(function(r) { return r.json(); })
                        .then(function(res) {
                            if (res.success) {
                                var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                if (modal) modal.hide();
                                location.reload();
                            } else {
                                alert(res.message || 'Có lỗi xảy ra.');
                                btnSubmit.disabled = false;
                                btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Giải Đấu';
                            }
                        })
                        .catch(function(err) {
                            alert('Lỗi kết nối: ' + err.message);
                            btnSubmit.disabled = false;
                            btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Giải Đấu';
                        });
                }
            });
        }
    })();
</script>
