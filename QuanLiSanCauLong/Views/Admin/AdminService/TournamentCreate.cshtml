@model QuanLiSanCauLong.Models.Tournament
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
        --blue: #1d4ed8;
    }

    * {
        font-family: 'Outfit', sans-serif;
        box-sizing: border-box;
    }

    .tc-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .tc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .tc-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .tc-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .tc-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .tc-title em {
            font-style: italic;
            color: var(--gold);
        }

    .tc-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .tc-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .tc-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .tc-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .tc-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .tc-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .tc-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .tc-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .tc-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: var(--red);
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* TYPE CARDS */
    .type-cards {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .6rem;
    }

    .type-card {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .75rem .5rem;
        cursor: pointer;
        text-align: center;
        transition: all .2s;
        user-select: none;
    }

        .type-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .type-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
        }

        .type-card .tc-icon {
            font-size: 1.4rem;
            margin-bottom: .25rem;
        }

        .type-card .tc-name {
            font-size: .75rem;
            font-weight: 700;
            color: var(--deep);
        }

        .type-card .tc-sub {
            font-size: .62rem;
            color: var(--muted);
            margin-top: .1rem;
        }

    /* STATUS */
    .status-opts {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 500;
        transition: all .2s;
        user-select: none;
    }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            font-weight: 700;
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        cursor: pointer;
    }

    .toggle-label {
        font-size: .84rem;
        color: var(--deep);
    }

    /* PRIZE TABLE */
    .prize-table {
        width: 100%;
        border-collapse: collapse;
    }

        .prize-table th {
            background: var(--warm);
            padding: .5rem .75rem;
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .prize-table td {
            padding: .6rem .75rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .prize-table tr:last-child td {
            border-bottom: none;
        }

        .prize-table .rank-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            font-size: .75rem;
            font-weight: 700;
        }

        .prize-table .rank-1 {
            background: #ffd700;
            color: #000;
        }

        .prize-table .rank-2 {
            background: #c0c0c0;
            color: #000;
        }

        .prize-table .rank-3 {
            background: #cd7f32;
            color: #fff;
        }

        .prize-table input {
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: .4rem .6rem;
            font-size: .84rem;
            width: 100%;
            outline: none;
        }

            .prize-table input:focus {
                border-color: var(--gold);
            }

    /* FEATURED IMAGE */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        min-height: 160px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: border-color .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
        }

        .img-upload-zone.has-preview {
            border-style: solid;
            border-color: var(--gold);
        }

    .img-preview-tc {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

        .img-preview-tc.show {
            display: block;
        }

    .img-upload-inner-tc {
        text-align: center;
        padding: 2rem 1rem;
        pointer-events: none;
    }

    .upload-icon {
        font-size: 2rem;
        color: var(--gold);
        margin-bottom: .5rem;
    }

    .upload-text {
        font-size: .84rem;
        color: var(--muted);
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .65rem;
    }

        .img-url-row .fg-input {
            flex: 1;
        }

    .btn-url-confirm {
        padding: .65rem 1rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-url-confirm:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
        }

    /* GALLERY */
    .gallery-drop-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        margin-bottom: .75rem;
    }

        .gallery-drop-zone:hover, .gallery-drop-zone.drag-over {
            border-color: var(--gold);
            background: rgba(212,160,23,.05);
        }

        .gallery-drop-zone .dz-icon {
            font-size: 1.75rem;
            color: var(--gold);
        }

        .gallery-drop-zone .dz-text {
            font-size: .84rem;
            color: var(--muted);
            margin-top: .4rem;
        }

        .gallery-drop-zone .dz-sub {
            font-size: .7rem;
            color: var(--muted);
            margin-top: .2rem;
        }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .6rem;
    }

    .gallery-thumb {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--border);
        background: var(--warm);
    }

        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .gallery-thumb .thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.45);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            opacity: 0;
            transition: opacity .2s;
        }

        .gallery-thumb:hover .thumb-overlay {
            opacity: 1;
        }

    .thumb-btn {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
    }

        .thumb-btn.del {
            background: var(--red);
            color: #fff;
        }

        .thumb-btn.primary {
            background: var(--gold);
            color: var(--deep);
        }

    .gallery-thumb.is-primary::after {
        content: '★ Chính';
        position: absolute;
        top: 4px;
        left: 4px;
        background: var(--gold);
        color: var(--deep);
        font-size: .6rem;
        font-weight: 700;
        padding: .15rem .4rem;
        border-radius: 3px;
    }

    .gallery-count {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    /* VIDEO */
    .video-preview {
        margin-top: .65rem;
        border-radius: 8px;
        overflow: hidden;
        display: none;
    }

        .video-preview.show {
            display: block;
        }

        .video-preview iframe {
            width: 100%;
            height: 180px;
            border: none;
            border-radius: 8px;
        }

    /* SPONSORS */
    .sponsor-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        margin-top: .5rem;
    }

    .sp-tag {
        display: flex;
        align-items: center;
        gap: .35rem;
        background: rgba(29,78,216,.08);
        border: 1px solid rgba(29,78,216,.2);
        border-radius: 20px;
        padding: .3rem .75rem;
        font-size: .78rem;
        color: var(--deep);
    }

        .sp-tag .sp-remove {
            cursor: pointer;
            color: var(--muted);
            font-size: .7rem;
            background: none;
            border: none;
            padding: 0;
            line-height: 1;
        }

            .sp-tag .sp-remove:hover {
                color: var(--red);
            }

    .sp-input-row {
        display: flex;
        gap: .5rem;
    }

        .sp-input-row .fg-input {
            flex: 1;
        }

    .btn-sp-add {
        padding: .65rem .9rem;
        background: var(--deep);
        border: none;
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--gold);
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-sp-add:hover {
            background: rgba(26,18,9,.85);
        }

    /* FOOTER */
    .tc-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .75rem;
        padding: 1rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        flex-shrink: 0;
    }

    .btn-tc-cancel {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-tc-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    .btn-tc-save {
        padding: .7rem 1.75rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
    }

        .btn-tc-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

        .btn-tc-save:disabled {
            opacity: .6;
            transform: none;
            cursor: not-allowed;
        }

    .spin {
        width: 28px;
        height: 28px;
        border: 3px solid var(--warm);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin .7s linear infinite;
        margin: 0 auto .75rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="tc-wrapper">
    <!-- HEADER -->
    <div class="tc-header">
        <div>
            <div class="tc-header-label"><i class="bi bi-trophy-fill"></i> Giải Đấu</div>
            <div class="tc-title">Tạo <em>Giải Đấu</em> Mới</div>
            <div class="tc-subtitle">Thông tin đầy đủ + ảnh đẹp = nhiều VĐV đăng ký hơn</div>
        </div>
        <button class="tc-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- BODY -->
    <div class="tc-body">
        <form id="frmTournamentCreate-@uid" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-info-circle-fill"></i><span class="tc-card-title">Thông Tin Cơ Bản</span></div>
                <div class="tc-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Giải Đấu <span class="req">*</span></label>
                        <input name="TournamentName" class="fg-input" required maxlength="200"
                               placeholder="VD: Giải Cầu Lông Mở Rộng Hè 2025 — Cúp Vàng CLB" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <input name="ShortDesc" class="fg-input" maxlength="300"
                               placeholder="Câu mô tả hấp dẫn hiển thị trên thẻ giải đấu..." />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="4" required
                                  placeholder="Giới thiệu giải đấu, mục tiêu, đối tượng tham gia, ban tổ chức..."></textarea>
                    </div>
                </div>
            </div>

            <!-- 2. THỂ THỨC -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-person-fill"></i><span class="tc-card-title">Thể Thức Thi Đấu</span></div>
                <div class="tc-card-body">
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Hình Thức <span class="req">*</span></label>
                        <div class="type-cards" id="typeCards-@uid">
                            <div class="type-card" data-type="Singles">
                                <div class="tc-icon">🏸</div>
                                <div class="tc-name">Đơn Nam/Nữ</div>
                                <div class="tc-sub">Singles</div>
                            </div>
                            <div class="type-card" data-type="Doubles">
                                <div class="tc-icon">👫</div>
                                <div class="tc-name">Đôi</div>
                                <div class="tc-sub">Doubles</div>
                            </div>
                            <div class="type-card" data-type="Mixed">
                                <div class="tc-icon">🤝</div>
                                <div class="tc-name">Đôi Nam Nữ</div>
                                <div class="tc-sub">Mixed Doubles</div>
                            </div>
                            <div class="type-card" data-type="All">
                                <div class="tc-icon">🏆</div>
                                <div class="tc-name">Tất Cả</div>
                                <div class="tc-sub">Đa nội dung</div>
                            </div>
                        </div>
                        <input type="hidden" name="TournamentType" id="typeInput-@uid" value="" />
                        <div id="typeRequired-@uid" style="display:none; color:var(--red); font-size:.75rem; margin-top:.4rem;">
                            <i class="bi bi-exclamation-circle me-1"></i>Vui lòng chọn thể thức thi đấu
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. THỜI GIAN & ĐỊA ĐIỂM -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-calendar-event-fill"></i><span class="tc-card-title">Thời Gian & Địa Điểm</span></div>
                <div class="tc-card-body">
                    <div class="fg fg-row3">
                        <div>
                            <label class="fg-label">Ngày Bắt Đầu <span class="req">*</span></label>
                            <input name="StartDate" type="datetime-local" class="fg-input" required />
                        </div>
                        <div>
                            <label class="fg-label">Ngày Kết Thúc</label>
                            <input name="EndDate" type="datetime-local" class="fg-input" />
                        </div>
                        <div>
                            <label class="fg-label">Hạn Đăng Ký</label>
                            <input name="RegistrationDeadline" type="datetime-local" class="fg-input" />
                        </div>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Tên Địa Điểm <span class="req">*</span></label>
                        <input name="Venue" class="fg-input" required maxlength="200"
                               placeholder="VD: Sân Cầu Lông ABC — 123 Nguyễn Văn Linh, Q.7" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Địa Chỉ Đầy Đủ</label>
                        <input name="VenueAddress" class="fg-input" maxlength="300"
                               placeholder="Số nhà, đường, phường, quận, thành phố..." />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-geo-alt me-1"></i>Google Maps URL</label>
                        <input name="MapUrl" id="mapUrlInput-@uid" class="fg-input"
                               placeholder="https://maps.google.com/maps?q=..." />
                        <div class="fg-hint">Paste link từ Google Maps → giúp VĐV tìm đường dễ hơn</div>
                    </div>
                </div>
            </div>

            <!-- 4. ĐĂNG KÝ & GIẢI THƯỞNG -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-trophy-fill"></i><span class="tc-card-title">Đăng Ký & Giải Thưởng — Yếu Tố Quyết Định</span></div>
                <div class="tc-card-body">
                    <div class="fg fg-row4">
                        <div>
                            <label class="fg-label">Phí Đăng Ký (VNĐ)</label>
                            <input name="EntryFee" type="number" class="fg-input" min="0" step="10000" placeholder="200,000" />
                        </div>
                        <div>
                            <label class="fg-label">Tổng Giải Thưởng (VNĐ)</label>
                            <input name="PrizeMoney" type="number" class="fg-input" min="0" step="100000" placeholder="10,000,000" />
                        </div>
                        <div>
                            <label class="fg-label">Số VĐV Tối Đa</label>
                            <input name="MaxPlayers" type="number" class="fg-input" min="1" placeholder="64" />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự Hiển Thị</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="0" min="0" />
                        </div>
                    </div>

                    <!-- PRIZE TABLE -->
                    <div class="fg">
                        <label class="fg-label">🥇 Chi Tiết Giải Thưởng Từng Hạng</label>
                        <table class="prize-table">
                            <thead>
                                <tr>
                                    <th style="width:50px;">Hạng</th>
                                    <th>Giải thưởng</th>
                                    <th>Phần thưởng thêm (cúp, huy chương...)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span class="rank-badge rank-1">🥇</span></td>
                                    <td><input type="text" id="prize1Cash-@uid" placeholder="VD: 5,000,000đ" /></td>
                                    <td><input type="text" id="prize1Extra-@uid" placeholder="VD: Cúp vàng + Vợt Yonex trị giá 3tr" /></td>
                                </tr>
                                <tr>
                                    <td><span class="rank-badge rank-2">🥈</span></td>
                                    <td><input type="text" id="prize2Cash-@uid" placeholder="VD: 3,000,000đ" /></td>
                                    <td><input type="text" id="prize2Extra-@uid" placeholder="VD: Cúp bạc + Áo thi đấu" /></td>
                                </tr>
                                <tr>
                                    <td><span class="rank-badge rank-3">🥉</span></td>
                                    <td><input type="text" id="prize3Cash-@uid" placeholder="VD: 1,000,000đ" /></td>
                                    <td><input type="text" id="prize3Extra-@uid" placeholder="VD: Cúp đồng + Vợt" /></td>
                                </tr>
                            </tbody>
                        </table>
                        <input type="hidden" name="PrizeDescription" id="prizeDescInput-@uid" />
                        <div class="fg-hint">Điền chi tiết → VĐV hào hứng hơn khi nhìn thấy giải thưởng rõ ràng</div>
                    </div>

                    <!-- LỊCH TRÌNH -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">📅 Lịch Trình Thi Đấu</label>
                        <textarea name="Schedule" class="fg-textarea" rows="3"
                                  placeholder="Ngày 1 (14/6): Vòng bảng — 07:00~17:00&#10;Ngày 2 (15/6): Tứ kết + Bán kết — 07:00~16:00&#10;Ngày 3 (16/6): Chung kết + Lễ trao giải — 09:00~12:00"></textarea>
                    </div>
                </div>
            </div>

            <!-- 5. THỂ LỆ & NHÀ TÀI TRỢ -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-file-text-fill"></i><span class="tc-card-title">Thể Lệ & Nhà Tài Trợ</span></div>
                <div class="tc-card-body">
                    <div class="fg">
                        <label class="fg-label">Thể Lệ Thi Đấu</label>
                        <textarea name="Rules" class="fg-textarea" rows="4"
                                  placeholder="- Hệ thức đấu: loại trực tiếp / vòng tròn&#10;- Mỗi game 21 điểm, thi đấu 3 ván 2 thắng&#10;- Trang phục: áo có cổ, giày thể thao đế không màu&#10;- VĐV phải có mặt trước trận 15 phút"></textarea>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-building me-1"></i>Nhà Tài Trợ</label>
                        <div class="sp-input-row">
                            <input type="text" id="spInput-@uid" class="fg-input"
                                   placeholder="VD: Yonex Việt Nam, Café ABC, Nhà Thuốc XYZ..." maxlength="100" />
                            <button type="button" class="btn-sp-add" id="btnAddSp-@uid">
                                <i class="bi bi-plus-lg"></i> Thêm
                            </button>
                        </div>
                        <div class="sponsor-tags" id="spTags-@uid"></div>
                        <input type="hidden" name="Sponsors" id="sponsorsInput-@uid" value="" />
                        <div class="fg-hint">Nhà tài trợ uy tín tăng độ tin cậy và thu hút VĐV đăng ký</div>
                    </div>
                </div>
            </div>

            <!-- 6. HÌNH ẢNH & VIDEO -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-images"></i><span class="tc-card-title">Hình Ảnh & Video — Tạo Sức Hút</span></div>
                <div class="tc-card-body">
                    <!-- ẢNH ĐẠI DIỆN -->
                    <div class="fg">
                        <label class="fg-label">Banner Giải Đấu</label>
                        <div class="img-upload-zone" id="tcUploadZone-@uid">
                            <img class="img-preview-tc" id="imgPreviewTC-@uid" src="" alt="Preview" />
                            <div class="img-upload-inner-tc" id="uploadInnerTC-@uid">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để tải banner lên</strong> hoặc kéo thả</div>
                                <div id="imgNameTC-@uid" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                            </div>
                        </div>
                        <input type="file" id="imgInputTC-@uid" name="featuredImage" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="imgUrlTC-@uid" name="FeaturedImage" class="fg-input"
                                   placeholder="Hoặc nhập URL banner..." />
                            <button type="button" class="btn-url-confirm" id="btnUrlTC-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                    </div>

                    <!-- GALLERY -->
                    <div class="fg">
                        <label class="fg-label">
                            <i class="bi bi-grid-3x3-gap-fill me-1"></i>Thư Viện Ảnh
                            <span style="font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0;"> — ảnh mùa giải trước, sân thi đấu, lễ trao giải</span>
                        </label>
                        <div class="gallery-drop-zone" id="galleryDrop-@uid">
                            <div class="dz-icon"><i class="bi bi-images"></i></div>
                            <div class="dz-text"><strong>Click hoặc kéo thả nhiều ảnh vào đây</strong></div>
                            <div class="dz-sub">Ảnh từ mùa giải trước sẽ thuyết phục VĐV mới đăng ký</div>
                        </div>
                        <input type="file" id="galleryFileInput-@uid" name="galleryImages" accept="image/*" multiple style="display:none" />
                        <div class="gallery-grid" id="galleryGrid-@uid"></div>
                        <div class="gallery-count" id="galleryCount-@uid"></div>
                    </div>

                    <!-- VIDEO HIGHLIGHT -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-play-circle-fill me-1"></i>Video Highlight Mùa Trước</label>
                        <div style="display:flex;gap:.5rem;align-items:flex-start;">
                            <input type="text" name="VideoUrl" id="videoUrlInput-@uid" class="fg-input"
                                   placeholder="https://www.youtube.com/watch?v=..." />
                            <button type="button" class="btn-url-confirm" id="btnVideoPreview-@uid">
                                <i class="bi bi-play"></i> Xem thử
                            </button>
                        </div>
                        <div class="video-preview" id="videoPreview-@uid">
                            <iframe id="videoIframe-@uid" src="" allowfullscreen></iframe>
                        </div>
                        <div class="fg-hint">Video sôi động từ mùa trước là "bằng chứng sống" thu hút VĐV đăng ký</div>
                    </div>
                </div>
            </div>

            <!-- 7. TRẠNG THÁI -->
            <div class="tc-card">
                <div class="tc-card-head"><i class="bi bi-toggles"></i><span class="tc-card-title">Trạng Thái & Hiển Thị</span></div>
                <div class="tc-card-body">
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="statusOptsTC-@uid">
                            <div class="status-opt selected" data-status="Upcoming">
                                <span class="status-dot" style="background:var(--blue);"></span> Sắp Diễn Ra
                            </div>
                            <div class="status-opt" data-status="Ongoing">
                                <span class="status-dot" style="background:var(--green);"></span> Đang Diễn Ra
                            </div>
                            <div class="status-opt" data-status="Finished">
                                <span class="status-dot" style="background:var(--muted);"></span> Đã Kết Thúc
                            </div>
                            <div class="status-opt" data-status="Cancelled">
                                <span class="status-dot" style="background:var(--red);"></span> Đã Hủy
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInputTC-@uid" value="Upcoming" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="toggle-item">
                            <input name="IsFeatured" type="checkbox" value="true" />
                            <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Giải đấu nổi bật</span>
                        </label>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="tc-footer">
        <button type="button" class="btn-tc-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-tc-save" id="btnTournamentSubmit-@uid"
                data-form="frmTournamentCreate-@uid" data-url="/AdminService/TournamentCreate">
            <i class="bi bi-trophy"></i> Tạo Giải Đấu
        </button>
    </div>

</div>

<script>
    (function () {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // TYPE CARDS
        var typeCards = el('typeCards');
        if (typeCards) {
            typeCards.querySelectorAll('.type-card').forEach(function (card) {
                card.addEventListener('click', function () {
                    typeCards.querySelectorAll('.type-card').forEach(function (c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('typeInput').value = this.dataset.type;
                    var req = el('typeRequired');
                    if (req) req.style.display = 'none';
                });
            });
        }

        // STATUS OPTS
        var statusOptsTC = el('statusOptsTC');
        if (statusOptsTC) {
            statusOptsTC.querySelectorAll('.status-opt').forEach(function (opt) {
                opt.addEventListener('click', function () {
                    statusOptsTC.querySelectorAll('.status-opt').forEach(function (c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputTC').value = this.dataset.status;
                });
            });
        }

        // PRIZE TABLE → PrizeDescription
        function syncPrizeDescription() {
            var parts = [];
            var p1c = el('prize1Cash'), p1e = el('prize1Extra');
            var p2c = el('prize2Cash'), p2e = el('prize2Extra');
            var p3c = el('prize3Cash'), p3e = el('prize3Extra');
            if (p1c && p1c.value) parts.push('🥇 ' + p1c.value + (p1e && p1e.value ? ' | ' + p1e.value : ''));
            if (p2c && p2c.value) parts.push('🥈 ' + p2c.value + (p2e && p2e.value ? ' | ' + p2e.value : ''));
            if (p3c && p3c.value) parts.push('🥉 ' + p3c.value + (p3e && p3e.value ? ' | ' + p3e.value : ''));
            var hidden = el('prizeDescInput');
            if (hidden) hidden.value = parts.join('\n');
        }
        ['prize1Cash','prize1Extra','prize2Cash','prize2Extra','prize3Cash','prize3Extra'].forEach(function(id) {
            var inp = el(id);
            if (inp) inp.addEventListener('input', syncPrizeDescription);
        });

        // SPONSORS
        var spInput = el('spInput'), btnAddSp = el('btnAddSp');
        var spTagsDiv = el('spTags'), sponsorsInput = el('sponsorsInput');
        var sponsors = [];
        function renderSponsors() {
            if (!spTagsDiv) return;
            spTagsDiv.innerHTML = '';
            sponsors.forEach(function (sp, idx) {
                var tag = document.createElement('div'); tag.className = 'sp-tag';
                tag.innerHTML = '🏢 ' + sp + '<button type="button" class="sp-remove">✕</button>';
                tag.querySelector('.sp-remove').addEventListener('click', function () { sponsors.splice(idx, 1); renderSponsors(); });
                spTagsDiv.appendChild(tag);
            });
            if (sponsorsInput) sponsorsInput.value = JSON.stringify(sponsors);
        }
        function addSponsor() {
            if (!spInput) return;
            var val = spInput.value.trim();
            if (!val || sponsors.includes(val) || sponsors.length >= 10) return;
            sponsors.push(val); spInput.value = ''; renderSponsors();
        }
        if (btnAddSp) btnAddSp.addEventListener('click', addSponsor);
        if (spInput) spInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); addSponsor(); } });

        // FEATURED IMAGE
        var uploadZone = el('tcUploadZone'), fileInput = el('imgInputTC');
        var imgPreview = el('imgPreviewTC'), uploadInner = el('uploadInnerTC');
        function showPreview(src) {
            if (!imgPreview) return;
            imgPreview.src = src; imgPreview.classList.add('show');
            if (uploadInner) uploadInner.style.display = 'none';
            if (uploadZone) uploadZone.classList.add('has-preview');
        }
        function resetPreview() {
            if (!imgPreview) return;
            imgPreview.src = ''; imgPreview.classList.remove('show');
            if (uploadInner) uploadInner.style.display = '';
            if (uploadZone) uploadZone.classList.remove('has-preview');
        }
        if (uploadZone && fileInput) {
            uploadZone.addEventListener('click', function (e) {
                if (e.target === imgPreview) { resetPreview(); fileInput.value = ''; return; }
                fileInput.click();
            });
            fileInput.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                var nameEl = el('imgNameTC');
                if (nameEl) nameEl.textContent = this.files[0].name;
                var reader = new FileReader();
                reader.onload = function (ev) { showPreview(ev.target.result); };
                reader.readAsDataURL(this.files[0]);
            });
        }
        var btnUrlTC = el('btnUrlTC'), imgUrlTC = el('imgUrlTC');
        if (btnUrlTC && imgUrlTC) {
            btnUrlTC.addEventListener('click', function () {
                var url = imgUrlTC.value.trim();
                if (!url) { resetPreview(); return; }
                showPreview(url); if (fileInput) fileInput.value = '';
            });
        }

        // GALLERY
        var galleryDrop = el('galleryDrop'), galleryInput = el('galleryFileInput');
        var galleryGrid = el('galleryGrid'), galleryCount = el('galleryCount');
        var galleryFiles = [], MAX_GALLERY = 10;
        function renderGalleryGrid() {
            if (!galleryGrid) return;
            galleryGrid.innerHTML = '';
            galleryFiles.forEach(function (file, idx) {
                var thumb = document.createElement('div');
                thumb.className = 'gallery-thumb' + (idx === 0 ? ' is-primary' : '');
                thumb.innerHTML = '<img src="" alt=""><div class="thumb-overlay">' +
                    '<button type="button" class="thumb-btn primary"><i class="bi bi-star-fill"></i></button>' +
                    '<button type="button" class="thumb-btn del"><i class="bi bi-trash3-fill"></i></button></div>';
                var img = thumb.querySelector('img');
                var reader = new FileReader(); reader.onload = function (ev) { img.src = ev.target.result; }; reader.readAsDataURL(file);
                thumb.querySelector('.thumb-btn.del').addEventListener('click', function () { galleryFiles.splice(idx,1); renderGalleryGrid(); rebuildFileInput(); });
                thumb.querySelector('.thumb-btn.primary').addEventListener('click', function () { var f=galleryFiles.splice(idx,1)[0]; galleryFiles.unshift(f); renderGalleryGrid(); rebuildFileInput(); });
                galleryGrid.appendChild(thumb);
            });
            if (galleryCount) galleryCount.textContent = galleryFiles.length > 0 ? galleryFiles.length + ' ảnh đã thêm' : '';
        }
        function addGalleryFiles(files) {
            Array.from(files).forEach(function (file) {
                if (!file.type.startsWith('image/')) return;
                if (file.size > 5*1024*1024) { alert(file.name + ' quá 5MB.'); return; }
                if (galleryFiles.length >= MAX_GALLERY) { alert('Tối đa '+MAX_GALLERY+' ảnh.'); return; }
                galleryFiles.push(file);
            });
            renderGalleryGrid(); rebuildFileInput();
        }
        function rebuildFileInput() {
            if (!galleryInput) return;
            var dt = new DataTransfer(); galleryFiles.forEach(function (f) { dt.items.add(f); }); galleryInput.files = dt.files;
        }
        if (galleryDrop && galleryInput) {
            galleryDrop.addEventListener('click', function () { galleryInput.click(); });
            galleryInput.addEventListener('change', function () { addGalleryFiles(this.files); this.value=''; });
            galleryDrop.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('drag-over'); });
            galleryDrop.addEventListener('dragleave', function () { this.classList.remove('drag-over'); });
            galleryDrop.addEventListener('drop', function (e) { e.preventDefault(); this.classList.remove('drag-over'); addGalleryFiles(e.dataTransfer.files); });
        }

        // VIDEO
        var btnVideoPreview = el('btnVideoPreview'), videoUrlInput = el('videoUrlInput');
        var videoPreview = el('videoPreview'), videoIframe = el('videoIframe');
        if (btnVideoPreview && videoIframe) {
            btnVideoPreview.addEventListener('click', function () {
                var url = videoUrlInput ? videoUrlInput.value.trim() : '';
                if (!url) { videoPreview && videoPreview.classList.remove('show'); return; }
                var match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);
                if (match) { videoIframe.src = 'https://www.youtube.com/embed/' + match[1]; videoPreview && videoPreview.classList.add('show'); }
                else { alert('Chỉ hỗ trợ xem thử YouTube.'); }
            });
        }

        // SUBMIT
        var btnSubmit = el('btnTournamentSubmit');
        if (btnSubmit) {
            btnSubmit.addEventListener('click', function () {
                var formId = this.dataset.form, url = this.dataset.url;
                var form = document.getElementById(formId);
                if (!form) return;

                var typeVal = el('typeInput') ? el('typeInput').value : '';
                if (!typeVal) {
                    var req = el('typeRequired');
                    if (req) req.style.display = 'block';
                    typeCards && typeCards.scrollIntoView({ behavior:'smooth', block:'center' });
                    return;
                }

                if (!form.checkValidity()) { form.reportValidity(); return; }
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
                if (typeof submitServiceForm === 'function') {
                    submitServiceForm(formId, url);
                } else {
                    fetch(url, { method:'POST', body: new FormData(form) })
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.success) {
                                var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                if (modal) modal.hide();
                                location.reload();
                            } else {
                                alert(res.message || 'Có lỗi xảy ra.');
                                btnSubmit.disabled = false;
                                btnSubmit.innerHTML = '<i class="bi bi-trophy"></i> Tạo Giải Đấu';
                            }
                        })
                        .catch(function (err) {
                            alert('Lỗi kết nối: ' + err.message);
                            btnSubmit.disabled = false;
                            btnSubmit.innerHTML = '<i class="bi bi-trophy"></i> Tạo Giải Đấu';
                        });
                }
            });
        }
    })();
</script>
