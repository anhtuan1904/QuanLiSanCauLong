@model QuanLiSanCauLong.Models.Service
@{
    Layout = null;
    var images = ViewBag.ServiceImages as List<QuanLiSanCauLong.Models.ServiceImage> ?? new List<QuanLiSanCauLong.Models.ServiceImage>();
}

<style>
:root {
    --deep:#1a1209; --gold:#d4a017; --gold2:#f5c842;
    --cream:#fdf8f0; --warm:#f5ede0; --border:#e8ddd0; --muted:#8a7560;
}
* { font-family:'Outfit',sans-serif; box-sizing:border-box; }

/* MODAL HEADER */
.se-header {
    display:flex; align-items:flex-start; justify-content:space-between;
    padding:1.5rem 1.75rem 0;
}
.se-header-label {
    font-size:.65rem; letter-spacing:.2em; text-transform:uppercase;
    color:var(--gold); display:flex; align-items:center; gap:.5rem; margin-bottom:.4rem;
}
.se-header-label::before { content:''; width:14px; height:1px; background:var(--gold); }
.se-title {
    font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:700; color:var(--deep);
}
.se-title em { font-style:italic; color:var(--gold); }
.se-subtitle { font-size:.82rem; color:var(--muted); margin-top:.2rem; }
.se-close {
    width:32px; height:32px; border:1px solid var(--border); border-radius:6px;
    background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center;
    color:var(--muted); transition:all .2s; flex-shrink:0;
}
.se-close:hover { border-color:var(--deep); color:var(--deep); }

/* BODY */
.se-body { padding:1.25rem 1.75rem 1rem; }

/* CARD */
.se-card {
    background:#fff; border:1px solid var(--border); border-radius:12px;
    overflow:hidden; margin-bottom:1.1rem;
}
.se-card-head {
    padding:.85rem 1.25rem; border-bottom:1px solid var(--border);
    background:var(--warm); display:flex; align-items:center; gap:.55rem;
}
.se-card-head i { color:var(--gold); font-size:.9rem; }
.se-card-title {
    font-size:.67rem; font-weight:700; letter-spacing:.14em;
    text-transform:uppercase; color:var(--muted);
}
.se-card-body { padding:1.25rem; }

/* FORM ELEMENTS */
.fg { margin-bottom:1.1rem; }
.fg:last-child { margin-bottom:0; }
.fg-row2 { display:grid; grid-template-columns:1fr 1fr; gap:.9rem; }
.fg-row3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:.9rem; }
.fg-row4 { display:grid; grid-template-columns:2fr 1fr 1fr; gap:.9rem; }

.fg-label {
    display:block; font-size:.71rem; font-weight:700; letter-spacing:.08em;
    text-transform:uppercase; color:var(--muted); margin-bottom:.45rem;
}
.fg-label .req { color:#c94b2a; }
.fg-input, .fg-select, .fg-textarea {
    width:100%; padding:.65rem 1rem; border:1.5px solid var(--border);
    border-radius:7px; font-family:'Outfit',sans-serif; font-size:.86rem;
    color:var(--deep); background:#fff; outline:none; transition:border-color .2s;
}
.fg-input:focus, .fg-select:focus, .fg-textarea:focus {
    border-color:var(--gold); background:var(--cream);
}
.fg-textarea { resize:vertical; min-height:80px; }
.fg-hint { font-size:.7rem; color:var(--muted); margin-top:.3rem; }

/* STATUS PILLS */
.status-opts {
    display:flex; gap:.6rem; flex-wrap:wrap;
}
.status-opt {
    display:flex; align-items:center; gap:.5rem;
    padding:.5rem 1rem; border:1.5px solid var(--border); border-radius:6px;
    cursor:pointer; font-size:.82rem; font-weight:600; color:var(--muted);
    transition:all .2s; user-select:none;
}
.status-opt:hover { border-color:rgba(212,160,23,.5); }
.status-opt.selected { border-color:var(--gold); background:rgba(212,160,23,.07); color:var(--deep); }
.status-dot { width:8px; height:8px; border-radius:50%; }

/* CHECKBOX TOGGLES */
.toggle-row { display:flex; gap:1rem; flex-wrap:wrap; }
.toggle-item {
    display:flex; align-items:center; gap:.6rem;
    border:1.5px solid var(--border); border-radius:7px;
    padding:.6rem 1rem; cursor:pointer; transition:all .2s;
}
.toggle-item:has(input:checked) {
    border-color:var(--gold); background:rgba(212,160,23,.06);
}
.toggle-item input { accent-color:var(--gold); width:16px; height:16px; cursor:pointer; }
.toggle-label { font-size:.84rem; font-weight:600; color:var(--deep); }

/* IMAGE UPLOAD */
.img-upload-zone {
    border:2px dashed var(--border); border-radius:10px; padding:1.25rem;
    background:var(--cream); transition:border-color .2s;
}
.img-upload-zone:hover { border-color:rgba(212,160,23,.5); }
.img-grid { display:flex; flex-wrap:wrap; gap:.6rem; margin-bottom:.75rem; }
.img-thumb-wrap {
    position:relative; width:82px; height:82px; border-radius:8px; overflow:hidden;
    border:2px solid var(--border); cursor:pointer; transition:all .2s;
}
.img-thumb-wrap img { width:100%; height:100%; object-fit:cover; }
.img-thumb-wrap .main-star {
    position:absolute; top:4px; left:4px;
    background:rgba(212,160,23,.9); border-radius:50%;
    width:20px; height:20px; display:none; align-items:center;
    justify-content:center; font-size:.6rem; color:var(--deep);
}
.img-thumb-wrap.is-main { border-color:var(--gold); border-width:2.5px; }
.img-thumb-wrap.is-main .main-star { display:flex; }
.img-thumb-wrap .del-btn {
    position:absolute; top:3px; right:3px;
    background:rgba(201,75,42,.9); color:#fff; border:none; border-radius:50%;
    width:20px; height:20px; display:flex; align-items:center; justify-content:center;
    cursor:pointer; font-size:.65rem;
}
.add-img-btn {
    width:82px; height:82px; border:2px dashed var(--border); border-radius:8px;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    cursor:pointer; color:var(--muted); gap:.2rem; font-size:.7rem; transition:all .2s;
}
.add-img-btn:hover { border-color:var(--gold); color:var(--gold); background:rgba(212,160,23,.05); }
.add-img-btn i { font-size:1.2rem; }
.img-hint { font-size:.72rem; color:var(--muted); display:flex; align-items:center; gap:.35rem; }
.img-hint i { color:var(--gold); }

/* FOOTER */
.se-footer {
    display:flex; justify-content:flex-end; gap:.65rem;
    padding:1rem 1.75rem 1.5rem; border-top:1px solid var(--border);
}
.btn-se-cancel {
    padding:.65rem 1.4rem; border:1.5px solid var(--border); border-radius:7px;
    background:#fff; color:var(--muted); font-size:.84rem; font-weight:600;
    cursor:pointer; transition:all .2s; font-family:'Outfit',sans-serif;
}
.btn-se-cancel:hover { border-color:var(--deep); color:var(--deep); }
.btn-se-save {
    padding:.65rem 1.75rem; border:none; border-radius:7px;
    background:linear-gradient(135deg,var(--gold),var(--gold2));
    color:var(--deep); font-size:.84rem; font-weight:700;
    cursor:pointer; transition:all .2s; display:flex; align-items:center; gap:.4rem;
    font-family:'Outfit',sans-serif;
}
.btn-se-save:hover { transform:translateY(-1px); box-shadow:0 5px 15px rgba(212,160,23,.3); }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="se-header">
    <div>
        <div class="se-header-label"><i class="bi bi-pencil-square"></i> Chỉnh sửa dịch vụ</div>
        <div class="se-title">Cập Nhật <em>Dịch Vụ</em></div>
        <div class="se-subtitle">Đang chỉnh sửa: <strong>@Model.ServiceName</strong></div>
    </div>
    <button type="button" class="se-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="se-body">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ServiceId" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="ViewCount" />
        <input type="hidden" asp-for="Slug" />

        <!-- 1. THÔNG TIN CƠ BẢN -->
        <div class="se-card">
            <div class="se-card-head">
                <i class="bi bi-info-circle"></i>
                <span class="se-card-title">Thông Tin Cơ Bản</span>
            </div>
            <div class="se-card-body">
                <div class="fg-row4 fg">
                    <div>
                        <label class="fg-label">Tên Dịch Vụ <span class="req">*</span></label>
                        <input asp-for="ServiceName" class="fg-input" required />
                    </div>
                    <div>
                        <label class="fg-label">Thứ Tự</label>
                        <input asp-for="DisplayOrder" type="number" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Icon</label>
                        <input asp-for="Icon" class="fg-input" placeholder="bi bi-..." />
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Mô Tả Ngắn</label>
                    <textarea asp-for="ShortDescription" class="fg-textarea" rows="2"></textarea>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                    <textarea asp-for="Description" class="fg-textarea" rows="5" required></textarea>
                </div>
            </div>
        </div>

        <!-- 2. GIÁ -->
        <div class="se-card">
            <div class="se-card-head">
                <i class="bi bi-currency-exchange"></i>
                <span class="se-card-title">Giá Dịch Vụ</span>
            </div>
            <div class="se-card-body">
                <div class="fg-row3" style="margin-bottom:0;">
                    <div>
                        <label class="fg-label">Giá Gốc (VNĐ)</label>
                        <input asp-for="Price" type="number" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Giá Khuyến Mãi</label>
                        <input asp-for="DiscountPrice" type="number" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Đơn Vị</label>
                        <select asp-for="PriceUnit" class="fg-select">
                            <option value="">-- Chọn --</option>
                            <option value="giờ">/giờ</option>
                            <option value="tháng">/tháng</option>
                            <option value="lần">/lần</option>
                            <option value="khóa">/khóa</option>
                            <option value="buổi">/buổi</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. TÍNH NĂNG -->
        <div class="se-card">
            <div class="se-card-head">
                <i class="bi bi-list-check"></i>
                <span class="se-card-title">Tính Năng</span>
            </div>
            <div class="se-card-body">
                <div class="fg" style="margin-bottom:0;">
                    <textarea asp-for="Features" class="fg-textarea" rows="4"
                              placeholder="- Tính năng 1&#10;- Tính năng 2"></textarea>
                    <div class="fg-hint">Mỗi dòng một tính năng, bắt đầu bằng dấu "-"</div>
                </div>
            </div>
        </div>

        <!-- 4. HÌNH ẢNH -->
        <div class="se-card">
            <div class="se-card-head">
                <i class="bi bi-images"></i>
                <span class="se-card-title">Hình Ảnh</span>
            </div>
            <div class="se-card-body">
                <div class="img-upload-zone">
                    <div class="img-grid" id="imagePreviewEdit">
                        <div class="add-img-btn" onclick="document.getElementById('imgInputEdit').click()">
                            <i class="bi bi-plus-lg"></i>
                            <span>Thêm ảnh</span>
                        </div>
                    </div>
                    <input type="file" id="imgInputEdit" name="NewImageFiles" multiple accept="image/*" style="display:none" />
                    <input type="hidden" name="PrimaryImageId" id="primaryImageIdEdit" value="@(images.FirstOrDefault(i => i.IsPrimary)?.ImageId ?? 0)" />
                    <input type="hidden" name="NewMainImageIndex" id="mainImageIdxEdit" value="-1" />
                    <input type="hidden" name="DeletedImageIds" id="deletedImageIdsEdit" value="" />
                    <div id="existingImagesContainer"></div>
                    <div class="img-hint"><i class="bi bi-info-circle"></i> Nhấn vào ảnh để đặt làm ảnh chính. X để xóa.</div>
                </div>
            </div>
        </div>

        <!-- 5. TRẠNG THÁI & CÀI ĐẶT -->
        <div class="se-card">
            <div class="se-card-head">
                <i class="bi bi-toggles"></i>
                <span class="se-card-title">Trạng Thái & Cài Đặt</span>
            </div>
            <div class="se-card-body">
                <div class="fg">
                    <label class="fg-label">Trạng Thái</label>
                    <div class="status-opts">
                        <div class="status-opt @(Model.Status == "Active" ? "selected" : "")" id="st-Active" data-val="Active">
                            <span class="status-dot" style="background:#16a34a;"></span> Hoạt Động
                        </div>
                        <div class="status-opt @(Model.Status == "Inactive" ? "selected" : "")" id="st-Inactive" data-val="Inactive">
                            <span class="status-dot" style="background:#c94b2a;"></span> Ngừng Hoạt Động
                        </div>
                    </div>
                    <input asp-for="Status" type="hidden" id="statusInput" />
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Cài Đặt Hiển Thị</label>
                    <div class="toggle-row">
                        <label class="toggle-item">
                            <input asp-for="IsFeatured" type="checkbox" />
                            <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span>
                        </label>
                        <label class="toggle-item">
                            <input asp-for="IsPopular" type="checkbox" />
                            <span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Phổ biến</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

<!-- FOOTER -->
<div class="se-footer">
    <button type="button" class="btn-se-cancel" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Hủy
    </button>
    <button type="button" class="btn-se-save" onclick="document.querySelector('form[action*=Edit]').submit()">
        <i class="bi bi-check-circle"></i> Lưu Thay Đổi
    </button>
</div>

<script>
(function() {
    // selectStatus scoped — tránh conflict khi nhiều modal
    function selectStatus(val) {
        document.querySelectorAll('#modalServiceContent .status-opt').forEach(function(c) {
            c.classList.remove('selected');
        });
        var target = document.getElementById('st-' + val);
        if (target) target.classList.add('selected');
        var si = document.getElementById('statusInput');
        if (si) si.value = val;
    }

    // Attach click handlers thay vì dùng inline onclick
    document.querySelectorAll('#modalServiceContent .status-opt').forEach(function(opt) {
        opt.addEventListener('click', function() { selectStatus(this.dataset.val || this.id.replace('st-','')); });
    });
    // Fallback: expose selectStatus cho inline onclick nếu cần
    window._editSelectStatus = selectStatus;

(function() {
    const existingImages = @Html.Raw(Json.Serialize(images.Select(i => new { 
        imageId = i.ImageId, 
        imagePath = i.ImagePath, 
        isPrimary = i.IsPrimary 
    })));

    const previewContainer = document.getElementById('imagePreviewEdit');
    const addBtn = previewContainer.querySelector('.add-img-btn');
    const imgInput = document.getElementById('imgInputEdit');
    const existingImagesContainer = document.getElementById('existingImagesContainer');
    const deletedIdsInput = document.getElementById('deletedImageIdsEdit');
    const primaryIdInput = document.getElementById('primaryImageIdEdit');
    const mainIdxInput = document.getElementById('mainImageIdxEdit');
    let newFiles = [], deletedIds = [];

    existingImages.forEach(img => {
        const wrap = createExistingThumb(img);
        previewContainer.insertBefore(wrap, addBtn);
        const hidden = document.createElement('input');
        hidden.type = 'hidden'; hidden.name = 'ExistingImageIds';
        hidden.value = img.imageId; hidden.dataset.imageId = img.imageId;
        existingImagesContainer.appendChild(hidden);
    });

    function createExistingThumb(img) {
        const wrap = document.createElement('div');
        wrap.className = 'img-thumb-wrap' + (img.isPrimary ? ' is-main' : '');
        wrap.dataset.type = 'existing'; wrap.dataset.imageId = img.imageId;
        wrap.innerHTML = `<img src="${img.imagePath}" /><div class="main-star"><i class="bi bi-star-fill" style="font-size:.55rem;color:var(--deep);"></i></div><button type="button" class="del-btn"><i class="bi bi-x" style="font-size:.7rem;"></i></button>`;
        wrap.addEventListener('click', e => { if (!e.target.closest('.del-btn')) setMainExisting(wrap, img.imageId); });
        wrap.querySelector('.del-btn').addEventListener('click', e => { e.stopPropagation(); removeExisting(img.imageId, wrap); });
        return wrap;
    }

    function setMainExisting(wrap, id) {
        document.querySelectorAll('#imagePreviewEdit .img-thumb-wrap').forEach(w => w.classList.remove('is-main'));
        wrap.classList.add('is-main');
        primaryIdInput.value = id; mainIdxInput.value = -1;
    }

    function removeExisting(id, wrap) {
        deletedIds.push(id); deletedIdsInput.value = deletedIds.join(',');
        existingImagesContainer.querySelector(`input[data-image-id="${id}"]`)?.remove();
        wrap.remove();
    }

    imgInput.addEventListener('change', e => {
        Array.from(e.target.files).forEach(file => {
            if (!file.type.startsWith('image/')) return;
            const idx = newFiles.length; newFiles.push(file);
            const reader = new FileReader();
            reader.onload = ev => previewContainer.insertBefore(createNewThumb(ev.target.result, idx), addBtn);
            reader.readAsDataURL(file);
        });
        updateInput();
    });

    function createNewThumb(src, index) {
        const wrap = document.createElement('div');
        wrap.className = 'img-thumb-wrap'; wrap.dataset.type = 'new'; wrap.dataset.index = index;
        wrap.innerHTML = `<img src="${src}" /><div class="main-star"><i class="bi bi-star-fill" style="font-size:.55rem;color:var(--deep);"></i></div><button type="button" class="del-btn"><i class="bi bi-x" style="font-size:.7rem;"></i></button>`;
        wrap.addEventListener('click', e => { if (!e.target.closest('.del-btn')) setMainNew(wrap, index); });
        wrap.querySelector('.del-btn').addEventListener('click', e => { e.stopPropagation(); newFiles[index] = null; wrap.remove(); updateInput(); });
        return wrap;
    }

    function setMainNew(wrap, index) {
        document.querySelectorAll('#imagePreviewEdit .img-thumb-wrap').forEach(w => w.classList.remove('is-main'));
        wrap.classList.add('is-main');
        primaryIdInput.value = -1; mainIdxInput.value = index;
    }

    function updateInput() {
        const dt = new DataTransfer();
        newFiles.forEach(f => { if (f) dt.items.add(f); });
        imgInput.files = dt.files;
    }
})();
})();
</script>
