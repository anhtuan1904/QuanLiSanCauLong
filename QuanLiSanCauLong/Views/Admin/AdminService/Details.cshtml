@model QuanLiSanCauLong.Models.Service
@{
    Layout = null;
    var images = ViewBag.ServiceImages as List<QuanLiSanCauLong.Models.ServiceImage> ?? new List<QuanLiSanCauLong.Models.ServiceImage>();
    var primaryImage = images.FirstOrDefault(i => i.IsPrimary)?.ImagePath ?? Model.FeaturedImage;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    /* MODAL HEADER */
    .sd-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 0;
    }

    .sd-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .sd-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .sd-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .sd-title em {
            font-style: italic;
            color: var(--gold);
        }

    .sd-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .sd-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    /* BODY */
    .sd-body {
        padding: 1.25rem 1.75rem 1.5rem;
    }

    /* IMAGE GALLERY */
    .sd-gallery {
        margin-bottom: 1.5rem;
    }

    .sd-main-img {
        width: 100%;
        aspect-ratio: 16/7;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
        margin-bottom: .75rem;
        background: var(--warm);
    }

        .sd-main-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .sd-thumbs {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .sd-thumb {
        width: 64px;
        height: 64px;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid var(--border);
        cursor: pointer;
        transition: all .2s;
    }

        .sd-thumb:hover, .sd-thumb.active {
            border-color: var(--gold);
            transform: scale(1.05);
        }

        .sd-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* INFO STRIP */
    .sd-info-strip {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .sd-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--deep);
    }

    .sd-badges {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        margin-top: .4rem;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .badge-active {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .badge-inactive {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .badge-featured {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .badge-popular {
        background: rgba(6,182,212,.08);
        color: #0e7490;
    }

    /* PRICE BLOCK */
    .sd-price-block {
        text-align: right;
    }

    .sd-price-old {
        font-size: .78rem;
        color: var(--muted);
        text-decoration: line-through;
        margin-bottom: .1rem;
    }

    .sd-price-now {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .sd-price-unit {
        font-size: .75rem;
        color: var(--muted);
        font-family: 'Outfit',sans-serif;
    }

    .sd-discount-badge {
        display: inline-block;
        background: #c94b2a;
        color: #fff;
        font-size: .65rem;
        font-weight: 700;
        padding: .15rem .5rem;
        border-radius: 3px;
        margin-left: .4rem;
    }

    /* SECTION */
    .sd-section {
        margin-bottom: 1.25rem;
    }

    .sd-section-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .6rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .sd-section-label i {
            color: var(--gold);
        }

    .sd-text {
        font-size: .86rem;
        color: var(--deep);
        line-height: 1.75;
        white-space: pre-wrap;
    }

    .sd-short {
        font-size: .86rem;
        color: var(--muted);
        line-height: 1.6;
    }

    /* FEATURES */
    .sd-features {
        display: grid;
        gap: .4rem;
    }

    .sd-feature-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        font-size: .85rem;
        color: var(--deep);
    }

        .sd-feature-item i {
            color: #16a34a;
            margin-top: .15rem;
            flex-shrink: 0;
        }

    /* ICON PREVIEW */
    .sd-icon-preview {
        display: inline-flex;
        align-items: center;
        gap: .75rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: .6rem 1rem;
    }

        .sd-icon-preview i {
            font-size: 1.5rem;
            color: var(--gold);
        }

    .sd-icon-code {
        font-size: .78rem;
        color: var(--muted);
        font-family: monospace;
    }

    /* META */
    .sd-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        margin-top: 1rem;
    }

    .sd-meta-item {
        font-size: .75rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .sd-meta-item strong {
            color: var(--deep);
        }

        .sd-meta-item i {
            color: var(--gold);
        }

    /* FOOTER */
    .sd-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .btn-sd-close {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sd-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-sd-edit {
        padding: .65rem 1.6rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sd-edit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="sd-header">
    <div>
        <div class="sd-header-label"><i class="bi bi-info-circle"></i> Chi tiết dịch vụ</div>
        <div class="sd-title">@Model.ServiceName</div>
    </div>
    <button type="button" class="sd-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="sd-body">

    <!-- Image Gallery -->
    @if (images.Any())
    {
        <div class="sd-gallery">
            <div class="sd-main-img">
                <img src="@primaryImage" id="mainDisplayImage" alt="@Model.ServiceName" />
            </div>
            @if (images.Count > 1)
            {
                <div class="sd-thumbs">
                    @foreach (var img in images)
                    {
                        <div class="sd-thumb @(img.IsPrimary ? "active" : "")"
                             onclick="changeMainImage('@img.ImagePath', this)">
                            <img src="@img.ImagePath" alt="Thumb" />
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- Info Strip -->
    <div class="sd-info-strip">
        <div>
            <div class="sd-name">@Model.ServiceName</div>
            <div class="sd-badges">
                @if (Model.Status == "Active")
                {
                    <span class="badge-pill badge-active">● Hoạt động</span>
                }
                else
                {
                    <span class="badge-pill badge-inactive">● Ngừng hoạt động</span>
                }
                @if (Model.IsFeatured)
                {
                    <span class="badge-pill badge-featured"><i class="bi bi-star-fill"></i> Nổi bật</span>
                }
                @if (Model.IsPopular)
                {
                    <span class="badge-pill badge-popular"><i class="bi bi-fire"></i> Phổ biến</span>
                }
            </div>
        </div>
        @if (Model.Price.HasValue)
        {
            <div class="sd-price-block">
                @if (Model.DiscountPrice.HasValue)
                {
                    <div class="sd-price-old">@Model.Price.Value.ToString("N0")đ</div>
                    <div class="sd-price-now">
                        @Model.DiscountPrice.Value.ToString("N0")đ
                        <span class="sd-discount-badge">-@(((Model.Price - Model.DiscountPrice) / Model.Price * 100).Value.ToString("N0"))%</span>
                    </div>
                }
                else
                {
                    <div class="sd-price-now">@Model.Price.Value.ToString("N0")đ</div>
                }
                @if (!string.IsNullOrEmpty(Model.PriceUnit))
                {
                    <div class="sd-price-unit">/@Model.PriceUnit</div>
                }
            </div>
        }
    </div>

    <!-- Short Description -->
    @if (!string.IsNullOrEmpty(Model.ShortDescription))
    {
        <div class="sd-section">
            <div class="sd-section-label"><i class="bi bi-chat-quote"></i> Mô tả ngắn</div>
            <div class="sd-short">@Model.ShortDescription</div>
        </div>
    }

    <!-- Full Description -->
    <div class="sd-section">
        <div class="sd-section-label"><i class="bi bi-file-text"></i> Mô tả chi tiết</div>
        <div class="sd-text">@Model.Description</div>
    </div>

    <!-- Features -->
    @if (!string.IsNullOrEmpty(Model.Features))
    {
        <div class="sd-section">
            <div class="sd-section-label"><i class="bi bi-check2-all"></i> Tính năng nổi bật</div>
            <div class="sd-features">
                @foreach (var feature in Model.Features.Split('\n').Where(f => !string.IsNullOrWhiteSpace(f)))
                {
                    <div class="sd-feature-item">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>@feature.Trim().TrimStart('-').Trim()</span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Icon -->
    @if (!string.IsNullOrEmpty(Model.Icon))
    {
        <div class="sd-section">
            <div class="sd-section-label"><i class="bi bi-palette"></i> Icon</div>
            <div class="sd-icon-preview">
                <i class="@Model.Icon"></i>
                <span class="sd-icon-code">@Model.Icon</span>
            </div>
        </div>
    }

    <!-- Meta -->
    <div class="sd-meta">
        <div class="sd-meta-item"><i class="bi bi-sort-numeric-down"></i> Thứ tự: <strong>@Model.DisplayOrder</strong></div>
        <div class="sd-meta-item"><i class="bi bi-calendar-plus"></i> Tạo: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></div>
        <div class="sd-meta-item"><i class="bi bi-eye"></i> Lượt xem: <strong>@Model.ViewCount.ToString("N0")</strong></div>
    </div>

</div>

<!-- FOOTER -->
<div class="sd-footer">
    <button type="button" class="btn-sd-close" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Đóng
    </button>
    <button type="button" class="btn-sd-edit" onclick="openEditFromDetails(@Model.ServiceId)">
        <i class="bi bi-pencil"></i> Chỉnh Sửa
    </button>
</div>

<script>
    function changeMainImage(imagePath, thumbElement) {
        document.getElementById('mainDisplayImage').src = imagePath;
        document.querySelectorAll('.sd-thumb').forEach(el => el.classList.remove('active'));
        thumbElement.classList.add('active');
    }
    function openEditFromDetails(id) {
        const currentModal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
        if (currentModal) currentModal.hide();
        setTimeout(() => { openEditModal(id); }, 300);
    }
</script>
