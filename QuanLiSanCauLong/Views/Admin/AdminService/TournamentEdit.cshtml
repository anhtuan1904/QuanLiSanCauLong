@model QuanLiSanCauLong.Models.Tournament
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .te-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 0;
    }

    .te-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .te-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .te-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
    }

        .te-title em {
            font-style: italic;
            color: var(--gold);
        }

    .te-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .te-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .te-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .te-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        max-height: calc(90vh - 130px);
    }

    .te-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .te-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .te-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .te-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .te-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 80px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* Type cards */
    .ty-card {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .75rem .5rem;
        text-align: center;
        cursor: pointer;
        transition: all .22s;
        user-select: none;
        background: #fff;
    }

        .ty-card:hover {
            border-color: rgba(212,160,23,.5);
            background: var(--cream);
        }

        .ty-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .ty-card-icon {
        font-size: 1.4rem;
        margin-bottom: .3rem;
    }

    .ty-card-name {
        font-size: .72rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.3;
    }

    /* Status opts */
    .status-opts-te {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt-te {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
        user-select: none;
    }

        .status-opt-te:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt-te.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
            color: var(--deep);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* Toggle */
    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* Image */
    .img-upload-zone-te {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--cream);
        cursor: pointer;
        transition: all .25s;
        min-height: 110px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: 1.25rem;
    }

        .img-upload-zone-te:hover {
            border-color: var(--gold);
        }

        .img-upload-zone-te.has-preview {
            border-color: var(--gold);
            padding: 0;
        }

    .img-preview-te {
        width: 100%;
        height: 130px;
        object-fit: cover;
        display: none;
        border-radius: 8px;
    }

        .img-preview-te.show {
            display: block;
        }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }

    .te-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .btn-te-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-te-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-te-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-te-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }

        .btn-te-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="te-header">
    <div>
        <div class="te-header-label"><i class="bi bi-pencil-square"></i> Chỉnh sửa giải đấu</div>
        <div class="te-title">Cập Nhật <em>Giải Đấu</em></div>
        <div class="te-subtitle">Đang chỉnh sửa: <strong>@Model.TournamentName</strong></div>
    </div>
    <button type="button" class="te-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="te-body">
    <form id="frmTournamentEdit-@uid" method="post" enctype="multipart/form-data" action="/AdminService/TournamentEdit">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TournamentId" value="@Model.TournamentId" />
        <input type="hidden" name="CreatedAt" value="@Model.CreatedAt.ToString("o")" />
        <input type="hidden" name="ViewCount" value="@Model.ViewCount" />
        <input type="hidden" name="Slug" value="@Model.Slug" />
        <input type="hidden" name="CurrentPlayers" value="@Model.CurrentPlayers" />
        <input type="hidden" id="typeInputTE-@uid" name="TournamentType" value="@Model.TournamentType" />
        <input type="hidden" id="statusInputTE-@uid" name="Status" value="@Model.Status" />

        <!-- 1. THÔNG TIN -->
        <div class="te-card">
            <div class="te-card-head"><i class="bi bi-trophy"></i><span class="te-card-title">Thông Tin Giải Đấu</span></div>
            <div class="te-card-body">
                <div class="fg">
                    <label class="fg-label">Tên Giải Đấu <span class="req">*</span></label>
                    <input name="TournamentName" value="@Model.TournamentName" class="fg-input" required />
                </div>
                <div class="fg-row2 fg">
                    <div>
                        <label class="fg-label">Địa Điểm</label>
                        <input name="Venue" value="@Model.Venue" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Số VĐV Tối Đa</label>
                        <input name="MaxPlayers" type="number" value="@Model.MaxPlayers" class="fg-input" min="2" />
                    </div>
                </div>
                <div class="fg-row3 fg" style="margin-bottom:0;">
                    <div>
                        <label class="fg-label">Ngày Bắt Đầu</label>
                        <input name="StartDate" type="date" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Ngày Kết Thúc</label>
                        <input name="EndDate" type="date" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Hạn Đăng Ký</label>
                        <input name="RegistrationDeadline" type="date" value="@(Model.RegistrationDeadline?.ToString("yyyy-MM-dd"))" class="fg-input" />
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. HÌNH THỨC -->
        <div class="te-card">
            <div class="te-card-head"><i class="bi bi-people"></i><span class="te-card-title">Hình Thức Thi Đấu</span></div>
            <div class="te-card-body">
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;margin-bottom:.5rem;" id="typeCardsTE-@uid">
                    <div class="ty-card @(Model.TournamentType == "Đơn Nam" ? "selected" : "")" data-type="Đơn Nam"><div class="ty-card-icon">🏃‍♂️</div><div class="ty-card-name">Đơn Nam</div></div>
                    <div class="ty-card @(Model.TournamentType == "Đơn Nữ" ? "selected" : "")" data-type="Đơn Nữ"><div class="ty-card-icon">🏃‍♀️</div><div class="ty-card-name">Đơn Nữ</div></div>
                    <div class="ty-card @(Model.TournamentType == "Đôi Nam" ? "selected" : "")" data-type="Đôi Nam"><div class="ty-card-icon">👬</div><div class="ty-card-name">Đôi Nam</div></div>
                    <div class="ty-card @(Model.TournamentType == "Đôi Nữ" ? "selected" : "")" data-type="Đôi Nữ"><div class="ty-card-icon">👭</div><div class="ty-card-name">Đôi Nữ</div></div>
                    <div class="ty-card @(Model.TournamentType == "Đôi Mix" ? "selected" : "")" data-type="Đôi Mix"><div class="ty-card-icon">👫</div><div class="ty-card-name">Đôi Mix</div></div>
                    <div class="ty-card @(Model.TournamentType == "Đơn Nam/Nữ" ? "selected" : "")" data-type="Đơn Nam/Nữ"><div class="ty-card-icon">⚡</div><div class="ty-card-name">Đơn Nam/Nữ</div></div>
                    <div class="ty-card @(Model.TournamentType == "Đôi Tổng Hợp" ? "selected" : "")" data-type="Đôi Tổng Hợp"><div class="ty-card-icon">🏆</div><div class="ty-card-name">Đôi Tổng Hợp</div></div>
                    <div class="ty-card @(Model.TournamentType == "Khác" ? "selected" : "")" data-type="Khác"><div class="ty-card-icon">📋</div><div class="ty-card-name">Khác</div></div>
                </div>
            </div>
        </div>

        <!-- 3. GIẢI THƯỞNG -->
        <div class="te-card">
            <div class="te-card-head"><i class="bi bi-trophy-fill"></i><span class="te-card-title">Giải Thưởng & Phí</span></div>
            <div class="te-card-body">
                <div class="fg-row2 fg">
                    <div>
                        <label class="fg-label">Tổng Giải Thưởng (VNĐ)</label>
                        <input name="PrizeMoney" type="number" value="@Model.PrizeMoney" class="fg-input" step="100000" />
                    </div>
                    <div>
                        <label class="fg-label">Phí Đăng Ký (VNĐ)</label>
                        <input name="EntryFee" type="number" value="@Model.EntryFee" class="fg-input" step="10000" />
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Cơ Cấu Giải Thưởng</label>
                    <textarea name="PrizeDescription" class="fg-textarea" rows="3" placeholder="Giải Nhất: 5.000.000đ&#10;Giải Nhì: 3.000.000đ">@Model.PrizeDescription</textarea>
                </div>
            </div>
        </div>

        <!-- 4. MÔ TẢ & THỂ LỆ -->
        <div class="te-card">
            <div class="te-card-head"><i class="bi bi-file-text"></i><span class="te-card-title">Mô Tả & Thể Lệ</span></div>
            <div class="te-card-body">
                <div class="fg">
                    <label class="fg-label">Mô Tả Ngắn</label>
                    <textarea name="ShortDesc" class="fg-textarea" rows="2">@Model.ShortDesc</textarea>
                </div>
                <div class="fg">
                    <label class="fg-label">Mô Tả Chi Tiết</label>
                    <textarea name="Description" class="fg-textarea" rows="3">@Model.Description</textarea>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Thể Lệ Thi Đấu</label>
                    <textarea name="Rules" class="fg-textarea" rows="4" placeholder="- Luật 1&#10;- Luật 2">@Model.Rules</textarea>
                    <div class="fg-hint">Mỗi dòng một quy tắc</div>
                </div>
            </div>
        </div>

        <!-- 5. HÌNH ẢNH -->
        <div class="te-card">
            <div class="te-card-head"><i class="bi bi-image"></i><span class="te-card-title">Hình Ảnh Đại Diện</span></div>
            <div class="te-card-body">
                <div class="img-upload-zone-te" id="teUploadZone-@uid">
                    <img class="img-preview-te @(!string.IsNullOrEmpty(Model.FeaturedImage) ? "show" : "")"
                         id="teImgPreview-@uid" src="@(Model.FeaturedImage ?? "")" alt="Preview" />
                    <div id="tePlaceholder-@uid" style="@(!string.IsNullOrEmpty(Model.FeaturedImage) ? "display:none;" : "")display:flex;flex-direction:column;align-items:center;gap:.5rem;">
                        <i class="bi bi-cloud-arrow-up" style="font-size:1.8rem;color:var(--muted);"></i>
                        <span style="font-size:.84rem;font-weight:600;">Click để tải ảnh lên</span>
                    </div>
                    <input type="file" id="teImgInput-@uid" name="featuredImage" accept="image/*" style="display:none" />
                </div>
                <div class="img-url-row">
                    <input type="text" id="teImgUrl-@uid" name="FeaturedImage" value="@Model.FeaturedImage" class="fg-input" placeholder="Hoặc nhập URL ảnh: https://..." />
                    <button type="button" id="teBtnUrl-@uid" style="padding:.65rem 1.2rem;border:none;border-radius:7px;background:var(--gold);color:var(--deep);font-weight:700;cursor:pointer;white-space:nowrap;font-family:'Outfit',sans-serif;">✓ Áp dụng</button>
                </div>
            </div>
        </div>

        <!-- 6. TRẠNG THÁI -->
        <div class="te-card">
            <div class="te-card-head"><i class="bi bi-toggles"></i><span class="te-card-title">Trạng Thái & Cài Đặt</span></div>
            <div class="te-card-body">
                <div class="fg">
                    <label class="fg-label">Trạng Thái</label>
                    <div class="status-opts-te" id="teStatusOpts-@uid">
                        <div class="status-opt-te @(Model.Status == "Upcoming" ? "selected" : "")" data-status="Upcoming"><span class="status-dot" style="background:#7c3aed;"></span> Sắp Diễn Ra</div>
                        <div class="status-opt-te @(Model.Status == "Ongoing" ? "selected" : "")" data-status="Ongoing"><span class="status-dot" style="background:#0284c7;"></span> Đang Diễn Ra</div>
                        <div class="status-opt-te @(Model.Status == "Completed" ? "selected" : "")" data-status="Completed"><span class="status-dot" style="background:#16a34a;"></span> Đã Kết Thúc</div>
                        <div class="status-opt-te @(Model.Status == "Cancelled" ? "selected" : "")" data-status="Cancelled"><span class="status-dot" style="background:#dc2626;"></span> Đã Hủy</div>
                    </div>
                </div>
                <div class="fg-row2 fg" style="margin-bottom:.75rem;">
                    <div>
                        <label class="fg-label">Thứ Tự Hiển Thị</label>
                        <input name="DisplayOrder" type="number" value="@Model.DisplayOrder" class="fg-input" />
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <div class="toggle-row">
                        <label class="toggle-item"><input type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") /><span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span></label>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- FOOTER -->
<div class="te-footer">
    <button type="button" class="btn-te-cancel" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Hủy</button>
    <button type="button" class="btn-te-save" id="btnTournamentEditSave-@uid"><i class="bi bi-check-circle"></i> Lưu Thay Đổi</button>
</div>

<script>
    (function() {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // Type cards
        var typeCards = el('typeCardsTE');
        if (typeCards) {
            typeCards.querySelectorAll('.ty-card').forEach(function(card) {
                card.addEventListener('click', function() {
                    typeCards.querySelectorAll('.ty-card').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('typeInputTE').value = this.dataset.type;
                });
            });
        }

        // Status opts
        var statusOpts = el('teStatusOpts');
        if (statusOpts) {
            statusOpts.querySelectorAll('.status-opt-te').forEach(function(opt) {
                opt.addEventListener('click', function() {
                    statusOpts.querySelectorAll('.status-opt-te').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputTE').value = this.dataset.status;
                });
            });
        }

        // Image
        var zone = el('teUploadZone'), input = el('teImgInput');
        var preview = el('teImgPreview'), placeholder = el('tePlaceholder');
        var urlInput = el('teImgUrl'), btnUrl = el('teBtnUrl');

        function showPreview(src) {
            preview.src = src; preview.classList.add('show');
            placeholder.style.display = 'none'; zone.classList.add('has-preview');
        }
        function resetPreview() {
            preview.src = ''; preview.classList.remove('show');
            placeholder.style.display = 'flex'; zone.classList.remove('has-preview');
            input.value = ''; urlInput.value = '';
        }
        zone.addEventListener('click', function(e) {
            if (!preview.classList.contains('show')) input.click(); else resetPreview();
        });
        input.addEventListener('change', function() {
            if (!this.files[0]) return;
            var reader = new FileReader();
            reader.onload = function(ev) { showPreview(ev.target.result); urlInput.value = ''; };
            reader.readAsDataURL(this.files[0]);
        });
        btnUrl.addEventListener('click', function() {
            var url = urlInput.value.trim();
            if (url) { showPreview(url); input.value = ''; }
        });

        // Submit
        var btnSave = el('btnTournamentEditSave');
        var form = document.getElementById('frmTournamentEdit-' + UID);
        btnSave.addEventListener('click', function() {
            if (!form.checkValidity()) { form.reportValidity(); return; }
            btnSave.disabled = true;
            btnSave.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
            fetch('/AdminService/TournamentEdit', { method:'POST', body: new FormData(form) })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('modalService'))?.hide();
                        location.reload();
                    } else {
                        alert(res.message || 'Có lỗi xảy ra');
                        btnSave.disabled = false;
                        btnSave.innerHTML = '<i class="bi bi-check-circle"></i> Lưu Thay Đổi';
                    }
                });
        });
    })();
</script>
