@model QuanLiSanCauLong.Models.Course
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
    var effectivePrice = Model.DiscountFee ?? Model.TuitionFee;
    var hasDiscount = Model.DiscountFee.HasValue && Model.TuitionFee.HasValue;
    var pct = Model.MaxStudents.HasValue && Model.MaxStudents > 0
              ? Math.Min(100, (int)(Model.CurrentStudents * 100.0 / Model.MaxStudents.Value)) : 0;
    var pctColor = pct >= 90 ? "#c94b2a" : pct >= 70 ? "#d4a017" : "#16a34a";
    var isFull = Model.IsFull || Model.Status == "Full";
    var allImages = new List<string>();
    if (!string.IsNullOrEmpty(Model.FeaturedImage)) allImages.Add(Model.FeaturedImage);
    if (Model.CourseImages != null)
        allImages.AddRange(Model.CourseImages.OrderBy(i => i.DisplayOrder).Select(i => i.ImagePath));
    var highlights = new List<string>();
    if (!string.IsNullOrEmpty(Model.Highlights))
    {
        try { highlights = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Highlights) ?? new(); } catch { }
    }
}
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .cd-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .cd-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.25rem 1.75rem .9rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .cd-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .3rem;
    }

        .cd-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .cd-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.25;
        max-width: 560px;
    }

    .cd-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .cd-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .cd-body {
        padding: 1.25rem 1.75rem 1.5rem;
        overflow-y: auto;
        flex: 1;
    }

    /* GALLERY SLIDER */
    .gallery-slider {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.25rem;
        background: var(--warm);
        border: 1px solid var(--border);
    }

    .gallery-main {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
        cursor: zoom-in;
        transition: opacity .3s;
    }

        .gallery-main.loading {
            opacity: .5;
        }

    .gallery-placeholder {
        width: 100%;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
    }

    .gallery-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,.85);
        border: none;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--deep);
        font-size: .9rem;
        transition: all .2s;
    }

        .gallery-nav:hover {
            background: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,.15);
        }

        .gallery-nav.prev {
            left: 8px;
        }

        .gallery-nav.next {
            right: 8px;
        }

    .gallery-dots {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: .35rem;
    }

    .gallery-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: rgba(255,255,255,.55);
        cursor: pointer;
        transition: all .2s;
    }

        .gallery-dot.active {
            background: #fff;
            width: 20px;
            border-radius: 4px;
        }

    .gallery-counter {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,.5);
        color: #fff;
        font-size: .7rem;
        padding: .2rem .5rem;
        border-radius: 4px;
    }

    .gallery-thumbs {
        display: flex;
        gap: .4rem;
        overflow-x: auto;
        padding: .5rem 0;
        scrollbar-width: thin;
    }

        .gallery-thumbs::-webkit-scrollbar {
            height: 3px;
        }

        .gallery-thumbs::-webkit-scrollbar-track {
            background: var(--warm);
        }

        .gallery-thumbs::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 2px;
        }

    .thumb-item {
        flex-shrink: 0;
        width: 52px;
        height: 52px;
        border-radius: 6px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color .2s;
    }

        .thumb-item:hover {
            border-color: rgba(212,160,23,.5);
        }

        .thumb-item.active {
            border-color: var(--gold);
        }

        .thumb-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    /* INFO STRIP */
    .cd-strip {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.1rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .cd-badges {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        margin-top: .5rem;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .badge-active {
        background: rgba(22,163,74,.1);
        color: var(--green);
    }

    .badge-inactive {
        background: rgba(201,75,42,.1);
        color: var(--red);
    }

    .badge-full {
        background: rgba(201,75,42,.1);
        color: var(--red);
    }

    .badge-featured {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .badge-popular {
        background: rgba(239,68,68,.1);
        color: #dc2626;
    }

    .badge-level {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .cd-price-block {
        text-align: right;
        flex-shrink: 0;
    }

    .cd-price-old {
        font-size: .78rem;
        color: var(--muted);
        text-decoration: line-through;
        margin-bottom: .1rem;
    }

    .cd-price-now {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .cd-price-unit {
        font-size: .73rem;
        color: var(--muted);
    }

    .cd-discount-badge {
        display: inline-block;
        background: var(--red);
        color: #fff;
        font-size: .62rem;
        font-weight: 700;
        padding: .12rem .45rem;
        border-radius: 3px;
        margin-left: .35rem;
    }

    /* HIGHLIGHTS */
    .hl-strip {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: 1.1rem;
    }

    .hl-chip {
        background: rgba(212,160,23,.12);
        border: 1px solid rgba(212,160,23,.3);
        border-radius: 20px;
        padding: .3rem .75rem;
        font-size: .78rem;
        color: var(--deep);
    }

    /* GRID */
    .cd-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .75rem;
        margin-bottom: 1.1rem;
    }

    .cd-grid-item {
        background: var(--warm);
        padding: .9rem 1rem;
        border-radius: 8px;
        border: 1px solid var(--border);
    }

    .cd-grid-label {
        font-size: .65rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: .3rem;
    }

    .cd-grid-val {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
    }

    /* PROGRESS */
    .cd-progress {
        margin-bottom: 1.1rem;
    }

    .cd-progress-label {
        display: flex;
        justify-content: space-between;
        font-size: .72rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .cd-progress-bg {
        height: 8px;
        background: var(--border);
        border-radius: 4px;
        overflow: hidden;
    }

    .cd-progress-bar {
        height: 8px;
        border-radius: 4px;
        transition: width 1s;
    }

    /* SECTION */
    .cd-section {
        margin-bottom: 1.1rem;
    }

    .cd-section-label {
        font-size: .67rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-bottom: .6rem;
        padding-bottom: .4rem;
        border-bottom: 1px solid var(--border);
    }

    .cd-text {
        font-size: .87rem;
        color: var(--deep);
        line-height: 1.65;
        white-space: pre-wrap;
    }

    .cd-feature-list {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .cd-feature-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        font-size: .85rem;
        color: var(--deep);
    }

        .cd-feature-item i {
            color: var(--green);
            font-size: .9rem;
            flex-shrink: 0;
            margin-top: .1rem;
        }

    .cd-outcomes-list {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .cd-outcome-item {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        font-size: .85rem;
        color: var(--deep);
    }

        .cd-outcome-item i {
            color: var(--gold);
            font-size: .9rem;
            flex-shrink: 0;
            margin-top: .1rem;
        }

    /* INSTRUCTOR */
    .instructor-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.1rem;
    }

    .instructor-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--gold);
        flex-shrink: 0;
    }

    .instructor-avatar-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: rgba(212,160,23,.15);
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .instructor-name {
        font-weight: 700;
        font-size: .92rem;
        color: var(--deep);
    }

    .instructor-title {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    /* VIDEO */
    .video-embed {
        margin-bottom: 1.1rem;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .video-embed iframe {
            width: 100%;
            height: 200px;
            display: block;
            border: none;
        }

    /* META */
    .cd-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-top: .9rem;
        border-top: 1px solid var(--border);
    }

    .cd-meta-item {
        font-size: .74rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .cd-meta-item strong {
            color: var(--deep);
        }

        .cd-meta-item i {
            color: var(--gold);
        }

    /* FOOTER */
    .cd-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        flex-shrink: 0;
    }

    .btn-cd-close {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-cd-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-cd-edit {
        padding: .65rem 1.6rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-cd-edit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<div class="cd-wrapper">
    <!-- HEADER -->
    <div class="cd-header">
        <div>
            <div class="cd-header-label"><i class="bi bi-mortarboard-fill"></i> Chi Tiết Khóa Học</div>
            <div class="cd-title">@Model.CourseName</div>
        </div>
        <button type="button" class="cd-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- BODY -->
    <div class="cd-body">

        <!-- GALLERY SLIDER -->
        @if (allImages.Any())
        {
            <div class="gallery-slider" id="slider-@uid">
                <img class="gallery-main" id="mainImg-@uid" src="@allImages[0]" alt="@Model.CourseName" />
                @if (allImages.Count > 1)
                {
                    <button class="gallery-nav prev" id="prevBtn-@uid"><i class="bi bi-chevron-left"></i></button>
                    <button class="gallery-nav next" id="nextBtn-@uid"><i class="bi bi-chevron-right"></i></button>
                    <div class="gallery-dots" id="dots-@uid">
                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <div class="gallery-dot @(i == 0 ? "active" : "")" data-idx="@i"></div>
                        }
                    </div>
                    <div class="gallery-counter" id="counter-@uid">1 / @allImages.Count</div>
                }
            </div>
            @if (allImages.Count > 1)
            {
                <div class="gallery-thumbs" id="thumbs-@uid" style="margin-top:-1rem;margin-bottom:1.25rem;">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="thumb-item @(i == 0 ? "active" : "")" data-idx="@i">
                            <img src="@allImages[i]" alt="" />
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div style="background:var(--warm);border:1px solid var(--border);border-radius:12px;height:180px;display:flex;align-items:center;justify-content:center;color:var(--muted);margin-bottom:1.25rem;">
                <div style="text-align:center;"><i class="bi bi-mortarboard" style="font-size:3rem;opacity:.25;"></i><br /><span style="font-size:.8rem;">Chưa có ảnh</span></div>
            </div>
        }

        <!-- INFO STRIP -->
        <div class="cd-strip">
            <div>
                <div style="font-weight:700;font-size:.96rem;color:var(--deep);">@Model.CourseName</div>
                <div class="cd-badges">
                    @if (isFull)
                    {
                        <span class="badge-pill badge-full">⊗ Đã đầy</span>
                    }
                    else if (Model.Status == "Active")
                    {

                        <span class="badge-pill badge-active">● Hoạt động</span>
                    }
                    else
                    {

                        <span class="badge-pill badge-inactive">○ Ngừng</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Level))
                    {
                        var lvl = Model.Level switch { "Beginner" => "🌱 Cơ Bản", "Intermediate" => "🏸 Trung Cấp", "Advanced" => "🏆 Nâng Cao", "All" => "👥 Tất Cả", _ => Model.Level };
                        <span class="badge-pill badge-level">@lvl</span>
                    }
                    @if (Model.IsFeatured)
                    {
                        <span class="badge-pill badge-featured">⭐ Nổi bật</span>
                    }
                    @if (Model.IsPopular)
                    {
                        <span class="badge-pill badge-popular">🔥 Hot</span>
                    }
                </div>
            </div>
            @if (effectivePrice.HasValue)
            {
                <div class="cd-price-block">
                    @if (hasDiscount)
                    {
                        <div class="cd-price-old">@Model.TuitionFee!.Value.ToString("N0")đ</div>
                        <div class="cd-price-now">
                            @Model.DiscountFee!.Value.ToString("N0")đ
                            <span class="cd-discount-badge">-@(((Model.TuitionFee - Model.DiscountFee) / Model.TuitionFee * 100)!.Value.ToString("N0"))%</span>
                        </div>
                    }
                    else
                    {
                        <div class="cd-price-now">@effectivePrice.Value.ToString("N0")đ</div>
                    }
                    <div class="cd-price-unit">/khóa học</div>
                </div>
            }
        </div>

        <!-- HIGHLIGHTS BADGES -->
        @if (highlights.Any())
        {
            <div class="hl-strip">
                @foreach (var hl in highlights)
                {
                    <span class="hl-chip">⚡ @hl</span>
                }
            </div>
        }

        <!-- INSTRUCTOR -->
        @if (!string.IsNullOrEmpty(Model.Instructor))
        {
            <div class="instructor-card">
                @if (!string.IsNullOrEmpty(Model.InstructorAvatar))
                {
                    <img class="instructor-avatar" src="@Model.InstructorAvatar" alt="@Model.Instructor" />
                }
                else
                {
                    <div class="instructor-avatar-placeholder"><i class="bi bi-person-fill"></i></div>
                }
                <div>
                    <div class="instructor-name">@Model.Instructor</div>
                    @if (!string.IsNullOrEmpty(Model.InstructorTitle))
                    {
                        <div class="instructor-title"><i class="bi bi-patch-check-fill text-warning me-1"></i>@Model.InstructorTitle</div>
                    }
                </div>
            </div>
        }

        <!-- THÔNG TIN GRID -->
        <div class="cd-grid">
            <div class="cd-grid-item">
                <span class="cd-grid-label"><i class="bi bi-calendar3 me-1"></i>Lịch Học</span>
                <span class="cd-grid-val" style="font-size:.82rem;">@(Model.Schedule ?? "—")</span>
            </div>
            <div class="cd-grid-item">
                <span class="cd-grid-label"><i class="bi bi-clock me-1"></i>Thời Lượng</span>
                <span class="cd-grid-val">@(Model.DurationWeeks != null ? Model.DurationWeeks + " tuần" : "—")</span>
            </div>
            <div class="cd-grid-item">
                <span class="cd-grid-label"><i class="bi bi-people me-1"></i>Sĩ Số</span>
                <span class="cd-grid-val">@Model.CurrentStudents / @(Model.MaxStudents?.ToString() ?? "∞")</span>
            </div>
            <div class="cd-grid-item">
                <span class="cd-grid-label"><i class="bi bi-eye me-1"></i>Lượt Xem</span>
                <span class="cd-grid-val">@Model.ViewCount.ToString("N0")</span>
            </div>
        </div>

        <!-- PROGRESS -->
        @if (Model.MaxStudents.HasValue && Model.MaxStudents > 0)
        {
            <div class="cd-progress">
                <div class="cd-progress-label">
                    <span>Tỷ lệ lấp đầy lớp</span>
                    <span style="font-weight:700;color:var(--deep);">
                        @pct%
                        @if (isFull)
                        {
                            <span style="color:var(--red);">— Đã đầy</span>
                        }
                        else
                        {

                            <span style="color:var(--muted);">— Còn @Model.AvailableSlots chỗ</span>
                        }
                    </span>
                </div>
                <div class="cd-progress-bg">
                    <div class="cd-progress-bar" style="width:@pct%;background:@pctColor;"></div>
                </div>
            </div>
        }

        <!-- VIDEO -->
        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            var ytM = System.Text.RegularExpressions.Regex.Match(Model.VideoUrl, @"(?:youtube\.com/watch\?v=|youtu\.be/)([^&?#]+)");
            if (ytM.Success)
            {
                <div class="cd-section">
                    <div class="cd-section-label"><i class="bi bi-play-circle-fill"></i>Video Giới Thiệu Khóa Học</div>
                    <div class="video-embed">
                        <iframe src="https://www.youtube.com/embed/@ytM.Groups[1].Value" allowfullscreen></iframe>
                    </div>
                </div>
            }
        }

        <!-- MÔ TẢ NGẮN -->
        @if (!string.IsNullOrEmpty(Model.ShortDesc))
        {
            <div class="cd-section">
                <div class="cd-section-label"><i class="bi bi-chat-quote"></i>Mô Tả Ngắn</div>
                <div class="cd-text" style="color:var(--muted);">@Model.ShortDesc</div>
            </div>
        }

        <!-- MÔ TẢ CHI TIẾT -->
        <div class="cd-section">
            <div class="cd-section-label"><i class="bi bi-file-text"></i>Mô Tả Chi Tiết</div>
            <div class="cd-text">@Model.Description</div>
        </div>

        <!-- TÍNH NĂNG -->
        @if (!string.IsNullOrEmpty(Model.Features))
        {
            <div class="cd-section">
                <div class="cd-section-label"><i class="bi bi-check2-all"></i>Tính Năng & Ưu Điểm</div>
                <div class="cd-feature-list">
                    @foreach (var f in Model.Features.Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)))
                    {
                        <div class="cd-feature-item"><i class="bi bi-check-circle-fill"></i><span>@f.Trim().TrimStart('-').Trim()</span></div>
                    }
                </div>
            </div>
        }

        <!-- YÊU CẦU -->
        @if (!string.IsNullOrEmpty(Model.Requirements))
        {
            <div class="cd-section">
                <div class="cd-section-label"><i class="bi bi-clipboard-check"></i>Yêu Cầu Đầu Vào</div>
                <div class="cd-feature-list">
                    @foreach (var r in Model.Requirements.Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)))
                    {
                        <div class="cd-feature-item">
                            <i class="bi bi-info-circle-fill" style="color:var(--muted);"></i>
                            <span>@r.Trim().TrimStart('-').Trim()</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- KẾT QUẢ -->
        @if (!string.IsNullOrEmpty(Model.Outcomes))
        {
            <div class="cd-section">
                <div class="cd-section-label"><i class="bi bi-trophy-fill"></i>Sau Khóa Học Đạt Được</div>
                <div class="cd-outcomes-list">
                    @foreach (var o in Model.Outcomes.Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)))
                    {
                        <div class="cd-outcome-item"><i class="bi bi-star-fill"></i><span>@o.Trim().TrimStart('-').Trim()</span></div>
                    }
                </div>
            </div>
        }

        <!-- META -->
        <div class="cd-meta">
            <div class="cd-meta-item"><i class="bi bi-calendar-plus"></i>Tạo: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></div>
            <div class="cd-meta-item"><i class="bi bi-pencil-square"></i>Cập nhật: <strong>@Model.UpdatedAt.ToString("dd/MM/yyyy")</strong></div>
            @if (!string.IsNullOrEmpty(Model.Slug))
            {
                <div class="cd-meta-item"><i class="bi bi-link-45deg"></i>Slug: <strong>@Model.Slug</strong></div>
            }
            <div class="cd-meta-item"><i class="bi bi-sort-numeric-down"></i>Thứ tự: <strong>#@Model.DisplayOrder</strong></div>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="cd-footer">
        <button type="button" class="btn-cd-close" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Đóng</button>
        <button type="button" class="btn-cd-edit" onclick="openCourseEditFromDetail(@Model.CourseId)">
            <i class="bi bi-pencil"></i> Chỉnh Sửa
        </button>
    </div>
</div>

<script>
    (function(){
        var UID = '@uid';
        var images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allImages));
        var current = 0;

        function goTo(idx) {
            if (images.length <= 1) return;
            current = (idx + images.length) % images.length;
            var mainImg = document.getElementById('mainImg-' + UID);
            if (mainImg) { mainImg.classList.add('loading'); mainImg.src = images[current]; mainImg.onload = function(){ mainImg.classList.remove('loading'); }; }
            // dots
            var dots = document.querySelectorAll('#dots-' + UID + ' .gallery-dot');
            dots.forEach(function(d,i){ d.classList.toggle('active', i===current); });
            // counter
            var counter = document.getElementById('counter-' + UID);
            if (counter) counter.textContent = (current+1) + ' / ' + images.length;
            // thumbs
            var thumbs = document.querySelectorAll('#thumbs-' + UID + ' .thumb-item');
            thumbs.forEach(function(t,i){ t.classList.toggle('active', i===current); });
        }

        var prev = document.getElementById('prevBtn-' + UID);
        var next = document.getElementById('nextBtn-' + UID);
        if (prev) prev.addEventListener('click', function(){ goTo(current-1); });
        if (next) next.addEventListener('click', function(){ goTo(current+1); });
        document.querySelectorAll('#dots-' + UID + ' .gallery-dot').forEach(function(d){
            d.addEventListener('click', function(){ goTo(parseInt(this.dataset.idx)); });
        });
        document.querySelectorAll('#thumbs-' + UID + ' .thumb-item').forEach(function(t){
            t.addEventListener('click', function(){ goTo(parseInt(this.dataset.idx)); });
        });
    })();

    function openCourseEditFromDetail(id) {
        var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
        if (modal) modal.hide();
        setTimeout(function(){ if (typeof openModal==='function') openModal('/AdminService/CourseEdit/'+id); }, 300);
    }
</script>
