@model QuanLiSanCauLong.Models.StringingService
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    * {
        font-family: 'Outfit', sans-serif;
        box-sizing: border-box;
    }

    .ss-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .ss-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .ss-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .ss-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .ss-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .ss-title em {
            font-style: italic;
            color: var(--gold);
        }

    .ss-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .ss-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .ss-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .ss-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .ss-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .ss-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .ss-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .ss-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .ss-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row32 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: var(--red);
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* BRAND CARDS */
    .brand-cards {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: .55rem;
    }

    .br-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .6rem .5rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
        user-select: none;
    }

        .br-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .br-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
        }

        .br-card .br-name {
            font-size: .75rem;
            font-weight: 700;
            color: var(--deep);
        }

        .br-card .br-logo {
            font-size: 1.1rem;
            margin-bottom: .2rem;
        }

    /* TENSION SLIDER */
    .tension-slider-row {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

        .tension-slider-row input[type=range] {
            flex: 1;
            accent-color: var(--gold);
        }

    .tension-display {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--deep);
        min-width: 60px;
        text-align: center;
    }

    /* STATUS */
    .status-opts {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 500;
        transition: all .2s;
        user-select: none;
    }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            font-weight: 700;
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        cursor: pointer;
    }

    .toggle-label {
        font-size: .84rem;
        color: var(--deep);
    }

    /* BENEFIT TAGS */
    .benefit-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .5rem;
        margin-top: .5rem;
    }

    .benefit-chip {
        border: 1.5px solid var(--border);
        border-radius: 20px;
        padding: .4rem .8rem;
        font-size: .78rem;
        cursor: pointer;
        text-align: center;
        transition: all .2s;
        user-select: none;
        color: var(--muted);
    }

        .benefit-chip:hover {
            border-color: rgba(212,160,23,.5);
            color: var(--deep);
        }

        .benefit-chip.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.12);
            color: var(--deep);
            font-weight: 600;
        }

    /* FEATURED IMAGE */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        min-height: 160px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: border-color .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
        }

        .img-upload-zone.has-preview {
            border-style: solid;
            border-color: var(--gold);
        }

    .img-preview-ss {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

        .img-preview-ss.show {
            display: block;
        }

    .img-upload-inner-ss {
        text-align: center;
        padding: 2rem 1rem;
        pointer-events: none;
    }

    .upload-icon {
        font-size: 2rem;
        color: var(--gold);
        margin-bottom: .5rem;
    }

    .upload-text {
        font-size: .84rem;
        color: var(--muted);
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .65rem;
    }

        .img-url-row .fg-input {
            flex: 1;
        }

    .btn-url-confirm {
        padding: .65rem 1rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-url-confirm:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
        }

    /* GALLERY */
    .gallery-drop-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        margin-bottom: .75rem;
    }

        .gallery-drop-zone:hover, .gallery-drop-zone.drag-over {
            border-color: var(--gold);
            background: rgba(212,160,23,.05);
        }

        .gallery-drop-zone .dz-icon {
            font-size: 1.75rem;
            color: var(--gold);
        }

        .gallery-drop-zone .dz-text {
            font-size: .84rem;
            color: var(--muted);
            margin-top: .4rem;
        }

        .gallery-drop-zone .dz-sub {
            font-size: .7rem;
            color: var(--muted);
            margin-top: .2rem;
        }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .6rem;
    }

    .gallery-thumb {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--border);
        background: var(--warm);
    }

        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .gallery-thumb .thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.45);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            opacity: 0;
            transition: opacity .2s;
        }

        .gallery-thumb:hover .thumb-overlay {
            opacity: 1;
        }

    .thumb-btn {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
    }

        .thumb-btn.del {
            background: var(--red);
            color: #fff;
        }

        .thumb-btn.primary {
            background: var(--gold);
            color: var(--deep);
        }

    .gallery-thumb.is-primary::after {
        content: '★ Chính';
        position: absolute;
        top: 4px;
        left: 4px;
        background: var(--gold);
        color: var(--deep);
        font-size: .6rem;
        font-weight: 700;
        padding: .15rem .4rem;
        border-radius: 3px;
    }

    .gallery-count {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    /* VIDEO */
    .video-preview {
        margin-top: .65rem;
        border-radius: 8px;
        overflow: hidden;
        display: none;
    }

        .video-preview.show {
            display: block;
        }

        .video-preview iframe {
            width: 100%;
            height: 180px;
            border: none;
            border-radius: 8px;
        }

    /* FOOTER */
    .ss-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .75rem;
        padding: 1rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        flex-shrink: 0;
    }

    .btn-cancel {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    .btn-save {
        padding: .7rem 1.75rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

        .btn-save:disabled {
            opacity: .6;
            transform: none;
            cursor: not-allowed;
        }

    .spin {
        width: 28px;
        height: 28px;
        border: 3px solid var(--warm);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin .7s linear infinite;
        margin: 0 auto .75rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="ss-wrapper">
    <!-- HEADER -->
    <div class="ss-header">
        <div>
            <div class="ss-header-label"><i class="bi bi-tools"></i> Căng Vợt</div>
            <div class="ss-title">Thêm Dịch Vụ <em>Căng Vợt</em></div>
            <div class="ss-subtitle">Ảnh đẹp + thông số đầy đủ giúp khách chọn nhanh hơn</div>
        </div>
        <button class="ss-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- BODY -->
    <div class="ss-body">
        <form id="frmStringingCreate-@uid" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="ss-card">
                <div class="ss-card-head"><i class="bi bi-info-circle-fill"></i><span class="ss-card-title">Thông Tin Dịch Vụ</span></div>
                <div class="ss-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Dịch Vụ <span class="req">*</span></label>
                        <input name="ServiceName" class="fg-input" required maxlength="200"
                               placeholder="VD: Căng Vợt Yonex BG65 — Bền Bỉ, Đa Năng" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <input name="ShortDesc" class="fg-input" maxlength="300"
                               placeholder="Câu mô tả ngắn gọn, hấp dẫn hiển thị trên thẻ..." />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="3" required
                                  placeholder="Giải thích dòng dây, cảm giác đánh, phù hợp lối chơi nào..."></textarea>
                    </div>
                </div>
            </div>

            <!-- 2. THƯƠNG HIỆU & MODEL -->
            <div class="ss-card">
                <div class="ss-card-head"><i class="bi bi-patch-check-fill"></i><span class="ss-card-title">Thương Hiệu & Model Dây</span></div>
                <div class="ss-card-body">
                    <div class="fg">
                        <label class="fg-label">Thương Hiệu</label>
                        <div class="brand-cards" id="brandCards-@uid">
                            <div class="br-card" data-brand="Yonex"><div class="br-logo">🟡</div><div class="br-name">Yonex</div></div>
                            <div class="br-card" data-brand="Victor"><div class="br-logo">🔵</div><div class="br-name">Victor</div></div>
                            <div class="br-card" data-brand="Li-Ning"><div class="br-logo">🔴</div><div class="br-name">Li-Ning</div></div>
                            <div class="br-card" data-brand="Apacs"><div class="br-logo">⚫</div><div class="br-name">Apacs</div></div>
                            <div class="br-card" data-brand="Khác"><div class="br-logo">📦</div><div class="br-name">Khác</div></div>
                        </div>
                        <input type="hidden" name="Brand" id="brandInput-@uid" value="" />
                    </div>
                    <div class="fg fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Model Dây</label>
                            <input name="StringModel" class="fg-input" maxlength="100"
                                   placeholder="VD: BG65, Aerobite, Turbo Nano..." />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="0" min="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. THÔNG SỐ KỸ THUẬT -->
            <div class="ss-card">
                <div class="ss-card-head"><i class="bi bi-sliders"></i><span class="ss-card-title">Thông Số Kỹ Thuật — Khách Hàng Muốn Biết</span></div>
                <div class="ss-card-body">
                    <div class="fg fg-row4">
                        <div>
                            <label class="fg-label">Giá (VNĐ) <span class="req">*</span></label>
                            <input name="Price" type="number" class="fg-input" required min="0" step="5000" placeholder="150,000" />
                        </div>
                        <div>
                            <label class="fg-label">Giá KM (VNĐ)</label>
                            <input name="DiscountPrice" type="number" class="fg-input" min="0" step="5000" placeholder="" />
                        </div>
                        <div>
                            <label class="fg-label">Thời Gian (phút)</label>
                            <input name="DurationMinutes" type="number" class="fg-input" min="5" placeholder="30" />
                        </div>
                        <div>
                            <label class="fg-label">Bảo Hành (ngày)</label>
                            <input name="WarrantyDays" type="number" class="fg-input" min="0" placeholder="30" />
                        </div>
                    </div>

                    <!-- Tension Range Slider -->
                    <div class="fg">
                        <label class="fg-label">Lực Căng (lbs)</label>
                        <div class="fg-row2">
                            <div>
                                <label style="font-size:.7rem;color:var(--muted);">Tối thiểu</label>
                                <input name="TensionMin" id="tensionMin-@uid" type="number" class="fg-input" min="10" max="35" placeholder="20" />
                            </div>
                            <div>
                                <label style="font-size:.7rem;color:var(--muted);">Tối đa</label>
                                <input name="TensionMax" id="tensionMax-@uid" type="number" class="fg-input" min="10" max="35" placeholder="28" />
                            </div>
                        </div>
                        <input name="Tension" type="hidden" id="tensionHidden-@uid" />
                        <div class="fg-hint">VD: 20–28 lbs. Lực căng cao → kiểm soát tốt | Lực căng thấp → lực đánh mạnh hơn</div>
                    </div>

                    <div class="fg fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Độ Dày Dây (Gauge)</label>
                            <select name="StringGauge" class="fg-select">
                                <option value="">— Chọn độ dày —</option>
                                <option value="0.61mm">0.61mm (Mỏng — cảm giác tốt)</option>
                                <option value="0.63mm">0.63mm</option>
                                <option value="0.65mm">0.65mm</option>
                                <option value="0.66mm">0.66mm (Standard)</option>
                                <option value="0.68mm">0.68mm</option>
                                <option value="0.70mm">0.70mm (Bền)</option>
                                <option value="0.72mm">0.72mm (Rất bền)</option>
                            </select>
                        </div>
                        <div>
                            <label class="fg-label">Màu Dây</label>
                            <input name="StringColor" class="fg-input" maxlength="50"
                                   placeholder="VD: Trắng, Vàng, Đỏ..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. NỘI DUNG THU HÚT -->
            <div class="ss-card">
                <div class="ss-card-head"><i class="bi bi-stars"></i><span class="ss-card-title">Lợi Ích & Tính Năng — Thu Hút Khách Chọn</span></div>
                <div class="ss-card-body">
                    <!-- BENEFIT CHIPS -->
                    <div class="fg">
                        <label class="fg-label">⚡ Lợi Ích Chính (chọn nhiều)</label>
                        <div class="benefit-grid" id="benefitGrid-@uid">
                            <div class="benefit-chip" data-v="Smash mạnh hơn">💪 Smash mạnh hơn</div>
                            <div class="benefit-chip" data-v="Kiểm soát hướng cầu">🎯 Kiểm soát tốt</div>
                            <div class="benefit-chip" data-v="Cảm giác cầu rõ">✋ Cảm giác rõ</div>
                            <div class="benefit-chip" data-v="Độ bền cao">🛡️ Độ bền cao</div>
                            <div class="benefit-chip" data-v="Ít đứt dây">🔗 Ít đứt dây</div>
                            <div class="benefit-chip" data-v="Phù hợp mọi lối chơi">🔄 Đa năng</div>
                            <div class="benefit-chip" data-v="Tốc độ cao">⚡ Tốc độ cao</div>
                            <div class="benefit-chip" data-v="Phòng thủ tốt">🛡️ Phòng thủ tốt</div>
                            <div class="benefit-chip" data-v="Dành cho người mới">🌱 Người mới</div>
                        </div>
                        <input type="hidden" name="Benefits" id="benefitsInput-@uid" value="" />
                    </div>

                    <!-- TÍNH NĂNG CHI TIẾT -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">✅ Tính Năng Chi Tiết</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Dây đan chéo kép tăng độ bền 30%&#10;- Lực căng ổn định sau 6 tháng sử dụng&#10;- Màu sắc đa dạng, phù hợp nhiều loại vợt&#10;- Thợ căng dây chuyên nghiệp, bảo hành 30 ngày"></textarea>
                        <div class="fg-hint">Mỗi dòng một điểm, bắt đầu bằng "-". Thêm số liệu cụ thể sẽ thuyết phục hơn.</div>
                    </div>
                </div>
            </div>

            <!-- 5. HÌNH ẢNH & VIDEO -->
            <div class="ss-card">
                <div class="ss-card-head"><i class="bi bi-images"></i><span class="ss-card-title">Hình Ảnh & Video Demo</span></div>
                <div class="ss-card-body">
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone" id="ssUploadZone-@uid">
                            <img class="img-preview-ss" id="imgPreviewSS-@uid" src="" alt="Preview" />
                            <div class="img-upload-inner-ss" id="uploadInnerSS-@uid">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để tải ảnh lên</strong> hoặc kéo thả</div>
                                <div id="imgNameSS-@uid" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                            </div>
                        </div>
                        <input type="file" id="imgInputSS-@uid" name="featuredImage" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="imgUrlSS-@uid" name="FeaturedImage" class="fg-input"
                                   placeholder="Hoặc nhập URL ảnh..." />
                            <button type="button" class="btn-url-confirm" id="btnUrlSS-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                    </div>

                    <!-- GALLERY -->
                    <div class="fg">
                        <label class="fg-label">
                            <i class="bi bi-grid-3x3-gap-fill me-1"></i>Thư Viện Ảnh
                            <span style="font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0;"> — ảnh vợt trước/sau căng, ảnh thợ đang làm...</span>
                        </label>
                        <div class="gallery-drop-zone" id="galleryDrop-@uid">
                            <div class="dz-icon"><i class="bi bi-images"></i></div>
                            <div class="dz-text"><strong>Click hoặc kéo thả nhiều ảnh</strong></div>
                            <div class="dz-sub">Ảnh thực tế sẽ tăng lòng tin của khách hàng</div>
                        </div>
                        <input type="file" id="galleryFileInput-@uid" name="galleryImages" accept="image/*" multiple style="display:none" />
                        <div class="gallery-grid" id="galleryGrid-@uid"></div>
                        <div class="gallery-count" id="galleryCount-@uid"></div>
                    </div>

                    <!-- VIDEO -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-play-circle-fill me-1"></i>Video Demo Căng Dây</label>
                        <div style="display:flex;gap:.5rem;align-items:flex-start;">
                            <input type="text" name="VideoUrl" id="videoUrlInput-@uid" class="fg-input"
                                   placeholder="https://www.youtube.com/watch?v=..." />
                            <button type="button" class="btn-url-confirm" id="btnVideoPreview-@uid">
                                <i class="bi bi-play"></i> Xem thử
                            </button>
                        </div>
                        <div class="video-preview" id="videoPreview-@uid">
                            <iframe id="videoIframe-@uid" src="" allowfullscreen></iframe>
                        </div>
                        <div class="fg-hint">Video quy trình căng dây thực tế giúp khách an tâm đặt dịch vụ</div>
                    </div>
                </div>
            </div>

            <!-- 6. TRẠNG THÁI -->
            <div class="ss-card">
                <div class="ss-card-head"><i class="bi bi-toggles"></i><span class="ss-card-title">Trạng Thái & Hiển Thị</span></div>
                <div class="ss-card-body">
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="ssStatusOpts-@uid">
                            <div class="status-opt selected" data-status="Active">
                                <span class="status-dot" style="background:var(--green);"></span> Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInputSS-@uid" value="Active" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <div class="toggle-row">
                            <label class="toggle-item">
                                <input name="IsFeatured" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span>
                            </label>
                            <label class="toggle-item">
                                <input name="IsPopular" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Phổ biến</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="ss-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-save" id="btnStringingSubmit-@uid"
                data-form="frmStringingCreate-@uid" data-url="/AdminService/StringingCreate">
            <i class="bi bi-plus-circle"></i> Thêm Dịch Vụ
        </button>
    </div>

</div>

<script>
    (function () {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // BRAND CARDS
        var brandCards = el('brandCards');
        if (brandCards) {
            brandCards.querySelectorAll('.br-card').forEach(function (card) {
                card.addEventListener('click', function () {
                    brandCards.querySelectorAll('.br-card').forEach(function (c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('brandInput').value = this.dataset.brand;
                });
            });
        }

        // STATUS OPTS
        var ssStatusOpts = el('ssStatusOpts');
        if (ssStatusOpts) {
            ssStatusOpts.querySelectorAll('.status-opt').forEach(function (opt) {
                opt.addEventListener('click', function () {
                    ssStatusOpts.querySelectorAll('.status-opt').forEach(function (c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputSS').value = this.dataset.status;
                });
            });
        }

        // TENSION sync
        var tensionMin = el('tensionMin'), tensionMax = el('tensionMax'), tensionHidden = el('tensionHidden');
        function syncTension() {
            if (!tensionHidden) return;
            var min = tensionMin ? tensionMin.value : '';
            var max = tensionMax ? tensionMax.value : '';
            tensionHidden.value = (min && max) ? min + '-' + max + ' lbs' : (min || max ? (min || max) + ' lbs' : '');
        }
        if (tensionMin) tensionMin.addEventListener('input', syncTension);
        if (tensionMax) tensionMax.addEventListener('input', syncTension);

        // BENEFIT CHIPS
        var benefitGrid = el('benefitGrid'), benefitsInput = el('benefitsInput');
        var selectedBenefits = [];
        if (benefitGrid) {
            benefitGrid.querySelectorAll('.benefit-chip').forEach(function (chip) {
                chip.addEventListener('click', function () {
                    this.classList.toggle('selected');
                    selectedBenefits = Array.from(benefitGrid.querySelectorAll('.benefit-chip.selected')).map(function (c) { return c.dataset.v; });
                    if (benefitsInput) benefitsInput.value = selectedBenefits.join('\n');
                });
            });
        }

        // FEATURED IMAGE
        var uploadZone = el('ssUploadZone'), fileInput = el('imgInputSS');
        var imgPreview = el('imgPreviewSS'), uploadInner = el('uploadInnerSS');
        function showPreview(src) {
            if (!imgPreview) return;
            imgPreview.src = src; imgPreview.classList.add('show');
            if (uploadInner) uploadInner.style.display = 'none';
            if (uploadZone) uploadZone.classList.add('has-preview');
        }
        function resetPreview() {
            if (!imgPreview) return;
            imgPreview.src = ''; imgPreview.classList.remove('show');
            if (uploadInner) uploadInner.style.display = '';
            if (uploadZone) uploadZone.classList.remove('has-preview');
        }
        if (uploadZone && fileInput) {
            uploadZone.addEventListener('click', function (e) {
                if (e.target === imgPreview) { resetPreview(); fileInput.value = ''; return; }
                fileInput.click();
            });
            fileInput.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                var nameEl = el('imgNameSS');
                if (nameEl) nameEl.textContent = this.files[0].name;
                var reader = new FileReader();
                reader.onload = function (ev) { showPreview(ev.target.result); };
                reader.readAsDataURL(this.files[0]);
            });
        }
        var btnUrlSS = el('btnUrlSS'), imgUrlInput = el('imgUrlSS');
        if (btnUrlSS && imgUrlInput) {
            btnUrlSS.addEventListener('click', function () {
                var url = imgUrlInput.value.trim();
                if (!url) { resetPreview(); return; }
                showPreview(url);
                if (fileInput) fileInput.value = '';
            });
        }

        // GALLERY
        var galleryDrop = el('galleryDrop'), galleryInput = el('galleryFileInput');
        var galleryGrid = el('galleryGrid'), galleryCount = el('galleryCount');
        var galleryFiles = [], MAX_GALLERY = 10;

        function renderGalleryGrid() {
            if (!galleryGrid) return;
            galleryGrid.innerHTML = '';
            galleryFiles.forEach(function (file, idx) {
                var thumb = document.createElement('div');
                thumb.className = 'gallery-thumb' + (idx === 0 ? ' is-primary' : '');
                thumb.innerHTML = '<img src="" alt=""><div class="thumb-overlay">' +
                    '<button type="button" class="thumb-btn primary" title="Đặt làm ảnh chính"><i class="bi bi-star-fill"></i></button>' +
                    '<button type="button" class="thumb-btn del" title="Xóa"><i class="bi bi-trash3-fill"></i></button></div>';
                var img = thumb.querySelector('img');
                var reader = new FileReader();
                reader.onload = function (ev) { img.src = ev.target.result; };
                reader.readAsDataURL(file);
                thumb.querySelector('.thumb-btn.del').addEventListener('click', function () { galleryFiles.splice(idx, 1); renderGalleryGrid(); rebuildFileInput(); });
                thumb.querySelector('.thumb-btn.primary').addEventListener('click', function () { var f = galleryFiles.splice(idx, 1)[0]; galleryFiles.unshift(f); renderGalleryGrid(); rebuildFileInput(); });
                galleryGrid.appendChild(thumb);
            });
            if (galleryCount) galleryCount.textContent = galleryFiles.length > 0 ? galleryFiles.length + ' ảnh đã thêm' : '';
        }
        function addGalleryFiles(files) {
            Array.from(files).forEach(function (file) {
                if (!file.type.startsWith('image/')) return;
                if (file.size > 5 * 1024 * 1024) { alert(file.name + ' quá 5MB, bỏ qua.'); return; }
                if (galleryFiles.length >= MAX_GALLERY) { alert('Tối đa ' + MAX_GALLERY + ' ảnh.'); return; }
                galleryFiles.push(file);
            });
            renderGalleryGrid(); rebuildFileInput();
        }
        function rebuildFileInput() {
            if (!galleryInput) return;
            var dt = new DataTransfer();
            galleryFiles.forEach(function (f) { dt.items.add(f); });
            galleryInput.files = dt.files;
        }
        if (galleryDrop && galleryInput) {
            galleryDrop.addEventListener('click', function () { galleryInput.click(); });
            galleryInput.addEventListener('change', function () { addGalleryFiles(this.files); this.value = ''; });
            galleryDrop.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('drag-over'); });
            galleryDrop.addEventListener('dragleave', function () { this.classList.remove('drag-over'); });
            galleryDrop.addEventListener('drop', function (e) { e.preventDefault(); this.classList.remove('drag-over'); addGalleryFiles(e.dataTransfer.files); });
        }

        // VIDEO PREVIEW
        var btnVideoPreview = el('btnVideoPreview'), videoUrlInput = el('videoUrlInput');
        var videoPreview = el('videoPreview'), videoIframe = el('videoIframe');
        if (btnVideoPreview && videoIframe) {
            btnVideoPreview.addEventListener('click', function () {
                var url = videoUrlInput ? videoUrlInput.value.trim() : '';
                if (!url) { videoPreview && videoPreview.classList.remove('show'); return; }
                var match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);
                if (match) { videoIframe.src = 'https://www.youtube.com/embed/' + match[1]; videoPreview && videoPreview.classList.add('show'); }
                else { alert('Chỉ hỗ trợ xem thử YouTube.'); }
            });
        }

        // SUBMIT
        var btnSubmit = el('btnStringingSubmit');
        if (btnSubmit) {
            btnSubmit.addEventListener('click', function () {
                var formId = this.dataset.form, url = this.dataset.url;
                var form = document.getElementById(formId);
                if (!form) return;
                if (!form.checkValidity()) { form.reportValidity(); return; }
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
                if (typeof submitServiceForm === 'function') {
                    submitServiceForm(formId, url);
                } else {
                    fetch(url, { method: 'POST', body: new FormData(form) })
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.success) {
                                var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                if (modal) modal.hide();
                                location.reload();
                            } else {
                                alert(res.message || 'Có lỗi xảy ra.');
                                btnSubmit.disabled = false;
                                btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Dịch Vụ';
                            }
                        })
                        .catch(function (err) {
                            alert('Lỗi kết nối: ' + err.message);
                            btnSubmit.disabled = false;
                            btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Dịch Vụ';
                        });
                }
            });
        }
    })();
</script>
