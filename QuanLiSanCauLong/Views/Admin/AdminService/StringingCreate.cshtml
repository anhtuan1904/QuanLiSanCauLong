@model QuanLiSanCauLong.Models.StringingService
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .ss-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .ss-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .ss-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .ss-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .ss-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .ss-title em {
            font-style: italic;
            color: var(--gold);
        }

    .ss-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .ss-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .ss-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .ss-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .ss-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .ss-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .ss-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .ss-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .ss-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row32 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* BRAND CARDS */
    .brand-cards {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: .55rem;
    }

    .br-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .6rem .5rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .br-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .br-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .br-name {
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        margin-top: .25rem;
    }

    .br-logo {
        font-size: 1.1rem;
    }

    /* STATUS */
    .status-opts {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
    }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
            color: var(--deep);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* TOGGLES */
    .toggle-row {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* IMAGE UPLOAD */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 1.5rem;
        background: var(--cream);
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        position: relative;
        overflow: hidden;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

        .img-upload-zone.has-preview {
            border-color: var(--gold);
            padding: 0;
        }

    .img-preview-ss {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        display: none;
    }

        .img-preview-ss.show {
            display: block;
        }

    .img-upload-inner-ss {
        padding: 1.5rem;
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }

        .img-url-row .fg-input {
            flex: 1;
            font-size: .8rem;
        }

    .btn-url-confirm {
        padding: .5rem .9rem;
        background: var(--gold);
        border: none;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        font-family: 'Outfit',sans-serif;
    }

    .upload-icon {
        font-size: 1.8rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .upload-text {
        font-size: .82rem;
        color: var(--muted);
    }

        .upload-text strong {
            color: var(--deep);
        }

    /* FOOTER */
    .ss-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
    }

    .btn-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- WRAPPER -->
<div class="ss-wrapper">

    <!-- HEADER -->
    <div class="ss-header">
        <div>
            <div class="ss-header-label"><i class="bi bi-tools"></i> Dịch vụ mới</div>
            <div class="ss-title">Thêm <em>Căng Vợt</em></div>
            <div class="ss-subtitle">Tạo dịch vụ căng dây vợt cầu lông mới</div>
        </div>
        <button type="button" class="ss-close" data-bs-dismiss="modal">
            <i class="bi bi-x" style="font-size:1.1rem;"></i>
        </button>
    </div>

    <div class="ss-body">
        <form id="frmStringingCreate-@uid" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="ss-card">
                <div class="ss-card-head">
                    <i class="bi bi-info-circle"></i>
                    <span class="ss-card-title">Thông Tin Dịch Vụ</span>
                </div>
                <div class="ss-card-body">
                    <div class="fg-row32 fg">
                        <div>
                            <label class="fg-label">Tên Dịch Vụ <span class="req">*</span></label>
                            <input name="ServiceName" class="fg-input" placeholder="VD: Căng Vợt Yonex BG80" required />
                        </div>
                        <div>
                            <label class="fg-label">Model Dây</label>
                            <input name="StringModel" class="fg-input" placeholder="VD: BG80, VS850..." />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="0" />
                        </div>
                    </div>
                    <div class="fg fg-row3">
                        <div>
                            <label class="fg-label">Giá Dịch Vụ (VNĐ)</label>
                            <input name="Price" type="number" class="fg-input" placeholder="150.000" />
                        </div>
                        <div>
                            <label class="fg-label">Thời Gian (phút)</label>
                            <input name="DurationMinutes" type="number" class="fg-input" placeholder="30" />
                        </div>
                        <div>
                            <label class="fg-label">Bảo Hành (ngày)</label>
                            <input name="WarrantyDays" type="number" class="fg-input" placeholder="7" />
                        </div>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Lực Căng Hỗ Trợ</label>
                        <input name="Tension" class="fg-input" placeholder="VD: 20–30 lbs" />
                    </div>
                </div>
            </div>

            <!-- 2. THƯƠNG HIỆU -->
            <div class="ss-card">
                <div class="ss-card-head">
                    <i class="bi bi-patch-check"></i>
                    <span class="ss-card-title">Thương Hiệu Dây</span>
                </div>
                <div class="ss-card-body">
                    <input name="Brand" type="hidden" id="brandInput-@uid" value="" />
                    <div class="brand-cards" id="brandCards-@uid">
                        <div class="br-card" data-brand="Yonex">
                            <div class="br-logo">🏸</div>
                            <div class="br-name">Yonex</div>
                        </div>
                        <div class="br-card" data-brand="Victor">
                            <div class="br-logo">⚡</div>
                            <div class="br-name">Victor</div>
                        </div>
                        <div class="br-card" data-brand="Lining">
                            <div class="br-logo">🔥</div>
                            <div class="br-name">Lining</div>
                        </div>
                        <div class="br-card" data-brand="Apacs">
                            <div class="br-logo">🎯</div>
                            <div class="br-name">Apacs</div>
                        </div>
                        <div class="br-card" data-brand="Khác">
                            <div class="br-logo">📦</div>
                            <div class="br-name">Khác</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. MÔ TẢ & TÍNH NĂNG -->
            <div class="ss-card">
                <div class="ss-card-head">
                    <i class="bi bi-file-text"></i>
                    <span class="ss-card-title">Mô Tả & Tính Năng</span>
                </div>
                <div class="ss-card-body">
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <textarea name="ShortDesc" class="fg-textarea" rows="2" placeholder="Mô tả ngắn gọn về dịch vụ..."></textarea>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="3"
                                  placeholder="Mô tả đặc điểm, ưu điểm của dây và dịch vụ..." required></textarea>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Tính Năng Nổi Bật</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Độ bền cao, ít đứt dây&#10;- Tăng lực đánh smash mạnh&#10;- Kiểm soát hướng cầu chính xác"></textarea>
                        <div class="fg-hint">Mỗi dòng một tính năng, bắt đầu bằng dấu "-"</div>
                    </div>
                </div>
            </div>

            <!-- 4. HÌNH ẢNH & TRẠNG THÁI -->
            <div class="ss-card">
                <div class="ss-card-head">
                    <i class="bi bi-toggles"></i>
                    <span class="ss-card-title">Hình Ảnh & Trạng Thái</span>
                </div>
                <div class="ss-card-body">
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone" id="ssUploadZone-@uid">
                            <img class="img-preview-ss" id="imgPreviewSS-@uid" src="" alt="Preview" />
                            <div class="img-upload-inner-ss" id="uploadInnerSS-@uid">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để tải ảnh lên</strong> hoặc kéo thả</div>
                                <div id="imgNameSS-@uid" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                            </div>
                        </div>
                        <input type="file" id="imgInputSS-@uid" name="featuredImageFile" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="imgUrlSS-@uid" name="FeaturedImage" class="fg-input"
                                   placeholder="Hoặc nhập URL ảnh: https://..." />
                            <button type="button" class="btn-url-confirm" id="btnUrlSS-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                        <div class="fg-hint">Upload file hoặc nhập URL rồi nhấn Áp dụng</div>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="ssStatusOpts-@uid">
                            <div class="status-opt selected" data-status="Active">
                                <span class="status-dot" style="background:#16a34a;"></span> Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInputSS-@uid" value="Active" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Cài Đặt Hiển Thị</label>
                        <div class="toggle-row">
                            <label class="toggle-item">
                                <input name="IsFeatured" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span>
                            </label>
                            <label class="toggle-item">
                                <input name="IsPopular" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Phổ biến</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="ss-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-save" id="btnStringingSubmit-@uid"
                data-form="frmStringingCreate-@uid" data-url="/AdminService/StringingCreate">
            <i class="bi bi-plus-circle"></i> Thêm Dịch Vụ
        </button>
    </div><!-- /ss-wrapper -->

    <script>
        (function() {
            var UID = '@uid';
            function el(id) { return document.getElementById(id + '-' + UID); }

            // ── BRAND CARDS ──────────────────────────────────────
            var brandCards = el('brandCards');
            if (brandCards) {
                brandCards.querySelectorAll('.br-card').forEach(function(card) {
                    card.addEventListener('click', function() {
                        brandCards.querySelectorAll('.br-card').forEach(function(c) { c.classList.remove('selected'); });
                        this.classList.add('selected');
                        el('brandInput').value = this.dataset.brand;
                    });
                });
            }

            // ── STATUS OPTS ──────────────────────────────────────
            var ssStatusOpts = el('ssStatusOpts');
            if (ssStatusOpts) {
                ssStatusOpts.querySelectorAll('.status-opt').forEach(function(opt) {
                    opt.addEventListener('click', function() {
                        ssStatusOpts.querySelectorAll('.status-opt').forEach(function(c) { c.classList.remove('selected'); });
                        this.classList.add('selected');
                        el('statusInputSS').value = this.dataset.status;
                    });
                });
            }

            // ── IMAGE UPLOAD (file) ───────────────────────────────
            var uploadZone  = el('ssUploadZone');
            var fileInput   = el('imgInputSS');
            var imgPreview  = el('imgPreviewSS');
            var uploadInner = el('uploadInnerSS');

            function showPreview(src) {
                if (!imgPreview) return;
                imgPreview.src = src;
                imgPreview.classList.add('show');
                if (uploadInner) uploadInner.style.display = 'none';
                if (uploadZone)  uploadZone.classList.add('has-preview');
            }
            function resetPreview() {
                if (!imgPreview) return;
                imgPreview.src = '';
                imgPreview.classList.remove('show');
                if (uploadInner) uploadInner.style.display = '';
                if (uploadZone)  uploadZone.classList.remove('has-preview');
            }

            if (uploadZone && fileInput) {
                uploadZone.addEventListener('click', function(e) {
                    if (e.target === imgPreview) { resetPreview(); fileInput.value = ''; return; }
                    fileInput.click();
                });
                fileInput.addEventListener('change', function() {
                    if (!this.files || !this.files[0]) return;
                    var nameEl = el('imgNameSS');
                    if (nameEl) nameEl.textContent = this.files[0].name;
                    var reader = new FileReader();
                    reader.onload = function(ev) { showPreview(ev.target.result); };
                    reader.readAsDataURL(this.files[0]);
                });
            }

            // ── IMAGE URL ─────────────────────────────────────────
            var btnUrlSS   = el('btnUrlSS');
            var imgUrlInput = el('imgUrlSS');
            if (btnUrlSS && imgUrlInput) {
                btnUrlSS.addEventListener('click', function() {
                    var url = imgUrlInput.value.trim();
                    if (!url) { resetPreview(); return; }
                    showPreview(url);
                    if (fileInput) fileInput.value = '';
                });
                imgUrlInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') { e.preventDefault(); btnUrlSS.click(); }
                });
            }

            // ── SUBMIT ────────────────────────────────────────────
            var btnSubmit = el('btnStringingSubmit');
            if (btnSubmit) {
                btnSubmit.addEventListener('click', function() {
                    var formId = this.dataset.form;
                    var url    = this.dataset.url;
                    var form   = document.getElementById(formId);
                    if (!form) return;
                    if (!form.checkValidity()) { form.reportValidity(); return; }
                    btnSubmit.disabled = true;
                    btnSubmit.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
                    if (typeof submitServiceForm === 'function') {
                        submitServiceForm(formId, url);
                    } else {
                        fetch(url, { method: 'POST', body: new FormData(form) })
                            .then(function(r) { return r.json(); })
                            .then(function(res) {
                                if (res.success) {
                                    var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                    if (modal) modal.hide();
                                    location.reload();
                                } else {
                                    alert(res.message || 'Có lỗi xảy ra.');
                                    btnSubmit.disabled = false;
                                    btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Dịch Vụ';
                                }
                            })
                            .catch(function(err) {
                                alert('Lỗi kết nối: ' + err.message);
                                btnSubmit.disabled = false;
                                btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Dịch Vụ';
                            });
                    }
                });
            }
        })();
    </script>
