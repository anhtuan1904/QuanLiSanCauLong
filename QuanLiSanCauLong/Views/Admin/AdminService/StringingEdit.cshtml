@model QuanLiSanCauLong.Models.StringingService
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
    var benefitList = new List<string>();
    if (!string.IsNullOrEmpty(Model.Benefits))
        benefitList = Model.Benefits.Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x.Trim()).ToList();
}

<style>
    :root{--deep:#1a1209;--gold:#d4a017;--gold2:#f5c842;--cream:#fdf8f0;--warm:#f5ede0;--border:#e8ddd0;--muted:#8a7560;--green:#16a34a;--red:#c94b2a;}
    *{font-family:'Outfit',sans-serif;box-sizing:border-box;}
    .sse-wrapper{display:flex;flex-direction:column;max-height:90vh;overflow:hidden;}
    .sse-header{display:flex;align-items:flex-start;justify-content:space-between;padding:1.5rem 1.75rem 1rem;flex-shrink:0;border-bottom:1px solid var(--border);background:#fff;}
    .sse-header-label{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem;}
    .sse-header-label::before{content:'';width:14px;height:1px;background:var(--gold);}
    .sse-title{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--deep);}
    .sse-title em{font-style:italic;color:var(--gold);}
    .sse-subtitle{font-size:.82rem;color:var(--muted);margin-top:.2rem;}
    .sse-close{width:32px;height:32px;border:1px solid var(--border);border-radius:6px;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:all .2s;flex-shrink:0;}
    .sse-close:hover{border-color:var(--deep);color:var(--deep);}
    .sse-body{padding:1.25rem 1.75rem 1rem;overflow-y:auto;flex:1;}
    .sse-card{background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:1.1rem;}
    .sse-card-head{padding:.85rem 1.25rem;border-bottom:1px solid var(--border);background:var(--warm);display:flex;align-items:center;gap:.55rem;}
    .sse-card-head i{color:var(--gold);font-size:.9rem;}
    .sse-card-title{font-size:.67rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
    .sse-card-body{padding:1.25rem;}
    .fg{margin-bottom:1.1rem;}.fg:last-child{margin-bottom:0;}
    .fg-row2{display:grid;grid-template-columns:1fr 1fr;gap:.9rem;}
    .fg-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.9rem;}
    .fg-row4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.9rem;}
    .fg-label{display:block;font-size:.71rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:.45rem;}
    .fg-label .req{color:var(--red);}
    .fg-input,.fg-select,.fg-textarea{width:100%;padding:.65rem 1rem;border:1.5px solid var(--border);border-radius:7px;font-family:'Outfit',sans-serif;font-size:.86rem;color:var(--deep);background:#fff;outline:none;transition:border-color .2s;}
    .fg-input:focus,.fg-select:focus,.fg-textarea:focus{border-color:var(--gold);background:var(--cream);}
    .fg-textarea{resize:vertical;}
    .fg-hint{font-size:.7rem;color:var(--muted);margin-top:.3rem;}

    /* BRAND CARDS */
    .brand-cards{display:grid;grid-template-columns:repeat(5,1fr);gap:.55rem;}
    .br-card{border:1.5px solid var(--border);border-radius:8px;padding:.6rem .5rem;cursor:pointer;transition:all .2s;text-align:center;user-select:none;}
    .br-card:hover{border-color:rgba(212,160,23,.5);}
    .br-card.selected{border-color:var(--gold);background:rgba(212,160,23,.1);}
    .br-card .br-logo{font-size:1.1rem;margin-bottom:.2rem;}
    .br-card .br-name{font-size:.75rem;font-weight:700;color:var(--deep);}

    /* BENEFIT CHIPS */
    .benefit-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin-top:.5rem;}
    .benefit-chip{border:1.5px solid var(--border);border-radius:20px;padding:.4rem .8rem;font-size:.78rem;cursor:pointer;text-align:center;transition:all .2s;user-select:none;color:var(--muted);}
    .benefit-chip:hover{border-color:rgba(212,160,23,.5);color:var(--deep);}
    .benefit-chip.selected{border-color:var(--gold);background:rgba(212,160,23,.12);color:var(--deep);font-weight:600;}

    /* STATUS */
    .status-opts{display:flex;gap:.65rem;flex-wrap:wrap;}
    .status-opt{display:flex;align-items:center;gap:.45rem;padding:.55rem 1rem;border:1.5px solid var(--border);border-radius:7px;cursor:pointer;font-size:.82rem;font-weight:500;transition:all .2s;user-select:none;}
    .status-opt.selected{border-color:var(--gold);background:rgba(212,160,23,.08);font-weight:700;}
    .status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .toggle-row{display:flex;gap:1rem;flex-wrap:wrap;}
    .toggle-item{display:flex;align-items:center;gap:.5rem;cursor:pointer;}
    .toggle-label{font-size:.84rem;color:var(--deep);}

    /* IMAGE */
    .img-upload-zone{border:2px dashed var(--border);border-radius:10px;background:var(--warm);min-height:150px;cursor:pointer;position:relative;overflow:hidden;transition:border-color .2s;display:flex;align-items:center;justify-content:center;}
    .img-upload-zone:hover{border-color:var(--gold);}
    .img-upload-zone.has-preview{border-style:solid;border-color:var(--gold);}
    .img-preview{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none;}
    .img-preview.show{display:block;}
    .img-upload-inner{text-align:center;padding:2rem 1rem;pointer-events:none;}
    .upload-icon{font-size:2rem;color:var(--gold);margin-bottom:.5rem;}
    .upload-text{font-size:.84rem;color:var(--muted);}
    .img-url-row{display:flex;gap:.5rem;margin-top:.65rem;}
    .img-url-row .fg-input{flex:1;}
    .btn-url-confirm{padding:.65rem 1rem;background:var(--warm);border:1.5px solid var(--border);border-radius:7px;font-size:.82rem;font-weight:600;color:var(--deep);cursor:pointer;white-space:nowrap;transition:all .2s;}
    .btn-url-confirm:hover{border-color:var(--gold);background:rgba(212,160,23,.1);}

    /* GALLERY */
    .gallery-drop-zone{border:2px dashed var(--border);border-radius:10px;background:var(--warm);padding:1.2rem;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:.75rem;}
    .gallery-drop-zone:hover,.gallery-drop-zone.drag-over{border-color:var(--gold);background:rgba(212,160,23,.05);}
    .gallery-drop-zone .dz-icon{font-size:1.5rem;color:var(--gold);}
    .gallery-drop-zone .dz-text{font-size:.82rem;color:var(--muted);margin-top:.3rem;}
    .gallery-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:.5rem;}
    .gallery-thumb{position:relative;aspect-ratio:1;border-radius:7px;overflow:hidden;border:2px solid var(--border);background:var(--warm);}
    .gallery-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
    .gallery-thumb .thumb-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;}
    .gallery-thumb:hover .thumb-overlay{opacity:1;}
    .thumb-btn{width:26px;height:26px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.72rem;}
    .thumb-btn.del{background:var(--red);color:#fff;}
    .gallery-thumb.existing .del-existing{position:absolute;top:3px;right:3px;background:var(--red);color:#fff;border:none;border-radius:50%;width:22px;height:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.65rem;}

    /* VIDEO */
    .video-preview{margin-top:.65rem;border-radius:8px;overflow:hidden;display:none;}
    .video-preview.show{display:block;}
    .video-preview iframe{width:100%;height:175px;border:none;border-radius:8px;}

    /* FOOTER */
    .sse-footer{display:flex;align-items:center;justify-content:flex-end;gap:.75rem;padding:1rem 1.75rem;border-top:1px solid var(--border);background:var(--warm);flex-shrink:0;}
    .btn-sse-cancel{padding:.65rem 1.25rem;border:1.5px solid var(--border);border-radius:7px;background:#fff;font-size:.84rem;font-weight:600;color:var(--muted);cursor:pointer;display:flex;align-items:center;gap:.4rem;transition:all .2s;}
    .btn-sse-cancel:hover{border-color:var(--muted);color:var(--deep);}
    .btn-sse-save{padding:.7rem 1.75rem;background:linear-gradient(135deg,var(--gold),var(--gold2));border:none;border-radius:7px;font-family:'Outfit',sans-serif;font-size:.86rem;font-weight:700;color:var(--deep);cursor:pointer;display:flex;align-items:center;gap:.45rem;transition:all .25s;}
    .btn-sse-save:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(212,160,23,.35);}
    .btn-sse-save:disabled{opacity:.6;transform:none;cursor:not-allowed;}
</style>

<div class="sse-wrapper">
    <div class="sse-header">
        <div>
            <div class="sse-header-label"><i class="bi bi-tools"></i> Chỉnh Sửa Căng Vợt</div>
            <div class="sse-title">Sửa: <em>@Model.ServiceName.Substring(0,Math.Min(40,Model.ServiceName.Length))@(Model.ServiceName.Length>40?"…":"")</em></div>
            <div class="sse-subtitle">ID: #@Model.StringingId · Tạo @Model.CreatedAt.ToString("dd/MM/yyyy")</div>
        </div>
        <button class="sse-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <div class="sse-body">
        <form id="frmStringEdit-@uid" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" name="StringingId" value="@Model.StringingId" />

            <!-- 1. THÔNG TIN -->
            <div class="sse-card">
                <div class="sse-card-head"><i class="bi bi-info-circle-fill"></i><span class="sse-card-title">Thông Tin Dịch Vụ</span></div>
                <div class="sse-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Dịch Vụ <span class="req">*</span></label>
                        <input name="ServiceName" class="fg-input" required maxlength="200" value="@Model.ServiceName" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <input name="ShortDesc" class="fg-input" maxlength="300" value="@Model.ShortDesc" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="3" required>@Model.Description</textarea>
                    </div>
                </div>
            </div>

            <!-- 2. THƯƠNG HIỆU -->
            <div class="sse-card">
                <div class="sse-card-head"><i class="bi bi-patch-check-fill"></i><span class="sse-card-title">Thương Hiệu & Model</span></div>
                <div class="sse-card-body">
                    <div class="fg">
                        <label class="fg-label">Thương Hiệu</label>
                        <div class="brand-cards" id="brandCardsSE-@uid">
                            @foreach (var b in new[]{"Yonex","Victor","Li-Ning","Apacs","Khác"})
                            {
                                var logos = new Dictionary<string,string>{{"Yonex","🟡"},{"Victor","🔵"},{"Li-Ning","🔴"},{"Apacs","⚫"},{"Khác","📦"}};
                                <div class="br-card @(Model.Brand==b?"selected":"")" data-brand="@b">
                                    <div class="br-logo">@logos[b]</div><div class="br-name">@b</div>
                                </div>
                            }
                        </div>
                        <input type="hidden" name="Brand" id="brandInputSE-@uid" value="@Model.Brand" />
                    </div>
                    <div class="fg fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Model Dây</label>
                            <input name="StringModel" class="fg-input" value="@Model.StringModel" maxlength="100" placeholder="BG65, Aerobite..." />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="@Model.DisplayOrder" min="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. THÔNG SỐ KỸ THUẬT -->
            <div class="sse-card">
                <div class="sse-card-head"><i class="bi bi-sliders"></i><span class="sse-card-title">Thông Số Kỹ Thuật</span></div>
                <div class="sse-card-body">
                    <div class="fg fg-row4">
                        <div>
                            <label class="fg-label">Giá (VNĐ) <span class="req">*</span></label>
                            <input name="Price" type="number" class="fg-input" required value="@Model.Price" min="0" step="5000" />
                        </div>
                        <div>
                            <label class="fg-label">Giá KM</label>
                            <input name="DiscountPrice" type="number" class="fg-input" value="@Model.DiscountPrice" min="0" step="5000" />
                        </div>
                        <div>
                            <label class="fg-label">Thời Gian (phút)</label>
                            <input name="DurationMinutes" type="number" class="fg-input" value="@Model.DurationMinutes" min="5" />
                        </div>
                        <div>
                            <label class="fg-label">Bảo Hành (ngày)</label>
                            <input name="WarrantyDays" type="number" class="fg-input" value="@Model.WarrantyDays" min="0" />
                        </div>
                    </div>
                    <div class="fg fg-row2">
                        <div>
                            <label class="fg-label">Lực Căng Tối Thiểu (lbs)</label>
                            <input name="TensionMin" id="tensionMinSE-@uid" type="number" class="fg-input" value="@Model.TensionMin" min="10" max="35" />
                        </div>
                        <div>
                            <label class="fg-label">Lực Căng Tối Đa (lbs)</label>
                            <input name="TensionMax" id="tensionMaxSE-@uid" type="number" class="fg-input" value="@Model.TensionMax" min="10" max="35" />
                        </div>
                    </div>
                    <input name="Tension" type="hidden" id="tensionHiddenSE-@uid" value="@Model.Tension" />
                    <div class="fg fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Độ Dày Dây (Gauge)</label>
                            <select name="StringGauge" class="fg-select">
                                <option value="">— Chọn —</option>
                                @foreach (var g in new[] { "0.61mm", "0.63mm", "0.65mm", "0.66mm", "0.68mm", "0.70mm", "0.72mm" })
                                {
                                    <option value="@g" selected="@(Model.StringGauge == g)">@g</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="fg-label">Màu Dây</label>
                            <input name="StringColor" class="fg-input" value="@Model.StringColor" maxlength="50" placeholder="Trắng, Vàng, Đỏ..." />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. LỢI ÍCH & TÍNH NĂNG -->
            <div class="sse-card">
                <div class="sse-card-head"><i class="bi bi-stars"></i><span class="sse-card-title">Lợi Ích & Tính Năng</span></div>
                <div class="sse-card-body">
                    <div class="fg">
                        <label class="fg-label">⚡ Lợi Ích Chính</label>
                        <div class="benefit-grid" id="benefitGridSE-@uid">
                            @{
                                var allBenefits = new[]{"Smash mạnh hơn","Kiểm soát hướng cầu","Cảm giác cầu rõ","Độ bền cao","Ít đứt dây","Phù hợp mọi lối chơi","Tốc độ cao","Phòng thủ tốt","Dành cho người mới"};
                                var benefitIcons = new[]{"💪","🎯","✋","🛡️","🔗","🔄","⚡","🛡️","🌱"};
                                for (int i = 0; i < allBenefits.Length; i++) {
                                    var isSelected = benefitList.Contains(allBenefits[i]);
                                    <div class="benefit-chip @(isSelected?"selected":"")" data-v="@allBenefits[i]">@benefitIcons[i] @allBenefits[i]</div>
                                }
                            }
                        </div>
                        <input type="hidden" name="Benefits" id="benefitsInputSE-@uid" value="@Model.Benefits" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">✅ Tính Năng Chi Tiết</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Mỗi dòng một tính năng...">@Model.Features</textarea>
                    </div>
                </div>
            </div>

            <!-- 5. HÌNH ẢNH & VIDEO -->
            <div class="sse-card">
                <div class="sse-card-head"><i class="bi bi-images"></i><span class="sse-card-title">Hình Ảnh & Video</span></div>
                <div class="sse-card-body">
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone @(!string.IsNullOrEmpty(Model.FeaturedImage)?"has-preview":"")" id="sseUploadZone-@uid">
                            <img class="img-preview @(!string.IsNullOrEmpty(Model.FeaturedImage)?"show":"")"
                                 id="sseImgPreview-@uid" src="@(Model.FeaturedImage??"")" alt="Preview" />
                            <div class="img-upload-inner" id="sseUploadInner-@uid"
                                 style="@(!string.IsNullOrEmpty(Model.FeaturedImage)?"display:none;":"")">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để đổi ảnh</strong></div>
                            </div>
                        </div>
                        <input type="file" id="sseImgInput-@uid" name="featuredImage" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="sseImgUrl-@uid" name="FeaturedImage" class="fg-input"
                                   value="@Model.FeaturedImage" placeholder="Hoặc nhập URL mới..." />
                            <button type="button" class="btn-url-confirm" id="sseBtnUrl-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                    </div>

                    @if (Model.StringingImages != null && Model.StringingImages.Any())
                    {
                        <div class="fg">
                            <label class="fg-label">Gallery Hiện Tại</label>
                            <div class="gallery-grid" id="existingGallerySE-@uid">
                                @foreach (var img in Model.StringingImages.OrderBy(i => i.DisplayOrder))
                                {
                                    <div class="gallery-thumb existing @(img.IsPrimary?"is-primary":"")" data-img-id="@img.ImageId">
                                        <img src="@img.ImagePath" alt="Gallery" />
                                        <button type="button" class="del-existing" onclick="deleteStringingImage(@img.ImageId, this)">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="fg">
                        <label class="fg-label"><i class="bi bi-plus-circle me-1"></i>Thêm Ảnh Mới</label>
                        <div class="gallery-drop-zone" id="galleryDropSE-@uid">
                            <div class="dz-icon"><i class="bi bi-images"></i></div>
                            <div class="dz-text">Click hoặc kéo thả · tối đa 5MB/ảnh</div>
                        </div>
                        <input type="file" id="galleryFileInputSE-@uid" name="galleryImages" accept="image/*" multiple style="display:none" />
                        <div class="gallery-grid" id="galleryGridSE-@uid"></div>
                        <div id="galleryCountSE-@uid" style="font-size:.72rem;color:var(--muted);margin-top:.3rem;"></div>
                    </div>

                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-play-circle-fill me-1"></i>Video Demo</label>
                        <div style="display:flex;gap:.5rem;">
                            <input type="text" name="VideoUrl" id="videoUrlSE-@uid" class="fg-input"
                                   value="@Model.VideoUrl" placeholder="https://www.youtube.com/watch?v=..." />
                            <button type="button" class="btn-url-confirm" id="btnVideoSE-@uid">
                                <i class="bi bi-play"></i> Xem
                            </button>
                        </div>
                        <div class="video-preview @(!string.IsNullOrEmpty(Model.VideoUrl)?"show":"")" id="videoPreviewSE-@uid">
                            @if (!string.IsNullOrEmpty(Model.VideoUrl)) {
                                var m = System.Text.RegularExpressions.Regex.Match(Model.VideoUrl, @"(?:youtube\.com/watch\?v=|youtu\.be/)([^&?#]+)");
                                if (m.Success) { <iframe id="videoIframeSE-@uid" src="https://www.youtube.com/embed/@m.Groups[1].Value" allowfullscreen></iframe> }
                                else { <iframe id="videoIframeSE-@uid" src="" allowfullscreen></iframe> }
                            } else { <iframe id="videoIframeSE-@uid" src="" allowfullscreen></iframe> }
                        </div>
                    </div>
                </div>
            </div>

            <!-- 6. TRẠNG THÁI -->
            <div class="sse-card">
                <div class="sse-card-head"><i class="bi bi-toggles"></i><span class="sse-card-title">Trạng Thái & Hiển Thị</span></div>
                <div class="sse-card-body">
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="sseStatusOpts-@uid">
                            <div class="status-opt @(Model.Status=="Active"?"selected":"")" data-status="Active">
                                <span class="status-dot" style="background:var(--green);"></span> Hoạt Động
                            </div>
                            <div class="status-opt @(Model.Status=="Inactive"?"selected":"")" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInputSE-@uid" value="@Model.Status" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <div class="toggle-row">
                            <label class="toggle-item">
                                <input type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured?"checked":"") />
                                <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span>
                            </label>
                            <label class="toggle-item">
                                <input type="checkbox" name="IsPopular" value="true" @(Model.IsPopular?"checked":"") />
                                <span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Phổ biến</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="sse-footer">
        <button type="button" class="btn-sse-cancel" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Hủy</button>
        <button type="button" class="btn-sse-save" id="btnStringEditSave-@uid"><i class="bi bi-check-circle"></i> Lưu Thay Đổi</button>
    </div>
</div>

<script>
(function(){
    var UID = '@uid';
    function el(id){ return document.getElementById(id+'-'+UID); }

    // BRAND
    var brandCards = el('brandCardsSE');
    if(brandCards){brandCards.querySelectorAll('.br-card').forEach(function(c){c.addEventListener('click',function(){brandCards.querySelectorAll('.br-card').forEach(function(x){x.classList.remove('selected');});this.classList.add('selected');el('brandInputSE').value=this.dataset.brand;});});}

    // TENSION SYNC
    var tMin=el('tensionMinSE'),tMax=el('tensionMaxSE'),tHid=el('tensionHiddenSE');
    function syncTension(){if(tHid){var min=tMin?tMin.value:'';var max=tMax?tMax.value:'';tHid.value=(min&&max)?min+'-'+max+' lbs':(min||max?(min||max)+' lbs':'');}}
    if(tMin)tMin.addEventListener('input',syncTension);
    if(tMax)tMax.addEventListener('input',syncTension);

    // BENEFIT CHIPS
    var bgSE=el('benefitGridSE'),biSE=el('benefitsInputSE');
    if(bgSE){bgSE.querySelectorAll('.benefit-chip').forEach(function(c){c.addEventListener('click',function(){this.classList.toggle('selected');var sel=Array.from(bgSE.querySelectorAll('.benefit-chip.selected')).map(function(x){return x.dataset.v;});if(biSE)biSE.value=sel.join('\n');});});}

    // STATUS
    var ssOpts=el('sseStatusOpts');
    if(ssOpts){ssOpts.querySelectorAll('.status-opt').forEach(function(o){o.addEventListener('click',function(){ssOpts.querySelectorAll('.status-opt').forEach(function(x){x.classList.remove('selected');});this.classList.add('selected');el('statusInputSE').value=this.dataset.status;});});}

    // FEATURED IMAGE
    var zone=el('sseUploadZone'),inp=el('sseImgInput'),prev=el('sseImgPreview'),inner=el('sseUploadInner');
    function showP(src){prev.src=src;prev.classList.add('show');if(inner)inner.style.display='none';zone.classList.add('has-preview');}
    function resetP(){prev.src='';prev.classList.remove('show');if(inner)inner.style.display='';zone.classList.remove('has-preview');}
    if(zone&&inp){
        zone.addEventListener('click',function(e){if(e.target===prev){resetP();inp.value='';return;}inp.click();});
        inp.addEventListener('change',function(){if(!this.files||!this.files[0])return;var r=new FileReader();r.onload=function(ev){showP(ev.target.result);};r.readAsDataURL(this.files[0]);});
    }
    var btnUrl=el('sseBtnUrl'),urlInp=el('sseImgUrl');
    if(btnUrl&&urlInp){btnUrl.addEventListener('click',function(){var url=urlInp.value.trim();if(url){showP(url);if(inp)inp.value='';}else resetP();});}

    // NEW GALLERY
    var gDrop=el('galleryDropSE'),gInp=el('galleryFileInputSE'),gGrid=el('galleryGridSE'),gCount=el('galleryCountSE');
    var gFiles=[],MAX_G=10;
    function renderGNew(){if(!gGrid)return;gGrid.innerHTML='';gFiles.forEach(function(f,i){var t=document.createElement('div');t.className='gallery-thumb';t.innerHTML='<img src="" alt=""><div class="thumb-overlay"><button type="button" class="thumb-btn del"><i class="bi bi-trash3-fill"></i></button></div>';var r=new FileReader();r.onload=function(ev){t.querySelector('img').src=ev.target.result;};r.readAsDataURL(f);t.querySelector('.thumb-btn.del').addEventListener('click',function(){gFiles.splice(i,1);renderGNew();rebuildG();});gGrid.appendChild(t);});if(gCount)gCount.textContent=gFiles.length>0?'Sẽ thêm '+gFiles.length+' ảnh':'';}
    function addGFiles(files){Array.from(files).forEach(function(f){if(!f.type.startsWith('image/'))return;if(f.size>5*1024*1024){alert(f.name+' quá 5MB');return;}if(gFiles.length>=MAX_G){alert('Tối đa '+MAX_G+' ảnh');return;}gFiles.push(f);});renderGNew();rebuildG();}
    function rebuildG(){if(!gInp)return;var dt=new DataTransfer();gFiles.forEach(function(f){dt.items.add(f);});gInp.files=dt.files;}
    if(gDrop&&gInp){gDrop.addEventListener('click',function(){gInp.click();});gInp.addEventListener('change',function(){addGFiles(this.files);this.value='';});gDrop.addEventListener('dragover',function(e){e.preventDefault();this.classList.add('drag-over');});gDrop.addEventListener('dragleave',function(){this.classList.remove('drag-over');});gDrop.addEventListener('drop',function(e){e.preventDefault();this.classList.remove('drag-over');addGFiles(e.dataTransfer.files);});}

    // VIDEO
    var btnV=el('btnVideoSE'),vUrl=el('videoUrlSE'),vPrev=el('videoPreviewSE'),vFrame=el('videoIframeSE');
    if(btnV&&vFrame){btnV.addEventListener('click',function(){var url=vUrl?vUrl.value.trim():'';if(!url){vPrev&&vPrev.classList.remove('show');return;}var m=url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);if(m){vFrame.src='https://www.youtube.com/embed/'+m[1];vPrev&&vPrev.classList.add('show');}else alert('Chỉ hỗ trợ xem thử YouTube.');});}

    // DELETE existing gallery
    window.deleteStringingImage=function(imageId,btn){
        if(!confirm('Xóa ảnh này?'))return;
        var fd=new FormData();fd.append('imageId',imageId);
        var tok=document.querySelector('input[name="__RequestVerificationToken"]');
        if(tok)fd.append('__RequestVerificationToken',tok.value);
        fetch('/AdminService/StringingImageDelete',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(res){if(res.success){var t=btn.closest('.gallery-thumb');if(t)t.remove();}else alert('Không thể xóa.');}).catch(function(){alert('Lỗi kết nối.');});
    };

    // SUBMIT
    var btnSave=el('btnStringEditSave'),form=document.getElementById('frmStringEdit-'+UID);
    if(btnSave&&form){btnSave.addEventListener('click',function(){if(!form.checkValidity()){form.reportValidity();return;}btnSave.disabled=true;btnSave.innerHTML='<i class="bi bi-hourglass-split"></i> Đang lưu...';fetch('/AdminService/StringingEdit',{method:'POST',body:new FormData(form)}).then(function(r){return r.json();}).then(function(res){if(res.success){var modal=bootstrap.Modal.getInstance(document.getElementById('modalService'));if(modal)modal.hide();location.reload();}else{alert(res.message||'Có lỗi xảy ra');btnSave.disabled=false;btnSave.innerHTML='<i class="bi bi-check-circle"></i> Lưu Thay Đổi';}}).catch(function(){alert('Lỗi kết nối');btnSave.disabled=false;btnSave.innerHTML='<i class="bi bi-check-circle"></i> Lưu Thay Đổi';});});}
})();
</script>
