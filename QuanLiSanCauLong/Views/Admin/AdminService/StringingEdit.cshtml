@model QuanLiSanCauLong.Models.StringingService
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .sse-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 0;
    }

    .sse-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .sse-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .sse-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--deep);
    }

        .sse-title em {
            font-style: italic;
            color: var(--gold);
        }

    .sse-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .sse-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .sse-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .sse-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        max-height: calc(90vh - 130px);
    }

    .sse-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .sse-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .sse-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .sse-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sse-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 80px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* Brand cards */
    .br-card {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .75rem .6rem;
        text-align: center;
        cursor: pointer;
        transition: all .22s;
        user-select: none;
        background: #fff;
    }

        .br-card:hover {
            border-color: rgba(212,160,23,.5);
            background: var(--cream);
        }

        .br-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .br-card-icon {
        font-size: 1.6rem;
        margin-bottom: .3rem;
    }

    .br-card-name {
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
    }

    /* Status opts */
    .status-opts-sse {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt-sse {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
        user-select: none;
    }

        .status-opt-sse:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt-sse.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
            color: var(--deep);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* Toggles */
    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* Image */
    .img-upload-zone-sse {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--cream);
        cursor: pointer;
        transition: all .25s;
        min-height: 110px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: 1.25rem;
        position: relative;
    }

        .img-upload-zone-sse:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

        .img-upload-zone-sse.has-preview {
            border-color: var(--gold);
            padding: 0;
        }

    .img-preview-sse {
        width: 100%;
        height: 130px;
        object-fit: cover;
        display: none;
        border-radius: 8px;
    }

        .img-preview-sse.show {
            display: block;
        }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }

    .sse-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.5rem;
        border-top: 1px solid var(--border);
    }

    .btn-sse-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sse-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-sse-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sse-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }

        .btn-sse-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- HEADER -->
<div class="sse-header">
    <div>
        <div class="sse-header-label"><i class="bi bi-pencil-square"></i> Chỉnh sửa căng vợt</div>
        <div class="sse-title">Cập Nhật <em>Căng Vợt</em></div>
        <div class="sse-subtitle">Đang chỉnh sửa: <strong>@Model.ServiceName</strong></div>
    </div>
    <button type="button" class="sse-close" data-bs-dismiss="modal">
        <i class="bi bi-x" style="font-size:1.1rem;"></i>
    </button>
</div>

<!-- BODY -->
<div class="sse-body">
    <form id="frmStringEdit-@uid" method="post" enctype="multipart/form-data" action="/AdminService/StringingEdit">
        @Html.AntiForgeryToken()
        <input type="hidden" name="StringingId" value="@Model.StringingId" />
        <input type="hidden" name="CreatedAt" value="@Model.CreatedAt.ToString("o")" />
        <input type="hidden" name="ViewCount" value="@Model.ViewCount" />
        <input type="hidden" name="Slug" value="@Model.Slug" />
        <input type="hidden" name="TotalOrders" value="@Model.TotalOrders" />
        <input type="hidden" id="brandInputSSE-@uid" name="Brand" value="@Model.Brand" />
        <input type="hidden" id="statusInputSSE-@uid" name="Status" value="@Model.Status" />

        <!-- 1. THÔNG TIN -->
        <div class="sse-card">
            <div class="sse-card-head"><i class="bi bi-tools"></i><span class="sse-card-title">Thông Tin Dịch Vụ</span></div>
            <div class="sse-card-body">
                <div class="fg">
                    <label class="fg-label">Tên Dịch Vụ <span class="req">*</span></label>
                    <input name="ServiceName" value="@Model.ServiceName" class="fg-input" required />
                </div>
                <div class="fg-row2 fg">
                    <div>
                        <label class="fg-label">Model Dây</label>
                        <input name="StringModel" value="@Model.StringModel" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Lực Căng</label>
                        <input name="Tension" value="@Model.Tension" class="fg-input" placeholder="VD: 22-28 lbs" />
                    </div>
                </div>
                <div class="fg-row3 fg" style="margin-bottom:0;">
                    <div>
                        <label class="fg-label">Giá (VNĐ)</label>
                        <input name="Price" type="number" value="@Model.Price" class="fg-input" step="1000" />
                    </div>
                    <div>
                        <label class="fg-label">Thời Gian (phút)</label>
                        <input name="DurationMinutes" type="number" value="@Model.DurationMinutes" class="fg-input" />
                    </div>
                    <div>
                        <label class="fg-label">Bảo Hành (ngày)</label>
                        <input name="WarrantyDays" type="number" value="@Model.WarrantyDays" class="fg-input" />
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. THƯƠNG HIỆU -->
        <div class="sse-card">
            <div class="sse-card-head"><i class="bi bi-patch-check"></i><span class="sse-card-title">Thương Hiệu Dây</span></div>
            <div class="sse-card-body">
                <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:.6rem;" id="brandCardsSSE-@uid">
                    <div class="br-card @(Model.Brand == "Yonex" ? "selected" : "")" data-brand="Yonex"><div class="br-card-icon">🏸</div><div class="br-card-name">Yonex</div></div>
                    <div class="br-card @(Model.Brand == "Victor" ? "selected" : "")" data-brand="Victor"><div class="br-card-icon">⚡</div><div class="br-card-name">Victor</div></div>
                    <div class="br-card @(Model.Brand == "Lining" ? "selected" : "")" data-brand="Lining"><div class="br-card-icon">🔥</div><div class="br-card-name">Lining</div></div>
                    <div class="br-card @(Model.Brand == "Apacs" ? "selected" : "")" data-brand="Apacs"><div class="br-card-icon">🎯</div><div class="br-card-name">Apacs</div></div>
                    <div class="br-card @(Model.Brand == "Khác" ? "selected" : "")" data-brand="Khác"><div class="br-card-icon">📦</div><div class="br-card-name">Khác</div></div>
                </div>
            </div>
        </div>

        <!-- 3. MÔ TẢ -->
        <div class="sse-card">
            <div class="sse-card-head"><i class="bi bi-file-text"></i><span class="sse-card-title">Mô Tả</span></div>
            <div class="sse-card-body">
                <div class="fg">
                    <label class="fg-label">Mô Tả Ngắn</label>
                    <textarea name="ShortDesc" class="fg-textarea" rows="2">@Model.ShortDesc</textarea>
                </div>
                <div class="fg">
                    <label class="fg-label">Mô Tả Chi Tiết</label>
                    <textarea name="Description" class="fg-textarea" rows="3">@Model.Description</textarea>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Tính Năng Nổi Bật</label>
                    <textarea name="Features" class="fg-textarea" rows="3" placeholder="- Tính năng 1&#10;- Tính năng 2">@Model.Features</textarea>
                </div>
            </div>
        </div>

        <!-- 4. HÌNH ẢNH -->
        <div class="sse-card">
            <div class="sse-card-head"><i class="bi bi-image"></i><span class="sse-card-title">Hình Ảnh Đại Diện</span></div>
            <div class="sse-card-body">
                <div class="img-upload-zone-sse" id="sseUploadZone-@uid">
                    <img class="img-preview-sse @(!string.IsNullOrEmpty(Model.FeaturedImage) ? "show" : "")"
                         id="sseImgPreview-@uid" src="@(Model.FeaturedImage ?? "")" alt="Preview" />
                    <div id="ssePlaceholder-@uid" style="@(!string.IsNullOrEmpty(Model.FeaturedImage) ? "display:none;" : "")display:flex;flex-direction:column;align-items:center;gap:.5rem;">
                        <i class="bi bi-cloud-arrow-up" style="font-size:1.8rem;color:var(--muted);"></i>
                        <span style="font-size:.84rem;font-weight:600;">Click để tải ảnh lên</span>
                    </div>
                    <input type="file" id="sseImgInput-@uid" name="featuredImage" accept="image/*" style="display:none" />
                </div>
                <div class="img-url-row">
                    <input type="text" id="sseImgUrl-@uid" name="FeaturedImage" value="@Model.FeaturedImage" class="fg-input" placeholder="Hoặc nhập URL ảnh: https://..." />
                    <button type="button" id="sseBtnUrl-@uid" style="padding:.65rem 1.2rem;border:none;border-radius:7px;background:var(--gold);color:var(--deep);font-weight:700;cursor:pointer;white-space:nowrap;font-family:'Outfit',sans-serif;">✓ Áp dụng</button>
                </div>
                <div class="fg-hint"><i class="bi bi-info-circle me-1"></i>Upload file hoặc nhập URL rồi nhấn Áp dụng</div>
            </div>
        </div>

        <!-- 5. TRẠNG THÁI -->
        <div class="sse-card">
            <div class="sse-card-head"><i class="bi bi-toggles"></i><span class="sse-card-title">Trạng Thái & Cài Đặt</span></div>
            <div class="sse-card-body">
                <div class="fg">
                    <label class="fg-label">Trạng Thái</label>
                    <div class="status-opts-sse" id="sseStatusOpts-@uid">
                        <div class="status-opt-sse @(Model.Status == "Active" ? "selected" : "")" data-status="Active"><span class="status-dot" style="background:#16a34a;"></span> Hoạt Động</div>
                        <div class="status-opt-sse @(Model.Status == "Inactive" ? "selected" : "")" data-status="Inactive"><span class="status-dot" style="background:#c94b2a;"></span> Ngừng Hoạt Động</div>
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Thứ Tự Hiển Thị</label>
                    <input name="DisplayOrder" type="number" value="@Model.DisplayOrder" class="fg-input" style="max-width:120px;" />
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Cài Đặt Hiển Thị</label>
                    <div class="toggle-row">
                        <label class="toggle-item"><input type="checkbox" name="IsFeatured" value="true" @(Model.IsFeatured ? "checked" : "") /><span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Nổi bật</span></label>
                        <label class="toggle-item"><input type="checkbox" name="IsPopular" value="true" @(Model.IsPopular ? "checked" : "") /><span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Phổ biến</span></label>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- FOOTER -->
<div class="sse-footer">
    <button type="button" class="btn-sse-cancel" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Hủy</button>
    <button type="button" class="btn-sse-save" id="btnStringEditSave-@uid"><i class="bi bi-check-circle"></i> Lưu Thay Đổi</button>
</div>

<script>
    (function() {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // Brand cards
        var brandCards = el('brandCardsSSE');
        if (brandCards) {
            brandCards.querySelectorAll('.br-card').forEach(function(card) {
                card.addEventListener('click', function() {
                    brandCards.querySelectorAll('.br-card').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('brandInputSSE').value = this.dataset.brand;
                });
            });
        }

        // Status opts
        var statusOpts = el('sseStatusOpts');
        if (statusOpts) {
            statusOpts.querySelectorAll('.status-opt-sse').forEach(function(opt) {
                opt.addEventListener('click', function() {
                    statusOpts.querySelectorAll('.status-opt-sse').forEach(function(c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInputSSE').value = this.dataset.status;
                });
            });
        }

        // Image
        var zone = el('sseUploadZone'), input = el('sseImgInput');
        var preview = el('sseImgPreview'), placeholder = el('ssePlaceholder');
        var urlInput = el('sseImgUrl'), btnUrl = el('sseBtnUrl');

        function showPreview(src) {
            preview.src = src; preview.classList.add('show');
            placeholder.style.display = 'none'; zone.classList.add('has-preview');
        }
        function resetPreview() {
            preview.src = ''; preview.classList.remove('show');
            placeholder.style.display = 'flex'; zone.classList.remove('has-preview');
            input.value = ''; urlInput.value = '';
        }
        zone.addEventListener('click', function(e) {
            if (!preview.classList.contains('show')) input.click(); else resetPreview();
        });
        input.addEventListener('change', function() {
            if (!this.files[0]) return;
            var reader = new FileReader();
            reader.onload = function(ev) { showPreview(ev.target.result); urlInput.value = ''; };
            reader.readAsDataURL(this.files[0]);
        });
        btnUrl.addEventListener('click', function() {
            var url = urlInput.value.trim();
            if (url) { showPreview(url); input.value = ''; }
        });

        // Submit
        var btnSave = el('btnStringEditSave');
        var form = document.getElementById('frmStringEdit-' + UID);
        btnSave.addEventListener('click', function() {
            if (!form.checkValidity()) { form.reportValidity(); return; }
            btnSave.disabled = true;
            btnSave.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';
            fetch('/AdminService/StringingEdit', { method:'POST', body: new FormData(form) })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('modalService'))?.hide();
                        location.reload();
                    } else {
                        alert(res.message || 'Có lỗi xảy ra');
                        btnSave.disabled = false;
                        btnSave.innerHTML = '<i class="bi bi-check-circle"></i> Lưu Thay Đổi';
                    }
                });
        });
    })();
</script>
