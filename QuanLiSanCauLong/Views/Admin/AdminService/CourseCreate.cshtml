@model QuanLiSanCauLong.Models.Course
@{
    Layout = null;
    // Tạo ID duy nhất để tránh conflict khi modal inject nhiều lần
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .sc-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .sc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .sc-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .sc-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .sc-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .sc-title em {
            font-style: italic;
            color: var(--gold);
        }

    .sc-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .sc-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .sc-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .sc-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .sc-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .sc-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .sc-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .sc-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sc-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* LEVEL CARDS */
    .level-cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .65rem;
    }

    .lv-card {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .8rem 1rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
        user-select: none;
    }

        .lv-card:hover {
            border-color: rgba(212,160,23,.5);
            background: rgba(212,160,23,.03);
        }

        .lv-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

    .lv-icon {
        font-size: 1.4rem;
        display: block;
        margin-bottom: .3rem;
    }

    .lv-name {
        font-size: .8rem;
        font-weight: 700;
        color: var(--deep);
    }

    .lv-sub {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    /* STATUS OPTS */
    .status-opts {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
        user-select: none;
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
            color: var(--deep);
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* TOGGLE */
    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* UPLOAD */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 1.25rem;
        background: var(--cream);
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        position: relative;
        overflow: hidden;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

        .img-upload-zone.has-preview {
            border-color: var(--gold);
            padding: 0;
        }

    .upload-icon {
        font-size: 1.8rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .upload-text {
        font-size: .82rem;
        color: var(--muted);
    }

        .upload-text strong {
            color: var(--deep);
        }

    .img-preview {
        width: 100%;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        display: none;
    }

        .img-preview.show {
            display: block;
        }

    .img-upload-inner {
        padding: 1.25rem;
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }

        .img-url-row .fg-input {
            flex: 1;
            font-size: .8rem;
        }

    .btn-url-confirm {
        padding: .5rem .9rem;
        background: var(--gold);
        border: none;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        font-family: 'Outfit',sans-serif;
    }

    /* FOOTER */
    .sc-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
    }

    .btn-sc-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sc-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-sc-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sc-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- WRAPPER -->
<div class="sc-wrapper" id="scWrapper-@uid">

    <!-- HEADER -->
    <div class="sc-header">
        <div>
            <div class="sc-header-label"><i class="bi bi-mortarboard"></i> Khóa học mới</div>
            <div class="sc-title">Thêm <em>Khóa Học</em></div>
            <div class="sc-subtitle">Tạo khóa học cầu lông mới trong hệ thống</div>
        </div>
        <button type="button" class="sc-close" data-bs-dismiss="modal">
            <i class="bi bi-x" style="font-size:1.1rem;"></i>
        </button>
    </div>

    <!-- BODY -->
    <div class="sc-body">
        <form id="frmCourseCreate-@uid" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-info-circle"></i>
                    <span class="sc-card-title">Thông Tin Khóa Học</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Khóa Học <span class="req">*</span></label>
                        <input name="CourseName" class="fg-input" placeholder="VD: Khóa học cầu lông cơ bản" required />
                    </div>
                    <div class="fg-row2 fg">
                        <div>
                            <label class="fg-label">Huấn Luyện Viên</label>
                            <input name="Instructor" class="fg-input" placeholder="VD: HLV Nguyễn Văn A" />
                        </div>
                        <div>
                            <label class="fg-label">Lịch Học</label>
                            <input name="Schedule" class="fg-input" placeholder="Thứ 2, 4, 6 — 18h–19h30" />
                        </div>
                    </div>
                    <div class="fg-row3 fg" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Thời Lượng (tuần)</label>
                            <input name="DurationWeeks" type="number" class="fg-input" placeholder="8" min="1" />
                        </div>
                        <div>
                            <label class="fg-label">Sĩ Số Tối Đa</label>
                            <input name="MaxStudents" type="number" class="fg-input" placeholder="15" min="1" />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự Hiển Thị</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. TRÌNH ĐỘ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-bar-chart-steps"></i>
                    <span class="sc-card-title">Trình Độ Học Viên</span>
                </div>
                <div class="sc-card-body">
                    <input name="Level" type="hidden" id="levelInput-@uid" value="" />
                    <div class="level-cards" id="levelCards-@uid">
                        <div class="lv-card" data-level="Beginner">
                            <span class="lv-icon">🌱</span>
                            <div class="lv-name">Cơ Bản</div>
                            <div class="lv-sub">Beginner</div>
                        </div>
                        <div class="lv-card" data-level="Intermediate">
                            <span class="lv-icon">⚡</span>
                            <div class="lv-name">Trung Cấp</div>
                            <div class="lv-sub">Intermediate</div>
                        </div>
                        <div class="lv-card" data-level="Advanced">
                            <span class="lv-icon">🏆</span>
                            <div class="lv-name">Nâng Cao</div>
                            <div class="lv-sub">Advanced</div>
                        </div>
                    </div>
                    <p id="levelRequired-@uid" style="display:none;color:#c94b2a;font-size:.75rem;margin-top:.5rem;">
                        <i class="bi bi-exclamation-circle me-1"></i>Vui lòng chọn trình độ
                    </p>
                </div>
            </div>

            <!-- 3. MÔ TẢ & TÍNH NĂNG -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-file-text"></i>
                    <span class="sc-card-title">Mô Tả & Nội Dung</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <textarea name="ShortDesc" class="fg-textarea" rows="2" placeholder="Mô tả ngắn gọn về khóa học..."></textarea>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="4" placeholder="Nội dung chi tiết khóa học..." required></textarea>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Nội Dung / Tính Năng Khóa Học</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Kỹ thuật cầm vợt và tư thế đứng&#10;- Đánh cầu thuận tay / trái tay&#10;- Di chuyển chân cơ bản"></textarea>
                        <div class="fg-hint">Mỗi dòng một tính năng, bắt đầu bằng dấu "-"</div>
                    </div>
                </div>
            </div>

            <!-- 4. HỌC PHÍ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-currency-exchange"></i>
                    <span class="sc-card-title">Học Phí</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Học Phí (VNĐ)</label>
                            <input name="TuitionFee" type="number" class="fg-input" placeholder="2500000" min="0" />
                        </div>
                        <div>
                            <label class="fg-label">Học Phí Khuyến Mãi</label>
                            <input name="DiscountFee" type="number" class="fg-input" placeholder="2000000" min="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 5. HÌNH ẢNH & TRẠNG THÁI -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-toggles"></i>
                    <span class="sc-card-title">Hình Ảnh & Trạng Thái</span>
                </div>
                <div class="sc-card-body">
                    <!-- ẢNH ĐẠI DIỆN -->
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone" id="scUploadZone-@uid">
                            <img class="img-preview" id="imgPreview-@uid" src="" alt="Preview" />
                            <div class="img-upload-inner" id="uploadInner-@uid">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để tải ảnh lên</strong> hoặc kéo thả</div>
                                <div id="imgName-@uid" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                            </div>
                        </div>
                        <input type="file" id="featuredImgFile-@uid" name="featuredImageFile" accept="image/*" style="display:none" />
                        <!-- Nhập URL ảnh -->
                        <div class="img-url-row">
                            <input type="text" id="imgUrlInput-@uid" name="FeaturedImage" class="fg-input"
                                   placeholder="Hoặc nhập URL ảnh: https://..." />
                            <button type="button" class="btn-url-confirm" id="btnUrlConfirm-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                        <div class="fg-hint">Upload file ảnh hoặc nhập URL rồi nhấn Áp dụng</div>
                    </div>

                    <!-- TRẠNG THÁI -->
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="statusOpts-@uid">
                            <div class="status-opt selected" data-status="Active">
                                <span class="status-dot" style="background:#16a34a;"></span> Đang Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Full">
                                <span class="status-dot" style="background:#c94b2a;"></span> Đã Đầy
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInput-@uid" value="Active" />
                    </div>

                    <div class="fg" style="margin-bottom:0;">
                        <label class="toggle-item">
                            <input name="IsFeatured" type="checkbox" value="true" />
                            <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Đánh dấu nổi bật</span>
                        </label>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="sc-footer">
        <button type="button" class="btn-sc-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-sc-save" id="btnCourseSubmit-@uid"
                data-form="frmCourseCreate-@uid" data-url="/AdminService/CourseCreate">
            <i class="bi bi-plus-circle"></i> Thêm Khóa Học
        </button>
    </div>

</div><!-- /sc-wrapper -->

<script>
    (function() {
        var UID = '@uid';

        // ── Helper: querySelector trong wrapper của UID này
        function el(id) { return document.getElementById(id + '-' + UID); }

        // ── LEVEL CARDS ──────────────────────────────────────
        var levelCards = el('levelCards');
        if (levelCards) {
            levelCards.querySelectorAll('.lv-card').forEach(function(card) {
                card.addEventListener('click', function() {
                    levelCards.querySelectorAll('.lv-card').forEach(function(c) {
                        c.classList.remove('selected');
                    });
                    this.classList.add('selected');
                    el('levelInput').value = this.dataset.level;
                    // Ẩn thông báo lỗi nếu đã chọn
                    var req = el('levelRequired');
                    if (req) req.style.display = 'none';
                });
            });
        }

        // ── STATUS OPTIONS ────────────────────────────────────
        var statusOpts = el('statusOpts');
        if (statusOpts) {
            statusOpts.querySelectorAll('.status-opt').forEach(function(opt) {
                opt.addEventListener('click', function() {
                    statusOpts.querySelectorAll('.status-opt').forEach(function(c) {
                        c.classList.remove('selected');
                    });
                    this.classList.add('selected');
                    el('statusInput').value = this.dataset.status;
                });
            });
        }

        // ── IMAGE UPLOAD (file) ───────────────────────────────
        var uploadZone  = el('scUploadZone');
        var fileInput   = el('featuredImgFile');
        var imgPreview  = el('imgPreview');
        var uploadInner = el('uploadInner');
        var imgNameEl   = el('imgName');

        function showPreview(src, label) {
            if (!imgPreview) return;
            imgPreview.src = src;
            imgPreview.classList.add('show');
            if (uploadInner) uploadInner.style.display = 'none';
            if (uploadZone)  uploadZone.classList.add('has-preview');
        }

        function resetPreview() {
            if (!imgPreview) return;
            imgPreview.src = '';
            imgPreview.classList.remove('show');
            if (uploadInner) uploadInner.style.display = '';
            if (uploadZone)  uploadZone.classList.remove('has-preview');
        }

        if (uploadZone && fileInput) {
            uploadZone.addEventListener('click', function(e) {
                // Không kích hoạt khi click vào preview (cho phép reset)
                if (e.target === imgPreview) { resetPreview(); fileInput.value = ''; return; }
                fileInput.click();
            });

            fileInput.addEventListener('change', function() {
                if (!this.files || !this.files[0]) return;
                var file = this.files[0];
                if (imgNameEl) imgNameEl.textContent = file.name;
                var reader = new FileReader();
                reader.onload = function(ev) { showPreview(ev.target.result, file.name); };
                reader.readAsDataURL(file);
            });

            // Drag & drop
            uploadZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                this.style.borderColor = 'var(--gold)';
            });
            uploadZone.addEventListener('dragleave', function() {
                this.style.borderColor = '';
            });
            uploadZone.addEventListener('drop', function(e) {
                e.preventDefault();
                this.style.borderColor = '';
                var file = e.dataTransfer.files[0];
                if (!file || !file.type.startsWith('image/')) return;
                var dt = new DataTransfer();
                dt.items.add(file);
                fileInput.files = dt.files;
                if (imgNameEl) imgNameEl.textContent = file.name;
                var reader = new FileReader();
                reader.onload = function(ev) { showPreview(ev.target.result, file.name); };
                reader.readAsDataURL(file);
            });
        }

        // ── IMAGE URL ─────────────────────────────────────────
        var btnUrlConfirm = el('btnUrlConfirm');
        var imgUrlInput   = el('imgUrlInput');

        if (btnUrlConfirm && imgUrlInput) {
            btnUrlConfirm.addEventListener('click', function() {
                var url = imgUrlInput.value.trim();
                if (!url) { resetPreview(); return; }
                showPreview(url, url);
                // Khi dùng URL, xóa file đã chọn nếu có
                if (fileInput) fileInput.value = '';
            });

            imgUrlInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); btnUrlConfirm.click(); }
            });
        }

        // ── SUBMIT ────────────────────────────────────────────
        var btnSubmit = el('btnCourseSubmit');
        if (btnSubmit) {
            btnSubmit.addEventListener('click', function() {
                var formId = this.dataset.form;
                var url    = this.dataset.url;
                var form   = document.getElementById(formId);
                if (!form) return;

                // Validate: bắt buộc chọn trình độ
                var levelVal = el('levelInput') ? el('levelInput').value : '';
                if (!levelVal) {
                    var req = el('levelRequired');
                    if (req) req.style.display = 'block';
                    levelCards && levelCards.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                if (!form.checkValidity()) { form.reportValidity(); return; }

                // Disable nút tránh double-submit
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';

                var formData = new FormData(form);

                if (typeof submitServiceForm === 'function') {
                    submitServiceForm(formId, url);
                } else {
                    fetch(url, { method: 'POST', body: formData })
                        .then(function(r) { return r.json(); })
                        .then(function(res) {
                            if (res.success) {
                                var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                if (modal) modal.hide();
                                location.reload();
                            } else {
                                alert(res.message || 'Có lỗi xảy ra, vui lòng thử lại.');
                                btnSubmit.disabled = false;
                                btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Khóa Học';
                            }
                        })
                        .catch(function(err) {
                            alert('Lỗi kết nối: ' + err.message);
                            btnSubmit.disabled = false;
                            btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Khóa Học';
                        });
                }
            });
        }

    })();
</script>
