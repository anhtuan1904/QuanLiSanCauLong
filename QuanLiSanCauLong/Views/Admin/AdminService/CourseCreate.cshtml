@model QuanLiSanCauLong.Models.Course
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    /* Flex layout để header/footer cố định, body scroll */
    .sc-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .sc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .sc-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .sc-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .sc-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .sc-title em {
            font-style: italic;
            color: var(--gold);
        }

    .sc-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .sc-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .sc-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .sc-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .sc-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .sc-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .sc-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .sc-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sc-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* LEVEL CARDS */
    .level-cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .65rem;
    }

    .lv-card {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .8rem 1rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .lv-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .lv-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .lv-icon {
        font-size: 1.4rem;
        display: block;
        margin-bottom: .3rem;
    }

    .lv-name {
        font-size: .8rem;
        font-weight: 700;
        color: var(--deep);
    }

    .lv-sub {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    /* STATUS OPTS */
    .status-opts {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
            color: var(--deep);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* TOGGLE */
    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    /* UPLOAD */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 1.25rem;
        background: var(--cream);
        text-align: center;
        cursor: pointer;
        transition: all .2s;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

    .upload-icon {
        font-size: 1.8rem;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .upload-text {
        font-size: .82rem;
        color: var(--muted);
    }

        .upload-text strong {
            color: var(--deep);
        }

    /* FOOTER */
    .sc-footer {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
    }

    .btn-sc-cancel {
        padding: .65rem 1.4rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sc-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-sc-save {
        padding: .65rem 1.75rem;
        border: none;
        border-radius: 7px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-family: 'Outfit',sans-serif;
    }

        .btn-sc-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(212,160,23,.3);
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- WRAPPER -->
<div class="sc-wrapper">

    <!-- HEADER -->
    <div class="sc-header">
        <div>
            <div class="sc-header-label"><i class="bi bi-mortarboard"></i> Khóa học mới</div>
            <div class="sc-title">Thêm <em>Khóa Học</em></div>
            <div class="sc-subtitle">Tạo khóa học cầu lông mới trong hệ thống</div>
        </div>
        <button type="button" class="sc-close" data-bs-dismiss="modal">
            <i class="bi bi-x" style="font-size:1.1rem;"></i>
        </button>
    </div>

    <!-- BODY -->
    <div class="sc-body">
        <form id="frmCourseCreate" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-info-circle"></i>
                    <span class="sc-card-title">Thông Tin Khóa Học</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Khóa Học <span class="req">*</span></label>
                        <input name="CourseName" class="fg-input" placeholder="VD: Khóa học cầu lông cơ bản" required />
                    </div>
                    <div class="fg-row2 fg">
                        <div>
                            <label class="fg-label">Huấn Luyện Viên</label>
                            <input name="Instructor" class="fg-input" placeholder="VD: HLV Nguyễn Văn A" />
                        </div>
                        <div>
                            <label class="fg-label">Lịch Học</label>
                            <input name="Schedule" class="fg-input" placeholder="Thứ 2, 4, 6 — 18h–19h30" />
                        </div>
                    </div>
                    <div class="fg-row3 fg" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Thời Lượng (tuần)</label>
                            <input name="DurationWeeks" type="number" class="fg-input" placeholder="8" />
                        </div>
                        <div>
                            <label class="fg-label">Sĩ Số Tối Đa</label>
                            <input name="MaxStudents" type="number" class="fg-input" placeholder="15" />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự Hiển Thị</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 2. TRÌNH ĐỘ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-bar-chart-steps"></i>
                    <span class="sc-card-title">Trình Độ Học Viên</span>
                </div>
                <div class="sc-card-body">
                    <input name="Level" type="hidden" id="levelInput" value="" />
                    <div class="level-cards" id="levelCards">
                        <div class="lv-card" data-level="Beginner">
                            <span class="lv-icon">🌱</span>
                            <div class="lv-name">Cơ Bản</div>
                            <div class="lv-sub">Beginner</div>
                        </div>
                        <div class="lv-card" data-level="Intermediate">
                            <span class="lv-icon">⚡</span>
                            <div class="lv-name">Trung Cấp</div>
                            <div class="lv-sub">Intermediate</div>
                        </div>
                        <div class="lv-card" data-level="Advanced">
                            <span class="lv-icon">🏆</span>
                            <div class="lv-name">Nâng Cao</div>
                            <div class="lv-sub">Advanced</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. MÔ TẢ & TÍNH NĂNG -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-file-text"></i>
                    <span class="sc-card-title">Mô Tả & Nội Dung</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <textarea name="ShortDesc" class="fg-textarea" rows="2" placeholder="Mô tả ngắn gọn về khóa học..."></textarea>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="4" placeholder="Nội dung chi tiết khóa học..." required></textarea>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Nội Dung / Tính Năng Khóa Học</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Kỹ thuật cầm vợt và tư thế đứng&#10;- Đánh cầu thuận tay / trái tay&#10;- Di chuyển chân cơ bản"></textarea>
                        <div class="fg-hint">Mỗi dòng một tính năng, bắt đầu bằng dấu "-"</div>
                    </div>
                </div>
            </div>

            <!-- 4. HỌC PHÍ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-currency-exchange"></i>
                    <span class="sc-card-title">Học Phí</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg-row2" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Học Phí (VNĐ)</label>
                            <input name="TuitionFee" type="number" class="fg-input" placeholder="2.500.000" />
                        </div>
                        <div>
                            <label class="fg-label">Học Phí Khuyến Mãi</label>
                            <input name="DiscountFee" type="number" class="fg-input" placeholder="2.000.000" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 5. HÌNH ẢNH & TRẠNG THÁI -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-toggles"></i>
                    <span class="sc-card-title">Hình Ảnh & Trạng Thái</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        <div class="img-upload-zone" id="scUploadZone">
                            <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                            <div class="upload-text"><strong>Click để tải ảnh lên</strong> hoặc kéo thả</div>
                            <div id="imgName" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                        </div>
                        <input type="file" id="featuredImgInput" name="featuredImage" accept="image/*" style="display:none" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="statusOpts">
                            <div class="status-opt selected" data-status="Active">
                                <span class="status-dot" style="background:#16a34a;"></span> Đang Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Full">
                                <span class="status-dot" style="background:#c94b2a;"></span> Đã Đầy
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInput" value="Active" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="toggle-item">
                            <input name="IsFeatured" type="checkbox" value="true" />
                            <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Đánh dấu nổi bật</span>
                        </label>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="sc-footer">
        <button type="button" class="btn-sc-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-sc-save" id="btnCourseSubmit"
                data-form="frmCourseCreate" data-url="/AdminService/CourseCreate">
            <i class="bi bi-plus-circle"></i> Thêm Khóa Học
        </button>
    </div>

</div><!-- /sc-wrapper -->

<script>
    (function() {
        // Scope toàn bộ JS trong IIFE để tránh conflict khi inject vào modal

        // Level cards
        var levelCards = document.getElementById('levelCards');
        if (levelCards) {
            levelCards.addEventListener('click', function(e) {
                var card = e.target.closest('.lv-card');
                if (!card) return;
                levelCards.querySelectorAll('.lv-card').forEach(function(c) { c.classList.remove('selected'); });
                card.classList.add('selected');
                document.getElementById('levelInput').value = card.dataset.level;
            });
        }

        // Status opts
        var statusOpts = document.getElementById('statusOpts');
        if (statusOpts) {
            statusOpts.addEventListener('click', function(e) {
                var opt = e.target.closest('.status-opt');
                if (!opt) return;
                statusOpts.querySelectorAll('.status-opt').forEach(function(c) { c.classList.remove('selected'); });
                opt.classList.add('selected');
                document.getElementById('statusInput').value = opt.dataset.status;
            });
        }

        // Submit button
        var btnSubmit = document.getElementById('btnCourseSubmit');
        if (btnSubmit) {
            btnSubmit.addEventListener('click', function() {
                var formId = this.dataset.form;
                var url    = this.dataset.url;
                var form   = document.getElementById(formId);
                if (!form) return;
                if (!form.checkValidity()) { form.reportValidity(); return; }
                // Dùng hàm submitServiceForm đã có ở Index
                if (typeof submitServiceForm === 'function') {
                    submitServiceForm(formId, url);
                } else {
                    fetch(url, { method: 'POST', body: new FormData(form) })
                        .then(function(r) { return r.json(); })
                        .then(function(res) {
                            if (res.success) {
                                var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                if (modal) modal.hide();
                                location.reload();
                            } else {
                                alert(res.message || 'Có lỗi xảy ra, vui lòng thử lại.');
                            }
                        })
                        .catch(function(err) { alert('Lỗi kết nối: ' + err.message); });
                }
            });
        }

        // Image upload name display
        var scUploadZone = document.getElementById('scUploadZone');
        var imgInput = document.getElementById('featuredImgInput');
        if (scUploadZone && imgInput) {
            scUploadZone.addEventListener('click', function() { imgInput.click(); });
            imgInput.addEventListener('change', function() {
                var nameEl = document.getElementById('imgName');
                if (nameEl) nameEl.textContent = this.files[0] ? this.files[0].name : '';
            });
        }
    })();
</script>
