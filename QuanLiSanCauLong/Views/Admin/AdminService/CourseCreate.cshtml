@model QuanLiSanCauLong.Models.Course
@{
    Layout = null;
    var uid = Guid.NewGuid().ToString("N")[..8];
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    * {
        font-family: 'Outfit', sans-serif;
        box-sizing: border-box;
    }

    .sc-wrapper {
        display: flex;
        flex-direction: column;
        max-height: 90vh;
        overflow: hidden;
    }

    .sc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.5rem 1.75rem 1rem;
        flex-shrink: 0;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .sc-header-label {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .4rem;
    }

        .sc-header-label::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .sc-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

        .sc-title em {
            font-style: italic;
            color: var(--gold);
        }

    .sc-subtitle {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .sc-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .sc-close:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .sc-body {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .sc-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .sc-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .sc-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .sc-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sc-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-row4 {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: var(--red);
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* LEVEL CARDS */
    .level-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: .65rem;
    }

    .lv-card {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .8rem 1rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
        user-select: none;
    }

        .lv-card:hover {
            border-color: rgba(212,160,23,.5);
            background: rgba(212,160,23,.03);
        }

        .lv-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

        .lv-card .lv-icon {
            font-size: 1.4rem;
            margin-bottom: .3rem;
        }

        .lv-card .lv-name {
            font-size: .78rem;
            font-weight: 700;
            color: var(--deep);
        }

        .lv-card .lv-sub {
            font-size: .65rem;
            color: var(--muted);
            margin-top: .15rem;
        }

    /* STATUS */
    .status-opts {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .55rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 500;
        transition: all .2s;
        user-select: none;
    }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            font-weight: 700;
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* TOGGLE */
    .toggle-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toggle-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        cursor: pointer;
    }

    .toggle-label {
        font-size: .84rem;
        color: var(--deep);
    }

    /* ═══════════════════════════════════════════════
           FEATURED IMAGE UPLOAD
        ═══════════════════════════════════════════════ */
    .img-upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        min-height: 160px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: border-color .2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .img-upload-zone:hover {
            border-color: var(--gold);
        }

        .img-upload-zone.has-preview {
            border-style: solid;
            border-color: var(--gold);
        }

    .img-preview {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

        .img-preview.show {
            display: block;
        }

    .img-upload-inner {
        text-align: center;
        padding: 2rem 1rem;
        pointer-events: none;
    }

    .upload-icon {
        font-size: 2rem;
        color: var(--gold);
        margin-bottom: .5rem;
    }

    .upload-text {
        font-size: .84rem;
        color: var(--muted);
    }

    .img-url-row {
        display: flex;
        gap: .5rem;
        margin-top: .65rem;
    }

        .img-url-row .fg-input {
            flex: 1;
        }

    .btn-url-confirm {
        padding: .65rem 1rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-url-confirm:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.1);
        }

    /* ═══════════════════════════════════════════════
           MULTI-IMAGE GALLERY UPLOAD  ← MỚI
        ═══════════════════════════════════════════════ */
    .gallery-drop-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        background: var(--warm);
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        margin-bottom: .75rem;
    }

        .gallery-drop-zone:hover, .gallery-drop-zone.drag-over {
            border-color: var(--gold);
            background: rgba(212,160,23,.05);
        }

        .gallery-drop-zone .dz-icon {
            font-size: 1.75rem;
            color: var(--gold);
        }

        .gallery-drop-zone .dz-text {
            font-size: .84rem;
            color: var(--muted);
            margin-top: .4rem;
        }

        .gallery-drop-zone .dz-sub {
            font-size: .7rem;
            color: var(--muted);
            margin-top: .2rem;
        }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: .6rem;
        min-height: 0;
    }

    .gallery-thumb {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--border);
        background: var(--warm);
    }

        .gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .gallery-thumb .thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.45);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            opacity: 0;
            transition: opacity .2s;
        }

        .gallery-thumb:hover .thumb-overlay {
            opacity: 1;
        }

    .thumb-btn {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
    }

        .thumb-btn.del {
            background: var(--red);
            color: #fff;
        }

        .thumb-btn.primary {
            background: var(--gold);
            color: var(--deep);
        }

    .gallery-thumb.is-primary::after {
        content: '★ Chính';
        position: absolute;
        top: 4px;
        left: 4px;
        background: var(--gold);
        color: var(--deep);
        font-size: .6rem;
        font-weight: 700;
        padding: .15rem .4rem;
        border-radius: 3px;
    }

    .gallery-count {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    /* VIDEO URL */
    .video-preview {
        margin-top: .65rem;
        border-radius: 8px;
        overflow: hidden;
        display: none;
    }

        .video-preview.show {
            display: block;
        }

        .video-preview iframe {
            width: 100%;
            height: 180px;
            border: none;
            border-radius: 8px;
        }

    /* HIGHLIGHTS */
    .highlight-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        margin-top: .5rem;
    }

    .hl-tag {
        display: flex;
        align-items: center;
        gap: .35rem;
        background: rgba(212,160,23,.12);
        border: 1px solid rgba(212,160,23,.3);
        border-radius: 20px;
        padding: .3rem .75rem;
        font-size: .78rem;
        color: var(--deep);
    }

        .hl-tag .hl-remove {
            cursor: pointer;
            color: var(--muted);
            font-size: .7rem;
            background: none;
            border: none;
            padding: 0;
            line-height: 1;
        }

            .hl-tag .hl-remove:hover {
                color: var(--red);
            }

    .hl-input-row {
        display: flex;
        gap: .5rem;
    }

        .hl-input-row .fg-input {
            flex: 1;
        }

    .btn-hl-add {
        padding: .65rem .9rem;
        background: var(--deep);
        border: none;
        border-radius: 7px;
        font-size: .82rem;
        font-weight: 600;
        color: var(--gold);
        cursor: pointer;
        white-space: nowrap;
        transition: all .2s;
    }

        .btn-hl-add:hover {
            background: rgba(26,18,9,.85);
        }

    /* FOOTER */
    .sc-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .75rem;
        padding: 1rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        flex-shrink: 0;
    }

    .btn-sc-cancel {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-sc-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    .btn-sc-save {
        padding: .7rem 1.75rem;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
    }

        .btn-sc-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

        .btn-sc-save:disabled {
            opacity: .6;
            transform: none;
            cursor: not-allowed;
        }

    /* INSTRUCTOR AVATAR */
    .avatar-zone {
        border: 2px dashed var(--border);
        border-radius: 50%;
        width: 90px;
        height: 90px;
        cursor: pointer;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--warm);
        transition: border-color .2s;
        flex-shrink: 0;
    }

        .avatar-zone:hover {
            border-color: var(--gold);
        }

        .avatar-zone img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: none;
        }

            .avatar-zone img.show {
                display: block;
            }

        .avatar-zone .av-icon {
            font-size: 1.5rem;
            color: var(--muted);
            pointer-events: none;
        }

    .instructor-row {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .instructor-fields {
        flex: 1;
    }

    .spin {
        width: 28px;
        height: 28px;
        border: 3px solid var(--warm);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin .7s linear infinite;
        margin: 0 auto .75rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="sc-wrapper">
    <!-- HEADER -->
    <div class="sc-header">
        <div>
            <div class="sc-header-label"><i class="bi bi-mortarboard-fill"></i> Khóa Học</div>
            <div class="sc-title">Thêm <em>Khóa Học</em> Mới</div>
            <div class="sc-subtitle">Điền đầy đủ thông tin giúp học viên dễ tìm kiếm & đăng ký</div>
        </div>
        <button class="sc-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
    </div>

    <!-- BODY -->
    <div class="sc-body">
        <form id="frmCourseCreate-@uid" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <!-- 1. THÔNG TIN CƠ BẢN -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-info-circle-fill"></i>
                    <span class="sc-card-title">Thông Tin Cơ Bản</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Tên Khóa Học <span class="req">*</span></label>
                        <input name="CourseName" class="fg-input" required maxlength="200"
                               placeholder="VD: Khóa Cầu Lông Cơ Bản — Nâng Chuẩn Kỹ Thuật" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Mô Tả Ngắn</label>
                        <input name="ShortDesc" class="fg-input" maxlength="300"
                               placeholder="Câu mô tả hấp dẫn hiển thị trên thẻ dịch vụ..." />
                        <div class="fg-hint">Hiển thị trên danh sách — nên ngắn gọn, lôi cuốn (≤ 120 ký tự)</div>
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Mô Tả Chi Tiết <span class="req">*</span></label>
                        <textarea name="Description" class="fg-textarea" rows="4" required
                                  placeholder="Mô tả đầy đủ: nội dung khóa học, phương pháp dạy học, lợi ích học viên nhận được..."></textarea>
                    </div>
                </div>
            </div>

            <!-- 2. TRÌNH ĐỘ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-bar-chart-fill"></i>
                    <span class="sc-card-title">Trình Độ Học Viên</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Phù Hợp Với <span class="req">*</span></label>
                        <div class="level-cards" id="levelCards-@uid">
                            <div class="lv-card" data-level="Beginner">
                                <div class="lv-icon">🌱</div>
                                <div class="lv-name">Mới Bắt Đầu</div>
                                <div class="lv-sub">Chưa biết đánh</div>
                            </div>
                            <div class="lv-card" data-level="Intermediate">
                                <div class="lv-icon">🏸</div>
                                <div class="lv-name">Trung Cấp</div>
                                <div class="lv-sub">Đánh được cơ bản</div>
                            </div>
                            <div class="lv-card" data-level="Advanced">
                                <div class="lv-icon">🏆</div>
                                <div class="lv-name">Nâng Cao</div>
                                <div class="lv-sub">Thi đấu phong trào</div>
                            </div>
                            <div class="lv-card" data-level="All">
                                <div class="lv-icon">👥</div>
                                <div class="lv-name">Tất Cả</div>
                                <div class="lv-sub">Mọi trình độ</div>
                            </div>
                        </div>
                        <input type="hidden" name="Level" id="levelInput-@uid" value="" />
                        <div id="levelRequired-@uid" style="display:none; color:var(--red); font-size:.75rem; margin-top:.4rem;">
                            <i class="bi bi-exclamation-circle me-1"></i>Vui lòng chọn trình độ phù hợp
                        </div>
                    </div>
                </div>
            </div>

            <!-- 3. CHI TIẾT & GIÁ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-calendar3"></i>
                    <span class="sc-card-title">Chi Tiết Khóa Học & Học Phí</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg fg-row4">
                        <div>
                            <label class="fg-label">Lịch Học</label>
                            <input name="Schedule" class="fg-input" placeholder="T2,T4,T6 — 18:00~20:00" />
                        </div>
                        <div>
                            <label class="fg-label">Số Tuần</label>
                            <input name="DurationWeeks" type="number" class="fg-input" min="1" max="52" placeholder="8" />
                        </div>
                        <div>
                            <label class="fg-label">Sĩ Số Tối Đa</label>
                            <input name="MaxStudents" type="number" class="fg-input" min="1" placeholder="20" />
                        </div>
                        <div>
                            <label class="fg-label">Thứ Tự</label>
                            <input name="DisplayOrder" type="number" class="fg-input" value="0" min="0" />
                        </div>
                    </div>
                    <div class="fg fg-row3" style="margin-bottom:0;">
                        <div>
                            <label class="fg-label">Học Phí Gốc (VNĐ)</label>
                            <input name="TuitionFee" type="number" class="fg-input" min="0" step="10000" placeholder="1,500,000" />
                        </div>
                        <div>
                            <label class="fg-label">Giá Khuyến Mãi (VNĐ)</label>
                            <input name="DiscountFee" type="number" class="fg-input" min="0" step="10000" placeholder="1,200,000" />
                        </div>
                        <div>
                            <label class="fg-label">Hiện Học Viên</label>
                            <input name="CurrentStudents" type="number" class="fg-input" value="0" min="0" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. HUẤN LUYỆN VIÊN -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-person-badge-fill"></i>
                    <span class="sc-card-title">Huấn Luyện Viên — Xây Dựng Lòng Tin</span>
                </div>
                <div class="sc-card-body">
                    <div class="instructor-row">
                        <div>
                            <div class="avatar-zone" id="avatarZone-@uid" title="Click để tải ảnh HLV">
                                <img id="avatarPreview-@uid" src="" alt="Avatar" />
                                <i class="bi bi-person-fill av-icon" id="avatarIcon-@uid"></i>
                            </div>
                            <input type="file" id="avatarFile-@uid" name="InstructorAvatarFile" accept="image/*" style="display:none" />
                            <div style="font-size:.65rem;color:var(--muted);text-align:center;margin-top:.3rem;">Ảnh HLV</div>
                        </div>
                        <div class="instructor-fields">
                            <div class="fg">
                                <label class="fg-label">Tên Huấn Luyện Viên</label>
                                <input name="Instructor" class="fg-input" placeholder="VD: Nguyễn Văn A" maxlength="100" />
                            </div>
                            <div class="fg" style="margin-bottom:0;">
                                <label class="fg-label">Chức Danh / Kinh Nghiệm</label>
                                <input name="InstructorTitle" class="fg-input"
                                       placeholder="VD: HLV quốc gia — 10 năm kinh nghiệm, cựu VĐV tỉnh" maxlength="150" />
                                <div class="fg-hint">Thêm thông tin uy tín giúp học viên tin tưởng đăng ký</div>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" name="InstructorAvatar" id="instructorAvatarPath-@uid" />
                </div>
            </div>

            <!-- 5. NỘI DUNG THU HÚT HỌC VIÊN -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-stars"></i>
                    <span class="sc-card-title">Nội Dung Thu Hút — Tăng Tỷ Lệ Đăng Ký</span>
                </div>
                <div class="sc-card-body">
                    <!-- ĐIỂM NỔI BẬT (Highlights tags) -->
                    <div class="fg">
                        <label class="fg-label">⚡ Điểm Nổi Bật (Hiển thị dạng badges)</label>
                        <div class="hl-input-row">
                            <input type="text" id="hlInput-@uid" class="fg-input"
                                   placeholder="VD: Học phí hợp lý · Lớp nhỏ chất lượng · HLV kinh nghiệm" maxlength="80" />
                            <button type="button" class="btn-hl-add" id="btnAddHl-@uid">
                                <i class="bi bi-plus-lg"></i> Thêm
                            </button>
                        </div>
                        <div class="highlight-tags" id="hlTags-@uid"></div>
                        <input type="hidden" name="Highlights" id="highlightsInput-@uid" value="" />
                        <div class="fg-hint">Gợi ý: "Cam kết hoàn tiền", "Dụng cụ miễn phí", "Chứng chỉ hoàn thành", "Lớp ≤ 10 người"</div>
                    </div>

                    <!-- TÍNH NĂNG / ƯU ĐIỂM -->
                    <div class="fg">
                        <label class="fg-label">✅ Tính Năng & Ưu Điểm Khóa Học</label>
                        <textarea name="Features" class="fg-textarea" rows="4"
                                  placeholder="- Học kỹ thuật cơ bản từ đầu: cầm vợt, di chuyển, footwork&#10;- Phân tích video bài đánh sau mỗi buổi&#10;- Tặng cầu lông tập luyện trong suốt khóa&#10;- Nhận chứng chỉ hoàn thành khóa học"></textarea>
                        <div class="fg-hint">Mỗi dòng một điểm, bắt đầu bằng dấu "-". Những gì CỤ THỂ và KHÁC BIỆT sẽ thuyết phục hơn.</div>
                    </div>

                    <!-- YÊU CẦU ĐẦU VÀO -->
                    <div class="fg">
                        <label class="fg-label">📋 Yêu Cầu Đầu Vào / Dụng Cụ Cần Mang</label>
                        <textarea name="Requirements" class="fg-textarea" rows="3"
                                  placeholder="- Không yêu cầu kinh nghiệm trước đó&#10;- Mang theo vợt (hoặc thuê tại sân giá 20,000đ)&#10;- Giày thể thao đế mềm"></textarea>
                        <div class="fg-hint">Càng rõ ràng → học viên càng không do dự đăng ký</div>
                    </div>

                    <!-- SAU KHÓA HỌC ĐẠT GÌ -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">🎯 Sau Khóa Học Bạn Sẽ Đạt Được</label>
                        <textarea name="Outcomes" class="fg-textarea" rows="3"
                                  placeholder="- Đánh được các kỹ thuật cơ bản: lob, drop, smash, clear&#10;- Tự tin tham gia các trận đấu phong trào&#10;- Hiểu luật thi đấu và cách di chuyển sân"></textarea>
                        <div class="fg-hint">Đây là yếu tố QUAN TRỌNG NHẤT giúp người dùng quyết định đăng ký</div>
                    </div>
                </div>
            </div>

            <!-- 6. HÌNH ẢNH & VIDEO -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-images"></i>
                    <span class="sc-card-title">Hình Ảnh & Video — Tạo Ấn Tượng Đầu Tiên</span>
                </div>
                <div class="sc-card-body">
                    <!-- ẢNH ĐẠI DIỆN -->
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện (Thumbnail chính)</label>
                        <div class="img-upload-zone" id="scUploadZone-@uid">
                            <img class="img-preview" id="imgPreview-@uid" src="" alt="Preview" />
                            <div class="img-upload-inner" id="uploadInner-@uid">
                                <div class="upload-icon"><i class="bi bi-cloud-upload"></i></div>
                                <div class="upload-text"><strong>Click để tải ảnh lên</strong> hoặc kéo thả</div>
                                <div id="imgName-@uid" style="font-size:.75rem;color:var(--gold);margin-top:.3rem;"></div>
                            </div>
                        </div>
                        <input type="file" id="featuredImgFile-@uid" name="featuredImage" accept="image/*" style="display:none" />
                        <div class="img-url-row">
                            <input type="text" id="imgUrlInput-@uid" name="FeaturedImage" class="fg-input"
                                   placeholder="Hoặc nhập URL ảnh: https://..." />
                            <button type="button" class="btn-url-confirm" id="btnUrlConfirm-@uid">
                                <i class="bi bi-check2"></i> Áp dụng
                            </button>
                        </div>
                    </div>

                    <!-- THƯ VIỆN ẢNH (MULTI) -->
                    <div class="fg">
                        <label class="fg-label">
                            <i class="bi bi-grid-3x3-gap-fill me-1"></i>Thư Viện Ảnh
                            <span style="font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0;"> — tối đa 10 ảnh, ≤ 5MB/ảnh</span>
                        </label>
                        <div class="gallery-drop-zone" id="galleryDrop-@uid">
                            <div class="dz-icon"><i class="bi bi-images"></i></div>
                            <div class="dz-text"><strong>Click hoặc kéo thả nhiều ảnh</strong> vào đây</div>
                            <div class="dz-sub">JPG, PNG, WEBP · Tải cùng lúc nhiều ảnh</div>
                        </div>
                        <input type="file" id="galleryFileInput-@uid" name="galleryImages" accept="image/*" multiple style="display:none" />
                        <div class="gallery-grid" id="galleryGrid-@uid"></div>
                        <div class="gallery-count" id="galleryCount-@uid"></div>
                    </div>

                    <!-- VIDEO YOUTUBE / FACEBOOK -->
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label"><i class="bi bi-play-circle-fill me-1"></i>Video Giới Thiệu Khóa Học</label>
                        <div style="display:flex;gap:.5rem;align-items:flex-start;">
                            <input type="text" name="VideoUrl" id="videoUrlInput-@uid" class="fg-input"
                                   placeholder="https://www.youtube.com/watch?v=... hoặc link Facebook Video" />
                            <button type="button" class="btn-url-confirm" id="btnVideoPreview-@uid">
                                <i class="bi bi-play"></i> Xem thử
                            </button>
                        </div>
                        <div class="video-preview" id="videoPreview-@uid">
                            <iframe id="videoIframe-@uid" src="" allowfullscreen></iframe>
                        </div>
                        <div class="fg-hint">Video thực tế buổi học sẽ tăng đáng kể tỷ lệ đăng ký</div>
                    </div>
                </div>
            </div>

            <!-- 7. TRẠNG THÁI & HIỂN THỊ -->
            <div class="sc-card">
                <div class="sc-card-head">
                    <i class="bi bi-toggles"></i>
                    <span class="sc-card-title">Trạng Thái & Hiển Thị</span>
                </div>
                <div class="sc-card-body">
                    <div class="fg">
                        <label class="fg-label">Trạng Thái</label>
                        <div class="status-opts" id="statusOpts-@uid">
                            <div class="status-opt selected" data-status="Active">
                                <span class="status-dot" style="background:var(--green);"></span> Đang Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Inactive">
                                <span class="status-dot" style="background:var(--muted);"></span> Ngừng Hoạt Động
                            </div>
                            <div class="status-opt" data-status="Full">
                                <span class="status-dot" style="background:var(--red);"></span> Đã Đầy Lớp
                            </div>
                        </div>
                        <input name="Status" type="hidden" id="statusInput-@uid" value="Active" />
                    </div>
                    <div class="fg" style="margin-bottom:0;">
                        <label class="fg-label">Cài Đặt Hiển Thị</label>
                        <div class="toggle-row">
                            <label class="toggle-item">
                                <input name="IsFeatured" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-star text-warning me-1"></i> Khóa học nổi bật</span>
                            </label>
                            <label class="toggle-item">
                                <input name="IsPopular" type="checkbox" value="true" />
                                <span class="toggle-label"><i class="bi bi-fire text-danger me-1"></i> Đang hot / phổ biến</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- FOOTER -->
    <div class="sc-footer">
        <button type="button" class="btn-sc-cancel" data-bs-dismiss="modal">
            <i class="bi bi-x-circle"></i> Hủy
        </button>
        <button type="button" class="btn-sc-save" id="btnCourseSubmit-@uid"
                data-form="frmCourseCreate-@uid" data-url="/AdminService/CourseCreate">
            <i class="bi bi-plus-circle"></i> Thêm Khóa Học
        </button>
    </div>

</div>

<script>
    (function () {
        var UID = '@uid';
        function el(id) { return document.getElementById(id + '-' + UID); }

        // ── LEVEL CARDS ──────────────────────────────────────────
        var levelCards = el('levelCards');
        if (levelCards) {
            levelCards.querySelectorAll('.lv-card').forEach(function (card) {
                card.addEventListener('click', function () {
                    levelCards.querySelectorAll('.lv-card').forEach(function (c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('levelInput').value = this.dataset.level;
                    var req = el('levelRequired');
                    if (req) req.style.display = 'none';
                });
            });
        }

        // ── STATUS OPTIONS ────────────────────────────────────────
        var statusOpts = el('statusOpts');
        if (statusOpts) {
            statusOpts.querySelectorAll('.status-opt').forEach(function (opt) {
                opt.addEventListener('click', function () {
                    statusOpts.querySelectorAll('.status-opt').forEach(function (c) { c.classList.remove('selected'); });
                    this.classList.add('selected');
                    el('statusInput').value = this.dataset.status;
                });
            });
        }

        // ── FEATURED IMAGE ────────────────────────────────────────
        var uploadZone = el('scUploadZone');
        var fileInput  = el('featuredImgFile');
        var imgPreview = el('imgPreview');
        var uploadInner = el('uploadInner');

        function showPreview(src) {
            if (!imgPreview) return;
            imgPreview.src = src;
            imgPreview.classList.add('show');
            if (uploadInner) uploadInner.style.display = 'none';
            if (uploadZone) uploadZone.classList.add('has-preview');
        }
        function resetPreview() {
            if (!imgPreview) return;
            imgPreview.src = '';
            imgPreview.classList.remove('show');
            if (uploadInner) uploadInner.style.display = '';
            if (uploadZone) uploadZone.classList.remove('has-preview');
        }

        if (uploadZone && fileInput) {
            uploadZone.addEventListener('click', function (e) {
                if (e.target === imgPreview) { resetPreview(); fileInput.value = ''; return; }
                fileInput.click();
            });
            fileInput.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                var nameEl = el('imgName');
                if (nameEl) nameEl.textContent = this.files[0].name;
                var reader = new FileReader();
                reader.onload = function (ev) { showPreview(ev.target.result); };
                reader.readAsDataURL(this.files[0]);
            });
            uploadZone.addEventListener('dragover', function (e) { e.preventDefault(); this.style.borderColor = 'var(--gold)'; });
            uploadZone.addEventListener('dragleave', function () { this.style.borderColor = ''; });
            uploadZone.addEventListener('drop', function (e) {
                e.preventDefault(); this.style.borderColor = '';
                var file = e.dataTransfer.files[0];
                if (!file || !file.type.startsWith('image/')) return;
                var dt = new DataTransfer(); dt.items.add(file); fileInput.files = dt.files;
                var reader = new FileReader();
                reader.onload = function (ev) { showPreview(ev.target.result); };
                reader.readAsDataURL(file);
            });
        }

        var btnUrlConfirm = el('btnUrlConfirm');
        var imgUrlInput = el('imgUrlInput');
        if (btnUrlConfirm && imgUrlInput) {
            btnUrlConfirm.addEventListener('click', function () {
                var url = imgUrlInput.value.trim();
                if (!url) { resetPreview(); return; }
                showPreview(url);
                if (fileInput) fileInput.value = '';
            });
            imgUrlInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); btnUrlConfirm.click(); } });
        }

        // ── INSTRUCTOR AVATAR ─────────────────────────────────────
        var avatarZone    = el('avatarZone');
        var avatarFile    = el('avatarFile');
        var avatarPreview = el('avatarPreview');
        var avatarIcon    = el('avatarIcon');

        if (avatarZone && avatarFile) {
            avatarZone.addEventListener('click', function () { avatarFile.click(); });
            avatarFile.addEventListener('change', function () {
                if (!this.files || !this.files[0]) return;
                var reader = new FileReader();
                reader.onload = function (ev) {
                    avatarPreview.src = ev.target.result;
                    avatarPreview.classList.add('show');
                    if (avatarIcon) avatarIcon.style.display = 'none';
                };
                reader.readAsDataURL(this.files[0]);
            });
        }

        // ── GALLERY MULTI-IMAGE ───────────────────────────────────
        var galleryDrop   = el('galleryDrop');
        var galleryInput  = el('galleryFileInput');
        var galleryGrid   = el('galleryGrid');
        var galleryCount  = el('galleryCount');
        var galleryFiles  = []; // FileList simulation via array
        var MAX_GALLERY   = 10;

        function updateGalleryCount() {
            if (!galleryCount) return;
            var n = galleryFiles.length;
            galleryCount.textContent = n > 0 ? n + ' ảnh đã thêm' + (n >= MAX_GALLERY ? ' (đã đạt tối đa)' : '') : '';
        }

        function renderGalleryGrid() {
            if (!galleryGrid) return;
            galleryGrid.innerHTML = '';
            galleryFiles.forEach(function (file, idx) {
                var thumb = document.createElement('div');
                thumb.className = 'gallery-thumb' + (idx === 0 ? ' is-primary' : '');
                thumb.innerHTML = '<img src="" alt=""><div class="thumb-overlay">' +
                    '<button type="button" class="thumb-btn primary" title="Đặt làm ảnh chính"><i class="bi bi-star-fill"></i></button>' +
                    '<button type="button" class="thumb-btn del" title="Xóa"><i class="bi bi-trash3-fill"></i></button>' +
                    '</div>';
                var img = thumb.querySelector('img');
                var reader = new FileReader();
                reader.onload = function (ev) { img.src = ev.target.result; };
                reader.readAsDataURL(file);

                thumb.querySelector('.thumb-btn.del').addEventListener('click', function () {
                    galleryFiles.splice(idx, 1);
                    renderGalleryGrid();
                    updateGalleryCount();
                    rebuildFileInput();
                });
                thumb.querySelector('.thumb-btn.primary').addEventListener('click', function () {
                    var f = galleryFiles.splice(idx, 1)[0];
                    galleryFiles.unshift(f);
                    renderGalleryGrid();
                    rebuildFileInput();
                });
                galleryGrid.appendChild(thumb);
            });
            updateGalleryCount();
        }

        function addGalleryFiles(files) {
            Array.from(files).forEach(function (file) {
                if (!file.type.startsWith('image/')) return;
                if (file.size > 5 * 1024 * 1024) { alert(file.name + ' quá 5MB, bỏ qua.'); return; }
                if (galleryFiles.length >= MAX_GALLERY) { alert('Tối đa ' + MAX_GALLERY + ' ảnh.'); return; }
                galleryFiles.push(file);
            });
            renderGalleryGrid();
            rebuildFileInput();
        }

        function rebuildFileInput() {
            // Sync galleryFiles -> input file (DataTransfer trick)
            if (!galleryInput) return;
            var dt = new DataTransfer();
            galleryFiles.forEach(function (f) { dt.items.add(f); });
            galleryInput.files = dt.files;
        }

        if (galleryDrop && galleryInput) {
            galleryDrop.addEventListener('click', function () { galleryInput.click(); });
            galleryInput.addEventListener('change', function () {
                addGalleryFiles(this.files);
                this.value = '';
            });
            galleryDrop.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('drag-over'); });
            galleryDrop.addEventListener('dragleave', function () { this.classList.remove('drag-over'); });
            galleryDrop.addEventListener('drop', function (e) {
                e.preventDefault(); this.classList.remove('drag-over');
                addGalleryFiles(e.dataTransfer.files);
            });
        }

        // ── VIDEO PREVIEW ─────────────────────────────────────────
        var btnVideoPreview = el('btnVideoPreview');
        var videoUrlInput   = el('videoUrlInput');
        var videoPreview    = el('videoPreview');
        var videoIframe     = el('videoIframe');

        function getYouTubeEmbedUrl(url) {
            var match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);
            return match ? 'https://www.youtube.com/embed/' + match[1] : null;
        }

        if (btnVideoPreview && videoUrlInput && videoIframe) {
            btnVideoPreview.addEventListener('click', function () {
                var url = videoUrlInput.value.trim();
                if (!url) { videoPreview.classList.remove('show'); return; }
                var embedUrl = getYouTubeEmbedUrl(url);
                if (embedUrl) {
                    videoIframe.src = embedUrl;
                    videoPreview.classList.add('show');
                } else {
                    alert('Hiện tại chỉ hỗ trợ xem thử YouTube. URL sẽ vẫn được lưu.');
                    videoPreview.classList.remove('show');
                }
            });
        }

        // ── HIGHLIGHTS TAGS ───────────────────────────────────────
        var hlInput     = el('hlInput');
        var btnAddHl    = el('btnAddHl');
        var hlTagsDiv   = el('hlTags');
        var hlHidden    = el('highlightsInput');
        var highlights  = [];

        function renderHighlights() {
            if (!hlTagsDiv) return;
            hlTagsDiv.innerHTML = '';
            highlights.forEach(function (hl, idx) {
                var tag = document.createElement('div');
                tag.className = 'hl-tag';
                tag.innerHTML = hl + '<button type="button" class="hl-remove" title="Xóa">✕</button>';
                tag.querySelector('.hl-remove').addEventListener('click', function () {
                    highlights.splice(idx, 1);
                    renderHighlights();
                });
                hlTagsDiv.appendChild(tag);
            });
            if (hlHidden) hlHidden.value = JSON.stringify(highlights);
        }

        function addHighlight() {
            if (!hlInput) return;
            var val = hlInput.value.trim();
            if (!val || highlights.includes(val) || highlights.length >= 8) return;
            highlights.push(val);
            hlInput.value = '';
            renderHighlights();
        }

        if (btnAddHl) btnAddHl.addEventListener('click', addHighlight);
        if (hlInput) hlInput.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); addHighlight(); } });

        // ── SUBMIT ────────────────────────────────────────────────
        var btnSubmit = el('btnCourseSubmit');
        if (btnSubmit) {
            btnSubmit.addEventListener('click', function () {
                var formId = this.dataset.form;
                var url    = this.dataset.url;
                var form   = document.getElementById(formId);
                if (!form) return;

                var levelVal = el('levelInput') ? el('levelInput').value : '';
                if (!levelVal) {
                    var req = el('levelRequired');
                    if (req) req.style.display = 'block';
                    levelCards && levelCards.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                if (!form.checkValidity()) { form.reportValidity(); return; }

                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lưu...';

                if (typeof submitServiceForm === 'function') {
                    submitServiceForm(formId, url);
                } else {
                    fetch(url, { method: 'POST', body: new FormData(form) })
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (res.success) {
                                var modal = bootstrap.Modal.getInstance(document.getElementById('modalService'));
                                if (modal) modal.hide();
                                location.reload();
                            } else {
                                alert(res.message || 'Có lỗi xảy ra, vui lòng thử lại.');
                                btnSubmit.disabled = false;
                                btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Khóa Học';
                            }
                        })
                        .catch(function (err) {
                            alert('Lỗi kết nối: ' + err.message);
                            btnSubmit.disabled = false;
                            btnSubmit.innerHTML = '<i class="bi bi-plus-circle"></i> Thêm Khóa Học';
                        });
                }
            });
        }

    })();
</script>
