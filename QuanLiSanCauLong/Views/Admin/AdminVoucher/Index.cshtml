@model IEnumerable<QuanLiSanCauLong.ViewModels.VoucherViewModel>
@{
    ViewData["Title"] = "Quản lý Voucher";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var ct = DateTime.Now;
}
@await Html.PartialAsync("_VoucherShared")

<div>

    @* ── ALERTS ── *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-ok"><i class="bi bi-check-circle-fill"></i> @Html.Raw(TempData["SuccessMessage"])</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-err"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]</div>
    }

    @* ── PAGE HEADER ── *@
    <div class="pg-head">
        <div>
            <h1 class="pg-title">Quản Lý <em>Voucher</em></h1>
            <div class="pg-sub">Tạo và quản lý mã giảm giá cho đặt sân & sản phẩm</div>
        </div>
        <div style="display:flex;gap:.65rem;align-items:center;">
            <a asp-action="Create" class="btn-gold">
                <i class="bi bi-plus-circle"></i> Tạo Voucher
            </a>
        </div>
    </div>

    @* ── STAT STRIP ── *@
    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@ViewBag.TotalVouchers</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--deep);"></span>Tổng voucher</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--green);">@ViewBag.ActiveVouchers</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--green);"></span>Đang hoạt động</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--red);">@ViewBag.ExpiredVouchers</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--red);"></span>Đã hết hạn</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--gold);">@ViewBag.TotalUsage</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Lượt sử dụng</div>
        </div>
    </div>

    @* ── TOOLBAR: filter + search ── *@
    <form method="get" asp-action="Index">
        <div class="toolbar">
            <div class="tb-search">
                <i class="bi bi-search"></i>
                <input type="text" name="search" placeholder="Tìm mã hoặc tên voucher…"
                       value="@ViewBag.Search" oninput="filterTable(this.value)" />
            </div>
            @{
                var curStatus = ViewBag.Status as string ?? "";
                var curFor    = ViewBag.ApplicableFor as string ?? "";
            }
            <select name="status" class="tb-sel" onchange="this.form.submit()">
                <option value="">Tất cả trạng thái</option>
                @if (curStatus == "active")   { <option value="active" selected>Đang hoạt động</option> }
                else                          { <option value="active">Đang hoạt động</option> }
                @if (curStatus == "upcoming") { <option value="upcoming" selected>Chưa bắt đầu</option> }
                else                          { <option value="upcoming">Chưa bắt đầu</option> }
                @if (curStatus == "expired")  { <option value="expired" selected>Đã hết hạn</option> }
                else                          { <option value="expired">Đã hết hạn</option> }
                @if (curStatus == "inactive") { <option value="inactive" selected>Đã tắt</option> }
                else                          { <option value="inactive">Đã tắt</option> }
            </select>
            <select name="applicableFor" class="tb-sel" onchange="this.form.submit()">
                <option value="">Tất cả loại</option>
                @if (curFor == "All")     { <option value="All" selected>Tất cả dịch vụ</option> }
                else                      { <option value="All">Tất cả dịch vụ</option> }
                @if (curFor == "Booking") { <option value="Booking" selected>Đặt sân</option> }
                else                      { <option value="Booking">Đặt sân</option> }
                @if (curFor == "Order")   { <option value="Order" selected>Đơn hàng</option> }
                else                      { <option value="Order">Đơn hàng</option> }
            </select>
            @if (!string.IsNullOrEmpty(ViewBag.Status as string) || !string.IsNullOrEmpty(ViewBag.ApplicableFor as string) || !string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn-ov" style="white-space:nowrap;">
                    <i class="bi bi-x-circle"></i> Xóa lọc
                </a>
            }
        </div>
    </form>

    @* ── TABLE ── *@
    <div class="v-table-wrap">
        <table class="v-table" id="voucherTable">
            <thead>
                <tr>
                    <th>Mã Voucher</th>
                    <th>Loại giảm</th>
                    <th>Áp dụng</th>
                    <th>Sử dụng</th>
                    <th>Hiệu lực</th>
                    <th>Trạng thái</th>
                    <th style="text-align:right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var v in Model)
                    {
                        var isActive = v.IsActive && v.StartDate <= ct && v.EndDate >= ct;
                        var isUpcoming = v.StartDate > ct;
                        var isExpired = v.EndDate < ct;
                        string sCls, sLbl;

                        if (!v.IsActive) { sCls = "chip-grey"; sLbl = "Đã tắt"; }
                        else if (isUpcoming) { sCls = "chip-blue"; sLbl = "Chưa bắt đầu"; }
                        else if (isExpired) { sCls = "chip-red"; sLbl = "Hết hạn"; }
                        else { sCls = "chip-green"; sLbl = "Đang chạy"; }

                        var pct = (v.UsageLimit.HasValue && v.UsageLimit > 0)
                        ? Math.Min((double)v.UsedCount / v.UsageLimit.Value * 100, 100) : 0;
                        var pCol = pct >= 90 ? "var(--red)" : pct >= 60 ? "var(--gold)" : "var(--green)";

                        var discLabel = v.DiscountType == "Percentage"
                        ? $"−{v.DiscountValue:0.##}%"
                        : $"−{v.DiscountValue:N0}đ";
                        var maxLabel = (v.DiscountType == "Percentage" && v.MaxDiscount.HasValue)
                        ? $" (tối đa {v.MaxDiscount.Value:N0}đ)" : "";

                        <tr data-name="@(v.VoucherCode.ToLower()) @(v.VoucherName?.ToLower())">
                            <td>
                                <div style="display:flex;flex-direction:column;gap:.2rem;">
                                    <span style="font-family:monospace;font-size:.92rem;font-weight:700;color:var(--deep);letter-spacing:.08em;">@v.VoucherCode</span>
                                    <span style="font-size:.78rem;color:var(--muted);">@v.VoucherName</span>
                                </div>
                            </td>
                            <td>
                                <div style="font-weight:700;font-size:.9rem;color:var(--red);">@discLabel</div>
                                <div style="font-size:.75rem;color:var(--muted);">@maxLabel Min: @(v.MinOrderAmount.HasValue ? v.MinOrderAmount.Value.ToString("N0") + "đ" : "0đ")</div>
                            </td>
                            <td>
                                <span class="chip @(v.ApplicableFor == "Booking" ? "chip-blue" : v.ApplicableFor == "Order" ? "chip-gold" : "chip-grey")">
                                    @(v.ApplicableFor == "Booking" ? "Đặt sân" : v.ApplicableFor == "Order" ? "Đơn hàng" : "Tất cả")
                                </span>
                            </td>
                            <td>
                                <div style="font-weight:700;font-size:.88rem;">
                                    @v.UsedCount / @(v.UsageLimit.HasValue ? v.UsageLimit.Value.ToString() : "∞")
                                </div>
                                @if (v.UsageLimit.HasValue && v.UsageLimit > 0)
                                {
                                    <div class="prog-wrap"><div class="prog-bar" style="width:@pct%;background:@pCol;"></div></div>
                                }
                            </td>
                            <td>
                                <div style="font-size:.82rem;font-weight:600;">@v.StartDate?.ToString("dd/MM/yy")</div>
                                <div style="font-size:.75rem;color:var(--muted);">→ @v.EndDate?.ToString("dd/MM/yy")</div>
                            </td>
                            <td>
                                <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                                    <input type="checkbox" class="toggle-status" data-id="@v.VoucherId"
                                           @(v.IsActive ? "checked" : "")
                                           style="width:16px;height:16px;accent-color:var(--gold);cursor:pointer;" />
                                    <span class="chip @sCls">● @sLbl</span>
                                </label>
                            </td>
                            <td>
                                <div class="act-g" style="justify-content:flex-end;">
                                    <a asp-action="Details" asp-route-id="@v.VoucherId" class="act-b view" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Usage"   asp-route-id="@v.VoucherId" class="act-b usage" title="Lịch sử dùng"><i class="bi bi-clock-history"></i></a>
                                    <a asp-action="Edit"    asp-route-id="@v.VoucherId" class="act-b edit" title="Sửa"><i class="bi bi-pencil"></i></a>
                                    <button onclick="confirmDelete(@v.VoucherId)" class="act-b del" title="Xóa"><i class="bi bi-trash3"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-ticket-perforated"></i>
                                <div>Không tìm thấy voucher nào</div>
                                <a asp-action="Create" class="btn-gold" style="margin-top:1rem;font-size:.8rem;">
                                    <i class="bi bi-plus-circle"></i> Tạo voucher đầu tiên
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // ── Client-side search filter ──
        function filterTable(q) {
            q = q.toLowerCase();
            document.querySelectorAll('#voucherTable tbody tr[data-name]').forEach(function(r) {
                r.style.display = (r.dataset.name || '').includes(q) ? '' : 'none';
            });
        }

        // ── Toggle active status ──
        document.querySelectorAll('.toggle-status').forEach(function(cb) {
            cb.addEventListener('change', function() {
                var id = this.dataset.id, val = this.checked;
                $.post('/AdminVoucher/ToggleStatus', { voucherId: id, isActive: val }, function(res) {
                    if (!res.success) {
                        cb.checked = !val;
                        Swal.fire('Lỗi', res.message, 'error');
                    }
                });
            });
        });

        // ── Delete confirm ──
        function confirmDelete(id) {
            Swal.fire({
                title: 'Xóa voucher?',
                text: 'Dữ liệu sẽ không thể khôi phục!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c94b2a',
                cancelButtonColor: '#8a7560',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy',
                reverseButtons: true
            }).then(function(r) {
                if (!r.isConfirmed) return;
                $.ajax({ url: '/AdminVoucher/Delete/' + id, type: 'POST', success: function(res) {
                    if (res.success)
                        Swal.fire({ icon: 'success', title: 'Đã xóa!', text: res.message, timer: 1500, showConfirmButton: false })
                            .then(function() { location.reload(); });
                    else
                        Swal.fire('Không thể xóa', res.message, 'error');
                }});
            });
        }
    </script>
}
