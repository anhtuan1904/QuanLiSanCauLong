@model IEnumerable<QuanLiSanCauLong.ViewModels.VoucherViewModel>
@{
    ViewData["Title"] = "Quản lý Voucher";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var ct = DateTime.Now;
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>

    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .pg-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .25rem;
    }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .72rem 1.5rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .btn-dv {
        padding: .65rem 1.25rem;
        border: 1.5px solid rgba(201,75,42,.3);
        border-radius: 8px;
        background: rgba(201,75,42,.07);
        color: #c94b2a;
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-dv:hover {
            background: #c94b2a;
            color: #fff;
            border-color: #c94b2a;
        }

    .btn-back {
        width: 36px;
        height: 36px;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .sys-ok {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.25);
        color: #16a34a;
    }

    .sys-err {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(201,75,42,.06);
        border: 1px solid rgba(201,75,42,.25);
        color: #c94b2a;
    }

    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .71rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .35rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .tb-search {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .tb-search input {
            width: 100%;
            padding: .65rem 1rem .65rem 2.25rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .84rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
                background: var(--cream);
            }

        .tb-search i {
            position: absolute;
            left: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .82rem;
        }

    .tb-sel {
        padding: .65rem 1rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    .v-table-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .v-table {
        width: 100%;
        border-collapse: collapse;
    }

        .v-table th {
            background: var(--warm);
            padding: .8rem 1rem;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .v-table td {
            padding: .95rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .86rem;
            vertical-align: middle;
            color: var(--deep);
        }

        .v-table tr:last-child td {
            border-bottom: none;
        }

        .v-table tbody tr:hover td {
            background: var(--cream);
        }

    .vc-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

        .vc-icon.pct {
            background: linear-gradient(135deg,var(--gold),var(--gold2));
            color: var(--deep);
        }

        .vc-icon.fix {
            background: var(--warm);
            color: var(--gold);
        }

    .code-tag {
        display: inline-block;
        background: var(--deep);
        color: var(--gold2);
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        padding: .18rem .55rem;
        border-radius: 4px;
        font-family: monospace;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .22rem .6rem;
        border-radius: 4px;
        letter-spacing: .04em;
        white-space: nowrap;
    }

    .chip-green {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-red {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-gold {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .chip-blue {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .chip-neutral {
        background: var(--warm);
        color: var(--muted);
    }

    .disc-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--gold);
    }

    .disc-sub {
        font-size: .71rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .prog-wrap {
        height: 5px;
        background: var(--border);
        border-radius: 3px;
        margin-top: .4rem;
    }

    .prog-bar {
        height: 5px;
        border-radius: 3px;
    }

    .act-g {
        display: flex;
        gap: .3rem;
        align-items: center;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        font-size: .78rem;
        text-decoration: none;
    }

        .act-b.view:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.07);
        }

        .act-b.edit:hover {
            border-color: #4f46e5;
            color: #4f46e5;
            background: rgba(79,70,229,.07);
        }

        .act-b.del:hover {
            border-color: #c94b2a;
            color: #c94b2a;
            background: rgba(201,75,42,.07);
        }

    .f-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

        .f-card:last-child {
            margin-bottom: 0;
        }

    .f-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .f-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .f-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .f-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-r2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-r3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

    .req {
        color: #c94b2a;
    }

    .fg-input, .fg-sel, .fg-ta {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s,background .2s;
    }

        .fg-input:focus, .fg-sel:focus, .fg-ta:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

        .fg-input[readonly] {
            background: var(--warm);
            cursor: default;
            color: var(--muted);
        }

    .fg-ta {
        resize: vertical;
        min-height: 80px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .fg-addon {
        display: flex;
    }

        .fg-addon .fg-input {
            border-radius: 7px 0 0 7px;
            border-right: none;
        }

    .fg-addon-txt {
        padding: .65rem .9rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-left: none;
        border-radius: 0 7px 7px 0;
        font-size: .84rem;
        font-weight: 700;
        color: var(--muted);
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .disc-opts {
        display: flex;
        gap: .65rem;
    }

    .disc-opt {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        padding: .65rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
    }

        .disc-opt:hover {
            border-color: rgba(212,160,23,.5);
            color: var(--deep);
        }

        .disc-opt.active {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            color: var(--deep);
        }

    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    .v-modal .modal-content {
        display: flex;
        flex-direction: column;
        max-height: 88vh;
        overflow: hidden;
        border-radius: 14px;
        border: none;
        box-shadow: 0 20px 60px rgba(26,18,9,.18);
    }

    .v-mh {
        flex-shrink: 0;
        padding: 1.4rem 1.75rem 1rem;
        border-bottom: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .v-modal form {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
    }

    .v-mb {
        flex: 1;
        overflow-y: auto !important;
        padding: 1.25rem 1.75rem 1rem;
        min-height: 0;
    }

        .v-mb::-webkit-scrollbar {
            width: 5px;
        }

        .v-mb::-webkit-scrollbar-track {
            background: var(--warm);
        }

        .v-mb::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    .v-mf {
        flex-shrink: 0;
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
    }

    .v-mlabel {
        font-size: .64rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .3rem;
    }

        .v-mlabel::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .v-mtitle {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
    }

        .v-mtitle em {
            font-style: italic;
            color: var(--gold);
        }

    .v-mclose {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .v-mclose:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .pg-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-top: 1.5rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .25;
        }

    .v-crumb {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .v-crumb a {
            color: var(--muted);
            text-decoration: none;
        }

            .v-crumb a:hover {
                color: var(--gold);
            }

    .sb {
        background: var(--deep);
        border-radius: 12px;
        padding: 1.5rem 1.75rem;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .sb-l {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .sb-code {
        background: rgba(245,200,66,.12);
        border: 1px solid rgba(245,200,66,.3);
        border-radius: 8px;
        padding: .55rem 1rem;
    }

        .sb-code span {
            font-family: monospace;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--gold2);
            letter-spacing: .12em;
        }

    .sb-info h4 {
        font-family: 'Playfair Display',serif;
        color: #fff;
        font-size: 1.15rem;
        margin: 0 0 .2rem;
    }

    .sb-info p {
        color: rgba(255,255,255,.5);
        font-size: .82rem;
        margin: 0;
    }

    .sb-r {
        text-align: right;
    }

        .sb-r .big {
            font-family: 'Playfair Display',serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--gold2);
            line-height: 1;
        }

        .sb-r small {
            color: rgba(255,255,255,.45);
            font-size: .72rem;
            display: block;
            margin-top: .2rem;
        }

    .av-cust {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .av-ava {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(212,160,23,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-size: .85rem;
        flex-shrink: 0;
    }

</style>

<div>

    <div class="pg-head">
        <div>
            <h1 class="pg-title">Voucher & <em>Khuyến Mãi</em></h1>
            <div class="pg-sub">Tạo và quản lý các chiến dịch giảm giá cho hệ thống</div>
        </div>
        <button class="btn-gold" data-bs-toggle="modal" data-bs-target="#modalCreate">
            <i class="bi bi-plus-circle"></i> Tạo Voucher Mới
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-ok"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-err"><i class="bi bi-exclamation-circle"></i>@TempData["ErrorMessage"]</div>
    }

    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@ViewBag.TotalVouchers</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng Voucher</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@ViewBag.ActiveVouchers</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Đang Hoạt Động</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#4f46e5;">@ViewBag.TotalUsage</div>
            <div class="stat-l"><span class="stat-dot" style="background:#4f46e5;"></span>Lượt Sử Dụng</div>
        </div>
        <div class="stat-box" style="padding:1rem 1.5rem;">
            <div class="stat-l" style="margin-top:0;margin-bottom:.55rem;">Bộ Lọc Nhanh</div>
            <form method="get">
                @{
                    var curStatus = (string)ViewBag.CurrentStatus ?? "";
                }
                <select name="status" class="tb-sel" style="width:100%;padding:.42rem .75rem;font-size:.8rem;" onchange="this.form.submit()">
                    <option value="" selected="@(curStatus == "" ? "selected" : null)">Tất cả trạng thái</option>
                    <option value="active" selected="@(curStatus == "active" ? "selected" : null)">Đang hoạt động</option>
                    <option value="upcoming" selected="@(curStatus == "upcoming" ? "selected" : null)">Sắp diễn ra</option>
                    <option value="expired" selected="@(curStatus == "expired" ? "selected" : null)">Đã hết hạn</option>
                    <option value="inactive" selected="@(curStatus == "inactive" ? "selected" : null)">Đã tạm dừng</option>
                </select>
            </form>
        </div>
    </div>

    <div class="toolbar">
        <div class="tb-search">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Tìm mã hoặc tên voucher..." oninput="filterV(this.value)">
        </div>
    </div>

    <div class="v-table-wrap">
        <table class="v-table">
            <thead>
                <tr>
                    <th>Voucher</th>
                    <th>Loại Giảm</th>
                    <th>Giá Trị</th>
                    <th>Lượt Dùng</th>
                    <th>Thời Hạn</th>
                    <th>Trạng Thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var v in Model)
                    {
                        var sCls = !v.IsActive ? "chip-neutral" : (v.StartDate.HasValue && v.StartDate > ct) ? "chip-blue" : (v.EndDate.HasValue && v.EndDate < ct) ? "chip-red" : "chip-green";
                        var sLbl = !v.IsActive ? "Tạm dừng" : (v.StartDate.HasValue && v.StartDate > ct) ? "Sắp diễn ra" : (v.EndDate.HasValue && v.EndDate < ct) ? "Hết hạn" : "Đang chạy";
                        double pct = 0;
                        if (v.UsageLimit.HasValue && v.UsageLimit > 0)
                            pct = Math.Min(100, (double)v.UsedCount * 100.0 / v.UsageLimit.Value);
                        var pCol = pct >= 90 ? "#c94b2a" : pct >= 60 ? "#d4a017" : "#16a34a";
                        <tr data-name="@v.VoucherCode.ToLower() @v.VoucherName.ToLower()">
                            <td>
                                <div style="display:flex;align-items:center;gap:.75rem;">
                                    <div class="vc-icon @(v.DiscountType == "Percentage" ? "pct" : "fix")">
                                        <i class="bi @(v.DiscountType == "Percentage" ? "bi-percent" : "bi-cash-stack")"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight:700;font-size:.88rem;color:var(--deep);">@v.VoucherName</div>
                                        <div style="margin-top:.25rem;"><span class="code-tag">@v.VoucherCode</span></div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (v.DiscountType == "Percentage")
                                {
                                    <span class="chip chip-gold">% Phần trăm</span>
                                }
                                else
                                {

                                    <span class="chip chip-neutral">đ Cố định</span>
                                }
                            </td>
                            <td>
                                <div class="disc-val">
                                    @if (v.DiscountType == "Percentage")
                                    {
                                        @($"{v.DiscountValue:0.#}%")
                                    }
                                    else
                                    {

                                        @(v.DiscountValue.ToString("N0") + "đ")
                                    }
                                </div>
                                <div class="disc-sub">
                                    Tối đa: @(v.MaxDiscount.HasValue? v.MaxDiscount.Value.ToString("N0") + "đ" : "∞") ·
                                    Min: @(v.MinOrderAmount.HasValue? v.MinOrderAmount.Value.ToString("N0") + "đ" : "0đ")
                                </div>
                            </td>
                            <td>
                                <div style="font-weight:700;font-size:.88rem;">
                                    @v.UsedCount / @(v.UsageLimit.HasValue? v.UsageLimit.Value.ToString() : "∞")
                                </div>
                                @if (v.UsageLimit.HasValue && v.UsageLimit > 0)
                                {
                                    <div class="prog-wrap"><div class="prog-bar" style="width:@pct%;background:@pCol;"></div></div>
                                }
                            </td>
                            <td>
                                <div style="font-size:.82rem;font-weight:600;">@(string.Format("{0:dd/MM/yy}", v.StartDate))</div>
                                <div style="font-size:.75rem;color:var(--muted);">→ @(string.Format("{0:dd/MM/yy}", v.EndDate))</div>
                            </td>
                            <td><span class="chip @sCls">● @sLbl</span></td>
                            <td>
                                <div class="act-g">
                                    <a asp-action="Details" asp-route-id="@v.VoucherId" class="act-b view" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@v.VoucherId" class="act-b edit" title="Sửa"><i class="bi bi-pencil"></i></a>
                                    <button onclick="confirmDelete(@v.VoucherId)" class="act-b del" title="Xóa"><i class="bi bi-trash3"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-ticket-perforated"></i>
                                <div>Không tìm thấy voucher nào</div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@* MODAL TẠO VOUCHER *@
<div class="modal fade v-modal" id="modalCreate" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="v-mh">
                <div>
                    <div class="v-mlabel"><i class="bi bi-ticket-perforated"></i> Voucher mới</div>
                    <div class="v-mtitle">Thiết Lập <em>Voucher</em></div>
                </div>
                <button type="button" class="v-mclose" data-bs-dismiss="modal">
                    <i class="bi bi-x" style="font-size:1.1rem;"></i>
                </button>
            </div>
            <form asp-action="Create" method="post">
                <div class="v-mb">
                    <div class="f-card">
                        <div class="f-card-head"><i class="bi bi-info-circle"></i><span class="f-card-title">Thông Tin Cơ Bản</span></div>
                        <div class="f-card-body">
                            <div class="fg-r2 fg">
                                <div>
                                    <label class="fg-label">Mã Voucher <span class="req">*</span></label>
                                    <input name="VoucherCode" class="fg-input" style="text-transform:uppercase;font-weight:700;letter-spacing:.1em;font-family:monospace;" placeholder="VD: KM50K" required />
                                </div>
                                <div>
                                    <label class="fg-label">Tên Chương Trình <span class="req">*</span></label>
                                    <input name="VoucherName" class="fg-input" placeholder="Chào mừng thành viên mới" required />
                                </div>
                            </div>
                            <div class="fg" style="margin-bottom:0;">
                                <label class="fg-label">Ghi Chú / Điều Kiện</label>
                                <textarea name="Description" class="fg-ta" placeholder="Ghi chú chi tiết điều kiện áp dụng..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="f-card">
                        <div class="f-card-head"><i class="bi bi-currency-exchange"></i><span class="f-card-title">Cấu Hình Giảm Giá</span></div>
                        <div class="f-card-body">
                            <div class="fg">
                                <label class="fg-label">Loại Giảm Giá</label>
                                <input type="hidden" name="DiscountType" id="mDiscInput" value="Percentage" />
                                <div class="disc-opts" id="mDiscOpts">
                                    <div class="disc-opt active" data-val="Percentage"><i class="bi bi-percent"></i> Phần Trăm (%)</div>
                                    <div class="disc-opt" data-val="FixedAmount"><i class="bi bi-cash-stack"></i> Số Tiền Cố Định (đ)</div>
                                </div>
                            </div>
                            <div class="fg-r2 fg">
                                <div>
                                    <label class="fg-label" id="mLabelVal">Giá Trị Giảm (%) <span class="req">*</span></label>
                                    <div class="fg-addon">
                                        <input name="DiscountValue" type="number" min="0" class="fg-input" required />
                                        <span class="fg-addon-txt" id="mAddon">%</span>
                                    </div>
                                </div>
                                <div id="mMaxBox">
                                    <label class="fg-label">Giảm Tối Đa (đ)</label>
                                    <input name="MaxDiscount" type="number" class="fg-input" placeholder="Không giới hạn" />
                                </div>
                            </div>
                            <div class="fg" style="margin-bottom:0;">
                                <label class="fg-label">Đơn Hàng Tối Thiểu (đ)</label>
                                <input name="MinOrderAmount" type="number" class="fg-input" value="0" />
                            </div>
                        </div>
                    </div>
                    <div class="f-card">
                        <div class="f-card-head"><i class="bi bi-calendar3"></i><span class="f-card-title">Thời Gian & Giới Hạn</span></div>
                        <div class="f-card-body">
                            <div class="fg-r3 fg">
                                <div>
                                    <label class="fg-label">Ngày Bắt Đầu</label>
                                    <input name="StartDate" type="datetime-local" class="fg-input" value="@ct.ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                                <div>
                                    <label class="fg-label">Ngày Kết Thúc</label>
                                    <input name="EndDate" type="datetime-local" class="fg-input" value="@ct.AddMonths(1).ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                                <div>
                                    <label class="fg-label">Giới Hạn Lượt Dùng</label>
                                    <input name="UsageLimit" type="number" class="fg-input" placeholder="∞ Không giới hạn" />
                                </div>
                            </div>
                            <div class="fg" style="margin-bottom:0;">
                                <label class="toggle-item">
                                    <input name="IsActive" type="checkbox" value="true" checked />
                                    <span class="toggle-label"><i class="bi bi-lightning-charge me-1" style="color:var(--gold);"></i> Kích hoạt ngay</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="v-mf">
                    <button type="button" class="btn-ov" data-bs-dismiss="modal"><i class="bi bi-x-circle"></i> Hủy</button>
                    <button type="submit" class="btn-gold" style="padding:.65rem 1.5rem;"><i class="bi bi-plus-circle"></i> Tạo Voucher</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function(){
            var opts = document.getElementById('mDiscOpts');
            if (opts) {
                opts.addEventListener('click', function(e) {
                    var o = e.target.closest('.disc-opt'); if (!o) return;
                    opts.querySelectorAll('.disc-opt').forEach(function(c){c.classList.remove('active');});
                    o.classList.add('active');
                    var isP = o.dataset.val === 'Percentage';
                    document.getElementById('mDiscInput').value = o.dataset.val;
                    document.getElementById('mLabelVal').innerHTML = isP ? 'Giá Trị Giảm (%) <span class="req">*</span>' : 'Giá Trị Giảm (đ) <span class="req">*</span>';
                    document.getElementById('mAddon').textContent = isP ? '%' : 'đ';
                    var mb = document.getElementById('mMaxBox');
                    mb.style.opacity = isP ? '1' : '0.45';
                    mb.style.pointerEvents = isP ? 'auto' : 'none';
                });
            }
            window.filterV = function(q) {
                q = q.toLowerCase();
                document.querySelectorAll('.v-table tbody tr[data-name]').forEach(function(r) {
                    r.style.display = (r.dataset.name||'').includes(q) ? '' : 'none';
                });
            };
            window.confirmDelete = function(id) {
                Swal.fire({title:'Xóa voucher?',text:'Dữ liệu sẽ không thể khôi phục!',icon:'warning',showCancelButton:true,
                    confirmButtonColor:'#c94b2a',cancelButtonColor:'#8a7560',confirmButtonText:'Xóa',cancelButtonText:'Hủy',reverseButtons:true})
                .then(function(r) {
                    if (!r.isConfirmed) return;
                    $.ajax({url:'/AdminVoucher/Delete/'+id,type:'POST',success:function(res){
                        if (res.success) Swal.fire({icon:'success',title:'Đã xóa!',text:res.message,timer:1500,showConfirmButton:false}).then(function(){location.reload();});
                        else Swal.fire('Lỗi!',res.message,'error');
                    }});
                });
            };
        })();
    </script>
}
