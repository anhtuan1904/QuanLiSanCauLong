@model IEnumerable<QuanLiSanCauLong.ViewModels.VoucherUsageViewModel>
@{
    ViewData["Title"] = "Lịch Sử Sử Dụng Voucher";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var voucherInfo = ViewBag.Voucher as QuanLiSanCauLong.ViewModels.VoucherViewModel;
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .pg-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .25rem;
    }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .72rem 1.5rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .btn-dv {
        padding: .65rem 1.25rem;
        border: 1.5px solid rgba(201,75,42,.3);
        border-radius: 8px;
        background: rgba(201,75,42,.07);
        color: #c94b2a;
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-dv:hover {
            background: #c94b2a;
            color: #fff;
            border-color: #c94b2a;
        }

    .btn-back {
        width: 36px;
        height: 36px;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .sys-ok {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.25);
        color: #16a34a;
    }

    .sys-err {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(201,75,42,.06);
        border: 1px solid rgba(201,75,42,.25);
        color: #c94b2a;
    }

    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .71rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .35rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .tb-search {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .tb-search input {
            width: 100%;
            padding: .65rem 1rem .65rem 2.25rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .84rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
                background: var(--cream);
            }

        .tb-search i {
            position: absolute;
            left: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .82rem;
        }

    .tb-sel {
        padding: .65rem 1rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    .v-table-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .v-table {
        width: 100%;
        border-collapse: collapse;
    }

        .v-table th {
            background: var(--warm);
            padding: .8rem 1rem;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .v-table td {
            padding: .95rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .86rem;
            vertical-align: middle;
            color: var(--deep);
        }

        .v-table tr:last-child td {
            border-bottom: none;
        }

        .v-table tbody tr:hover td {
            background: var(--cream);
        }

    .vc-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

        .vc-icon.pct {
            background: linear-gradient(135deg,var(--gold),var(--gold2));
            color: var(--deep);
        }

        .vc-icon.fix {
            background: var(--warm);
            color: var(--gold);
        }

    .code-tag {
        display: inline-block;
        background: var(--deep);
        color: var(--gold2);
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        padding: .18rem .55rem;
        border-radius: 4px;
        font-family: monospace;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .22rem .6rem;
        border-radius: 4px;
        letter-spacing: .04em;
        white-space: nowrap;
    }

    .chip-green {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-red {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-gold {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .chip-blue {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .chip-neutral {
        background: var(--warm);
        color: var(--muted);
    }

    .disc-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--gold);
    }

    .disc-sub {
        font-size: .71rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .prog-wrap {
        height: 5px;
        background: var(--border);
        border-radius: 3px;
        margin-top: .4rem;
    }

    .prog-bar {
        height: 5px;
        border-radius: 3px;
    }

    .act-g {
        display: flex;
        gap: .3rem;
        align-items: center;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        font-size: .78rem;
        text-decoration: none;
    }

        .act-b.view:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.07);
        }

        .act-b.edit:hover {
            border-color: #4f46e5;
            color: #4f46e5;
            background: rgba(79,70,229,.07);
        }

        .act-b.del:hover {
            border-color: #c94b2a;
            color: #c94b2a;
            background: rgba(201,75,42,.07);
        }

    .f-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

        .f-card:last-child {
            margin-bottom: 0;
        }

    .f-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .f-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .f-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .f-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-r2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-r3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

    .req {
        color: #c94b2a;
    }

    .fg-input, .fg-sel, .fg-ta {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s,background .2s;
    }

        .fg-input:focus, .fg-sel:focus, .fg-ta:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

        .fg-input[readonly] {
            background: var(--warm);
            cursor: default;
            color: var(--muted);
        }

    .fg-ta {
        resize: vertical;
        min-height: 80px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .fg-addon {
        display: flex;
    }

        .fg-addon .fg-input {
            border-radius: 7px 0 0 7px;
            border-right: none;
        }

    .fg-addon-txt {
        padding: .65rem .9rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-left: none;
        border-radius: 0 7px 7px 0;
        font-size: .84rem;
        font-weight: 700;
        color: var(--muted);
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .disc-opts {
        display: flex;
        gap: .65rem;
    }

    .disc-opt {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        padding: .65rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        font-size: .84rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
    }

        .disc-opt:hover {
            border-color: rgba(212,160,23,.5);
            color: var(--deep);
        }

        .disc-opt.active {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            color: var(--deep);
        }

    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    .v-modal .modal-content {
        border-radius: 14px;
        overflow: hidden;
        border: none;
        box-shadow: 0 20px 60px rgba(26,18,9,.18);
        display: flex;
        flex-direction: column;
        max-height: 90vh;
    }

    .v-mh {
        padding: 1.4rem 1.75rem 1rem;
        border-bottom: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .v-mlabel {
        font-size: .64rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .3rem;
    }

        .v-mlabel::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .v-mtitle {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
    }

        .v-mtitle em {
            font-style: italic;
            color: var(--gold);
        }

    .v-mclose {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .v-mclose:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .v-mb {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

        .v-mb::-webkit-scrollbar {
            width: 5px;
        }

        .v-mb::-webkit-scrollbar-track {
            background: var(--warm);
        }

        .v-mb::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    .v-mf {
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
    }

    .pg-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-top: 1.5rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .25;
        }

    .v-crumb {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .v-crumb a {
            color: var(--muted);
            text-decoration: none;
        }

            .v-crumb a:hover {
                color: var(--gold);
            }

    .sb {
        background: var(--deep);
        border-radius: 12px;
        padding: 1.5rem 1.75rem;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .sb-l {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .sb-code {
        background: rgba(245,200,66,.12);
        border: 1px solid rgba(245,200,66,.3);
        border-radius: 8px;
        padding: .55rem 1rem;
    }

        .sb-code span {
            font-family: monospace;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--gold2);
            letter-spacing: .12em;
        }

    .sb-info h4 {
        font-family: 'Playfair Display',serif;
        color: #fff;
        font-size: 1.15rem;
        margin: 0 0 .2rem;
    }

    .sb-info p {
        color: rgba(255,255,255,.5);
        font-size: .82rem;
        margin: 0;
    }

    .sb-r {
        text-align: right;
    }

        .sb-r .big {
            font-family: 'Playfair Display',serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--gold2);
            line-height: 1;
        }

        .sb-r small {
            color: rgba(255,255,255,.45);
            font-size: .72rem;
            display: block;
            margin-top: .2rem;
        }

    .av-cust {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .av-ava {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(212,160,23,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-size: .85rem;
        flex-shrink: 0;
    }
</style>

<div>

    {* ── BREADCRUMB ── *}
    <div class="v-crumb">
        <a asp-action="Index"><i class="bi bi-ticket-perforated"></i> Voucher</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <span>Lịch Sử Sử Dụng</span>
    </div>

    {* ── STATUS BANNER ── *}
    <div class="sb">
        <div class="sb-l">
            <a asp-action="Index" class="btn-back" style="border-color:rgba(255,255,255,.15);color:rgba(255,255,255,.6);" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold2)';" onmouseout="this.style.borderColor='rgba(255,255,255,.15)';this.style.color='rgba(255,255,255,.6)';">
                <i class="bi bi-arrow-left" style="font-size:.85rem;"></i>
            </a>
            <div class="sb-code">
                <span>@voucherInfo.VoucherCode</span>
            </div>
            <div class="sb-info">
                <h4>@voucherInfo.VoucherName</h4>
                <p>Đã sử dụng @voucherInfo.UsedCount lượt · Mã giảm giá đang hoạt động</p>
            </div>
        </div>
        <div class="sb-r">
            <div class="big">@(((decimal)ViewBag.TotalDiscounted).ToString("N0"))đ</div>
            <small>Tổng tiền đã giảm</small>
        </div>
    </div>

    {* ── TABLE ── *}
    <div class="v-table-wrap">
        <table class="v-table">
            <thead>
                <tr>
                    <th>Khách Hàng</th>
                    <th>Đơn Hàng / Đặt Sân</th>
                    <th>Ngày Sử Dụng</th>
                    <th>Giá Trị Đơn</th>
                    <th>Đã Giảm</th>
                    <th style="text-align:right;">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="av-cust">
                                    <div class="av-ava">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight:700;font-size:.88rem;color:var(--deep);">@item.CustomerName</div>
                                        <div style="font-size:.75rem;color:var(--muted);">@item.CustomerPhone</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a href="#" style="font-weight:700;font-size:.88rem;color:var(--deep);text-decoration:none;">#@item.OrderCode</a>
                                <div style="font-size:.75rem;color:var(--muted);margin-top:.1rem;">@item.OrderType</div>
                            </td>
                            <td>
                                <div style="font-size:.86rem;font-weight:600;">@item.UsedAt.ToString("dd/MM/yyyy")</div>
                                <div style="font-size:.75rem;color:var(--muted);">@item.UsedAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div style="font-size:.86rem;font-weight:600;">@item.OrderTotal.ToString("N0")đ</div>
                            </td>
                            <td>
                                <div style="font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:#c94b2a;">
                                    −@item.DiscountAmount.ToString("N0")đ
                                </div>
                            </td>
                            <td style="text-align:right;">
                                <span class="chip chip-green">● Hoàn thành</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>Chưa có lượt sử dụng nào cho mã này</div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
