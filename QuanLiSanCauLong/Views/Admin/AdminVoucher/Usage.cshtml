@model IEnumerable<QuanLiSanCauLong.ViewModels.VoucherUsageViewModel>
@{
    ViewData["Title"] = "Lịch Sử Sử Dụng Voucher";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var voucherInfo = ViewBag.Voucher as QuanLiSanCauLong.ViewModels.VoucherViewModel;
    var totalDisc = (decimal)(ViewBag.TotalDiscounted ?? 0m);
}
@await Html.PartialAsync("_VoucherShared")

<div>

    @* ── BREADCRUMB ── *@
    <div class="v-crumb">
        <a asp-action="Index"><i class="bi bi-ticket-perforated"></i> Voucher</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <a asp-action="Details" asp-route-id="@voucherInfo?.VoucherId">@voucherInfo?.VoucherCode</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <span>Lịch Sử Sử Dụng</span>
    </div>

    @* ── BANNER ── *@
    @if (voucherInfo != null)
    {
        var ct = DateTime.Now;
        var isActive = voucherInfo.IsActive && voucherInfo.StartDate <= ct && voucherInfo.EndDate >= ct;
        <div class="v-banner">
            <div class="v-banner-l">
                <a asp-action="Index" class="btn-back"
                   style="border-color:rgba(255,255,255,.15);color:rgba(255,255,255,.6);"
                   onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold2)'"
                   onmouseout="this.style.borderColor='rgba(255,255,255,.15)';this.style.color='rgba(255,255,255,.6)'">
                    <i class="bi bi-arrow-left" style="font-size:.85rem;"></i>
                </a>
                <div class="v-banner-code">
                    <span>@voucherInfo.VoucherCode</span>
                </div>
                <div class="v-banner-info">
                    <h4>@voucherInfo.VoucherName</h4>
                    <p>
                        @voucherInfo.UsedCount lượt đã dùng
                        @if (voucherInfo.UsageLimit.HasValue)
                        {
                            <text>/ @voucherInfo.UsageLimit.Value tổng giới hạn</text>
                        }
                        ·
                        <span style="color:@(isActive ? "#34d399" : "#ef4444");">
                            ● @(isActive ? "Đang hoạt động" : "Không hoạt động")
                        </span>
                    </p>
                </div>
            </div>
            <div class="v-banner-r">
                <div class="big">@totalDisc.ToString("N0")đ</div>
                <small>Tổng tiền đã giảm cho khách</small>
            </div>
        </div>

        @* ── QUICK STATS ── *@
        <div class="stat-strip" style="grid-template-columns:repeat(3,1fr);">
            <div class="stat-box">
                <div class="stat-n">@Model.Count()</div>
                <div class="stat-l"><span class="stat-dot" style="background:var(--deep);"></span>Tổng lượt dùng</div>
            </div>
            <div class="stat-box">
                <div class="stat-n" style="color:var(--red);">@totalDisc.ToString("N0")đ</div>
                <div class="stat-l"><span class="stat-dot" style="background:var(--red);"></span>Tổng tiền giảm</div>
            </div>
            <div class="stat-box">
                <div class="stat-n" style="color:var(--gold);">
                    @(Model.Any() ? (totalDisc / Model.Count()).ToString("N0") : "0")đ
                </div>
                <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Trung bình / lượt</div>
            </div>
        </div>
    }

    @* ── TABLE ── *@
    <div class="v-table-wrap">
        <table class="v-table">
            <thead>
                <tr>
                    <th>Khách Hàng</th>
                    <th>Đơn / Đặt Sân</th>
                    <th>Ngày Sử Dụng</th>
                    <th>Giá Trị Đơn</th>
                    <th>Đã Giảm</th>
                    <th style="text-align:right;">Loại</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="av-cust">
                                    <div class="av-ava"><i class="bi bi-person"></i></div>
                                    <div>
                                        <div style="font-weight:700;font-size:.88rem;color:var(--deep);">@item.CustomerName</div>
                                        <div style="font-size:.75rem;color:var(--muted);">@item.CustomerPhone</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span style="font-weight:700;font-size:.88rem;color:var(--deep);">#@item.OrderCode</span>
                                <div style="font-size:.75rem;color:var(--muted);margin-top:.1rem;">@item.OrderType</div>
                            </td>
                            <td>
                                <div style="font-size:.86rem;font-weight:600;">@item.UsedAt.ToString("dd/MM/yyyy")</div>
                                <div style="font-size:.75rem;color:var(--muted);">@item.UsedAt.ToString("HH:mm")</div>
                            </td>
                            <td style="font-weight:600;">@item.OrderTotal.ToString("N0")đ</td>
                            <td>
                                <span style="font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--red);">
                                    −@item.DiscountAmount.ToString("N0")đ
                                </span>
                            </td>
                            <td style="text-align:right;">
                                <span class="chip @(item.OrderType == "Đặt sân" ? "chip-blue" : "chip-gold")">
                                    ● @item.OrderType
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <div>Chưa có lượt sử dụng nào cho mã này</div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="margin-top:1rem;display:flex;justify-content:flex-end;">
        <a asp-action="Edit" asp-route-id="@voucherInfo?.VoucherId" class="btn-ov">
            <i class="bi bi-pencil"></i> Chỉnh sửa voucher
        </a>
    </div>

</div>
