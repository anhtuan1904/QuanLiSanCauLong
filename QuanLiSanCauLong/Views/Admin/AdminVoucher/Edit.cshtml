@model QuanLiSanCauLong.ViewModels.VoucherViewModel
@{
    ViewData["Title"] = "Chỉnh Sửa Voucher";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@await Html.PartialAsync("_VoucherShared")

<div>
    <div class="v-crumb">
        <a asp-action="Index"><i class="bi bi-ticket-perforated"></i> Voucher</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <span>Chỉnh Sửa — @Model.VoucherCode</span>
    </div>

    <div class="pg-head">
        <div>
            <h1 class="pg-title">Chỉnh Sửa <em>@Model.VoucherCode</em></h1>
            <div class="pg-sub">@Model.VoucherName</div>
        </div>
        <div style="display:flex;gap:.65rem;">
            <a asp-action="Usage" asp-route-id="@Model.VoucherId" class="btn-ov">
                <i class="bi bi-clock-history"></i> Lịch sử dùng
            </a>
            <a asp-action="Index" class="btn-ov"><i class="bi bi-arrow-left"></i> Quay Lại</a>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="sys-err"></div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="VoucherId" />
        <input type="hidden" asp-for="UsedCount" />

        @* ── Thông tin cơ bản ── *@
        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-info-circle"></i><span class="f-card-title">Thông Tin Cơ Bản</span></div>
            <div class="f-card-body">
                <div class="fg-r2 fg">
                    <div>
                        <label class="fg-label">Mã Voucher</label>
                        <input value="@Model.VoucherCode" class="fg-input"
                               style="font-family:monospace;font-weight:700;letter-spacing:.1em;background:var(--warm);cursor:not-allowed;"
                               disabled title="Không thể thay đổi mã voucher sau khi tạo" />
                        <span class="fg-hint"><i class="bi bi-lock-fill" style="font-size:.65rem;"></i> Không thể thay đổi mã sau khi tạo</span>
                    </div>
                    <div>
                        <label class="fg-label">Tên Chương Trình <span class="req">*</span></label>
                        <input asp-for="VoucherName" class="fg-input" />
                        <span asp-validation-for="VoucherName" class="fg-hint" style="color:var(--red);"></span>
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Áp Dụng Cho</label>
                    <select asp-for="ApplicableFor" class="fg-input">
                        <option value="All">Tất cả (đặt sân + đơn hàng)</option>
                        <option value="Booking">Chỉ đặt sân</option>
                        <option value="Order">Chỉ đơn hàng</option>
                    </select>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Ghi Chú / Điều Kiện Áp Dụng</label>
                    <textarea asp-for="Description" class="fg-ta" rows="3"></textarea>
                </div>
            </div>
        </div>

        @* ── Cấu hình giảm giá ── *@
        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-currency-exchange"></i><span class="f-card-title">Cấu Hình Giảm Giá</span></div>
            <div class="f-card-body">
                <div class="fg">
                    <label class="fg-label">Loại Giảm Giá</label>
                    <input type="hidden" asp-for="DiscountType" id="discTypeInput" />
                    <div class="disc-opts" id="discOpts">
                        <div class="disc-opt @(Model.DiscountType == "Percentage" ? "active" : "")"
                             data-val="Percentage" onclick="setDiscType('Percentage')">
                            <i class="bi bi-percent"></i> Phần Trăm (%)
                        </div>
                        <div class="disc-opt @(Model.DiscountType == "FixedAmount" ? "active" : "")"
                             data-val="FixedAmount" onclick="setDiscType('FixedAmount')">
                            <i class="bi bi-cash-stack"></i> Số Tiền Cố Định (đ)
                        </div>
                    </div>
                </div>
                <div class="fg-r2 fg">
                    <div>
                        <label class="fg-label" id="labelDiscVal">
                            @(Model.DiscountType == "Percentage" ? "Giá Trị Giảm (%)" : "Giá Trị Giảm (đ)")
                            <span class="req">*</span>
                        </label>
                        <div class="fg-addon">
                            <input asp-for="DiscountValue" type="number" min="0" step="0.01" class="fg-input" />
                            <span class="fg-addon-txt" id="addonDisc">@(Model.DiscountType == "Percentage" ? "%" : "đ")</span>
                        </div>
                        <span asp-validation-for="DiscountValue" class="fg-hint" style="color:var(--red);"></span>
                    </div>
                    <div id="maxDiscBox" style="opacity:@(Model.DiscountType == "Percentage" ? "1" : "0.4");pointer-events:@(Model.DiscountType == "Percentage" ? "auto" : "none");">
                        <label class="fg-label">Giảm Tối Đa (đ) <span class="fg-hint" style="display:inline;">chỉ áp dụng cho %</span></label>
                        <input asp-for="MaxDiscount" type="number" min="0" class="fg-input" placeholder="Không giới hạn" />
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Đơn Hàng / Booking Tối Thiểu (đ)</label>
                    <input asp-for="MinOrderAmount" type="number" min="0" class="fg-input" />
                </div>
            </div>
        </div>

        @* ── Thời gian & giới hạn ── *@
        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-calendar3"></i><span class="f-card-title">Thời Gian & Giới Hạn Sử Dụng</span></div>
            <div class="f-card-body">
                <div class="fg-r2 fg">
                    <div>
                        <label class="fg-label">Ngày Bắt Đầu <span class="req">*</span></label>
                        <input asp-for="StartDate" type="datetime-local" class="fg-input" />
                        <span asp-validation-for="StartDate" class="fg-hint" style="color:var(--red);"></span>
                    </div>
                    <div>
                        <label class="fg-label">Ngày Kết Thúc <span class="req">*</span></label>
                        <input asp-for="EndDate" type="datetime-local" class="fg-input" />
                        <span asp-validation-for="EndDate" class="fg-hint" style="color:var(--red);"></span>
                    </div>
                </div>
                <div class="fg-r2 fg">
                    <div>
                        <label class="fg-label">Tổng Lượt Sử Dụng</label>
                        <input asp-for="UsageLimit" type="number" min="1" class="fg-input"
                               placeholder="Để trống = không giới hạn" />
                        <span class="fg-hint">Đã dùng: <strong>@Model.UsedCount</strong> lượt</span>
                    </div>
                    <div>
                        <label class="fg-label">Giới Hạn / Người Dùng</label>
                        <input asp-for="UsageLimitPerUser" type="number" min="1" class="fg-input"
                               placeholder="Để trống = không giới hạn" />
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="toggle-item">
                        <input asp-for="IsActive" type="checkbox" value="true" />
                        <span class="toggle-label">
                            <i class="bi bi-lightning-charge" style="color:var(--gold);margin-right:.3rem;"></i>
                            Voucher đang kích hoạt
                        </span>
                    </label>
                </div>
            </div>
        </div>

        <div class="pg-foot">
            <a asp-action="Index" class="btn-ov"><i class="bi bi-x-circle"></i> Hủy Bỏ</a>
            <button type="submit" class="btn-gold"><i class="bi bi-check-circle"></i> Lưu Thay Đổi</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function setDiscType(val) {
            var isP = val === 'Percentage';
            document.getElementById('discTypeInput').value = val;
            document.querySelectorAll('#discOpts .disc-opt').forEach(function(o) {
                o.classList.toggle('active', o.dataset.val === val);
            });
            document.getElementById('labelDiscVal').innerHTML = isP
                ? 'Giá Trị Giảm (%) <span class="req">*</span>'
                : 'Giá Trị Giảm (đ) <span class="req">*</span>';
            document.getElementById('addonDisc').textContent = isP ? '%' : 'đ';
            var mb = document.getElementById('maxDiscBox');
            mb.style.opacity = isP ? '1' : '0.4';
            mb.style.pointerEvents = isP ? 'auto' : 'none';
        }
    </script>
}
