@model QuanLiSanCauLong.Models.User

@{
    ViewData["Title"] = "Chi Tiết Người Dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var roleCls = Model.Role == "Admin" ? "role-admin" : Model.Role == "Staff" ? "role-staff" : "role-cust";
    var roleIcon = Model.Role == "Admin" ? "bi-shield-fill" : Model.Role == "Staff" ? "bi-person-badge" : "bi-person";
    var totalSpent = ViewBag.TotalSpent != null ? Convert.ToDecimal(ViewBag.TotalSpent) : 0m;
    var lastBooking = ViewBag.LastBooking as QuanLiSanCauLong.Models.Booking;
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
{{!-- Cropper.js CSS --}}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .pg-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .72rem 1.5rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .sys-ok {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.25);
        color: #16a34a;
    }

    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .71rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .35rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .f-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .f-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .f-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .f-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .f-card-body {
        padding: 1.25rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .22rem .6rem;
        border-radius: 4px;
        letter-spacing: .04em;
        white-space: nowrap;
    }

    .chip-green {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-red {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .role-admin {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .role-staff {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .role-cust {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: .85rem 0;
        border-bottom: 1px solid var(--border);
    }

        .info-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .info-icon {
        width: 34px;
        height: 34px;
        border-radius: 7px;
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-size: .82rem;
        flex-shrink: 0;
    }

    .info-key {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .18rem;
    }

    .info-val {
        font-size: .88rem;
        font-weight: 600;
        color: var(--deep);
    }

    .pg-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-top: 1.1rem;
    }

    .v-crumb {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .v-crumb a {
            color: var(--muted);
            text-decoration: none;
        }

            .v-crumb a:hover {
                color: var(--gold);
            }

    /* ── Banner người dùng với avatar lớn ─────────────────── */
    .sb {
        background: var(--deep);
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .sb-l {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .sb-r {
        text-align: right;
    }

        .sb-r .big {
            font-family: 'Playfair Display',serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--gold2);
            line-height: 1;
        }

        .sb-r small {
            color: rgba(255,255,255,.45);
            font-size: .72rem;
            display: block;
            margin-top: .2rem;
        }

    /* ── Đặt v-modal styles (dùng chung) ───────────────────── */
    .v-modal .modal-content {
        border-radius: 14px;
        overflow: hidden;
        border: none;
        box-shadow: 0 20px 60px rgba(26,18,9,.18);
        display: flex;
        flex-direction: column;
        max-height: 92vh;
    }

    .v-mh {
        padding: 1.4rem 1.75rem 1rem;
        border-bottom: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .v-mlabel {
        font-size: .64rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .3rem;
    }

        .v-mlabel::before {
            content: '';
            width: 14px;
            height: 1px;
            background: var(--gold);
        }

    .v-mtitle {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
    }

        .v-mtitle em {
            font-style: italic;
            color: var(--gold);
        }

    .v-mclose {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .v-mclose:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .v-mb {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

        .v-mb::-webkit-scrollbar {
            width: 5px;
        }

        .v-mb::-webkit-scrollbar-track {
            background: var(--warm);
        }

        .v-mb::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    .v-mf {
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
    }
</style>

@Html.AntiForgeryToken()

<div>
    <div class="v-crumb">
        <a asp-action="Index"><i class="bi bi-people"></i> Người dùng</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <span>Chi tiết</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-ok"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }

    {{!-- Banner: Avatar lớn + thông tin chính ──────────────────────────── --}}
    <div class="sb">
        <div class="sb-l">
            {{!-- ✅ Avatar widget size LG --}}
            @{
                ViewData["UserId"] = Model.UserId;
                ViewData["AvatarUrl"] = Model.AvatarUrl;
                ViewData["FullName"] = Model.FullName;
            }
            <div class="av-widget lg">
                @await Html.PartialAsync("_AvatarCropper", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                {
                ["UserId"] = Model.UserId,
                                ["AvatarUrl"] = Model.AvatarUrl,
                                ["FullName"] = Model.FullName
                                })
            </div>

            <div>
                <div style="font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:#fff;">@Model.FullName</div>
                <div style="margin-top:.35rem;display:flex;align-items:center;gap:.65rem;flex-wrap:wrap;">
                    <span class="chip @roleCls"><i class="bi @roleIcon"></i> @Model.Role</span>
                    @if (Model.IsActive)
                    {
                        <span class="chip chip-green">● Hoạt động</span>
                    }
                    else
                    {
                        <span class="chip chip-red">● Bị khóa</span>
                    }
                </div>
                <div style="margin-top:.5rem;font-size:.78rem;color:rgba(255,255,255,.45);">
                    <i class="bi bi-camera me-1" style="color:var(--gold2);"></i>
                    Click vào ảnh để thay đổi
                </div>
            </div>
        </div>
        <div class="sb-r">
            <div style="font-size:.72rem;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.08em;">Tham gia</div>
            <div class="big">@Model.CreatedAt.ToString("dd/MM")</div>
            <small>@Model.CreatedAt.ToString("yyyy")</small>
        </div>
    </div>

    {{!-- Stats ─────────────────────────────────────────────────────────── --}}
    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@ViewBag.TotalBookings</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng đặt sân</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@ViewBag.CompletedBookings</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Hoàn thành</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--gold);font-size:1.35rem;">@totalSpent.ToString("N0")đ</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng chi tiêu</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="font-size:1rem;padding-top:.3rem;">
                @(lastBooking != null ? lastBooking.CreatedAt.ToString("dd/MM/yy") : "—")
            </div>
            <div class="stat-l"><span class="stat-dot" style="background:#4f46e5;"></span>Đặt gần nhất</div>
        </div>
    </div>

    {{!-- Thông tin chi tiết ─────────────────────────────────────────────── --}}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.1rem;">
        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-person-circle"></i><span class="f-card-title">Thông Tin Cá Nhân</span></div>
            <div class="f-card-body">
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-person"></i></div>
                    <div><div class="info-key">Họ và Tên</div><div class="info-val">@Model.FullName</div></div>
                </div>
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-envelope"></i></div>
                    <div><div class="info-key">Email</div><div class="info-val">@Model.Email</div></div>
                </div>
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-phone"></i></div>
                    <div><div class="info-key">Điện Thoại</div><div class="info-val">@(Model.Phone ?? "—")</div></div>
                </div>
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-calendar3"></i></div>
                    <div><div class="info-key">Ngày Tạo</div><div class="info-val">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></div>
                </div>
            </div>
        </div>
        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-diagram-3"></i><span class="f-card-title">Vai Trò & Phân Công</span></div>
            <div class="f-card-body">
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-shield"></i></div>
                    <div>
                        <div class="info-key">Vai Trò</div>
                        <div class="info-val"><span class="chip @roleCls"><i class="bi @roleIcon"></i> @Model.Role</span></div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-building"></i></div>
                    <div><div class="info-key">Cơ Sở</div><div class="info-val">@(Model.Facility?.FacilityName ?? "—")</div></div>
                </div>
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-toggle-on"></i></div>
                    <div>
                        <div class="info-key">Trạng Thái</div>
                        <div class="info-val">
                            @if (Model.IsActive)
                            {
                                <span class="chip chip-green">● Hoạt động</span>
                            }
                            else
                            {
                                <span class="chip chip-red">● Bị khóa</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon"><i class="bi bi-hash"></i></div>
                    <div><div class="info-key">User ID</div><div class="info-val" style="font-family:monospace;">#@Model.UserId</div></div>
                </div>
            </div>
        </div>
    </div>

    <div class="pg-foot">
        <a asp-action="Index" class="btn-ov"><i class="bi bi-arrow-left"></i> Danh Sách</a>
        <div style="display:flex;gap:.65rem;">
            <button type="button" onclick="resetPassword(@Model.UserId)" class="btn-ov" style="border-color:#92660a;color:#92660a;">
                <i class="bi bi-key"></i> Reset Mật Khẩu
            </button>
            <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn-gold">
                <i class="bi bi-pencil"></i> Chỉnh Sửa
            </a>
        </div>
    </div>
</div>

@section Scripts {
        {{!-- Cropper.js --}}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/avatar-cropper.js"></script>
    <script>
        function resetPassword(id) {
            Swal.fire({
                title:'Reset mật khẩu?', text:'Mật khẩu sẽ được đặt lại về 123456',
                icon:'warning', showCancelButton:true,
                confirmButtonColor:'#d4a017', cancelButtonColor:'#8a7560',
                confirmButtonText:'Reset', cancelButtonText:'Hủy', reverseButtons:true
            }).then(function(r) {
                if (!r.isConfirmed) return;
                var fd = new FormData();
                fd.append('userId', id);
                fd.append('__RequestVerificationToken', document.querySelector('[name=__RequestVerificationToken]').value);
                fetch('/AdminUser/ResetPassword', {method:'POST', body:fd})
                .then(res => res.json())
                .then(data => {
                    if (data.success) Swal.fire({icon:'success',title:'Đã reset!',text:data.message,confirmButtonColor:'#d4a017'});
                    else Swal.fire('Lỗi!', data.message, 'error');
                }).catch(function(){ Swal.fire('Lỗi!','Không thể kết nối máy chủ.','error'); });
            });
        }
    </script>
}
