@model QuanLiSanCauLong.Models.User
@{
    ViewData["Title"] = "Chỉnh Sửa Người Dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var ini = string.Join("", Model.FullName.Split(' ').TakeLast(2).Select(x => x[0]));
    var roleCls = Model.Role == "Admin" ? "role-admin" : Model.Role == "Staff" ? "role-staff" : "role-cust";
    var roleIcon = Model.Role == "Admin" ? "bi-shield-fill" : Model.Role == "Staff" ? "bi-person-badge" : "bi-person";
    var roles = ViewBag.Roles as IEnumerable<string> ?? new[] { "Customer", "Staff", "Admin" };
    var facs = ViewBag.Facilities as IEnumerable<QuanLiSanCauLong.Models.Facility>
                   ?? new List<QuanLiSanCauLong.Models.Facility>();
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .pg-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .72rem 1.5rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Outfit',sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .sys-err {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(201,75,42,.06);
        border: 1px solid rgba(201,75,42,.25);
        color: #c94b2a;
    }

    .v-crumb {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .v-crumb a {
            color: var(--muted);
            text-decoration: none;
        }

            .v-crumb a:hover {
                color: var(--gold);
            }

    .f-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .f-card-head {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .f-card-head i {
            color: var(--gold);
            font-size: .9rem;
        }

    .f-card-title {
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .f-card-body {
        padding: 1.25rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-r2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .9rem;
    }

    .fg-label {
        display: block;
        font-size: .71rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

    .req {
        color: #c94b2a;
    }

    .fg-input, .fg-sel {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s,background .2s;
    }

        .fg-input:focus, .fg-sel:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .3rem;
    }

        .fg-hint.err {
            color: #c94b2a;
        }

    .fg-addon {
        display: flex;
    }

        .fg-addon .fg-input {
            border-radius: 7px 0 0 7px;
            border-right: none;
        }

    .fg-addon-txt {
        padding: .65rem .9rem;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-left: none;
        border-radius: 0 7px 7px 0;
        font-size: .84rem;
        font-weight: 700;
        color: var(--muted);
        display: flex;
        align-items: center;
        white-space: nowrap;
    }

    .toggle-item {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .2s;
    }

        .toggle-item:has(input:checked) {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .toggle-item input {
            accent-color: var(--gold);
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
    }

    .pg-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-top: 1.5rem;
    }

    .btn-back {
        width: 36px;
        height: 36px;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .22rem .6rem;
        border-radius: 4px;
        letter-spacing: .04em;
        white-space: nowrap;
    }

    .u-ava {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display',serif;
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--deep);
        flex-shrink: 0;
    }

        .u-ava.sm {
            width: 36px;
            height: 36px;
            font-size: .9rem;
        }

    .role-admin {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .role-staff {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .role-cust {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }
    /* ✅ NÂNG CẤP: Password strength indicator */
    .pwd-strength {
        height: 4px;
        border-radius: 2px;
        margin-top: .4rem;
        transition: all .3s;
        background: var(--border);
    }

        .pwd-strength.weak {
            background: #c94b2a;
            width: 33%;
        }

        .pwd-strength.medium {
            background: var(--gold);
            width: 66%;
        }

        .pwd-strength.strong {
            background: #16a34a;
            width: 100%;
        }
</style>

<div>
    <div class="v-crumb">
        <a asp-action="Index"><i class="bi bi-people"></i> Người dùng</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <span>Chỉnh sửa</span>
    </div>
    <div class="pg-head">
        <div style="display:flex;align-items:center;gap:1rem;">
            <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left" style="font-size:.85rem;"></i></a>
            <div>
                <h1 class="pg-title" style="font-size:1.6rem;">Chỉnh Sửa <em>Tài Khoản</em></h1>
                <div style="margin-top:.3rem;display:flex;align-items:center;gap:.65rem;">
                    @await Html.PartialAsync("_AvatarCropper", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                    {
                    ["UserId"] = Model.UserId,
                                        ["AvatarUrl"] = Model.AvatarUrl,
                                        ["FullName"] = Model.FullName
                                        })
                    <span style="font-size:.86rem;font-weight:600;color:var(--deep);">@Model.FullName</span>
                    <span class="chip @roleCls"><i class="bi @roleIcon"></i> @Model.Role</span>
                </div>
            </div>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="sys-err"></div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="PasswordHash" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="Password" value="" />
        <input type="hidden" asp-for="AvatarUrl" />

        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-person-circle"></i><span class="f-card-title">Thông Tin Cá Nhân</span></div>
            <div class="f-card-body">
                <div class="fg-r2 fg">
                    <div>
                        <label class="fg-label">Họ và Tên <span class="req">*</span></label>
                        <input asp-for="FullName" class="fg-input" required />
                        <span asp-validation-for="FullName" class="fg-hint err"></span>
                    </div>
                    <div>
                        <label class="fg-label">Số Điện Thoại</label>
                        <input asp-for="Phone" class="fg-input" />
                        <span asp-validation-for="Phone" class="fg-hint err"></span>
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Email <span class="req">*</span></label>
                    <input asp-for="Email" type="email" class="fg-input" required />
                    <span asp-validation-for="Email" class="fg-hint err"></span>
                </div>
            </div>
        </div>

        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-shield-lock"></i><span class="f-card-title">Đổi Mật Khẩu <span style="font-size:.7rem;font-weight:400;color:var(--muted);">(Để trống nếu không đổi)</span></span></div>
            <div class="f-card-body">
                <div class="fg-addon" style="margin-bottom:0;">
                    <input name="newPassword" type="password" id="newPwd" class="fg-input"
                           placeholder="Mật khẩu mới (≥6 ký tự)" minlength="6"
                           autocomplete="new-password"
                           oninput="checkStrength(this.value)" />
                    <button type="button" class="fg-addon-txt" style="cursor:pointer;"
                            onclick="var f=document.getElementById('newPwd'),e=document.getElementById('newEye');
                                 f.type=f.type==='password'?'text':'password';
                                 e.className=f.type==='text'?'bi bi-eye-slash':'bi bi-eye';">
                        <i class="bi bi-eye" id="newEye"></i>
                    </button>
                </div>
                {{!-- ✅ NÂNG CẤP: Password strength bar --}}
                <div class="pwd-strength" id="pwdStrength"></div>
                <span asp-validation-for="Password" class="fg-hint err"></span>
            </div>
        </div>

        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-diagram-3"></i><span class="f-card-title">Vai Trò & Phân Công</span></div>
            <div class="f-card-body">
                <div class="fg-r2 fg" style="margin-bottom:0;">
                    <div>
                        <label class="fg-label">Vai Trò <span class="req">*</span></label>
                        <select asp-for="Role" class="fg-sel" id="eRoleSelect" onchange="onRoleChange(this.value)" required>
                            @foreach (var r in roles)
                            {
                                <option value="@r">@r</option>
                            }
                        </select>
                        <span asp-validation-for="Role" class="fg-hint err"></span>
                    </div>
                    <div id="eFacilityGroup">
                        <label class="fg-label">Cơ Sở Làm Việc</label>
                        <select asp-for="FacilityId" id="eFacilitySel" class="fg-sel">
                            <option value="">— Không chọn —</option>
                            @foreach (var f in facs)
                            {
                                <option value="@f.FacilityId" selected="@(Model.FacilityId == f.FacilityId ? "selected" : null)">@f.FacilityName</option>
                            }
                        </select>
                        <span asp-validation-for="FacilityId" class="fg-hint err"></span>
                        <div id="eFacilityHint" class="fg-hint" style="display:none;color:#c94b2a;">
                            <i class="bi bi-exclamation-circle"></i> Bắt buộc chọn cơ sở cho Staff
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="f-card">
            <div class="f-card-head"><i class="bi bi-toggle-on"></i><span class="f-card-title">Trạng Thái Tài Khoản</span></div>
            <div class="f-card-body">
                <div style="display:flex;gap:.65rem;">
                    <label class="toggle-item">
                        <input type="radio" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
                        <span class="toggle-label"><i class="bi bi-check-circle me-1" style="color:#16a34a;"></i> Hoạt động</span>
                    </label>
                    <label class="toggle-item">
                        <input type="radio" name="IsActive" value="false" @(!Model.IsActive ? "checked" : "") />
                        <span class="toggle-label"><i class="bi bi-lock me-1" style="color:#c94b2a;"></i> Bị khóa</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="pg-foot">
            <a asp-action="Index" class="btn-ov"><i class="bi bi-x-circle"></i> Hủy Bỏ</a>
            <button type="submit" class="btn-gold"><i class="bi bi-floppy"></i> Lưu Thay Đổi</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function onRoleChange(val) {
            var fg = document.getElementById('eFacilityGroup');
            var sel = document.getElementById('eFacilitySel');
            var hint = document.getElementById('eFacilityHint');

            if (val === 'Staff') {
                fg.style.opacity = '1';
                fg.style.pointerEvents = 'auto';
                sel.setAttribute('required', 'required');
                hint.style.display = 'block';
            } else {
                fg.style.opacity = '0.4';
                fg.style.pointerEvents = 'none';
                sel.removeAttribute('required');
                hint.style.display = 'none';
            }
        }
        // Chạy khi load để đồng bộ trạng thái
        onRoleChange(document.getElementById('eRoleSelect').value);

        // ✅ NÂNG CẤP: Password strength indicator
        function checkStrength(val) {
            var bar = document.getElementById('pwdStrength');
            if (!val) { bar.className = 'pwd-strength'; return; }
            if (val.length < 6) bar.className = 'pwd-strength weak';
            else if (val.length < 10 || !/[0-9]/.test(val) || !/[A-Za-z]/.test(val)) bar.className = 'pwd-strength medium';
            else bar.className = 'pwd-strength strong';
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script src="~/js/avatar-cropper.js"></script>
}
