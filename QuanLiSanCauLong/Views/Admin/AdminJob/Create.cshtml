@model QuanLiSanCauLong.Models.JobPosting
@{
    Layout = null;
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-bg: #f5f0e8;
        --court-border: #e8e0d0;
        --court-muted: #7a7060;
    }

    .modal-header-court {
        background: var(--court-dark);
        color: #fff;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

        .modal-header-court h5 {
            font-weight: 800;
            font-size: 1.1rem;
            margin: 0 0 2px;
            color: #fff;
        }

        .modal-header-court p {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.6);
            margin: 0;
        }

        .modal-header-court .btn-close {
            filter: invert(1);
            opacity: 0.7;
        }

    .court-form-label {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--court-muted);
        margin-bottom: 5px;
    }

    .court-input,
    .court-select,
    .court-textarea {
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        background: var(--court-bg);
        color: #2d2d2d;
        font-size: 0.875rem;
        padding: 0.5rem 0.75rem;
        width: 100%;
        transition: all 0.2s;
    }

        .court-input:focus,
        .court-select:focus,
        .court-textarea:focus {
            outline: none;
            border-color: var(--court-gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(232,200,64,0.2);
        }

    .court-textarea {
        resize: vertical;
        min-height: 90px;
    }

    .section-divider {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-dark);
        padding: 0.25rem 0;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: 0.75rem;
        display: inline-block;
    }

    .btn-court-primary {
        background: var(--court-gold);
        color: var(--court-dark);
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.75rem;
        font-weight: 800;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-court-primary:hover {
            background: #d4b320;
            box-shadow: 0 4px 12px rgba(232,200,64,0.4);
        }

    .btn-court-secondary {
        background: var(--court-bg);
        color: #2d2d2d;
        border: 1.5px solid var(--court-border);
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-court-secondary:hover {
            background: #ede8de;
        }

    .featured-check {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--court-bg);
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        padding: 0.6rem 0.9rem;
        cursor: pointer;
    }

        .featured-check input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: var(--court-gold);
            cursor: pointer;
        }

        .featured-check label {
            font-size: 0.875rem;
            font-weight: 600;
            color: #2d2d2d;
            cursor: pointer;
            margin: 0;
        }
</style>

<div class="modal-header-court">
    <div>
        <h5>Thêm Tin Tuyển Dụng Mới</h5>
        <p>Điền đầy đủ thông tin vị trí cần tuyển dụng</p>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body px-4 py-3" style="background:#fff;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-3">

            <!-- Thông tin cơ bản -->
            <div class="col-12">
                <span class="section-divider">📋 Thông Tin Cơ Bản</span>
            </div>
            <div class="col-md-8">
                <label class="court-form-label">Vị trí tuyển dụng <span class="text-danger">*</span></label>
                <input asp-for="JobTitle" class="court-input" placeholder="VD: Nhân viên quản lý sân" required />
            </div>
            <div class="col-md-4">
                <label class="court-form-label">Số lượng <span class="text-danger">*</span></label>
                <input asp-for="VacancyCount" type="number" class="court-input" value="1" min="1" required />
            </div>

            <div class="col-12">
                <label class="court-form-label">Mô tả công việc <span class="text-danger">*</span></label>
                <textarea asp-for="JobDescription" class="court-textarea" rows="4" placeholder="Mô tả chi tiết về công việc..." required></textarea>
            </div>

            <div class="col-md-6">
                <label class="court-form-label">Yêu cầu</label>
                <textarea asp-for="Requirements" class="court-textarea" rows="3" placeholder="Kỹ năng, kinh nghiệm cần thiết..."></textarea>
            </div>
            <div class="col-md-6">
                <label class="court-form-label">Quyền lợi</label>
                <textarea asp-for="Benefits" class="court-textarea" rows="3" placeholder="Quyền lợi được hưởng..."></textarea>
            </div>

            <!-- Phân loại -->
            <div class="col-12 mt-2">
                <span class="section-divider">🏷️ Phân Loại & Mức Lương</span>
            </div>
            <div class="col-md-6">
                <label class="court-form-label">Loại hình</label>
                <select asp-for="JobType" class="court-select">
                    <option value="">-- Chọn loại hình --</option>
                    <option value="Full-time">Full-time</option>
                    <option value="Part-time">Part-time</option>
                    <option value="Contract">Contract</option>
                    <option value="Internship">Internship</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="court-form-label">Cấp bậc</label>
                <select asp-for="Level" class="court-select">
                    <option value="">-- Chọn cấp bậc --</option>
                    <option value="Intern">Intern</option>
                    <option value="Junior">Junior</option>
                    <option value="Senior">Senior</option>
                    <option value="Manager">Manager</option>
                    <option value="Director">Director</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="court-form-label">Lương tối thiểu (VNĐ)</label>
                <input asp-for="SalaryMin" type="number" class="court-input" placeholder="5,000,000" />
            </div>
            <div class="col-md-4">
                <label class="court-form-label">Lương tối đa (VNĐ)</label>
                <input asp-for="SalaryMax" type="number" class="court-input" placeholder="10,000,000" />
            </div>
            <div class="col-md-4">
                <label class="court-form-label">Hạn nộp hồ sơ</label>
                <input asp-for="Deadline" type="date" class="court-input" />
            </div>

            <div class="col-12">
                <label class="court-form-label">Địa điểm làm việc</label>
                <input asp-for="Location" class="court-input" placeholder="VD: Quận 1, TP.HCM" />
            </div>

            <!-- Liên hệ -->
            <div class="col-12 mt-2">
                <span class="section-divider">📞 Thông Tin Liên Hệ</span>
            </div>
            <div class="col-md-4">
                <label class="court-form-label">Người liên hệ</label>
                <input asp-for="ContactPerson" class="court-input" placeholder="Họ và tên" />
            </div>
            <div class="col-md-4">
                <label class="court-form-label">Email</label>
                <input asp-for="ContactEmail" type="email" class="court-input" placeholder="email@example.com" />
            </div>
            <div class="col-md-4">
                <label class="court-form-label">Số điện thoại</label>
                <input asp-for="ContactPhone" class="court-input" placeholder="0123 456 789" />
            </div>

            <div class="col-12">
                <label class="featured-check">
                    <input asp-for="IsFeatured" type="checkbox" />
                    <span>⭐ Đánh dấu là tin <strong>nổi bật</strong> (ưu tiên hiển thị)</span>
                </label>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top:1px solid #e8e0d0;">
            <button type="button" class="btn-court-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
            <button type="submit" class="btn-court-primary">
                <i class="bi bi-plus-circle-fill"></i> Thêm Tin Tuyển Dụng
            </button>
        </div>
    </form>
</div>
