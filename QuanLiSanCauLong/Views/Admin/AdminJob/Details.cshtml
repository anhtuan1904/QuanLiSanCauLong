@model QuanLiSanCauLong.Models.JobPosting
@{
    Layout = null;
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-bg: #f5f0e8;
        --court-border: #e8e0d0;
        --court-muted: #7a7060;
    }

    .modal-header-court {
        background: var(--court-dark);
        color: #fff;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

        .modal-header-court h5 {
            font-weight: 800;
            font-size: 1.1rem;
            margin: 0 0 2px;
            color: #fff;
        }

        .modal-header-court p {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.6);
            margin: 0;
        }

        .modal-header-court .btn-close {
            filter: invert(1);
            opacity: 0.7;
        }

    .detail-hero {
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.25rem;
    }

    .detail-job-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: 0.5rem;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .badge-open {
        background: #d4edda;
        color: #1a6b2e;
    }

    .badge-closed {
        background: #e2e3e5;
        color: #4a4a5a;
    }

    .badge-filled {
        background: #cce5ff;
        color: #1a5fa0;
    }

    .badge-featured {
        background: #fff3cd;
        color: #856404;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem 1.5rem;
        margin-top: 1rem;
    }

    .detail-item label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--court-muted);
        display: block;
        margin-bottom: 2px;
    }

    .detail-item strong {
        font-size: 0.9rem;
        color: var(--court-dark);
        font-weight: 700;
    }

    .detail-section {
        margin-bottom: 1.25rem;
    }

    .detail-section-title {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-dark);
        padding-bottom: 0.4rem;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: 0.75rem;
        display: inline-block;
    }

    .detail-text {
        font-size: 0.875rem;
        color: #4a4a5a;
        line-height: 1.7;
        white-space: pre-wrap;
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }

    .salary-box {
        background: #f0faf3;
        border: 1.5px solid #86efac;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1rem;
        font-weight: 800;
        color: #1a6b2e;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
    }

    .contact-item {
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        border-radius: 8px;
        padding: 0.65rem 0.9rem;
    }

        .contact-item label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--court-muted);
            display: block;
            margin-bottom: 2px;
        }

        .contact-item strong {
            font-size: 0.85rem;
            color: var(--court-dark);
        }

    .meta-bar {
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        border-radius: 8px;
        padding: 0.65rem 1rem;
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        font-size: 0.8rem;
        color: var(--court-muted);
    }

        .meta-bar strong {
            color: var(--court-dark);
        }

    .btn-court-primary {
        background: var(--court-gold);
        color: var(--court-dark);
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 800;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-court-primary:hover {
            background: #d4b320;
        }

    .btn-court-secondary {
        background: var(--court-bg);
        color: #2d2d2d;
        border: 1.5px solid var(--court-border);
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-court-secondary:hover {
            background: #ede8de;
        }
</style>

<div class="modal-header-court">
    <div>
        <h5>Chi Tiết Tin Tuyển Dụng</h5>
        <p>Xem đầy đủ thông tin vị trí tuyển dụng</p>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body px-4 py-3" style="background:#fff;">

    <!-- Hero Card -->
    <div class="detail-hero">
        <div class="detail-job-title">@Model.JobTitle</div>
        <div class="d-flex flex-wrap gap-2 mb-2">
            @{
                string statusClass = Model.Status == "Open" ? "badge-open" : (Model.Status == "Filled" ? "badge-filled" : "badge-closed");
                string statusText = Model.Status == "Open" ? "● Đang tuyển" : (Model.Status == "Filled" ? "● Đã tuyển đủ" : "● Đã đóng");
            }
            <span class="badge-status @statusClass">@statusText</span>
            @if (Model.IsFeatured)
            {
                <span class="badge-status badge-featured">⭐ Nổi bật</span>
            }
        </div>
        <div class="detail-grid">
            <div class="detail-item">
                <label>Loại hình</label>
                <strong><i class="bi bi-briefcase me-1"></i>@Model.JobType</strong>
            </div>
            <div class="detail-item">
                <label>Cấp bậc</label>
                <strong><i class="bi bi-diagram-3 me-1"></i>@Model.Level</strong>
            </div>
            <div class="detail-item">
                <label>Số lượng tuyển</label>
                <strong><i class="bi bi-people me-1"></i>@Model.VacancyCount vị trí</strong>
            </div>
            <div class="detail-item">
                <label>Địa điểm</label>
                <strong><i class="bi bi-geo-alt me-1"></i>@Model.Location</strong>
            </div>
        </div>
    </div>

    <!-- Salary -->
    @if (Model.SalaryMin.HasValue || Model.SalaryMax.HasValue)
    {
        <div class="detail-section">
            <span class="detail-section-title">💰 Mức Lương</span>
            <div class="salary-box mt-2">
                <i class="bi bi-cash-coin fs-5"></i>
                @if (Model.SalaryMin.HasValue && Model.SalaryMax.HasValue)
                {
                    <span>@Model.SalaryMin.Value.ToString("N0")đ – @Model.SalaryMax.Value.ToString("N0")đ</span>
                }
                else if (Model.SalaryMin.HasValue)
                {
                    <span>Từ @Model.SalaryMin.Value.ToString("N0")đ</span>
                }
                else
                {
                    <span>Lên đến @Model.SalaryMax.Value.ToString("N0")đ</span>
                }
            </div>
        </div>
    }

    <!-- Description -->
    <div class="detail-section">
        <span class="detail-section-title">📝 Mô Tả Công Việc</span>
        <div class="detail-text mt-2">@Model.JobDescription</div>
    </div>

    <!-- Requirements -->
    @if (!string.IsNullOrEmpty(Model.Requirements))
    {
        <div class="detail-section">
            <span class="detail-section-title">✅ Yêu Cầu</span>
            <div class="detail-text mt-2">@Model.Requirements</div>
        </div>
    }

    <!-- Benefits -->
    @if (!string.IsNullOrEmpty(Model.Benefits))
    {
        <div class="detail-section">
            <span class="detail-section-title">🎁 Quyền Lợi</span>
            <div class="detail-text mt-2">@Model.Benefits</div>
        </div>
    }

    <!-- Contact -->
    <div class="detail-section">
        <span class="detail-section-title">📞 Thông Tin Liên Hệ</span>
        <div class="contact-grid mt-2">
            @if (!string.IsNullOrEmpty(Model.ContactPerson))
            {
                <div class="contact-item">
                    <label>Người liên hệ</label>
                    <strong>@Model.ContactPerson</strong>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ContactEmail))
            {
                <div class="contact-item">
                    <label>Email</label>
                    <strong>@Model.ContactEmail</strong>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ContactPhone))
            {
                <div class="contact-item">
                    <label>Điện thoại</label>
                    <strong>@Model.ContactPhone</strong>
                </div>
            }
        </div>
    </div>

    <!-- Meta -->
    <div class="meta-bar">
        <span><i class="bi bi-calendar-plus me-1"></i>Đăng ngày: <strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></span>
        @if (Model.Deadline.HasValue)
        {
            <span><i class="bi bi-calendar-x me-1"></i>Hạn nộp: <strong>@Model.Deadline.Value.ToString("dd/MM/yyyy")</strong></span>
        }
        <span><i class="bi bi-eye me-1"></i>Lượt xem: <strong>@Model.ViewCount.ToString("N0")</strong></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top:1px solid #e8e0d0;">
        <button type="button" class="btn-court-secondary" data-bs-dismiss="modal">Đóng</button>
        <button type="button" class="btn-court-primary" onclick="openEditFromDetails(@Model.JobId)">
            <i class="bi bi-pencil-fill"></i> Chỉnh Sửa
        </button>
    </div>
</div>

<script>
    function openEditFromDetails(id) {
        const currentModal = bootstrap.Modal.getInstance(document.getElementById('modalJob'));
        if (currentModal) currentModal.hide();
        setTimeout(() => { openEditModal(id); }, 300);
    }
</script>
