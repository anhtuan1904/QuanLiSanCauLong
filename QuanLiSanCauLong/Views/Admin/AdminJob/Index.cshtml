@model IEnumerable<QuanLiSanCauLong.Models.JobPosting>
@{
    ViewData["Title"] = "Quản Lý Tuyển Dụng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    :root {
        --deep: #1a1209;
        --deep2: #231a0e;
        --deep3: #2e2110;
        --gold: #d4a017;
        --gold2: #f5c842;
        --gold3: rgba(212,160,23,.1);
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
        --purple: #7c3aed;
        --orange: #c2410c;
        --shadow: 0 1px 3px rgba(26,18,9,.06), 0 4px 12px rgba(26,18,9,.04);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit', sans-serif;
    }

    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem 2.25rem;
    }

    /* HEADER */
    .pg-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .pg-eyebrow {
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .24em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: .25rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .pg-eyebrow::before {
            content: '';
            display: block;
            width: 18px;
            height: 2px;
            background: var(--gold);
            border-radius: 2px;
        }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.1;
        margin: 0;
    }

        .pg-title em {
            color: var(--gold);
            font-style: italic;
        }

    .pg-sub {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .hd-btns {
        display: flex;
        gap: .45rem;
        flex-wrap: wrap;
        align-items: center;
    }

    /* BUTTONS */
    .btn-gold {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .58rem 1.15rem;
        border: none;
        border-radius: 9px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
        text-decoration: none;
        box-shadow: 0 2px 8px rgba(212,160,23,.3);
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 18px rgba(212,160,23,.45);
            color: var(--deep);
        }

    .btn-dark {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .58rem 1.05rem;
        border: none;
        border-radius: 9px;
        background: var(--deep2);
        color: rgba(255,255,255,.85);
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
        text-decoration: none;
    }

        .btn-dark:hover {
            background: var(--deep3);
            color: #fff;
        }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .56rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        background: #fff;
        color: var(--muted);
        font-size: .8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
        text-decoration: none;
    }

        .btn-ghost:hover {
            border-color: var(--deep);
            color: var(--deep);
            background: var(--cream);
        }

    /* TOAST */
    .toast-ok {
        position: fixed;
        top: 1.2rem;
        right: 1.5rem;
        z-index: 9999;
        background: var(--cream);
        border: 1px solid rgba(212,160,23,.4);
        border-left: 4px solid var(--gold);
        border-radius: 10px;
        padding: .75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .875rem;
        font-weight: 600;
        color: var(--deep);
        box-shadow: 0 8px 24px rgba(26,18,9,.12);
        animation: slideIn .3s ease;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(110%);
            opacity: 0
        }

        to {
            transform: translateX(0);
            opacity: 1
        }
    }

    /* STAT CARDS */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .scard {
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 14px;
        padding: 1rem 1.15rem 1rem 1.35rem;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: all .2s;
    }

        .scard::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            border-radius: 4px 0 0 4px;
        }

        .scard:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(26,18,9,.1);
        }

    .scard-ico {
        position: absolute;
        right: .85rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.7rem;
        opacity: .07;
        pointer-events: none;
    }

    .sc-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        line-height: 1;
        color: var(--deep);
        position: relative;
        z-index: 1;
    }

    .sc-l {
        font-size: .59rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .28rem;
        position: relative;
        z-index: 1;
    }

    .sc-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* TABS */
    .tabs {
        display: flex;
        gap: .35rem;
        margin-bottom: 1.25rem;
        border-bottom: 2px solid var(--border);
    }

    .tab {
        padding: .55rem 1.1rem;
        font-size: .82rem;
        font-weight: 700;
        color: var(--muted);
        cursor: pointer;
        border-bottom: 2.5px solid transparent;
        margin-bottom: -2px;
        transition: all .18s;
        display: flex;
        align-items: center;
        gap: 5px;
        text-decoration: none;
    }

        .tab:hover {
            color: var(--deep);
        }

        .tab.active {
            color: var(--deep);
            border-bottom-color: var(--gold);
        }

        .tab .cnt {
            background: var(--warm);
            border-radius: 20px;
            padding: 1px 7px;
            font-size: .7rem;
        }

        .tab.active .cnt {
            background: var(--gold);
            color: var(--deep);
        }

    /* TOOLBAR */
    .toolbar {
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: .75rem 1rem;
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
    }

    .srch-wrap {
        flex: 1;
        min-width: 200px;
        position: relative;
    }

        .srch-wrap i {
            position: absolute;
            left: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
            pointer-events: none;
        }

        .srch-wrap input {
            width: 100%;
            padding: .58rem .9rem .58rem 2.2rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: .83rem;
            color: var(--deep);
            background: var(--warm);
            outline: none;
            transition: .18s;
        }

            .srch-wrap input:focus {
                border-color: var(--gold);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(212,160,23,.12);
            }

    .tb-sel {
        padding: .57rem .85rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: .81rem;
        color: var(--deep);
        background: var(--warm);
        outline: none;
        cursor: pointer;
        transition: border-color .18s;
    }

        .tb-sel:focus {
            border-color: var(--gold);
            background: #fff;
        }

    /* TABLE */
    .tbl-card {
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .tbl-hd {
        background: var(--deep2);
        padding: .9rem 1.2rem;
        display: flex;
        align-items: center;
        gap: .7rem;
        border-bottom: 2px solid rgba(212,160,23,.15);
    }

    .tbl-hd-ico {
        width: 28px;
        height: 28px;
        background: rgba(212,160,23,.15);
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold2);
        font-size: .85rem;
        flex-shrink: 0;
    }

    .tbl-hd-title {
        font-family: 'Playfair Display',serif;
        font-style: italic;
        font-size: .95rem;
        font-weight: 700;
        color: #fff;
    }

    .tbl-cnt {
        margin-left: auto;
        font-size: .7rem;
        font-weight: 700;
        color: var(--gold2);
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(212,160,23,.2);
        padding: .22rem .7rem;
        border-radius: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        padding: .7rem 1rem;
        background: #2a1e0d;
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .13em;
        text-transform: uppercase;
        color: rgba(212,160,23,.65);
        text-align: left;
        white-space: nowrap;
        border-bottom: 1px solid rgba(255,255,255,.04);
    }

    tbody td {
        padding: .88rem 1rem;
        border-bottom: 1px solid #f0e8df;
        font-size: .83rem;
        color: var(--deep);
        vertical-align: middle;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover td {
        background: #fffcf5;
    }

    /* job cell */
    .job-name {
        font-weight: 700;
        color: var(--deep);
        font-size: .88rem;
        margin-bottom: 2px;
        display: flex;
        align-items: center;
        gap: .35rem;
        flex-wrap: wrap;
    }

    .job-sub {
        font-size: .73rem;
        color: var(--muted);
        display: flex;
        flex-wrap: wrap;
        gap: .3rem .75rem;
        margin-top: .2rem;
    }

        .job-sub i {
            color: var(--gold);
            opacity: .7;
        }

    /* badges */
    .bdg {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .bdg-open {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .bdg-closed {
        background: var(--warm);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    .bdg-filled {
        background: #dbeafe;
        color: #1e40af;
        border: 1px solid #bfdbfe;
    }

    .bdg-draft {
        background: rgba(212,160,23,.12);
        color: #92400e;
        border: 1px solid rgba(212,160,23,.3);
    }

    .bdg-urgent {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }

    .bdg-ft {
        background: #e0e7ff;
        color: #3730a3;
        border: 1px solid #c7d2fe;
    }

    .bdg-pt {
        background: #fce7f3;
        color: #9d174d;
        border: 1px solid #fbcfe8;
    }

    .bdg-ct {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .bdg-re {
        background: #ede9fe;
        color: #5b21b6;
        border: 1px solid #ddd6fe;
    }

    .bdg-lvl {
        background: var(--warm);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    .sal-num {
        font-weight: 700;
        color: var(--green);
        font-size: .82rem;
    }

    .sal-neg {
        color: var(--muted);
        font-size: .82rem;
        font-style: italic;
    }

    .dl-ok {
        color: var(--muted);
        font-size: .8rem;
    }

    .dl-soon {
        color: var(--orange);
        font-weight: 700;
        font-size: .8rem;
    }

    .dl-exp {
        color: var(--red);
        text-decoration: line-through;
        font-size: .8rem;
    }

    .apps-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 20px;
        padding: 3px 11px;
        font-size: .76rem;
        font-weight: 700;
        color: var(--deep);
        text-decoration: none;
        transition: .18s;
    }

        .apps-pill:hover {
            background: var(--gold3);
            border-color: var(--gold);
            color: var(--deep);
        }

    .new-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--red);
        display: inline-block;
    }

    /* action btns */
    .qa {
        display: flex;
        gap: .28rem;
        justify-content: flex-end;
    }

    .qa-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
        font-size: .78rem;
    }

        .qa-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(0,0,0,.08);
        }

    .qa-view:hover {
        border-color: var(--gold);
        color: var(--gold);
        background: #fffbeb;
    }

    .qa-edit:hover {
        border-color: var(--blue);
        color: var(--blue);
        background: #eff6ff;
    }

    .qa-del:hover {
        border-color: var(--red);
        color: var(--red);
        background: #fef2f2;
    }

    .empty-box {
        text-align: center;
        padding: 4rem 2rem;
    }

        .empty-box i {
            font-size: 2.8rem;
            color: var(--border);
            margin-bottom: .75rem;
            display: block;
        }

        .empty-box h6 {
            font-family: 'Playfair Display',serif;
            font-style: italic;
            color: var(--deep);
            margin-bottom: .35rem;
            font-size: 1.1rem;
        }

        .empty-box p {
            color: var(--muted);
            font-size: .85rem;
            margin: 0;
        }

    /* delete modal */
    .del-modal .modal-content {
        border-radius: 16px;
        border: none;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
    }

    .del-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #fee2e2;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: var(--red);
        margin: 0 auto 1rem;
    }

    .btn-del-confirm {
        width: 100%;
        background: var(--red);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: .65rem;
        font-weight: 700;
        cursor: pointer;
        transition: .18s;
    }

        .btn-del-confirm:hover {
            background: #b91c1c;
        }

    .btn-del-cancel {
        width: 100%;
        background: var(--warm);
        color: var(--deep);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .65rem;
        font-weight: 600;
        cursor: pointer;
        transition: .18s;
    }

        .btn-del-cancel:hover {
            background: var(--cream);
            border-color: var(--deep);
        }

    @@media(max-width:900px) {
        .pg {
            padding: 1.25rem 1rem;
        }

        .stats-row {
            grid-template-columns: repeat(3,1fr);
        }

        .toolbar {
            flex-direction: column;
            align-items: stretch;
        }
    }

    @@media(max-width:600px) {
        .stats-row {
            grid-template-columns: repeat(2,1fr);
        }
    }
</style>

<div class="pg">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast-ok" id="successToast">
            <i class="bi bi-check-circle-fill" style="color:var(--gold);"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Header -->
    <div class="pg-hd">
        <div>
            <div class="pg-eyebrow">Quản trị · Nhân sự</div>
            <h1 class="pg-title">Quản Lý <em>Tuyển Dụng</em></h1>
            <div class="pg-sub">Đăng tin · Theo dõi hồ sơ · Quản lý tuyển dụng nhân sự</div>
        </div>
        <div class="hd-btns">
            <button class="btn-gold" onclick="openCreateModal()">
                <i class="bi bi-plus-lg"></i> Thêm Tin Mới
            </button>
            <a class="btn-dark" href="@Url.Action("Applications", "AdminJob")">
                <i class="bi bi-file-earmark-person"></i> Hồ Sơ Ứng Tuyển
                @if ((int)(ViewBag.NewApps ?? 0) > 0)
                {
                    <span style="background:var(--red);color:#fff;border-radius:10px;padding:.05rem .42rem;font-size:.62rem;font-weight:800;">@ViewBag.NewApps</span>
                }
            </a>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="scard" style="border-left-color:var(--gold);">
            <style>
                .scard:nth-child(1)::before {
                    background: var(--gold)
                }</style>
            <i class="bi bi-briefcase scard-ico"></i>
            <div class="sc-n">@ViewBag.TotalJobs</div>
            <div class="sc-l"><span class="sc-dot" style="background:var(--gold)"></span>Tổng tin đăng</div>
        </div>
        <div class="scard">
            <style>
                .scard:nth-child(2)::before {
                    background: var(--green)
                }</style>
            <i class="bi bi-broadcast scard-ico" style="color:var(--green)"></i>
            <div class="sc-n" style="color:var(--green)">@ViewBag.OpenJobs</div>
            <div class="sc-l"><span class="sc-dot" style="background:var(--green)"></span>Đang tuyển</div>
        </div>
        <div class="scard">
            <style>
                .scard:nth-child(3)::before {
                    background: var(--blue)
                }</style>
            <i class="bi bi-people scard-ico" style="color:var(--blue)"></i>
            <div class="sc-n" style="color:var(--blue)">@ViewBag.TotalVacancy</div>
            <div class="sc-l"><span class="sc-dot" style="background:var(--blue)"></span>Chỉ tiêu tuyển</div>
        </div>
        <div class="scard">
            <style>
                .scard:nth-child(4)::before {
                    background: var(--purple)
                }</style>
            <i class="bi bi-file-earmark-person scard-ico" style="color:var(--purple)"></i>
            <div class="sc-n" style="color:var(--purple)">@ViewBag.TotalApps</div>
            <div class="sc-l"><span class="sc-dot" style="background:var(--purple)"></span>Tổng hồ sơ</div>
        </div>
        <div class="scard">
            <style>
                .scard:nth-child(5)::before {
                    background: var(--red)
                }</style>
            <i class="bi bi-bell scard-ico" style="color:var(--red)"></i>
            <div class="sc-n" style="color:var(--red)">@ViewBag.NewApps</div>
            <div class="sc-l"><span class="sc-dot" style="background:var(--red)"></span>Hồ sơ mới</div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs">
        <a class="tab active" href="@Url.Action("Index", "AdminJob")">
            <i class="bi bi-list-ul"></i> Tin Tuyển Dụng
            <span class="cnt">@Model.Count()</span>
        </a>
        <a class="tab" href="@Url.Action("Applications", "AdminJob")">
            <i class="bi bi-file-earmark-person"></i> Hồ Sơ Ứng Tuyển
            <span class="cnt">@ViewBag.TotalApps</span>
        </a>
    </div>

    <!-- Toolbar -->
    <form method="get" class="toolbar">
        <div class="srch-wrap">
            <i class="bi bi-search"></i>
            <input type="text" name="search" placeholder="Tìm vị trí, mô tả..."
                   value="@Context.Request.Query["search"]" />
        </div>
        <select name="status" class="tb-sel">
            <option value="">Tất cả trạng thái</option>
            <option value="Open" selected="@(Context.Request.Query["status"] == "Open")">Đang tuyển</option>
            <option value="Closed" selected="@(Context.Request.Query["status"] == "Closed")">Đã đóng</option>
            <option value="Filled" selected="@(Context.Request.Query["status"] == "Filled")">Đã tuyển đủ</option>
            <option value="Draft" selected="@(Context.Request.Query["status"] == "Draft")">Nháp</option>
        </select>
        <select name="jobType" class="tb-sel">
            <option value="">Tất cả loại hình</option>
            <option value="Full-time">Full-time</option>
            <option value="Part-time">Part-time</option>
            <option value="Contract">Hợp đồng</option>
            <option value="Internship">Thực tập</option>
            <option value="Remote">Remote</option>
        </select>
        <select name="department" class="tb-sel">
            <option value="">Tất cả bộ phận</option>
            <option value="Vận hành">Vận hành</option>
            <option value="Kỹ thuật">Kỹ thuật</option>
            <option value="Marketing">Marketing</option>
            <option value="Kế toán">Kế toán</option>
            <option value="Bảo vệ">Bảo vệ</option>
            <option value="Dịch vụ khách hàng">DVKH</option>
        </select>
        <button type="submit" class="btn-dark" style="padding:.57rem 1rem;">
            <i class="bi bi-funnel-fill"></i> Lọc
        </button>
        @if (!string.IsNullOrEmpty(Context.Request.Query["search"]) || !string.IsNullOrEmpty(Context.Request.Query["status"]) || !string.IsNullOrEmpty(Context.Request.Query["jobType"]) || !string.IsNullOrEmpty(Context.Request.Query["department"]))
        {
            <a href="@Url.Action("Index", "AdminJob")" class="btn-ghost" style="padding:.57rem .9rem;">
                <i class="bi bi-x-lg"></i> Xóa lọc
            </a>
        }
    </form>

    <!-- Table -->
    <div class="tbl-card">
        <div class="tbl-hd">
            <div class="tbl-hd-ico"><i class="bi bi-briefcase-fill"></i></div>
            <span class="tbl-hd-title">Danh sách tin tuyển dụng</span>
            <span class="tbl-cnt">@Model.Count() tin</span>
        </div>

        @if (Model.Any())
        {
            <div style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr>
                            <th>Vị trí tuyển dụng</th>
                            <th>Loại hình / Cấp bậc</th>
                            <th>Mức lương</th>
                            <th>Hạn nộp</th>
                            <th>Hồ sơ</th>
                            <th>Trạng thái</th>
                            <th style="text-align:right;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model)
                        {
                            var appCount = job.Applications?.Count ?? 0;
                            var newCount = job.Applications?.Count(a => a.Status == "New") ?? 0;
                            bool expired = job.Deadline.HasValue && job.Deadline.Value.Date < DateTime.Today;
                            bool expireSoon = job.Deadline.HasValue && !expired && job.Deadline.Value.Date <= DateTime.Today.AddDays(7);
                            string dlClass = expired ? "dl-exp" : expireSoon ? "dl-soon" : "dl-ok";
                            string dlIcon = expired ? "bi-calendar-x-fill" : expireSoon ? "bi-clock-fill" : "bi-calendar3";

                            <tr>
                                <td style="min-width:220px;">
                                    <div class="job-name">
                                        @if (job.IsFeatured)
                                        {
                                            <i class="bi bi-star-fill" style="color:var(--gold);font-size:.72rem;"></i>
                                        }
                                        @if (job.IsUrgent)
                                        {
                                            <span class="bdg bdg-urgent" style="font-size:.62rem;padding:1px 7px;">Hot</span>
                                        }
                                        @job.JobTitle
                                    </div>
                                    <div class="job-sub">
                                        @if (!string.IsNullOrEmpty(job.Department))
                                        {
                                            <span><i class="bi bi-building"></i>@job.Department</span>
                                        }
                                        @if (!string.IsNullOrEmpty(job.Location))
                                        {
                                            <span><i class="bi bi-geo-alt"></i>@job.Location</span>
                                        }
                                        <span><i class="bi bi-people"></i>@job.VacancyCount vị trí</span>
                                        <span><i class="bi bi-eye"></i>@job.ViewCount lượt</span>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(job.JobType))
                                    {
                                        string jc = job.JobType switch { "Full-time" => "bdg-ft", "Part-time" => "bdg-pt", "Contract" => "bdg-ct", _ => "bdg-re" };
                                        <span class="bdg @jc">@job.JobType</span>
                                    }
                                    @if (!string.IsNullOrEmpty(job.Level))
                                    {
                                        <span class="bdg bdg-lvl ms-1">@job.Level</span>
                                    }
                                </td>
                                <td>
                                    @if (job.SalaryType == "Negotiable" || job.SalaryType == "Competitive")
                                    {
                                        <span class="sal-neg">Thương lượng</span>
                                    }
                                    else if (job.SalaryMin.HasValue || job.SalaryMax.HasValue)
                                    {
                                        <span class="sal-num">
                                            @if (job.SalaryMin.HasValue && job.SalaryMax.HasValue)
                                            {
                                                @($"{job.SalaryMin.Value / 1000000:0.#}M – {job.SalaryMax.Value / 1000000:0.#}M")
                                            }
                                            else if (job.SalaryMin.HasValue)
                                            {

                                                @($"Từ {job.SalaryMin.Value / 1000000:0.#}M")
                                            }
                                            else
                                            {

                                                @($"Đến {job.SalaryMax!.Value / 1000000:0.#}M")
                                            }
                                        </span>
                                    }
                                    else
                                    {

                                        <span class="sal-neg">—</span>
                                    }
                                </td>
                                <td>
                                    @if (job.Deadline.HasValue)
                                    {
                                        <span class="@dlClass"><i class="bi @dlIcon me-1"></i>@job.Deadline.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else
                                    {

                                        <span class="dl-ok">—</span>
                                    }
                                </td>
                                <td>
                                    <a class="apps-pill" href="@Url.Action("Applications", "AdminJob", new { jobId = job.JobId })">
                                        <i class="bi bi-file-earmark-person"></i> @appCount hồ sơ
                                        @if (newCount > 0)
                                        {
                                            <span class="new-dot"></span>
                                        }
                                    </a>
                                </td>
                                <td>
                                    @{
                                        string bc = job.Status switch { "Open" => "bdg-open", "Filled" => "bdg-filled", "Draft" => "bdg-draft", _ => "bdg-closed" };
                                        string bt = job.Status switch { "Open" => "Đang tuyển", "Filled" => "Đã tuyển đủ", "Draft" => "Nháp", _ => "Đã đóng" };
                                    }
                                    <span class="bdg @bc">● @bt</span>
                                </td>
                                <td style="text-align:right;white-space:nowrap;">
                                    <div class="qa">
                                        <button class="qa-btn qa-view" title="Xem chi tiết" onclick="openDetailsModal(@job.JobId)"><i class="bi bi-eye"></i></button>
                                        <button class="qa-btn qa-edit" title="Chỉnh sửa" onclick="openEditModal(@job.JobId)"><i class="bi bi-pencil"></i></button>
                                        <button class="qa-btn qa-del" title="Xóa" onclick="confirmDelete(@job.JobId,'@Html.Raw(job.JobTitle.Replace("'", "\\\'"))')"><i class="bi bi-trash3"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-box">
                <i class="bi bi-briefcase"></i>
                <h6>Chưa có tin tuyển dụng nào</h6>
                <p>Nhấn <strong>"Thêm Tin Mới"</strong> để bắt đầu đăng tin</p>
            </div>
        }
    </div>
</div>

<!-- Modal chính -->
<div class="modal fade" id="modalJob" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content rounded-3 border-0 shadow" id="modalJobContent">
            <div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold);"></div></div>
        </div>
    </div>
</div>

<!-- Modal xóa -->
<div class="modal fade del-modal" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:360px;">
        <div class="modal-content p-4">
            <div class="del-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <h5 class="text-center fw-bold mb-1" style="color:var(--deep);">Xác nhận xóa?</h5>
            <p class="text-center mb-3" style="font-size:.85rem;color:var(--muted);">
                Xóa tin <strong id="deleteName" style="color:var(--deep);"></strong>.<br>
                Toàn bộ hồ sơ liên quan cũng bị xóa. Không thể khôi phục!
            </p>
            <div class="d-flex gap-2">
                <button class="btn-del-cancel" data-bs-dismiss="modal">Hủy bỏ</button>
                <form id="deleteForm" method="post" style="width:100%;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-del-confirm">Xác nhận xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(()=>{ const t=document.getElementById('successToast'); if(t) t.style.display='none'; },3500);
        function openCreateModal() {
            const mc=document.getElementById('modalJobContent');
            mc.innerHTML='<div class="p-5 text-center"><div class="spinner-border" style="color:#d4a017;"></div></div>';
            new bootstrap.Modal(document.getElementById('modalJob')).show();
            fetch('/AdminJob/Create').then(r=>r.text()).then(html=>{ mc.innerHTML=html; });
        }
        function openEditModal(id) {
            const mc=document.getElementById('modalJobContent');
            mc.innerHTML='<div class="p-5 text-center"><div class="spinner-border" style="color:#d4a017;"></div></div>';
            new bootstrap.Modal(document.getElementById('modalJob')).show();
            fetch('/AdminJob/Edit/'+id).then(r=>r.text()).then(html=>{ mc.innerHTML=html; });
        }
        function openDetailsModal(id) {
            const mc=document.getElementById('modalJobContent');
            mc.innerHTML='<div class="p-5 text-center"><div class="spinner-border" style="color:#d4a017;"></div></div>';
            new bootstrap.Modal(document.getElementById('modalJob')).show();
            fetch('/AdminJob/Details/'+id).then(r=>r.text()).then(html=>{ mc.innerHTML=html; });
        }
        function confirmDelete(id, title) {
            document.getElementById('deleteName').textContent=title;
            document.getElementById('deleteForm').onsubmit=function(e){
                e.preventDefault();
                const token=this.querySelector('[name=__RequestVerificationToken]').value;
                fetch('/AdminJob/Delete/'+id,{method:'POST',headers:{'RequestVerificationToken':token}})
                    .then(r=>r.json()).then(res=>{
                        bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                        if(res.success) location.reload(); else alert(res.message);
                    });
            };
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}
