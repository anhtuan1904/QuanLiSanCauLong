@model QuanLiSanCauLong.Models.JobPosting
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --deep2: #231a0e;
        --deep3: #2e2110;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .mh {
        background: var(--deep2);
        color: #fff;
        border-radius: 16px 16px 0 0;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 2px solid rgba(212,160,23,.2);
    }

    .mh-left {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .mh-ico {
        width: 36px;
        height: 36px;
        background: rgba(212,160,23,.15);
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold2);
        font-size: 1rem;
        flex-shrink: 0;
    }

    .mh h5 {
        font-weight: 800;
        font-size: 1.05rem;
        margin: 0 0 2px;
    }

    .mh p {
        font-size: .78rem;
        color: rgba(255,255,255,.5);
        margin: 0;
    }

    .mh .btn-close {
        filter: invert(1);
        opacity: .6;
    }

    .edit-badge {
        background: rgba(212,160,23,.18);
        color: var(--gold2);
        border: 1px solid rgba(212,160,23,.35);
        border-radius: 5px;
        padding: 1px 9px;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
    }

    .modal-body {
        background: #fff;
    }

    .sec {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--deep);
        margin-bottom: .85rem;
    }

        .sec::after {
            content: '';
            flex: 1;
            height: 1.5px;
            background: linear-gradient(90deg,rgba(212,160,23,.35),transparent);
        }

    .sec-ico {
        width: 22px;
        height: 22px;
        background: var(--gold2);
        border-radius: 5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .7rem;
        color: var(--deep);
        flex-shrink: 0;
    }

    .fl {
        font-size: .73rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: var(--muted);
        margin-bottom: 5px;
        display: block;
    }

    .fi, .fs, .ft {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: var(--warm);
        color: var(--deep);
        font-size: .875rem;
        padding: .5rem .75rem;
        width: 100%;
        transition: .18s;
    }

        .fi:focus, .fs:focus, .ft:focus {
            outline: none;
            border-color: var(--gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(212,160,23,.15);
        }

    .ft {
        resize: vertical;
        min-height: 85px;
    }

    .check-row {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .55rem .9rem;
        cursor: pointer;
        transition: .18s;
    }

        .check-row:hover {
            border-color: var(--gold);
            background: var(--cream);
        }

        .check-row input {
            width: 16px;
            height: 16px;
            accent-color: var(--gold);
            cursor: pointer;
            flex-shrink: 0;
        }

        .check-row span {
            font-size: .875rem;
            font-weight: 600;
            color: var(--deep);
        }

    .salary-wrap {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .salary-wrap span {
            color: var(--muted);
            font-size: .85rem;
            white-space: nowrap;
        }

    .tip {
        font-size: .71rem;
        color: var(--muted);
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .tip i {
            color: var(--gold);
            opacity: .7;
            font-size: .7rem;
        }

    .btn-p {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        border-radius: 10px;
        padding: .62rem 1.75rem;
        font-weight: 800;
        font-size: .875rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: .2s;
        box-shadow: 0 2px 8px rgba(212,160,23,.3);
    }

        .btn-p:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.45);
        }

    .btn-s {
        background: var(--warm);
        color: var(--deep);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: .62rem 1.5rem;
        font-weight: 600;
        font-size: .875rem;
        cursor: pointer;
        transition: .2s;
    }

        .btn-s:hover {
            background: var(--cream);
            border-color: var(--deep);
        }

    .footer-bar {
        border-top: 1.5px solid var(--border);
        background: var(--cream);
        padding: .85rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-radius: 0 0 16px 16px;
    }

    .footer-meta {
        font-size: .73rem;
        color: var(--muted);
    }

        .footer-meta i {
            color: var(--gold);
            opacity: .7;
        }
</style>

<div class="mh">
    <div class="mh-left">
        <div class="mh-ico"><i class="bi bi-pencil-fill"></i></div>
        <div>
            <h5>Chỉnh Sửa Tin Tuyển Dụng <span class="edit-badge ms-1">ID #@Model.JobId</span></h5>
            <p>Cập nhật thông tin — <strong style="color:#fff;">@Model.JobTitle</strong></p>
        </div>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body px-4 py-3">
    <form asp-action="Edit" method="post" id="editJobForm">
        @Html.AntiForgeryToken()
        <input asp-for="JobId" type="hidden" />
        <div class="row g-3">

            <div class="col-12 mt-1">
                <div class="sec"><span class="sec-ico">📋</span> Thông Tin Cơ Bản</div>
            </div>
            <div class="col-md-7">
                <label class="fl">Vị trí tuyển dụng <span class="text-danger">*</span></label>
                <input asp-for="JobTitle" class="fi" required />
                <span asp-validation-for="JobTitle" class="text-danger" style="font-size:.75rem;"></span>
            </div>
            <div class="col-md-3">
                <label class="fl">Bộ phận</label>
                <select asp-for="Department" class="fs">
                    <option value="">-- Chọn --</option>
                    <option>Vận hành</option>
                    <option>Kỹ thuật</option>
                    <option>Marketing</option>
                    <option>Kế toán</option>
                    <option>Bảo vệ</option>
                    <option>Dịch vụ khách hàng</option>
                    <option>Nhân sự</option>
                    <option>IT</option>
                    <option>Khác</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="fl">Số lượng</label>
                <input asp-for="VacancyCount" type="number" class="fi" min="1" max="99" required />
            </div>

            <div class="col-md-6">
                <label class="fl">Địa điểm làm việc</label>
                <input asp-for="Location" class="fi" />
            </div>
            <div class="col-md-3">
                <label class="fl">Hạn nộp hồ sơ</label>
                <input asp-for="Deadline" type="date" class="fi" />
            </div>
            <div class="col-md-3">
                <label class="fl">Trạng thái</label>
                <select asp-for="Status" class="fs">
                    <option value="Open">Đang tuyển</option>
                    <option value="Closed">Đã đóng</option>
                    <option value="Filled">Đã tuyển đủ</option>
                    <option value="Draft">Lưu nháp</option>
                </select>
            </div>

            <div class="col-12">
                <label class="fl">Mô tả công việc <span class="text-danger">*</span></label>
                <textarea asp-for="JobDescription" class="ft" rows="4" required></textarea>
                <span asp-validation-for="JobDescription" class="text-danger" style="font-size:.75rem;"></span>
            </div>
            <div class="col-md-6">
                <label class="fl">Yêu cầu ứng viên</label>
                <textarea asp-for="Requirements" class="ft" rows="4"></textarea>
            </div>
            <div class="col-md-6">
                <label class="fl">Quyền lợi</label>
                <textarea asp-for="Benefits" class="ft" rows="4"></textarea>
            </div>

            <div class="col-12 mt-1">
                <div class="sec"><span class="sec-ico">💼</span> Loại Hình & Mức Lương</div>
            </div>
            <div class="col-md-4">
                <label class="fl">Loại hình</label>
                <select asp-for="JobType" class="fs">
                    <option value="">-- Chọn --</option>
                    <option value="Full-time">Full-time</option>
                    <option value="Part-time">Part-time</option>
                    <option value="Contract">Hợp đồng</option>
                    <option value="Internship">Thực tập</option>
                    <option value="Remote">Remote</option>
                    <option value="Hybrid">Hybrid</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="fl">Cấp bậc</label>
                <select asp-for="Level" class="fs">
                    <option value="">-- Chọn --</option>
                    <option value="Intern">Intern / Thực tập</option>
                    <option value="Junior">Junior (0–2 năm)</option>
                    <option value="Middle">Middle (2–5 năm)</option>
                    <option value="Senior">Senior (5+ năm)</option>
                    <option value="Lead">Lead / Trưởng nhóm</option>
                    <option value="Manager">Manager / Quản lý</option>
                    <option value="Director">Director / Giám đốc</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="fl">Hình thức lương</label>
                <select asp-for="SalaryType" class="fs" id="salaryTypeSelect">
                    <option value="Fixed">Lương cố định</option>
                    <option value="Negotiable">Thương lượng</option>
                    <option value="Competitive">Cạnh tranh</option>
                </select>
            </div>
            <div class="col-12" id="salaryRange">
                <label class="fl">Khoảng lương (VNĐ/tháng)</label>
                <div class="salary-wrap">
                    <input asp-for="SalaryMin" type="number" class="fi" step="500000" />
                    <span>—</span>
                    <input asp-for="SalaryMax" type="number" class="fi" step="500000" />
                </div>
            </div>

            <div class="col-12 mt-1">
                <div class="sec"><span class="sec-ico">📞</span> Liên Hệ Tuyển Dụng</div>
            </div>
            <div class="col-md-4">
                <label class="fl">Người phụ trách</label>
                <input asp-for="ContactPerson" class="fi" />
            </div>
            <div class="col-md-4">
                <label class="fl">Email liên hệ</label>
                <input asp-for="ContactEmail" type="email" class="fi" />
            </div>
            <div class="col-md-4">
                <label class="fl">Số điện thoại</label>
                <input asp-for="ContactPhone" class="fi" />
            </div>

            <div class="col-12 mt-1">
                <div class="sec"><span class="sec-ico">⚙️</span> Cài Đặt Hiển Thị</div>
            </div>
            <div class="col-md-4">
                <label class="check-row">
                    <input asp-for="IsFeatured" type="checkbox" />
                    <span>⭐ Đánh dấu tin <strong>nổi bật</strong></span>
                </label>
            </div>
            <div class="col-md-4">
                <label class="check-row">
                    <input asp-for="IsUrgent" type="checkbox" />
                    <span>🔥 Tuyển <strong>gấp</strong> (nhãn Hot)</span>
                </label>
            </div>
            <div class="col-12">
                <label class="fl">Mô tả ngắn / SEO</label>
                <input asp-for="MetaDescription" class="fi" maxlength="500" />
                <div class="tip"><i class="bi bi-info-circle"></i>Tối đa 500 ký tự</div>
            </div>
        </div>
    </form>
    <div class="footer-bar">
        <span class="footer-meta"><i class="bi bi-clock me-1"></i>Cập nhật lần cuối: @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span>
        <div class="d-flex gap-2">
            <button type="button" class="btn-s" data-bs-dismiss="modal">Hủy bỏ</button>
            <button type="submit" form="editJobForm" class="btn-p"><i class="bi bi-check2-circle"></i> Lưu Thay Đổi</button>
        </div>
    </div>
</div>

<script>
    (function(){
        const sel=document.getElementById('salaryTypeSelect');
        const rng=document.getElementById('salaryRange');
        function update(){ rng.style.opacity=sel.value==='Fixed'?'1':'.45'; }
        sel?.addEventListener('change',update); update();
    })();
</script>
