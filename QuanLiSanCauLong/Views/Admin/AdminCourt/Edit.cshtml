@model QuanLiSanCauLong.Models.Court
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-sub {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
        max-height: calc(85vh - 130px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .mbody::-webkit-scrollbar {
            width: 5px;
        }

        .mbody::-webkit-scrollbar-track {
            background: var(--warm);
            border-radius: 3px;
        }

        .mbody::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

            .mbody::-webkit-scrollbar-thumb:hover {
                background: var(--gold2);
            }

    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-req {
        color: #c94b2a;
        margin-left: .15rem;
    }

    .fg-input, .fg-select, .fg-textarea {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.08);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 70px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .location-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
    }

    .loc-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .7rem .9rem;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .7rem;
    }

        .loc-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .loc-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .loc-icon {
        width: 34px;
        height: 34px;
        border-radius: 7px;
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .loc-card.selected .loc-icon {
        background: rgba(212,160,23,.15);
    }

    .loc-name {
        font-weight: 700;
        font-size: .82rem;
        color: var(--deep);
    }

    .loc-desc {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .surface-cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .6rem;
    }

    .surf-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .65rem .7rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .surf-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .surf-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .surf-icon {
        font-size: 1.3rem;
        margin-bottom: .25rem;
    }

    .surf-name {
        font-size: .76rem;
        font-weight: 700;
        color: var(--deep);
    }

    .surf-sub {
        font-size: .64rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .status-opts {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .status-text {
        font-size: .8rem;
        font-weight: 600;
        color: var(--deep);
    }

    .amenity-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
    }

    .amenity-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .6rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

        .amenity-item:hover {
            border-color: rgba(212,160,23,.4);
        }

        .amenity-item.checked {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .amenity-item input[type=checkbox] {
            width: 15px;
            height: 15px;
            accent-color: var(--gold);
            cursor: pointer;
        }

    .amenity-label {
        font-size: .82rem;
        color: var(--deep);
        font-weight: 500;
        cursor: pointer;
        user-select: none;
    }

    /* Existing images */
    .exist-imgs {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(78px,1fr));
        gap: .5rem;
        margin-bottom: .6rem;
    }

    .exist-img {
        position: relative;
        aspect-ratio: 1;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid var(--border);
        cursor: pointer;
    }

        .exist-img.primary {
            border-color: var(--gold);
            border-width: 2.5px;
        }

        .exist-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .ei-primary-badge {
        position: absolute;
        bottom: 3px;
        left: 3px;
        background: var(--gold);
        color: var(--deep);
        font-size: .55rem;
        font-weight: 800;
        padding: .1rem .4rem;
        border-radius: 3px;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .ei-del {
        position: absolute;
        top: 3px;
        right: 3px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background: rgba(201,75,42,.9);
        color: #fff;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: .6rem;
    }

    .exist-img:hover .ei-del {
        display: flex;
    }

    .exist-img.deleted {
        opacity: .35;
        filter: grayscale(1);
    }

        .exist-img.deleted .ei-del {
            display: flex;
            background: rgba(26,18,9,.6);
        }

    .upload-zone {
        border: 1.5px dashed var(--border);
        border-radius: 8px;
        padding: .9rem;
        background: var(--cream);
        cursor: pointer;
        transition: border-color .2s;
        text-align: center;
    }

        .upload-zone:hover {
            border-color: var(--gold);
        }

    .new-imgs {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(78px,1fr));
        gap: .5rem;
        margin-top: .6rem;
    }

    .ni {
        position: relative;
        aspect-ratio: 1;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid rgba(212,160,23,.4);
    }

        .ni img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .ni-del {
        position: absolute;
        top: 3px;
        right: 3px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background: rgba(201,75,42,.9);
        color: #fff;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: .6rem;
    }

    .ni:hover .ni-del {
        display: flex;
    }

    /* Slot management */
    .day-tab-e {
        padding: .35rem .75rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .76rem;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
    }

        .day-tab-e:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        .day-tab-e.active {
            background: linear-gradient(135deg,var(--gold),var(--gold2));
            color: var(--deep);
            border-color: var(--gold);
            font-weight: 700;
        }

    .slot-row-e {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .65rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 7px;
        margin-bottom: .35rem;
    }

    .slot-time-e {
        font-weight: 700;
        font-size: .82rem;
        color: var(--deep);
        min-width: 100px;
        font-family: monospace;
    }

    .slot-price-e {
        font-size: .8rem;
        color: #16a34a;
        font-weight: 600;
        flex: 1;
    }

    .slot-inactive-e {
        opacity: .45;
    }

    .slot-del-e {
        width: 24px;
        height: 24px;
        border-radius: 5px;
        border: 1px solid rgba(201,75,42,.3);
        background: rgba(201,75,42,.06);
        color: #c94b2a;
        cursor: pointer;
        font-size: .7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .slot-del-e:hover {
            background: #c94b2a;
            color: #fff;
        }

    .slot-toggle-e {
        width: 24px;
        height: 24px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--muted);
        cursor: pointer;
        font-size: .7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .slot-toggle-e:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

    .slot-empty-e {
        color: var(--muted);
        font-size: .8rem;
        padding: .6rem 0;
    }

    .btn-add-slot-e {
        padding: .45rem .85rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: .35rem;
        transition: all .2s;
    }

        .btn-add-slot-e:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(212,160,23,.3);
        }

    .slot-msg-ok {
        color: #16a34a;
    }

    .slot-msg-err {
        color: #c94b2a;
    }

    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-save:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Chỉnh Sửa</div>
        <div class="mh-title">Cập Nhật Sân</div>
        <div class="mh-sub">@Model.CourtNumber</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="mbody">
    <form id="editCourtForm" asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="CourtId" type="hidden" />
        <input asp-for="CreatedAt" type="hidden" />
        <input asp-for="ImagePath" type="hidden" />

        <!-- 1. Cơ sở -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-building sf-card-icon"></i>
                <span class="sf-card-title">Thuộc Cơ Sở</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="fg">
                    <label class="fg-label">Cơ Sở <span class="fg-req">*</span></label>
                    <select asp-for="FacilityId" asp-items="@(ViewBag.Facilities as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"
                            class="fg-select">
                        <option value="">— Chọn cơ sở —</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- 2. Thông tin sân -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-card-text sf-card-icon"></i>
                <span class="sf-card-title">Thông Tin Sân</span>
            </div>
            <div class="sf-card-body">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:.75rem;">
                    <div class="fg">
                        <label class="fg-label">Tên / Số Sân <span class="fg-req">*</span></label>
                        <input asp-for="CourtNumber" class="fg-input" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Vị Trí Tầng</label>
                        <input asp-for="FloorNumber" class="fg-input" />
                    </div>
                </div>

                <div class="fg">
                    <label class="fg-label">Vị Trí <span class="fg-req">*</span></label>
                    <input asp-for="CourtType" type="hidden" id="courtTypeInputE" />
                    <div class="location-cards">
                        <div class="loc-card" id="locE-Indoor" onclick="selectLocationE('Indoor')">
                            <div class="loc-icon">🏠</div>
                            <div><div class="loc-name">Trong Nhà</div><div class="loc-desc">Có mái che</div></div>
                        </div>
                        <div class="loc-card" id="locE-Outdoor" onclick="selectLocationE('Outdoor')">
                            <div class="loc-icon">☀️</div>
                            <div><div class="loc-name">Ngoài Trời</div><div class="loc-desc">Lộ thiên</div></div>
                        </div>
                    </div>
                </div>

                <div class="fg">
                    <label class="fg-label">Loại Mặt Sân <span class="fg-req">*</span></label>
                    <input asp-for="SurfaceType" type="hidden" id="surfaceInputE" />
                    <div class="surface-cards">
                        <div class="surf-card" id="surfE-PVC" onclick="selectSurfaceE('PVC')">
                            <div class="surf-icon">🟨</div><div class="surf-name">Thảm PVC</div><div class="surf-sub">Cao su tổng hợp</div>
                        </div>
                        <div class="surf-card" id="surfE-Wood" onclick="selectSurfaceE('Wood')">
                            <div class="surf-icon">🪵</div><div class="surf-name">Sàn Gỗ</div><div class="surf-sub">Chuyên nghiệp</div>
                        </div>
                        <div class="surf-card" id="surfE-Silicon" onclick="selectSurfaceE('Silicon')">
                            <div class="surf-icon">🎨</div><div class="surf-name">Sơn Silicon</div><div class="surf-sub">Độ bám tốt</div>
                        </div>
                    </div>
                </div>

                <div class="fg">
                    <label class="fg-label">Tình Trạng <span class="fg-req">*</span></label>
                    <input asp-for="Status" type="hidden" id="statusInputE" />
                    <div class="status-opts">
                        <div class="status-opt" id="stE-Available" onclick="selectStatusE('Available')">
                            <span class="status-dot" style="background:#16a34a;"></span>
                            <span class="status-text">Đang Trống</span>
                        </div>
                        <div class="status-opt" id="stE-Active" onclick="selectStatusE('Active')">
                            <span class="status-dot" style="background:var(--gold);"></span>
                            <span class="status-text">Hoạt Động</span>
                        </div>
                        <div class="status-opt" id="stE-Maintenance" onclick="selectStatusE('Maintenance')">
                            <span class="status-dot" style="background:#c94b2a;"></span>
                            <span class="status-text">Bảo Trì</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. Tiện ích -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-lightning-charge sf-card-icon"></i>
                <span class="sf-card-title">Tiện Ích Sân</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="amenity-grid">
                    <label class="amenity-item @(Model.HasLighting ? "checked" : "")" id="amE-light">
                        <span>💡</span>
                        <input asp-for="HasLighting" type="checkbox" onchange="document.getElementById('amE-light').classList.toggle('checked',this.checked)" />
                        <span class="amenity-label">Đèn chiếu sáng</span>
                    </label>
                    <label class="amenity-item @(Model.HasAC ? "checked" : "")" id="amE-ac">
                        <span>❄️</span>
                        <input asp-for="HasAC" type="checkbox" onchange="document.getElementById('amE-ac').classList.toggle('checked',this.checked)" />
                        <span class="amenity-label">Điều hoà</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 4. Mô tả -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-chat-left-text sf-card-icon"></i>
                <span class="sf-card-title">Mô Tả</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="fg">
                    <textarea asp-for="Description" class="fg-textarea"
                              placeholder="VD: Gần cửa sổ, ánh sáng tự nhiên tốt nhất..."></textarea>
                </div>
            </div>
        </div>

        <!-- 5. Hình ảnh -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-images sf-card-icon"></i>
                <span class="sf-card-title">Hình Ảnh</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                @if (Model.CourtImages != null && Model.CourtImages.Any())
                {
                    <div style="font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem;">
                        Ảnh hiện tại — Click chọn ảnh chính / hover để xóa
                    </div>
                    <div class="exist-imgs" id="existImgsE">
                        @foreach (var img in Model.CourtImages.OrderBy(i => i.DisplayOrder))
                        {
                            <div class="exist-img @(img.IsPrimary ? "primary" : "")"
                                 id="eiE-@img.ImageId"
                                 onclick="setPrimaryExistE(@img.ImageId)">
                                <img src="@img.ImagePath" alt="">
                                @if (img.IsPrimary)
                                {
                                    <span class="ei-primary-badge">Chính</span>
                                }
                                <button type="button" class="ei-del"
                                        onclick="deleteExistImgE(@img.ImageId, event)">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <input type="hidden" id="deletedImgIdsE" name="DeletedImageIds" value="" />
                    <input type="hidden" id="newPrimaryImgIdE" name="NewPrimaryImageId" value="" />
                }

                <input type="file" id="imgInputE" name="CourtImages" multiple accept="image/*" style="display:none;" />
                <div class="upload-zone" onclick="document.getElementById('imgInputE').click()">
                    <i class="bi bi-plus-circle" style="font-size:1.2rem;color:var(--muted);display:block;margin-bottom:.2rem;"></i>
                    <div style="font-size:.82rem;color:var(--muted);">
                        <strong>Thêm ảnh mới</strong><br>
                        <span style="font-size:.72rem;">PNG, JPG (tối đa 5MB)</span>
                    </div>
                </div>
                <div class="new-imgs" id="newImgsE"></div>
            </div>
        </div>

    </form>

    <!-- 6. Khung giờ & Giá (ngoài form, dùng AJAX) -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-clock sf-card-icon"></i>
            <span class="sf-card-title">Khung Giờ & Giá</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.75rem;">
                @foreach (var (dayNum, dayName) in new (int, string)[]{
                                (1,"T2"),(2,"T3"),(3,"T4"),(4,"T5"),(5,"T6"),(6,"T7"),(0,"CN")})
                {
                    <button type="button" class="day-tab-e" data-day="@dayNum"
                            onclick="loadSlotsE(@dayNum)">
                        @dayName
                    </button>
                }
            </div>

            <div id="slotListE" style="min-height:40px;">
                <div class="slot-empty-e">Chọn ngày để xem khung giờ</div>
            </div>

            <div style="border-top:1px solid var(--border);margin-top:.75rem;padding-top:.75rem;">
                <div style="font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
                            color:var(--muted);margin-bottom:.5rem;">
                    Thêm Khung Giờ Mới
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:.5rem;align-items:end;">
                    <div>
                        <label class="fg-label">Từ giờ</label>
                        <input type="time" id="newStartE" class="fg-input" value="06:00" step="1800" />
                    </div>
                    <div>
                        <label class="fg-label">Đến giờ</label>
                        <input type="time" id="newEndE" class="fg-input" value="07:00" step="1800" />
                    </div>
                    <div>
                        <label class="fg-label">Giá (₫)</label>
                        <input type="number" id="newPriceE" class="fg-input" value="80000" min="0" step="5000" />
                    </div>
                    <div>
                        <button type="button" class="btn-add-slot-e" onclick="addSlotE()">
                            <i class="bi bi-plus-circle"></i> Thêm
                        </button>
                    </div>
                </div>
                <div id="slotMsgE" style="margin-top:.4rem;font-size:.78rem;display:none;"></div>
            </div>
        </div>
    </div>

</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="submit" form="editCourtForm" class="btn-save" id="btnEditSubmit">
        <i class="bi bi-check-circle"></i> Lưu Thay Đổi
    </button>
</div>

<script>
    (function() {
        const COURT_ID = @Model.CourtId;

        // ── Pickers ──
        window.selectLocationE = function(val) {
            document.querySelectorAll('#locE-Indoor,#locE-Outdoor').forEach(c => c.classList.remove('selected'));
            document.getElementById('locE-' + val)?.classList.add('selected');
            document.getElementById('courtTypeInputE').value = val;
        };
        window.selectSurfaceE = function(val) {
            document.querySelectorAll('#surfE-PVC,#surfE-Wood,#surfE-Silicon').forEach(c => c.classList.remove('selected'));
            document.getElementById('surfE-' + val)?.classList.add('selected');
            document.getElementById('surfaceInputE').value = val;
        };
        window.selectStatusE = function(val) {
            document.querySelectorAll('#stE-Available,#stE-Active,#stE-Maintenance').forEach(c => c.classList.remove('selected'));
            document.getElementById('stE-' + val)?.classList.add('selected');
            document.getElementById('statusInputE').value = val;
        };

        // Init pickers with model values
        const ct = '@Model.CourtType';
        const sf = '@Model.SurfaceType';
        const st = '@Model.Status';
        if (ct) selectLocationE(ct);
        if (sf) selectSurfaceE(sf);
        if (st) selectStatusE(st);

        // ── Existing images ──
        let deletedIdsE = [];
        window.deleteExistImgE = function(id, e) {
            e.stopPropagation();
            const el = document.getElementById('eiE-' + id);
            el.classList.toggle('deleted');
            if (deletedIdsE.includes(id)) deletedIdsE = deletedIdsE.filter(x => x !== id);
            else deletedIdsE.push(id);
            document.getElementById('deletedImgIdsE').value = deletedIdsE.join(',');
        };
        window.setPrimaryExistE = function(id) {
            document.querySelectorAll('.exist-img').forEach(el => {
                el.classList.remove('primary');
                const badge = el.querySelector('.ei-primary-badge');
                if (badge) badge.remove();
            });
            const el = document.getElementById('eiE-' + id);
            el.classList.add('primary');
            el.insertAdjacentHTML('beforeend', '<span class="ei-primary-badge">Chính</span>');
            document.getElementById('newPrimaryImgIdE').value = id;
        };

        // ── New images ──
        let newImgsE = [];
        const imgInputE = document.getElementById('imgInputE');
        imgInputE.addEventListener('change', function() {
            Array.from(this.files).forEach(file => {
                const r = new FileReader();
                r.onload = e => {
                    const i = newImgsE.length;
                    newImgsE.push(e.target.result);
                    const div = document.createElement('div');
                    div.className = 'ni'; div.id = 'niE-' + i;
                    div.innerHTML = `<img src="${e.target.result}" alt="">
                        <button type="button" class="ni-del" onclick="event.stopPropagation();window._delNewE(${i})">
                            <i class="bi bi-x"></i></button>`;
                    document.getElementById('newImgsE').appendChild(div);
                };
                r.readAsDataURL(file);
            });
        });
        window._delNewE = function(i) {
            newImgsE[i] = null;
            document.getElementById('niE-' + i)?.remove();
        };

        // ── AJAX submit ──
        document.getElementById('editCourtForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('btnEditSubmit');
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';
            try {
                const r = await fetch(this.action, { method:'POST', body: new FormData(this), redirect:'follow' });
                const ct = r.headers.get('content-type') || '';
                if (ct.includes('application/json')) {
                    const res = await r.json();
                    if (res.success) { alert(res.message || 'Cập nhật thành công!'); window.location.reload(); }
                    else alert('Lỗi: ' + (res.message || 'Dữ liệu không hợp lệ'));
                } else {
                    // Server trả về HTML (redirect hoặc View) → coi như thành công
                    if (r.ok || r.redirected) {
                        alert('Cập nhật thành công!');
                        window.location.reload();
                    } else {
                        alert('Lỗi server! Mã: ' + r.status);
                    }
                }
            } catch(err) { alert('Lỗi hệ thống: ' + err.message); }
            finally { btn.disabled = false; btn.innerHTML = orig; }
        });

        // ── PRICESLOT MANAGEMENT ──
        let currentDayE = -1;

        window.loadSlotsE = function(day) {
            currentDayE = day;
            document.querySelectorAll('.day-tab-e').forEach(t => {
                t.classList.toggle('active', parseInt(t.dataset.day) === day);
            });
            fetchSlotsE(day);
        };

        function fetchSlotsE(day) {
            document.getElementById('slotListE').innerHTML =
                '<div class="slot-empty-e"><i class="bi bi-arrow-repeat"></i> Đang tải...</div>';
            fetch(`/AdminCourt/GetPriceSlots?courtId=${COURT_ID}`)
                .then(r => r.json())
                .then(data => {
                    if (!data.success) { renderSlotsE([], day); return; }
                    const daySlots = data.slots.filter(s => s.dayOfWeek === day);
                    renderSlotsE(daySlots, day);
                })
                .catch(() => renderSlotsE([], day));
        }

        function renderSlotsE(slots, day) {
            const list = document.getElementById('slotListE');
            if (!slots.length) {
                list.innerHTML = '<div class="slot-empty-e">Chưa có khung giờ cho ngày này.</div>';
                return;
            }
            slots.sort((a, b) => a.startTime.localeCompare(b.startTime));
            list.innerHTML = slots.map(s => `
                <div class="slot-row-e ${s.isActive ? '' : 'slot-inactive-e'}" id="slotE-${s.slotId}">
                    <i class="bi bi-clock" style="font-size:.7rem;color:var(--gold);"></i>
                    <span class="slot-time-e">${s.startTime} – ${s.endTime}</span>
                    <span class="slot-price-e">${Number(s.price).toLocaleString('vi-VN')} ₫/h</span>
                    <span style="font-size:.68rem;color:var(--muted);">${s.isActive ? '✓' : '✗'}</span>
                    <button type="button" class="slot-toggle-e" onclick="toggleSlotE(${s.slotId})">
                        <i class="bi bi-${s.isActive ? 'eye-slash' : 'eye'}"></i>
                    </button>
                    <button type="button" class="slot-del-e" onclick="deleteSlotE(${s.slotId}, '${s.startTime}–${s.endTime}')">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>`).join('');
        }

        window.addSlotE = function() {
            if (currentDayE < 0) { showMsgE('Chọn ngày trước!', false); return; }
            const start = document.getElementById('newStartE').value;
            const end   = document.getElementById('newEndE').value;
            const price = document.getElementById('newPriceE').value;
            if (!start || !end) { showMsgE('Nhập giờ bắt đầu & kết thúc!', false); return; }
            if (start >= end)   { showMsgE('Giờ bắt đầu < giờ kết thúc!', false); return; }
            if (!price || price < 0) { showMsgE('Nhập giá hợp lệ!', false); return; }

            const fd = new FormData();
            fd.append('courtId', COURT_ID);
            fd.append('dayOfWeek', currentDayE);
            fd.append('startTime', start);
            fd.append('endTime', end);
            fd.append('price', price);
            fd.append('isActive', 'true');
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            fetch('/AdminCourt/AddPriceSlot', { method:'POST', body: fd })
                .then(r => r.json())
                .then(data => {
                    showMsgE(data.message, data.success);
                    if (data.success) {
                        document.getElementById('newStartE').value = end;
                        const [h, m] = end.split(':').map(Number);
                        document.getElementById('newEndE').value =
                            String(h + 1).padStart(2,'0') + ':' + String(m).padStart(2,'0');
                        fetchSlotsE(currentDayE);
                    }
                })
                .catch(() => showMsgE('Lỗi kết nối!', false));
        };

        window.deleteSlotE = function(id, label) {
            if (!confirm(`Xóa khung giờ ${label}?`)) return;
            const fd = new FormData();
            fd.append('slotId', id);
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
            fetch('/AdminCourt/DeletePriceSlot', { method:'POST', body: fd })
                .then(r => r.json())
                .then(data => { showMsgE(data.message, data.success); if (data.success) fetchSlotsE(currentDayE); })
                .catch(() => showMsgE('Lỗi!', false));
        };

        window.toggleSlotE = function(id) {
            const fd = new FormData();
            fd.append('slotId', id);
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
            fetch('/AdminCourt/TogglePriceSlot', { method:'POST', body: fd })
                .then(r => r.json())
                .then(data => { showMsgE(data.message, data.success); if (data.success) fetchSlotsE(currentDayE); });
        };

        function showMsgE(msg, ok) {
            const el = document.getElementById('slotMsgE');
            el.textContent = msg;
            el.className = ok ? 'slot-msg-ok' : 'slot-msg-err';
            el.style.display = 'block';
            setTimeout(() => { el.style.display = 'none'; }, 3500);
        }

        // Default load Monday
        loadSlotsE(1);
    })();
</script>
