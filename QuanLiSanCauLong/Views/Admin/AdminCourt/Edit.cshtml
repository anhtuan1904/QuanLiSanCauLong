@model QuanLiSanCauLong.Models.Court
@{
    ViewData["Title"] = "Sửa Sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    .cf-wrap {
        max-width: 680px;
        margin: 0 auto;
        font-family: 'Outfit',sans-serif;
    }

    .cf-head {
        margin-bottom: 2rem;
    }

    .cf-head-label {
        font-size: .68rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .6rem;
    }

        .cf-head-label::before {
            content: '';
            width: 16px;
            height: 1px;
            background: var(--gold);
        }

    .cf-title {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
    }

        .cf-title em {
            font-style: italic;
            color: var(--gold);
        }

    .cf-sub {
        font-size: .85rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .cf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .cf-card-head {
        padding: 1.1rem 1.75rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .cf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cf-card-icon {
        color: var(--gold);
        font-size: .95rem;
    }

    .cf-card-body {
        padding: 1.75rem;
    }

    .fg {
        margin-bottom: 1.25rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-label {
        display: block;
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .5rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .7rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 90px;
    }

    .fg-hint {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .field-error {
        font-size: .75rem;
        color: #c94b2a;
        margin-top: .3rem;
        display: block;
    }

    .alert-error {
        background: rgba(201,75,42,.06);
        border: 1px solid rgba(201,75,42,.3);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        color: #c94b2a;
        display: flex;
        align-items: flex-start;
        gap: .6rem;
    }

    .location-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }

    .loc-card {
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .9rem;
    }

        .loc-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .loc-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .loc-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .loc-card.selected .loc-icon {
        background: rgba(212,160,23,.15);
    }

    .loc-name {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
    }

    .loc-desc {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .surface-cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .75rem;
    }

    .surf-card {
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: .9rem 1rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .surf-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .surf-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .surf-icon {
        font-size: 1.6rem;
        margin-bottom: .4rem;
    }

    .surf-name {
        font-size: .8rem;
        font-weight: 700;
        color: var(--deep);
    }

    .surf-sub {
        font-size: .67rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .status-opts {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .6rem 1.1rem;
        border: 2px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .status-text {
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
    }

    .amenity-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
    }

    .amenity-item {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .8rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

        .amenity-item:hover {
            border-color: rgba(212,160,23,.4);
        }

        .amenity-item.checked {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .amenity-item input[type=checkbox] {
            width: 16px;
            height: 16px;
            accent-color: var(--gold);
            cursor: pointer;
        }

    .amenity-label {
        font-size: .84rem;
        color: var(--deep);
        font-weight: 500;
        cursor: pointer;
        user-select: none;
    }

    .amenity-icon {
        font-size: 1rem;
    }

    /* Existing images */
    .exist-imgs {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(90px,1fr));
        gap: .6rem;
        margin-bottom: .9rem;
    }

    .exist-img {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--border);
        cursor: pointer;
    }

        .exist-img.primary {
            border-color: var(--gold);
            border-width: 2.5px;
        }

        .exist-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .ei-primary-badge {
        position: absolute;
        bottom: 3px;
        left: 3px;
        background: var(--gold);
        color: var(--deep);
        font-size: .55rem;
        font-weight: 800;
        padding: .1rem .4rem;
        border-radius: 3px;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .ei-del {
        position: absolute;
        top: 3px;
        right: 3px;
        width: 20px;
        height: 20px;
        border-radius: 4px;
        background: rgba(201,75,42,.9);
        color: #fff;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
    }

    .exist-img:hover .ei-del {
        display: flex;
    }

    .exist-img.deleted {
        opacity: .35;
        filter: grayscale(1);
    }

        .exist-img.deleted .ei-del {
            display: flex;
            background: rgba(26,18,9,.6);
        }

    .upload-zone {
        border: 2px dashed var(--border);
        border-radius: 10px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        background: var(--cream);
    }

        .upload-zone:hover {
            border-color: var(--gold);
        }

    .upload-text {
        font-size: .84rem;
        color: var(--muted);
    }

        .upload-text strong {
            color: var(--deep);
        }

    .new-imgs {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(90px,1fr));
        gap: .6rem;
        margin-top: .75rem;
    }

    .ni {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid rgba(212,160,23,.4);
    }

        .ni img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .ni-del {
        position: absolute;
        top: 3px;
        right: 3px;
        width: 20px;
        height: 20px;
        border-radius: 4px;
        background: rgba(201,75,42,.9);
        color: #fff;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
    }

    .ni:hover .ni-del {
        display: flex;
    }

    .cf-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .btn-save {
        flex: 1;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .9rem 2rem;
        font-family: 'Outfit',sans-serif;
        font-size: .9rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .55rem;
        transition: all .25s;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-cancel {
        padding: .9rem 1.75rem;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
    }

        .btn-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    @@media(max - width:600px) {
        .fg-row2, .surface-cards, .location-cards {
            grid-template-columns: 1fr;
        }

        .amenity-grid {
            grid-template-columns: 1fr;
        }

        .status-opts {
            flex-direction: column;
        }
    }
</style>

<div class="cf-wrap">

    <div class="cf-head">
        <div class="cf-head-label">Quản Lý Sân</div>
        <h1 class="cf-title">Sửa <em>@Model.CourtNumber</em></h1>
        <div class="cf-sub">Cập nhật thông tin chi tiết cho sân cầu lông</div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-error">
            <i class="bi bi-exclamation-circle"></i>
            <div>
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@e.ErrorMessage</div>
                }
            </div>
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="CourtId" type="hidden" />
        <input asp-for="CreatedAt" type="hidden" />
        <input asp-for="ImagePath" type="hidden" />

        <!-- 1. CƠ SỞ -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-building cf-card-icon"></i>
                <span class="cf-card-title">Thuộc Cơ Sở</span>
            </div>
            <div class="cf-card-body">
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Cơ Sở <span class="req">*</span></label>
                    <select asp-for="FacilityId" asp-items="@(ViewBag.Facilities as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"
                            class="fg-select">
                        <option value="">— Chọn cơ sở —</option>
                    </select>
                    <span asp-validation-for="FacilityId" class="field-error"></span>
                </div>
            </div>
        </div>

        <!-- 2. THÔNG TIN SÂN -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-card-text cf-card-icon"></i>
                <span class="cf-card-title">Thông Tin Sân</span>
            </div>
            <div class="cf-card-body">

                <div class="fg-row2">
                    <div class="fg">
                        <label class="fg-label">Tên / Số Sân <span class="req">*</span></label>
                        <input asp-for="CourtNumber" class="fg-input" placeholder="VD: Sân số 1, Sân VIP" />
                        <span asp-validation-for="CourtNumber" class="field-error"></span>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Vị Trí Tầng</label>
                        <input asp-for="FloorNumber" class="fg-input" placeholder="VD: Tầng 1, Tầng 2" />
                    </div>
                </div>

                <!-- VỊ TRÍ -->
                <div class="fg">
                    <label class="fg-label">Vị Trí <span class="req">*</span></label>
                    <input asp-for="CourtType" type="hidden" id="courtTypeInput" />
                    <div class="location-cards">
                        <div class="loc-card" id="loc-Indoor" onclick="selectLocation('Indoor')">
                            <div class="loc-icon">🏠</div>
                            <div>
                                <div class="loc-name">Trong Nhà</div>
                                <div class="loc-desc">Sân có mái che, điều tiết nhiệt độ</div>
                            </div>
                        </div>
                        <div class="loc-card" id="loc-Outdoor" onclick="selectLocation('Outdoor')">
                            <div class="loc-icon">☀️</div>
                            <div>
                                <div class="loc-name">Ngoài Trời</div>
                                <div class="loc-desc">Sân lộ thiên, không gian thoáng</div>
                            </div>
                        </div>
                    </div>
                    <span asp-validation-for="CourtType" class="field-error"></span>
                </div>

                <!-- LOẠI MẶT SÂN -->
                <div class="fg">
                    <label class="fg-label">Loại Mặt Sân <span class="req">*</span></label>
                    <input asp-for="SurfaceType" type="hidden" id="surfaceInput" />
                    <div class="surface-cards">
                        <div class="surf-card" id="surf-PVC" onclick="selectSurface('PVC')">
                            <div class="surf-icon">🟨</div>
                            <div class="surf-name">Thảm PVC</div>
                            <div class="surf-sub">Cao su tổng hợp</div>
                        </div>
                        <div class="surf-card" id="surf-Wood" onclick="selectSurface('Wood')">
                            <div class="surf-icon">🪵</div>
                            <div class="surf-name">Sàn Gỗ</div>
                            <div class="surf-sub">Chuyên nghiệp</div>
                        </div>
                        <div class="surf-card" id="surf-Silicon" onclick="selectSurface('Silicon')">
                            <div class="surf-icon">🎨</div>
                            <div class="surf-name">Sơn Silicon</div>
                            <div class="surf-sub">Độ bám tốt</div>
                        </div>
                    </div>
                    <span asp-validation-for="SurfaceType" class="field-error"></span>
                </div>

                <!-- TÌNH TRẠNG -->
                <div class="fg">
                    <label class="fg-label">Tình Trạng <span class="req">*</span></label>
                    <input asp-for="Status" type="hidden" id="statusInput" />
                    <div class="status-opts">
                        <div class="status-opt" id="st-Available" onclick="selectStatus('Available')">
                            <span class="status-dot" style="background:#16a34a;"></span>
                            <span class="status-text">Đang Trống</span>
                        </div>
                        <div class="status-opt" id="st-Active" onclick="selectStatus('Active')">
                            <span class="status-dot" style="background:var(--gold);"></span>
                            <span class="status-text">Đang Hoạt Động</span>
                        </div>
                        <div class="status-opt" id="st-Maintenance" onclick="selectStatus('Maintenance')">
                            <span class="status-dot" style="background:#c94b2a;"></span>
                            <span class="status-text">Đang Bảo Trì</span>
                        </div>
                    </div>
                    <span asp-validation-for="Status" class="field-error"></span>
                </div>

            </div>
        </div>

        <!-- 3. TIỆN ÍCH -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-lightning-charge cf-card-icon"></i>
                <span class="cf-card-title">Tiện Ích Sân</span>
            </div>
            <div class="cf-card-body">
                <div class="amenity-grid">
                    <label class="amenity-item @(Model.HasLighting ? "checked" : "")" id="am-light">
                        <span class="amenity-icon">💡</span>
                        <input asp-for="HasLighting" type="checkbox" onchange="syncAmenity('am-light',this)" />
                        <span class="amenity-label">Đèn chiếu sáng chuyên dụng</span>
                    </label>
                    <label class="amenity-item @(Model.HasAC ? "checked" : "")" id="am-ac">
                        <span class="amenity-icon">❄️</span>
                        <input asp-for="HasAC" type="checkbox" onchange="syncAmenity('am-ac',this)" />
                        <span class="amenity-label">Điều hoà không khí</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 4. MÔ TẢ -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-chat-left-text cf-card-icon"></i>
                <span class="cf-card-title">Mô Tả Thêm</span>
            </div>
            <div class="cf-card-body">
                <div class="fg" style="margin-bottom:0;">
                    <textarea asp-for="Description" class="fg-textarea"
                              placeholder="VD: Gần cửa sổ, ánh sáng tự nhiên tốt nhất..."></textarea>
                    <div class="fg-hint">Tuỳ chọn — giúp khách chọn sân phù hợp hơn</div>
                </div>
            </div>
        </div>

        <!-- 5. HÌNH ẢNH -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-images cf-card-icon"></i>
                <span class="cf-card-title">Hình Ảnh</span>
            </div>
            <div class="cf-card-body">

                @if (Model.CourtImages != null && Model.CourtImages.Any())
                {
                    <div style="font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.6rem;">
                        Ảnh Hiện Tại — Click để chọn ảnh chính / hover để xóa
                    </div>
                    <div class="exist-imgs" id="existImgs">
                        @foreach (var img in Model.CourtImages.OrderBy(i => i.DisplayOrder))
                        {
                            <div class="exist-img @(img.IsPrimary ? "primary" : "")"
                                 id="ei-@img.ImageId"
                                 onclick="setPrimaryExist(@img.ImageId)">
                                <img src="@img.ImagePath" alt="">
                                @if (img.IsPrimary)
                                {
                                    <span class="ei-primary-badge">Chính</span>
                                }
                                <button type="button" class="ei-del"
                                        onclick="deleteExistImg(@img.ImageId, event)">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }
                    </div>
                    <input type="hidden" id="deletedImgIds" name="DeletedImageIds" value="" />
                    <input type="hidden" id="newPrimaryImgId" name="NewPrimaryImageId" value="" />
                }

                <input type="file" id="imgInput" name="CourtImages" multiple accept="image/*"
                       class="d-none" onchange="handleNewUpload(this)" />
                <div class="upload-zone" onclick="document.getElementById('imgInput').click()">
                    <i class="bi bi-plus-circle" style="font-size:1.5rem;color:var(--muted);display:block;margin-bottom:.4rem;"></i>
                    <div class="upload-text">
                        <strong>Thêm ảnh mới</strong><br>
                        <span style="font-size:.76rem;">PNG, JPG (tối đa 5MB)</span>
                    </div>
                </div>
                <div class="new-imgs" id="newImgs"></div>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="cf-actions">
            <button type="submit" class="btn-save">
                <i class="bi bi-check-circle"></i> Lưu Thay Đổi
            </button>
            <a asp-action="Details" asp-route-id="@Model.CourtId" class="btn-cancel">
                <i class="bi bi-eye"></i> Xem Chi Tiết
            </a>
            <a asp-action="Index" class="btn-cancel">
                <i class="bi bi-arrow-left"></i> Hủy
            </a>
        </div>

    </form>

    <!-- ═══════════════════════════════════════════════════════════
         6. QUẢN LÝ KHUNG GIỜ (ngoài form, dùng AJAX riêng)
    ═══════════════════════════════════════════════════════════ -->
    <div class="cf-card" style="margin-top:1.5rem;">
        <div class="cf-card-head">
            <i class="bi bi-clock cf-card-icon"></i>
            <span class="cf-card-title">Khung Giờ &amp; Giá Sân</span>
        </div>
        <div class="cf-card-body">

            <!-- Chọn ngày -->
            <div style="display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1rem;">
                @foreach (var (dayNum, dayName) in new (int, string)[]{
                                (1,"Thứ 2"),(2,"Thứ 3"),(3,"Thứ 4"),(4,"Thứ 5"),
                                (5,"Thứ 6"),(6,"Thứ 7"),(0,"CN")})
                {
                    <button type="button" class="day-tab" data-day="@dayNum"
                            onclick="loadSlots(@dayNum)">
                        @dayName
                    </button>
                }
            </div>

            <!-- Danh sách khung giờ của ngày đang chọn -->
            <div id="slotList" style="min-height:60px;">
                <div class="slot-empty">Chọn ngày để xem khung giờ</div>
            </div>

            <!-- Form thêm khung giờ mới -->
            <div style="border-top:1px solid var(--border);margin-top:1rem;padding-top:1rem;">
                <div style="font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
                            color:var(--muted);margin-bottom:.75rem;">
                    Thêm Khung Giờ Mới
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:.6rem;align-items:end;flex-wrap:wrap;">
                    <div>
                        <label class="fg-label">Từ giờ</label>
                        <input type="time" id="newStart" class="fg-input" value="06:00" step="1800" />
                    </div>
                    <div>
                        <label class="fg-label">Đến giờ</label>
                        <input type="time" id="newEnd" class="fg-input" value="07:00" step="1800" />
                    </div>
                    <div>
                        <label class="fg-label">Giá (₫)</label>
                        <input type="number" id="newPrice" class="fg-input" value="80000"
                               min="0" step="5000" placeholder="VD: 80000" />
                    </div>
                    <div>
                        <button type="button" class="btn-add-slot" onclick="addSlot()">
                            <i class="bi bi-plus-circle"></i> Thêm
                        </button>
                    </div>
                </div>
                <div id="slotMsg" style="margin-top:.6rem;font-size:.8rem;display:none;"></div>
            </div>

        </div>
    </div>

</div>

<style>
    /* ── PRICESLOT STYLES ─────────────────────────── */
    .day-tab {
        padding: .4rem .9rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .8rem;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
    }

        .day-tab:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        .day-tab.active {
            background: linear-gradient(135deg,var(--gold),var(--gold2));
            color: var(--deep);
            border-color: var(--gold);
            font-weight: 700;
        }

    .slot-row {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .55rem .75rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 7px;
        margin-bottom: .4rem;
    }

    .slot-time {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
        min-width: 110px;
        font-family: monospace;
    }

    .slot-price {
        font-size: .82rem;
        color: #16a34a;
        font-weight: 600;
        flex: 1;
    }

    .slot-inactive {
        opacity: .45;
    }

    .slot-del {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        border: 1px solid rgba(201,75,42,.3);
        background: rgba(201,75,42,.06);
        color: #c94b2a;
        cursor: pointer;
        font-size: .75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .slot-del:hover {
            background: #c94b2a;
            color: #fff;
        }

    .slot-toggle {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--muted);
        cursor: pointer;
        font-size: .75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .slot-toggle:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

    .slot-empty {
        color: var(--muted);
        font-size: .83rem;
        padding: .75rem 0;
    }

    .btn-add-slot {
        padding: .55rem 1rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-add-slot:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(212,160,23,.3);
        }

    .slot-msg-ok {
        color: #16a34a;
    }

    .slot-msg-err {
        color: #c94b2a;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Pickers
        function selectLocation(val) {
            document.querySelectorAll('.loc-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('loc-' + val)?.classList.add('selected');
            document.getElementById('courtTypeInput').value = val;
        }
        function selectSurface(val) {
            document.querySelectorAll('.surf-card').forEach(c => c.classList.remove('selected'));
            document.getElementById('surf-' + val)?.classList.add('selected');
            document.getElementById('surfaceInput').value = val;
        }
        function selectStatus(val) {
            document.querySelectorAll('.status-opt').forEach(c => c.classList.remove('selected'));
            document.getElementById('st-' + val)?.classList.add('selected');
            document.getElementById('statusInput').value = val;
        }
        function syncAmenity(id, cb) {
            document.getElementById(id).classList.toggle('checked', cb.checked);
        }

        // Existing images
        let deletedIds = [];
        function deleteExistImg(id, e) {
            e.stopPropagation();
            const el = document.getElementById('ei-' + id);
            el.classList.toggle('deleted');
            if (deletedIds.includes(id)) {
                deletedIds = deletedIds.filter(x => x !== id);
            } else {
                deletedIds.push(id);
            }
            document.getElementById('deletedImgIds').value = deletedIds.join(',');
        }
        function setPrimaryExist(id) {
            document.querySelectorAll('.exist-img').forEach(el => {
                el.classList.remove('primary');
                const badge = el.querySelector('.ei-primary-badge');
                if (badge) badge.remove();
            });
            const el = document.getElementById('ei-' + id);
            el.classList.add('primary');
            el.insertAdjacentHTML('beforeend', '<span class="ei-primary-badge">Chính</span>');
            document.getElementById('newPrimaryImgId').value = id;
        }

        // New image upload
        let newImgs = [];
        function handleNewUpload(input) {
            Array.from(input.files).forEach(file => {
                const r = new FileReader();
                r.onload = e => {
                    const i = newImgs.length;
                    newImgs.push(e.target.result);
                    const div = document.createElement('div');
                    div.className = 'ni';
                    div.id = 'ni-' + i;
                    div.innerHTML = `<img src="${e.target.result}" alt="">
                        <button type="button" class="ni-del" onclick="delNew(${i},event)">
                            <i class="bi bi-x"></i>
                        </button>`;
                    document.getElementById('newImgs').appendChild(div);
                };
                r.readAsDataURL(file);
            });
        }
        function delNew(i, e) {
            e.stopPropagation();
            newImgs[i] = null;
            document.getElementById('ni-' + i)?.remove();
        }

        // ── PRICESLOT MANAGEMENT ───────────────────────────────────
        const COURT_ID = @Model.CourtId;
        let currentDay = -1;

        // Chọn tab ngày
        function loadSlots(day) {
            currentDay = day;
            document.querySelectorAll('.day-tab').forEach(t => {
                t.classList.toggle('active', parseInt(t.dataset.day) === day);
            });
            fetchSlots(day);
        }

        // Lấy danh sách khung giờ từ server
        function fetchSlots(day) {
            document.getElementById('slotList').innerHTML =
                '<div class="slot-empty"><i class="bi bi-arrow-repeat" style="animation:spin 1s linear infinite"></i> Đang tải...</div>';

            fetch(`/AdminCourt/GetPriceSlots?courtId=${COURT_ID}`)
                .then(r => r.json())
                .then(data => {
                    if (!data.success) { renderSlots([], day); return; }
                    const daySlots = data.slots.filter(s => s.dayOfWeek === day);
                    renderSlots(daySlots, day);
                })
                .catch(() => renderSlots([], day));
        }

        // Render danh sách slot
        function renderSlots(slots, day) {
            const list = document.getElementById('slotList');
            if (!slots.length) {
                list.innerHTML = '<div class="slot-empty">Chưa có khung giờ nào cho ngày này. Hãy thêm bên dưới.</div>';
                return;
            }

            // Sắp xếp theo giờ bắt đầu
            slots.sort((a, b) => a.startTime.localeCompare(b.startTime));

            list.innerHTML = slots.map(s => `
                <div class="slot-row ${s.isActive ? '' : 'slot-inactive'}" id="slot-${s.slotId}">
                    <span class="slot-time">
                        <i class="bi bi-clock" style="font-size:.72rem;color:var(--gold);margin-right:.3rem;"></i>
                        ${s.startTime} – ${s.endTime}
                    </span>
                    <span class="slot-price">
                        ${Number(s.price).toLocaleString('vi-VN')} ₫/giờ
                    </span>
                    <span style="font-size:.7rem;color:var(--muted);">
                        ${s.isActive ? '✓ Hiện' : '✗ Ẩn'}
                    </span>
                    <button type="button" class="slot-toggle" title="${s.isActive ? 'Ẩn khung giờ' : 'Hiện khung giờ'}"
                            onclick="toggleSlot(${s.slotId})">
                        <i class="bi bi-${s.isActive ? 'eye-slash' : 'eye'}"></i>
                    </button>
                    <button type="button" class="slot-del" title="Xóa khung giờ"
                            onclick="deleteSlot(${s.slotId}, '${s.startTime}–${s.endTime}')">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>`).join('');
        }

        // ✅ THÊM KHUNG GIỜ — GỌI ENDPOINT ĐÃ SỬA LOGIC OVERLAP
        function addSlot() {
            if (currentDay < 0) {
                showMsg('Vui lòng chọn ngày trước!', false); return;
            }
            const start = document.getElementById('newStart').value;
            const end   = document.getElementById('newEnd').value;
            const price = document.getElementById('newPrice').value;

            if (!start || !end) { showMsg('Vui lòng nhập giờ bắt đầu và kết thúc!', false); return; }
            if (start >= end)   { showMsg('Giờ bắt đầu phải nhỏ hơn giờ kết thúc!', false); return; }
            if (!price || price < 0) { showMsg('Vui lòng nhập giá hợp lệ!', false); return; }

            const fd = new FormData();
            fd.append('courtId',   COURT_ID);
            fd.append('dayOfWeek', currentDay);
            fd.append('startTime', start);
            fd.append('endTime',   end);
            fd.append('price',     price);
            fd.append('isActive',  'true');
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            fetch('/AdminCourt/AddPriceSlot', { method: 'POST', body: fd })
                .then(r => r.json())
                .then(data => {
                    showMsg(data.message, data.success);
                    if (data.success) {
                        // Tự động đặt giờ bắt đầu tiếp theo = giờ kết thúc vừa thêm
                        document.getElementById('newStart').value = end;
                        const [h, m] = end.split(':').map(Number);
                        const nextEnd = String(h + 1).padStart(2,'0') + ':' + String(m).padStart(2,'0');
                        document.getElementById('newEnd').value = nextEnd;
                        fetchSlots(currentDay);
                    }
                })
                .catch(() => showMsg('Lỗi kết nối máy chủ!', false));
        }

        // Xóa khung giờ
        function deleteSlot(id, label) {
            if (!confirm(`Xóa khung giờ ${label}?`)) return;
            const fd = new FormData();
            fd.append('slotId', id);
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            fetch('/AdminCourt/DeletePriceSlot', { method:'POST', body: fd })
                .then(r => r.json())
                .then(data => {
                    showMsg(data.message, data.success);
                    if (data.success) fetchSlots(currentDay);
                })
                .catch(() => showMsg('Lỗi kết nối!', false));
        }

        // Bật/tắt hiển thị
        function toggleSlot(id) {
            const fd = new FormData();
            fd.append('slotId', id);
            fd.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');

            fetch('/AdminCourt/TogglePriceSlot', { method:'POST', body: fd })
                .then(r => r.json())
                .then(data => {
                    showMsg(data.message, data.success);
                    if (data.success) fetchSlots(currentDay);
                });
        }

        // Hiển thị thông báo
        function showMsg(msg, ok) {
            const el = document.getElementById('slotMsg');
            el.textContent = msg;
            el.className = ok ? 'slot-msg-ok' : 'slot-msg-err';
            el.style.display = 'block';
            setTimeout(() => { el.style.display = 'none'; }, 3500);
        }

        // Mặc định chọn Thứ 2 khi load trang
        document.addEventListener('DOMContentLoaded', () => loadSlots(1));
        // ── END PRICESLOT ──────────────────────────────────────────
    </script>
}
