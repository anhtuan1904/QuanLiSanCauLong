@model QuanLiSanCauLong.Models.Court
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-sub {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
        max-height: calc(85vh - 130px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .mbody::-webkit-scrollbar {
            width: 5px;
        }

        .mbody::-webkit-scrollbar-track {
            background: var(--warm);
            border-radius: 3px;
        }

        .mbody::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

            .mbody::-webkit-scrollbar-thumb:hover {
                background: var(--gold2);
            }

    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-req {
        color: #c94b2a;
        margin-left: .15rem;
    }

    .fg-input, .fg-select, .fg-textarea {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.08);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 70px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    /* Location/Surface/Status cards */
    .location-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
    }

    .loc-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .7rem .9rem;
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: .7rem;
    }

        .loc-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .loc-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .loc-icon {
        width: 34px;
        height: 34px;
        border-radius: 7px;
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .loc-card.selected .loc-icon {
        background: rgba(212,160,23,.15);
    }

    .loc-name {
        font-weight: 700;
        font-size: .82rem;
        color: var(--deep);
    }

    .loc-desc {
        font-size: .68rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .surface-cards {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .6rem;
    }

    .surf-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .65rem .7rem;
        cursor: pointer;
        transition: all .2s;
        text-align: center;
    }

        .surf-card:hover {
            border-color: rgba(212,160,23,.5);
        }

        .surf-card.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .surf-icon {
        font-size: 1.3rem;
        margin-bottom: .25rem;
    }

    .surf-name {
        font-size: .76rem;
        font-weight: 700;
        color: var(--deep);
    }

    .surf-sub {
        font-size: .64rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    .status-opts {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .status-text {
        font-size: .8rem;
        font-weight: 600;
        color: var(--deep);
    }

    .amenity-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
    }

    .amenity-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .6rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

        .amenity-item:hover {
            border-color: rgba(212,160,23,.4);
        }

        .amenity-item.checked {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .amenity-item input[type=checkbox] {
            width: 15px;
            height: 15px;
            accent-color: var(--gold);
            cursor: pointer;
        }

    .amenity-label {
        font-size: .82rem;
        color: var(--deep);
        font-weight: 500;
        cursor: pointer;
        user-select: none;
    }

    /* Upload */
    .upload-zone {
        border: 1.5px dashed var(--border);
        border-radius: 8px;
        padding: .9rem;
        background: var(--cream);
        cursor: pointer;
        transition: border-color .2s;
        text-align: center;
    }

        .upload-zone:hover {
            border-color: var(--gold);
        }

    .img-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(78px,1fr));
        gap: .5rem;
        margin-top: .6rem;
    }

    .img-item {
        position: relative;
        aspect-ratio: 1;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid var(--border);
        cursor: pointer;
    }

        .img-item.primary {
            border-color: var(--gold);
            border-width: 2.5px;
        }

        .img-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .img-primary-badge {
        position: absolute;
        bottom: 3px;
        left: 3px;
        background: var(--gold);
        color: var(--deep);
        font-size: .55rem;
        font-weight: 800;
        padding: .1rem .4rem;
        border-radius: 3px;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .img-del {
        position: absolute;
        top: 3px;
        right: 3px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background: rgba(201,75,42,.9);
        color: #fff;
        border: none;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: .6rem;
    }

    .img-item:hover .img-del {
        display: flex;
    }

    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-save:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Quản Lý Sân</div>
        <div class="mh-title">Thêm Sân Mới</div>
        <div class="mh-sub">Điền thông tin chi tiết cho sân cầu lông</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="mbody">
    <form id="createCourtForm" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- 1. Cơ sở -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-building sf-card-icon"></i>
                <span class="sf-card-title">Thuộc Cơ Sở</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="fg">
                    <label class="fg-label">Cơ Sở <span class="fg-req">*</span></label>
                    <select asp-for="FacilityId" class="fg-select" id="facilitySelectC">
                        <option value="">— Chọn cơ sở —</option>
                        @foreach (var f in (IEnumerable<QuanLiSanCauLong.Models.Facility>)ViewBag.Facilities)
                        {
                            <option value="@f.FacilityId">@f.FacilityName</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- 2. Thông tin sân -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-card-text sf-card-icon"></i>
                <span class="sf-card-title">Thông Tin Sân</span>
            </div>
            <div class="sf-card-body">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:.75rem;">
                    <div class="fg">
                        <label class="fg-label">Tên / Số Sân <span class="fg-req">*</span></label>
                        <input asp-for="CourtNumber" class="fg-input" placeholder="VD: Sân số 1" />
                    </div>
                    <div class="fg">
                        <label class="fg-label">Vị Trí Tầng</label>
                        <input asp-for="FloorNumber" class="fg-input" placeholder="VD: Tầng 1" />
                    </div>
                </div>

                <!-- Vị trí -->
                <div class="fg">
                    <label class="fg-label">Vị Trí <span class="fg-req">*</span></label>
                    <input asp-for="CourtType" type="hidden" id="courtTypeInputC" />
                    <div class="location-cards">
                        <div class="loc-card" id="locC-Indoor" onclick="selectLocationC('Indoor')">
                            <div class="loc-icon">🏠</div>
                            <div><div class="loc-name">Trong Nhà</div><div class="loc-desc">Có mái che</div></div>
                        </div>
                        <div class="loc-card" id="locC-Outdoor" onclick="selectLocationC('Outdoor')">
                            <div class="loc-icon">☀️</div>
                            <div><div class="loc-name">Ngoài Trời</div><div class="loc-desc">Lộ thiên</div></div>
                        </div>
                    </div>
                </div>

                <!-- Mặt sân -->
                <div class="fg">
                    <label class="fg-label">Loại Mặt Sân <span class="fg-req">*</span></label>
                    <input asp-for="SurfaceType" type="hidden" id="surfaceInputC" />
                    <div class="surface-cards">
                        <div class="surf-card" id="surfC-PVC" onclick="selectSurfaceC('PVC')">
                            <div class="surf-icon">🟨</div><div class="surf-name">Thảm PVC</div>
                            <div class="surf-sub">Cao su tổng hợp</div>
                        </div>
                        <div class="surf-card" id="surfC-Wood" onclick="selectSurfaceC('Wood')">
                            <div class="surf-icon">🪵</div><div class="surf-name">Sàn Gỗ</div>
                            <div class="surf-sub">Chuyên nghiệp</div>
                        </div>
                        <div class="surf-card" id="surfC-Silicon" onclick="selectSurfaceC('Silicon')">
                            <div class="surf-icon">🎨</div><div class="surf-name">Sơn Silicon</div>
                            <div class="surf-sub">Độ bám tốt</div>
                        </div>
                    </div>
                </div>

                <!-- Tình trạng -->
                <div class="fg">
                    <label class="fg-label">Tình Trạng <span class="fg-req">*</span></label>
                    <input asp-for="Status" type="hidden" id="statusInputC" value="Available" />
                    <div class="status-opts">
                        <div class="status-opt selected" id="stC-Available" onclick="selectStatusC('Available')">
                            <span class="status-dot" style="background:#16a34a;"></span>
                            <span class="status-text">Đang Trống</span>
                        </div>
                        <div class="status-opt" id="stC-Active" onclick="selectStatusC('Active')">
                            <span class="status-dot" style="background:var(--gold);"></span>
                            <span class="status-text">Hoạt Động</span>
                        </div>
                        <div class="status-opt" id="stC-Maintenance" onclick="selectStatusC('Maintenance')">
                            <span class="status-dot" style="background:#c94b2a;"></span>
                            <span class="status-text">Bảo Trì</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. Tiện ích -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-lightning-charge sf-card-icon"></i>
                <span class="sf-card-title">Tiện Ích Sân</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="amenity-grid">
                    <label class="amenity-item" id="amC-light">
                        <span>💡</span>
                        <input asp-for="HasLighting" type="checkbox" onchange="document.getElementById('amC-light').classList.toggle('checked',this.checked)" />
                        <span class="amenity-label">Đèn chiếu sáng</span>
                    </label>
                    <label class="amenity-item" id="amC-ac">
                        <span>❄️</span>
                        <input asp-for="HasAC" type="checkbox" onchange="document.getElementById('amC-ac').classList.toggle('checked',this.checked)" />
                        <span class="amenity-label">Điều hoà</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 4. Mô tả -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-chat-left-text sf-card-icon"></i>
                <span class="sf-card-title">Mô Tả</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="fg">
                    <textarea asp-for="Description" class="fg-textarea"
                              placeholder="VD: Gần cửa sổ, ánh sáng tự nhiên tốt nhất..."></textarea>
                    <div class="fg-hint">Tuỳ chọn — giúp khách chọn sân phù hợp hơn</div>
                </div>
            </div>
        </div>

        <!-- 5. Hình ảnh -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-images sf-card-icon"></i>
                <span class="sf-card-title">Hình Ảnh</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <input type="file" id="imgInputC" name="CourtImages" multiple accept="image/*" style="display:none;" />
                <div class="upload-zone" onclick="document.getElementById('imgInputC').click()">
                    <i class="bi bi-plus-circle" style="font-size:1.3rem;color:var(--muted);display:block;margin-bottom:.25rem;"></i>
                    <div style="font-size:.82rem;color:var(--muted);">
                        <strong>Click để tải ảnh</strong><br>
                        <span style="font-size:.72rem;">PNG, JPG (tối đa 5MB)</span>
                    </div>
                </div>
                <div class="img-grid" id="imgGridC"></div>
                <input type="hidden" id="primaryImgIdxC" name="PrimaryImageIndex" value="0" />
            </div>
        </div>

    </form>
</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="submit" form="createCourtForm" class="btn-save" id="btnCreateSubmit">
        <i class="bi bi-check-circle"></i> Thêm Sân
    </button>
</div>

<script>
    (function() {
        // Pickers
        window.selectLocationC = function(val) {
            document.querySelectorAll('#locC-Indoor,#locC-Outdoor').forEach(c => c.classList.remove('selected'));
            document.getElementById('locC-' + val)?.classList.add('selected');
            document.getElementById('courtTypeInputC').value = val;
        };
        window.selectSurfaceC = function(val) {
            document.querySelectorAll('#surfC-PVC,#surfC-Wood,#surfC-Silicon').forEach(c => c.classList.remove('selected'));
            document.getElementById('surfC-' + val)?.classList.add('selected');
            document.getElementById('surfaceInputC').value = val;
        };
        window.selectStatusC = function(val) {
            document.querySelectorAll('#stC-Available,#stC-Active,#stC-Maintenance').forEach(c => c.classList.remove('selected'));
            document.getElementById('stC-' + val)?.classList.add('selected');
            document.getElementById('statusInputC').value = val;
        };

        // Image upload
        let imgsC = [], primaryIdxC = 0;
        const imgInputC = document.getElementById('imgInputC');
        imgInputC.addEventListener('change', function() {
            Array.from(this.files).forEach(file => {
                const r = new FileReader();
                r.onload = e => { imgsC.push(e.target.result); renderGridC(); };
                r.readAsDataURL(file);
            });
        });

        function renderGridC() {
            const grid = document.getElementById('imgGridC');
            grid.innerHTML = '';
            imgsC.forEach((src, i) => {
                if (!src) return;
                const div = document.createElement('div');
                div.className = 'img-item' + (i === primaryIdxC ? ' primary' : '');
                div.innerHTML = `<img src="${src}" alt="">
                    ${i === primaryIdxC ? '<span class="img-primary-badge">Chính</span>' : ''}
                    <button type="button" class="img-del" onclick="event.stopPropagation();window._delImgC(${i})">
                        <i class="bi bi-x"></i></button>`;
                div.onclick = () => { primaryIdxC = i; document.getElementById('primaryImgIdxC').value = i; renderGridC(); };
                grid.appendChild(div);
            });
        }
        window._delImgC = function(i) {
            imgsC.splice(i, 1);
            if (primaryIdxC >= imgsC.length) primaryIdxC = 0;
            renderGridC();
        };

        // AJAX submit
        document.getElementById('createCourtForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('btnCreateSubmit');
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';
            try {
                const r = await fetch(this.action, { method:'POST', body: new FormData(this), redirect:'follow' });
                const ct = r.headers.get('content-type') || '';
                if (ct.includes('application/json')) {
                    const res = await r.json();
                    if (res.success) { alert(res.message || 'Thêm sân thành công!'); window.location.reload(); }
                    else alert('Lỗi: ' + (res.message || 'Dữ liệu không hợp lệ'));
                } else {
                    // Server trả về HTML (redirect hoặc View) → coi như thành công
                    if (r.ok || r.redirected) {
                        alert('Thêm sân thành công!');
                        window.location.reload();
                    } else {
                        alert('Lỗi server! Mã: ' + r.status);
                    }
                }
            } catch(err) { alert('Lỗi hệ thống: ' + err.message); }
            finally { btn.disabled = false; btn.innerHTML = orig; }
        });
    })();
</script>
