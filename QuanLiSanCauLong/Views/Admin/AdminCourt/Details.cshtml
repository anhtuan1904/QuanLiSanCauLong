@model QuanLiSanCauLong.Models.Court
@{
    ViewData["Title"] = Model.CourtNumber + " – " + Model.Facility?.FacilityName;

    // Tập hợp tất cả ảnh: ảnh sân trước, rồi ảnh cơ sở
    var courtImgs = (Model.CourtImages?.OrderBy(i => i.IsPrimary ? 0 : 1).ThenBy(i => i.DisplayOrder).ToList())
                     ?? new List<CourtImage>();
    var facImgs = (Model.Facility?.FacilityImages?.ToList()) ?? new List<FacilityImage>();
    // Dùng ảnh sân nếu có, ngược lại dùng ảnh cơ sở
    var allImgs = courtImgs.Any()
                        ? courtImgs.Select(i => i.ImagePath).ToList()
                        : facImgs.Select(i => i.ImagePath).ToList();
    if (!allImgs.Any() && !string.IsNullOrEmpty(Model.ImagePath))
        allImgs.Add(Model.ImagePath);

    var bookDate = ViewBag.BookingDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var startTime = ViewBag.StartTime as string ?? "";
    var endTime = ViewBag.EndTime as string ?? "";
}

<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --D3: #2e2010;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.10);
        --G4: rgba(212,160,23,.18);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
        --M: rgba(255,255,255,.38);
        --M2: rgba(255,255,255,.08);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        background: var(--W);
        margin: 0;
        font-family: 'Outfit', sans-serif;
    }

    /* ── BREADCRUMB ─────────────────────────────────────────── */
    .bc {
        background: var(--D);
        padding: .75rem 2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        border-bottom: 1px solid var(--G4);
    }

        .bc a {
            color: var(--G2);
            text-decoration: none;
            font-size: .78rem;
            font-weight: 600;
            opacity: .8;
            display: flex;
            align-items: center;
            gap: .35rem;
        }

            .bc a:hover {
                opacity: 1;
            }

    .bc-sep {
        color: var(--M);
        font-size: .65rem;
    }

    .bc-cur {
        color: var(--M);
        font-size: .78rem;
        font-style: italic;
    }

    /* ── HERO ───────────────────────────────────────────────── */
    .hero {
        background: var(--D);
        position: relative;
        overflow: hidden;
    }

        .hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 55% 90% at 72% 50%,rgba(212,160,23,.07),transparent 65%);
            pointer-events: none;
        }

    .hero-wrap {
        max-width: 1300px;
        margin: 0 auto;
        padding: 2.4rem 2rem;
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 2.5rem;
        align-items: start;
        position: relative;
        z-index: 1;
    }

    /* Carousel */
    .gallery {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--G4);
    }

        .gallery .carousel-item img {
            height: 420px;
            object-fit: cover;
            filter: brightness(.88);
        }

        .gallery .carousel-control-prev, .gallery .carousel-control-next {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(26,18,9,.72);
            border: 1px solid var(--G4);
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity .25s;
        }

        .gallery:hover .carousel-control-prev,
        .gallery:hover .carousel-control-next {
            opacity: 1;
        }

        .gallery .carousel-control-prev {
            left: 10px;
        }

        .gallery .carousel-control-next {
            right: 10px;
        }

    .carousel-indicators [data-bs-target] {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--G);
        border: 0;
        opacity: .45;
    }

    .carousel-indicators .active {
        opacity: 1;
    }

    /* Thumb strip */
    .thumbs {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
        overflow-x: auto;
        padding-bottom: .3rem;
    }

        .thumbs img {
            width: 64px;
            height: 48px;
            object-fit: cover;
            border-radius: 6px;
            border: 2px solid transparent;
            cursor: pointer;
            flex-shrink: 0;
            transition: border-color .2s;
        }

            .thumbs img.act {
                border-color: var(--G2);
            }

    /* Info panel */
    .iblock {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .i-pills {
        display: flex;
        gap: .5rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .pill {
        padding: .24rem .72rem;
        border-radius: 3px;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
    }

    .pill-type {
        background: var(--R);
        color: #fff;
    }

    .pill-open {
        background: rgba(16,185,129,.12);
        color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .pill-maint {
        background: rgba(201,75,42,.12);
        color: #ef8c72;
        border: 1px solid rgba(201,75,42,.2);
    }

    .i-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.5rem,2.5vw,2.2rem);
        font-weight: 700;
        color: #fff;
        margin: 0;
        line-height: 1.15;
    }

    .i-sub {
        font-size: .84rem;
        color: var(--M);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .i-sub i {
            color: var(--G);
        }

    /* Stats grid */
    .stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1px;
        background: var(--G4);
        border: 1px solid var(--G4);
        border-radius: 8px;
        overflow: hidden;
    }

    .stat {
        background: var(--D2);
        padding: .9rem .6rem;
        text-align: center;
        transition: background .18s;
    }

        .stat:hover {
            background: var(--G3);
        }

    .sv {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--G2);
        line-height: 1;
        margin-bottom: .28rem;
    }

    .sl {
        font-size: .56rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--M);
    }

    /* Tags */
    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .27rem .78rem;
        background: var(--M2);
        border: 1px solid var(--G4);
        border-radius: 4px;
        color: rgba(255,255,255,.65);
        font-size: .72rem;
        font-weight: 500;
        transition: all .2s;
    }

        .tag i {
            color: var(--G);
        }

        .tag:hover {
            background: var(--G3);
            border-color: var(--G);
            color: var(--G2);
        }

    /* CTA box */
    .cta-box {
        background: var(--D2);
        border: 1px solid var(--G4);
        border-radius: 10px;
        padding: 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: .4rem;
    }

    .cta-price {
        font-family: 'Outfit',sans-serif;
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--G2);
        line-height: 1;
    }

        .cta-price span {
            font-size: .8rem;
            color: var(--M);
            font-weight: 400;
        }

    .btn-book-main {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
        font-family: 'Outfit',sans-serif;
        font-size: .95rem;
        font-weight: 800;
        letter-spacing: .03em;
        padding: .9rem 1.6rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all .22s;
        text-decoration: none;
        width: 100%;
        text-align: center;
    }

        .btn-book-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(212,160,23,.4);
            filter: brightness(1.05);
            color: var(--D);
        }

    .btn-back {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        background: var(--M2);
        color: rgba(255,255,255,.65);
        border: 1px solid var(--G4);
        border-radius: 8px;
        padding: .6rem 1rem;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
    }

        .btn-back:hover {
            background: var(--G3);
            border-color: var(--G);
            color: var(--G2);
        }

    /* ── CONTENT SECTION ────────────────────────────────────── */
    .content-wrap {
        max-width: 1300px;
        margin: 0 auto;
        padding: 2.5rem 2rem 4rem;
    }

    /* Article-style rich content area */
    .rich-section {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 12px;
        padding: 2.2rem 2.5rem;
        margin-bottom: 1.8rem;
    }

    .sec-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--D);
        margin: 0 0 1.4rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .sec-title i {
            color: var(--G);
        }

        .sec-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg,var(--S),transparent);
            margin-left: .8rem;
        }

    /* Mô tả dạng bài viết (HTML-safe) */
    .article-body {
        font-size: .93rem;
        line-height: 1.9;
        color: #4a3828;
    }

        .article-body h2 {
            font-family: 'Playfair Display',serif;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--D);
            margin: 1.6rem 0 .6rem;
        }

        .article-body h3 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--D);
            margin: 1.3rem 0 .5rem;
        }

        .article-body p {
            margin: 0 0 1rem;
        }

        .article-body img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 1.2rem 0;
            border: 1px solid var(--S);
            display: block;
        }

        .article-body figure {
            margin: 1.5rem 0;
            text-align: center;
        }

            .article-body figure img {
                margin: 0 auto .5rem;
            }

        .article-body figcaption {
            font-size: .78rem;
            color: #8c7a68;
            font-style: italic;
        }

        .article-body blockquote {
            border-left: 3px solid var(--G);
            padding: .8rem 1.2rem;
            background: #fdf8f0;
            border-radius: 0 6px 6px 0;
            margin: 1.2rem 0;
            color: #6b5040;
            font-style: italic;
        }

        .article-body ul, .article-body ol {
            padding-left: 1.4rem;
            margin: 0 0 1rem;
        }

        .article-body li {
            margin-bottom: .4rem;
        }

    /* Info grid */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
        gap: 1.2rem;
    }

    .info-item {
        display: flex;
        align-items: flex-start;
        gap: .75rem;
        padding: 1rem 1.2rem;
        background: #fdf8f0;
        border: 1px solid var(--S);
        border-radius: 8px;
    }

    .info-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: linear-gradient(135deg,var(--G),var(--G2));
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .info-icon i {
            color: var(--D);
            font-size: .9rem;
        }

    .info-lbl {
        font-size: .68rem;
        color: #8c7a68;
        font-weight: 600;
        letter-spacing: .05em;
        text-transform: uppercase;
        margin-bottom: .2rem;
    }

    .info-val {
        font-size: .92rem;
        font-weight: 700;
        color: var(--D);
    }

    /* Facility chips */
    .fac-info {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
        margin-bottom: 1.2rem;
    }

    .fac-img {
        width: 72px;
        height: 72px;
        border-radius: 8px;
        object-fit: cover;
        border: 2px solid var(--G4);
        flex-shrink: 0;
    }

    .fac-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--D);
        margin-bottom: .25rem;
    }

    .fac-addr {
        font-size: .8rem;
        color: #6b5040;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .fac-addr i {
            color: var(--R);
        }

    /* Responsive */
    @@media(max-width:1100px) {
        .hero-wrap {
            grid-template-columns: 1fr;
        }

        .gallery .carousel-item img {
            height: 300px;
        }

        .stats {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media(max-width:768px) {
        .hero-wrap, .content-wrap, .bc {
            padding-left: 1.2rem;
            padding-right: 1.2rem;
        }

        .rich-section {
            padding: 1.4rem 1.2rem;
        }

        .info-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<!-- BREADCRUMB -->
<div class="bc">
    <a href="@Url.Action("Index", "Facility")"><i class="bi bi-house"></i> Trang chủ</a>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <a href="@Url.Action("Details", "Facility", new { id = Model.FacilityId })">@Model.Facility?.FacilityName</a>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <span class="bc-cur">@Model.CourtNumber</span>
</div>

<!-- HERO -->
<div class="hero">
    <div class="hero-wrap">
        <!-- Gallery -->
        <div>
            <div id="courtCarousel" class="carousel slide gallery" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    @for (int i = 0; i < allImgs.Count; i++)
                    {
                        <button type="button" data-bs-target="#courtCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                    }
                </div>
                <div class="carousel-inner">
                    @if (allImgs.Any())
                    {
                        for (int i = 0; i < allImgs.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@allImgs[i]" class="d-block w-100" alt="@Model.CourtNumber" />
                            </div>
                        }
                    }
                    else
                    {
                        <div class="carousel-item active">
                            <img src="/images/placeholder-court.jpg" class="d-block w-100" alt="Chưa có ảnh" />
                        </div>
                    }
                </div>
                @if (allImgs.Count > 1)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#courtCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
                    <button class="carousel-control-next" type="button" data-bs-target="#courtCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
                }
            </div>
            <!-- Thumbnail strip -->
            @if (allImgs.Count > 1)
            {
                <div class="thumbs" id="thumbStrip">
                    @for (int i = 0; i < allImgs.Count; i++)
                    {
                        <img src="@allImgs[i]" class="@(i == 0 ? "act" : "")" data-idx="@i" onclick="goSlide(@i)" alt="thumb @i" />
                    }
                </div>
            }
        </div>

        <!-- Info + CTA -->
        <div class="iblock">
            <div class="i-pills">
                <div class="pill pill-type">
                    @(Model.CourtType == "Indoor" ? "Trong nhà" : "Ngoài trời")
                </div>
                @if (Model.Status == "Maintenance")
                {
                    <div class="pill pill-maint"><i class="bi bi-tools"></i> Đang bảo trì</div>
                }
                else
                {
                    <div class="pill pill-open"><i class="bi bi-circle-fill" style="font-size:.38rem"></i> Sẵn sàng</div>
                }
            </div>

            <h1 class="i-title">@Model.CourtNumber</h1>
            <div class="i-sub"><i class="bi bi-building"></i> @Model.Facility?.FacilityName</div>
            @if (!string.IsNullOrEmpty(Model.Facility?.Address))
            {
                <div class="i-sub"><i class="bi bi-geo-alt-fill" style="color:var(--R)"></i> @Model.Facility!.Address@(!string.IsNullOrEmpty(Model.Facility.District) ? ", " + Model.Facility.District : "")@(!string.IsNullOrEmpty(Model.Facility.City) ? ", " + Model.Facility.City : "")</div>
            }

            <div class="stats">
                <div class="stat">
                    <div class="sv">@Model.SurfaceTypeLabel</div>
                    <div class="sl">Mặt sân</div>
                </div>
                <div class="stat">
                    <div class="sv">@(Model.HasLighting ? "Có" : "Không")</div>
                    <div class="sl">Đèn chiếu sáng</div>
                </div>
                <div class="stat">
                    <div class="sv">@(Model.HasAC ? "Có" : "Không")</div>
                    <div class="sl">Điều hoà</div>
                </div>
            </div>

            <div class="tags">
                <div class="tag"><i class="bi bi-layers"></i> @Model.CourtTypeLabel</div>
                <div class="tag"><i class="bi bi-grid-3x3"></i> @Model.SurfaceTypeLabel</div>
                @if (!string.IsNullOrEmpty(Model.FloorNumber))
                {
                    <div class="tag"><i class="bi bi-building-up"></i> @Model.FloorNumber</div>
                }
                @if (Model.HasLighting)
                {
                    <div class="tag"><i class="bi bi-lightbulb-fill"></i> Đèn chiếu sáng</div>
                }
                @if (Model.HasAC)
                {
                    <div class="tag"><i class="bi bi-wind"></i> Điều hoà</div>
                }
            </div>

            <!-- CTA Box -->
            <div class="cta-box">
                @if (Model.HourlyRate.HasValue && Model.HourlyRate > 0)
                {
                    <div>
                        <div class="cta-price">
                            @Model.HourlyRate.Value.ToString("N0")đ <span>/ giờ</span>
                        </div>
                        <div style="font-size:.72rem;color:var(--M);margin-top:.3rem">Giá có thể thay đổi theo khung giờ</div>
                    </div>
                }

                @if (Model.Status == "Maintenance")
                {
                    <button class="btn-book-main" disabled style="opacity:.5;cursor:not-allowed">
                        <i class="bi bi-tools"></i> Sân đang bảo trì
                    </button>
                }
                else
                {
                    // Nếu đã chọn slot ở facility page, truyền thẳng vào Booking/Create
                    string bookUrl;
                    if (!string.IsNullOrEmpty(startTime))
                    {
                        bookUrl = Url.Action("Create", "Booking", new { courtId = Model.CourtId, bookingDate = bookDate, startTime, endTime })!;
                    }
                    else
                    {
                        // Quay lại facility để chọn slot
                        bookUrl = Url.Action("Details", "Facility", new { id = Model.FacilityId })!;
                    }
                    <a href="@bookUrl" class="btn-book-main">
                        <i class="bi bi-calendar-check-fill"></i>
                        @(string.IsNullOrEmpty(startTime) ? "Chọn khung giờ & Đặt sân" : "Xác nhận đặt sân")
                    </a>
                }
                <a href="@Url.Action("Details", "Facility", new { id = Model.FacilityId })" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Quay lại cơ sở
                </a>
            </div>
        </div>
    </div>
</div>

<!-- CONTENT SECTION -->
<div class="content-wrap">

    <!-- ── Thông tin chi tiết ── -->
    <div class="rich-section">
        <h2 class="sec-title"><i class="bi bi-info-circle-fill"></i> Thông tin sân</h2>
        <div class="info-grid">
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                <div>
                    <div class="info-lbl">Tên sân</div>
                    <div class="info-val">@Model.CourtNumber</div>
                </div>
            </div>
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-house-door-fill"></i></div>
                <div>
                    <div class="info-lbl">Vị trí</div>
                    <div class="info-val">@Model.CourtTypeLabel</div>
                </div>
            </div>
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-layers-fill"></i></div>
                <div>
                    <div class="info-lbl">Loại mặt sân</div>
                    <div class="info-val">@Model.SurfaceTypeLabel</div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.FloorNumber))
            {
                <div class="info-item">
                    <div class="info-icon"><i class="bi bi-building"></i></div>
                    <div>
                        <div class="info-lbl">Vị trí tầng</div>
                        <div class="info-val">@Model.FloorNumber</div>
                    </div>
                </div>
            }
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-lightbulb-fill"></i></div>
                <div>
                    <div class="info-lbl">Đèn chiếu sáng</div>
                    <div class="info-val">@(Model.HasLighting ? "✔ Có đèn chiếu sáng" : "Không có")</div>
                </div>
            </div>
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-wind"></i></div>
                <div>
                    <div class="info-lbl">Điều hoà</div>
                    <div class="info-val">@(Model.HasAC ? "✔ Có điều hoà" : "Không có")</div>
                </div>
            </div>
            @if (Model.HourlyRate.HasValue && Model.HourlyRate > 0)
            {
                <div class="info-item">
                    <div class="info-icon"><i class="bi bi-tag-fill"></i></div>
                    <div>
                        <div class="info-lbl">Giá thuê</div>
                        <div class="info-val">@Model.HourlyRate.Value.ToString("N0") đ/giờ</div>
                    </div>
                </div>
            }
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-check2-circle"></i></div>
                <div>
                    <div class="info-lbl">Tình trạng</div>
                    <div class="info-val">@Model.StatusLabel</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Mô tả chi tiết dạng bài viết (hỗ trợ HTML / văn bản + ảnh) ── -->
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <div class="rich-section">
            <h2 class="sec-title"><i class="bi bi-file-text-fill"></i> Mô tả sân</h2>
            <div class="article-body">
                @* Nếu Description chứa HTML (thẻ <p>, <img>, <h2>...) sẽ render đúng *@
                @Html.Raw(Model.Description)
            </div>
        </div>
    }

    <!-- ── Thông tin cơ sở ── -->
    @if (Model.Facility != null)
    {
        <div class="rich-section">
            <h2 class="sec-title"><i class="bi bi-building-fill"></i> Thông tin cơ sở</h2>

            <div class="fac-info">
                @{
                    var facPrimary = Model.Facility.FacilityImages?.FirstOrDefault(i => i.IsPrimary)?.ImagePath
                    ?? Model.Facility.FacilityImages?.FirstOrDefault()?.ImagePath
                    ?? Model.Facility.ImageUrl;
                }
                @if (!string.IsNullOrEmpty(facPrimary))
                {
                    <img src="@facPrimary" class="fac-img" alt="@Model.Facility.FacilityName" />
                }
                <div>
                    <div class="fac-name">@Model.Facility.FacilityName</div>
                    @if (!string.IsNullOrEmpty(Model.Facility.Address))
                    {
                        <div class="fac-addr">
                            <i class="bi bi-geo-alt-fill"></i>
                            @Model.Facility.Address@(!string.IsNullOrEmpty(Model.Facility.District) ? ", " + Model.Facility.District : "")@(!string.IsNullOrEmpty(Model.Facility.City) ? ", " + Model.Facility.City : "")
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Facility.Phone))
                    {
                        <div class="fac-addr" style="margin-top:.3rem">
                            <i class="bi bi-telephone-fill"></i> @Model.Facility.Phone
                        </div>
                    }
                    @if (Model.Facility.OpenTime.HasValue)
                    {
                        <div class="fac-addr" style="margin-top:.3rem">
                            <i class="bi bi-clock-fill" style="color:var(--G)"></i>
                            @Model.Facility.OpenTime.Value.ToString(@"hh\:mm") – @Model.Facility.CloseTime?.ToString(@"hh\:mm")
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Facility.Description))
            {
                <div class="article-body" style="margin-top:.5rem">
                    @Html.Raw(Model.Facility.Description)
                </div>
            }
        </div>
    }

    <!-- ── Nút hành động cuối trang ── -->
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1rem">
        <a href="@Url.Action("Details", "Facility", new { id = Model.FacilityId })" class="btn-back" style="padding:.75rem 1.8rem;font-size:.86rem">
            <i class="bi bi-arrow-left"></i> Quay lại chọn sân
        </a>
        @if (Model.Status != "Maintenance")
        {
            string bookUrlBottom = string.IsNullOrEmpty(startTime)
            ? Url.Action("Details", "Facility", new { id = Model.FacilityId })!
            : Url.Action("Create", "Booking", new { courtId = Model.CourtId, bookingDate = bookDate, startTime, endTime })!;
            <a href="@bookUrlBottom" class="btn-book-main" style="max-width:320px">
                <i class="bi bi-calendar-check-fill"></i>
                @(string.IsNullOrEmpty(startTime) ? "Chọn khung giờ & Đặt sân" : "Xác nhận đặt sân")
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Carousel + thumb sync
        var carousel = document.getElementById('courtCarousel');
        if (carousel) {
            carousel.addEventListener('slid.bs.carousel', function(e) {
                document.querySelectorAll('#thumbStrip img').forEach(function(t, idx) {
                    t.classList.toggle('act', idx === e.to);
                });
            });
            new bootstrap.Carousel(carousel, { interval: 4000, wrap: true });
        }

        function goSlide(idx) {
            var c = bootstrap.Carousel.getOrCreateInstance(document.getElementById('courtCarousel'));
            c.to(idx);
        }
    </script>
}
