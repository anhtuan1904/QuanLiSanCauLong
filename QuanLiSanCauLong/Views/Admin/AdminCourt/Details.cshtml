@model QuanLiSanCauLong.Models.Court
@{
    Layout = null;

    var primaryImg = Model.CourtImages?.FirstOrDefault(i => i.IsPrimary)
                   ?? Model.CourtImages?.OrderBy(i => i.DisplayOrder).FirstOrDefault();
    var allImages = Model.CourtImages?.OrderBy(i => i.DisplayOrder).ToList()
                   ?? new List<QuanLiSanCauLong.Models.CourtImage>();

    var statusColor = Model.Status switch {
        "Available"   => "#16a34a",
        "Active"      => "#d4a017",
        "Maintenance" => "#c94b2a",
        _ => "#8a7560"
    };
    var statusBg = Model.Status switch {
        "Available"   => "rgba(22,163,74,.08)",
        "Active"      => "rgba(212,160,23,.1)",
        "Maintenance" => "rgba(201,75,42,.08)",
        _ => "rgba(138,117,96,.1)"
    };

    var slotsByDay = Model.PriceSlots?
        .Where(ps => ps.IsActive)
        .GroupBy(ps => ps.DayOfWeek)
        .OrderBy(g => g.Key)
        .ToList();

    string DayName(DayOfWeek? d) => d switch {
        DayOfWeek.Sunday    => "CN",
        DayOfWeek.Monday    => "T2",
        DayOfWeek.Tuesday   => "T3",
        DayOfWeek.Wednesday => "T4",
        DayOfWeek.Thursday  => "T5",
        DayOfWeek.Friday    => "T6",
        DayOfWeek.Saturday  => "T7",
        _ => "Tất cả"
    };
}

<style>
:root {
    --deep:#1a1209; --gold:#d4a017; --gold2:#f5c842;
    --cream:#fdf8f0; --warm:#f5ede0; --border:#e8ddd0; --muted:#8a7560;
}

.mh { display:flex; align-items:flex-start; justify-content:space-between;
    padding:1.4rem 1.5rem 0; gap:1rem; }
.mh-label { font-size:.65rem; letter-spacing:.18em; text-transform:uppercase;
    color:var(--gold); font-weight:700; margin-bottom:.3rem;
    display:flex; align-items:center; gap:.5rem; }
.mh-label::before { content:''; width:12px; height:1px; background:var(--gold); }
.mh-title { font-family:'Playfair Display',serif; font-size:1.35rem; font-weight:700; color:var(--deep); }
.mh-sub { font-size:.78rem; color:var(--muted); margin-top:.15rem; }
.mh-close { width:32px; height:32px; border:1px solid var(--border); border-radius:6px;
    background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center;
    color:var(--muted); font-size:.85rem; transition:all .15s; flex-shrink:0; }
.mh-close:hover { background:var(--deep); color:var(--gold2); border-color:var(--deep); }

.mbody { padding:1.25rem 1.5rem; max-height:calc(85vh - 130px);
    overflow-y:auto; overflow-x:hidden; }
.mbody::-webkit-scrollbar { width:5px; }
.mbody::-webkit-scrollbar-track { background:var(--warm); border-radius:3px; }
.mbody::-webkit-scrollbar-thumb { background:var(--gold); border-radius:3px; }
.mbody::-webkit-scrollbar-thumb:hover { background:var(--gold2); }

.sf-card { background:#fff; border:1px solid var(--border); border-radius:10px;
    margin-bottom:.9rem; overflow:hidden; }
.sf-card-head { padding:.7rem 1rem; background:var(--warm); display:flex;
    align-items:center; gap:.5rem; border-bottom:1px solid var(--border); }
.sf-card-icon { color:var(--gold); font-size:.9rem; }
.sf-card-title { font-size:.72rem; font-weight:700; letter-spacing:.1em;
    text-transform:uppercase; color:var(--muted); }
.sf-card-badge { margin-left:auto; font-size:.72rem; color:var(--muted); }
.sf-card-body { padding:1rem; display:grid; gap:.75rem; }
.sfg2 { grid-template-columns:1fr 1fr; }

.fg { display:flex; flex-direction:column; gap:.3rem; }
.fg-label { font-size:.72rem; font-weight:700; letter-spacing:.05em;
    text-transform:uppercase; color:var(--muted); }
.fg-val { padding:.6rem .85rem; border:1px solid var(--border); border-radius:7px;
    font-family:'Outfit',sans-serif; font-size:.86rem; color:var(--deep);
    background:var(--cream); min-height:38px; display:flex; align-items:center; gap:.4rem; }

.status-badge { display:inline-flex; align-items:center; gap:.35rem; padding:.25rem .75rem;
    border-radius:20px; font-size:.68rem; font-weight:700; letter-spacing:.05em; }
.status-dot { width:7px; height:7px; border-radius:50%; }

.amenity-chips { display:flex; flex-wrap:wrap; gap:.5rem; }
.amenity-chip { display:inline-flex; align-items:center; gap:.4rem; padding:.35rem .8rem;
    border:1.5px solid var(--border); border-radius:7px; font-size:.82rem; color:var(--muted); }
.amenity-chip.on { border-color:var(--gold); background:rgba(212,160,23,.07);
    color:var(--deep); font-weight:600; }

.img-gallery { display:flex; flex-wrap:wrap; gap:.5rem; }
.img-thumb-view { width:78px; height:78px; border-radius:7px; overflow:hidden;
    border:2px solid var(--border); position:relative; }
.img-thumb-view.is-main { border-color:var(--gold); border-width:2.5px; }
.img-thumb-view img { width:100%; height:100%; object-fit:cover; }
.img-thumb-view .star-badge { position:absolute; top:3px; left:3px; width:18px; height:18px;
    background:rgba(212,160,23,.9); border-radius:50%; display:flex;
    align-items:center; justify-content:center; font-size:.6rem; color:var(--deep); }

.day-tabs-d { display:flex; gap:.3rem; flex-wrap:wrap; margin-bottom:.75rem; }
.day-tab-d { padding:.3rem .7rem; border:1px solid var(--border); border-radius:5px;
    font-size:.72rem; font-weight:600; cursor:pointer; color:var(--muted);
    background:#fff; transition:all .15s; }
.day-tab-d:hover { border-color:rgba(212,160,23,.5); }
.day-tab-d.active { border-color:var(--gold); background:rgba(212,160,23,.08); color:var(--deep); }
.slot-row-d { display:flex; align-items:center; gap:.6rem; padding:.5rem .75rem;
    border:1px solid var(--border); border-radius:7px; background:var(--cream); margin-bottom:.35rem; }
.slot-time-d { font-weight:700; font-size:.84rem; color:var(--deep); min-width:100px; font-family:monospace; }
.slot-price-d { font-size:.84rem; font-weight:700; color:#16a34a; margin-left:auto; }
.slot-badge-d { font-size:.62rem; padding:.15rem .45rem; border-radius:3px; font-weight:700;
    background:rgba(212,160,23,.1); color:#92660a; }

.desc-block { font-size:.86rem; color:var(--deep); line-height:1.7;
    background:var(--cream); border-radius:7px; padding:.85rem 1rem;
    border-left:3px solid var(--gold); }

.no-data { color:var(--muted); font-style:italic; font-size:.84rem; }

.mfooter { display:flex; justify-content:flex-end; gap:.6rem;
    padding:1rem 1.5rem; border-top:1px solid var(--border); background:var(--warm); }
.btn-cancel { padding:.6rem 1.4rem; border:1px solid var(--border); border-radius:7px;
    background:#fff; font-family:'Outfit',sans-serif; font-size:.84rem; cursor:pointer;
    color:var(--muted); transition:all .15s; text-decoration:none;
    display:inline-flex; align-items:center; gap:.4rem; }
.btn-cancel:hover { border-color:var(--deep); color:var(--deep); }
.btn-edit { padding:.6rem 1.8rem; background:linear-gradient(135deg,var(--gold),var(--gold2));
    border:none; border-radius:7px; font-family:'Outfit',sans-serif; font-size:.84rem;
    font-weight:700; color:var(--deep); cursor:pointer; display:inline-flex;
    align-items:center; gap:.4rem; transition:all .2s; text-decoration:none; }
.btn-edit:hover { box-shadow:0 4px 14px rgba(212,160,23,.35); transform:translateY(-1px); color:var(--deep); }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Chi Tiết Sân</div>
        <div class="mh-title">@Model.CourtNumber</div>
        <div class="mh-sub">
            @(Model.Facility?.FacilityName ?? "—")
            @if (!string.IsNullOrEmpty(Model.FloorNumber))
            {
                <span style="margin:0 .3rem;color:var(--border);">·</span>
                <span>@Model.FloorNumber</span>
            }
        </div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="mbody">

    <!-- 1. Thông tin sân -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-card-text sf-card-icon"></i>
            <span class="sf-card-title">Thông Tin Sân</span>
            <span class="sf-card-badge">
                <span class="status-badge" style="background:@statusBg; color:@statusColor;">
                    <span class="status-dot" style="background:@statusColor;"></span>
                    @Model.StatusLabel
                </span>
            </span>
        </div>
        <div class="sf-card-body sfg2">
            <div class="fg">
                <div class="fg-label">Tên / Số Sân</div>
                <div class="fg-val"><i class="bi bi-grid-3x3-gap" style="color:var(--gold)"></i> @Model.CourtNumber</div>
            </div>
            <div class="fg">
                <div class="fg-label">Cơ Sở</div>
                <div class="fg-val"><i class="bi bi-building" style="color:var(--gold)"></i> @(Model.Facility?.FacilityName ?? "—")</div>
            </div>
            <div class="fg">
                <div class="fg-label">Vị Trí Sân</div>
                <div class="fg-val">
                    @(Model.CourtType == "Indoor" ? "🏠" : "☀️") @Model.CourtTypeLabel
                </div>
            </div>
            <div class="fg">
                <div class="fg-label">Loại Mặt Sân</div>
                <div class="fg-val">
                    @(Model.SurfaceType == "PVC" ? "🟨" : Model.SurfaceType == "Wood" ? "🪵" : "🎨") @Model.SurfaceTypeLabel
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.FloorNumber))
            {
                <div class="fg">
                    <div class="fg-label">Vị Trí Tầng</div>
                    <div class="fg-val"><i class="bi bi-layers" style="color:var(--gold)"></i> @Model.FloorNumber</div>
                </div>
            }
            <div class="fg">
                <div class="fg-label">Ngày Tạo</div>
                <div class="fg-val"><i class="bi bi-calendar3" style="color:var(--gold)"></i> @Model.CreatedAt.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>

    <!-- 2. Tiện ích -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-lightning-charge sf-card-icon"></i>
            <span class="sf-card-title">Tiện Ích Sân</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            <div class="amenity-chips">
                <div class="amenity-chip @(Model.HasLighting ? "on" : "")">
                    💡 Đèn chiếu sáng
                    @if (Model.HasLighting) { <i class="bi bi-check-circle-fill" style="color:var(--gold);font-size:.8rem;"></i> }
                </div>
                <div class="amenity-chip @(Model.HasAC ? "on" : "")">
                    ❄️ Điều hoà
                    @if (Model.HasAC) { <i class="bi bi-check-circle-fill" style="color:var(--gold);font-size:.8rem;"></i> }
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Mô tả -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-chat-left-text sf-card-icon"></i>
            <span class="sf-card-title">Mô Tả</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="desc-block">@Model.Description</div>
            }
            else
            {
                <span class="no-data">Chưa có mô tả</span>
            }
        </div>
    </div>

    <!-- 4. Hình ảnh -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-images sf-card-icon"></i>
            <span class="sf-card-title">Hình Ảnh Sân</span>
            @if (allImages.Any())
            {
                <span class="sf-card-badge">@allImages.Count ảnh</span>
            }
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @if (allImages.Any())
            {
                <div class="img-gallery">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="img-thumb-view @(allImages[i].IsPrimary ? "is-main" : "")">
                            <img src="@allImages[i].ImagePath" alt="Ảnh @(i + 1)"
                                 onerror="this.src='/images/no-image.png'" />
                            @if (allImages[i].IsPrimary)
                            {
                                <div class="star-badge"><i class="bi bi-star-fill"></i></div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="no-data">Chưa có hình ảnh</span>
            }
        </div>
    </div>

    <!-- 5. Khung giờ & Giá -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-clock sf-card-icon"></i>
            <span class="sf-card-title">Khung Giờ & Giá</span>
            <span class="sf-card-badge">@(Model.PriceSlots?.Count(ps => ps.IsActive) ?? 0) khung giờ</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @if (slotsByDay?.Any() == true)
            {
                <div class="day-tabs-d" id="dayTabsDetail">
                    @{ bool firstDay = true; }
                    @foreach (var grp in slotsByDay)
                    {
                        <div class="day-tab-d @(firstDay ? "active" : "")"
                             data-day="@((int?)grp.Key ?? -1)"
                             onclick="switchDayDetail(this)">
                            @DayName(grp.Key)
                        </div>
                        firstDay = false;
                    }
                </div>

                {
                    bool firstPanel = true;
                    foreach (var grp in slotsByDay)
                    {
                        var slots = grp.OrderBy(ps => ps.StartTime).ToList();
                        <div class="slot-panel-d @(firstPanel ? "" : "d-none")"
                             data-day="@((int?)grp.Key ?? -1)">
                            @foreach (var slot in slots)
                            {
                                <div class="slot-row-d">
                                    <i class="bi bi-clock" style="color:var(--gold);font-size:.75rem;"></i>
                                    <span class="slot-time-d">
                                        @slot.StartTime.ToString(@"hh\:mm") – @slot.EndTime.ToString(@"hh\:mm")
                                    </span>
                                    @if (slot.IsPeakHour)
                                    {
                                        <span class="slot-badge-d">Cao điểm</span>
                                    }
                                    <span class="slot-price-d">@slot.Price.ToString("N0")đ/h</span>
                                </div>
                            }
                        </div>
                        firstPanel = false;
                    }
                }
            }
            else
            {
                <span class="no-data">Chưa cấu hình khung giờ</span>
            }
        </div>
    </div>

</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Đóng
    </button>
    <a href="javascript:void(0)"
       onclick="fetchModalContent('@Url.Action("Edit", "AdminCourt", new { id = Model.CourtId })', true)"
       class="btn-edit">
        <i class="bi bi-pencil-square"></i> Chỉnh Sửa
    </a>
</div>

<script>
function switchDayDetail(tabEl) {
    document.querySelectorAll('.day-tab-d').forEach(t => t.classList.remove('active'));
    tabEl.classList.add('active');
    const day = tabEl.dataset.day;
    document.querySelectorAll('.slot-panel-d').forEach(p => {
        p.classList.toggle('d-none', p.dataset.day !== day);
    });
}
</script>
