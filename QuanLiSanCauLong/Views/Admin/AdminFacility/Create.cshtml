@model QuanLiSanCauLong.Models.Facility
@{
    Layout = null;
}

<style>
    /* ── SHARED MODAL STYLES (AdminCourt palette) ─────────────── */
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
    }

    /* Section card */
    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .sfg2 {
        grid-template-columns: 1fr 1fr;
    }

    .sfg3 {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .sfg72 {
        grid-template-columns: 7fr 5fr;
    }

    /* Field group */
    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-req {
        color: #c94b2a;
        margin-left: .15rem;
    }

    .fg-input, .fg-select, .fg-textarea {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.08);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 70px;
    }

    .fg-hint {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .input-icon {
        position: relative;
    }

        .input-icon i {
            position: absolute;
            left: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        .input-icon .fg-input {
            padding-left: 2.2rem;
        }

    .field-error {
        font-size: .72rem;
        color: #c94b2a;
    }

    /* Time row */
    .time-sep {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .8rem;
        padding-top: 1.6rem;
    }

    /* Amenity grid */
    .amenity-grid {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .amenity-item {
        cursor: pointer;
        margin: 0;
    }

        .amenity-item input {
            display: none;
        }

    .amenity-box {
        display: flex;
        align-items: center;
        gap: .45rem;
        padding: .4rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        color: var(--muted);
        transition: all .18s;
        user-select: none;
    }

    .amenity-item input:checked + .amenity-box {
        border-color: var(--gold);
        background: rgba(212,160,23,.07);
        color: var(--deep);
        font-weight: 600;
    }

    .amenity-box i {
        font-size: .95rem;
    }

    /* Image upload */
    .upload-zone {
        border: 1.5px dashed var(--border);
        border-radius: 8px;
        padding: .9rem;
        background: var(--cream);
        cursor: pointer;
        transition: border-color .2s;
    }

        .upload-zone:hover {
            border-color: var(--gold);
        }

    .img-previews {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-bottom: .6rem;
    }

    .img-thumb {
        position: relative;
        width: 78px;
        height: 78px;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid var(--border);
        cursor: pointer;
        transition: all .2s;
    }

        .img-thumb:hover {
            border-color: var(--gold);
        }

        .img-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .img-thumb.is-main {
            border-color: var(--gold);
            border-width: 2.5px;
        }

        .img-thumb .star {
            position: absolute;
            top: 3px;
            left: 3px;
            width: 18px;
            height: 18px;
            background: rgba(212,160,23,.9);
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: .6rem;
            color: var(--deep);
        }

        .img-thumb.is-main .star {
            display: flex;
        }

        .img-thumb .del {
            position: absolute;
            top: 3px;
            right: 3px;
            width: 18px;
            height: 18px;
            background: rgba(201,75,42,.85);
            color: #fff;
            border: none;
            border-radius: 50%;
            font-size: .6rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

            .img-thumb .del:hover {
                background: #c94b2a;
            }

    .add-img-btn {
        width: 78px;
        height: 78px;
        border: 1.5px dashed var(--border);
        border-radius: 7px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        font-size: .7rem;
        transition: .2s;
    }

        .add-img-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

    /* Footer */
    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-save:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Cơ Sở Mới</div>
        <div class="mh-title">Thêm Cơ Sở Sân</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="mbody">
    <form id="createFacilityForm" asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- 1. Thông tin cơ bản -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-building sf-card-icon"></i>
                <span class="sf-card-title">Thông Tin Cơ Bản</span>
            </div>
            <div class="sf-card-body sfg72">
                <div class="fg">
                    <label class="fg-label">Tên Cơ Sở <span class="fg-req">*</span></label>
                    <input asp-for="FacilityName" class="fg-input" placeholder="Sân cầu lông ABC – Chi nhánh 1" />
                    <span asp-validation-for="FacilityName" class="field-error"></span>
                </div>
                <div class="fg">
                    <label class="fg-label">Hotline <span class="fg-req">*</span></label>
                    <div class="input-icon">
                        <i class="bi bi-telephone"></i>
                        <input asp-for="Phone" class="fg-input" placeholder="0123 456 789" />
                    </div>
                </div>
                <div class="fg" style="grid-column:1/-1;">
                    <label class="fg-label">Địa Chỉ Chi Tiết <span class="fg-req">*</span></label>
                    <div class="input-icon">
                        <i class="bi bi-geo-alt"></i>
                        <input asp-for="Address" class="fg-input" placeholder="Số nhà, tên đường, phường/xã..." />
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Quận / Huyện</label>
                    <input asp-for="District" class="fg-input" placeholder="Quận 1" />
                </div>
                <div class="fg">
                    <label class="fg-label">Thành Phố</label>
                    <input asp-for="City" class="fg-input" placeholder="TP.HCM" />
                </div>
            </div>
        </div>

        <!-- 2. Giờ hoạt động -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-clock sf-card-icon"></i>
                <span class="sf-card-title">Giờ Hoạt Động</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr auto 1fr;">
                <div class="fg">
                    <label class="fg-label">Giờ Mở Cửa</label>
                    <input asp-for="OpenTime" type="time" class="fg-input" value="05:00" />
                </div>
                <div class="time-sep">→</div>
                <div class="fg">
                    <label class="fg-label">Giờ Đóng Cửa</label>
                    <input asp-for="CloseTime" type="time" class="fg-input" value="22:00" />
                </div>
            </div>
        </div>

        <!-- 3. Tọa độ -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-pin-map sf-card-icon"></i>
                <span class="sf-card-title">Tọa Độ Google Maps</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr 1fr auto;">
                <div class="fg">
                    <label class="fg-label">Vĩ độ (Lat)</label>
                    <input type="number" step="any" name="Latitude" class="fg-input" placeholder="10.7769" />
                </div>
                <div class="fg">
                    <label class="fg-label">Kinh độ (Lng)</label>
                    <input type="number" step="any" name="Longitude" class="fg-input" placeholder="106.7009" />
                </div>
                <div class="fg">
                    <label class="fg-label">&nbsp;</label>
                    <a href="https://www.google.com/maps" target="_blank"
                       style="display:flex;align-items:center;gap:.4rem;padding:.6rem .9rem;
                       border:1px solid var(--border);border-radius:7px;color:var(--muted);
                       text-decoration:none;font-size:.8rem;background:#fff;white-space:nowrap;">
                        <i class="bi bi-map" style="color:var(--gold);"></i> Maps
                    </a>
                </div>
                <div style="grid-column:1/-1;">
                    <div class="fg-hint"><i class="bi bi-info-circle me-1"></i>Mở Google Maps → Nhấp chuột phải vào địa điểm → Copy tọa độ</div>
                </div>
            </div>
        </div>

        <!-- 4. Tiện ích -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-stars sf-card-icon"></i>
                <span class="sf-card-title">Tiện Ích Đi Kèm</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="amenity-grid">
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="parking" class="amenity-check" />
                        <span class="amenity-box"><i class="bi bi-p-square-fill" style="color:#2196f3;"></i> Gửi xe</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="wifi" class="amenity-check" />
                        <span class="amenity-box"><i class="bi bi-wifi" style="color:#4caf50;"></i> Wifi</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="canteen" class="amenity-check" />
                        <span class="amenity-box"><i class="bi bi-cup-hot-fill" style="color:#ff9800;"></i> Căng tin</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="shower" class="amenity-check" />
                        <span class="amenity-box"><i class="bi bi-droplet-fill" style="color:#00bcd4;"></i> Nhà tắm</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="rental" class="amenity-check" />
                        <span class="amenity-box"><i class="bi bi-bag-fill" style="color:#9c27b0;"></i> Thuê vợt / giày</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 5. Mô tả -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-chat-left-text sf-card-icon"></i>
                <span class="sf-card-title">Mô Tả</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="fg" style="margin:0;">
                    <textarea asp-for="Description" class="fg-textarea"
                              placeholder="Mô tả ngắn về cơ sở (vị trí thuận tiện, cơ sở vật chất...)"></textarea>
                    <div class="fg-hint">Tuỳ chọn — giúp khách hàng hiểu rõ hơn về cơ sở</div>
                </div>
            </div>
        </div>

        <!-- 6. Hình ảnh -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-images sf-card-icon"></i>
                <span class="sf-card-title">Hình Ảnh Cơ Sở</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="upload-zone" onclick="document.getElementById('imgInputCreate').click()">
                    <div class="img-previews" id="imagePreviewCreate">
                        <div class="add-img-btn">
                            <i class="bi bi-plus-circle" style="font-size:1.3rem;margin-bottom:.25rem;"></i>
                            <span>Thêm ảnh</span>
                        </div>
                    </div>
                    <div class="fg-hint" style="margin:0;">
                        <i class="bi bi-info-circle me-1"></i>Click vào ảnh để đặt làm ảnh chính. Hỗ trợ JPG, PNG, WEBP.
                    </div>
                </div>
                <input type="file" id="imgInputCreate" name="FacilityImages" multiple accept="image/jpeg,image/png,image/webp" style="display:none;" />
                <input type="hidden" name="PrimaryImageIndex" id="mainImageIdxCreate" value="0" />
            </div>
        </div>

    </form>
</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="submit" form="createFacilityForm" class="btn-save" id="btnCreateSubmit">
        <i class="bi bi-plus-circle"></i> Thêm Cơ Sở
    </button>
</div>

<script>
    (function() {
        const input     = document.getElementById('imgInputCreate');
        const preview   = document.getElementById('imagePreviewCreate');
        const mainIdx   = document.getElementById('mainImageIdxCreate');
        const addBtn    = preview.querySelector('.add-img-btn');
        const form      = document.getElementById('createFacilityForm');
        let files       = [];

        input.addEventListener('change', function(e) {
            Array.from(e.target.files).forEach(file => {
                if (!file.type.startsWith('image/')) return;
                const uid = Date.now() + Math.random();
                files.push({ id: uid, file });
                const reader = new FileReader();
                reader.onload = ev => {
                    const el = makeThumb(ev.target.result, uid);
                    preview.insertBefore(el, addBtn);
                    if (preview.querySelectorAll('.img-thumb').length === 1) setMain(el);
                };
                reader.readAsDataURL(file);
            });
            input.value = '';
            sync();
        });

        function makeThumb(src, uid) {
            const d = document.createElement('div');
            d.className = 'img-thumb';
            d.dataset.uid = uid;
            d.innerHTML = `<img src="${src}" /><div class="star"><i class="bi bi-star-fill"></i></div>
                <button type="button" class="del"><i class="bi bi-x"></i></button>`;
            d.addEventListener('click', e => { if (!e.target.closest('.del')) setMain(d); });
            d.querySelector('.del').addEventListener('click', e => { e.stopPropagation(); removeThumb(d, uid); });
            return d;
        }
        function setMain(el) {
            preview.querySelectorAll('.img-thumb').forEach(t => t.classList.remove('is-main'));
            el.classList.add('is-main');
            sync();
        }
        function removeThumb(el, uid) {
            const wasMain = el.classList.contains('is-main');
            files = files.filter(f => f.id !== uid);
            el.remove();
            if (wasMain) { const next = preview.querySelector('.img-thumb'); if (next) setMain(next); }
            sync();
        }
        function sync() {
            const dt = new DataTransfer(); let idx = 0, mainI = 0;
            preview.querySelectorAll('.img-thumb').forEach(t => {
                const item = files.find(f => f.id === parseFloat(t.dataset.uid));
                if (item) { dt.items.add(item.file); if (t.classList.contains('is-main')) mainI = idx; idx++; }
            });
            input.files = dt.files;
            if (mainIdx) mainIdx.value = mainI;
        }

        // AJAX submit
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('btnCreateSubmit');
            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';
            try {
                const r = await fetch(this.action, { method:'POST', body: new FormData(this) });
                const ct = r.headers.get('content-type');
                if (!ct?.includes('application/json')) throw new Error('Lỗi server');
                const res = await r.json();
                if (res.success) { alert(res.message); window.location.reload(); }
                else alert('Lỗi: ' + res.message);
            } catch(err) { alert('Lỗi hệ thống: ' + err.message); }
            finally { btn.disabled = false; btn.innerHTML = orig; }
        });
    })();
</script>
