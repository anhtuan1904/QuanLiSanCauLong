@model IEnumerable<QuanLiSanCauLong.Models.Facility>
@{
    ViewData["Title"] = "Quản lý cơ sở";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    body, * {
        font-family: 'Outfit',sans-serif;
    }

    /* HEADER */
    .idx-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .idx-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .idx-title em {
            font-style: italic;
            color: var(--gold);
        }

    .add-btn {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .75rem 1.6rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        transition: all .25s;
    }

        .add-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
            color: var(--deep);
        }

    /* STAT STRIP */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .72rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    /* TOOLBAR */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .tb-search {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .tb-search input {
            width: 100%;
            padding: .65rem 1rem .65rem 2.3rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .84rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
            }

        .tb-search i {
            position: absolute;
            left: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
        }

    .tb-sel {
        padding: .65rem 1rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    /* CARDS GRID */
    .fac-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(340px,1fr));
        gap: 1.25rem;
    }

    .fc {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition: all .2s;
    }

        .fc:hover {
            box-shadow: 0 5px 20px rgba(26,18,9,.08);
            transform: translateY(-2px);
        }

    /* Card image */
    .fc-img {
        position: relative;
        aspect-ratio: 16/7;
        background: var(--warm);
        overflow: hidden;
    }

        .fc-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .fc-img-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 2.5rem;
        opacity: .2;
    }

    .fc-status {
        position: absolute;
        top: .7rem;
        right: .7rem;
    }

    /* Chips */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .68rem;
        font-weight: 700;
        padding: .25rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
    }

    .chip-active {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-maintenance {
        background: rgba(234,179,8,.1);
        color: #a16207;
    }

    .chip-inactive {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    /* Card body */
    .fc-body {
        padding: 1.1rem 1.25rem;
    }

    .fc-name {
        font-weight: 700;
        font-size: .98rem;
        color: var(--deep);
        margin-bottom: .25rem;
    }

    .fc-addr {
        font-size: .75rem;
        color: var(--muted);
        margin-bottom: .85rem;
        display: flex;
        align-items: flex-start;
        gap: .3rem;
        line-height: 1.4;
    }

        .fc-addr i {
            color: var(--gold);
            margin-top: 1px;
            flex-shrink: 0;
        }

    /* Info row */
    .fc-info {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem .75rem;
        margin-bottom: .9rem;
    }

    .fc-info-item {
        font-size: .78rem;
    }

        .fc-info-item .fi-label {
            color: var(--muted);
            margin-bottom: .1rem;
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .fc-info-item .fi-val {
            font-weight: 600;
            color: var(--deep);
        }

    /* Court mini badges */
    .court-row {
        display: flex;
        gap: .35rem;
        flex-wrap: wrap;
        margin-bottom: .9rem;
        align-items: center;
    }

    .court-mini {
        font-size: .7rem;
        font-weight: 600;
        padding: .2rem .55rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--muted);
    }

    .court-avail {
        background: rgba(22,163,74,.08);
        border-color: rgba(22,163,74,.2);
        color: #16a34a;
    }

    /* Action buttons */
    .act-g {
        display: flex;
        gap: .4rem;
        border-top: 1px solid var(--border);
        padding: .85rem 1.25rem;
        background: var(--warm);
    }

    .act-b {
        flex: 1;
        padding: .52rem;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .2s;
        font-size: .78rem;
        font-weight: 600;
        text-decoration: none;
    }

        .act-b:hover.view {
            border-color: var(--gold);
            color: #92660a;
            background: rgba(212,160,23,.07);
        }

        .act-b:hover.edit {
            border-color: #4f46e5;
            color: #4f46e5;
            background: rgba(79,70,229,.07);
        }

        .act-b:hover.del {
            border-color: #c94b2a;
            color: #c94b2a;
            background: rgba(201,75,42,.07);
        }

    /* Alerts */
    .sys-alert {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #16a34a;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    /* Empty */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
        grid-column: 1/-1;
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .3;
        }

    /* Modal */
    .fm-content {
        border-radius: 12px !important;
        border: 0 !important;
        overflow: hidden;
    }
</style>

<div>
    <!-- HEADER -->
    <div class="idx-head">
        <div>
            <h1 class="idx-title">Quản Lý <em>Cơ Sở Sân</em></h1>
            <div style="font-size:.82rem;color:var(--muted);margin-top:.25rem;">
                Tổng cộng @(Model?.Count() ?? 0) cơ sở trong hệ thống
            </div>
        </div>
        <button class="add-btn" onclick="openCreateModal()">
            <i class="bi bi-plus-circle"></i> Thêm Cơ Sở Mới
        </button>
    </div>

    <!-- ALERTS -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i>@TempData["ErrorMessage"]</div>
    }

    <!-- STATS -->
    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@(Model?.Count() ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng Cơ Sở</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@(Model?.Count(f => f.Status == "Active") ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Hoạt Động</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#a16207;">@(Model?.Count(f => f.Status == "Maintenance") ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#a16207;"></span>Bảo Trì</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--deep);">@(Model?.Sum(f => f.Courts?.Count ?? 0) ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--deep);"></span>Tổng Sân</div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="tb-search">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Tìm tên cơ sở..." onkeyup="liveSearch()" />
        </div>
        <select class="tb-sel" id="statusFilter" onchange="liveSearch()">
            <option value="">Tất cả trạng thái</option>
            <option value="active">Hoạt động</option>
            <option value="maintenance">Bảo trì</option>
            <option value="inactive">Ngừng hoạt động</option>
        </select>
    </div>

    <!-- CARDS -->
    <div class="fac-grid" id="facGrid">
        @if (Model?.Any() == true)
        {
            foreach (var f in Model)
            {
                var statusChip = f.Status switch
                {
                                "Active" => ("chip-active", "✓ Hoạt động"),
                                "Maintenance" => ("chip-maintenance", "⚠ Bảo trì"),
                    _ => ("chip-inactive", "✗ Ngừng HĐ")
                };
                var primaryImg = f.FacilityImages?.FirstOrDefault(i => i.IsPrimary) ?? f.FacilityImages?.FirstOrDefault();
                var imgSrc = primaryImg?.ImagePath ?? f.ImageUrl;
                var totalCourts = f.Courts?.Count ?? 0;
                var availCourts = f.Courts?.Count(c => c.Status == "Available") ?? 0;
                var minPrice = f.Courts?.Any() == true ? f.Courts.Min(c => (decimal?)c.HourlyRate) : null;

                <div class="fc fac-card-item"
                     data-name="@f.FacilityName.ToLower()"
                     data-status="@f.Status.ToLower()">

                    <!-- Image -->
                    <div class="fc-img">
                        @if (!string.IsNullOrEmpty(imgSrc))
                        {
                            <img src="@imgSrc" alt="@f.FacilityName" />
                        }
                        else
                        {
                            <div class="fc-img-empty"><i class="bi bi-building"></i></div>
                        }
                        <div class="fc-status">
                            <span class="chip @statusChip.Item1">@statusChip.Item2</span>
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="fc-body">
                        <div class="fc-name">@f.FacilityName</div>
                        <div class="fc-addr">
                            <i class="bi bi-geo-alt-fill"></i>
                            @(string.IsNullOrEmpty(f.Address) ? "Chưa cập nhật địa chỉ" :
                                                (!string.IsNullOrEmpty(f.District) ? $"{f.Address}, {f.District}" : f.Address))
                        </div>

                        <!-- Info -->
                        <div class="fc-info">
                            <div class="fc-info-item">
                                <div class="fi-label">Giờ hoạt động</div>
                                <div class="fi-val">
                                    <i class="bi bi-clock" style="color:var(--gold);font-size:.75rem;"></i>
                                    @(f.OpenTime?.ToString(@"hh\:mm") ?? "--") – @(f.CloseTime?.ToString(@"hh\:mm") ?? "--")
                                </div>
                            </div>
                            <div class="fc-info-item">
                                <div class="fi-label">Hotline</div>
                                <div class="fi-val">
                                    <i class="bi bi-telephone" style="color:var(--gold);font-size:.75rem;"></i>
                                    @(string.IsNullOrEmpty(f.Phone) ? "—" : f.Phone)
                                </div>
                            </div>
                            <div class="fc-info-item">
                                <div class="fi-label">Giá từ</div>
                                <div class="fi-val" style="color:#16a34a;">
                                    @(minPrice.HasValue ? $"{minPrice.Value:N0}đ/giờ" : "—")
                                </div>
                            </div>
                            <div class="fc-info-item">
                                <div class="fi-label">Sân trống / Tổng</div>
                                <div class="fi-val">
                                    <span style="color:#16a34a;">@availCourts</span>
                                    <span style="color:var(--muted);">/@totalCourts sân</span>
                                </div>
                            </div>
                        </div>

                        <!-- Court badges -->
                        @if (f.Courts?.Any() == true)
                        {
                            <div class="court-row">
                                @foreach (var c in f.Courts.Take(5))
                                {
                                    <span class="court-mini @(c.Status == "Available" ? "court-avail" : "")">
                                        @c.CourtNumber
                                    </span>
                                }
                                @if (f.Courts.Count > 5)
                                {
                                    <span class="court-mini">+@(f.Courts.Count - 5)</span>
                                }
                            </div>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="act-g">
                        <button class="act-b view" onclick="openDetailsModal(@f.FacilityId)" title="Xem chi tiết">
                            <i class="bi bi-eye"></i> Xem
                        </button>
                        <button class="act-b edit" onclick="openEditModal(@f.FacilityId)" title="Chỉnh sửa">
                            <i class="bi bi-pencil"></i> Sửa
                        </button>
                        <button class="act-b del" onclick="confirmDelete(@f.FacilityId,'@Html.Raw(f.FacilityName.Replace("'", "&#39;"))')" title="Xóa">
                            <i class="bi bi-trash3"></i> Xóa
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-building-x"></i>
                <div>Chưa có cơ sở nào. <span style="color:var(--gold);cursor:pointer;" onclick="openCreateModal()">Thêm ngay</span></div>
            </div>
        }
    </div>
</div>

<!-- ═══ MODAL: Create / Edit / Details ═══ -->
<div class="modal fade" id="modalFacility" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content fm-content" id="modalFacilityContent">
            <div class="p-5 text-center">
                <div class="spinner-border" style="color:var(--gold);"></div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ MODAL: Delete Confirm ═══ -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content fm-content">
            <div class="modal-body p-4 text-center">
                <div style="width:72px;height:72px;border-radius:50%;background:rgba(201,75,42,.08);
                    display:inline-flex;align-items:center;justify-content:center;margin-bottom:1rem;">
                    <i class="bi bi-exclamation-triangle" style="font-size:1.8rem;color:#c94b2a;"></i>
                </div>
                <h5 style="font-family:'Playfair Display',serif;font-weight:700;color:var(--deep);margin-bottom:.5rem;">
                    Xác nhận xóa?
                </h5>
                <p style="font-size:.84rem;color:var(--muted);margin-bottom:1.5rem;">
                    Bạn có chắc muốn xóa cơ sở <strong id="deleteName" style="color:var(--deep);"></strong>?<br>
                    Hành động này không thể hoàn tác.
                </p>
                <div style="display:flex;gap:.6rem;">
                    <button class="btn-cancel-sm" data-bs-dismiss="modal"
                            style="flex:1;padding:.65rem;border:1px solid var(--border);border-radius:7px;
                            background:#fff;font-family:'Outfit',sans-serif;cursor:pointer;font-size:.84rem;">
                        Hủy
                    </button>
                    <form id="deleteForm" method="post" style="flex:1;">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                style="width:100%;padding:.65rem;border:none;border-radius:7px;
                                background:#c94b2a;color:#fff;font-family:'Outfit',sans-serif;
                                font-weight:700;cursor:pointer;font-size:.84rem;">
                            Xác nhận xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        let facilityModal;
        document.addEventListener('DOMContentLoaded', () => {
            const el = document.getElementById('modalFacility');
            if (el) facilityModal = new bootstrap.Modal(el);
        });

        function executeScripts(container) {
            container.querySelectorAll('script').forEach(old => {
                const s = document.createElement('script');
                Array.from(old.attributes).forEach(a => s.setAttribute(a.name, a.value));
                s.appendChild(document.createTextNode(old.innerHTML));
                old.parentNode.replaceChild(s, old);
            });
        }

        async function fetchModalContent(url, hasScripts = false) {
            const content = document.getElementById('modalFacilityContent');
            content.innerHTML = `<div class="p-5 text-center">
                <div class="spinner-border" style="color:var(--gold);"></div>
                <p style="margin-top:.75rem;font-size:.82rem;color:var(--muted);">Đang tải...</p>
            </div>`;
            facilityModal.show();
            try {
                const r = await fetch(url);
                content.innerHTML = await r.text();
                if (hasScripts) setTimeout(() => executeScripts(content), 50);
            } catch {
                content.innerHTML = `<div class="p-5 text-center" style="color:#c94b2a;">Lỗi kết nối máy chủ!</div>`;
            }
        }

        function openCreateModal()      { fetchModalContent('/AdminFacility/Create', true); }
        function openEditModal(id)      { fetchModalContent('/AdminFacility/Edit/' + id, true); }
        function openDetailsModal(id)   { fetchModalContent('/AdminFacility/Details/' + id, false); }

        function confirmDelete(id, name) {
            const modalEl = document.getElementById('deleteModal');
            document.getElementById('deleteName').textContent = name;
            document.getElementById('deleteForm').onsubmit = async function(e) {
                e.preventDefault();
                const token = this.querySelector('[name=__RequestVerificationToken]').value;
                try {
                    const r = await fetch('/AdminFacility/Delete/' + id, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token, 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: '__RequestVerificationToken=' + encodeURIComponent(token)
                    });
                    const res = await r.json();
                    bootstrap.Modal.getInstance(modalEl).hide();
                    if (res.success) {
                        Swal.fire({ icon:'success', title:'Đã xóa!', text:res.message,
                            timer:1500, showConfirmButton:false }).then(() => location.reload());
                    } else {
                        Swal.fire('Lỗi!', res.message, 'error');
                    }
                } catch { Swal.fire('Lỗi!', 'Không thể kết nối máy chủ!', 'error'); }
            };
            new bootstrap.Modal(modalEl).show();
        }

        function liveSearch() {
            const q      = document.getElementById('searchInput').value.toLowerCase();
            const status = document.getElementById('statusFilter').value.toLowerCase();
            document.querySelectorAll('.fac-card-item').forEach(el => {
                const nameMatch   = el.dataset.name.includes(q);
                const statusMatch = !status || el.dataset.status === status;
                el.style.display = (nameMatch && statusMatch) ? '' : 'none';
            });
        }
    </script>
}
