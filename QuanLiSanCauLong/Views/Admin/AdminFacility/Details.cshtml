@model QuanLiSanCauLong.ViewModels.FacilityDetailsViewModel
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    .mh {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 1.4rem 1.5rem 0;
        gap: 1rem;
    }

    .mh-label {
        font-size: .65rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 700;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .mh-label::before {
            content: '';
            width: 12px;
            height: 1px;
            background: var(--gold);
        }

    .mh-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
    }

    .mh-close {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .85rem;
        transition: all .15s;
        flex-shrink: 0;
    }

        .mh-close:hover {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .mbody {
        padding: 1.25rem 1.5rem;
        max-height: calc(85vh - 130px);
        overflow-y: auto;
        overflow-x: hidden;
    }

        .mbody::-webkit-scrollbar {
            width: 5px;
        }

        .mbody::-webkit-scrollbar-track {
            background: var(--warm);
            border-radius: 3px;
        }

        .mbody::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

            .mbody::-webkit-scrollbar-thumb:hover {
                background: var(--gold2);
            }

    /* Section card */
    .sf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: .9rem;
        overflow: hidden;
    }

    .sf-card-head {
        padding: .7rem 1rem;
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
        border-bottom: 1px solid var(--border);
    }

    .sf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .sf-card-title {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .sf-card-body {
        padding: 1rem;
        display: grid;
        gap: .75rem;
    }

    .sfg2 {
        grid-template-columns: 1fr 1fr;
    }

    .sfg3 {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .sfg72 {
        grid-template-columns: 7fr 5fr;
    }

    /* Field group - readonly */
    .fg {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .fg-label {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .05em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fg-val {
        padding: .6rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: var(--cream);
        min-height: 38px;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .fg-val.empty {
            color: var(--muted);
            font-style: italic;
        }

    .fg-val-lg {
        padding: .75rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: .86rem;
        color: var(--deep);
        background: var(--cream);
        line-height: 1.7;
        min-height: 70px;
    }

    /* Amenity chips */
    .amenity-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .amenity-chip {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .35rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .82rem;
        color: var(--deep);
        background: rgba(212,160,23,.07);
        border-color: var(--gold);
        font-weight: 600;
    }

        .amenity-chip i {
            font-size: .9rem;
        }

    /* Image gallery */
    .img-gallery {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .img-thumb-view {
        width: 78px;
        height: 78px;
        border-radius: 7px;
        overflow: hidden;
        border: 2px solid var(--border);
        position: relative;
    }

        .img-thumb-view.is-main {
            border-color: var(--gold);
            border-width: 2.5px;
        }

        .img-thumb-view img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .img-thumb-view .star-badge {
            position: absolute;
            top: 3px;
            left: 3px;
            width: 18px;
            height: 18px;
            background: rgba(212,160,23,.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .6rem;
            color: var(--deep);
        }

    /* Court cards */
    .court-list {
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    .court-item {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: .75rem 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #fff;
    }

    .court-num {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        color: var(--deep);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: .78rem;
        flex-shrink: 0;
    }

    .court-info {
        flex: 1;
        min-width: 0;
    }

    .court-name {
        font-weight: 700;
        font-size: .9rem;
        color: var(--deep);
    }

    .court-meta {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        margin-top: .25rem;
    }

    .court-tag {
        font-size: .68rem;
        padding: 2px 7px;
        border-radius: 4px;
        font-weight: 600;
    }

    .ct-indoor {
        background: #e3f2fd;
        color: #1565c0;
    }

    .ct-outdoor {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .ct-available {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .ct-maintain {
        background: #fff3e0;
        color: #e65100;
    }

    .ct-pvc {
        background: #f3e5f5;
        color: #6a1b9a;
    }

    .ct-wood {
        background: #fbe9e7;
        color: #bf360c;
    }

    .ct-default {
        background: var(--warm);
        color: var(--muted);
    }

    .court-feats {
        display: flex;
        gap: .4rem;
        margin-top: .3rem;
    }

    .feat-dot {
        font-size: .7rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .25rem;
    }

        .feat-dot i {
            color: var(--gold);
            font-size: .72rem;
        }

    /* Status badge on header */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .25rem .75rem;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .05em;
    }

    .sb-active {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #a5d6a7;
    }

    .sb-inactive {
        background: #fbe9e7;
        color: #c62828;
        border: 1px solid #ef9a9a;
    }

    /* Footer */
    .mfooter {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
    }

    .btn-cancel {
        padding: .6rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-edit {
        padding: .6rem 1.8rem;
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        border: none;
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
        text-decoration: none;
    }

        .btn-edit:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
            color: var(--deep);
        }

    .no-data {
        color: var(--muted);
        font-style: italic;
        font-size: .84rem;
    }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Chi Tiết Cơ Sở</div>
        <div class="mh-title">@Model.FacilityName</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="mbody">

    <!-- 1. Thông tin cơ bản -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-building sf-card-icon"></i>
            <span class="sf-card-title">Thông Tin Cơ Bản</span>
        </div>
        <div class="sf-card-body sfg72">
            <div class="fg">
                <div class="fg-label">Tên Cơ Sở</div>
                <div class="fg-val"><i class="bi bi-building" style="color:var(--gold)"></i> @Model.FacilityName</div>
            </div>
            <div class="fg">
                <div class="fg-label">Hotline</div>
                <div class="fg-val">
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <i class="bi bi-telephone" style="color:var(--gold)"></i>
                        <span>@Model.Phone</span>
                    }
                    else
                    {
                        <span class="empty">—</span>
                    }
                </div>
            </div>
            <div class="fg" style="grid-column:1/-1;">
                <div class="fg-label">Địa Chỉ Chi Tiết</div>
                <div class="fg-val">
                    <i class="bi bi-geo-alt" style="color:var(--gold)"></i>
                    @(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)
                </div>
            </div>
            <div class="fg">
                <div class="fg-label">Quận / Huyện</div>
                <div class="fg-val @(string.IsNullOrEmpty(Model.District) ? "empty" : "")">
                    @(string.IsNullOrEmpty(Model.District) ? "—" : Model.District)
                </div>
            </div>
            <div class="fg">
                <div class="fg-label">Thành Phố</div>
                <div class="fg-val @(string.IsNullOrEmpty(Model.City) ? "empty" : "")">
                    @(string.IsNullOrEmpty(Model.City) ? "—" : Model.City)
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Giờ hoạt động -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-clock sf-card-icon"></i>
            <span class="sf-card-title">Giờ Hoạt Động</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr auto 1fr;">
            <div class="fg">
                <div class="fg-label">Giờ Mở Cửa</div>
                <div class="fg-val">
                    <i class="bi bi-door-open" style="color:var(--gold)"></i>
                    @(Model.OpenTime.HasValue
                                        ? DateTime.Today.Add(Model.OpenTime.Value).ToString("HH:mm")
                                        : "—")
                </div>
            </div>
            <div style="display:flex;align-items:center;justify-content:center;padding-top:1.4rem;color:var(--muted);">→</div>
            <div class="fg">
                <div class="fg-label">Giờ Đóng Cửa</div>
                <div class="fg-val">
                    <i class="bi bi-door-closed" style="color:var(--muted)"></i>
                    @(Model.CloseTime.HasValue
                                        ? DateTime.Today.Add(Model.CloseTime.Value).ToString("HH:mm")
                                        : "—")
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Tọa độ -->
    @if (Model.Latitude.HasValue || Model.Longitude.HasValue)
    {
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-pin-map sf-card-icon"></i>
                <span class="sf-card-title">Tọa Độ Google Maps</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr 1fr auto;">
                <div class="fg">
                    <div class="fg-label">Vĩ độ (Lat)</div>
                    <div class="fg-val">@(Model.Latitude?.ToString("F6") ?? "—")</div>
                </div>
                <div class="fg">
                    <div class="fg-label">Kinh độ (Lng)</div>
                    <div class="fg-val">@(Model.Longitude?.ToString("F6") ?? "—")</div>
                </div>
                <div class="fg">
                    <div class="fg-label">&nbsp;</div>
                    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                    {
                        <a href="https://www.google.com/maps?q=@Model.Latitude,@Model.Longitude"
                           target="_blank"
                           style="display:flex;align-items:center;gap:.4rem;padding:.6rem .9rem;
                                          border:1px solid var(--border);border-radius:7px;color:var(--muted);
                                          text-decoration:none;font-size:.8rem;background:#fff;white-space:nowrap;">
                            <i class="bi bi-map" style="color:var(--gold)"></i> Xem Maps
                        </a>
                    }
                </div>
            </div>
        </div>
    }

    <!-- 4. Tiện ích -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-stars sf-card-icon"></i>
            <span class="sf-card-title">Tiện Ích Đi Kèm</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @{
                var amenityIcons = new Dictionary<string, (string icon, string color, string label)>
                {
                    ["parking"] = ("bi-p-square-fill", "#2196f3", "Gửi xe"),
                    ["wifi"] = ("bi-wifi", "#4caf50", "Wifi"),
                    ["canteen"] = ("bi-cup-hot-fill", "#ff9800", "Căng tin"),
                    ["shower"] = ("bi-droplet-fill", "#00bcd4", "Nhà tắm"),
                    ["rental"] = ("bi-bag-fill", "#9c27b0", "Thuê vợt / giày"),
                };
                var availAmenities = Model.Amenities?.Where(a => a.IsAvailable).ToList()
                ?? new List<QuanLiSanCauLong.ViewModels.FacilityAmenityViewModel>();
            }
            @if (availAmenities.Any())
            {
                <div class="amenity-chips">
                    @foreach (var a in availAmenities)
                    {
                        var key = a.AmenityName?.ToLower().Trim() ?? "";
                        var hasIcon = amenityIcons.ContainsKey(key);
                        var ico = hasIcon ? amenityIcons[key].icon : "bi-check-circle-fill";
                        var col = hasIcon ? amenityIcons[key].color : "#d4a017";
                        var lbl = hasIcon ? amenityIcons[key].label : a.AmenityName;
                        <div class="amenity-chip">
                            <i class="bi @ico" style="color:@col"></i> @lbl
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="no-data">Chưa có tiện ích nào được cấu hình</span>
            }
        </div>
    </div>

    <!-- 5. Mô tả -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-chat-left-text sf-card-icon"></i>
            <span class="sf-card-title">Mô Tả</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="fg-val-lg">@Model.Description</div>
            }
            else
            {
                <span class="no-data">Chưa có mô tả</span>
            }
        </div>
    </div>

    <!-- 6. Hình ảnh -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-images sf-card-icon"></i>
            <span class="sf-card-title">Hình Ảnh Cơ Sở</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @if (Model.ImageUrls != null && Model.ImageUrls.Any())
            {
                <div class="img-gallery">
                    @for (int i = 0; i < Model.ImageUrls.Count; i++)
                    {
                        <div class="img-thumb-view @(i == 0 ? "is-main" : "")">
                            <img src="@Model.ImageUrls[i]" alt="Ảnh @(i + 1)"
                                 onerror="this.src='/images/no-image.png'" />
                            @if (i == 0)
                            {
                                <div class="star-badge"><i class="bi bi-star-fill"></i></div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="no-data">Chưa có hình ảnh</span>
            }
        </div>
    </div>

    <!-- 7. Danh sách sân -->
    <div class="sf-card">
        <div class="sf-card-head">
            <i class="bi bi-grid-3x3-gap sf-card-icon"></i>
            <span class="sf-card-title">Danh Sách Sân (@Model.TotalCourts)</span>
        </div>
        <div class="sf-card-body" style="grid-template-columns:1fr;">
            @if (Model.Courts != null && Model.Courts.Any())
            {
                <div class="court-list">
                    @foreach (var c in Model.Courts)
                    {
                        var typeClass = c.CourtType == "Indoor" ? "ct-indoor" : "ct-outdoor";
                        var statusClass = c.Status is "Available" or "Active" ? "ct-available" : "ct-maintain";
                        var surfClass = c.SurfaceType == "PVC" ? "ct-pvc" : c.SurfaceType == "Wood" ? "ct-wood" : "ct-default";
                        <div class="court-item">
                            <div class="court-num">
                                <i class="bi bi-grid-3x3-gap"></i>
                            </div>
                            <div class="court-info">
                                <div class="court-name">@c.CourtNumber</div>
                                <div class="court-meta">
                                    <span class="court-tag @typeClass">@c.CourtTypeLabel</span>
                                    <span class="court-tag @surfClass">@c.SurfaceTypeLabel</span>
                                    <span class="court-tag @statusClass">@c.StatusLabel</span>
                                    @if (!string.IsNullOrEmpty(c.FloorNumber))
                                    {
                                        <span class="court-tag ct-default"><i class="bi bi-layers"></i> @c.FloorNumber</span>
                                    }
                                </div>
                                <div class="court-feats">
                                    @if (c.HasLighting)
                                    {
                                        <span class="feat-dot"><i class="bi bi-lightbulb-fill"></i> Đèn chiếu sáng</span>
                                    }
                                    @if (c.HasAC)
                                    {
                                        <span class="feat-dot"><i class="bi bi-wind"></i> Điều hoà</span>
                                    }
                                    @if (c.HourlyRate.HasValue)
                                    {
                                        <span class="feat-dot"><i class="bi bi-tag-fill"></i> @c.HourlyRate.Value.ToString("N0")đ/h</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="no-data">Cơ sở chưa có sân nào</span>
            }
        </div>
    </div>

</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">
        <i class="bi bi-x-circle"></i> Đóng
    </button>
    <a href="javascript:void(0)"
       onclick="loadModal('@Url.Action("Edit", "AdminFacility", new { id = Model.FacilityId })')"
       class="btn-edit">
        <i class="bi bi-pencil-square"></i> Chỉnh Sửa
    </a>
</div>
