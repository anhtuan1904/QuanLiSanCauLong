@model QuanLiSanCauLong.Models.Facility
@{
    Layout = null;
    var images = ViewBag.FacilityImages as List<QuanLiSanCauLong.Models.FacilityImage>
                 ?? Model.FacilityImages?.OrderBy(i => i.DisplayOrder).ToList()
                 ?? new List<QuanLiSanCauLong.Models.FacilityImage>();
    var existingAmenities = (Model.Amenities ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries)
                                                    .Select(a => a.Trim()).ToHashSet();
}

<style>
:root {
    --deep:#1a1209; --gold:#d4a017; --gold2:#f5c842;
    --cream:#fdf8f0; --warm:#f5ede0; --border:#e8ddd0; --muted:#8a7560;
}
.mh { display:flex; align-items:flex-start; justify-content:space-between;
    padding:1.4rem 1.5rem 0; gap:1rem; }
.mh-label { font-size:.65rem; letter-spacing:.18em; text-transform:uppercase;
    color:var(--gold); font-weight:700; margin-bottom:.3rem;
    display:flex; align-items:center; gap:.5rem; }
.mh-label::before { content:''; width:12px; height:1px; background:var(--gold); }
.mh-title { font-family:'Playfair Display',serif; font-size:1.35rem; font-weight:700; color:var(--deep); }
.mh-sub { font-size:.78rem; color:var(--muted); margin-top:.15rem; }
.mh-close { width:32px; height:32px; border:1px solid var(--border); border-radius:6px;
    background:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center;
    color:var(--muted); font-size:.85rem; transition:all .15s; flex-shrink:0; }
.mh-close:hover { background:var(--deep); color:var(--gold2); border-color:var(--deep); }
.mbody { padding:1.25rem 1.5rem; }
.sf-card { background:#fff; border:1px solid var(--border); border-radius:10px;
    margin-bottom:.9rem; overflow:hidden; }
.sf-card-head { padding:.7rem 1rem; background:var(--warm); display:flex;
    align-items:center; gap:.5rem; border-bottom:1px solid var(--border); }
.sf-card-icon { color:var(--gold); font-size:.9rem; }
.sf-card-title { font-size:.72rem; font-weight:700; letter-spacing:.1em;
    text-transform:uppercase; color:var(--muted); }
.sf-card-body { padding:1rem; display:grid; gap:.75rem; }
.fg { display:flex; flex-direction:column; gap:.3rem; }
.fg-label { font-size:.72rem; font-weight:700; letter-spacing:.05em;
    text-transform:uppercase; color:var(--muted); }
.fg-req { color:#c94b2a; margin-left:.15rem; }
.fg-input, .fg-select, .fg-textarea {
    padding:.6rem .85rem; border:1px solid var(--border); border-radius:7px;
    font-family:'Outfit',sans-serif; font-size:.86rem; color:var(--deep);
    background:#fff; outline:none; transition:border-color .2s; width:100%; box-sizing:border-box; }
.fg-input:focus, .fg-select:focus, .fg-textarea:focus {
    border-color:var(--gold); box-shadow:0 0 0 3px rgba(212,160,23,.08); }
.fg-textarea { resize:vertical; min-height:70px; }
.fg-hint { font-size:.7rem; color:var(--muted); margin-top:.2rem; }
.input-icon { position:relative; }
.input-icon i { position:absolute; left:.8rem; top:50%; transform:translateY(-50%);
    color:var(--muted); pointer-events:none; }
.input-icon .fg-input { padding-left:2.2rem; }
.time-sep { display:flex; align-items:center; justify-content:center;
    color:var(--muted); font-size:.8rem; padding-top:1.6rem; }
.amenity-grid { display:flex; flex-wrap:wrap; gap:.5rem; }
.amenity-item { cursor:pointer; margin:0; }
.amenity-item input { display:none; }
.amenity-box { display:flex; align-items:center; gap:.45rem; padding:.4rem .8rem;
    border:1.5px solid var(--border); border-radius:7px; background:#fff;
    font-size:.82rem; color:var(--muted); transition:all .18s; user-select:none; }
.amenity-item input:checked + .amenity-box {
    border-color:var(--gold); background:rgba(212,160,23,.07);
    color:var(--deep); font-weight:600; }
.amenity-box i { font-size:.95rem; }
.upload-zone { border:1.5px dashed var(--border); border-radius:8px; padding:.9rem;
    background:var(--cream); cursor:pointer; transition:border-color .2s; }
.upload-zone:hover { border-color:var(--gold); }
.img-previews { display:flex; flex-wrap:wrap; gap:.5rem; margin-bottom:.6rem; }
.img-thumb { position:relative; width:78px; height:78px; border-radius:7px;
    overflow:hidden; border:2px solid var(--border); cursor:pointer; transition:all .2s; }
.img-thumb:hover { border-color:var(--gold); }
.img-thumb img { width:100%; height:100%; object-fit:cover; }
.img-thumb.is-main { border-color:var(--gold); border-width:2.5px; }
.img-thumb .star { position:absolute; top:3px; left:3px; width:18px; height:18px;
    background:rgba(212,160,23,.9); border-radius:50%; display:none;
    align-items:center; justify-content:center; font-size:.6rem; color:var(--deep); }
.img-thumb.is-main .star { display:flex; }
.img-thumb .del { position:absolute; top:3px; right:3px; width:18px; height:18px;
    background:rgba(201,75,42,.85); color:#fff; border:none; border-radius:50%;
    font-size:.6rem; display:flex; align-items:center; justify-content:center; cursor:pointer; }
.img-thumb .del:hover { background:#c94b2a; }
.add-img-btn { width:78px; height:78px; border:1.5px dashed var(--border); border-radius:7px;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    cursor:pointer; color:var(--muted); font-size:.7rem; transition:.2s; }
.add-img-btn:hover { border-color:var(--gold); color:var(--gold); }
.mfooter { display:flex; justify-content:flex-end; gap:.6rem;
    padding:1rem 1.5rem; border-top:1px solid var(--border); background:var(--warm); }
.btn-cancel { padding:.6rem 1.4rem; border:1px solid var(--border); border-radius:7px;
    background:#fff; font-family:'Outfit',sans-serif; font-size:.84rem; cursor:pointer;
    color:var(--muted); transition:all .15s; }
.btn-cancel:hover { border-color:var(--deep); color:var(--deep); }
.btn-save { padding:.6rem 1.8rem; background:linear-gradient(135deg,var(--gold),var(--gold2));
    border:none; border-radius:7px; font-family:'Outfit',sans-serif; font-size:.84rem;
    font-weight:700; color:var(--deep); cursor:pointer; display:flex; align-items:center;
    gap:.4rem; transition:all .2s; }
.btn-save:hover { box-shadow:0 4px 14px rgba(212,160,23,.35); transform:translateY(-1px); }
.btn-save:disabled { opacity:.6; cursor:not-allowed; transform:none; }
</style>

<!-- HEADER -->
<div class="mh">
    <div>
        <div class="mh-label">Chỉnh Sửa</div>
        <div class="mh-title">Cập Nhật Cơ Sở</div>
        <div class="mh-sub">@Model.FacilityName</div>
    </div>
    <button class="mh-close" data-bs-dismiss="modal" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="mbody">
    <form id="editFacilityForm" asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="FacilityId" />
        <input type="hidden" asp-for="CreatedAt" />

        <!-- 1. Thông tin cơ bản -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-building sf-card-icon"></i>
                <span class="sf-card-title">Thông Tin Cơ Bản</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:7fr 5fr;">
                <div class="fg">
                    <label class="fg-label">Tên Cơ Sở <span class="fg-req">*</span></label>
                    <input asp-for="FacilityName" class="fg-input" />
                </div>
                <div class="fg">
                    <label class="fg-label">Hotline</label>
                    <div class="input-icon">
                        <i class="bi bi-telephone"></i>
                        <input asp-for="Phone" class="fg-input" />
                    </div>
                </div>
                <div class="fg" style="grid-column:1/-1;">
                    <label class="fg-label">Địa Chỉ Chi Tiết</label>
                    <div class="input-icon">
                        <i class="bi bi-geo-alt"></i>
                        <input asp-for="Address" class="fg-input" />
                    </div>
                </div>
                <div class="fg">
                    <label class="fg-label">Quận / Huyện</label>
                    <input asp-for="District" class="fg-input" />
                </div>
                <div class="fg">
                    <label class="fg-label">Thành Phố</label>
                    <input asp-for="City" class="fg-input" />
                </div>
            </div>
        </div>

        <!-- 2. Giờ hoạt động + Trạng thái -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-clock sf-card-icon"></i>
                <span class="sf-card-title">Giờ Hoạt Động & Trạng Thái</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr auto 1fr 1fr;">
                <div class="fg">
                    <label class="fg-label">Giờ Mở Cửa</label>
                    <input asp-for="OpenTime" type="time" class="fg-input" />
                </div>
                <div class="time-sep">→</div>
                <div class="fg">
                    <label class="fg-label">Giờ Đóng Cửa</label>
                    <input asp-for="CloseTime" type="time" class="fg-input" />
                </div>
                <div class="fg">
                    <label class="fg-label">Trạng Thái</label>
                    <select asp-for="Status" class="fg-select">
                        <option value="Active">✓ Hoạt Động</option>
                        <option value="Maintenance">⚠ Bảo Trì</option>
                        <option value="Inactive">✗ Ngừng HĐ</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- 3. Tọa độ -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-pin-map sf-card-icon"></i>
                <span class="sf-card-title">Tọa Độ Google Maps</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr 1fr auto;">
                <div class="fg">
                    <label class="fg-label">Vĩ độ (Lat)</label>
                    <input type="number" step="any" name="Latitude" value="@Model.Latitude" class="fg-input" placeholder="10.7769" />
                </div>
                <div class="fg">
                    <label class="fg-label">Kinh độ (Lng)</label>
                    <input type="number" step="any" name="Longitude" value="@Model.Longitude" class="fg-input" placeholder="106.7009" />
                </div>
                <div class="fg">
                    <label class="fg-label">&nbsp;</label>
                    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                    {
                        <a href="https://www.google.com/maps?q=@Model.Latitude,@Model.Longitude" target="_blank"
                           style="display:flex;align-items:center;gap:.4rem;padding:.6rem .9rem;
                           border:1px solid rgba(22,163,74,.4);border-radius:7px;color:#16a34a;
                           text-decoration:none;font-size:.8rem;background:rgba(22,163,74,.06);white-space:nowrap;">
                            <i class="bi bi-map-fill"></i> Xem vị trí
                        </a>
                    }
                    else
                    {
                        <a href="https://www.google.com/maps" target="_blank"
                           style="display:flex;align-items:center;gap:.4rem;padding:.6rem .9rem;
                           border:1px solid var(--border);border-radius:7px;color:var(--muted);
                           text-decoration:none;font-size:.8rem;background:#fff;white-space:nowrap;">
                            <i class="bi bi-map" style="color:var(--gold);"></i> Maps
                        </a>
                    }
                </div>
                <div style="grid-column:1/-1;">
                    <div class="fg-hint"><i class="bi bi-info-circle me-1"></i>Mở Google Maps → Nhấp chuột phải → Copy tọa độ</div>
                </div>
            </div>
        </div>

        <!-- 4. Tiện ích -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-stars sf-card-icon"></i>
                <span class="sf-card-title">Tiện Ích Đi Kèm</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="amenity-grid">
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="parking"
                               @(existingAmenities.Contains("parking") ? "checked" : "") />
                        <span class="amenity-box"><i class="bi bi-p-square-fill" style="color:#2196f3;"></i> Gửi xe</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="wifi"
                               @(existingAmenities.Contains("wifi") ? "checked" : "") />
                        <span class="amenity-box"><i class="bi bi-wifi" style="color:#4caf50;"></i> Wifi</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="canteen"
                               @(existingAmenities.Contains("canteen") ? "checked" : "") />
                        <span class="amenity-box"><i class="bi bi-cup-hot-fill" style="color:#ff9800;"></i> Căng tin</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="shower"
                               @(existingAmenities.Contains("shower") ? "checked" : "") />
                        <span class="amenity-box"><i class="bi bi-droplet-fill" style="color:#00bcd4;"></i> Nhà tắm</span>
                    </label>
                    <label class="amenity-item">
                        <input type="checkbox" name="Amenities" value="rental"
                               @(existingAmenities.Contains("rental") ? "checked" : "") />
                        <span class="amenity-box"><i class="bi bi-bag-fill" style="color:#9c27b0;"></i> Thuê vợt / giày</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 5. Mô tả -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-chat-left-text sf-card-icon"></i>
                <span class="sf-card-title">Mô Tả</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="fg" style="margin:0;">
                    <textarea asp-for="Description" class="fg-textarea"></textarea>
                </div>
            </div>
        </div>

        <!-- 6. Hình ảnh -->
        <div class="sf-card">
            <div class="sf-card-head">
                <i class="bi bi-images sf-card-icon"></i>
                <span class="sf-card-title">Hình Ảnh Cơ Sở</span>
            </div>
            <div class="sf-card-body" style="grid-template-columns:1fr;">
                <div class="upload-zone" onclick="document.getElementById('imgInputEdit').click()">
                    <div class="img-previews" id="imagePreviewEdit">
                        <div class="add-img-btn" id="addImgBtnEdit">
                            <i class="bi bi-plus-circle" style="font-size:1.3rem;margin-bottom:.25rem;"></i>
                            <span>Thêm ảnh</span>
                        </div>
                    </div>
                    <div class="fg-hint" style="margin:0;">
                        <i class="bi bi-info-circle me-1"></i>Click vào ảnh để đặt làm ảnh chính. Click X để xóa.
                    </div>
                </div>
                <input type="file" id="imgInputEdit" name="NewImageFiles" multiple accept="image/jpeg,image/png,image/webp" style="display:none;" />
                <input type="hidden" name="PrimaryImageId" id="primaryImageIdEdit" value="@(images.FirstOrDefault(i => i.IsPrimary)?.ImageId ?? 0)" />
                <input type="hidden" name="NewMainImageIndex" id="mainImageIdxEdit" value="-1" />
                <input type="hidden" name="DeletedImageIds" id="deletedImageIdsEdit" value="" />
                <div id="existingImagesContainer"></div>
            </div>
        </div>

    </form>
</div>

<!-- FOOTER -->
<div class="mfooter">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button type="submit" form="editFacilityForm" class="btn-save" id="btnEditSubmit">
        <i class="bi bi-check-circle"></i> Lưu Thay Đổi
    </button>
</div>

<script>
(function() {
    const existingImages = @Html.Raw(Json.Serialize(images.Select(i => new {
        imageId   = i.ImageId,
        imagePath = i.ImagePath,
        isPrimary = i.IsPrimary
    })));

    const preview    = document.getElementById('imagePreviewEdit');
    const addBtn     = document.getElementById('addImgBtnEdit');
    const imgInput   = document.getElementById('imgInputEdit');
    const existCont  = document.getElementById('existingImagesContainer');
    const deletedInp = document.getElementById('deletedImageIdsEdit');
    const primaryInp = document.getElementById('primaryImageIdEdit');
    const mainIdxInp = document.getElementById('mainImageIdxEdit');
    let newFiles     = [];
    let deletedIds   = [];

    // Render ảnh cũ
    existingImages.forEach(img => {
        const el = makeExistThumb(img);
        preview.insertBefore(el, addBtn);
        const h = document.createElement('input');
        h.type = 'hidden'; h.name = 'ExistingImageIds'; h.value = img.imageId;
        h.dataset.imageId = img.imageId;
        existCont.appendChild(h);
    });

    function makeExistThumb(img) {
        const d = document.createElement('div');
        d.className = 'img-thumb' + (img.isPrimary ? ' is-main' : '');
        d.dataset.type = 'existing'; d.dataset.imageId = img.imageId;
        d.innerHTML = `<img src="${img.imagePath}" /><div class="star"><i class="bi bi-star-fill"></i></div>
            <button type="button" class="del"><i class="bi bi-x"></i></button>`;
        d.addEventListener('click', e => { if (!e.target.closest('.del')) setMain(d); });
        d.querySelector('.del').addEventListener('click', e => { e.stopPropagation(); removeExist(img.imageId, d); });
        return d;
    }

    imgInput.addEventListener('change', function(e) {
        Array.from(e.target.files).forEach(file => {
            if (!file.type.startsWith('image/')) return;
            newFiles.push(file);
            const reader = new FileReader();
            reader.onload = ev => {
                const el = makeNewThumb(ev.target.result);
                preview.insertBefore(el, addBtn);
                if (!preview.querySelector('.img-thumb.is-main')) setMain(el);
            };
            reader.readAsDataURL(file);
        });
        syncFiles();
    });

    function makeNewThumb(src) {
        const d = document.createElement('div');
        d.className = 'img-thumb'; d.dataset.type = 'new';
        d.innerHTML = `<img src="${src}" /><div class="star"><i class="bi bi-star-fill"></i></div>
            <button type="button" class="del"><i class="bi bi-x"></i></button>`;
        d.addEventListener('click', e => { if (!e.target.closest('.del')) setMain(d); });
        d.querySelector('.del').addEventListener('click', e => { e.stopPropagation(); removeNew(d); });
        return d;
    }

    function setMain(el) {
        preview.querySelectorAll('.img-thumb').forEach(t => t.classList.remove('is-main'));
        el.classList.add('is-main'); syncFiles();
    }
    function removeExist(imageId, el) {
        const wasMain = el.classList.contains('is-main');
        deletedIds.push(imageId); deletedInp.value = deletedIds.join(',');
        existCont.querySelector(`input[data-image-id="${imageId}"]`)?.remove();
        el.remove(); if (wasMain) fallbackMain();
    }
    function removeNew(el) {
        const wasMain = el.classList.contains('is-main');
        const allNew = Array.from(preview.querySelectorAll('.img-thumb[data-type="new"]'));
        const idx = allNew.indexOf(el);
        if (idx > -1) newFiles.splice(idx, 1);
        el.remove(); syncFiles(); if (wasMain) fallbackMain();
    }
    function fallbackMain() {
        const rem = preview.querySelector('.img-thumb'); if (rem) setMain(rem);
    }
    function syncFiles() {
        const dt = new DataTransfer();
        newFiles.forEach(f => dt.items.add(f));
        imgInput.files = dt.files;
        const main = preview.querySelector('.img-thumb.is-main');
        if (!main) { primaryInp.value = -1; mainIdxInp.value = -1; return; }
        if (main.dataset.type === 'existing') {
            primaryInp.value = main.dataset.imageId; mainIdxInp.value = -1;
        } else {
            const allNew = Array.from(preview.querySelectorAll('.img-thumb[data-type="new"]'));
            primaryInp.value = -1; mainIdxInp.value = allNew.indexOf(main);
        }
    }

    // AJAX submit
    document.getElementById('editFacilityForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = document.getElementById('btnEditSubmit');
        const orig = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang lưu...';
        try {
            const r = await fetch(this.action, { method:'POST', body: new FormData(this) });
            const ct = r.headers.get('content-type');
            if (!ct?.includes('application/json')) throw new Error('Lỗi server');
            const res = await r.json();
            if (res.success) { alert(res.message); window.location.reload(); }
            else alert('Lỗi: ' + res.message);
        } catch(err) { alert('Lỗi hệ thống: ' + err.message); }
        finally { btn.disabled = false; btn.innerHTML = orig; }
    });
})();
</script>
