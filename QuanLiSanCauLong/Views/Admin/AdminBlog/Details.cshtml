@model QuanLiSanCauLong.Models.BlogPost
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --success: #16a34a;
        --danger: #c94b2a;
    }

    .cf-modal-header {
        padding: 1.2rem 1.6rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .cf-modal-header h5 {
            font-family: 'Playfair Display',serif;
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--deep);
            margin: 0;
        }

        .cf-modal-header p {
            font-size: .77rem;
            color: var(--muted);
            margin: .12rem 0 0;
        }

    .cf-close-btn {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: 1.1rem;
        padding: .3rem;
        transition: color .2s;
    }

        .cf-close-btn:hover {
            color: var(--deep);
        }

    /* STAT ROW */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .stat-cell {
        background: var(--cream);
        padding: .75rem 1rem;
    }

    .stat-cell-label {
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-bottom: .15rem;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .stat-cell-val {
        font-size: .9rem;
        font-weight: 700;
        color: var(--deep);
    }

    /* CARD */
    .cf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: .85rem;
    }

        .cf-card:last-child {
            margin-bottom: 0;
        }

    .cf-card-head {
        padding: .7rem 1.2rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .cf-card-title {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cf-card-icon {
        color: var(--gold);
        font-size: .85rem;
    }

    .cf-card-body {
        padding: 1.1rem 1.2rem;
    }

    /* CHIPS */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .7rem;
        font-weight: 700;
        padding: .28rem .65rem;
        border-radius: 4px;
        letter-spacing: .04em;
    }

    .chip-published {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-draft {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .chip-archived {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-category {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .chip-featured {
        background: rgba(212,160,23,.15);
        color: #92660a;
    }

    .chip-tag {
        background: var(--warm);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    /* FEATURED IMG */
    .featured-img-wrap {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--border);
        margin-bottom: .9rem;
    }

        .featured-img-wrap img {
            width: 100%;
            max-height: 280px;
            object-fit: cover;
            display: block;
        }

    /* POST TITLE */
    .post-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.3;
        margin-bottom: .65rem;
    }

    /* EXCERPT */
    .excerpt-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-left: 3px solid var(--gold);
        border-radius: 0 8px 8px 0;
        padding: .85rem 1.1rem;
        font-size: .87rem;
        color: var(--muted);
        font-style: italic;
        line-height: 1.6;
    }

    /* CONTENT */
    .post-content-box {
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.1rem 1.25rem;
        max-height: 360px;
        overflow-y: auto;
        font-size: .875rem;
        line-height: 1.75;
        color: var(--deep);
    }

        .post-content-box img {
            max-width: 100%;
            height: auto;
            border-radius: 6px;
            margin: 1rem 0;
        }

        .post-content-box h1, .post-content-box h2, .post-content-box h3 {
            font-family: 'Playfair Display',serif;
            color: var(--deep);
        }

        .post-content-box a {
            color: var(--gold);
        }

        .post-content-box blockquote {
            border-left: 3px solid var(--gold);
            padding-left: 1rem;
            color: var(--muted);
            font-style: italic;
        }

    /* SEO */
    .seo-row {
        display: grid;
        gap: .65rem;
    }

    .seo-field-label {
        font-size: .66rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-bottom: .25rem;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .seo-field-val {
        font-size: .84rem;
        color: var(--deep);
        padding: .55rem .85rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 6px;
    }

    /* ACTIONS */
    .cf-actions {
        display: flex;
        gap: .75rem;
        padding: .9rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        justify-content: flex-end;
    }

    .btn-primary {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .7rem 1.6rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .22s;
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .btn-secondary {
        padding: .7rem 1.3rem;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 600;
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-secondary:hover {
            border-color: var(--muted);
            color: var(--deep);
        }
</style>

<!-- HEADER -->
<div class="cf-modal-header">
    <div>
        <h5>📄 Chi Tiết <em style="font-style:italic;color:var(--gold);">Bài Viết</em></h5>
        <p>Xem đầy đủ thông tin bài viết</p>
    </div>
    <button type="button" class="cf-close-btn" data-bs-dismiss="modal">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="modal-body" style="padding:1.25rem 1.5rem;background:var(--cream);">

    <!-- STAT ROW -->
    <div class="stat-row">
        <div class="stat-cell">
            <div class="stat-cell-label"><i class="bi bi-calendar-plus" style="color:var(--gold);"></i>Ngày tạo</div>
            <div class="stat-cell-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</div>
        </div>
        @if (Model.PublishedAt.HasValue)
        {
            <div class="stat-cell">
                <div class="stat-cell-label"><i class="bi bi-calendar-check" style="color:var(--success);"></i>Xuất bản</div>
                <div class="stat-cell-val">@Model.PublishedAt.Value.ToString("dd/MM/yyyy")</div>
            </div>
        }
        <div class="stat-cell">
            <div class="stat-cell-label"><i class="bi bi-eye" style="color:#4f46e5;"></i>Lượt xem</div>
            <div class="stat-cell-val">@Model.ViewCount.ToString("N0")</div>
        </div>
        <div class="stat-cell">
            <div class="stat-cell-label"><i class="bi bi-clock" style="color:var(--muted);"></i>Cập nhật</div>
            <div class="stat-cell-val">@Model.UpdatedAt.ToString("dd/MM/yy")</div>
        </div>
    </div>

    <!-- THÔNG TIN BÀI VIẾT -->
    <div class="cf-card">
        <div class="cf-card-head">
            <i class="bi bi-card-heading cf-card-icon"></i>
            <span class="cf-card-title">Thông Tin Bài Viết</span>
        </div>
        <div class="cf-card-body">
            @if (!string.IsNullOrEmpty(Model.FeaturedImage))
            {
                <div class="featured-img-wrap">
                    <img src="@Model.FeaturedImage" alt="@Model.Title" />
                </div>
            }

            <div class="post-title">@Model.Title</div>

            <div style="display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:.9rem;">
                @switch (Model.Status)
                {
                    case "Published":
                        <span class="chip chip-published">✓ Đã Xuất Bản</span>
                        break;
                    case "Draft":
                        <span class="chip chip-draft">● Bản Nháp</span>
                        break;
                    default:
                        <span class="chip chip-archived">⊘ Lưu Trữ</span>
                        break;
                }
                @if (Model.Category != null)
                {
                    <span class="chip chip-category"><i class="bi bi-folder2"></i> @Model.Category.CategoryName</span>
                }
                @if (Model.IsFeatured)
                {
                    <span class="chip chip-featured">⭐ Nổi Bật</span>
                }
                @if (Model.AllowComments)
                {
                    <span class="chip" style="background:rgba(6,182,212,.08);color:#0e7490;">💬 Bình luận bật</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Excerpt))
            {
                <div class="excerpt-box">@Model.Excerpt</div>
            }

            @if (!string.IsNullOrEmpty(Model.Tags))
            {
                <div style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.75rem;">
                    @foreach (var tag in Model.Tags.Split(','))
                    {
                        <span class="chip chip-tag">#@tag.Trim()</span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- NỘI DUNG -->
    <div class="cf-card">
        <div class="cf-card-head">
            <i class="bi bi-body-text cf-card-icon"></i>
            <span class="cf-card-title">Nội Dung</span>
        </div>
        <div class="cf-card-body">
            <div class="post-content-box">
                @Html.Raw(Model.Content)
            </div>
        </div>
    </div>

    <!-- SEO (chỉ hiện nếu có dữ liệu) -->
    @if (!string.IsNullOrEmpty(Model.MetaTitle) || !string.IsNullOrEmpty(Model.MetaDescription))
    {
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-search cf-card-icon"></i>
                <span class="cf-card-title">Thông Tin SEO</span>
            </div>
            <div class="cf-card-body">
                <div class="seo-row">
                    @if (!string.IsNullOrEmpty(Model.MetaTitle))
                    {
                        <div>
                            <div class="seo-field-label"><i class="bi bi-type-h1"></i> Meta Title</div>
                            <div class="seo-field-val">@Model.MetaTitle</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.MetaDescription))
                    {
                        <div>
                            <div class="seo-field-label"><i class="bi bi-text-paragraph"></i> Meta Description</div>
                            <div class="seo-field-val">@Model.MetaDescription</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

</div>

<!-- ACTIONS -->
<div class="cf-actions">
    <button type="button" class="btn-secondary" data-bs-dismiss="modal">
        <i class="bi bi-x"></i> Đóng
    </button>
    <button type="button" class="btn-primary" onclick="openEditFromDetails(@Model.PostId)">
        <i class="bi bi-pencil"></i> Chỉnh Sửa
    </button>
</div>

<script>
    function openEditFromDetails(id) {
        const m = bootstrap.Modal.getInstance(document.getElementById('modalPost'));
        if (m) m.hide();
        setTimeout(() => openEditModal(id), 300);
    }
</script>
