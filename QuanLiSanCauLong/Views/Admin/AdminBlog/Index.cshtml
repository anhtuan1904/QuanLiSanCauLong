@model IEnumerable<QuanLiSanCauLong.Models.BlogPost>
@{
    ViewData["Title"] = "Quản Lý Bài Viết";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --success: #16a34a;
        --danger: #c94b2a;
    }

    body, * {
        font-family: 'Outfit', sans-serif;
    }

    /* ── HEADER ── */
    .idx-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
    }

    .idx-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.85rem;
        font-weight: 700;
        color: var(--deep);
    }

        .idx-title em {
            font-style: italic;
            color: var(--gold);
        }

    .add-btn {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .72rem 1.5rem;
        font-family: 'Outfit',sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        text-decoration: none;
        transition: all .22s;
    }

        .add-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
            color: var(--deep);
        }

    /* ── STAT STRIP ── */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.1rem 1.4rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .7rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    /* ── TOOLBAR ── */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 9px;
        padding: .6rem .8rem;
    }

    .toolbar-sep {
        width: 1px;
        height: 22px;
        background: var(--border);
        flex-shrink: 0;
    }

    .tb-search {
        position: relative;
        flex: 1;
        min-width: 180px;
        max-width: 260px;
    }

        .tb-search input {
            width: 100%;
            padding: .52rem .85rem .52rem 2.1rem;
            border: 1.5px solid var(--border);
            border-radius: 6px;
            font-family: 'Outfit',sans-serif;
            font-size: .83rem;
            color: var(--deep);
            background: var(--cream);
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
            }

        .tb-search i {
            position: absolute;
            left: .7rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

    .tb-sel {
        padding: .52rem .85rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: var(--cream);
        outline: none;
        cursor: pointer;
        transition: border-color .2s;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    /* FILTER CHIPS (status quick filter) */
    .filter-chips {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .fchip {
        padding: .35rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 20px;
        font-size: .76rem;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
        color: var(--muted);
        transition: all .18s;
        white-space: nowrap;
    }

        .fchip:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

        .fchip.active {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .view-btns {
        display: flex;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        margin-left: auto;
    }

    .vb {
        padding: .5rem .8rem;
        background: #fff;
        border: none;
        cursor: pointer;
        font-size: .8rem;
        color: var(--muted);
        transition: all .15s;
    }

        .vb.active {
            background: var(--deep);
            color: var(--gold2);
        }

        .vb:hover:not(.active) {
            background: var(--warm);
        }

    /* ── TABLE ── */
    .idx-table-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .idx-table {
        width: 100%;
        border-collapse: collapse;
    }

        .idx-table th {
            background: var(--warm);
            padding: .75rem 1rem;
            font-size: .66rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .idx-table td {
            padding: .85rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .86rem;
            vertical-align: middle;
            color: var(--deep);
        }

        .idx-table tr:last-child td {
            border-bottom: none;
        }

        .idx-table tr:hover td {
            background: var(--cream);
        }

    /* POST CELL */
    .post-badge {
        width: 38px;
        height: 36px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display',serif;
        font-weight: 700;
        font-size: .85rem;
        color: var(--deep);
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        flex-shrink: 0;
    }

    .post-name-cell {
        display: flex;
        align-items: center;
        gap: .7rem;
    }

    .pn-info .pn-title {
        font-weight: 700;
        font-size: .87rem;
        color: var(--deep);
        line-height: 1.2;
    }

    .pn-info .pn-sub {
        font-size: .71rem;
        color: var(--muted);
        margin-top: .12rem;
    }

    /* CHIPS */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .68rem;
        font-weight: 700;
        padding: .25rem .6rem;
        border-radius: 4px;
        letter-spacing: .04em;
    }

    .chip-published {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-draft {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .chip-archived {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-category {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .chip-featured {
        background: rgba(212,160,23,.15);
        color: #92660a;
    }

    .chip-tag {
        background: var(--warm);
        color: var(--muted);
        border: 1px solid var(--border);
    }

    /* ACTION BUTTONS */
    .act-g {
        display: flex;
        gap: .3rem;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .18s;
        font-size: .78rem;
        text-decoration: none;
    }

        .act-b:hover.view {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.07);
        }

        .act-b:hover.edit {
            border-color: #4f46e5;
            color: #4f46e5;
            background: rgba(79,70,229,.07);
        }

        .act-b:hover.del {
            border-color: var(--danger);
            color: var(--danger);
            background: rgba(201,75,42,.07);
        }

    /* CARD VIEW */
    .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(295px,1fr));
        gap: 1.1rem;
    }

    .pc {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition: all .2s;
    }

        .pc:hover {
            box-shadow: 0 5px 20px rgba(26,18,9,.08);
            transform: translateY(-2px);
        }

    .pc-img {
        position: relative;
        aspect-ratio: 16/9;
        background: var(--warm);
    }

        .pc-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .pc-img-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 2rem;
        opacity: .22;
    }

    .pc-status {
        position: absolute;
        top: .6rem;
        right: .6rem;
    }

    .pc-featured-badge {
        position: absolute;
        top: .6rem;
        left: .6rem;
    }

    .pc-body {
        padding: 1rem 1.15rem;
    }

    .pc-title {
        font-weight: 700;
        font-size: .93rem;
        color: var(--deep);
        margin-bottom: .28rem;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .pc-category {
        font-size: .74rem;
        color: var(--muted);
        margin-bottom: .65rem;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .pc-category i {
            color: var(--gold);
        }

    .pc-excerpt {
        font-size: .77rem;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.5;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .pc-footer {
        padding: .75rem 1.15rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .pc-meta {
        font-size: .73rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    /* ALERTS */
    .sys-alert {
        padding: .85rem 1.2rem;
        border-radius: 8px;
        margin-bottom: 1.1rem;
        font-size: .83rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #16a34a;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    /* EMPTY */
    .empty-state {
        text-align: center;
        padding: 3.5rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 2.8rem;
            display: block;
            margin-bottom: .9rem;
            opacity: .28;
        }

    /* MODAL */
    .modal-content {
        border: 1px solid var(--border);
        border-radius: 14px;
        font-family: 'Outfit',sans-serif;
        overflow: hidden;
    }

    /* RESULT COUNT */
    .result-count {
        font-size: .78rem;
        color: var(--muted);
        padding: .25rem 0;
    }

        .result-count strong {
            color: var(--deep);
        }

    .hidden {
        display: none !important;
    }
</style>

<div>
    <!-- HEADER -->
    <div class="idx-head">
        <div>
            <h1 class="idx-title">Quản Lý <em>Bài Viết</em></h1>
            <div style="font-size:.8rem;color:var(--muted);margin-top:.2rem;">
                Tổng cộng @(Model?.Count() ?? 0) bài viết trong hệ thống
            </div>
        </div>
        <button class="add-btn" data-bs-toggle="modal" data-bs-target="#modalPost" onclick="openCreateModal()">
            <i class="bi bi-plus-circle"></i> Thêm Bài Viết
        </button>
    </div>

    <!-- ALERTS -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i>@TempData["ErrorMessage"]</div>
    }

    <!-- STATS -->
    <div class="stat-strip">
        <div class="stat-box">
            <div class="stat-n">@(Model?.Count() ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng Bài Viết</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@(Model?.Count(p => p.Status == "Published") ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Đã Xuất Bản</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#92660a;">@(Model?.Count(p => p.Status == "Draft") ?? 0)</div>
            <div class="stat-l"><span class="stat-dot" style="background:#92660a;"></span>Bản Nháp</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#4f46e5;">@(Model?.Sum(p => p.ViewCount).ToString("N0") ?? "0")</div>
            <div class="stat-l"><span class="stat-dot" style="background:#4f46e5;"></span>Tổng Lượt Xem</div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <!-- Search -->
        <div class="tb-search">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Tìm bài viết..." id="searchInput" oninput="applyFilters()" />
        </div>

        <div class="toolbar-sep"></div>

        <!-- Category filter -->
        <select class="tb-sel" id="catFilter" onchange="applyFilters()">
            <option value="">Tất cả danh mục</option>
            @foreach (var cat in ViewBag.Categories as List<QuanLiSanCauLong.Models.BlogCategory> ?? new())
            {
                <option value="@cat.CategoryName.ToLower()">@cat.CategoryName</option>
            }
        </select>

        <div class="toolbar-sep"></div>

        <!-- Status quick chips -->
        <div class="filter-chips">
            <span class="fchip active" data-status="" onclick="setStatusFilter(this,'')">Tất cả</span>
            <span class="fchip" data-status="published" onclick="setStatusFilter(this,'published')">✓ Đã xuất bản</span>
            <span class="fchip" data-status="draft" onclick="setStatusFilter(this,'draft')">● Nháp</span>
            <span class="fchip" data-status="archived" onclick="setStatusFilter(this,'archived')">⊘ Lưu trữ</span>
        </div>

        <!-- View toggle -->
        <div class="view-btns">
            <button type="button" class="vb" id="vbTable" onclick="switchView('table')" title="Dạng bảng">
                <i class="bi bi-table"></i>
            </button>
            <button type="button" class="vb active" id="vbCard" onclick="switchView('card')" title="Dạng thẻ">
                <i class="bi bi-grid-3x3-gap"></i>
            </button>
        </div>
    </div>

    <!-- Result count -->
    <div class="result-count" id="resultCount" style="margin-bottom:.7rem;"></div>

    <!-- ═══ TABLE VIEW ═══ -->
    <div id="tableView" class="idx-table-wrap hidden">
        <table class="idx-table">
            <thead>
                <tr>
                    <th>Bài Viết</th>
                    <th>Danh Mục</th>
                    <th>Trạng Thái</th>
                    <th>Lượt Xem</th>
                    <th>Ngày Tạo</th>
                    <th style="text-align:right;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Any() == true)
                {
                    foreach (var post in Model)
                    {
                        <tr class="post-row"
                            data-title="@post.Title.ToLower()"
                            data-category="@(post.Category?.CategoryName?.ToLower() ?? "")"
                            data-status="@post.Status.ToLower()">
                            <td>
                                <div class="post-name-cell">
                                    @if (!string.IsNullOrEmpty(post.FeaturedImage))
                                    {
                                        <img src="@post.FeaturedImage" style="width:48px;height:36px;object-fit:cover;border-radius:6px;border:1px solid var(--border);flex-shrink:0;" alt="" />
                                    }
                                    else
                                    {
                                        <div class="post-badge">✍</div>
                                    }
                                    <div class="pn-info">
                                        <div class="pn-title">
                                            @if (post.IsFeatured)
                                            {
                                                <i class="bi bi-star-fill" style="color:var(--gold);font-size:.68rem;margin-right:.25rem;"></i>
                                            }
                                            @post.Title
                                        </div>
                                        @if (!string.IsNullOrEmpty(post.Excerpt))
                                        {
                                            <div class="pn-sub">@(post.Excerpt.Length > 60 ? post.Excerpt.Substring(0, 60) + "…" : post.Excerpt)</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="chip chip-category">@(post.Category?.CategoryName ?? "—")</span>
                            </td>
                            <td>
                                @switch (post.Status)
                                {
                                    case "Published":
                                        <span class="chip chip-published">✓ Xuất bản</span>
                                        break;
                                    case "Draft":
                                        <span class="chip chip-draft">● Nháp</span>
                                        break;
                                    default:
                                        <span class="chip chip-archived">⊘ Lưu trữ</span>
                                        break;
                                }
                            </td>
                            <td style="font-size:.81rem;color:var(--muted);">
                                <i class="bi bi-eye"></i> @post.ViewCount.ToString("N0")
                            </td>
                            <td style="font-size:.81rem;color:var(--muted);">@post.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="act-g" style="justify-content:flex-end;">
                                    <button class="act-b view" onclick="openViewModal(@post.PostId)" title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="act-b edit" title="Sửa"
                                            onclick="openEditModal(@post.PostId)"
                                            data-bs-toggle="modal" data-bs-target="#modalPost">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="act-b del"
                                            onclick="confirmDelete(@post.PostId,'@Html.Raw(post.Title.Replace("'", "&#39;"))')"
                                            title="Xóa">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        @if (Model?.Any() != true)
        {
            <div class="empty-state">
                <i class="bi bi-newspaper"></i>
                <div>Không có bài viết nào.</div>
                <button class="add-btn" style="display:inline-flex;margin-top:.75rem;"
                        data-bs-toggle="modal" data-bs-target="#modalPost" onclick="openCreateModal()">
                    + Thêm bài viết mới
                </button>
            </div>
        }
        <div class="empty-state hidden" id="tableEmpty" style="padding:2.5rem;">
            <i class="bi bi-search" style="font-size:2rem;"></i>
            <div style="margin-top:.5rem;">Không tìm thấy bài viết phù hợp</div>
        </div>
    </div>

    <!-- ═══ CARD VIEW ═══ -->
    <div id="cardView" class="posts-grid">
        @if (Model?.Any() == true)
        {
            foreach (var post in Model)
            {
                <div class="pc post-card-item"
                     data-title="@post.Title.ToLower()"
                     data-category="@(post.Category?.CategoryName?.ToLower() ?? "")"
                     data-status="@post.Status.ToLower()">
                    <div class="pc-img">
                        @if (!string.IsNullOrEmpty(post.FeaturedImage))
                        {
                            <img src="@post.FeaturedImage" alt="@post.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="pc-img-empty"><i class="bi bi-newspaper"></i></div>
                        }
                        <div class="pc-status">
                            @switch (post.Status)
                            {
                                case "Published":
                                    <span class="chip chip-published">✓ Xuất bản</span>
                                    break;
                                case "Draft":
                                    <span class="chip chip-draft">● Nháp</span>
                                    break;
                                default:
                                    <span class="chip chip-archived">⊘ Lưu trữ</span>
                                    break;
                            }
                        </div>
                        @if (post.IsFeatured)
                        {
                            <div class="pc-featured-badge">
                                <span class="chip chip-featured">⭐ Nổi bật</span>
                            </div>
                        }
                    </div>
                    <div class="pc-body">
                        <div class="pc-title">@post.Title</div>
                        <div class="pc-category">
                            <i class="bi bi-folder2"></i>
                            @(post.Category?.CategoryName ?? "—")
                            @if (!string.IsNullOrEmpty(post.Tags))
                            {
                                <span style="color:var(--border);">·</span>
                                @post.Tags.Split(',').First().Trim()
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(post.Excerpt))
                        {
                            <div class="pc-excerpt">@post.Excerpt</div>
                        }
                    </div>
                    <div class="pc-footer">
                        <div class="pc-meta">
                            <i class="bi bi-eye"></i>
                            @post.ViewCount.ToString("N0")
                            <span style="color:var(--border);">·</span>
                            @post.CreatedAt.ToString("dd/MM/yy")
                        </div>
                        <div class="act-g">
                            <button class="act-b view" onclick="openViewModal(@post.PostId)" title="Xem">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="act-b edit" title="Sửa"
                                    onclick="openEditModal(@post.PostId)"
                                    data-bs-toggle="modal" data-bs-target="#modalPost">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="act-b del"
                                    onclick="confirmDelete(@post.PostId,'@Html.Raw(post.Title.Replace("'", "&#39;"))')"
                                    title="Xóa">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state" style="grid-column:1/-1;">
                <i class="bi bi-newspaper"></i>
                <div>Không tìm thấy bài viết nào.</div>
                <button class="add-btn" style="display:inline-flex;margin-top:.75rem;"
                        data-bs-toggle="modal" data-bs-target="#modalPost" onclick="openCreateModal()">
                    + Thêm bài viết mới
                </button>
            </div>
        }
        <div class="empty-state hidden" id="cardEmpty" style="grid-column:1/-1;padding:2.5rem;">
            <i class="bi bi-search" style="font-size:2rem;"></i>
            <div style="margin-top:.5rem;">Không tìm thấy bài viết phù hợp</div>
        </div>
    </div>

</div>

<!-- MODAL -->
<div class="modal fade" id="modalPost" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" id="modalPostContent">
            <div style="padding:3rem;text-align:center;color:var(--muted);">
                <div class="spinner-border" style="color:var(--gold);"></div>
                <p style="margin-top:.75rem;font-size:.84rem;">Đang tải...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/tinymce/tinymce.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        /* ── FIX TINYMCE IN MODAL ── */
        document.addEventListener('focusin', (e) => {
            if (e.target.closest(".tox-tinymce-aux, .moxman-window, .tam-assetmanager-root") !== null) {
                e.stopImmediatePropagation();
            }
        });

        let currentEditor = null;

        function openCreateModal() {
            destroyEditor();
            const el = document.getElementById('modalPostContent');
            el.innerHTML = loadingHtml();
            fetch('/AdminBlog/Create')
                .then(r => r.text())
                .then(html => { el.innerHTML = html; setTimeout(initTinyMCE, 200); });
        }

        function openEditModal(id) {
            destroyEditor();
            const el = document.getElementById('modalPostContent');
            el.innerHTML = loadingHtml();
            const modal = new bootstrap.Modal(document.getElementById('modalPost'));
            modal.show();
            fetch('/AdminBlog/Edit/' + id)
                .then(r => r.text())
                .then(html => { el.innerHTML = html; setTimeout(initTinyMCE, 200); });
        }

        function openViewModal(id) {
            destroyEditor();
            const el = document.getElementById('modalPostContent');
            el.innerHTML = loadingHtml();
            const modal = new bootstrap.Modal(document.getElementById('modalPost'));
            modal.show();
            fetch('/AdminBlog/Details/' + id)
                .then(r => r.text())
                .then(html => { el.innerHTML = html; });
        }

        function loadingHtml() {
            return '<div style="padding:3rem;text-align:center;color:var(--muted);"><div class="spinner-border" style="color:var(--gold);"></div><p style="margin-top:.75rem;font-size:.84rem;">Đang tải...</p></div>';
        }

        function destroyEditor() {
            if (currentEditor) { currentEditor.remove(); currentEditor = null; }
        }

        function initTinyMCE() {
            const textarea = document.querySelector('#editor-content');
            if (!textarea) return;
            tinymce.init({
                selector: '#editor-content', height: 460, menubar: true,
                plugins: ['advlist','autolink','lists','link','image','charmap','preview',
                    'anchor','searchreplace','visualblocks','code','fullscreen',
                    'insertdatetime','media','table','help','wordcount'],
                toolbar: 'undo redo | blocks fontsize | bold italic underline forecolor backcolor | ' +
                    'alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | ' +
                    'removeformat | link image media table | code fullscreen help',
                base_url: '/lib/tinymce', suffix: '.min',
                content_style: 'body { font-family: Outfit, sans-serif; font-size:15px; line-height:1.75; padding:12px; }',
                images_upload_handler: function(blobInfo, success, failure) {
                    const reader = new FileReader();
                    reader.onload = () => success(reader.result);
                    reader.onerror = () => failure('Upload thất bại');
                    reader.readAsDataURL(blobInfo.blob());
                },
                paste_data_images: true,
                setup: function(editor) {
                    currentEditor = editor;
                    editor.on('change input undo redo', function() { editor.save(); });
                }
            });
        }

        document.getElementById('modalPost').addEventListener('hidden.bs.modal', destroyEditor);

        /* ── VIEW TOGGLE ── */
        let currentView = 'card';
        function switchView(v) {
            currentView = v;
            document.getElementById('tableView').classList.toggle('hidden', v !== 'table');
            document.getElementById('cardView').classList.toggle('hidden', v !== 'card');
            document.getElementById('vbTable').classList.toggle('active', v === 'table');
            document.getElementById('vbCard').classList.toggle('active', v === 'card');
            localStorage.setItem('blogView', v);
            updateResultCount();
        }

        /* ── FILTERS ── */
        let activeStatus = '';

        function setStatusFilter(el, status) {
            document.querySelectorAll('.fchip').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            activeStatus = status;
            applyFilters();
        }

        function applyFilters() {
            const q   = (document.getElementById('searchInput').value || '').toLowerCase().trim();
            const cat = (document.getElementById('catFilter').value || '').toLowerCase();
            const rows = document.querySelectorAll('.post-row, .post-card-item');
            let shown = 0;

            rows.forEach(el => {
                const title    = (el.dataset.title || '');
                const elCat    = (el.dataset.category || '');
                const elStatus = (el.dataset.status || '');

                const matchQ   = !q   || title.includes(q);
                const matchCat = !cat || elCat === cat;
                const matchSt  = !activeStatus || elStatus === activeStatus;

                const visible = matchQ && matchCat && matchSt;
                el.style.display = visible ? '' : 'none';
                if (visible) shown++;
            });

            // empty states
            document.getElementById('tableEmpty')?.classList.toggle('hidden', shown > 0);
            document.getElementById('cardEmpty')?.classList.toggle('hidden', shown > 0);
            updateResultCount(shown, rows.length);
        }

        function updateResultCount(shown, total) {
            const el = document.getElementById('resultCount');
            if (!el) return;
            if (shown === undefined) {
                const rows = document.querySelectorAll('.post-row, .post-card-item');
                shown = [...rows].filter(r => r.style.display !== 'none').length;
                total = rows.length / 2; // table + card = double
            }
            // Each post appears once in table and once in card, so divide by 2
            const actualShown = currentView === 'table'
                ? document.querySelectorAll('.post-row:not([style*="none"])').length
                : document.querySelectorAll('.post-card-item:not([style*="none"])').length;
            el.innerHTML = `Hiển thị <strong>${actualShown}</strong> bài viết`;
        }

        /* ── DELETE ── */
        function confirmDelete(id, title) {
            Swal.fire({
                title: 'Xóa bài viết này?',
                html: `Bài viết <strong>${title}</strong> sẽ bị xóa vĩnh viễn!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c94b2a',
                cancelButtonColor: '#8a7560',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy',
                reverseButtons: true
            }).then(r => {
                if (!r.isConfirmed) return;
                const fd = new FormData();
                fd.append('__RequestVerificationToken',
                    document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
                fetch('/AdminBlog/Delete/' + id, { method:'POST', body:fd })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({ icon:'success', title:'Đã xóa!', text:data.message, timer:1500, showConfirmButton:false })
                                .then(() => location.reload());
                        } else {
                            Swal.fire('Lỗi!', data.message, 'error');
                        }
                    })
                    .catch(() => Swal.fire('Lỗi!', 'Không thể kết nối máy chủ', 'error'));
            });
        }

        /* ── INIT ── */
        (function () {
            const saved = localStorage.getItem('blogView') || 'card';
            switchView(saved);
            updateResultCount();
        })();
    </script>
}
