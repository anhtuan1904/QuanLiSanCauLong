@model QuanLiSanCauLong.Models.BlogPost
@{
    ViewData["Title"] = Model.MetaTitle ?? Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--cream);
    }

    /* ── HERO / COVER ── */
    .read-hero {
        background: var(--deep);
        position: relative;
        overflow: hidden;
    }

    .read-hero-cover {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        display: block;
        opacity: .55;
    }

    .read-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 20%, rgba(26,18,9,.85) 100%);
    }

    .read-hero-no-img {
        height: 180px;
        background: linear-gradient(135deg, var(--deep), #2d1f0a);
    }

    .read-hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2rem 1.5rem 2rem;
        max-width: 820px;
        margin: 0 auto;
    }

    .read-hero-no-img + .read-hero-content {
        position: static;
        padding: 2.5rem 1.5rem 2rem;
        max-width: 820px;
        margin: 0 auto;
    }

    .read-archived-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(212,160,23,.2);
        border: 1px solid rgba(212,160,23,.4);
        color: var(--gold2);
        font-size: .72rem;
        font-weight: 700;
        padding: .3rem .75rem;
        border-radius: 4px;
        margin-bottom: .75rem;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .read-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.5rem, 3.5vw, 2.2rem);
        font-weight: 700;
        color: #fff;
        line-height: 1.3;
        margin: 0 0 .75rem;
    }

    .read-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .8rem;
        font-size: .78rem;
        color: rgba(255,255,255,.6);
        align-items: center;
    }

        .read-meta i {
            margin-right: .25rem;
        }

    /* ── LAYOUT ── */
    .read-wrap {
        max-width: 820px;
        margin: 0 auto;
        padding: 2.5rem 1.25rem 4rem;
    }

    /* ── BACK ── */
    .read-back {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: color .2s;
    }

        .read-back:hover {
            color: var(--deep);
        }

    /* ── CONTENT ── */
    .read-content {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 2rem 2.25rem;
        line-height: 1.85;
        font-size: .96rem;
        color: var(--deep);
    }

        .read-content h1, .read-content h2, .read-content h3 {
            font-family: 'Playfair Display', serif;
            color: var(--deep);
            margin-top: 1.75rem;
        }

        .read-content img {
            max-width: 100%;
            border-radius: 8px;
            margin: 1rem 0;
        }

        .read-content a {
            color: var(--gold);
        }

        .read-content blockquote {
            border-left: 3px solid var(--gold);
            margin: 1.5rem 0;
            padding: .75rem 1.25rem;
            background: var(--warm);
            border-radius: 0 8px 8px 0;
            font-style: italic;
            color: var(--muted);
        }

        .read-content table {
            width: 100%;
            border-collapse: collapse;
            margin: 1rem 0;
        }

            .read-content table th, .read-content table td {
                border: 1px solid var(--border);
                padding: .55rem .85rem;
                font-size: .88rem;
            }

            .read-content table th {
                background: var(--warm);
                font-weight: 700;
            }

    /* ── EXCERPT ── */
    .read-excerpt {
        background: var(--warm);
        border-left: 3px solid var(--gold);
        padding: .9rem 1.25rem;
        border-radius: 0 8px 8px 0;
        font-size: .88rem;
        color: var(--muted);
        font-style: italic;
        margin-bottom: 1.5rem;
    }

    /* ── ARCHIVE NOTICE ── */
    .arc-notice {
        background: rgba(212,160,23,.08);
        border: 1px solid rgba(212,160,23,.3);
        border-radius: 10px;
        padding: .85rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        font-size: .83rem;
        color: #92660a;
        margin-bottom: 1.5rem;
    }

        .arc-notice i {
            font-size: 1.1rem;
            flex-shrink: 0;
        }
</style>

<!-- HERO -->
<div class="read-hero">
    @if (!string.IsNullOrEmpty(Model.FeaturedImage))
    {
        <img class="read-hero-cover" src="@Model.FeaturedImage" alt="@Model.Title" />
        <div class="read-hero-overlay"></div>
        <div class="read-hero-content">
            <h1 class="read-title">@Model.Title</h1>
            <div class="read-meta">
                <span><i class="bi bi-calendar3"></i>@((Model.PublishedAt ?? Model.CreatedAt).ToString("dd/MM/yyyy"))</span>
                <span><i class="bi bi-eye"></i>@Model.ViewCount.ToString("N0") lượt xem</span>
                @if (Model.IsFeatured)
                {
                    <span>⭐ Nổi bật</span>
                }
            </div>
        </div>
    }
    else
    {
        <div class="read-hero-no-img"></div>
        <div class="read-hero-content" style="position:static;padding:2.5rem 1.5rem 2rem;max-width:820px;margin:0 auto;">
            <h1 class="read-title">@Model.Title</h1>
            <div class="read-meta">
                <span><i class="bi bi-calendar3"></i>@((Model.PublishedAt ?? Model.CreatedAt).ToString("dd/MM/yyyy"))</span>
                <span><i class="bi bi-eye"></i>@Model.ViewCount.ToString("N0") lượt xem</span>
                @if (Model.IsFeatured)
                {
                    <span>⭐ Nổi bật</span>
                }
            </div>
        </div>
    }
</div>

<div class="read-wrap">

    <a href="/Blog" class="read-back"><i class="bi bi-arrow-left"></i> Về trang tin tức</a>

    @if (!string.IsNullOrEmpty(Model.Excerpt))
    {
        <div class="read-excerpt">@Model.Excerpt</div>
    }

    <div class="read-content">
        @Html.Raw(Model.Content)
    </div>

</div>
