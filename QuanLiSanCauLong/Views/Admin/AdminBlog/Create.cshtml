@model QuanLiSanCauLong.Models.BlogPost
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --success: #16a34a;
        --danger: #c94b2a;
    }

    /* ── HEADER ── */
    .cf-modal-header {
        padding: 1.2rem 1.6rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .cf-modal-header h5 {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--deep);
            margin: 0;
        }

        .cf-modal-header p {
            font-size: .78rem;
            color: var(--muted);
            margin: .15rem 0 0;
        }

    .cf-close-btn {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: 1.1rem;
        padding: .3rem;
        transition: color .2s;
        line-height: 1;
    }

        .cf-close-btn:hover {
            color: var(--deep);
        }

    /* ── LAYOUT: 2 columns ── */
    .form-layout {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 1rem;
        padding: 1.25rem 1.5rem;
        background: var(--cream);
    }

    .col-main {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .col-side {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* ── CARD ── */
    .cf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .cf-card-head {
        padding: .7rem 1.2rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .cf-card-title {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cf-card-icon {
        color: var(--gold);
        font-size: .85rem;
    }

    .cf-card-body {
        padding: 1.1rem 1.2rem;
    }

    /* ── FIELD ── */
    .fg {
        margin-bottom: .9rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-label {
        display: block;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .35rem;
    }

        .fg-label .req {
            color: var(--danger);
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s, background .2s;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 72px;
    }

    .fg-hint {
        font-size: .69rem;
        color: var(--muted);
        margin-top: .25rem;
    }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    /* ── STATUS PICKER ── */
    .status-opts {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .55rem;
        padding: .5rem .85rem;
        border: 2px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
        font-size: .83rem;
        font-weight: 600;
        color: var(--deep);
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.45);
            background: rgba(212,160,23,.03);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ── TOGGLE SWITCH ── */
    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .55rem .1rem;
        border-bottom: 1px solid var(--border);
    }

        .toggle-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .toggle-row:first-child {
            padding-top: 0;
        }

    .toggle-label {
        font-size: .83rem;
        font-weight: 500;
        color: var(--deep);
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .toggle-switch {
        position: relative;
        width: 36px;
        height: 20px;
        flex-shrink: 0;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-track {
        position: absolute;
        inset: 0;
        background: #ddd;
        border-radius: 20px;
        cursor: pointer;
        transition: background .2s;
    }

        .toggle-track::after {
            content: '';
            position: absolute;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #fff;
            top: 3px;
            left: 3px;
            transition: transform .2s;
            box-shadow: 0 1px 3px rgba(0,0,0,.2);
        }

    .toggle-switch input:checked + .toggle-track {
        background: var(--gold);
    }

        .toggle-switch input:checked + .toggle-track::after {
            transform: translateX(16px);
        }

    /* ── IMAGE UPLOAD ZONE ── */
    .img-drop-zone {
        border: 2px dashed var(--border);
        border-radius: 8px;
        padding: 1.2rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        position: relative;
        overflow: hidden;
    }

        .img-drop-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.03);
        }

        .img-drop-zone.has-img {
            padding: 0;
            border-style: solid;
            border-color: var(--border);
        }

        .img-drop-zone input[type=file] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

    .img-placeholder {
        color: var(--muted);
        pointer-events: none;
    }

        .img-placeholder i {
            font-size: 1.6rem;
            display: block;
            margin-bottom: .4rem;
        }

        .img-placeholder span {
            font-size: .78rem;
        }

    .img-preview-wrap {
        position: relative;
    }

        .img-preview-wrap img {
            width: 100%;
            max-height: 160px;
            object-fit: cover;
            display: block;
            border-radius: 6px;
        }

    .img-remove-btn {
        position: absolute;
        top: 6px;
        right: 6px;
        background: rgba(0,0,0,.6);
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        cursor: pointer;
        font-size: .7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
    }

        .img-remove-btn:hover {
            background: var(--danger);
        }

    /* ── SEO COLLAPSIBLE ── */
    .seo-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        padding: .7rem 1.2rem;
        border-bottom: none;
        user-select: none;
    }

        .seo-toggle:hover {
            background: rgba(212,160,23,.04);
        }

        .seo-toggle .seo-icon {
            transition: transform .25s;
        }

        .seo-toggle.open .seo-icon {
            transform: rotate(180deg);
        }

    .seo-body {
        display: none;
        padding: 1.1rem 1.2rem;
        border-top: 1px solid var(--border);
    }

        .seo-body.open {
            display: block;
        }

    .char-counter {
        font-size: .69rem;
        color: var(--muted);
        margin-top: .2rem;
        text-align: right;
    }

        .char-counter.warn {
            color: #d97706;
        }

        .char-counter.danger {
            color: var(--danger);
        }

    /* ── ACTIONS ── */
    .cf-actions {
        display: flex;
        gap: .75rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        justify-content: flex-end;
        position: sticky;
        bottom: 0;
        z-index: 10;
        flex-shrink: 0;
    }

    .btn-save {
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        color: var(--deep);
        border: none;
        padding: .72rem 1.8rem;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .22s;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
        }

    .btn-cancel {
        padding: .72rem 1.3rem;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 600;
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }

    /* ── VALIDATION ── */
    .field-error {
        font-size: .71rem;
        color: var(--danger);
        margin-top: .25rem;
    }

    .fg-input.error, .fg-select.error, .fg-textarea.error {
        border-color: var(--danger);
    }
</style>

<!-- HEADER -->
<div class="cf-modal-header">
    <div>
        <h5>✍️ Thêm <em style="font-style:italic;color:var(--gold);">Bài Viết Mới</em></h5>
        <p>Điền thông tin và xuất bản bài viết</p>
    </div>
    <button type="button" class="cf-close-btn" onclick="closePostModal()" title="Đóng">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data"
      id="blogCreateForm" onsubmit="return validateAndSync()">
    @Html.AntiForgeryToken()

    <div class="modal-body" style="padding:0;overflow-y:auto;max-height:calc(85vh - 130px);">
        <div class="form-layout">

            <!-- ═══ LEFT / MAIN ═══ -->
            <div class="col-main">

                <!-- 1. THÔNG TIN CƠ BẢN -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-card-heading cf-card-icon"></i>
                        <span class="cf-card-title">Thông Tin Cơ Bản</span>
                    </div>
                    <div class="cf-card-body">
                        <input asp-for="CategoryId" type="hidden" value="1" />
                        <div class="fg">
                            <label class="fg-label">Tiêu Đề <span class="req">*</span></label>
                            <input asp-for="Title" class="fg-input" id="titleInput"
                                   placeholder="Nhập tiêu đề hấp dẫn..." autocomplete="off"
                                   oninput="autoFillSeoTitle(this.value)" />
                            <span asp-validation-for="Title" class="field-error"></span>
                        </div>
                        <div class="fg" style="margin-bottom:0">
                            <label class="fg-label">Tóm Tắt</label>
                            <textarea asp-for="Excerpt" class="fg-textarea" rows="2"
                                      placeholder="Mô tả ngắn hiển thị ở danh sách bài viết (≤ 200 ký tự)..."
                                      maxlength="200"
                                      oninput="updateCounter('excerptLen', this.value.length, 200)"></textarea>
                            <div class="char-counter" id="excerptLen">0 / 200</div>
                        </div>
                    </div>
                </div>

                <!-- 2. NỘI DUNG -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-body-text cf-card-icon"></i>
                        <span class="cf-card-title">Nội Dung Bài Viết</span>
                    </div>
                    <div class="cf-card-body" style="padding-bottom:0">
                        <textarea asp-for="Content" id="editor-content" class="fg-textarea" rows="8"
                                  placeholder="Nhập nội dung bài viết..."></textarea>
                    </div>
                </div>

                <!-- 3. SEO (collapse) -->
                <div class="cf-card">
                    <div class="cf-card-head seo-toggle" id="seoToggle" onclick="toggleSEO()">
                        <div style="display:flex;align-items:center;gap:.45rem;">
                            <i class="bi bi-search cf-card-icon"></i>
                            <span class="cf-card-title">Tối Ưu SEO</span>
                            <span style="font-size:.69rem;color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;">(tuỳ chọn)</span>
                        </div>
                        <i class="bi bi-chevron-down seo-icon" style="color:var(--muted);font-size:.8rem;"></i>
                    </div>
                    <div class="seo-body" id="seoBody">
                        <div class="fg">
                            <label class="fg-label">Meta Title</label>
                            <input asp-for="MetaTitle" id="metaTitleInput" class="fg-input"
                                   placeholder="Để trống = dùng tiêu đề bài viết" />
                        </div>
                        <div class="fg" style="margin-bottom:0">
                            <label class="fg-label">Meta Description</label>
                            <textarea asp-for="MetaDescription" class="fg-textarea" rows="2"
                                      placeholder="Mô tả cho Google (tối đa 160 ký tự)..."
                                      maxlength="160"
                                      oninput="updateCounter('metaDescLen', this.value.length, 160)"></textarea>
                            <div class="char-counter" id="metaDescLen">0 / 160</div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ═══ RIGHT / SIDEBAR ═══ -->
            <div class="col-side">

                <!-- TRẠNG THÁI -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-toggle-on cf-card-icon"></i>
                        <span class="cf-card-title">Trạng Thái</span>
                    </div>
                    <div class="cf-card-body">
                        <input asp-for="Status" type="hidden" id="statusInput" value="Published" />
                        <div class="status-opts">
                            <div class="status-opt selected" id="st-Published" onclick="selectStatus('Published')">
                                <span class="status-dot" style="background:var(--success);"></span> Xuất Bản
                            </div>
                            <div class="status-opt" id="st-Archived" onclick="selectStatus('Archived')">
                                <span class="status-dot" style="background:var(--danger);"></span> Lưu Trữ
                                <span style="font-size:.7rem;color:var(--muted);margin-left:auto;">📦 Kho</span>
                            </div>
                        </div>
                        <div style="margin-top:1rem;display:flex;flex-direction:column;gap:0;">
                            <div class="toggle-row" style="border-bottom:none;padding-bottom:0;">
                                <span class="toggle-label"><span>⭐</span> Bài viết nổi bật</span>
                                <label class="toggle-switch">
                                    <input asp-for="IsFeatured" type="checkbox" id="chkFeatured" />
                                    <span class="toggle-track"></span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ẢNH ĐẠI DIỆN -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-image cf-card-icon"></i>
                        <span class="cf-card-title">Ảnh Đại Diện</span>
                    </div>
                    <div class="cf-card-body">
                        <div class="img-drop-zone" id="imgDropZone">
                            <input type="file" name="featuredImage" id="imgFileInput"
                                   accept="image/*" onchange="previewImage(this)" />
                            <div class="img-placeholder" id="imgPlaceholder">
                                <i class="bi bi-cloud-upload"></i>
                                <span>Click hoặc kéo ảnh vào đây</span>
                                <div style="font-size:.67rem;color:var(--border);margin-top:.2rem;">JPG · PNG · WEBP · max 5MB</div>
                            </div>
                            <div class="img-preview-wrap" id="imgPreviewWrap" style="display:none;">
                                <img id="imgPreview" src="" alt="Preview" />
                                <button type="button" class="img-remove-btn" onclick="removeImage(event)" title="Xóa ảnh">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div><!-- /modal-body -->
    <!-- ACTIONS (sticky footer, outside modal-body) -->
    <div class="cf-actions">
        <button type="button" class="btn-cancel" onclick="closePostModal()">
            <i class="bi bi-arrow-left"></i> Hủy
        </button>
        <button type="submit" class="btn-save" id="submitBtn">
            <i class="bi bi-plus-circle"></i> Thêm Bài Viết
        </button>
    </div>

</form>

<script>
    /* ── STATUS ── */
    function selectStatus(val) {
        document.querySelectorAll('.status-opt').forEach(c => c.classList.remove('selected'));
        document.getElementById('st-' + val).classList.add('selected');
        document.getElementById('statusInput').value = val;
    }

    /* ── CHAR COUNTER ── */
    function updateCounter(id, len, max) {
        const el = document.getElementById(id);
        el.textContent = len + ' / ' + max;
        el.classList.toggle('warn', len > max * .85 && len <= max);
        el.classList.toggle('danger', len > max);
    }

    /* ── SEO COLLAPSIBLE ── */
    function toggleSEO() {
        const toggle = document.getElementById('seoToggle');
        const body   = document.getElementById('seoBody');
        toggle.classList.toggle('open');
        body.classList.toggle('open');
    }

    /* ── AUTO FILL SEO TITLE ── */
    function autoFillSeoTitle(val) {
        const mt = document.getElementById('metaTitleInput');
        if (mt && !mt.dataset.edited) mt.value = val;
    }
    document.addEventListener('DOMContentLoaded', () => {
        const mt = document.getElementById('metaTitleInput');
        if (mt) mt.addEventListener('input', () => { mt.dataset.edited = '1'; });
    });

    /* ── IMAGE PREVIEW ── */
    function previewImage(input) {
        if (!input.files || !input.files[0]) return;
        const file = input.files[0];
        if (file.size > 5 * 1024 * 1024) {
            alert('Ảnh quá lớn! Vui lòng chọn ảnh dưới 5MB.');
            input.value = '';
            return;
        }
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('imgPreview').src = e.target.result;
            document.getElementById('imgPlaceholder').style.display = 'none';
            document.getElementById('imgPreviewWrap').style.display = 'block';
            document.getElementById('imgDropZone').classList.add('has-img');
        };
        reader.readAsDataURL(file);
    }

    function removeImage(e) {
        e.stopPropagation();
        document.getElementById('imgFileInput').value = '';
        document.getElementById('imgPreviewWrap').style.display = 'none';
        document.getElementById('imgPlaceholder').style.display = 'block';
        document.getElementById('imgDropZone').classList.remove('has-img');
    }

    /* ── VALIDATE & SYNC ── */
    function validateAndSync() {
        if (typeof tinymce !== 'undefined' && tinymce.get('editor-content')) {
            tinymce.get('editor-content').save();
        }
        let ok = true;
        const title = document.getElementById('titleInput');
        if (!title.value.trim()) { title.classList.add('error'); ok = false; }
        else title.classList.remove('error');
        if (!ok) {
            title.closest('.cf-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        return ok;
    }
</script>
