@model QuanLiSanCauLong.Models.BlogPost
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --success: #16a34a;
        --danger: #c94b2a;
    }

    .cf-modal-header {
        padding: 1.2rem 1.6rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .cf-modal-header h5 {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--deep);
            margin: 0;
        }

        .cf-modal-header p {
            font-size: .78rem;
            color: var(--muted);
            margin: .15rem 0 0;
        }

    .cf-close-btn {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: 1.1rem;
        padding: .3rem;
        transition: color .2s;
        line-height: 1;
    }

        .cf-close-btn:hover {
            color: var(--deep);
        }

    /* STATS STRIP */
    .stats-strip {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        margin: 1.1rem 1.5rem 0;
    }

    .stat-item {
        background: var(--cream);
        padding: .65rem 1rem;
        flex: 1;
        min-width: 0;
    }

    .stat-item-label {
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-bottom: .15rem;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .stat-item-val {
        font-size: .9rem;
        font-weight: 700;
        color: var(--deep);
        white-space: nowrap;
    }

    /* LAYOUT */
    .form-layout {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 1rem;
        padding: 1.1rem 1.5rem 1.25rem;
        background: var(--cream);
    }

    .col-main {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .col-side {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* CARD */
    .cf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .cf-card-head {
        padding: .7rem 1.2rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .cf-card-title {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cf-card-icon {
        color: var(--gold);
        font-size: .85rem;
    }

    .cf-card-body {
        padding: 1.1rem 1.2rem;
    }

    /* FIELDS */
    .fg {
        margin-bottom: .9rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-label {
        display: block;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .35rem;
    }

        .fg-label .req {
            color: var(--danger);
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s, background .2s;
        box-sizing: border-box;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 72px;
    }

    .fg-hint {
        font-size: .69rem;
        color: var(--muted);
        margin-top: .25rem;
    }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    .field-error {
        font-size: .71rem;
        color: var(--danger);
        margin-top: .25rem;
    }

    .fg-input.error, .fg-select.error {
        border-color: var(--danger);
    }

    /* STATUS */
    .status-opts {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .55rem;
        padding: .5rem .85rem;
        border: 2px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
        font-size: .83rem;
        font-weight: 600;
        color: var(--deep);
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.45);
            background: rgba(212,160,23,.03);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.07);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* TOGGLE */
    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .55rem .1rem;
        border-bottom: 1px solid var(--border);
    }

        .toggle-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .toggle-row:first-child {
            padding-top: 0;
        }

    .toggle-label {
        font-size: .83rem;
        font-weight: 500;
        color: var(--deep);
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .toggle-switch {
        position: relative;
        width: 36px;
        height: 20px;
        flex-shrink: 0;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .toggle-track {
        position: absolute;
        inset: 0;
        background: #ddd;
        border-radius: 20px;
        cursor: pointer;
        transition: background .2s;
    }

        .toggle-track::after {
            content: '';
            position: absolute;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #fff;
            top: 3px;
            left: 3px;
            transition: transform .2s;
            box-shadow: 0 1px 3px rgba(0,0,0,.2);
        }

    .toggle-switch input:checked + .toggle-track {
        background: var(--gold);
    }

        .toggle-switch input:checked + .toggle-track::after {
            transform: translateX(16px);
        }

    /* IMAGE */
    .img-drop-zone {
        border: 2px dashed var(--border);
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        position: relative;
        overflow: hidden;
    }

        .img-drop-zone.empty {
            padding: 1.2rem;
        }

        .img-drop-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.03);
        }

        .img-drop-zone.has-img {
            border-style: solid;
            border-color: var(--border);
        }

        .img-drop-zone input[type=file] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

    .img-placeholder {
        color: var(--muted);
        pointer-events: none;
    }

        .img-placeholder i {
            font-size: 1.4rem;
            display: block;
            margin-bottom: .3rem;
        }

        .img-placeholder span {
            font-size: .78rem;
        }

    .img-preview-wrap {
        position: relative;
    }

        .img-preview-wrap img {
            width: 100%;
            max-height: 160px;
            object-fit: cover;
            display: block;
            border-radius: 6px;
        }

    .img-remove-btn {
        position: absolute;
        top: 6px;
        right: 6px;
        background: rgba(0,0,0,.6);
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        cursor: pointer;
        font-size: .7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
    }

        .img-remove-btn:hover {
            background: var(--danger);
        }

    .img-current-label {
        font-size: .68rem;
        color: var(--muted);
        text-align: center;
        padding: .35rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
    }

    /* TAGS */
    .tag-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        padding: .4rem .6rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        min-height: 40px;
        cursor: text;
        background: #fff;
        transition: border-color .2s;
        align-items: center;
    }

        .tag-wrap:focus-within {
            border-color: var(--gold);
            background: var(--cream);
        }

    .tag-chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: var(--warm);
        color: var(--deep);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: .15rem .45rem;
        font-size: .76rem;
        font-weight: 600;
    }

    .tag-chip-x {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: .7rem;
        padding: 0;
        line-height: 1;
    }

        .tag-chip-x:hover {
            color: var(--danger);
        }

    .tag-input {
        border: none;
        outline: none;
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: transparent;
        min-width: 80px;
        flex: 1;
    }

    /* SEO */
    .seo-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        padding: .7rem 1.2rem;
        user-select: none;
        border-bottom: none;
    }

        .seo-toggle:hover {
            background: rgba(212,160,23,.04);
        }

        .seo-toggle .seo-icon {
            transition: transform .25s;
        }

        .seo-toggle.open .seo-icon {
            transform: rotate(180deg);
        }

    .seo-body {
        display: none;
        padding: 1.1rem 1.2rem;
        border-top: 1px solid var(--border);
    }

        .seo-body.open {
            display: block;
        }

    .char-counter {
        font-size: .69rem;
        color: var(--muted);
        margin-top: .2rem;
        text-align: right;
    }

        .char-counter.warn {
            color: #d97706;
        }

        .char-counter.danger {
            color: var(--danger);
        }

    /* ACTIONS */
    .cf-actions {
        display: flex;
        gap: .75rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        justify-content: flex-end;
    }

    .btn-save {
        background: linear-gradient(135deg, var(--gold), var(--gold2));
        color: var(--deep);
        border: none;
        padding: .72rem 1.8rem;
        font-family: 'Outfit', sans-serif;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .22s;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .btn-cancel {
        padding: .72rem 1.3rem;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        font-family: 'Outfit', sans-serif;
        font-size: .84rem;
        font-weight: 600;
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }
</style>

<!-- HEADER -->
<div class="cf-modal-header">
    <div>
        <h5>✏️ Chỉnh Sửa <em style="font-style:italic;color:var(--gold);">Bài Viết</em></h5>
        <p style="max-width:420px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Model.Title</p>
    </div>
    <button type="button" class="cf-close-btn" data-bs-dismiss="modal">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<!-- STATS STRIP -->
<div class="stats-strip">
    <div class="stat-item">
        <div class="stat-item-label"><i class="bi bi-calendar-plus" style="color:var(--gold);"></i>Tạo lúc</div>
        <div class="stat-item-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</div>
    </div>
    @if (Model.PublishedAt.HasValue)
    {
        <div class="stat-item">
            <div class="stat-item-label"><i class="bi bi-calendar-check" style="color:var(--success);"></i>Xuất bản</div>
            <div class="stat-item-val">@Model.PublishedAt.Value.ToString("dd/MM/yyyy")</div>
        </div>
    }
    <div class="stat-item">
        <div class="stat-item-label"><i class="bi bi-eye" style="color:#4f46e5;"></i>Lượt xem</div>
        <div class="stat-item-val">@Model.ViewCount.ToString("N0")</div>
    </div>
    <div class="stat-item">
        <div class="stat-item-label"><i class="bi bi-clock" style="color:var(--muted);"></i>Cập nhật</div>
        <div class="stat-item-val">@Model.UpdatedAt.ToString("dd/MM/yy")</div>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data"
      id="blogEditForm" onsubmit="return validateAndSync()">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PostId" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="ViewCount" />
    <input type="hidden" asp-for="Slug" />
    <input type="hidden" asp-for="AuthorId" />
    <input type="hidden" asp-for="PublishedAt" />
    <input type="hidden" asp-for="FeaturedImage" id="existingImage" />
    <input type="hidden" name="removeExistingImage" id="removeExistingImage" value="false" />

    <div class="modal-body" style="padding:0;overflow-y:auto;">
        <div class="form-layout">

            <!-- ═══ LEFT ═══ -->
            <div class="col-main">

                <!-- THÔNG TIN CƠ BẢN -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-card-heading cf-card-icon"></i>
                        <span class="cf-card-title">Thông Tin Cơ Bản</span>
                    </div>
                    <div class="cf-card-body">
                        <div class="fg">
                            <label class="fg-label">Tiêu Đề <span class="req">*</span></label>
                            <input asp-for="Title" class="fg-input" id="titleInput"
                                   oninput="autoFillSeoTitle(this.value)" />
                        </div>
                        <div class="fg-row2">
                            <div class="fg" style="margin-bottom:0">
                                <label class="fg-label">Danh Mục <span class="req">*</span></label>
                                <select asp-for="CategoryId" class="fg-select" id="catSelect">
                                    @foreach (var cat in ViewBag.Categories as List<QuanLiSanCauLong.Models.BlogCategory> ?? new())
                                    {
                                        <option value="@cat.CategoryId"
                                                selected="@(cat.CategoryId == Model.CategoryId)">
                                            @cat.CategoryName
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="fg" style="margin-bottom:0">
                                <label class="fg-label">Tags</label>
                                <div class="tag-wrap" id="tagWrap" onclick="document.getElementById('tagInput').focus()">
                                    <input type="hidden" asp-for="Tags" id="tagsHidden" />
                                    <input type="text" id="tagInput" class="tag-input"
                                           placeholder="Nhập tag + Enter" autocomplete="off" />
                                </div>
                                <div class="fg-hint">Enter hoặc dấu phẩy để thêm</div>
                            </div>
                        </div>
                        <div class="fg" style="margin-top:.9rem;margin-bottom:0">
                            <label class="fg-label">Tóm Tắt</label>
                            <textarea asp-for="Excerpt" class="fg-textarea" rows="2"
                                      maxlength="200"
                                      oninput="updateCounter('excerptLen', this.value.length, 200)"></textarea>
                            <div class="char-counter" id="excerptLen">@(Model.Excerpt?.Length ?? 0) / 200</div>
                        </div>
                    </div>
                </div>

                <!-- NỘI DUNG -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-body-text cf-card-icon"></i>
                        <span class="cf-card-title">Nội Dung Bài Viết</span>
                    </div>
                    <div class="cf-card-body" style="padding-bottom:0">
                        <textarea asp-for="Content" id="editor-content" class="fg-textarea" rows="8">@Model.Content</textarea>
                    </div>
                </div>

                <!-- SEO (collapse) -->
                <div class="cf-card">
                    <div class="cf-card-head seo-toggle @((!string.IsNullOrEmpty(Model.MetaTitle) || !string.IsNullOrEmpty(Model.MetaDescription)) ? "open" : "")"
                         id="seoToggle" onclick="toggleSEO()">
                        <div style="display:flex;align-items:center;gap:.45rem;">
                            <i class="bi bi-search cf-card-icon"></i>
                            <span class="cf-card-title">Tối Ưu SEO</span>
                            <span style="font-size:.69rem;color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;">(tuỳ chọn)</span>
                        </div>
                        <i class="bi bi-chevron-down seo-icon" style="color:var(--muted);font-size:.8rem;"></i>
                    </div>
                    <div class="seo-body @((!string.IsNullOrEmpty(Model.MetaTitle) || !string.IsNullOrEmpty(Model.MetaDescription)) ? "open" : "")"
                         id="seoBody">
                        <div class="fg">
                            <label class="fg-label">Meta Title</label>
                            <input asp-for="MetaTitle" id="metaTitleInput" class="fg-input"
                                   placeholder="Để trống = dùng tiêu đề bài viết" />
                        </div>
                        <div class="fg" style="margin-bottom:0">
                            <label class="fg-label">Meta Description</label>
                            <textarea asp-for="MetaDescription" class="fg-textarea" rows="2"
                                      maxlength="160"
                                      oninput="updateCounter('metaDescLen', this.value.length, 160)"></textarea>
                            <div class="char-counter" id="metaDescLen">@(Model.MetaDescription?.Length ?? 0) / 160</div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ═══ RIGHT ═══ -->
            <div class="col-side">

                <!-- TRẠNG THÁI -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-toggle-on cf-card-icon"></i>
                        <span class="cf-card-title">Trạng Thái</span>
                    </div>
                    <div class="cf-card-body">
                        <input asp-for="Status" type="hidden" id="statusInput" value="@Model.Status" />
                        <div class="status-opts">
                            <div class="status-opt @(Model.Status == "Draft" ? "selected" : "")"
                                 id="st-Draft" onclick="selectStatus('Draft')">
                                <span class="status-dot" style="background:#92660a;"></span> Bản Nháp
                            </div>
                            <div class="status-opt @(Model.Status == "Published" ? "selected" : "")"
                                 id="st-Published" onclick="selectStatus('Published')">
                                <span class="status-dot" style="background:var(--success);"></span> Xuất Bản
                            </div>
                            <div class="status-opt @(Model.Status == "Archived" ? "selected" : "")"
                                 id="st-Archived" onclick="selectStatus('Archived')">
                                <span class="status-dot" style="background:var(--danger);"></span> Lưu Trữ
                            </div>
                        </div>
                        <div style="margin-top:1rem;">
                            <div class="toggle-row">
                                <span class="toggle-label"><span>⭐</span> Bài viết nổi bật</span>
                                <label class="toggle-switch">
                                    <input asp-for="IsFeatured" type="checkbox" />
                                    <span class="toggle-track"></span>
                                </label>
                            </div>
                            <div class="toggle-row">
                                <span class="toggle-label"><span>💬</span> Cho phép bình luận</span>
                                <label class="toggle-switch">
                                    <input asp-for="AllowComments" type="checkbox" />
                                    <span class="toggle-track"></span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ẢNH ĐẠI DIỆN -->
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-image cf-card-icon"></i>
                        <span class="cf-card-title">Ảnh Đại Diện</span>
                    </div>
                    <div class="cf-card-body">
                        <div class="img-drop-zone @(string.IsNullOrEmpty(Model.FeaturedImage) ? "empty" : "has-img")"
                             id="imgDropZone">
                            <input type="file" name="featuredImage" id="imgFileInput"
                                   accept="image/*" onchange="previewImage(this)" />
                            @if (string.IsNullOrEmpty(Model.FeaturedImage))
                            {
                                <div class="img-placeholder" id="imgPlaceholder">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span>Click hoặc kéo ảnh vào đây</span>
                                    <div style="font-size:.67rem;color:var(--border);margin-top:.2rem;">JPG · PNG · WEBP · max 5MB</div>
                                </div>
                            }
                            else
                            {
                                <div class="img-placeholder" id="imgPlaceholder" style="display:none;">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span>Click hoặc kéo ảnh vào đây</span>
                                </div>
                            }
                            <div class="img-preview-wrap" id="imgPreviewWrap"
                                 style="@(string.IsNullOrEmpty(Model.FeaturedImage) ? "display:none" : "")">
                                <img id="imgPreview" src="@Model.FeaturedImage" alt="Preview" />
                                <button type="button" class="img-remove-btn" onclick="removeImage(event)" title="Xóa ảnh">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.FeaturedImage))
                        {
                            <div class="img-current-label" id="currentImgLabel">
                                <i class="bi bi-check-circle-fill" style="color:var(--success);margin-right:.3rem;"></i>
                                Ảnh hiện tại — chọn file mới để thay thế
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div><!-- /modal-body -->
    <!-- ACTIONS (sticky footer) -->
    <div class="cf-actions">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">
            <i class="bi bi-arrow-left"></i> Hủy
        </button>
        <button type="submit" class="btn-save">
            <i class="bi bi-check-circle"></i> Lưu Thay Đổi
        </button>
    </div>

</form>

<script>
    function selectStatus(val) {
        document.querySelectorAll('.status-opt').forEach(c => c.classList.remove('selected'));
        document.getElementById('st-' + val).classList.add('selected');
        document.getElementById('statusInput').value = val;
    }

    function updateCounter(id, len, max) {
        const el = document.getElementById(id);
        el.textContent = len + ' / ' + max;
        el.classList.toggle('warn', len > max * .85 && len <= max);
        el.classList.toggle('danger', len > max);
    }

    function toggleSEO() {
        document.getElementById('seoToggle').classList.toggle('open');
        document.getElementById('seoBody').classList.toggle('open');
    }

    function autoFillSeoTitle(val) {
        const mt = document.getElementById('metaTitleInput');
        if (mt && !mt.dataset.edited) mt.value = val;
    }
    document.addEventListener('DOMContentLoaded', () => {
        const mt = document.getElementById('metaTitleInput');
        if (mt) mt.addEventListener('input', () => { mt.dataset.edited = '1'; });
    });

    /* TAG CHIPS */
    (function () {
        const tagInput  = document.getElementById('tagInput');
        const tagHidden = document.getElementById('tagsHidden');
        const tagWrap   = document.getElementById('tagWrap');
        let tags = tagHidden.value
            ? tagHidden.value.split(',').map(t => t.trim()).filter(Boolean)
            : [];

        function renderTags() {
            tagWrap.querySelectorAll('.tag-chip').forEach(c => c.remove());
            tags.forEach((t, i) => {
                const chip = document.createElement('span');
                chip.className = 'tag-chip';
                chip.innerHTML = `${t}<button type="button" class="tag-chip-x" onclick="removeTag(${i})">✕</button>`;
                tagWrap.insertBefore(chip, tagInput);
            });
            tagHidden.value = tags.join(', ');
        }

        window.removeTag = function (i) { tags.splice(i, 1); renderTags(); };

        tagInput.addEventListener('keydown', e => {
            if ((e.key === 'Enter' || e.key === ',') && tagInput.value.trim()) {
                e.preventDefault();
                tagInput.value.split(',').map(t => t.trim()).filter(Boolean)
                    .forEach(t => { if (!tags.includes(t)) tags.push(t); });
                tagInput.value = '';
                renderTags();
            }
            if (e.key === 'Backspace' && !tagInput.value && tags.length) {
                tags.pop(); renderTags();
            }
        });

        tagInput.addEventListener('blur', () => {
            if (tagInput.value.trim()) {
                tagInput.value.split(',').map(t => t.trim()).filter(Boolean)
                    .forEach(t => { if (!tags.includes(t)) tags.push(t); });
                tagInput.value = ''; renderTags();
            }
        });

        renderTags();
    })();

    /* IMAGE PREVIEW */
    function previewImage(input) {
        if (!input.files || !input.files[0]) return;
        const file = input.files[0];
        if (file.size > 5 * 1024 * 1024) {
            alert('Ảnh quá lớn! Vui lòng chọn ảnh dưới 5MB.');
            input.value = ''; return;
        }
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('imgPreview').src = e.target.result;
            document.getElementById('imgPlaceholder').style.display = 'none';
            document.getElementById('imgPreviewWrap').style.display = 'block';
            document.getElementById('imgDropZone').classList.add('has-img');
            document.getElementById('imgDropZone').classList.remove('empty');
            // Đã chọn ảnh mới → không xóa, chỉ thay thế
            document.getElementById('removeExistingImage').value = 'false';
            const lbl = document.getElementById('currentImgLabel');
            if (lbl) lbl.textContent = '📎 Ảnh mới đã chọn — sẽ thay thế ảnh cũ khi lưu';
        };
        reader.readAsDataURL(file);
    }

    function removeImage(e) {
        e.stopPropagation();
        document.getElementById('imgFileInput').value = '';
        document.getElementById('imgPreviewWrap').style.display = 'none';
        document.getElementById('imgPlaceholder').style.display = 'block';
        document.getElementById('imgDropZone').classList.remove('has-img');
        document.getElementById('imgDropZone').classList.add('empty');
        // Đánh dấu để server xóa ảnh cũ
        document.getElementById('removeExistingImage').value = 'true';
        const lbl = document.getElementById('currentImgLabel');
        if (lbl) lbl.innerHTML = '<i class="bi bi-x-circle" style="color:var(--danger);margin-right:.3rem;"></i>Ảnh sẽ bị xóa khi lưu';
    }

    function validateAndSync() {
        if (typeof tinymce !== 'undefined' && tinymce.get('editor-content')) {
            tinymce.get('editor-content').save();
        }
        let ok = true;
        const title = document.getElementById('titleInput');
        const cat   = document.getElementById('catSelect');
        if (!title.value.trim()) { title.classList.add('error'); ok = false; }
        else title.classList.remove('error');
        if (!cat.value) { cat.classList.add('error'); ok = false; }
        else cat.classList.remove('error');
        return ok;
    }
</script>
