@model QuanLiSanCauLong.Models.BlogPost
@{
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    .cf-modal-header {
        padding: 1.4rem 1.75rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .cf-modal-header h5 {
            font-family: 'Playfair Display',serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--deep);
            margin: 0;
        }

        .cf-modal-header p {
            font-size: .8rem;
            color: var(--muted);
            margin: .2rem 0 0;
        }

    .cf-close-btn {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: 1.1rem;
        padding: .3rem;
        transition: color .2s;
        line-height: 1;
    }

        .cf-close-btn:hover {
            color: var(--deep);
        }

    .cf-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .cf-card-head {
        padding: .85rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cf-card-title {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cf-card-icon {
        color: var(--gold);
        font-size: .9rem;
    }

    .cf-card-body {
        padding: 1.4rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fg-label {
        display: block;
        font-size: .73rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .45rem;
    }

        .fg-label .req {
            color: #c94b2a;
        }

    .fg-input, .fg-select, .fg-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .87rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus, .fg-select:focus, .fg-textarea:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-textarea {
        resize: vertical;
        min-height: 80px;
    }

    .fg-hint {
        font-size: .71rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .fg-row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .status-opts {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .status-opt {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .55rem 1rem;
        border: 2px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .status-opt:hover {
            border-color: rgba(212,160,23,.5);
        }

        .status-opt.selected {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .status-text {
        font-size: .82rem;
        font-weight: 600;
        color: var(--deep);
    }

    .check-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
    }

    .check-item {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .75rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

        .check-item:hover {
            border-color: rgba(212,160,23,.4);
        }

        .check-item.checked {
            border-color: var(--gold);
            background: rgba(212,160,23,.06);
        }

        .check-item input[type=checkbox] {
            width: 16px;
            height: 16px;
            accent-color: var(--gold);
            cursor: pointer;
        }

    .check-label {
        font-size: .84rem;
        color: var(--deep);
        font-weight: 500;
        cursor: pointer;
        user-select: none;
    }

    /* STATS BANNER */
    .stats-banner {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
    }

    .stats-banner-item {
        background: var(--cream);
        padding: .75rem 1rem;
    }

    .stats-banner-label {
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-bottom: .2rem;
    }

    .stats-banner-value {
        font-size: .88rem;
        font-weight: 700;
        color: var(--deep);
    }

    /* CURRENT IMG */
    .current-img-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: .75rem;
    }

        .current-img-wrap img {
            border-radius: 8px;
            border: 2px solid var(--gold);
            max-height: 90px;
        }

    .current-img-badge {
        position: absolute;
        bottom: -6px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--gold);
        color: var(--deep);
        font-size: .58rem;
        font-weight: 800;
        padding: .1rem .5rem;
        border-radius: 3px;
        letter-spacing: .06em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .char-counter {
        font-size: .71rem;
        color: var(--muted);
        margin-top: .3rem;
    }

        .char-counter.danger {
            color: #c94b2a;
        }

    .cf-actions {
        display: flex;
        gap: 1rem;
        padding: 1.2rem 1.75rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        justify-content: flex-end;
    }

    .btn-save {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .8rem 2rem;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .5rem;
        transition: all .25s;
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .btn-cancel {
        padding: .8rem 1.5rem;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        font-family: 'Outfit',sans-serif;
        font-size: .87rem;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-cancel:hover {
            border-color: var(--muted);
            color: var(--deep);
        }
</style>

<!-- MODAL HEADER -->
<div class="cf-modal-header">
    <div>
        <h5>Chỉnh Sửa <em style="font-style:italic;color:var(--gold);">Bài Viết</em></h5>
        <p>Cập nhật: <strong>@Model.Title</strong></p>
    </div>
    <button type="button" class="cf-close-btn" data-bs-dismiss="modal">
        <i class="bi bi-x-lg"></i>
    </button>
</div>

<div class="modal-body" style="padding:1.5rem;background:var(--cream);">
    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="blogEditForm" onsubmit="return syncEditorContent()">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PostId" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="ViewCount" />
        <input type="hidden" asp-for="Slug" />
        <input type="hidden" asp-for="AuthorId" />
        <input type="hidden" asp-for="FeaturedImage" />

        <!-- STATS BANNER -->
        <div class="stats-banner" style="margin-bottom:1rem;">
            <div class="stats-banner-item">
                <div class="stats-banner-label"><i class="bi bi-calendar-plus" style="color:var(--gold);margin-right:.3rem;"></i>Ngày Tạo</div>
                <div class="stats-banner-value">@Model.CreatedAt.ToString("dd/MM/yyyy")</div>
            </div>
            @if (Model.PublishedAt.HasValue)
            {
                <div class="stats-banner-item">
                    <div class="stats-banner-label"><i class="bi bi-calendar-check" style="color:#16a34a;margin-right:.3rem;"></i>Xuất Bản</div>
                    <div class="stats-banner-value">@Model.PublishedAt.Value.ToString("dd/MM/yyyy")</div>
                </div>
            }
            <div class="stats-banner-item">
                <div class="stats-banner-label"><i class="bi bi-eye" style="color:#4f46e5;margin-right:.3rem;"></i>Lượt Xem</div>
                <div class="stats-banner-value">@Model.ViewCount.ToString("N0")</div>
            </div>
        </div>

        <!-- 1. THÔNG TIN CƠ BẢN -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-card-heading cf-card-icon"></i>
                <span class="cf-card-title">Thông Tin Cơ Bản</span>
            </div>
            <div class="cf-card-body">
                <div class="fg">
                    <label class="fg-label">Tiêu Đề <span class="req">*</span></label>
                    <input asp-for="Title" class="fg-input" />
                </div>
                <div class="fg-row2">
                    <div class="fg">
                        <label class="fg-label">Danh Mục <span class="req">*</span></label>
                        <select asp-for="CategoryId" class="fg-select">
                            @foreach (var cat in ViewBag.Categories as List<QuanLiSanCauLong.Models.BlogCategory> ?? new())
                            {
                                <option value="@cat.CategoryId" selected="@(cat.CategoryId == Model.CategoryId)">@cat.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Tags</label>
                        <input asp-for="Tags" class="fg-input" placeholder="cầu lông, thể thao" />
                        <div class="fg-hint">Phân cách bằng dấu phẩy</div>
                    </div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Tóm Tắt</label>
                    <textarea asp-for="Excerpt" class="fg-textarea" rows="2"></textarea>
                </div>
            </div>
        </div>

        <!-- 2. NỘI DUNG -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-body-text cf-card-icon"></i>
                <span class="cf-card-title">Nội Dung Bài Viết</span>
            </div>
            <div class="cf-card-body">
                <div class="fg" style="margin-bottom:0;">
                    <textarea asp-for="Content" id="editor-content" class="fg-textarea" rows="6">@Model.Content</textarea>
                </div>
            </div>
        </div>

        <!-- 3. ẢNH & CÀI ĐẶT -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-images cf-card-icon"></i>
                <span class="cf-card-title">Ảnh & Cài Đặt</span>
            </div>
            <div class="cf-card-body">
                <div class="fg-row2">
                    <div class="fg">
                        <label class="fg-label">Ảnh Đại Diện</label>
                        @if (!string.IsNullOrEmpty(Model.FeaturedImage))
                        {
                            <div class="current-img-wrap">
                                <img src="@Model.FeaturedImage" alt="@Model.Title" />
                                <span class="current-img-badge">Ảnh Hiện Tại</span>
                            </div>
                        }
                        <input type="file" name="featuredImage" class="fg-input" accept="image/*"
                               style="padding:.5rem .75rem;cursor:pointer;" />
                        <div class="fg-hint">Chọn file mới để thay thế ảnh hiện tại</div>
                    </div>
                    <div class="fg">
                        <label class="fg-label">Trạng Thái <span class="req">*</span></label>
                        <input asp-for="Status" type="hidden" id="statusInput" value="@Model.Status" />
                        <div class="status-opts">
                            <div class="status-opt @(Model.Status == "Draft" ? "selected" : "")" id="st-Draft" onclick="selectStatus('Draft')">
                                <span class="status-dot" style="background:#92660a;"></span>
                                <span class="status-text">Bản Nháp</span>
                            </div>
                            <div class="status-opt @(Model.Status == "Published" ? "selected" : "")" id="st-Published" onclick="selectStatus('Published')">
                                <span class="status-dot" style="background:#16a34a;"></span>
                                <span class="status-text">Xuất Bản</span>
                            </div>
                            <div class="status-opt @(Model.Status == "Archived" ? "selected" : "")" id="st-Archived" onclick="selectStatus('Archived')">
                                <span class="status-dot" style="background:#c94b2a;"></span>
                                <span class="status-text">Lưu Trữ</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="check-grid">
                    <label class="check-item @(Model.IsFeatured ? "checked" : "")" id="chk-featured">
                        <span style="font-size:1rem;">⭐</span>
                        <input asp-for="IsFeatured" type="checkbox"
                               onchange="document.getElementById('chk-featured').classList.toggle('checked',this.checked)" />
                        <span class="check-label">Bài viết nổi bật</span>
                    </label>
                    <label class="check-item @(Model.AllowComments ? "checked" : "")" id="chk-comments">
                        <span style="font-size:1rem;">💬</span>
                        <input asp-for="AllowComments" type="checkbox"
                               onchange="document.getElementById('chk-comments').classList.toggle('checked',this.checked)" />
                        <span class="check-label">Cho phép bình luận</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 4. SEO -->
        <div class="cf-card">
            <div class="cf-card-head">
                <i class="bi bi-search cf-card-icon"></i>
                <span class="cf-card-title">Tối Ưu SEO</span>
            </div>
            <div class="cf-card-body">
                <div class="fg">
                    <label class="fg-label">Meta Title</label>
                    <input asp-for="MetaTitle" class="fg-input" placeholder="Để trống sẽ dùng tiêu đề bài viết" />
                </div>
                <div class="fg">
                    <label class="fg-label">Meta Description</label>
                    <textarea asp-for="MetaDescription" class="fg-textarea" rows="2"
                              maxlength="160"
                              oninput="updateCounter('metaDescLength',this.value.length,160)"></textarea>
                    <div class="char-counter" id="metaDescLength">@(Model.MetaDescription?.Length ?? 0) / 160 ký tự</div>
                </div>
                <div class="fg" style="margin-bottom:0;">
                    <label class="fg-label">Meta Keywords</label>
                    <input asp-for="MetaKeywords" class="fg-input" placeholder="từ khóa 1, từ khóa 2" />
                </div>
            </div>
        </div>

    </form>
</div>

<!-- ACTIONS -->
<div class="cf-actions">
    <button type="button" class="btn-cancel" data-bs-dismiss="modal">
        <i class="bi bi-arrow-left"></i> Hủy
    </button>
    <button type="button" class="btn-save" onclick="document.getElementById('blogEditForm').requestSubmit()">
        <i class="bi bi-check-circle"></i> Lưu Thay Đổi
    </button>
</div>

<script>
    function selectStatus(val) {
        document.querySelectorAll('.status-opt').forEach(c => c.classList.remove('selected'));
        document.getElementById('st-' + val).classList.add('selected');
        document.getElementById('statusInput').value = val;
    }

    function updateCounter(id, len, max) {
        const el = document.getElementById(id);
        el.textContent = len + ' / ' + max + ' ký tự';
        el.classList.toggle('danger', len > max);
    }

    function syncEditorContent() {
        if (typeof tinymce !== 'undefined' && tinymce.get('editor-content')) {
            tinymce.get('editor-content').save();
        }
        return true;
    }
</script>
