@model QuanLiSanCauLong.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var behavior = Model.Category?.BehaviorType ?? "Retail";
    var activeVariants = Model.Variants?.Where(v => v.IsActive).OrderBy(v => v.SizeName).ToList();
    bool hasVariants = activeVariants != null && activeVariants.Any();
    int totalStock = hasVariants ? activeVariants.Sum(v => v.StockQuantity) : Model.StockQuantity;
    int totalReserved = hasVariants ? activeVariants.Sum(v => v.ReservedQuantity) : Model.ReservedQuantity;
    int totalAvail = totalStock - totalReserved;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #ffffff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --green: #15803d;
        --green-soft: #dcfce7;
        --red: #dc2626;
        --red-soft: #fef2f2;
        --blue: #1d4ed8;
        --blue-soft: #eff6ff;
        --purple: #7c3aed;
        --purple-soft: #f5f3ff;
        --yellow-soft: #fef9c3;
    }

    body, .container-fluid {
        font-family: 'Outfit',sans-serif;
        background: var(--cream);
    }

    .bc {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .3rem;
        }

            .bc a:hover {
                color: var(--deep);
            }

    .bc-sep {
        opacity: .5;
    }

    .bc-cur {
        color: var(--deep);
        font-weight: 700;
    }

    .detail-wrap {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 1.4rem;
        align-items: start;
    }

    @@media(max-width:900px) {
        .detail-wrap {
            grid-template-columns: 1fr;
        }
    }

    /* Image panel */
    .img-panel {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(26,18,9,.06);
    }

    .img-panel-inner {
        background: var(--warm);
        border-bottom: 1px solid var(--border);
        padding: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 260px;
    }

    .product-main-img {
        max-width: 100%;
        max-height: 260px;
        object-fit: contain;
        border-radius: 12px;
    }

    .img-placeholder {
        text-align: center;
        color: var(--muted);
    }

        .img-placeholder i {
            font-size: 3rem;
            display: block;
            opacity: .4;
            margin-bottom: .5rem;
        }

    .img-panel-foot {
        padding: 1rem 1.25rem;
        display: flex;
        gap: .6rem;
    }

    /* Info cards */
    .info-panel {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .dc {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(26,18,9,.04);
    }

    .dc-hd {
        padding: .9rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .dc-hd i {
            color: var(--gold);
            font-size: .88rem;
        }

    .dc-hd-title {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
    }

    .dc-bd {
        padding: 1.25rem 1.4rem;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .45rem 0;
        border-bottom: 1px solid var(--warm);
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-lbl {
        font-size: .78rem;
        color: var(--muted);
        font-weight: 600;
    }

    .info-val {
        font-size: .88rem;
        font-weight: 700;
        color: var(--deep);
    }

    .desc-block {
        font-size: .85rem;
        color: var(--deep);
        line-height: 1.65;
        white-space: pre-wrap;
    }

    /* Behavior badge */
    .behavior-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .3rem .8rem;
        border-radius: 8px;
        font-size: .75rem;
        font-weight: 800;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .bh-retail {
        background: var(--green-soft);
        color: var(--green);
    }

    .bh-rental {
        background: var(--blue-soft);
        color: var(--blue);
    }

    .bh-service {
        background: var(--purple-soft);
        color: var(--purple);
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .6rem;
        border-radius: 6px;
        font-size: .72rem;
        font-weight: 700;
    }

    .badge-available {
        background: var(--green-soft);
        color: var(--green);
    }

    .badge-outofstock {
        background: var(--yellow-soft);
        color: #92400e;
    }

    .badge-discontinued {
        background: var(--red-soft);
        color: var(--red);
    }

    .badge-service {
        background: var(--purple-soft);
        color: var(--purple);
    }

    /* Stock summary */
    .stock-summary {
        display: flex;
        gap: 1.2rem;
        margin-bottom: 1.2rem;
        flex-wrap: wrap;
    }

    .stock-stat {
        text-align: center;
        padding: .7rem 1.2rem;
        border-radius: 10px;
        background: var(--warm);
        border: 1px solid var(--border);
        flex: 1;
        min-width: 80px;
    }

        .stock-stat.reserved {
            background: var(--yellow-soft);
            border-color: #fde68a;
        }

        .stock-stat.available {
            background: var(--green-soft);
            border-color: #86efac;
        }

        .stock-stat.rented {
            background: var(--blue-soft);
            border-color: #93c5fd;
        }

    .stock-stat-val {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--deep);
        line-height: 1;
    }

    .stock-stat-lbl {
        font-size: .68rem;
        color: var(--muted);
        font-weight: 600;
        text-transform: uppercase;
        margin-top: .2rem;
    }

    /* Variant table */
    .vt {
        width: 100%;
        border-collapse: collapse;
    }

        .vt th {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: var(--muted);
            padding: .5rem .7rem;
            border-bottom: 2px solid var(--border);
            text-align: left;
        }

        .vt td {
            padding: .5rem .7rem;
            border-bottom: 1px solid var(--warm);
            font-size: .84rem;
            color: var(--deep);
        }

        .vt tr:last-child td {
            border-bottom: none;
        }

    .size-chip {
        display: inline-flex;
        align-items: center;
        padding: .15rem .5rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 5px;
        font-size: .76rem;
        font-weight: 700;
        color: var(--deep);
    }

    .qty-ok {
        color: var(--green);
        font-weight: 700;
    }

    .qty-low {
        color: #92400e;
        font-weight: 700;
    }

    .qty-zero {
        color: var(--red);
        font-weight: 700;
    }

    .qty-reserved {
        color: #92400e;
        font-size: .8rem;
    }

    .qty-avail {
        font-weight: 700;
    }

    /* Rental stats */
    .rental-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .75rem;
    }

    @@media(max-width:600px) {
        .rental-info-grid {
            grid-template-columns: 1fr;
        }
    }

    .ri-box {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .8rem 1rem;
        text-align: center;
    }

    .ri-val {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--deep);
    }

    .ri-lbl {
        font-size: .68rem;
        color: var(--muted);
        font-weight: 600;
        text-transform: uppercase;
        margin-top: .15rem;
    }

    /* Service pricing */
    .svc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .svc-box {
        background: var(--purple-soft);
        border: 1px solid #ddd6fe;
        border-radius: 12px;
        padding: 1rem 1.25rem;
    }

    .svc-val {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--purple);
    }

    .svc-lbl {
        font-size: .7rem;
        color: var(--purple);
        opacity: .7;
        font-weight: 600;
        text-transform: uppercase;
    }

    .svc-unit {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    /* Action btns */
    .btn-edit {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        padding: .55rem 1rem;
        background: var(--gold2);
        color: var(--deep);
        border: none;
        border-radius: 9px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        text-decoration: none;
        transition: .18s;
        cursor: pointer;
    }

        .btn-edit:hover {
            background: var(--gold);
            color: #fff;
        }

    .btn-delete {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        padding: .55rem 1rem;
        background: var(--red-soft);
        color: var(--red);
        border: 1px solid #fca5a5;
        border-radius: 9px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        font-weight: 700;
        transition: .18s;
        cursor: pointer;
    }

        .btn-delete:hover {
            background: var(--red);
            color: #fff;
        }

    .toast-wrap {
        position: fixed;
        top: 1.2rem;
        right: 1.2rem;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        pointer-events: none;
    }

    .toast-msg {
        padding: .75rem 1.2rem;
        border-radius: 10px;
        font-size: .84rem;
        font-weight: 600;
        box-shadow: 0 8px 24px rgba(0,0,0,.14);
        pointer-events: all;
        display: flex;
        align-items: center;
        gap: .5rem;
        animation: slideIn .22s ease;
        background: #fff;
        border-left: 4px solid var(--red);
        color: var(--red);
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(20px)
        }

        to {
            opacity: 1;
            transform: translateX(0)
        }
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="bc">
        <a asp-action="Index"><i class="bi bi-house"></i> Sản phẩm</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <span class="bc-cur">@Model.ProductName</span>
    </div>

    <!-- Page title -->
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.6rem;flex-wrap:wrap;">
        <div>
            <div style="font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:var(--deep);">@Model.ProductName</div>
            <div style="font-size:.78rem;color:var(--muted);margin-top:.2rem">
                SKU: <code>@(Model.ProductCode ?? Model.SKU ?? "N/A")</code>
            </div>
        </div>
        <span class="behavior-badge @(behavior == "Rental" ? "bh-rental" : behavior == "Service" ? "bh-service" : "bh-retail")">
            @(behavior == "Retail" ? "🛒 Bán lẻ" : behavior == "Rental" ? "🔄 Cho thuê" : "🔧 Dịch vụ kỹ thuật")
        </span>
    </div>

    <div class="detail-wrap">

        <!-- ── LEFT: Image + actions ── -->
        <div>
            <div class="img-panel">
                <div class="img-panel-inner">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="product-main-img"
                             onerror="this.src='/images/no-image.png'" alt="@Model.ProductName" />
                    }
                    else
                    {
                        <div class="img-placeholder">
                            <i class="bi @(behavior == "Service" ? "bi-tools" : behavior == "Rental" ? "bi-arrow-repeat" : "bi-image")"></i>
                            <div style="font-size:.8rem">Chưa có ảnh</div>
                        </div>
                    }
                </div>
                <div class="img-panel-foot">
                    <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn-edit">
                        <i class="bi bi-pencil-fill"></i> Chỉnh sửa
                    </a>
                    <button onclick="deleteProduct(@Model.ProductId)" class="btn-delete">
                        <i class="bi bi-trash-fill"></i> Xóa
                    </button>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: Info cards ── -->
        <div class="info-panel">

            <!-- Thông tin chung -->
            <div class="dc">
                <div class="dc-hd">
                    <i class="bi bi-info-circle-fill"></i>
                    <span class="dc-hd-title">Thông tin chung</span>
                    @switch (Model.Status)
                    {
                        case "Active":
                            <span class="status-badge badge-available ms-auto"><i class="bi bi-check-circle-fill"></i> Đang bán</span>
                            break;
                        case "OutOfStock":
                            <span class="status-badge badge-outofstock ms-auto"><i class="bi bi-exclamation-circle-fill"></i> Hết hàng</span>
                            break;
                        default:
                            <span class="status-badge badge-discontinued ms-auto"><i class="bi bi-x-circle-fill"></i> Ngừng bán</span>
                            break;
                    }
                </div>
                <div class="dc-bd">
                    <div class="info-row">
                        <span class="info-lbl">Danh mục</span>
                        <span class="info-val">@Model.Category?.CategoryName</span>
                    </div>
                    <div class="info-row">
                        <span class="info-lbl">Đơn vị</span>
                        <span class="info-val">@Model.Unit</span>
                    </div>
                    <div class="info-row">
                        <span class="info-lbl">Giá @(behavior == "Rental" ? "cho thuê" : behavior == "Service" ? "trọn gói" : "bán")</span>
                        <span class="info-val" style="color:var(--gold)">₫@Model.Price.ToString("N0")</span>
                    </div>
                    <div class="info-row">
                        <span class="info-lbl">Ngày tạo</span>
                        <span class="info-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            </div>

            <!-- Mô tả -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="dc">
                    <div class="dc-hd"><i class="bi bi-file-text-fill"></i><span class="dc-hd-title">Mô tả</span></div>
                    <div class="dc-bd"><div class="desc-block">@Model.Description</div></div>
                </div>
            }

            <!-- ── RETAIL / RENTAL: Tồn kho ── -->
            @if (behavior != "Service")
            {
                <div class="dc">
                    <div class="dc-hd">
                        <i class="bi bi-bar-chart-fill" style="color:@(behavior == "Rental" ? "var(--blue)" : "var(--gold)")"></i>
                        <span class="dc-hd-title">@(behavior == "Rental" ? "Tình trạng cho thuê" : "Tồn kho")</span>
                    </div>
                    <div class="dc-bd">
                        <div class="stock-summary">
                            <div class="stock-stat">
                                <div class="stock-stat-val">@totalStock</div>
                                <div class="stock-stat-lbl">Tổng</div>
                            </div>
                            <div class="stock-stat @(behavior == "Rental" ? "rented" : "reserved")">
                                <div class="stock-stat-val">@totalReserved</div>
                                <div class="stock-stat-lbl">@(behavior == "Rental" ? "Đang thuê" : "Đang treo")</div>
                            </div>
                            <div class="stock-stat available">
                                <div class="stock-stat-val">@totalAvail</div>
                                <div class="stock-stat-lbl">Có sẵn</div>
                            </div>
                        </div>

                        @if (hasVariants)
                        {
                            <table class="vt">
                                <thead>
                                    <tr>
                                        <th>Size / Màu</th>
                                        <th>SKU</th>
                                        <th style="text-align:right">Tổng</th>
                                        <th style="text-align:right">@(behavior == "Rental" ? "Đang thuê" : "Treo")</th>
                                        <th style="text-align:right">Có sẵn</th>
                                        <th style="text-align:right">Cảnh báo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in activeVariants)
                                    {
                                        int avail = v.AvailableQuantity;
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrEmpty(v.SizeName))
                                                {
                                                    <span class="size-chip">@v.SizeName</span>
                                                }
                                                @if (!string.IsNullOrEmpty(v.ColorName))
                                                {
                                                    <span style="font-size:.82rem;color:var(--muted);margin-left:.35rem">@v.ColorName</span>
                                                }
                                            </td>
                                            <td style="font-family:'Courier New',monospace;font-size:.77rem;color:var(--muted)">@(v.VariantSKU ?? "—")</td>
                                            <td style="text-align:right"><span class="@(v.StockQuantity == 0 ? "qty-zero" : v.IsLowStock ? "qty-low" : "qty-ok")">@v.StockQuantity</span></td>
                                            <td style="text-align:right">
                                                @if (v.ReservedQuantity > 0)
                                                {
                                                    <span class="qty-reserved"><i class="bi bi-hourglass-split"></i> @v.ReservedQuantity</span>
                                                }
                                                else
                                                {

                                                    <span style="color:var(--muted)">—</span>
                                                }
                                            </td>
                                            <td style="text-align:right"><span class="qty-avail @(avail == 0 ? "qty-zero" : avail <= v.MinStockLevel && v.MinStockLevel > 0 ? "qty-low" : "qty-ok")">@avail</span></td>
                                            <td style="text-align:right">
                                                @if (avail == 0)
                                                {
                                                    <span style="font-size:.72rem;background:var(--red-soft);color:var(--red);padding:.15rem .45rem;border-radius:5px;font-weight:700">Hết</span>
                                                }
                                                else if (v.IsLowStock)
                                                {

                                                    <span style="font-size:.72rem;background:var(--yellow-soft);color:#92400e;padding:.15rem .45rem;border-radius:5px;font-weight:700">Sắp hết</span>
                                                }
                                                else
                                                {

                                                    <span style="color:var(--muted);font-size:.72rem">✓ Ổn</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="info-row">
                                <span class="info-lbl">Tồn kho thực</span>
                                <span class="info-val" style="color:var(--green)">@Model.StockQuantity @Model.Unit</span>
                            </div>
                            <div class="info-row">
                                <span class="info-lbl">Đang @(behavior == "Rental" ? "cho thuê" : "treo")</span>
                                <span class="info-val" style="color:#92400e">@Model.ReservedQuantity @Model.Unit</span>
                            </div>
                            <div class="info-row">
                                <span class="info-lbl">Có sẵn</span>
                                <span class="info-val" style="color:var(--blue)">@(Model.StockQuantity - Model.ReservedQuantity) @Model.Unit</span>
                            </div>
                            <div style="border-top:1px solid var(--border);margin-top:.75rem;padding-top:1rem;font-size:.8rem;color:var(--muted)">
                                <i class="bi bi-info-circle"></i> Chưa có phân loại size/màu.
                                <a asp-action="Edit" asp-route-id="@Model.ProductId" style="color:var(--gold);font-weight:700">Thêm phân loại →</a>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ── RENTAL: Chi tiết cài đặt ── -->
            @if (behavior == "Rental")
            {
                <div class="dc">
                    <div class="dc-hd" style="border-left:4px solid var(--blue)">
                        <i class="bi bi-arrow-repeat" style="color:var(--blue)"></i>
                        <span class="dc-hd-title">Cài đặt cho thuê</span>
                    </div>
                    <div class="dc-bd">
                        <div class="rental-info-grid">
                            <div class="ri-box">
                                <div class="ri-val">₫@Model.DepositAmount.ToString("N0")</div>
                                <div class="ri-lbl">Đặt cọc</div>
                            </div>
                            <div class="ri-box">
                                <div class="ri-val">₫@Model.CleaningFee.ToString("N0")</div>
                                <div class="ri-lbl">Phí vệ sinh</div>
                            </div>
                            <div class="ri-box">
                                <div class="ri-val">@(Model.MaxRentalHours.HasValue? Model.MaxRentalHours + "h" : "∞")</div>
                                <div class="ri-lbl">Tối đa</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ── SERVICE: Bảng giá dịch vụ ── -->
            @if (behavior == "Service")
            {
                <div class="dc">
                    <div class="dc-hd" style="border-left:4px solid var(--purple)">
                        <i class="bi bi-tools" style="color:var(--purple)"></i>
                        <span class="dc-hd-title">Bảng giá dịch vụ</span>
                    </div>
                    <div class="dc-bd">
                        <div class="svc-grid">
                            <div class="svc-box">
                                <div class="svc-val">₫@Model.LaborPrice.ToString("N0")</div>
                                <div class="svc-lbl">Tiền công</div>
                                <div class="svc-unit">/ @(Model.LaborUnit ?? "đơn vị")</div>
                            </div>
                            <div class="svc-box">
                                <div class="svc-val">₫@Model.MaterialPrice.ToString("N0")</div>
                                <div class="svc-lbl">Vật tư</div>
                                <div class="svc-unit">@(Model.MaterialPrice == 0 ? "Khách tự mang" : $"/ {Model.LaborUnit ?? "đơn vị"}")</div>
                            </div>
                        </div>
                        @if (Model.Price > 0)
                        {
                            <div class="info-row" style="margin-top:1rem">
                                <span class="info-lbl">Giá trọn gói</span>
                                <span class="info-val" style="color:var(--gold)">₫@Model.Price.ToString("N0")</span>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<div class="toast-wrap" id="toastWrap"></div>

@section Scripts {
    <script>
        function deleteProduct(id) {
            if (!confirm('Xóa sản phẩm này? Thao tác không thể hoàn tác.')) return;
            fetch(`/Admin/AdminProduct/Delete/${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' }
            }).then(r => r.json()).then(data => {
                if (data.success) { window.location.href = '/Admin/AdminProduct'; }
                else { showToast(data.message || 'Không thể xóa!'); }
            });
        }
        function showToast(msg) {
            const wrap = document.getElementById('toastWrap');
            const el = document.createElement('div');
            el.className = 'toast-msg';
            el.innerHTML = `<i class="bi bi-exclamation-circle-fill"></i> ${msg}`;
            wrap.appendChild(el);
            setTimeout(() => el.remove(), 3200);
        }
    </script>
}
