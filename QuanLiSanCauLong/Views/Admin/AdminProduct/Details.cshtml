@model QuanLiSanCauLong.Models.Product
@{
    ViewData["Title"] = "Chi tiết — " + Model.ProductName;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var bh = Model.Category?.BehaviorType ?? "Retail";
    var activeVars = Model.Variants?.Where(v => v.IsActive).OrderBy(v => v.SizeName).ThenBy(v => v.ColorName).ToList() ?? new();
    var hasVars = activeVars.Any();
    var totalStk = hasVars ? activeVars.Sum(v => v.StockQuantity) : Model.StockQuantity;
    var totalRes = hasVars ? activeVars.Sum(v => v.ReservedQuantity) : Model.ReservedQuantity;
    var totalAvail = totalStk - totalRes;
    var isLow = bh == "Retail" && Model.MinStockLevel > 0 && totalStk <= Model.MinStockLevel;
    string BhLbl(string b) => b switch { "Rental" => "Cho thuê", "Service" => "Dịch vụ", _ => "Bán lẻ" };
    string BhIco(string b) => b switch { "Rental" => "bi-arrow-repeat", "Service" => "bi-wrench-adjustable", _ => "bi-cart3" };
    string BhBg(string b) => b switch { "Rental" => "#eff6ff", "Service" => "#f5f3ff", _ => "#f0fdf4" };
    string BhClr(string b) => b switch { "Rental" => "#1d4ed8", "Service" => "#7c3aed", _ => "#166534" };
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
        --purple: #7c3aed;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }

    .bc {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .8rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .28rem;
        }

            .bc a:hover {
                color: var(--deep);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--deep);
        font-weight: 700;
    }

    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .pg-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

    .pg-sku {
        font-size: .76rem;
        color: var(--muted);
        margin-top: .2rem;
        font-family: monospace;
    }

    .bh-badge {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        padding: .25rem .75rem;
        border-radius: 5px;
        font-size: .72rem;
        font-weight: 700;
    }

    .hd-btns {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .65rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-edit:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
            color: var(--deep);
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .62rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        transition: all .18s;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-del {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .62rem 1.1rem;
        border: 1.5px solid rgba(201,75,42,.3);
        border-radius: 7px;
        background: rgba(201,75,42,.05);
        font-size: .82rem;
        font-weight: 600;
        color: var(--red);
        cursor: pointer;
        transition: all .18s;
    }

        .btn-del:hover {
            background: var(--red);
            color: #fff;
            border-color: var(--red);
        }

    .detail-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.4rem;
        align-items: start;
    }

    @@media(max-width:960px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }
    }

    .img-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .img-card-img {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        display: block;
    }

    .img-ph {
        width: 100%;
        aspect-ratio: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: var(--warm);
        gap: .5rem;
    }

        .img-ph i {
            font-size: 3rem;
            color: rgba(26,18,9,.1);
        }

        .img-ph span {
            font-size: .76rem;
            color: var(--muted);
        }

    .card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

        .card:last-child {
            margin-bottom: 0;
        }

    .card-hd {
        background: var(--warm);
        padding: .7rem 1.1rem;
        border-bottom: 1px solid var(--border);
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .card-bd {
        padding: .9rem 1.1rem;
    }

    .irow {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: .42rem 0;
        border-bottom: 1px solid var(--border);
        gap: .75rem;
    }

        .irow:last-child {
            border-bottom: none;
        }

    .il {
        font-size: .76rem;
        color: var(--muted);
        flex-shrink: 0;
    }

    .iv {
        font-size: .84rem;
        font-weight: 600;
        color: var(--deep);
        text-align: right;
    }

        .iv.gold {
            color: var(--gold);
        }

        .iv.green {
            color: var(--green);
        }

        .iv.blue {
            color: var(--blue);
        }

        .iv.purple {
            color: var(--purple);
        }

    .st-b {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .2rem .6rem;
        border-radius: 4px;
        font-size: .65rem;
        font-weight: 700;
    }

    .sg {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1px;
        background: var(--border);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .sb {
        background: #fff;
        padding: .85rem .75rem;
        text-align: center;
    }

    .sn {
        font-family: 'Playfair Display',serif;
        font-size: 1.55rem;
        font-weight: 700;
        line-height: 1;
    }

    .sl {
        font-size: .6rem;
        letter-spacing: .09em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .18rem;
    }

    .vtbl {
        width: 100%;
        border-collapse: collapse;
    }

        .vtbl th {
            padding: .55rem .8rem;
            background: var(--warm);
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        .vtbl td {
            padding: .62rem .8rem;
            border-bottom: 1px solid var(--border);
            font-size: .82rem;
            color: var(--deep);
        }

        .vtbl tr:last-child td {
            border-bottom: none;
        }

        .vtbl tr:hover td {
            background: var(--cream);
        }

    .vtag {
        display: inline-block;
        padding: .12rem .45rem;
        border-radius: 4px;
        font-size: .66rem;
        font-weight: 700;
        background: var(--warm);
        border: 1px solid var(--border);
        color: var(--muted);
    }

    .vdash {
        color: var(--muted);
        font-size: .8rem;
    }

    .vs-ok {
        color: var(--green);
        font-weight: 700;
    }

    .vs-warn {
        color: #c2410c;
        font-weight: 700;
    }

    .vs-zero {
        color: var(--muted);
    }

    .vbar-w {
        height: 6px;
        background: var(--warm);
        border-radius: 3px;
        overflow: hidden;
        width: 80px;
    }

    .vbar-f {
        height: 100%;
        border-radius: 3px;
        background: linear-gradient(90deg,var(--gold),var(--gold2));
    }

    .desc-t {
        font-size: .84rem;
        line-height: 1.8;
        color: var(--deep);
        padding: .5rem 0;
    }

    .empty-sm {
        text-align: center;
        padding: 1.5rem;
        color: var(--muted);
        font-size: .8rem;
    }

        .empty-sm i {
            display: block;
            font-size: 1.8rem;
            opacity: .2;
            margin-bottom: .4rem;
        }

    .warn-bar {
        padding: .65rem 1rem;
        background: #fff7ed;
        border: 1px solid #fed7aa;
        border-radius: 7px;
        font-size: .78rem;
        color: #c2410c;
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1rem;
    }
</style>

<div class="pg">
    <div class="bc">
        <a href="@Url.Action("Index", "AdminProduct")"><i class="bi bi-house"></i> Sản phẩm</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <span class="bc-cur">@Model.ProductName</span>
    </div>

    <div class="pg-hd">
        <div>
            <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:.25rem;">
                <h1 class="pg-name">@Model.ProductName</h1>
                <span class="bh-badge" style="background:@BhBg(bh);color:@BhClr(bh);">
                    <i class="bi @BhIco(bh)"></i> @BhLbl(bh)
                </span>
            </div>
            <div class="pg-sku">SKU: @(Model.ProductCode ?? Model.SKU ?? "N/A") &nbsp;·&nbsp; ID: #@Model.ProductId</div>
        </div>
        <div class="hd-btns">
            <a href="@Url.Action("Index", "AdminProduct")" class="btn-back"><i class="bi bi-arrow-left"></i> Danh sách</a>
            <button class="btn-edit" onclick="openEditModal(@Model.ProductId)"><i class="bi bi-pencil"></i> Chỉnh sửa</button>
            <button class="btn-del" onclick="delProd(@Model.ProductId,'@Html.Raw(Model.ProductName.Replace("'", "\'"))')"><i class="bi bi-trash3"></i></button>
        </div>
    </div>

    @if (isLow)
    {
        <div class="warn-bar">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Sắp hết hàng!</strong> Tồn kho (@totalStk) ≤ ngưỡng tối thiểu (@Model.MinStockLevel).
        </div>
    }

    <div class="detail-grid">

        <!-- LEFT -->
        <div>
            <div class="img-card">
                @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl != "/images/no-image.png")
                {
                    <img src="@Model.ImageUrl" class="img-card-img" alt="@Model.ProductName"
                         onerror="this.style.display='none';document.getElementById('imgPh').style.display='flex'" />
                    <div id="imgPh" class="img-ph" style="display:none;">
                        <i class="bi bi-image"></i>
                        <span>Ảnh lỗi</span>
                    </div>
                }
                else
                {
                    <div class="img-ph">
                        <i class="bi @BhIco(bh)"></i>
                        <span>Chưa có ảnh</span>
                    </div>
                }
            </div>

            <div class="card" style="margin-top:1rem;">
                <div class="card-hd"><i class="bi bi-tag"></i> Danh mục &amp; Trạng thái</div>
                <div class="card-bd">
                    <div class="irow">
                        <span class="il">Danh mục</span>
                        <span class="iv">@(Model.Category?.CategoryName ?? "—")</span>
                    </div>
                    <div class="irow">
                        <span class="il">Đơn vị</span>
                        <span class="iv">@(Model.Unit ?? "—")</span>
                    </div>
                    <div class="irow">
                        <span class="il">Trạng thái</span>
                        <span class="iv">
                            @if (Model.Status == "Active")
                            {
                                <span class="st-b" style="background:#f0fdf4;color:#15803d;">
                                    <i class="bi bi-check-circle-fill"></i> Còn hàng
                                </span>
                            }
                            else if (Model.Status == "OutOfStock")
                            {
                                <span class="st-b" style="background:#fff7ed;color:#c2410c;">
                                    <i class="bi bi-exclamation-circle-fill"></i> Hết hàng
                                </span>
                            }
                            else
                            {
                                <span class="st-b" style="background:#f9fafb;color:#6b7280;">
                                    <i class="bi bi-x-circle-fill"></i> Ngừng bán
                                </span>
                            }
                        </span>
                    </div>
                    <div class="irow">
                        <span class="il">Ngày tạo</span>
                        <span class="iv" style="font-size:.76rem;">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="irow">
                        <span class="il">Cập nhật</span>
                        <span class="iv" style="font-size:.76rem;">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div>

            @if (bh == "Retail")
            {
                var spare = totalStk - Model.MinStockLevel;
                <div class="sg">
                    <div class="sb">
                        <div class="sn @(isLow ? "text-danger" : "")">@totalStk</div>
                        <div class="sl">Tồn kho</div>
                    </div>
                    <div class="sb">
                        <div class="sn">@Model.MinStockLevel</div>
                        <div class="sl">Safety stock</div>
                    </div>
                    <div class="sb">
                        <div class="sn" style="color:var(--green)">@(spare > 0 ? spare : 0)</div>
                        <div class="sl">Dư an toàn</div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-hd"><i class="bi bi-currency-dollar"></i> Giá bán</div>
                    <div class="card-bd">
                        <div class="irow">
                            <span class="il">Giá bán lẻ</span>
                            <span class="iv gold" style="font-size:1rem;">@Model.Price.ToString("N0")đ</span>
                        </div>
                        @if (Model.CostPrice > 0)
                        {
                            <div class="irow">
                                <span class="il">Giá nhập</span>
                                <span class="iv">@Model.CostPrice.ToString("N0")đ</span>
                            </div>
                            <div class="irow">
                                <span class="il">Lợi nhuận / đơn vị</span>
                                <span class="iv green">+@((Model.Price - Model.CostPrice).ToString("N0"))đ</span>
                            </div>
                        }
                        @if (Model.SalePrice > 0)
                        {
                            <div class="irow">
                                <span class="il">Giá sỉ</span>
                                <span class="iv blue">@Model.SalePrice.ToString("N0")đ</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (bh == "Rental")
            {
                <div class="sg">
                    <div class="sb">
                        <div class="sn" style="color:var(--blue)">@totalAvail</div>
                        <div class="sl">Có sẵn</div>
                    </div>
                    <div class="sb">
                        <div class="sn" style="color:#c2410c;">@totalRes</div>
                        <div class="sl">Đang thuê</div>
                    </div>
                    <div class="sb">
                        <div class="sn">@totalStk</div>
                        <div class="sl">Tổng số</div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-hd"><i class="bi bi-arrow-repeat"></i> Cấu hình cho thuê</div>
                    <div class="card-bd">
                        <div class="irow">
                            <span class="il">Giá thuê / giờ</span>
                            <span class="iv gold" style="font-size:1rem;">@Model.Price.ToString("N0")đ/h</span>
                        </div>
                        <div class="irow">
                            <span class="il">Tiền đặt cọc</span>
                            <span class="iv">@(Model.DepositAmount > 0 ? Model.DepositAmount.ToString("N0") + "đ" : "Không yêu cầu")</span>
                        </div>
                        <div class="irow">
                            <span class="il">Phí vệ sinh</span>
                            <span class="iv">@(Model.CleaningFee > 0 ? Model.CleaningFee.ToString("N0") + "đ" : "Không")</span>
                        </div>
                        <div class="irow">
                            <span class="il">Thời gian tối đa</span>
                            <span class="iv">@(Model.MaxRentalHours.HasValue? Model.MaxRentalHours + " giờ" : "Không giới hạn")</span>
                        </div>
                    </div>
                </div>
            }

            @if (bh == "Service")
            {
                <div class="card">
                    <div class="card-hd"><i class="bi bi-wrench-adjustable"></i> Cấu hình dịch vụ</div>
                    <div class="card-bd">
                        <div class="irow">
                            <span class="il">Tiền công</span>
                            <span class="iv purple" style="font-size:1rem;">@Model.LaborPrice.ToString("N0")đ</span>
                        </div>
                        <div class="irow">
                            <span class="il">Đơn vị công</span>
                            <span class="iv">@(Model.LaborUnit ?? "—")</span>
                        </div>
                        @if (Model.MaterialPrice > 0)
                        {
                            <div class="irow">
                                <span class="il">Tiền vật tư</span>
                                <span class="iv">@Model.MaterialPrice.ToString("N0")đ</span>
                            </div>
                            <div class="irow">
                                <span class="il">Tổng / lần</span>
                                <span class="iv gold">@((Model.LaborPrice + Model.MaterialPrice).ToString("N0"))đ</span>
                            </div>
                        }
                        @if (Model.Price > 0)
                        {
                            <div class="irow">
                                <span class="il">Giá trọn gói</span>
                                <span class="iv gold">@Model.Price.ToString("N0")đ</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (bh != "Service")
            {
                <div class="card">
                    <div class="card-hd">
                        <i class="bi bi-layers"></i> Phân loại (size / màu)
                        @if (hasVars)
                        {
                            <span style="margin-left:.35rem;font-size:.6rem;font-weight:600;padding:.1rem .4rem;background:rgba(212,160,23,.15);color:#92660a;border-radius:3px;">
                                @activeVars.Count biến thể
                            </span>
                        }
                    </div>
                    @if (hasVars)
                    {
                        <div style="overflow-x:auto;">
                            <table class="vtbl">
                                <thead>
                                    <tr>
                                        <th>Size</th>
                                        <th>Màu</th>
                                        <th>SKU</th>
                                        <th style="text-align:right">Tồn kho</th>
                                        @if (bh == "Rental")
                                        {
                                            <th style="text-align:right">Đang thuê</th>
                                            <th style="text-align:right">Có sẵn</th>
                                        }
                                        <th style="text-align:right">Safety</th>
                                        <th style="width:90px">Tỉ lệ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in activeVars)
                                    {
                                        var avail = v.StockQuantity - v.ReservedQuantity;
                                        var pct = v.StockQuantity > 0 ? (int)((double)avail / v.StockQuantity * 100) : 0;
                                        var vLow = v.MinStockLevel > 0 && v.StockQuantity <= v.MinStockLevel;
                                        var sCls = vLow ? "vs-warn" : v.StockQuantity > 0 ? "vs-ok" : "vs-zero";
                                        <tr>
                                            <td>
                                                @if (string.IsNullOrEmpty(v.SizeName))
                                                {
                                                    <span class="vdash">—</span>
                                                }
                                                else
                                                {
                                                    <span class="vtag">@v.SizeName</span>
                                                }
                                            </td>
                                            <td>
                                                @if (string.IsNullOrEmpty(v.ColorName))
                                                {
                                                    <span class="vdash">—</span>
                                                }
                                                else
                                                {
                                                    <span class="vtag">@v.ColorName</span>
                                                }
                                            </td>
                                            <td>
                                                <span style="font-family:monospace;font-size:.72rem;color:var(--muted);">@v.VariantSKU</span>
                                            </td>
                                            <td style="text-align:right;" class="@sCls">@v.StockQuantity</td>
                                            @if (bh == "Rental")
                                            {
                                                <td style="text-align:right;color:#c2410c;">@v.ReservedQuantity</td>
                                                <td style="text-align:right;color:var(--blue);font-weight:700;">@avail</td>
                                            }
                                            <td style="text-align:right;font-size:.76rem;color:var(--muted);">@v.MinStockLevel</td>
                                            <td>
                                                <div class="vbar-w">
                                                    <div class="vbar-f" style="width:@(pct)%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="card-bd">
                            <div class="empty-sm">
                                <i class="bi bi-layers"></i>
                                Không có phân loại size/màu
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card">
                    <div class="card-hd"><i class="bi bi-text-paragraph"></i> Mô tả</div>
                    <div class="card-bd">
                        <div class="desc-t">@Model.Description</div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<!-- MODAL EDIT -->
<div class="modal fade" id="prodModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width:860px">
        <div class="modal-content" id="prodModalBody" style="border-radius:14px;border:none;">
            <div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        let prodModal;
        document.addEventListener('DOMContentLoaded', () => {
            prodModal = new bootstrap.Modal(document.getElementById('prodModal'));
        });
        function runScripts(el) {
            el.querySelectorAll('script').forEach(s => {
                const n = document.createElement('script');
                n.text = s.text;
                s.replaceWith(n);
            });
        }
        async function openEditModal(id) {
            document.getElementById('prodModalBody').innerHTML =
                '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            prodModal.show();
            const r = await fetch(`/Admin/AdminProduct/Edit/${id}`);
            document.getElementById('prodModalBody').innerHTML = await r.text();
            runScripts(document.getElementById('prodModalBody'));
        }
        function delProd(id, name) {
            Swal.fire({
                title: `Xóa "${name}"?`, text: 'Không thể hoàn tác.', icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#c94b2a', cancelButtonColor: '#8a7560',
                confirmButtonText: 'Xóa', cancelButtonText: 'Hủy', reverseButtons: true
            }).then(async r => {
                if (!r.isConfirmed) return;
                const res = await fetch(`/Admin/AdminProduct/Delete/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': TOKEN }
                }).then(r => r.json());
                if (res.success) window.location.href = '/Admin/AdminProduct';
                else Swal.fire('Không thể xóa!', res.message, 'error');
            });
        }
    </script>
}
