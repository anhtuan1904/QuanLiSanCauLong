@model QuanLiSanCauLong.Models.Product
@{
    Layout = null;
    var bh = Model.Category?.BehaviorType ?? "Retail";
    var cats = ViewBag.Categories as IEnumerable<QuanLiSanCauLong.Models.ProductCategory> ?? Enumerable.Empty<QuanLiSanCauLong.Models.ProductCategory>();
    var catsJson = ViewBag.CategoriesJson as string ?? "[]";
    var activeVars = Model.Variants?.Where(v => v.IsActive).OrderBy(v => v.SizeName).ThenBy(v => v.ColorName).ToList() ?? new();
}
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
        --purple: #7c3aed;
        --orange: #c2410c;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .md-hd {
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg,var(--deep),#2d1f0f);
        border-bottom: 1px solid rgba(255,255,255,.07);
    }

    .md-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
    }

        .md-title em {
            color: var(--gold2);
            font-style: italic;
            font-size: .95rem;
        }

    .md-title-meta {
        font-size: .63rem;
        color: rgba(255,255,255,.3);
        font-family: monospace;
        margin-left: .55rem;
    }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.4);
        font-size: .95rem;
        cursor: pointer;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .15s;
    }

        .md-close:hover {
            background: rgba(255,255,255,.15);
            color: #fff;
        }

    .md-body {
        padding: 1.3rem 1.5rem;
        max-height: 72vh;
        overflow-y: auto;
    }

        .md-body::-webkit-scrollbar {
            width: 4px;
        }

        .md-body::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 4px;
        }

    .md-ft {
        padding: .9rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--cream);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: .55rem;
    }

    .sec {
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--muted);
        padding: .4rem 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: .9rem;
        display: flex;
        align-items: center;
        gap: .38rem;
    }

    .row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .8rem;
    }

    .row3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .75rem;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: .28rem;
        margin-bottom: .82rem;
    }

        .fg label {
            font-size: .73rem;
            font-weight: 700;
            color: var(--deep);
        }

    .req {
        color: var(--red);
    }

    .hint {
        font-size: .67rem;
        color: var(--muted);
    }

    .fi {
        padding: .58rem .88rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        width: 100%;
        transition: all .2s;
    }

        .fi:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,160,23,.1);
        }

    textarea.fi {
        resize: vertical;
        min-height: 60px;
    }

    /* read-only system block */
    .ro-block {
        background: linear-gradient(135deg,#231a0e,var(--deep));
        border-radius: 10px;
        padding: .82rem 1.05rem;
        margin-bottom: 1.1rem;
    }

    .ro-hd {
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: rgba(255,255,255,.4);
        margin-bottom: .55rem;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .ro-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .8rem;
        padding: .22rem 0;
        border-bottom: 1px solid rgba(255,255,255,.07);
    }

        .ro-row:last-of-type {
            border: none;
        }

    .ro-lbl {
        color: rgba(255,255,255,.45);
    }

    .ro-val {
        font-weight: 700;
        color: #fff;
    }

        .ro-val.warn {
            color: var(--gold2);
        }

    .ro-note {
        font-size: .68rem;
        color: rgba(255,255,255,.3);
        margin-top: .5rem;
        display: flex;
        align-items: flex-start;
        gap: .35rem;
        line-height: 1.5;
    }

    /* behavior indicator */
    .bh-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .55rem;
        margin-bottom: .4rem;
    }

    .bh-card {
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: .75rem .8rem;
        text-align: center;
        background: #fff;
        opacity: .5;
        cursor: default;
    }

        .bh-card.on-Retail {
            border-color: #16a34a;
            background: linear-gradient(135deg,#f0fdf4,#dcfce7);
            opacity: 1;
        }

        .bh-card.on-Rental {
            border-color: #1d4ed8;
            background: linear-gradient(135deg,#eff6ff,#dbeafe);
            opacity: 1;
        }

        .bh-card.on-Service {
            border-color: #7c3aed;
            background: linear-gradient(135deg,#f5f3ff,#ede9fe);
            opacity: 1;
        }

    .bh-icon {
        font-size: 1.2rem;
        display: block;
        margin-bottom: .25rem;
    }

    .bh-nm {
        font-weight: 700;
        font-size: .8rem;
        color: var(--deep);
    }

    /* money input */
    .money-w {
        position: relative;
    }

        .money-w .fi {
            padding-right: 1.6rem;
        }

    .money-sfx {
        position: absolute;
        right: .6rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: .72rem;
        color: var(--muted);
        pointer-events: none;
    }

    /* info hints */
    .info-hint {
        padding: .55rem .9rem;
        border-radius: 8px;
        font-size: .76rem;
        line-height: 1.55;
        display: flex;
        align-items: flex-start;
        gap: .45rem;
        margin-bottom: .85rem;
    }

    .ib-green {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #15803d;
    }

    .ib-blue {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
    }

    .ib-purple {
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
        color: #7c3aed;
    }

    .ib-warn {
        background: #fff7ed;
        border: 1px solid #fed7aa;
        color: #c2410c;
    }

    /* combobox */
    .combo-w {
        position: relative;
    }

    .combo-list {
        position: absolute;
        top: calc(100% + 3px);
        left: 0;
        right: 0;
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        z-index: 100;
        box-shadow: 0 8px 28px rgba(0,0,0,.11);
        max-height: 180px;
        overflow-y: auto;
        display: none;
    }

        .combo-list.show {
            display: block;
        }

    .combo-opt {
        padding: .44rem .88rem;
        font-size: .83rem;
        cursor: pointer;
        color: var(--deep);
        transition: background .1s;
    }

        .combo-opt:hover {
            background: var(--warm);
        }

    /* variants */
    .vtbl {
        width: 100%;
        border-collapse: collapse;
        font-size: .81rem;
    }

        .vtbl th {
            padding: .44rem .65rem;
            font-size: .61rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            background: var(--warm);
            border-bottom: 1px solid var(--border);
        }

        .vtbl td {
            padding: .38rem .55rem;
            border-bottom: 1px solid var(--border);
        }

        .vtbl tr:last-child td {
            border-bottom: none;
        }

        .vtbl input {
            width: 100%;
            padding: .36rem .55rem;
            border: 1.5px solid var(--border);
            border-radius: 6px;
            font-size: .8rem;
            background: #fff;
            outline: none;
        }

            .vtbl input:focus {
                border-color: var(--gold);
            }

    .vt-del {
        width: 24px;
        height: 24px;
        border-radius: 5px;
        border: 1.5px solid var(--border);
        background: #fff;
        cursor: pointer;
        color: var(--muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
        transition: .15s;
    }

        .vt-del:hover:not(:disabled) {
            border-color: var(--red);
            color: var(--red);
        }

        .vt-del:disabled {
            opacity: .35;
            cursor: not-allowed;
        }

    .vt-res {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        font-size: .72rem;
        color: var(--orange);
        font-weight: 600;
    }

    .btn-add-var {
        padding: .36rem .8rem;
        border: 1.5px dashed var(--border);
        border-radius: 7px;
        background: transparent;
        font-size: .76rem;
        font-weight: 700;
        cursor: pointer;
        color: var(--muted);
        transition: .18s;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        margin-top: .5rem;
    }

        .btn-add-var:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

    .sz-pills {
        display: flex;
        flex-wrap: wrap;
        gap: .28rem;
        margin-bottom: .35rem;
    }

    .sz-pill {
        padding: .17rem .55rem;
        border: 1.5px solid var(--border);
        border-radius: 20px;
        font-size: .72rem;
        cursor: pointer;
        background: #fff;
        color: var(--muted);
        transition: .15s;
    }

        .sz-pill:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

    /* footer */
    .btn-cancel {
        padding: .6rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        font-size: .83rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: .18s;
    }

        .btn-cancel:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .62rem 1.4rem;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        transition: .2s;
        box-shadow: 0 2px 8px rgba(212,160,23,.3);
    }

        .btn-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.45);
        }

        .btn-save:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
</style>

@Html.AntiForgeryToken()

<div class="md-hd">
    <div>
        <span class="md-title">Sửa <em>@Model.ProductName</em></span>
        <span class="md-title-meta">#@Model.ProductId · @(Model.ProductCode ?? Model.SKU ?? "")</span>
    </div>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">

    @* System readonly block *@
    <div class="ro-block">
        <div class="ro-hd"><i class="bi bi-lock-fill"></i> Thông số hệ thống</div>
        <div class="ro-row"><span class="ro-lbl">Tổng tồn kho</span><span class="ro-val">@Model.StockQuantity @(Model.Unit ?? "")</span></div>
        @if (Model.ReservedQuantity > 0)
        {
            <div class="ro-row"><span class="ro-lbl">Đang @(bh == "Rental" ? "cho thuê" : "xử lý / treo")</span><span class="ro-val warn">@Model.ReservedQuantity @(Model.Unit ?? "")</span></div>
        }
        <div class="ro-row"><span class="ro-lbl">Ngày tạo</span><span class="ro-val" style="font-weight:400;font-size:.74rem">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
        <div class="ro-note"><i class="bi bi-info-circle"></i>Tồn kho thay đổi qua Nhập/Xuất kho. Số lượng đang treo/thuê không chỉnh thủ công.</div>
    </div>

    <div class="sec"><i class="bi bi-info-circle"></i> Thông tin cơ bản</div>
    <div class="fg">
        <label>Tên sản phẩm / dịch vụ <span class="req">*</span></label>
        <input type="text" id="inp_name" class="fi" maxlength="200" value="@Model.ProductName" />
    </div>
    <div class="row2">
        <div class="fg">
            <label>Mã SKU</label>
            <input type="text" id="inp_sku" class="fi" value="@(Model.ProductCode ?? Model.SKU ?? "")" />
        </div>
        <div class="fg">
            <label>Danh mục</label>
            <select id="inp_cat" class="fi" onchange="onCatChange(this.value)">
                <option value="">-- Chọn --</option>
                @foreach (var c in cats)
                {
                    var bhLbl2 = c.BehaviorType == "Retail" ? "Bán lẻ" : c.BehaviorType == "Rental" ? "Cho thuê" : "Dịch vụ";
                    <option value="@c.CategoryId" data-bh="@c.BehaviorType" data-unit="@c.DefaultUnit"
                            selected="@(Model.CategoryId==c.CategoryId?"selected":null)">
                        @c.CategoryName (@bhLbl2)
                    </option>
                }
            </select>
        </div>
    </div>
    <div class="row2">
        <div class="fg">
            <label>Đơn vị tính</label>
            <div class="combo-w">
                <input type="text" id="inp_unit" class="fi" value="@(Model.Unit ?? "")"
                       onfocus="showCombo('unitList')" oninput="filterCombo('unitList',this.value)" />
                <div class="combo-list" id="unitList">
                    @foreach (var u in new[] { "Cái", "Bộ", "Chiếc", "Đôi", "Chai", "Lon", "Hộp", "Thùng", "Túi", "Kg", "Gram", "Lít", "Lần", "Buổi" })
                    {
                        <div class="combo-opt" onclick="pickCombo('inp_unit','@u')">@u</div>
                    }
                </div>
            </div>
        </div>
        <div class="fg">
            <label>Trạng thái</label>
            @{
                var st = Model.Status ?? "Active";
            }
            <select id="inp_status" class="fi">
                <option value="Active" selected="@(st == "Active" ? "selected" : null)">✅ Hoạt động / Còn hàng</option>
                <option value="OutOfStock" selected="@(st == "OutOfStock" ? "selected" : null)">⚠ Hết hàng</option>
                <option value="Inactive" selected="@(st == "Inactive" ? "selected" : null)">⛔ Ngừng kinh doanh</option>
            </select>
        </div>
    </div>
    <div class="fg">
        <label>Mô tả</label>
        <textarea id="inp_desc" class="fi" rows="2" placeholder="Mô tả ngắn...">@(Model.Description ?? "")</textarea>
    </div>

    @* Behavior indicator (read-only) *@
    <div class="sec"><i class="bi bi-diagram-3"></i> Nhóm nghiệp vụ</div>
    <div class="bh-row">
        <div class="bh-card @(bh == "Retail" ? "on-Retail" : "")"><span class="bh-icon"><i class="bi bi-cart3" style="color:#16a34a"></i></span><div class="bh-nm">Bán lẻ</div></div>
        <div class="bh-card @(bh == "Rental" ? "on-Rental" : "")"><span class="bh-icon"><i class="bi bi-arrow-repeat" style="color:#1d4ed8"></i></span><div class="bh-nm">Cho thuê</div></div>
        <div class="bh-card @(bh == "Service" ? "on-Service" : "")"><span class="bh-icon"><i class="bi bi-wrench-adjustable" style="color:#7c3aed"></i></span><div class="bh-nm">Dịch vụ</div></div>
    </div>
    <p style="font-size:.7rem;color:var(--muted);margin-top:-.3rem;margin-bottom:1rem"><i class="bi bi-info-circle me-1"></i>Nhóm xác định bởi danh mục. Đổi danh mục để thay đổi nhóm.</p>

    @* Retail *@
    @if (bh == "Retail")
    {
        <div class="sec"><i class="bi bi-currency-dollar" style="color:var(--green)"></i> Giá bán</div>
        <div class="info-hint ib-green"><i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px"></i>Chỉ sửa giá tại đây. Tồn kho điều chỉnh qua module Nhập/Xuất kho.</div>
        <div class="row3">
            <div class="fg"><label>Giá bán lẻ (đ)</label><div class="money-w"><input type="number" id="inp_price" class="fi" min="0" step="1000" value="@Model.Price"><span class="money-sfx">₫</span></div></div>
            <div class="fg"><label>Giá nhập (đ)</label><div class="money-w"><input type="number" id="inp_cost" class="fi" min="0" step="1000" value="@Model.CostPrice"><span class="money-sfx">₫</span></div></div>
            <div class="fg"><label>Safety stock (≤ cảnh báo)</label><input type="number" id="inp_minstk" class="fi" min="0" value="@Model.MinStockLevel" /><span class="hint">Để 0 = tắt cảnh báo</span></div>
        </div>
    }

    @* Rental *@
    @if (bh == "Rental")
    {
        <div class="sec"><i class="bi bi-arrow-repeat" style="color:var(--blue)"></i> Cấu hình cho thuê</div>
        @if (Model.ReservedQuantity > 0)
        {
            <div class="info-hint ib-warn"><i class="bi bi-exclamation-circle-fill" style="flex-shrink:0;margin-top:1px"></i>Hiện có <strong>@Model.ReservedQuantity</strong> đang cho thuê — tự cập nhật khi khách trả.</div>
        }
        <div class="row3">
            <div class="fg"><label>Giá thuê / lần (đ)</label><div class="money-w"><input type="number" id="inp_rent_price" class="fi" min="0" step="1000" value="@Model.Price"><span class="money-sfx">₫</span></div></div>
            <div class="fg"><label>Tiền đặt cọc (đ)</label><div class="money-w"><input type="number" id="inp_deposit" class="fi" min="0" step="1000" value="@Model.DepositAmount"><span class="money-sfx">₫</span></div></div>
            <div class="fg"><label>Phí vệ sinh (đ)</label><div class="money-w"><input type="number" id="inp_cleaning" class="fi" min="0" step="1000" value="@Model.CleaningFee"><span class="money-sfx">₫</span></div></div>
        </div>
        <div class="fg" style="max-width:220px">
            <label>Thời gian tối đa (giờ)</label>
            <input type="number" id="inp_maxhours" class="fi" min="1" placeholder="Không giới hạn" value="@(Model.MaxRentalHours.HasValue? Model.MaxRentalHours.ToString():"")" />
            <span class="hint">Bỏ trống = không giới hạn</span>
        </div>
    }

    @* Service *@
    @if (bh == "Service")
    {
        <div class="sec"><i class="bi bi-wrench-adjustable" style="color:var(--purple)"></i> Cấu hình dịch vụ</div>
        <div class="info-hint ib-purple"><i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:1px"></i>Dịch vụ không có kho vật lý. Giá = tiền công + vật tư.</div>
        <div class="row2">
            <div class="fg"><label>Tiền công (đ)</label><div class="money-w"><input type="number" id="inp_labor" class="fi" min="0" step="1000" value="@Model.LaborPrice"><span class="money-sfx">₫</span></div></div>
            <div class="fg">
                <label>Đơn vị công</label>
                <div class="combo-w">
                    <input type="text" id="inp_laborunit" class="fi" value="@(Model.LaborUnit ?? "")" onfocus="showCombo('luList')" oninput="filterCombo('luList',this.value)" />
                    <div class="combo-list" id="luList">
                        @foreach (var u in new[] { "bộ", "chiếc", "cặp", "lần", "buổi" })
                        {
                            <div class="combo-opt" onclick="pickCombo('inp_laborunit','@u')">@u</div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="row2">
            <div class="fg"><label>Tiền vật tư (đ)</label><div class="money-w"><input type="number" id="inp_material" class="fi" min="0" step="1000" value="@Model.MaterialPrice"><span class="money-sfx">₫</span></div><span class="hint">Để 0 nếu khách tự mang</span></div>
            <div class="fg"><label>Giá trọn gói (đ)</label><div class="money-w"><input type="number" id="inp_svc_price" class="fi" min="0" step="1000" placeholder="Tự tính" value="@(Model.Price > 0 ? Model.Price.ToString() : "")"><span class="money-sfx">₫</span></div><span class="hint">Bỏ trống = công + vật tư</span></div>
        </div>
    }

    @* Variants *@
    @if (bh != "Service")
    {
        <div class="sec"><i class="bi bi-layers"></i> Phân loại size / màu <span style="font-weight:400;font-style:italic;font-size:.65rem">(tùy chọn)</span></div>
        @if (Model.ReservedQuantity > 0)
        {
            <div class="info-hint ib-blue"><i class="bi bi-exclamation-circle-fill" style="flex-shrink:0;margin-top:1px"></i>Những dòng đang @(bh == "Rental" ? "cho thuê" : "dùng trong đơn") không thể xóa.</div>
        }
        <div class="sz-pills">
            @foreach (var s in new[] { "XS", "S", "M", "L", "XL", "XXL", "Free Size" })
            {
                <span class="sz-pill" onclick="qAddSize('@s')">+ @s</span>
            }
        </div>
        <div style="overflow-x:auto;border:1px solid var(--border);border-radius:9px;overflow:hidden;margin-bottom:.5rem">
            <table class="vtbl">
                <thead><tr><th>#</th><th>Size</th><th>Màu</th><th style="width:90px">Tồn kho</th><th style="width:80px">@(bh == "Rental" ? "Đang thuê" : "Treo")</th><th style="width:80px">Safety</th><th style="width:28px"></th></tr></thead>
                <tbody id="varTbody">
                    @{
                        int vIdx = 0;
                    }
                    @foreach (var v in activeVars)
                    {
                        vIdx++;
                        var locked = v.ReservedQuantity > 0;
                        <tr>
                            <td style="color:var(--muted);font-size:.72rem">@vIdx</td>
                            <input type="hidden" name="variantId" value="@v.VariantId" />
                            <td><input type="text" name="variantSize" value="@v.SizeName" placeholder="S,M,L..." /></td>
                            <td><input type="text" name="variantColor" value="@v.ColorName" placeholder="Đen..." /></td>
                            <td><input type="number" name="variantStock" value="@v.StockQuantity" min="0" /></td>
                            <td style="text-align:center">
                                @if (locked)
                                {
                                    <span class="vt-res"><i class="bi bi-hourglass-split"></i> @v.ReservedQuantity</span>
                                }
                                else
                                {

                                    <span style="color:var(--muted);font-size:.8rem">—</span>
                                }
                            </td>
                            <td><input type="number" name="variantMinStock" value="@v.MinStockLevel" min="0" /></td>
                            <td>
                                @if (locked)
                                {
                                    <button type="button" class="vt-del" disabled title="Đang được sử dụng"><i class="bi bi-x"></i></button>
                                }
                                else
                                {

                                    <button type="button" class="vt-del" onclick="this.closest('tr').remove()"><i class="bi bi-x"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button type="button" class="btn-add-var" onclick="addVarRow()"><i class="bi bi-plus-circle"></i> Thêm phân loại</button>
    }

</div>

<div class="md-ft">
    <button class="btn-cancel" data-bs-dismiss="modal">Hủy</button>
    <button class="btn-save" id="editBtnSave" onclick="submitEdit()">
        <i class="bi bi-check-lg"></i> Lưu thay đổi
    </button>
</div>

<script>
    const EDIT_ID=@Model.ProductId;
    const EDIT_BH='@bh';
    const EDIT_CAT_DATA=@Html.Raw(catsJson);
    const TOKEN_E=document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';

    function showCombo(id){hideAllCombo();document.getElementById(id)?.classList.add('show');}
    function hideAllCombo(){document.querySelectorAll('.combo-list').forEach(l=>l.classList.remove('show'));}
    function pickCombo(id,val){document.getElementById(id).value=val;hideAllCombo();}
    function filterCombo(lid,q){const l=document.getElementById(lid);if(!l)return;l.classList.add('show');l.querySelectorAll('.combo-opt').forEach(o=>{o.style.display=o.textContent.toLowerCase().includes(q.toLowerCase())?'':'none';});}
    document.addEventListener('click',e=>{if(!e.target.closest('.combo-w'))hideAllCombo();});

    function onCatChange(catId){
        const cat=EDIT_CAT_DATA.find(c=>c.CategoryId==catId);
        if(cat&&cat.DefaultUnit)document.getElementById('inp_unit').value=cat.DefaultUnit;
    }
    function qAddSize(s){
        const rows=document.querySelectorAll('#varTbody input[name="variantSize"]');
        if(Array.from(rows).some(i=>i.value===s))return;
        addVarRow(s,'');
    }
    function addVarRow(size='',color=''){
        const idx=document.querySelectorAll('#varTbody tr').length+1;
        const tr=document.createElement('tr');
        tr.innerHTML=`<td style="color:var(--muted);font-size:.72rem">${idx}</td>
            <input type="hidden" name="variantId" value="0"/>
            <td><input type="text" name="variantSize" value="${size}" placeholder="S,M,L..."/></td>
            <td><input type="text" name="variantColor" value="${color}" placeholder="Đen..."/></td>
            <td><input type="number" name="variantStock" value="0" min="0"/></td>
            <td style="text-align:center"><span style="color:var(--muted);font-size:.8rem">—</span></td>
            <td><input type="number" name="variantMinStock" value="0" min="0"/></td>
            <td><button type="button" class="vt-del" onclick="this.closest('tr').remove()"><i class="bi bi-x"></i></button></td>`;
        document.getElementById('varTbody').appendChild(tr);
    }

    async function submitEdit(){
        const name=document.getElementById('inp_name').value.trim();
        if(!name){alert('Vui lòng nhập tên sản phẩm!');return;}
        const btn=document.getElementById('editBtnSave');
        btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';
        const fd=new FormData();
        fd.append('ProductId',EDIT_ID);
        fd.append('ProductName',name);
        fd.append('ProductCode',document.getElementById('inp_sku').value.trim());
        fd.append('CategoryId',document.getElementById('inp_cat').value);
        fd.append('Unit',document.getElementById('inp_unit').value);
        fd.append('Status',document.getElementById('inp_status').value);
        fd.append('Description',document.getElementById('inp_desc').value);
        if(EDIT_BH==='Retail'){fd.append('Price',document.getElementById('inp_price').value||'0');fd.append('CostPrice',document.getElementById('inp_cost').value||'0');fd.append('MinStockLevel',document.getElementById('inp_minstk').value||'0');}
        else if(EDIT_BH==='Rental'){fd.append('Price',document.getElementById('inp_rent_price').value||'0');fd.append('depositAmount',document.getElementById('inp_deposit').value||'0');fd.append('cleaningFee',document.getElementById('inp_cleaning').value||'0');fd.append('maxRentalHours',document.getElementById('inp_maxhours').value||'');}
        else{fd.append('Price',document.getElementById('inp_svc_price').value||'0');fd.append('laborPrice',document.getElementById('inp_labor').value||'0');fd.append('laborUnit',document.getElementById('inp_laborunit').value);fd.append('materialPrice',document.getElementById('inp_material').value||'0');}
        document.querySelectorAll('#varTbody tr').forEach(row=>{
            const vid=row.querySelector('input[name="variantId"]')?.value;
            const sz=row.querySelector('input[name="variantSize"]')?.value.trim();
            const cl=row.querySelector('input[name="variantColor"]')?.value.trim();
            if(sz||cl){if(vid)fd.append('variantId',vid);fd.append('variantSize',sz||'');fd.append('variantColor',cl||'');fd.append('variantStock',row.querySelector('input[name="variantStock"]')?.value||'0');fd.append('variantMinStock',row.querySelector('input[name="variantMinStock"]')?.value||'0');}
        });
        try{
            const res=await fetch(`/Admin/AdminProduct/EditAjax/${EDIT_ID}`,{method:'POST',headers:{'RequestVerificationToken':TOKEN_E},body:fd}).then(r=>r.json());
            if(res.success){
                bootstrap.Modal.getInstance(document.getElementById('prodModal'))?.hide();
                const t=document.createElement('div');t.style.cssText='position:fixed;bottom:1.5rem;right:1.5rem;background:#15803d;color:#fff;padding:.75rem 1.3rem;border-radius:10px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 6px 24px rgba(0,0,0,.2)';
                t.innerHTML=`<i class="bi bi-check-circle-fill"></i> ${res.message}`;document.body.appendChild(t);
                setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>{t.remove();location.reload();},400);},1800);
            }else{alert(res.message||'Có lỗi xảy ra!');btn.disabled=false;btn.innerHTML='<i class="bi bi-check-lg"></i> Lưu thay đổi';}
        }catch(e){alert('Lỗi kết nối!');btn.disabled=false;btn.innerHTML='<i class="bi bi-check-lg"></i> Lưu thay đổi';}
    }
</script>
