@model QuanLiSanCauLong.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var behavior = Model.Category?.BehaviorType ?? "Retail";
    var categoriesJson = ViewBag.CategoriesJson as string ?? "[]";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #f5f4ec;
        --warm: #f0ead8;
        --card: #ffffff;
        --border: #e4d9c8;
        --muted: #8a7560;
        --green: #15803d;
        --green-soft: #dcfce7;
        --red: #dc2626;
        --blue: #1d4ed8;
        --blue-soft: #eff6ff;
        --purple: #7c3aed;
        --purple-soft: #f5f3ff;
    }

    body, .container-fluid {
        font-family: 'Outfit',sans-serif;
        background: var(--cream);
    }

    .bc {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .82rem;
        color: var(--muted);
        margin-bottom: 1.4rem;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .3rem;
        }

            .bc a:hover {
                color: var(--deep);
            }

    .bc-sep {
        opacity: .5;
    }

    .bc-cur {
        color: var(--deep);
        font-weight: 700;
    }

    .cf-wrap {
        max-width: 780px;
        margin: 0 auto;
    }

    .cf-head {
        margin-bottom: 2rem;
    }

    .cf-head-label {
        font-size: .68rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .5rem;
    }

        .cf-head-label::before {
            content: '';
            width: 16px;
            height: 1px;
            background: var(--gold);
        }

    .cf-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .cf-title em {
            font-style: italic;
            color: var(--gold);
        }

    .cf-sub {
        font-size: .85rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .cf-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 1.25rem;
        box-shadow: 0 2px 12px rgba(26,18,9,.06);
    }

    .cf-card-head {
        padding: 1.1rem 1.75rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .cf-card-head i {
            color: var(--gold);
            font-size: .95rem;
        }

    .cf-card-head-title {
        font-weight: 700;
        font-size: .92rem;
        color: var(--deep);
        flex: 1;
    }

    .cf-card-body {
        padding: 1.6rem 1.75rem;
    }

    .field-group {
        margin-bottom: 1.2rem;
    }

    .field-label {
        display: block;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--muted);
        margin-bottom: .5rem;
    }

    .field-input, .field-select, .field-textarea {
        width: 100%;
        padding: .6rem .9rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 9px;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        color: var(--deep);
        outline: none;
        transition: .18s;
    }

        .field-input:focus, .field-select:focus, .field-textarea:focus {
            border-color: var(--gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(212,160,23,.1);
        }

    .field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .field-row-3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
    }

    @@media(max-width:600px) {
        .field-row, .field-row-3 {
            grid-template-columns: 1fr;
        }
    }

    .field-hint {
        font-size: .74rem;
        color: var(--muted);
        margin-top: .25rem;
    }

    .behavior-chip {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .3rem .75rem;
        border-radius: 7px;
        font-size: .75rem;
        font-weight: 800;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .bh-retail {
        background: var(--green-soft);
        color: var(--green);
    }

    .bh-rental {
        background: var(--blue-soft);
        color: var(--blue);
    }

    .bh-service {
        background: var(--purple-soft);
        color: var(--purple);
    }

    /* Variant Table */
    .variant-table {
        width: 100%;
        border-collapse: collapse;
    }

        .variant-table th {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--muted);
            padding: .5rem .7rem;
            border-bottom: 2px solid var(--border);
            text-align: left;
            white-space: nowrap;
        }

        .variant-table td {
            padding: .5rem .7rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .variant-table tr:last-child td {
            border-bottom: none;
        }

    .vt-input {
        width: 100%;
        padding: .42rem .65rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        outline: none;
        transition: .15s;
    }

        .vt-input:focus {
            border-color: var(--gold);
            background: #fff;
        }

    .stock-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .12rem .45rem;
        border-radius: 5px;
        font-size: .72rem;
        font-weight: 700;
    }

    .stock-low {
        background: #fef9c3;
        color: #92400e;
    }

    .vt-reserved {
        color: var(--muted);
        font-size: .8rem;
    }

    .btn-rm-row {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        padding: .3rem;
        border-radius: 5px;
        transition: .15s;
    }

        .btn-rm-row:hover {
            color: var(--red);
        }

        .btn-rm-row:disabled {
            opacity: .3;
            cursor: not-allowed;
        }

    .btn-add-row {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        margin-top: .8rem;
        padding: .45rem 1rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 8px;
        font-family: 'Outfit',sans-serif;
        font-size: .82rem;
        font-weight: 700;
        color: var(--muted);
        cursor: pointer;
        transition: .15s;
    }

        .btn-add-row:hover {
            background: var(--border);
        }

    /* Image edit */
    .img-edit-box {
        display: flex;
        gap: 1.2rem;
        align-items: flex-start;
    }

    .img-edit-thumb {
        width: 110px;
        height: 110px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid var(--border);
        flex-shrink: 0;
    }

    .img-edit-right {
        flex: 1;
    }

    .img-edit-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .75rem;
        font-weight: 700;
        color: var(--gold);
        margin-bottom: .4rem;
    }

    .img-edit-hint {
        font-size: .76rem;
        color: var(--muted);
        margin-bottom: .6rem;
    }

    .field-file {
        font-size: .82rem;
        color: var(--muted);
    }

    .btn-row {
        display: flex;
        gap: .75rem;
        margin-top: 1.5rem;
    }

    .btn-cancel {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: .65rem 1.4rem;
        background: var(--warm);
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 700;
        text-decoration: none;
        transition: .18s;
    }

        .btn-cancel:hover {
            background: var(--cream);
            color: var(--deep);
        }

    .btn-submit {
        flex: 2;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: .65rem 1.4rem;
        background: var(--gold2);
        color: var(--deep);
        border: none;
        border-radius: 10px;
        font-family: 'Outfit',sans-serif;
        font-size: .88rem;
        font-weight: 800;
        cursor: pointer;
        transition: .2s;
        box-shadow: 0 2px 8px rgba(212,160,23,.3);
    }

        .btn-submit:hover {
            background: var(--gold);
            color: #fff;
        }

    .info-box {
        padding: .75rem 1rem;
        border-radius: 9px;
        font-size: .8rem;
        line-height: 1.5;
        margin-bottom: .75rem;
    }

        .info-box.blue {
            background: var(--blue-soft);
            color: var(--blue);
            border: 1px solid #93c5fd;
        }

        .info-box.purple {
            background: var(--purple-soft);
            color: var(--purple);
            border: 1px solid #c4b5fd;
        }
</style>

<div class="container-fluid px-4 py-4">
    <div class="bc">
        <a asp-action="Index"><i class="bi bi-house"></i> Sản phẩm</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <a asp-action="Details" asp-route-id="@Model.ProductId">@Model.ProductName</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <span class="bc-cur">Chỉnh sửa</span>
    </div>

    <div class="cf-wrap">
        <div class="cf-head">
            <div class="cf-head-label">Sản Phẩm</div>
            <div class="cf-title">Chỉnh sửa <em>Sản Phẩm</em></div>
            <div class="cf-sub">
                ID: #@Model.ProductId —
                <span class="behavior-chip @(behavior == "Rental" ? "bh-rental" : behavior == "Service" ? "bh-service" : "bh-retail")">
                    @(behavior == "Retail" ? "🛒 Bán lẻ" : behavior == "Rental" ? "🔄 Cho thuê" : "🔧 Dịch vụ")
                </span>
            </div>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="ImageUrl" />

            <!-- ── Thông tin cơ bản ── -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-box-seam-fill"></i>
                    <span class="cf-card-head-title">Thông tin sản phẩm</span>
                </div>
                <div class="cf-card-body">
                    <div class="field-group">
                        <label class="field-label">Tên Sản Phẩm / Dịch vụ *</label>
                        <input asp-for="ProductName" class="field-input" />
                        <span asp-validation-for="ProductName" style="font-size:.78rem;color:var(--red);display:block;margin-top:.3rem"></span>
                    </div>
                    <div class="field-row">
                        <div class="field-group"><label class="field-label">Mã SKU</label><input asp-for="ProductCode" class="field-input" /></div>
                        <div class="field-group"><label class="field-label">Đơn vị</label><input asp-for="Unit" class="field-input" /></div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Giá bán (VNĐ)</label>
                            <input asp-for="Price" type="number" class="field-input" />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Danh mục</label>
                            <select asp-for="CategoryId" class="field-select"
                                    asp-items="@(new SelectList(ViewBag.Categories, "CategoryId", "CategoryName"))">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">Trạng thái</label>
                            <select asp-for="Status" class="field-select">
                                <option value="Active">✓ Đang bán / hoạt động</option>
                                <option value="OutOfStock">⚠ Hết hàng</option>
                                <option value="Inactive">✕ Ngừng bán</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── RENTAL FIELDS ── -->
            @if (behavior == "Rental")
            {
                <div class="cf-card">
                    <div class="cf-card-head" style="border-left:4px solid var(--blue)">
                        <i class="bi bi-arrow-repeat" style="color:var(--blue)"></i>
                        <span class="cf-card-head-title">Cài đặt Cho thuê</span>
                    </div>
                    <div class="cf-card-body">
                        <div class="info-box blue">
                            <i class="bi bi-info-circle-fill"></i>
                            Khi xuất → khách cầm đi. Khi nhập → khách trả về kho. Phí vệ sinh được thu khi nhận lại.
                        </div>
                        <div class="field-row-3">
                            <div class="field-group">
                                <label class="field-label">Tiền đặt cọc (₫)</label>
                                <input type="number" name="depositAmount" class="field-input" value="@Model.DepositAmount" min="0" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">Phí vệ sinh (₫)</label>
                                <input type="number" name="cleaningFee" class="field-input" value="@Model.CleaningFee" min="0" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">Tối đa (giờ)</label>
                                <input type="number" name="maxRentalHours" class="field-input" value="@Model.MaxRentalHours" min="1" placeholder="—" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ── SERVICE FIELDS ── -->
            @if (behavior == "Service")
            {
                <div class="cf-card">
                    <div class="cf-card-head" style="border-left:4px solid var(--purple)">
                        <i class="bi bi-tools" style="color:var(--purple)"></i>
                        <span class="cf-card-head-title">Cài đặt Dịch vụ kỹ thuật</span>
                    </div>
                    <div class="cf-card-body">
                        <div class="info-box purple">
                            <i class="bi bi-info-circle-fill"></i>
                            Dịch vụ không quản lý kho vật lý. Tính tiền = tiền công + vật tư.
                        </div>
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">Tiền công (₫ / đơn vị)</label>
                                <input type="number" name="laborPrice" class="field-input" value="@Model.LaborPrice" min="0" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">Đơn vị công</label>
                                <input type="text" name="laborUnit" class="field-input" value="@Model.LaborUnit" placeholder="bộ, chiếc..." />
                            </div>
                        </div>
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">Tiền vật tư (₫ / đơn vị)</label>
                                <input type="number" name="materialPrice" class="field-input" value="@Model.MaterialPrice" min="0" />
                                <div class="field-hint">Để 0 nếu khách tự mang vật tư</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- ── RETAIL + RENTAL: Phân loại Size / Màu ── -->
            @if (behavior != "Service")
            {
                <div class="cf-card">
                    <div class="cf-card-head">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                        <span class="cf-card-head-title">Phân loại sản phẩm</span>
                        <span style="font-size:.75rem;color:var(--muted)">Chỉnh sửa hoặc thêm mới size/màu</span>
                    </div>
                    <div class="cf-card-body">
                        <p style="font-size:.82rem;color:var(--muted);margin-bottom:1rem;">
                            <i class="bi bi-info-circle"></i>
                            Điều chỉnh số lượng trực tiếp tại đây. Cột <strong>Đang treo/thuê</strong> không chỉnh sửa được.
                        </p>
                        <div style="overflow-x:auto;">
                            <table class="variant-table">
                                <thead>
                                    <tr>
                                        <th style="width:36px;">#</th>
                                        <th>Size</th>
                                        <th>Màu sắc</th>
                                        <th style="width:110px;">Số lượng</th>
                                        <th style="width:100px;">Đang @(behavior == "Rental" ? "thuê" : "treo")</th>
                                        <th style="width:110px;">Tối thiểu</th>
                                        <th style="width:40px;"></th>
                                    </tr>
                                </thead>
                                <tbody id="variantBody">
                                    @if (Model.Variants != null && Model.Variants.Any())
                                    {
                                        int idx = 0;
                                        foreach (var v in Model.Variants.Where(v => v.IsActive))
                                        {
                                            <tr>
                                                <td style="color:var(--muted);font-size:.8rem;">@(++idx)</td>
                                                <td>
                                                    <input type="hidden" name="variantId" value="@v.VariantId" />
                                                    <input type="text" name="variantSize" class="vt-input" value="@v.SizeName" placeholder="S, M, 38..." />
                                                </td>
                                                <td><input type="text" name="variantColor" class="vt-input" value="@v.ColorName" placeholder="Đỏ, Xanh..." /></td>
                                                <td><input type="number" name="variantStock" class="vt-input" value="@v.StockQuantity" min="0" /></td>
                                                <td>
                                                    @if (v.ReservedQuantity > 0)
                                                    {
                                                        <span class="stock-badge stock-low"><i class="bi bi-hourglass-split"></i> @v.ReservedQuantity</span>
                                                    }
                                                    else
                                                    {

                                                        <span class="vt-reserved">—</span>
                                                    }
                                                </td>
                                                <td><input type="number" name="variantMinStock" class="vt-input" value="@v.MinStockLevel" min="0" /></td>
                                                <td>
                                                    <button type="button" class="btn-rm-row"
                                                            @(v.ReservedQuantity > 0 ? "disabled title=\"Đang được sử dụng\"" : "onclick=\"removeRow(this)\"")>
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <button type="button" class="btn-add-row" onclick="addVariantRow()">
                            <i class="bi bi-plus-lg"></i> Thêm phân loại
                        </button>
                    </div>
                </div>
            }

            <!-- ── Hình ảnh ── -->
            <div class="cf-card">
                <div class="cf-card-head">
                    <i class="bi bi-image-fill"></i>
                    <span class="cf-card-head-title">Hình ảnh</span>
                </div>
                <div class="cf-card-body">
                    <div class="img-edit-box">
                        <img id="previewEdit" src="@Model.ImageUrl" class="img-edit-thumb"
                             onerror="this.src='/images/no-image.png'" alt="@Model.ProductName" />
                        <div class="img-edit-right">
                            <div class="img-edit-badge"><i class="bi bi-pencil-fill"></i> Thay ảnh</div>
                            <div class="img-edit-hint">Tải ảnh mới để thay thế. Định dạng JPG, PNG, WEBP.</div>
                            <input type="file" name="ImageFile" class="field-file" accept="image/*" id="imgEditInput" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Actions ── -->
            <div class="btn-row">
                <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i> Hủy</a>
                <button type="submit" class="btn-submit"><i class="bi bi-cloud-arrow-up-fill"></i> Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('imgEditInput').onchange = function () {
            const [f] = this.files;
            if (f) document.getElementById('previewEdit').src = URL.createObjectURL(f);
        };

        function addVariantRow() {
            const tbody = document.getElementById('variantBody');
            const idx = tbody.rows.length + 1;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td style="color:var(--muted);font-size:.8rem;">${idx}</td>
                <td><input type="hidden" name="variantId" value="" /><input type="text" name="variantSize" class="vt-input" placeholder="S, M, 38..." /></td>
                <td><input type="text" name="variantColor" class="vt-input" placeholder="Đỏ, Xanh..." /></td>
                <td><input type="number" name="variantStock" class="vt-input" placeholder="0" min="0" value="0" /></td>
                <td><span class="vt-reserved">—</span></td>
                <td><input type="number" name="variantMinStock" class="vt-input" placeholder="0" min="0" value="0" /></td>
                <td><button type="button" class="btn-rm-row" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td>`;
            tbody.appendChild(tr);
            reindex();
        }
        function removeRow(btn) { btn.closest('tr').remove(); reindex(); }
        function reindex() {
            document.querySelectorAll('#variantBody tr').forEach((tr, i) => {
                tr.querySelector('td:first-child').textContent = i + 1;
            });
        }
    </script>
}
