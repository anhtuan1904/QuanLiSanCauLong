@model IEnumerable<QuanLiSanCauLong.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var cats = ViewBag.Categories as List<QuanLiSanCauLong.Models.ProductCategory> ?? new();

    string BhLbl(string? b) => b switch { "Rental" => "Cho thuê", "Service" => "Dịch vụ", _ => "Bán lẻ" };
    string BhBg(string? b) => b switch { "Rental" => "#eff6ff", "Service" => "#f5f3ff", _ => "#f0fdf4" };
    string BhClr(string? b) => b switch { "Rental" => "#1d4ed8", "Service" => "#7c3aed", _ => "#166534" };
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    /* ── HEADER ── */
    .pg-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    /* ── STAT STRIP ── */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.1rem 1.4rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .7rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
    }

    /* ── TOOLBAR ── */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .tab-grp {
        display: flex;
        gap: .35rem;
    }

    .tab-btn {
        padding: .5rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .8rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
    }

        .tab-btn:hover {
            border-color: rgba(212,160,23,.5);
            color: var(--deep);
        }

        .tab-btn.on {
            background: var(--deep);
            color: var(--gold2);
            border-color: var(--deep);
        }

    .tb-search {
        position: relative;
        min-width: 220px;
    }

        .tb-search input {
            width: 100%;
            padding: .6rem 1rem .6rem 2.2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-size: .84rem;
            outline: none;
            transition: border-color .2s;
            background: #fff;
        }

            .tb-search input:focus {
                border-color: var(--gold);
            }

        .tb-search i {
            position: absolute;
            left: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .85rem;
        }

    .tb-sel {
        padding: .6rem .9rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: .84rem;
        background: #fff;
        outline: none;
        cursor: pointer;
        color: var(--deep);
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    .btn-add {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .62rem 1.3rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        transition: all .22s;
        margin-left: auto;
        text-decoration: none;
    }

        .btn-add:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
            color: var(--deep);
        }

    /* ── TABLE ── */
    .tbl-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .tbl-hd {
        background: var(--deep);
        padding: .85rem 1.4rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .tbl-hd i {
            color: var(--gold);
        }

    .tbl-title {
        font-family: 'Playfair Display',serif;
        font-style: italic;
        font-size: .9rem;
        font-weight: 700;
        color: #fff;
    }

    .tbl-count {
        margin-left: auto;
        font-size: .72rem;
        font-weight: 700;
        color: var(--gold2);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        background: #231a0e;
        padding: .75rem 1rem;
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--gold);
        text-align: left;
        white-space: nowrap;
    }

    tbody td {
        padding: .8rem 1rem;
        border-bottom: 1px solid #f5f0ea;
        vertical-align: middle;
        font-size: .84rem;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr:hover td {
        background: var(--cream);
    }

    /* ── PRODUCT CELL ── */
    .prod-img {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid var(--border);
        flex-shrink: 0;
    }

    .prod-img-ph {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        background: var(--warm);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(26,18,9,.15);
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .prod-name {
        font-weight: 700;
        font-size: .86rem;
        color: var(--deep);
    }

    .prod-sku {
        font-size: .7rem;
        color: var(--muted);
        font-family: monospace;
        margin-top: .1rem;
    }

    /* ── BADGES ── */
    .bh-tag {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .18rem .6rem;
        border-radius: 4px;
        font-size: .66rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .st-tag {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .2rem .6rem;
        border-radius: 4px;
        font-size: .63rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .st-active {
        background: #f0fdf4;
        color: #15803d;
    }

    .st-outstock {
        background: #fff7ed;
        color: #c2410c;
    }

    .st-inactive {
        background: #f9fafb;
        color: #6b7280;
    }

    /* ── STOCK ── */
    .stk-ok {
        color: #15803d;
        font-weight: 700;
    }

    .stk-low {
        color: #c2410c;
        font-weight: 700;
    }

    .stk-zero {
        color: var(--muted);
    }

    /* ── ACTIONS ── */
    .act-g {
        display: flex;
        gap: .3rem;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .18s;
        font-size: .78rem;
        text-decoration: none;
    }

        .act-b:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        .act-b.danger:hover {
            border-color: #c94b2a;
            color: #c94b2a;
            background: rgba(201,75,42,.06);
        }

    /* ── SIDEBAR FILTER (left panel) ── */
    .layout {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    .filter-panel {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        position: sticky;
        top: 80px;
    }

    .fp-hd {
        background: var(--deep);
        padding: .75rem 1rem;
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: rgba(255,255,255,.6);
    }

    .fp-sec {
        padding: .65rem 1rem .3rem;
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .fp-link {
        display: block;
        padding: .5rem 1rem;
        font-size: .82rem;
        color: #4a3728;
        text-decoration: none;
        transition: all .15s;
        border-left: 2px solid transparent;
    }

        .fp-link:hover {
            background: var(--cream);
            color: var(--deep);
        }

        .fp-link.on {
            background: rgba(212,160,23,.09);
            color: var(--deep);
            border-left-color: var(--gold);
            font-weight: 600;
        }

    .fp-cnt {
        margin-left: auto;
        font-size: .68rem;
        background: var(--warm);
        border-radius: 3px;
        padding: .05rem .4rem;
        color: var(--muted);
        float: right;
    }

    /* ── EMPTY ── */
    .empty {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .2;
        }

        .empty h5 {
            font-family: 'Playfair Display',serif;
            font-style: italic;
            font-size: 1.1rem;
            color: var(--deep);
            margin-bottom: .4rem;
        }

    /* ── ALERTS ── */
    .sys-alert {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.success {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #15803d;
        }

        .sys-alert.error {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }

    /* ── TABLE FOOTER ── */
    .tbl-foot {
        padding: .8rem 1.25rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        font-size: .78rem;
        color: var(--muted);
    }

    @@media(max-width:960px) {
        .layout {
            grid-template-columns: 1fr;
        }

        .filter-panel {
            position: static;
        }

        .stat-strip {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width:600px) {
        .stat-strip {
            grid-template-columns: 1fr;
        }

        .toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-add {
            margin-left: 0;
        }
    }
</style>

@* Alerts *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="sys-alert success"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="sys-alert error"><i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]</div>
}

<!-- HEADER -->
<div class="pg-hd">
    <div>
        <h1 class="pg-title">Quản Lý <em>Sản Phẩm</em></h1>
        <div class="pg-sub">Tổng cộng @Model.Count() sản phẩm trong hệ thống</div>
    </div>
    <button class="btn-add" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i> Thêm sản phẩm
    </button>
</div>

<!-- STAT STRIP -->
<div class="stat-strip">
    <div class="stat-box">
        <div class="stat-n">@(ViewBag.CountAll ?? Model.Count())</div>
        <div class="stat-l">Tất cả</div>
    </div>
    <div class="stat-box">
        <div class="stat-n" style="color:#15803d">@(ViewBag.CountRetail ?? 0)</div>
        <div class="stat-l">Bán lẻ</div>
    </div>
    <div class="stat-box">
        <div class="stat-n" style="color:#1d4ed8">@(ViewBag.CountRental ?? 0)</div>
        <div class="stat-l">Cho thuê</div>
    </div>
    <div class="stat-box">
        <div class="stat-n" style="color:#7c3aed">@(ViewBag.CountService ?? 0)</div>
        <div class="stat-l">Dịch vụ</div>
    </div>
</div>

<div class="layout">

    <!-- FILTER SIDEBAR -->
    <div class="filter-panel">
        <div class="fp-hd">Lọc nhanh</div>

        <div class="fp-sec">Loại hành vi</div>
        <a href="@Url.Action("Index")" class="fp-link @(ViewBag.CurrentBehavior == null && ViewBag.CurrentCategory == null ? "on" : "")">
            Tất cả <span class="fp-cnt">@(ViewBag.CountAll ?? 0)</span>
        </a>
        <a href="@Url.Action("Index", new { behaviorType = "Retail" })" class="fp-link @(ViewBag.CurrentBehavior == "Retail" ? "on" : "")">
            Bán lẻ <span class="fp-cnt">@(ViewBag.CountRetail ?? 0)</span>
        </a>
        <a href="@Url.Action("Index", new { behaviorType = "Rental" })" class="fp-link @(ViewBag.CurrentBehavior == "Rental" ? "on" : "")">
            Cho thuê <span class="fp-cnt">@(ViewBag.CountRental ?? 0)</span>
        </a>
        <a href="@Url.Action("Index", new { behaviorType = "Service" })" class="fp-link @(ViewBag.CurrentBehavior == "Service" ? "on" : "")">
            Dịch vụ <span class="fp-cnt">@(ViewBag.CountService ?? 0)</span>
        </a>

        @if (cats.Any())
        {
            <div class="fp-sec" style="margin-top:.5rem;">Danh mục</div>
            @foreach (var cat in cats)
            {
                <a href="@Url.Action("Index", new { categoryId = cat.CategoryId })"
                   class="fp-link @(ViewBag.CurrentCategory?.ToString() == cat.CategoryId.ToString() ? "on" : "")">
                    @cat.CategoryName
                </a>
            }
        }
    </div>

    <!-- MAIN CONTENT -->
    <div>
        <!-- TOOLBAR -->
        <div class="toolbar">
            <div class="tab-grp">
                <button class="tab-btn @(ViewBag.CurrentStatus == null ? "on" : "")"
                        onclick="filterStatus('')">
                    Tất cả
                </button>
                <button class="tab-btn @(ViewBag.CurrentStatus == "Active" ? "on" : "")"
                        onclick="filterStatus('Active')">
                    Đang bán
                </button>
                <button class="tab-btn @(ViewBag.CurrentStatus == "OutOfStock" ? "on" : "")"
                        onclick="filterStatus('OutOfStock')">
                    Hết hàng
                </button>
                <button class="tab-btn @(ViewBag.CurrentStatus == "Inactive" ? "on" : "")"
                        onclick="filterStatus('Inactive')">
                    Ngừng bán
                </button>
            </div>
            <div class="tb-search">
                <i class="bi bi-search"></i>
                <input type="text" id="searchBox" placeholder="Tìm tên, SKU..."
                       value="@ViewBag.Search" oninput="liveSearch()" />
            </div>
        </div>

        <!-- TABLE -->
        <div class="tbl-card">
            <div class="tbl-hd">
                <i class="bi bi-box-seam"></i>
                <span class="tbl-title">Danh sách sản phẩm</span>
                <span class="tbl-count" id="visCount">@Model.Count() sản phẩm</span>
            </div>
            <div style="overflow-x:auto">
                @if (!Model.Any())
                {
                    <div class="empty">
                        <i class="bi bi-inbox"></i>
                        <h5>Chưa có sản phẩm nào</h5>
                        <p>Thêm sản phẩm đầu tiên bằng nút phía trên.</p>
                    </div>
                }
                else
                {
                    <table id="prodTable">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Danh mục</th>
                                <th>Loại</th>
                                <th style="text-align:right">Giá bán</th>
                                <th style="text-align:right">Tồn kho</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                var bh = p.Category?.BehaviorType ?? "Retail";
                                var activeVars = p.Variants?.Where(v => v.IsActive).ToList() ?? new();
                                var stk = activeVars.Any() ? activeVars.Sum(v => v.StockQuantity) : p.StockQuantity;
                                var isLow = bh == "Retail" && p.MinStockLevel > 0 && stk <= p.MinStockLevel;
                                var stkCls = stk == 0 ? "stk-zero" : isLow ? "stk-low" : "stk-ok";
                                var stCls = p.Status switch { "Active" => "st-active", "OutOfStock" => "st-outstock", _ => "st-inactive" };
                                var stLbl = p.Status switch { "Active" => "Đang bán", "OutOfStock" => "Hết hàng", _ => "Ngừng bán" };

                                <tr data-name="@p.ProductName.ToLower()"
                                    data-sku="@(p.ProductCode ?? p.SKU ?? "")" .ToLower()"
                                    data-status="@p.Status"
                                    data-bh="@bh">
                                    <td>
                                        <div style="display:flex;align-items:center;gap:.75rem;">
                                            @if (!string.IsNullOrEmpty(p.ImageUrl) && p.ImageUrl != "/images/no-image.png")
                                            {
                                                <img src="@p.ImageUrl" class="prod-img" alt="@p.ProductName"
                                                     onerror="this.style.display='none'" />
                                            }
                                            else
                                            {
                                                <div class="prod-img-ph"><i class="bi bi-box-seam"></i></div>
                                            }
                                            <div>
                                                <div class="prod-name">@p.ProductName</div>
                                                <div class="prod-sku">@(p.ProductCode ?? p.SKU ?? "—")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="font-size:.82rem;color:var(--muted)">@(p.Category?.CategoryName ?? "—")</td>
                                    <td>
                                        <span class="bh-tag" style="background:@BhBg(bh);color:@BhClr(bh)">
                                            @BhLbl(bh)
                                        </span>
                                    </td>
                                    <td style="text-align:right;font-weight:700;">
                                        @p.Price.ToString("N0")đ
                                        @if (p.SalePrice > 0 && p.SalePrice != p.Price)
                                        {
                                            <div style="font-size:.7rem;color:#1d4ed8;font-weight:600;">
                                                Sỉ: @p.SalePrice.ToString("N0")đ
                                            </div>
                                        }
                                    </td>
                                    <td style="text-align:right;">
                                        @if (bh == "Service")
                                        {
                                            <span style="color:var(--muted);font-size:.78rem;">—</span>
                                        }
                                        else
                                        {
                                            <span class="@stkCls">@stk</span>
                                            @if (isLow)
                                            {
                                                <i class="bi bi-exclamation-triangle-fill" style="color:#c2410c;font-size:.72rem;margin-left:.25rem;" title="Sắp hết hàng"></i>
                                            }
                                        }
                                    </td>
                                    <td><span class="st-tag @stCls">@stLbl</span></td>
                                    <td>
                                        <div class="act-g">
                                            <a href="@Url.Action("Details", new { id = p.ProductId })"
                                               class="act-b" title="Chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <button class="act-b" title="Chỉnh sửa"
                                                    onclick="openEditModal(@p.ProductId)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="act-b danger" title="Xóa"
                                                    onclick="delProd(@p.ProductId, '@Html.Raw(p.ProductName.Replace("'", "\'"))')">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="tbl-foot">
                Hiển thị <strong id="visNum">@Model.Count()</strong> / @Model.Count() sản phẩm
            </div>
        </div>
    </div>
</div>

<!-- MODAL Create/Edit -->
<div class="modal fade" id="prodModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width:860px">
        <div class="modal-content" id="prodModalBody" style="border-radius:14px;border:none;">
            <div class="p-5 text-center">
                <div class="spinner-border" style="color:var(--gold)"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        let prodModal;

        document.addEventListener('DOMContentLoaded', () => {
            prodModal = new bootstrap.Modal(document.getElementById('prodModal'));
        });

        function runScripts(el) {
            el.querySelectorAll('script').forEach(s => {
                const n = document.createElement('script');
                n.text = s.text;
                s.replaceWith(n);
            });
        }

        async function openCreateModal(behaviorType = '') {
            document.getElementById('prodModalBody').innerHTML =
                '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            prodModal.show();
            const url = behaviorType
                ? `/Admin/AdminProduct/Create?behaviorType=${behaviorType}`
                : '/Admin/AdminProduct/Create';
            const r = await fetch(url);
            document.getElementById('prodModalBody').innerHTML = await r.text();
            runScripts(document.getElementById('prodModalBody'));
        }

        async function openEditModal(id) {
            document.getElementById('prodModalBody').innerHTML =
                '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            prodModal.show();
            const r = await fetch(`/Admin/AdminProduct/Edit/${id}`);
            document.getElementById('prodModalBody').innerHTML = await r.text();
            runScripts(document.getElementById('prodModalBody'));
        }

        function delProd(id, name) {
            Swal.fire({
                title: `Xóa "${name}"?`, text: 'Không thể hoàn tác.',
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#c94b2a', cancelButtonColor: '#8a7560',
                confirmButtonText: 'Xóa', cancelButtonText: 'Hủy', reverseButtons: true
            }).then(async r => {
                if (!r.isConfirmed) return;
                const res = await fetch(`/Admin/AdminProduct/Delete/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': TOKEN }
                }).then(r => r.json());
                if (res.success) {
                    Swal.fire({ icon:'success', title:'Đã xóa!', text: res.message,
                        timer:1200, showConfirmButton:false })
                        .then(() => location.reload());
                } else {
                    Swal.fire('Không thể xóa!', res.message, 'error');
                }
            });
        }

        // ── Client-side live search ──
        function liveSearch() {
            const q = document.getElementById('searchBox').value.toLowerCase().trim();
            filterTable(q, activeStatus);
        }

        let activeStatus = '';
        function filterStatus(st) {
            activeStatus = st;
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('on'));
            event.target.classList.add('on');
            filterTable(document.getElementById('searchBox').value.toLowerCase().trim(), st);
        }

        function filterTable(q, st) {
            let vis = 0;
            document.querySelectorAll('#prodTable tbody tr').forEach(row => {
                const name = row.dataset.name ?? '';
                const sku  = row.dataset.sku  ?? '';
                const status = row.dataset.status ?? '';
                const matchQ  = !q  || name.includes(q) || sku.includes(q);
                const matchSt = !st || status === st;
                row.style.display = matchQ && matchSt ? '' : 'none';
                if (matchQ && matchSt) vis++;
            });
            document.getElementById('visNum').textContent = vis;
            document.getElementById('visCount').textContent = vis + ' sản phẩm';
        }
    </script>
}
