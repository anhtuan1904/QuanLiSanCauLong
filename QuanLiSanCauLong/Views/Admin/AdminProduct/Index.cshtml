@model IEnumerable<QuanLiSanCauLong.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var cats = ViewBag.Categories as List<QuanLiSanCauLong.Models.ProductCategory> ?? new();
    string BhIco(string b) => b switch { "Rental" => "bi-arrow-repeat", "Service" => "bi-wrench-adjustable", _ => "bi-cart3" };
    string BhBg(string b) => b switch { "Rental" => "#dbeafe", "Service" => "#ede9fe", _ => "#dcfce7" };
    string BhClr(string b) => b switch { "Rental" => "#1d4ed8", "Service" => "#6d28d9", _ => "#15803d" };
    string BhLbl(string b) => b switch { "Rental" => "Cho thuê", "Service" => "Dịch vụ", _ => "Bán lẻ" };
}
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --cream: #fdf8f0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
        --purple: #7c3aed;
        --orange: #c2410c;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }

    /* header */
    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .pg-eyebrow {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .22em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: .28rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.1;
    }

        .pg-title em {
            color: var(--gold);
            font-style: italic;
        }

    .pg-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .3rem;
    }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: .42rem;
        padding: .65rem 1.25rem;
        border: none;
        border-radius: 9px;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        font-size: .84rem;
        font-weight: 700;
        color: var(--deep);
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 2px 10px rgba(212,160,23,.3);
    }

        .btn-add:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 18px rgba(212,160,23,.45);
        }

    /* stat strip */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .75rem;
        margin-bottom: 1.75rem;
    }

    .sc {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: .9rem 1rem;
        cursor: pointer;
        transition: all .2s;
        position: relative;
        overflow: hidden;
    }

        .sc::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--border);
            transition: .2s;
        }

        .sc.s-all::after {
            background: var(--gold);
        }

        .sc.s-ret::after {
            background: var(--green);
        }

        .sc.s-ren::after {
            background: var(--blue);
        }

        .sc.s-svc::after {
            background: var(--purple);
        }

        .sc:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26,18,9,.1);
        }

        .sc.on.s-all {
            background: linear-gradient(135deg,var(--deep),#2d1f0f);
        }

        .sc.on.s-ret {
            background: linear-gradient(135deg,#14532d,#15803d);
        }

        .sc.on.s-ren {
            background: linear-gradient(135deg,#1e3a8a,#1d4ed8);
        }

        .sc.on.s-svc {
            background: linear-gradient(135deg,#4c1d95,#6d28d9);
        }

        .sc.on .sc-n, .sc.on .sc-l {
            color: #fff !important;
        }

        .sc.on::after {
            display: none;
        }

    .sc-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .sc-l {
        font-size: .62rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .22rem;
    }

    /* layout 2-col */
    .layout {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    /* sidebar */
    .sidebar {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        position: sticky;
        top: 1rem;
    }

    .sb-hd {
        padding: .7rem 1rem;
        background: var(--deep);
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
    }

    .sb-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .55rem 1rem;
        font-size: .81rem;
        color: var(--muted);
        text-decoration: none;
        transition: all .15s;
        border-bottom: 1px solid var(--border);
    }

        .sb-link:last-child {
            border-bottom: none;
        }

        .sb-link:hover {
            background: var(--warm);
            color: var(--deep);
        }

        .sb-link.on {
            background: var(--cream);
            color: var(--deep);
            font-weight: 700;
            border-left: 3px solid var(--gold);
        }

    .sb-cnt {
        font-size: .68rem;
        background: var(--warm);
        border-radius: 10px;
        padding: .06rem .42rem;
        font-weight: 700;
        color: var(--muted);
    }

    .sb-link.on .sb-cnt {
        background: rgba(212,160,23,.2);
        color: #92660a;
    }

    .sb-sec {
        padding: .45rem 1rem .3rem;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--cream);
    }

    /* main area */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
    }

    .tab-grp {
        display: flex;
        gap: .25rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: .25rem;
    }

    .tab-btn {
        padding: .38rem .82rem;
        border-radius: 6px;
        border: none;
        background: transparent;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: .15s;
        white-space: nowrap;
    }

        .tab-btn.on {
            background: var(--deep);
            color: var(--gold2);
        }

    .srch-w {
        flex: 1;
        min-width: 200px;
        position: relative;
    }

        .srch-w i {
            position: absolute;
            left: .72rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
            pointer-events: none;
        }

        .srch-w input {
            width: 100%;
            padding: .58rem .9rem .58rem 2.1rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: .82rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: all .2s;
        }

            .srch-w input:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px rgba(212,160,23,.1);
            }

    /* table card */
    .tbl-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(26,18,9,.06);
    }

    .tbl-top {
        background: var(--deep);
        padding: .85rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .7rem;
    }

    .tbl-top-title {
        font-family: 'Playfair Display',serif;
        font-style: italic;
        font-size: .92rem;
        font-weight: 700;
        color: #fff;
    }

    .tbl-cnt-badge {
        margin-left: auto;
        font-size: .72rem;
        font-weight: 700;
        color: var(--gold2);
        background: rgba(255,255,255,.1);
        padding: .22rem .65rem;
        border-radius: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        padding: .68rem 1rem;
        background: #231a0e;
        font-size: .61rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: rgba(212,160,23,.8);
        text-align: left;
        white-space: nowrap;
    }

    tbody td {
        padding: .82rem 1rem;
        border-bottom: 1px solid #f5f0ea;
        font-size: .83rem;
        color: var(--deep);
        vertical-align: middle;
    }

    tbody tr:last-child td {
        border-bottom: none;
    }

    tbody tr {
        transition: background .1s;
    }

        tbody tr:hover td {
            background: #fffbf2;
        }

    /* product cell */
    .p-cell {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .p-thumb {
        width: 40px;
        height: 40px;
        border-radius: 9px;
        object-fit: cover;
        border: 1px solid var(--border);
        flex-shrink: 0;
    }

    .p-ph {
        width: 40px;
        height: 40px;
        border-radius: 9px;
        background: var(--warm);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(26,18,9,.18);
        font-size: 1.05rem;
        flex-shrink: 0;
    }

    .p-name {
        font-weight: 700;
        font-size: .85rem;
        line-height: 1.2;
    }

    .p-sku {
        font-size: .66rem;
        color: var(--muted);
        font-family: monospace;
        margin-top: .04rem;
    }

    /* tags */
    .bh-tag {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .2rem .55rem;
        border-radius: 5px;
        font-size: .65rem;
        font-weight: 700;
    }

    .st-tag {
        display: inline-flex;
        align-items: center;
        gap: .22rem;
        padding: .2rem .55rem;
        border-radius: 5px;
        font-size: .64rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .st-active {
        background: #f0fdf4;
        color: #15803d;
    }

    .st-outstock {
        background: #fff7ed;
        color: var(--orange);
    }

    .st-inactive {
        background: #f9fafb;
        color: #6b7280;
    }

    /* stock */
    .stk-ok {
        color: var(--green);
        font-weight: 700;
    }

    .stk-low {
        color: var(--orange);
        font-weight: 700;
    }

    .stk-zero {
        color: var(--muted);
    }

    /* price */
    .price-val {
        font-weight: 700;
        font-size: .9rem;
    }

    /* actions */
    .act-g {
        display: flex;
        gap: .2rem;
        justify-content: flex-end;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1.5px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .15s;
        font-size: .75rem;
        text-decoration: none;
    }

        .act-b:hover {
            transform: translateY(-1px);
        }

    .act-view:hover {
        border-color: var(--blue);
        color: var(--blue);
        box-shadow: 0 3px 8px rgba(29,78,216,.15);
    }

    .act-edit:hover {
        border-color: var(--gold);
        color: var(--deep);
        box-shadow: 0 3px 8px rgba(212,160,23,.2);
    }

    .act-del:hover {
        border-color: var(--red);
        color: var(--red);
        background: rgba(201,75,42,.05);
    }

    /* empty */
    .empty-wrap {
        padding: 4rem 2rem;
        text-align: center;
        color: var(--muted);
    }

        .empty-wrap i {
            font-size: 3rem;
            opacity: .15;
            display: block;
            margin-bottom: .75rem;
        }

        .empty-wrap h4 {
            font-family: 'Playfair Display',serif;
            font-style: italic;
            font-size: 1.1rem;
            color: var(--deep);
            margin-bottom: .35rem;
        }

    .tbl-foot {
        padding: .75rem 1.2rem;
        border-top: 1px solid var(--border);
        background: var(--cream);
        font-size: .75rem;
        color: var(--muted);
    }

    /* sys alert */
    .sys-ok {
        padding: .85rem 1.2rem;
        border-radius: 10px;
        margin-bottom: 1.2rem;
        font-size: .82rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        background: rgba(22,163,74,.07);
        border: 1px solid rgba(22,163,74,.2);
        color: #15803d;
    }

    .sys-err {
        padding: .85rem 1.2rem;
        border-radius: 10px;
        margin-bottom: 1.2rem;
        font-size: .82rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        background: rgba(201,75,42,.06);
        border: 1px solid rgba(201,75,42,.2);
        color: var(--red);
    }

    @@media(max-width:960px) {
        .layout {
            grid-template-columns: 1fr
        }

        .sidebar {
            position: static
        }

        .stat-strip {
            grid-template-columns: 1fr 1fr
        }
    }
</style>

<div class="pg">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-ok"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-err"><i class="bi bi-exclamation-circle-fill"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="pg-hd">
        <div>
            <div class="pg-eyebrow">Quản trị · Hàng hóa</div>
            <h1 class="pg-title">Sản <em>Phẩm</em></h1>
            <div class="pg-sub">@Model.Count() sản phẩm · Bán lẻ · Cho thuê · Dịch vụ</div>
        </div>
        <button class="btn-add" onclick="openCreateModal()">
            <i class="bi bi-plus-lg"></i> Thêm sản phẩm
        </button>
    </div>

    <div class="stat-strip">
        <div class="sc s-all on" onclick="filterBh('','sb-all')" id="sb-all">
            <div class="sc-n">@(ViewBag.CountAll ?? Model.Count())</div>
            <div class="sc-l">Tất cả</div>
        </div>
        <div class="sc s-ret" onclick="filterBh('Retail','sb-Retail')" id="sb-Retail">
            <div class="sc-n" style="color:var(--green)">@(ViewBag.CountRetail ?? 0)</div>
            <div class="sc-l">Bán lẻ</div>
        </div>
        <div class="sc s-ren" onclick="filterBh('Rental','sb-Rental')" id="sb-Rental">
            <div class="sc-n" style="color:var(--blue)">@(ViewBag.CountRental ?? 0)</div>
            <div class="sc-l">Cho thuê</div>
        </div>
        <div class="sc s-svc" onclick="filterBh('Service','sb-Service')" id="sb-Service">
            <div class="sc-n" style="color:var(--purple)">@(ViewBag.CountService ?? 0)</div>
            <div class="sc-l">Dịch vụ</div>
        </div>
    </div>

    <div class="layout">
        <div class="sidebar">
            <div class="sb-hd">Bộ lọc</div>
            <a href="@Url.Action("Index")" class="sb-link @(ViewBag.CurrentBehavior == null && ViewBag.CurrentCategory == null ? "on" : "")">Tất cả <span class="sb-cnt">@(ViewBag.CountAll ?? 0)</span></a>
            <a href="@Url.Action("Index", new { behaviorType = "Retail" })" class="sb-link @(ViewBag.CurrentBehavior == "Retail" ? "on" : "")">🛒 Bán lẻ <span class="sb-cnt">@(ViewBag.CountRetail ?? 0)</span></a>
            <a href="@Url.Action("Index", new { behaviorType = "Rental" })" class="sb-link @(ViewBag.CurrentBehavior == "Rental" ? "on" : "")">🔄 Cho thuê <span class="sb-cnt">@(ViewBag.CountRental ?? 0)</span></a>
            <a href="@Url.Action("Index", new { behaviorType = "Service" })" class="sb-link @(ViewBag.CurrentBehavior == "Service" ? "on" : "")">🔧 Dịch vụ <span class="sb-cnt">@(ViewBag.CountService ?? 0)</span></a>
            @if (cats.Any())
            {
                <div class="sb-sec">Danh mục</div>
                @foreach (var c in cats)
                {
                    <a href="@Url.Action("Index", new { categoryId = c.CategoryId })" class="sb-link @(ViewBag.CurrentCategory?.ToString() == c.CategoryId.ToString() ? "on" : "")">@c.CategoryName</a>
                }
            }
        </div>

        <div>
            <div class="toolbar">
                <div class="tab-grp">
                    <button class="tab-btn on" onclick="filterStatus('',this)">Tất cả</button>
                    <button class="tab-btn" onclick="filterStatus('Active',this)">Đang bán</button>
                    <button class="tab-btn" onclick="filterStatus('OutOfStock',this)">Hết hàng</button>
                    <button class="tab-btn" onclick="filterStatus('Inactive',this)">Ngừng bán</button>
                </div>
                <div class="srch-w">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchBox" placeholder="Tìm tên, SKU..." value="@ViewBag.Search" oninput="runFilter()" />
                </div>
            </div>

            <div class="tbl-card">
                <div class="tbl-top">
                    <i class="bi bi-box-seam" style="color:var(--gold)"></i>
                    <span class="tbl-top-title">Danh sách sản phẩm</span>
                    <span class="tbl-cnt-badge" id="visCnt">@Model.Count() sản phẩm</span>
                </div>

                @if (!Model.Any())
                {
                    <div class="empty-wrap"><i class="bi bi-inbox"></i><h4>Chưa có sản phẩm nào</h4><p style="font-size:.82rem">Thêm sản phẩm đầu tiên bằng nút phía trên.</p><button class="btn-add" style="margin-top:.75rem" onclick="openCreateModal()"><i class="bi bi-plus-lg"></i> Thêm ngay</button></div>
                }
                else
                {
                    <div style="overflow-x:auto">
                        <table id="prodTable">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th style="width:120px">Danh mục</th>
                                    <th style="width:90px">Loại</th>
                                    <th style="width:120px;text-align:right">Giá</th>
                                    <th style="width:90px;text-align:right">Tồn kho</th>
                                    <th style="width:100px">Trạng thái</th>
                                    <th style="width:100px;text-align:right">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model)
                                {
                                    var bh = p.Category?.BehaviorType ?? "Retail";
                                    var stk = p.Variants?.Where(v => v.IsActive).Sum(v => v.StockQuantity) is int vs && vs > 0 ? vs : p.StockQuantity;
                                    var isLow = bh == "Retail" && p.MinStockLevel > 0 && stk <= p.MinStockLevel;
                                    var stkCls = stk == 0 ? "stk-zero" : isLow ? "stk-low" : "stk-ok";
                                    var stCls = p.Status switch { "Active" => "st-active", "OutOfStock" => "st-outstock", _ => "st-inactive" };
                                    var stLbl = p.Status switch { "Active" => "Đang bán", "OutOfStock" => "Hết hàng", _ => "Ngừng bán" };
                                    var stIco = p.Status switch { "Active" => "bi-check-circle-fill", "OutOfStock" => "bi-exclamation-circle-fill", _ => "bi-x-circle-fill" };
                                    <tr data-name="@p.ProductName.ToLower()" data-sku="@(p.ProductCode ?? p.SKU ?? "").ToLower()" data-status="@p.Status" data-bh="@bh">
                                        <td>
                                            <div class="p-cell">
                                                @if (!string.IsNullOrEmpty(p.ImageUrl) && p.ImageUrl != "/images/no-image.png")
                                                {
                                                    <img src="@p.ImageUrl" class="p-thumb" alt="" onerror="this.classList.add('d-none')" />
                                                }
                                                else
                                                {

                                                    <div class="p-ph"><i class="bi @BhIco(bh)"></i></div>
                                                }
                                                <div>
                                                    <div class="p-name">@p.ProductName</div>
                                                    <div class="p-sku">@(p.ProductCode ?? p.SKU ?? "—")</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="font-size:.78rem;color:var(--muted)">@(p.Category?.CategoryName ?? "—")</td>
                                        <td><span class="bh-tag" style="background:@BhBg(bh);color:@BhClr(bh)"><i class="bi @BhIco(bh)"></i> @BhLbl(bh)</span></td>
                                        <td style="text-align:right"><span class="price-val">@p.Price.ToString("N0")đ</span></td>
                                        <td style="text-align:right">
                                            @if (bh == "Service")
                                            {
                                                <span style="color:var(--muted);font-size:.76rem">—</span>
                                            }
                                            else
                                            {

                                                <span class="@stkCls">@stk</span>@if(isLow){
                                                <i class="bi bi-exclamation-triangle-fill" style="color:var(--orange);font-size:.68rem;margin-left:.22rem"></i>
                                            }
    }
                                    </td>
                                    <td><span class="st-tag @stCls"><i class="bi @stIco"></i> @stLbl</span></td>
                                    <td>
                                        <div class="act-g">
                                            <a href="@Url.Action("Details", new { id = p.ProductId })" class="act-b act-view" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                            <button class="act-b act-edit" title="Chỉnh sửa" onclick="openEditModal(@p.ProductId)"><i class="bi bi-pencil"></i></button>
                                            <button class="act-b act-del" title="Xóa" onclick="delProd(@p.ProductId,'@Html.Raw(p.ProductName.Replace("'", "\\'"))')"><i class="bi bi-trash3"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="tbl-foot">Hiển thị <strong id="visNum">@Model.Count()</strong> / @Model.Count() sản phẩm</div>
                                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="prodModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width:860px">
        <div class="modal-content" id="prodModalBody" style="border-radius:16px;border:none;box-shadow:0 25px 80px rgba(0,0,0,.2)">
            <div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN=document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';
        let prodModal;
        document.addEventListener('DOMContentLoaded',()=>{prodModal=new bootstrap.Modal(document.getElementById('prodModal'));});
        function runScripts(el){el.querySelectorAll('script').forEach(s=>{const n=document.createElement('script');n.text=s.text;s.replaceWith(n);});}
        async function loadModal(url){
            document.getElementById('prodModalBody').innerHTML='<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            prodModal.show();
            try{const r=await fetch(url);if(!r.ok)throw new Error('HTTP '+r.status);document.getElementById('prodModalBody').innerHTML=await r.text();runScripts(document.getElementById('prodModalBody'));}
            catch(e){document.getElementById('prodModalBody').innerHTML=`<div class="p-4 text-center text-danger"><i class="bi bi-exclamation-triangle fs-2 d-block mb-2"></i>Lỗi: ${e.message}<br><button class="btn btn-sm btn-secondary mt-2" onclick="prodModal.hide()">Đóng</button></div>`;}
        }
        function openCreateModal(bh=''){loadModal(bh?`/Admin/AdminProduct/Create?behaviorType=${bh}`:'/Admin/AdminProduct/Create');}
        function openEditModal(id){loadModal(`/Admin/AdminProduct/Edit/${id}`);}
        function delProd(id,name){
            Swal.fire({title:`Xóa "${name}"?`,text:'Không thể hoàn tác.',icon:'warning',showCancelButton:true,
                confirmButtonColor:'#c94b2a',cancelButtonColor:'#8a7560',confirmButtonText:'Xóa',cancelButtonText:'Hủy',reverseButtons:true
            }).then(async r=>{
                if(!r.isConfirmed)return;
                const res=await fetch(`/Admin/AdminProduct/Delete/${id}`,{method:'POST',headers:{'RequestVerificationToken':TOKEN}}).then(r=>r.json());
                if(res.success)Swal.fire({icon:'success',title:'Đã xóa!',text:res.message,timer:1200,showConfirmButton:false}).then(()=>location.reload());
                else Swal.fire('Không thể xóa!',res.message,'error');
            });
        }
        let activeBh='',activeStatus='';
        function filterBh(bh,cardId){
            activeBh=bh;
            document.querySelectorAll('.sc').forEach(c=>c.classList.remove('on'));
            document.getElementById(cardId)?.classList.add('on');
            runFilter();
        }
        function filterStatus(st,btn){activeStatus=st;document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('on'));btn?.classList.add('on');runFilter();}
        function runFilter(){
            const q=document.getElementById('searchBox').value.toLowerCase().trim();
            let cnt=0;
            document.querySelectorAll('#prodTable tbody tr').forEach(row=>{
                const show=(!q||row.dataset.name?.includes(q)||row.dataset.sku?.includes(q))&&(!activeBh||row.dataset.bh===activeBh)&&(!activeStatus||row.dataset.status===activeStatus);
                row.style.display=show?'':'none';if(show)cnt++;
            });
            document.getElementById('visNum').textContent=cnt;
            document.getElementById('visCnt').textContent=cnt+' sản phẩm';
        }
    </script>
}
