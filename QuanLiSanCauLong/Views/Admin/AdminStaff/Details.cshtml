@model QuanLiSanCauLong.ViewModels.StaffDetailsViewModel
@{
    ViewData["Title"] = "Hồ Sơ Nhân Viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .68rem 1.35rem;
        font-size: .84rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .62rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .crumb {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .crumb a {
            color: var(--muted);
            text-decoration: none;
        }

            .crumb a:hover {
                color: var(--gold);
            }

    .sys-ok {
        padding: .85rem 1.1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.2);
        color: #16a34a;
    }

    .banner {
        background: var(--deep);
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .banner-l {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .banner-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: #fff;
        margin: .25rem 0;
    }

    .banner-meta {
        color: rgba(255,255,255,.45);
        font-size: .75rem;
    }

    .banner-r {
        text-align: right;
    }

    .banner-since {
        font-size: .68rem;
        color: rgba(255,255,255,.35);
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .banner-date {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .stat-row {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.1rem 1.25rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .68rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .stat-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.1rem;
        margin-bottom: 1.1rem;
    }

    .card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .card-h {
        padding: .8rem 1.25rem;
        border-bottom: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .card-h i {
            color: var(--gold);
            font-size: .88rem;
        }

    .card-ht {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .card-h a {
        margin-left: auto;
        font-size: .72rem;
        color: var(--gold);
        text-decoration: none;
        font-weight: 700;
    }

    .card-b {
        padding: 1.1rem 1.25rem;
    }

    .ir {
        display: flex;
        align-items: flex-start;
        gap: .85rem;
        padding: .75rem 0;
        border-bottom: 1px solid var(--border);
    }

        .ir:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .ii {
        width: 32px;
        height: 32px;
        border-radius: 7px;
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-size: .78rem;
        flex-shrink: 0;
    }

    .ik {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .15rem;
    }

    .iv {
        font-size: .86rem;
        font-weight: 600;
        color: var(--deep);
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .22rem .6rem;
        border-radius: 4px;
        white-space: nowrap;
    }

    .chip-green {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-red {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-sched {
        background: rgba(79,70,229,.08);
        color: #4f46e5;
    }

    .chip-in {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-out {
        background: rgba(22,163,74,.15);
        color: #15803d;
    }

    .chip-absent {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .chip-late {
        background: rgba(234,88,12,.1);
        color: #ea580c;
    }

    .role-staff {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .tbl thead th {
            padding: .65rem .9rem;
            text-align: left;
            font-size: .63rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            background: var(--warm);
            border-bottom: 1px solid var(--border);
        }

        .tbl tbody td {
            padding: .75rem .9rem;
            border-bottom: 1px solid var(--border);
            font-size: .82rem;
            vertical-align: middle;
        }

        .tbl tbody tr:last-child td {
            border-bottom: none;
        }

        .tbl tbody tr:hover {
            background: rgba(212,160,23,.025);
        }

    .sh-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .55rem;
        border-radius: 5px;
        font-size: .7rem;
        font-weight: 700;
    }

    .pg-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-top: 1.1rem;
    }
    /* modal */
    .v-modal .modal-content {
        border-radius: 14px;
        overflow: hidden;
        border: none;
        box-shadow: 0 20px 60px rgba(26,18,9,.18);
        display: flex;
        flex-direction: column;
        max-height: 92vh;
    }

    .v-mh {
        padding: 1.4rem 1.75rem 1rem;
        border-bottom: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .v-mlabel {
        font-size: .64rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .3rem;
    }

    .v-mtitle {
        font-family: 'Playfair Display',serif;
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep);
    }

        .v-mtitle em {
            font-style: italic;
            color: var(--gold);
        }

    .v-mclose {
        width: 32px;
        height: 32px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .2s;
        flex-shrink: 0;
    }

        .v-mclose:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .v-mb {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .v-mf {
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
    }
</style>

@Html.AntiForgeryToken()

<div>
    <div class="crumb">
        <a asp-action="Index"><i class="bi bi-people"></i> Nhân viên</a>
        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
        <span>@Model.Staff.FullName</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-ok"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }

    @* Banner *@
    <div class="banner">
        <div class="banner-l">
            <div class="av-widget lg">
                @await Html.PartialAsync("_AvatarCropper", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                {
                ["UserId"] = Model.Staff.UserId, ["AvatarUrl"] = Model.Staff.AvatarUrl, ["FullName"] = Model.Staff.FullName
                                })
            </div>
            <div>
                <div class="banner-meta">Nhân viên · ID #@Model.Staff.UserId</div>
                <div class="banner-name">@Model.Staff.FullName</div>
                <div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;margin-top:.3rem;">
                    <span class="chip role-staff"><i class="bi bi-person-badge"></i> Staff</span>
                    @if (Model.Staff.IsActive)
                    {
                        <span class="chip chip-green">● Hoạt động</span>
                    }
                    else
                    {
                        <span class="chip chip-red">● Bị khóa</span>
                    }
                    @if (Model.Staff.Facility != null)
                    {
                        <span style="font-size:.75rem;color:rgba(255,255,255,.45);">
                            <i class="bi bi-building me-1" style="color:var(--gold2);"></i>@Model.Staff.Facility.FacilityName
                        </span>
                    }
                </div>
                <div style="margin-top:.4rem;font-size:.7rem;color:rgba(255,255,255,.3);">
                    <i class="bi bi-camera me-1" style="color:var(--gold2);"></i>Click ảnh để thay đổi
                </div>
            </div>
        </div>
        <div class="banner-r">
            <div class="banner-since">Ngày vào làm</div>
            <div class="banner-date">@Model.Staff.CreatedAt.ToString("dd/MM")</div>
            <div style="font-size:.7rem;color:rgba(255,255,255,.3);">@Model.Staff.CreatedAt.ToString("yyyy")</div>
        </div>
    </div>

    @* Stats *@
    <div class="stat-row">
        <div class="stat-box">
            <div class="stat-n">@Model.TotalShiftsThisMonth</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Ca tháng này</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@Model.TotalHoursThisMonth.ToString("0.0")h</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Giờ làm tháng này</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#c94b2a;">@Model.AbsentCount</div>
            <div class="stat-l"><span class="stat-dot" style="background:#c94b2a;"></span>Vắng mặt</div>
        </div>
        <div class="stat-box">
            <div class="stat-n">@Model.TotalShiftsAllTime</div>
            <div class="stat-l"><span class="stat-dot" style="background:#4f46e5;"></span>Tổng ca toàn thời gian</div>
        </div>
    </div>

    @* Info cards *@
    <div class="grid2">
        <div class="card">
            <div class="card-h"><i class="bi bi-person-circle"></i><span class="card-ht">Thông Tin Cá Nhân</span></div>
            <div class="card-b">
                <div class="ir"><div class="ii"><i class="bi bi-person"></i></div><div><div class="ik">Họ và Tên</div><div class="iv">@Model.Staff.FullName</div></div></div>
                <div class="ir"><div class="ii"><i class="bi bi-envelope"></i></div><div><div class="ik">Email</div><div class="iv">@Model.Staff.Email</div></div></div>
                <div class="ir"><div class="ii"><i class="bi bi-phone"></i></div><div><div class="ik">Điện Thoại</div><div class="iv">@(Model.Staff.Phone ?? "—")</div></div></div>
                <div class="ir"><div class="ii"><i class="bi bi-calendar3"></i></div><div><div class="ik">Ngày Tạo</div><div class="iv">@Model.Staff.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></div></div>
            </div>
        </div>
        <div class="card">
            <div class="card-h"><i class="bi bi-building"></i><span class="card-ht">Phân Công</span></div>
            <div class="card-b">
                <div class="ir"><div class="ii"><i class="bi bi-building"></i></div><div><div class="ik">Cơ Sở</div><div class="iv">@(Model.Staff.Facility?.FacilityName ?? "Chưa phân công")</div></div></div>
                <div class="ir"><div class="ii"><i class="bi bi-shield-badge"></i></div><div><div class="ik">Vai Trò</div><div class="iv"><span class="chip role-staff"><i class="bi bi-person-badge"></i> Staff</span></div></div></div>
                <div class="ir"><div class="ii"><i class="bi bi-toggle-on"></i></div><div><div class="ik">Trạng Thái</div><div class="iv">@if(Model.Staff.IsActive){
                <span class="chip chip-green">● Hoạt động</span>
                                }else
                {

                    <span class="chip chip-red">● Bị khóa</span>
                }
</div></div></div>
                <div class="ir"><div class="ii"><i class="bi bi-hash"></i></div><div><div class="ik">User ID</div><div class="iv" style="font-family:monospace;">#@Model.Staff.UserId</div></div></div>
            </div>
        </div>
    </div>

    @* Lịch sử ca *@
    <div class="card">
        <div class="card-h">
            <i class="bi bi-clock-history"></i>
            <span class="card-ht">Lịch Sử Ca Làm Việc Gần Nhất</span>
            <a asp-controller="AdminShift" asp-action="Report">Xem báo cáo →</a>
        </div>
        @if (!Model.RecentAssignments.Any())
        {
            <div style="text-align:center;padding:2rem;color:var(--muted);font-size:.82rem;">
                <i class="bi bi-calendar-x" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.3;"></i>
                Chưa có lịch sử ca làm việc
            </div>
        }
        else
        {
            <table class="tbl">
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th>Ca</th>
                        <th>Giờ làm</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Thực tế</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.RecentAssignments)
                    {
                        var sc = a.Status switch { "CheckedIn" => "chip-in", "CheckedOut" => "chip-out", "Absent" => "chip-absent", "Late" => "chip-late", _ => "chip-sched" };
                        var sl = a.Status switch { "Scheduled" => "Chờ", "CheckedIn" => "Đang làm", "CheckedOut" => "Hoàn thành", "Absent" => "Vắng", "Late" => "Đi trễ", _ => a.Status };
                        <tr>
                            <td style="font-weight:600;">@a.WorkDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (a.Shift != null)
                                {
                                    <span class="sh-badge" style="background:@a.Shift.Color;color:@(IsDark(a.Shift.Color) ? "#fff" : "#1a1209");">@a.Shift.ShiftName</span>
                                }
                            </td>
                            <td style="font-size:.78rem;color:var(--muted);">@(a.Shift?.TimeRange ?? "—")</td>
                            <td style="font-size:.82rem;">@(a.CheckInTime?.ToString("HH:mm") ?? "—")</td>
                            <td style="font-size:.82rem;">@(a.CheckOutTime?.ToString("HH:mm") ?? "—")</td>
                            <td style="font-weight:700;color:var(--gold);">@(a.ActualHours.HasValue? a.ActualHours.Value.ToString("0.0") + "h" : "—")</td>
                            <td><span class="chip @sc">@sl</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="pg-foot">
        <a asp-action="Index" class="btn-ov"><i class="bi bi-arrow-left"></i> Danh sách</a>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
            <a asp-controller="AdminShift" asp-action="Schedule" asp-route-facilityId="@Model.Staff.FacilityId"
               class="btn-ov" style="border-color:#4f46e5;color:#4f46e5;">
                <i class="bi bi-calendar-week"></i> Lịch ca
            </a>
            <button type="button" class="btn-ov" style="border-color:#92660a;color:#92660a;"
                    onclick="resetPwd(@Model.Staff.UserId)">
                <i class="bi bi-key"></i> Reset mật khẩu
            </button>
            <a asp-action="Edit" asp-route-id="@Model.Staff.UserId" class="btn-gold">
                <i class="bi bi-pencil"></i> Chỉnh sửa
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/avatar-cropper.js"></script>
    <script>
        var _tok = document.querySelector('[name=__RequestVerificationToken]').value;
        function resetPwd(id) {
            Swal.fire({ title:'Reset mật khẩu?', text:'Mật khẩu sẽ về 123456', icon:'warning',
                showCancelButton:true, confirmButtonColor:'#d4a017', cancelButtonColor:'#8a7560',
                confirmButtonText:'Reset', cancelButtonText:'Hủy', reverseButtons:true
            }).then(function(r) {
                if (!r.isConfirmed) return;
                var fd = new FormData(); fd.append('userId', id); fd.append('__RequestVerificationToken', _tok);
                fetch('/AdminStaff/ResetPassword', { method:'POST', body:fd })
                .then(res => res.json()).then(function(d) {
                    if (d.success) Swal.fire({ icon:'success', title:'Đã reset!', text:d.message, confirmButtonColor:'#d4a017' });
                    else Swal.fire('Lỗi!', d.message, 'error');
                });
            });
        }
    </script>
}

@functions {
    bool IsDark(string? hex)
    {
        if (string.IsNullOrEmpty(hex)) return false;
        hex = hex.TrimStart('#');
        if (hex.Length < 6) return false;
        return (Convert.ToInt32(hex[..2], 16) * 299 + Convert.ToInt32(hex[2..4], 16) * 587 + Convert.ToInt32(hex[4..6], 16) * 114) / 1000 < 128;
    }
}
