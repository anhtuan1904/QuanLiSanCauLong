@model QuanLiSanCauLong.ViewModels.StaffIndexViewModel
@{
    ViewData["Title"] = "Quản Lý Nhân Viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var facilities = ViewBag.Facilities as List<QuanLiSanCauLong.Models.Facility> ?? new();
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
    }

    * {
        font-family: 'Outfit',sans-serif;
        box-sizing: border-box;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .72rem 1.5rem;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .62rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .82rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .pg-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
    }

    .filter-bar {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
        align-items: center;
    }

    .f-input {
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        transition: border-color .2s;
        outline: none;
    }

        .f-input:focus, .f-input.af {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

    .stat-row {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .stat-box {
        background: #fff;
        padding: 1rem 1.25rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .7rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .tbl-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .tbl thead th {
            padding: .75rem 1rem;
            text-align: left;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            background: var(--warm);
            border-bottom: 1px solid var(--border);
        }

        .tbl tbody td {
            padding: .85rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .84rem;
            vertical-align: middle;
        }

        .tbl tbody tr:last-child td {
            border-bottom: none;
        }

        .tbl tbody tr:hover {
            background: rgba(212,160,23,.025);
        }

    .u-ava {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display',serif;
        font-weight: 700;
        font-size: .9rem;
        color: var(--deep);
        flex-shrink: 0;
    }

    .u-photo {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--border);
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .67rem;
        font-weight: 700;
        padding: .22rem .6rem;
        border-radius: 4px;
        white-space: nowrap;
    }

    .chip-green {
        background: rgba(22,163,74,.1);
        color: #16a34a;
    }

    .chip-red {
        background: rgba(201,75,42,.1);
        color: #c94b2a;
    }

    .act-btns {
        display: flex;
        gap: .4rem;
        justify-content: center;
    }

    .act-btn {
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: 1.5px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .75rem;
        color: var(--muted);
        transition: all .18s;
        text-decoration: none;
    }

        .act-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        .act-btn.del:hover {
            border-color: #c94b2a;
            color: #c94b2a;
        }

    .empty-state {
        text-align: center;
        padding: 3.5rem 1rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: .75rem;
            opacity: .3;
        }

    .pg-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
    }

    .pg-info {
        font-size: .78rem;
        color: var(--muted);
    }

    .pg-btns {
        display: flex;
        gap: .35rem;
    }

    .pg-btn {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1.5px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        text-decoration: none;
        color: var(--muted);
        transition: all .18s;
    }

        .pg-btn:hover, .pg-btn.cur {
            border-color: var(--gold);
            color: var(--gold);
            font-weight: 700;
        }

    .sys-ok {
        padding: .85rem 1.1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.2);
        color: #16a34a;
    }
</style>

@Html.AntiForgeryToken()

<div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-ok"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }

    <div class="pg-head">
        <div>
            <div style="font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.3rem;">QUẢN LÝ</div>
            <h1 class="pg-title">Nhân Viên <em>Cầu Lông</em></h1>
        </div>
        <div style="display:flex;gap:.65rem;flex-wrap:wrap;">
            <a asp-controller="AdminShift" asp-action="Schedule" class="btn-ov" style="border-color:#4f46e5;color:#4f46e5;">
                <i class="bi bi-calendar-week"></i> Lịch phân ca
            </a>
            <a asp-controller="AdminShift" asp-action="Report" class="btn-ov" style="border-color:#16a34a;color:#16a34a;">
                <i class="bi bi-bar-chart"></i> Báo cáo
            </a>
            <a asp-action="Create" class="btn-gold">
                <i class="bi bi-person-plus"></i> Thêm nhân viên
            </a>
        </div>
    </div>

    <div class="stat-row">
        <div class="stat-box">
            <div class="stat-n">@Model.TotalCount</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold);"></span>Tổng nhân viên</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#16a34a;">@Model.ActiveCount</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a;"></span>Hoạt động</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#c94b2a;">@Model.LockedCount</div>
            <div class="stat-l"><span class="stat-dot" style="background:#c94b2a;"></span>Bị khóa</div>
        </div>
        <div class="stat-box">
            <div class="stat-n">@Model.FacilityCount</div>
            <div class="stat-l"><span class="stat-dot" style="background:#4f46e5;"></span>Cơ sở</div>
        </div>
    </div>

    <form method="get" asp-action="Index" id="fForm">
        <div class="filter-bar">
            <input type="text" name="Filter.Search" value="@Model.Filter.Search"
                   class="f-input @(!string.IsNullOrEmpty(Model.Filter.Search) ? "af" : "")"
                   style="min-width:260px;" placeholder="🔍  Tìm tên, email, điện thoại…"
                   oninput="debounceFrm()" />

            @{
                // ✅ FIX RZ1031: Tách selected logic ra biến C# trước, không inline trong attribute
                var selFacility = Model.Filter.FacilityId;
                var selStatus = Model.Filter.Status ?? "";
            }

            <select name="Filter.FacilityId"
                    class="f-input @(Model.Filter.FacilityId != null ? "af" : "")"
                    onchange="this.form.submit()">
                <option value="">Tất cả cơ sở</option>
                @foreach (var f in facilities)
                {
                    if (selFacility == f.FacilityId)
                    {
                        <option value="@f.FacilityId" selected>@f.FacilityName</option>
                    }
                    else
                    {
                        <option value="@f.FacilityId">@f.FacilityName</option>
                    }
                }
            </select>

            <select name="Filter.Status"
                    class="f-input @(!string.IsNullOrEmpty(Model.Filter.Status) ? "af" : "")"
                    onchange="this.form.submit()">
                <option value="">Tất cả trạng thái</option>
                @if (selStatus == "Active")
                {
                    <option value="Active" selected>Hoạt động</option>
                    <option value="Locked">Bị khóa</option>
                }
                else if (selStatus == "Locked")
                {
                    <option value="Active">Hoạt động</option>
                    <option value="Locked" selected>Bị khóa</option>
                }
                else
                {
                    <option value="Active">Hoạt động</option>
                    <option value="Locked">Bị khóa</option>
                }
            </select>

            @if (!string.IsNullOrEmpty(Model.Filter.Search) || Model.Filter.FacilityId != null || !string.IsNullOrEmpty(Model.Filter.Status))
            {
                <a asp-action="Index" class="btn-ov" style="border-color:#c94b2a;color:#c94b2a;">
                    <i class="bi bi-x-circle"></i> Xóa lọc
                </a>
            }
        </div>
    </form>

    <div class="tbl-wrap">
        @if (!Model.Staff.Any())
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <div style="font-weight:700;margin-bottom:.4rem;">Không có nhân viên nào</div>
                <div style="font-size:.8rem;">Thử thay đổi bộ lọc hoặc thêm nhân viên mới</div>
            </div>
        }
        else
        {
            <table class="tbl">
                <thead>
                    <tr>
                        <th>Nhân viên</th>
                        <th>Liên hệ</th>
                        <th>Cơ sở</th>
                        <th>Trạng thái</th>
                        <th>Ngày vào</th>
                        <th style="text-align:center;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Staff)
                    {
                        var ini = string.Join("", s.FullName.Split(' ').TakeLast(2).Select(x => x[0]));
                        // ✅ FIX CS1003/CS1012: Escape tên nhân viên an toàn vào data-attribute
                        // Tránh dùng inline string nháy đơn trong onclick khi tên có dấu nháy
                        <tr id="row_@s.UserId" data-name="@s.FullName">
                            <td>
                                <div style="display:flex;align-items:center;gap:.75rem;">
                                    @if (!string.IsNullOrEmpty(s.AvatarUrl))
                                    {
                                        <img src="@s.AvatarUrl" alt="@s.FullName" class="u-photo" />
                                    }
                                    else
                                    {
                                        <div class="u-ava">@ini</div>
                                    }
                                    <div>
                                        <div style="font-weight:700;font-size:.88rem;">@s.FullName</div>
                                        <div style="font-size:.72rem;color:var(--muted);">ID #@s.UserId</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-size:.83rem;">@s.Email</div>
                                <div style="font-size:.74rem;color:var(--muted);">@(s.Phone ?? "—")</div>
                            </td>
                            <td style="font-size:.83rem;font-weight:600;">@(s.Facility?.FacilityName ?? "—")</td>
                            <td>
                                <span id="chip_@s.UserId" class="chip @(s.IsActive ? "chip-green" : "chip-red")">
                                    ● @(s.IsActive ? "Hoạt động" : "Bị khóa")
                                </span>
                            </td>
                            <td style="font-size:.8rem;color:var(--muted);">@s.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="act-btns">
                                    <a asp-action="Details" asp-route-id="@s.UserId" class="act-btn" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@s.UserId" class="act-btn" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="AdminShift" asp-action="Schedule" asp-route-facilityId="@s.FacilityId"
                                       class="act-btn" title="Lịch ca" style="border-color:#4f46e5;color:#4f46e5;">
                                        <i class="bi bi-calendar-week"></i>
                                    </a>
                                    <button type="button" class="act-btn" title="@(s.IsActive ? "Khóa" : "Mở khóa")"
                                            onclick="toggleStatus(@s.UserId, @s.IsActive.ToString().ToLower())">
                                        <i id="lockIcon_@s.UserId" class="bi @(s.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                    </button>
                                    @* ✅ FIX CS1003 dòng 198: Dùng data-attribute thay vì inline string *@
                                    <button type="button" class="act-btn del" title="Xóa"
                                            data-uid="@s.UserId"
                                            onclick="deleteStaff(this.dataset.uid, this.closest('tr').dataset.name)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.TotalPages > 1)
            {
                var f = Model.Filter;
                <div class="pg-nav">
                    <div class="pg-info">Trang @Model.CurrentPage / @Model.TotalPages &nbsp;·&nbsp; @Model.TotalCount nhân viên</div>
                    <div class="pg-btns">
                        @if (Model.HasPrevPage)
                        {
                            <a href="?Filter.Page=@(Model.CurrentPage - 1)&Filter.Search=@f.Search&Filter.FacilityId=@f.FacilityId&Filter.Status=@f.Status"
                               class="pg-btn"><i class="bi bi-chevron-left"></i></a>
                        }
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            if (p == Model.CurrentPage)
                            {
                                <a href="?Filter.Page=@p&Filter.Search=@f.Search&Filter.FacilityId=@f.FacilityId&Filter.Status=@f.Status"
                                   class="pg-btn cur">@p</a>
                            }
                            else
                            {
                                <a href="?Filter.Page=@p&Filter.Search=@f.Search&Filter.FacilityId=@f.FacilityId&Filter.Status=@f.Status"
                                   class="pg-btn">@p</a>
                            }
                        }
                        @if (Model.HasNextPage)
                        {
                            <a href="?Filter.Page=@(Model.CurrentPage + 1)&Filter.Search=@f.Search&Filter.FacilityId=@f.FacilityId&Filter.Status=@f.Status"
                               class="pg-btn"><i class="bi bi-chevron-right"></i></a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var _tok = document.querySelector('[name=__RequestVerificationToken]').value;
        var _dt;

        function debounceFrm() {
            clearTimeout(_dt);
            _dt = setTimeout(function(){ document.getElementById('fForm').submit(); }, 500);
        }

        function toggleStatus(id, isActive) {
            var fd = new FormData();
            fd.append('userId', id);
            fd.append('__RequestVerificationToken', _tok);
            fetch('/AdminStaff/ToggleStatus', { method:'POST', body:fd })
            .then(r => r.json()).then(function(d) {
                if (d.success) {
                    var chip = document.getElementById('chip_' + id);
                    var icon = document.getElementById('lockIcon_' + id);
                    if (chip) { chip.className = 'chip ' + (d.isActive ? 'chip-green' : 'chip-red'); chip.textContent = d.isActive ? '● Hoạt động' : '● Bị khóa'; }
                    if (icon) { icon.className = 'bi ' + (d.isActive ? 'bi-lock' : 'bi-unlock'); }
                    Swal.fire({ icon:'success', title:d.message, timer:1500, showConfirmButton:false, toast:true, position:'top-end' });
                } else { Swal.fire('Lỗi!', d.message, 'error'); }
            });
        }

        function deleteStaff(id, name) {
            Swal.fire({
                title:'Xóa nhân viên?', text:'Bạn muốn xóa "' + name + '"?', icon:'warning',
                showCancelButton:true, confirmButtonColor:'#c94b2a', cancelButtonColor:'#8a7560',
                confirmButtonText:'Xóa', cancelButtonText:'Hủy', reverseButtons:true
            }).then(function(r) {
                if (!r.isConfirmed) return;
                var fd = new FormData();
                fd.append('userId', id);
                fd.append('__RequestVerificationToken', _tok);
                fetch('/AdminStaff/Delete', { method:'POST', body:fd })
                .then(res => res.json()).then(function(d) {
                    if (d.success) {
                        var row = document.getElementById('row_' + id);
                        if (row) row.remove();
                        Swal.fire({ icon:'success', title:d.message, timer:1800, showConfirmButton:false, toast:true, position:'top-end' });
                    } else { Swal.fire('Lỗi!', d.message, 'error'); }
                });
            });
        }
    </script>
}
