@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Chi tiết - " + Model.CategoryName;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@functions {
    string TypeIcon(string t) => t switch { "Food" => "bi-egg-fried", "Beverage" => "bi-cup-straw", "Equipment" => "bi-gear-wide-connected", "Clothing" => "bi-bag-heart", "Accessory" => "bi-watch", _ => "bi-folder2-open" };
    string TypeColor(string t) => t switch { "Food" => "#b45309", "Beverage" => "#0369a1", "Equipment" => "#166534", "Clothing" => "#7e22ce", "Accessory" => "#be185d", _ => "#4b5563" };
    string TypeBg(string t) => t switch { "Food" => "#fffbeb", "Beverage" => "#f0f9ff", "Equipment" => "#f0fdf4", "Clothing" => "#faf5ff", "Accessory" => "#fdf2f8", _ => "#f9fafb" };
    string TypeLabel(string t) => t switch { "Food" => "🍱 Đồ ăn", "Beverage" => "🥤 Thức uống", "Equipment" => "🏸 Dụng cụ", "Clothing" => "👕 Quần áo", "Accessory" => "🧢 Phụ kiện", _ => "📦 Khác" };
    string VisualBg(string t) => t switch { "Food" => "linear-gradient(135deg,#fffbeb,#fef3c7)", "Beverage" => "linear-gradient(135deg,#f0f9ff,#dbeafe)", "Equipment" => "linear-gradient(135deg,#f0fdf4,#dcfce7)", "Clothing" => "linear-gradient(135deg,#faf5ff,#ede9fe)", "Accessory" => "linear-gradient(135deg,#fdf2f8,#fce7f3)", _ => "linear-gradient(135deg,#f9fafb,#f3f4f6)" };
}

@{
    var tc = Model.CategoryType;
    var productCount = Model.Products?.Count ?? 0;
    var activeCount = Model.Products?.Count(p => p.Status == "Active") ?? 0;
    var lowCount = Model.Products?.Count(p => p.StockQuantity <= p.MinStockLevel) ?? 0;
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-hover: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
        --green: #166534;
        --green-bg: #f0fdf4;
        --red: #dc2626;
        --red-bg: #fef2f2;
    }

    .page-wrapper {
        background: var(--court-bg);
        min-height: 100vh;
        padding: 2rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--court-dark);
    }

        .page-title span {
            color: var(--court-gold);
            font-style: italic;
        }

    .bc {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .82rem;
        color: var(--court-muted);
        margin-bottom: 1.5rem;
    }

        .bc a {
            color: var(--court-muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .25rem;
        }

            .bc a:hover {
                color: var(--court-dark);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--court-dark);
        font-weight: 700;
    }

    /* Action buttons */
    .act-row {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .btn-act {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.2rem;
        border-radius: 10px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: .18s;
        border: 1.5px solid;
        white-space: nowrap;
    }

    .btn-edit {
        background: var(--court-gold);
        color: var(--court-dark);
        border-color: var(--court-gold);
    }

        .btn-edit:hover {
            background: var(--court-gold-hover);
            color: var(--court-dark);
        }

    .btn-products {
        background: var(--court-card);
        color: var(--court-text);
        border-color: var(--court-border);
    }

        .btn-products:hover {
            background: var(--court-bg);
            border-color: var(--court-gold);
            color: var(--court-dark);
        }

    .btn-del {
        background: var(--court-card);
        color: var(--red);
        border-color: #fca5a5;
    }

        .btn-del:hover {
            background: var(--red-bg);
        }

    .btn-back {
        background: var(--court-card);
        color: var(--court-muted);
        border-color: var(--court-border);
    }

        .btn-back:hover {
            background: var(--court-bg);
            color: var(--court-dark);
        }

    /* Layout */
    .detail-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    @@media(max-width:900px) {
        .detail-layout {
            grid-template-columns: 1fr;
        }
    }

    /* Sidebar */
    .sidebar-card {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        overflow: hidden;
        position: sticky;
        top: 1.25rem;
    }

    .cat-visual {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .cat-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cat-visual .big-ico {
            font-size: 7rem;
            opacity: .12;
            position: absolute;
        }

        .cat-visual .center-ico {
            font-size: 3.5rem;
            z-index: 1;
            filter: drop-shadow(0 4px 10px rgba(0,0,0,.12));
        }

    .sidebar-info {
        padding: 1.3rem;
    }

    .cat-name-lg {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: .3rem;
    }

    .cat-id-row {
        font-size: .76rem;
        color: var(--court-muted);
        margin-bottom: .85rem;
    }

    .type-badge-lg {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: .3rem .9rem;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 800;
        border: 1.5px solid rgba(0,0,0,.08);
    }

    /* Rule tags */
    .rule-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        margin-top: .75rem;
    }

    .rule-tag {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .7rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        border: 1px solid;
    }

    .rt-hsd {
        background: #fef2f2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    .rt-fifo {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #93c5fd;
    }

    .rt-lot {
        background: #f9fafb;
        color: #374151;
        border-color: #d1d5db;
    }

    .rt-var {
        background: #fffbeb;
        color: #b45309;
        border-color: #fcd34d;
    }

    .rt-none {
        background: var(--court-bg);
        color: var(--court-muted);
        border-color: var(--court-border);
    }

    /* Mini stats */
    .mini-stats {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
        padding-top: .85rem;
        border-top: 1px solid var(--court-border);
    }

    .ms-item {
        text-align: center;
        flex: 1;
    }

    .ms-val {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--court-dark);
        line-height: 1;
    }

    .ms-lbl {
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--court-muted);
        margin-top: 2px;
    }

    /* Detail cards */
    .dc {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

    .dc-hd {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .85rem 1.2rem;
        border-bottom: 1px solid var(--court-border);
        background: #faf8f4;
    }

    .dc-hd-left {
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .dc-hd-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
    }

    .dc-hd-title {
        font-size: .9rem;
        font-weight: 800;
        color: var(--court-dark);
    }

    .dc-bd {
        padding: 1.2rem;
    }

    .desc-box {
        font-size: .875rem;
        color: #4a4a5a;
        line-height: 1.7;
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        border-radius: 8px;
        padding: .75rem 1rem;
    }

    /* Rule rows */
    .rule-grid-det {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
    }

    @@media(max-width:600px) {
        .rule-grid-det {
            grid-template-columns: 1fr;
        }
    }

    .rule-row {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .65rem .85rem;
        border-radius: 9px;
        border: 1px solid;
    }

        .rule-row.on {
            background: var(--green-bg);
            border-color: #86efac;
        }

        .rule-row.off {
            background: #f9fafb;
            border-color: #e5e7eb;
        }

        .rule-row i:first-child {
            font-size: 1rem;
        }

        .rule-row.on i:first-child {
            color: var(--green);
        }

        .rule-row.off i:first-child {
            color: #9ca3af;
        }

    .rule-row-info {
        flex: 1;
    }

    .rule-row-name {
        font-size: .82rem;
        font-weight: 700;
        color: var(--court-dark);
    }

    .rule-row-desc {
        font-size: .72rem;
        color: var(--court-muted);
    }

    .check-ico {
        margin-left: auto;
    }

    .rule-row.on .check-ico {
        color: var(--green);
    }

    .rule-row.off .check-ico {
        color: #d1d5db;
    }

    /* Product table */
    .prod-table {
        width: 100%;
        border-collapse: collapse;
    }

        .prod-table thead tr {
            background: var(--court-dark);
        }

        .prod-table thead th {
            color: rgba(255,255,255,.7);
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            padding: .7rem 1rem;
            border: none;
        }

        .prod-table tbody tr {
            border-bottom: 1px solid var(--court-border);
            transition: background .15s;
        }

            .prod-table tbody tr:last-child {
                border-bottom: none;
            }

            .prod-table tbody tr:hover {
                background: #faf8f0;
            }

        .prod-table td {
            padding: .7rem 1rem;
            vertical-align: middle;
            font-size: .875rem;
        }

    .prod-thumb {
        width: 36px;
        height: 36px;
        border-radius: 7px;
        object-fit: cover;
        border: 1px solid var(--court-border);
    }

    .prod-thumb-ph {
        width: 36px;
        height: 36px;
        border-radius: 7px;
        background: var(--court-bg);
        border: 1px solid var(--court-border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--court-muted);
        font-size: .9rem;
    }

    .prod-name-cell {
        font-weight: 700;
        font-size: .85rem;
        color: var(--court-dark);
    }

    .prod-sku {
        font-size: .75rem;
        color: var(--court-muted);
    }

    .prod-price {
        font-weight: 700;
        color: var(--court-dark);
    }

    .stock-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .sb-ok {
        background: var(--green-bg);
        color: var(--green);
        border: 1px solid #86efac;
    }

    .sb-low {
        background: var(--red-bg);
        color: var(--red);
        border: 1px solid #fca5a5;
    }

    .btn-sm-view {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: var(--court-dark);
        color: #fff;
        font-size: .8rem;
        text-decoration: none;
        transition: .15s;
    }

        .btn-sm-view:hover {
            background: var(--court-gold);
            color: var(--court-dark);
        }

    .more-row {
        text-align: center;
        padding: .6rem;
        font-size: .8rem;
        color: var(--court-muted);
        font-weight: 600;
        background: #faf8f4;
        border-top: 1px solid var(--court-border);
    }

    .link-all {
        font-size: .8rem;
        font-weight: 700;
        color: var(--court-gold);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .link-all:hover {
            color: var(--court-gold-hover);
        }
</style>

<div class="page-wrapper">

    <nav class="bc">
        <a asp-action="Index"><i class="bi bi-collection"></i>Danh Mục</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">@Model.CategoryName</span>
    </nav>

    <!-- Actions -->
    <div class="act-row">
        <a asp-action="Index" class="btn-act btn-back"><i class="bi bi-arrow-left"></i> Quay lại</a>
        <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn-act btn-edit"><i class="bi bi-pencil-square"></i> Chỉnh sửa</a>
        <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" class="btn-act btn-products"><i class="bi bi-box-seam"></i> Xem sản phẩm</a>
        <button onclick="deleteCategory(@Model.CategoryId, '@Model.CategoryName')" class="btn-act btn-del"><i class="bi bi-trash3"></i> Xóa</button>
    </div>

    <div class="detail-layout">

        <!-- Sidebar -->
        <div class="sidebar-card">
            <div class="cat-visual" style="background:@VisualBg(tc);">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.CategoryName" onerror="this.src='/images/no-image.png'" />
                }
                else
                {
                    <i class="bi @TypeIcon(tc) big-ico" style="color:@TypeColor(tc);"></i>
                    <i class="bi @TypeIcon(tc) center-ico" style="color:@TypeColor(tc);"></i>
                }
            </div>

            <div class="sidebar-info">
                <div class="cat-name-lg">@Model.CategoryName</div>
                <div class="cat-id-row">ID #@Model.CategoryId · Đơn vị: <strong>@(Model.DefaultUnit ?? "—")</strong> · Thứ tự: @Model.DisplayOrder</div>

                <span class="type-badge-lg" style="background:@TypeBg(tc);color:@TypeColor(tc);">
                    @TypeLabel(tc)
                </span>

                <div class="rule-tags">
                    @if (Model.RequiresExpiry)
                    {
                        <span class="rule-tag rt-hsd"><i class="bi bi-calendar-x"></i>HSD</span>
                    }
                    @if (Model.UseFIFO)
                    {
                        <span class="rule-tag rt-fifo"><i class="bi bi-arrow-left-right"></i>FIFO</span>
                    }
                    @if (Model.RequiresBatch)
                    {
                        <span class="rule-tag rt-lot"><i class="bi bi-upc"></i>Theo lô</span>
                    }
                    @if (Model.HasVariants)
                    {
                        <span class="rule-tag rt-var"><i class="bi bi-layers"></i>Biến thể</span>
                    }
                    @if (!Model.RequiresExpiry && !Model.UseFIFO && !Model.RequiresBatch && !Model.HasVariants)
                    {
                        <span class="rule-tag rt-none">Không có quy tắc đặc biệt</span>
                    }
                </div>

                <div class="mini-stats">
                    <div class="ms-item">
                        <div class="ms-val">@productCount</div>
                        <div class="ms-lbl">Tổng SP</div>
                    </div>
                    <div class="ms-item">
                        <div class="ms-val" style="color:var(--green);">@activeCount</div>
                        <div class="ms-lbl">Đang bán</div>
                    </div>
                    <div class="ms-item">
                        <div class="ms-val" style="color:var(--red);">@lowCount</div>
                        <div class="ms-lbl">Tồn thấp</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Content -->
        <div>
            <!-- Mô tả -->
            <div class="dc">
                <div class="dc-hd">
                    <div class="dc-hd-left">
                        <div class="dc-hd-icon" style="background:#f1f5f9;color:#475569;"><i class="bi bi-file-text"></i></div>
                        <span class="dc-hd-title">Mô tả danh mục</span>
                    </div>
                </div>
                <div class="dc-bd">
                    <div class="desc-box">
                        @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả cho danh mục này." : Model.Description)
                    </div>
                </div>
            </div>

            <!-- Quy tắc kho -->
            <div class="dc">
                <div class="dc-hd">
                    <div class="dc-hd-left">
                        <div class="dc-hd-icon" style="background:var(--green-bg);color:var(--green);"><i class="bi bi-sliders2"></i></div>
                        <span class="dc-hd-title">Quy tắc quản lý kho</span>
                    </div>
                </div>
                <div class="dc-bd">
                    <div class="rule-grid-det">
                        @{
                            void RuleRow(bool on, string icon, string name, string desc)
                            {
                                <div class="rule-row @(on ? "on" : "off")">
                                    <i class="bi @icon"></i>
                                    <div class="rule-row-info">
                                        <div class="rule-row-name">@name</div>
                                        <div class="rule-row-desc">@desc</div>
                                    </div>
                                    <i class="bi @(on ? "bi-check-circle-fill" : "bi-x-circle") check-ico"></i>
                                </div>
                            }
                        }
                        @{
                            RuleRow(Model.RequiresExpiry, "bi-calendar-x", "Theo dõi HSD", "Quản lý hạn sử dụng");
                        }
                        @{
                            RuleRow(Model.UseFIFO, "bi-arrow-left-right", "Nguyên tắc FIFO", "Nhập trước – Xuất trước");
                        }
                        @{
                            RuleRow(Model.RequiresBatch, "bi-upc", "Quản lý theo lô", "Truy xuất nguồn gốc Batch");
                        }
                        @{
                            RuleRow(Model.HasVariants, "bi-layers", "Có biến thể", "Nhiều màu/size");
                        }
                    </div>
                </div>
            </div>

            <!-- Sản phẩm -->
            @if (Model.Products != null && Model.Products.Any())
            {
                <div class="dc">
                    <div class="dc-hd">
                        <div class="dc-hd-left">
                            <div class="dc-hd-icon" style="background:var(--green-bg);color:var(--green);"><i class="bi bi-box-seam-fill"></i></div>
                            <span class="dc-hd-title">Sản phẩm trong danh mục</span>
                        </div>
                        <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" class="link-all">
                            Xem tất cả <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="prod-table">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>SKU</th>
                                    <th>Giá bán</th>
                                    <th>Tồn kho</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Products.Take(6))
                                {
                                    var isLow = p.StockQuantity <= p.MinStockLevel;
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                                {
                                                    <img src="@p.ImageUrl" class="prod-thumb" onerror="this.src='/images/no-image.png'" />
                                                }
                                                else
                                                {

                                                    <div class="prod-thumb-ph"><i class="bi bi-image"></i></div>
                                                }
                                                <div class="prod-name-cell">@p.ProductName</div>
                                            </div>
                                        </td>
                                        <td><span class="prod-sku" style="font-family:monospace;">@(p.SKU ?? "—")</span></td>
                                        <td><span class="prod-price">@p.SalePrice.ToString("N0")đ</span></td>
                                        <td>
                                            @if (isLow)
                                            {
                                                <span class="stock-badge sb-low"><i class="bi bi-exclamation-circle"></i> @p.StockQuantity</span>
                                            }
                                            else
                                            {

                                                <span class="stock-badge sb-ok"><i class="bi bi-check-circle"></i> @p.StockQuantity</span>
                                            }
                                        </td>
                                        <td style="text-align:right;">
                                            <a href="/Admin/AdminProduct/Details/@p.ProductId" class="btn-sm-view">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (Model.Products.Count > 6)
                        {
                            <div class="more-row">+ @(Model.Products.Count - 6) sản phẩm khác · <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" style="color:var(--court-gold);text-decoration:none;font-weight:700;">Xem tất cả</a></div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteCategory(id, name) {
            Swal.fire({
                title: 'Xóa danh mục?',
                html: `Bạn đang chuẩn bị xóa <b>${name}</b>.<br>Hành động này không thể hoàn tác.`,
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#dc2626', cancelButtonColor: '#1a1a2e',
                confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy bỏ'
            }).then(r => {
                if (!r.isConfirmed) return;
                fetch(`/Admin/AdminCategory/Delete/${id}`, { method: 'POST' })
                    .then(r => r.json())
                    .then(d => {
                        if (d.success) Swal.fire('Thành công!', d.message, 'success').then(() => window.location.href = '/Admin/AdminCategory');
                        else Swal.fire('Không thể xóa!', d.message, 'error');
                    });
            });
        }
    </script>
}
