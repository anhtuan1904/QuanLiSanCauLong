@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Chi tiết - " + Model.CategoryName;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var behavior = Model.BehaviorType ?? "Retail";
}

@functions {
    string TypeIcon(string t) => t switch { "Food" => "bi-egg-fried", "Beverage" => "bi-cup-straw", "Equipment" => "bi-gear-wide-connected", "Clothing" => "bi-bag-heart", "Accessory" => "bi-watch", _ => "bi-folder2-open" };
    string TypeColor(string t) => t switch { "Food" => "#b45309", "Beverage" => "#0369a1", "Equipment" => "#166534", "Clothing" => "#7e22ce", "Accessory" => "#be185d", _ => "#4b5563" };
    string TypeBg(string t) => t switch { "Food" => "#fffbeb", "Beverage" => "#f0f9ff", "Equipment" => "#f0fdf4", "Clothing" => "#faf5ff", "Accessory" => "#fdf2f8", _ => "#f9fafb" };
    string TypeLabel(string t) => t switch { "Food" => "🍱 Đồ ăn", "Beverage" => "🥤 Thức uống", "Equipment" => "🏸 Dụng cụ", "Clothing" => "👕 Quần áo", "Accessory" => "🧢 Phụ kiện", _ => "📦 Khác" };
    string VisualBg(string t) => t switch { "Food" => "linear-gradient(135deg,#fffbeb,#fef3c7)", "Beverage" => "linear-gradient(135deg,#f0f9ff,#dbeafe)", "Equipment" => "linear-gradient(135deg,#f0fdf4,#dcfce7)", "Clothing" => "linear-gradient(135deg,#faf5ff,#ede9fe)", "Accessory" => "linear-gradient(135deg,#fdf2f8,#fce7f3)", _ => "linear-gradient(135deg,#f9fafb,#f3f4f6)" };
}

@{
    var tc = Model.CategoryType ?? "";
    var productCount = Model.Products?.Count ?? 0;
    var activeCount = Model.Products?.Count(p => p.Status == "Active") ?? 0;
    var lowCount = Model.Products?.Count(p => p.StockQuantity <= p.MinStockLevel) ?? 0;
}

<style>
    :root {
        --dark: #1a1a2e;
        --gold: #e8c840;
        --gold-h: #d4b320;
        --bg: #f5f0e8;
        --card: #ffffff;
        --border: #e8e0d0;
        --text: #2d2d2d;
        --muted: #7a7060;
        --green: #166534;
        --green-bg: #f0fdf4;
        --red: #dc2626;
        --red-bg: #fef2f2;
    }

    .page-wrapper {
        background: var(--bg);
        min-height: 100vh;
        padding: 2rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--dark);
    }

        .page-title span {
            color: var(--gold);
            font-style: italic;
        }

    .bc {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .82rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .25rem;
        }

            .bc a:hover {
                color: var(--dark);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--dark);
        font-weight: 700;
    }

    .detail-layout {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 1.5rem;
        align-items: start;
    }
    @@media(max - width:900px) {
        .detail-layout {
            grid-template-columns: 1fr;
        }
    }

    /* Hero Card */
    .hero-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .hero-visual {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .hero-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .hero-big-ico {
        font-size: 8rem;
        opacity: .1;
        position: absolute;
    }

    .hero-center-ico {
        font-size: 4rem;
        z-index: 1;
        filter: drop-shadow(0 6px 16px rgba(0,0,0,.15));
    }

    .hero-body {
        padding: 1.4rem 1.5rem;
    }

    .hero-name {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: .5rem;
    }

    .hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: 1rem;
    }

    .badge-type {
        padding: .25rem .85rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
    }

    .badge-behavior {
        padding: .25rem .85rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
    }

    .badge-active {
        padding: .25rem .85rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
        background: var(--green-bg);
        color: var(--green);
    }

    .badge-inactive {
        padding: .25rem .85rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
        background: var(--red-bg);
        color: var(--red);
    }

    .hero-desc {
        font-size: .82rem;
        color: var(--muted);
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .hero-meta {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .hm-row {
        display: flex;
        justify-content: space-between;
        font-size: .8rem;
        padding: .35rem 0;
        border-bottom: 1px solid var(--border);
    }

        .hm-row:last-child {
            border: none;
        }

    .hm-key {
        color: var(--muted);
        font-weight: 600;
    }

    .hm-val {
        font-weight: 700;
        color: var(--dark);
    }

    .hero-actions {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        gap: .65rem;
    }

    .ha-btn {
        flex: 1;
        padding: .5rem 0;
        border-radius: 9px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--dark);
        font-size: .78rem;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        cursor: pointer;
        transition: .15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
    }

        .ha-btn:hover {
            background: var(--bg);
            color: var(--dark);
        }

        .ha-btn.gold-btn {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--dark);
        }

            .ha-btn.gold-btn:hover {
                background: var(--gold-h);
                border-color: var(--gold-h);
            }

        .ha-btn.danger {
            color: var(--red);
        }

            .ha-btn.danger:hover {
                background: var(--red-bg);
                border-color: #fca5a5;
            }

    /* Right Column */
    .info-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.4rem 1.5rem;
        margin-bottom: 1.2rem;
    }

    .ic-title {
        font-size: .8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--muted);
        padding-bottom: .6rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .ic-title i {
            font-size: 1rem;
        }

    /* Stats Row */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .75rem;
    }

    .sr-item {
        background: var(--bg);
        border-radius: 10px;
        padding: .85rem 1rem;
        text-align: center;
    }

    .sr-val {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--dark);
    }

    .sr-lbl {
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: var(--muted);
        margin-top: 2px;
    }

    /* Rules Grid */
    .rule-grid-view {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .65rem;
    }

    .rv-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .6rem .85rem;
        border-radius: 10px;
        font-size: .78rem;
        font-weight: 700;
    }

    .rv-on {
        background: #f0fdf4;
        color: #166534;
        border: 1.5px solid #86efac;
    }

    .rv-off {
        background: #f9fafb;
        color: #9ca3af;
        border: 1.5px solid #e5e7eb;
    }

    .rv-item i {
        font-size: .9rem;
    }

    /* Behavior panels */
    .bh-panel {
        border-radius: 12px;
        padding: 1rem 1.1rem;
        border: 1.5px solid transparent;
    }

    .bh-panel-retail {
        background: #f0fdf4;
        border-color: #86efac;
    }

    .bh-panel-rental {
        background: #eff6ff;
        border-color: #93c5fd;
    }

    .bh-panel-service {
        background: #f5f3ff;
        border-color: #c4b5fd;
    }

    .bh-panel-title {
        font-size: .72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: .75rem;
    }

    .bh-panel-retail .bh-panel-title {
        color: #166534;
    }

    .bh-panel-rental .bh-panel-title {
        color: #1d4ed8;
    }

    .bh-panel-service .bh-panel-title {
        color: #7c3aed;
    }

    .bh-detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
    }

    .bh-detail-item {
        padding: .5rem .75rem;
        background: rgba(255,255,255,.6);
        border-radius: 8px;
    }

    .bh-detail-key {
        font-size: .67rem;
        color: var(--muted);
        font-weight: 600;
    }

    .bh-detail-val {
        font-size: .82rem;
        font-weight: 800;
        color: var(--dark);
    }

    /* Product table */
    .prod-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .prod-table th {
            background: var(--bg);
            padding: .5rem .75rem;
            text-align: left;
            font-size: .7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--muted);
            border-bottom: 2px solid var(--border);
        }

        .prod-table td {
            padding: .6rem .75rem;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            vertical-align: middle;
        }

        .prod-table tr:last-child td {
            border: none;
        }

        .prod-table tr:hover td {
            background: var(--bg);
        }

    .status-active {
        background: #f0fdf4;
        color: #166534;
        font-size: .68rem;
        font-weight: 700;
        padding: .18rem .6rem;
        border-radius: 20px;
    }

    .status-inactive {
        background: #f9fafb;
        color: #6b7280;
        font-size: .68rem;
        font-weight: 700;
        padding: .18rem .6rem;
        border-radius: 20px;
    }

    .status-low {
        background: #fef2f2;
        color: #dc2626;
        font-size: .68rem;
        font-weight: 700;
        padding: .18rem .6rem;
        border-radius: 20px;
    }

    .empty-row td {
        text-align: center;
        color: var(--muted);
        padding: 2rem;
        font-style: italic;
    }
</style>

<div class="page-wrapper">
    <div class="bc">
        <a asp-action="Index"><i class="bi bi-house-door"></i> Danh mục</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">@Model.CategoryName</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-3" style="border-radius:10px;font-size:.875rem;">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="detail-layout">
        <!-- Hero Sidebar -->
        <div>
            <div class="hero-card">
                <div class="hero-visual" style="background:@VisualBg(tc);">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.CategoryName" />
                    }
                    else
                    {
                        <i class="bi @TypeIcon(tc) hero-big-ico" style="color:@TypeColor(tc);"></i>
                        <i class="bi @TypeIcon(tc) hero-center-ico" style="color:@TypeColor(tc);"></i>
                    }
                </div>
                <div class="hero-body">
                    <div class="hero-name">@Model.CategoryName</div>
                    <div class="hero-badges">
                        <span class="badge-type" style="background:@TypeBg(tc);color:@TypeColor(tc);">@TypeLabel(tc)</span>
                        @{
                            string bhLabel = behavior switch { "Rental" => "🔄 Cho thuê", "Service" => "🔧 Dịch vụ", _ => "🛒 Bán lẻ" };
                            string bhColor = behavior switch { "Rental" => "#1d4ed8", "Service" => "#7c3aed", _ => "#166534" };
                            string bhBg = behavior switch { "Rental" => "#eff6ff", "Service" => "#f5f3ff", _ => "#f0fdf4" };
                        }
                        <span class="badge-behavior" style="background:@bhBg;color:@bhColor;">@bhLabel</span>
                        @if (Model.IsActive)
                        {
                            <span class="badge-active"><i class="bi bi-eye"></i> Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge-inactive"><i class="bi bi-eye-slash"></i> Đã ẩn</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="hero-desc">@Model.Description</div>
                    }
                    <div class="hero-meta">
                        <div class="hm-row"><span class="hm-key">Đơn vị</span><span class="hm-val">@Model.DefaultUnit</span></div>
                        <div class="hm-row"><span class="hm-key">Safety Stock</span><span class="hm-val">@(Model.DefaultMinStock > 0 ? Model.DefaultMinStock.ToString() : "—")</span></div>
                        <div class="hm-row"><span class="hm-key">Thứ tự</span><span class="hm-val">@Model.DisplayOrder</span></div>
                        <div class="hm-row"><span class="hm-key">Tạo lúc</span><span class="hm-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                        <div class="hm-row"><span class="hm-key">Cập nhật</span><span class="hm-val">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
                    </div>
                </div>
                <div class="hero-actions">
                    <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="ha-btn gold-btn"><i class="bi bi-pencil"></i> Sửa</a>
                    <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" class="ha-btn"><i class="bi bi-box-seam"></i> Sản phẩm</a>
                    <button onclick="deleteCategory(@Model.CategoryId,'@Model.CategoryName')" class="ha-btn danger"><i class="bi bi-trash3"></i> Xóa</button>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div>
            <!-- Stats -->
            <div class="info-card">
                <div class="ic-title"><i class="bi bi-bar-chart-line"></i>Thống Kê Nhanh</div>
                <div class="stats-row">
                    <div class="sr-item"><div class="sr-val">@productCount</div><div class="sr-lbl">Sản phẩm</div></div>
                    <div class="sr-item"><div class="sr-val" style="color:var(--green);">@activeCount</div><div class="sr-lbl">Đang bán</div></div>
                    <div class="sr-item"><div class="sr-val" style="color:@(lowCount > 0 ? "var(--red)" : "var(--dark)");">@lowCount</div><div class="sr-lbl">Tồn thấp</div></div>
                </div>
            </div>

            <!-- Behavior-specific config -->
            <div class="info-card">
                <div class="ic-title"><i class="bi bi-diagram-3"></i>Cấu Hình Nghiệp Vụ</div>
                <div class="bh-panel bh-panel-@behavior.ToLower()">
                    <div class="bh-panel-title">
                        @(behavior == "Retail" ? "🛒 Bán Lẻ – Trừ kho thẳng" : behavior == "Rental" ? "🔄 Cho Thuê – Hoàn kho khi trả" : "🔧 Dịch Vụ – Không kho vật lý")
                    </div>

                    @if (behavior == "Retail")
                    {
                        <div class="rule-grid-view">
                            <div class="rv-item @(Model.RequiresExpiry ? "rv-on" : "rv-off")"><i class="bi @(Model.RequiresExpiry ? "bi-calendar-x" : "bi-calendar")"></i>Theo dõi HSD</div>
                            <div class="rv-item @(Model.UseFIFO ? "rv-on" : "rv-off")"><i class="bi @(Model.UseFIFO ? "bi-arrow-left-right" : "bi-dash")"></i>FIFO</div>
                            <div class="rv-item @(Model.RequiresBatch ? "rv-on" : "rv-off")"><i class="bi @(Model.RequiresBatch ? "bi-upc" : "bi-dash")"></i>Quản lý Lô</div>
                            <div class="rv-item @(Model.HasVariants ? "rv-on" : "rv-off")"><i class="bi @(Model.HasVariants ? "bi-layers" : "bi-dash")"></i>Biến thể</div>
                        </div>
                    }
                    else if (behavior == "Rental")
                    {
                        <div class="bh-detail-grid">
                            <div class="bh-detail-item"><div class="bh-detail-key">Quản lý Size</div><div class="bh-detail-val">@(Model.RequiresSize ? "✅ Có" : "—")</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Trả từng phần</div><div class="bh-detail-val">@(Model.AllowPartialReturn ? "✅ Cho phép" : "—")</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Đặt cọc</div><div class="bh-detail-val">@(Model.DepositRequired ? $"✅ {Model.DefaultDepositAmount:N0}₫" : "—")</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Phí vệ sinh</div><div class="bh-detail-val">@(Model.DefaultCleaningFee > 0 ? $"{Model.DefaultCleaningFee:N0}₫" : "—")</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Giờ thuê tối đa</div><div class="bh-detail-val">@(Model.MaxRentalHours > 0 ? $"{Model.MaxRentalHours}h" : "Không giới hạn")</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Phụ thu overtime</div><div class="bh-detail-val">@(Model.ChargeOvertime ? "✅ Có" : "—")</div></div>
                        </div>
                    }
                    else if (behavior == "Service")
                    {
                        <div class="bh-detail-grid">
                            <div class="bh-detail-item"><div class="bh-detail-key">Mô hình giá</div><div class="bh-detail-val">@Model.PricingModel</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Tách Công+VL</div><div class="bh-detail-val">@(Model.SeparateLaborAndMaterial ? "✅ Có" : "—")</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Đơn vị vật liệu</div><div class="bh-detail-val">@(string.IsNullOrEmpty(Model.MaterialUnit) ? "—" : Model.MaterialUnit)</div></div>
                            <div class="bh-detail-item"><div class="bh-detail-key">Vật liệu khách</div><div class="bh-detail-val">@(Model.AllowCustomerMaterial ? "✅ Cho phép" : "—")</div></div>
                        </div>
                    }
                </div>
            </div>

            <!-- Product List -->
            <div class="info-card">
                <div class="ic-title d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-seam"></i>Sản Phẩm Trong Danh Mục</span>
                    <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" style="font-size:.72rem;color:var(--gold);text-decoration:none;font-weight:700;">Xem tất cả →</a>
                </div>
                <div style="overflow-x:auto;">
                    <table class="prod-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Tồn kho</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Products != null && Model.Products.Any())
                            {
                                foreach (var p in Model.Products.Take(8))
                                {
                                    var isLow = p.StockQuantity <= p.MinStockLevel;
                                    <tr>
                                        <td><strong>@p.ProductName</strong></td>
                                        <td>@p.SalePrice.ToString("N0")₫</td>
                                        <td>
                                            <span class="@(isLow ? "status-low" : "")">@p.StockQuantity @p.Unit</span>
                                        </td>
                                        <td>
                                            <span class="@(p.Status == "Active" ? "status-active" : "status-inactive")">
                                                @(p.Status == "Active" ? "Đang bán" : "Ngừng")
                                            </span>
                                        </td>
                                    </tr>
                                }
                                @if (Model.Products.Count > 8)
                                {
                                    <tr>
                                        <td colspan="4" style="text-align:center;color:var(--muted);font-size:.78rem;padding:.75rem;">
                                            ... và @(Model.Products.Count - 8) sản phẩm khác
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr class="empty-row"><td colspan="4">Chưa có sản phẩm nào trong danh mục này</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteCategory(id, name) {
            Swal.fire({
                title: 'Xóa danh mục?',
                html: `Bạn đang xóa <b>${name}</b>.<br>Hành động này không thể hoàn tác.`,
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#dc2626', cancelButtonColor: '#1a1a2e',
                confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy bỏ'
            }).then(r => {
                if (!r.isConfirmed) return;
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                fetch(`/Admin/AdminCategory/Delete/${id}`, {
                    method: 'POST', headers: { 'RequestVerificationToken': token }
                })
                .then(r => r.json())
                .then(d => {
                    if (d.success) window.location.href = '/Admin/AdminCategory';
                    else Swal.fire('Không thể xóa!', d.message, 'error');
                })
                .catch(() => Swal.fire('Lỗi!', 'Không thể kết nối máy chủ.', 'error'));
            });
        }
    </script>
}
