@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Chi tiết - " + Model.CategoryName;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var behavior = Model.BehaviorType ?? "Retail";
    var productCount = Model.Products?.Count ?? 0;
    var activeCount = Model.Products?.Count(p => p.Status == "Active") ?? 0;
    var lowCount = Model.Products?.Count(p => p.StockQuantity <= p.MinStockLevel) ?? 0;
}
<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }
    /* breadcrumb */
    .bc {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.4rem;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .25rem;
        }

            .bc a:hover {
                color: var(--deep);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--deep);
        font-weight: 700;
    }
    /* layout */
    .detail-layout {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 1.4rem;
        align-items: start;
    }

    @@media(max-width:900px) {
        .detail-layout {
            grid-template-columns: 1fr;
        }
    }
    /* hero card */
    .hero-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
    }

    .hero-visual {
        height: 190px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .hero-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .hero-big-ico {
        font-size: 7rem;
        opacity: .1;
        position: absolute;
    }

    .hero-center-ico {
        font-size: 3.5rem;
        z-index: 1;
        filter: drop-shadow(0 4px 14px rgba(0,0,0,.15));
    }

    .hero-body {
        padding: 1.3rem 1.4rem;
    }

    .hero-name {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--deep);
        margin-bottom: .5rem;
    }

    .hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: .85rem;
    }

    .badge {
        padding: .22rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .hero-desc {
        font-size: .8rem;
        color: var(--muted);
        line-height: 1.6;
        margin-bottom: .85rem;
    }

    .hero-meta {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .hm-row {
        display: flex;
        justify-content: space-between;
        font-size: .79rem;
        padding: .35rem 0;
        border-bottom: 1px solid var(--border);
    }

        .hm-row:last-child {
            border: none;
        }

    .hm-key {
        color: var(--muted);
        font-weight: 600;
    }

    .hm-val {
        font-weight: 700;
        color: var(--deep);
    }

    .hero-actions {
        padding: .9rem 1.4rem;
        border-top: 1px solid var(--border);
        display: flex;
        gap: .6rem;
    }

    .ha-btn {
        flex: 1;
        padding: .48rem 0;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--deep);
        font-size: .76rem;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        cursor: pointer;
        transition: .15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
    }

        .ha-btn:hover {
            background: var(--warm);
            color: var(--deep);
        }

        .ha-btn.gold {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--deep);
        }

            .ha-btn.gold:hover {
                background: var(--gold2);
                border-color: var(--gold2);
            }

        .ha-btn.danger {
            color: var(--red);
        }

            .ha-btn.danger:hover {
                background: #fee2e2;
                border-color: #fca5a5;
            }
    /* info cards */
    .card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.3rem 1.4rem;
        margin-bottom: 1.1rem;
    }

    .card-hd {
        font-size: .65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--muted);
        padding-bottom: .6rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: .9rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }
    /* stats */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .7rem;
    }

    .sr {
        background: var(--warm);
        border-radius: 9px;
        padding: .8rem 1rem;
        text-align: center;
    }

    .sr-val {
        font-family: 'Playfair Display',serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep);
    }

    .sr-lbl {
        font-size: .62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: var(--muted);
        margin-top: 2px;
    }
    /* bh panel */
    .bh-panel {
        border-radius: 11px;
        padding: .9rem 1rem;
        border: 1.5px solid transparent;
    }

        .bh-panel.retail {
            background: #f0fdf4;
            border-color: #86efac;
        }

        .bh-panel.rental {
            background: #eff6ff;
            border-color: #93c5fd;
        }

        .bh-panel.service {
            background: #f5f3ff;
            border-color: #c4b5fd;
        }

    .bh-panel-title {
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: .75rem;
    }

    .bh-panel.retail .bh-panel-title {
        color: #166534;
    }

    .bh-panel.rental .bh-panel-title {
        color: #1d4ed8;
    }

    .bh-panel.service .bh-panel-title {
        color: #7c3aed;
    }
    /* rule items */
    .rule-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
    }

    .rv {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .52rem .75rem;
        border-radius: 9px;
        font-size: .76rem;
        font-weight: 700;
    }

        .rv.on {
            background: #f0fdf4;
            color: #166534;
            border: 1.5px solid #86efac;
        }

        .rv.off {
            background: #f9fafb;
            color: #9ca3af;
            border: 1.5px solid #e5e7eb;
        }
    /* detail grid */
    .bh-dg {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
    }

    .bh-di {
        padding: .48rem .7rem;
        background: rgba(255,255,255,.6);
        border-radius: 7px;
    }

    .bh-dk {
        font-size: .65rem;
        color: var(--muted);
        font-weight: 600;
    }

    .bh-dv {
        font-size: .8rem;
        font-weight: 800;
        color: var(--deep);
    }
    /* product table */
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

    th {
        background: var(--warm);
        padding: .5rem .75rem;
        text-align: left;
        font-size: .65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .8px;
        color: var(--muted);
        border-bottom: 2px solid var(--border);
    }

    td {
        padding: .58rem .75rem;
        border-bottom: 1px solid var(--border);
        color: var(--deep);
        vertical-align: middle;
    }

    tr:last-child td {
        border: none;
    }

    tr:hover td {
        background: var(--warm);
    }

    .st-a {
        background: #f0fdf4;
        color: #166534;
        font-size: .66rem;
        font-weight: 700;
        padding: .16rem .55rem;
        border-radius: 20px;
    }

    .st-i {
        background: #f9fafb;
        color: #6b7280;
        font-size: .66rem;
        font-weight: 700;
        padding: .16rem .55rem;
        border-radius: 20px;
    }

    .st-l {
        background: #fee2e2;
        color: #dc2626;
        font-size: .66rem;
        font-weight: 700;
        padding: .16rem .55rem;
        border-radius: 20px;
    }

    .empty-row td {
        text-align: center;
        color: var(--muted);
        padding: 2rem;
        font-style: italic;
    }
</style>

<div class="pg">
    <div class="bc">
        <a asp-action="Index"><i class="bi bi-house-door"></i> Danh mục</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">@Model.CategoryName</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-3" style="border-radius:10px;font-size:.875rem;"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
    }

    <div class="detail-layout">
        <!-- Hero sidebar -->
        <div>
            <div class="hero-card">
                @{
                    var bhBg = behavior == "Rental" ? "#eff6ff" : behavior == "Service" ? "#f5f3ff" : "#f0fdf4";
                    var bhClr = behavior == "Rental" ? "#1d4ed8" : behavior == "Service" ? "#7c3aed" : "#166534";
                    var bhIco = behavior == "Rental" ? "bi-arrow-repeat" : behavior == "Service" ? "bi-wrench-adjustable" : "bi-cart3";
                    var bhLbl = behavior == "Rental" ? "🔄 Cho thuê" : behavior == "Service" ? "🔧 Dịch vụ" : "🛒 Bán lẻ";
                }
                <div class="hero-visual" style="background:@bhBg">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.CategoryName" />
                    }
                    else
                    {
                        <i class="bi @bhIco hero-big-ico" style="color:@bhClr"></i>
                        <i class="bi @bhIco hero-center-ico" style="color:@bhClr"></i>
                    }
                </div>
                <div class="hero-body">
                    <div class="hero-name">@Model.CategoryName</div>
                    <div class="hero-badges">
                        <span class="badge" style="background:@bhBg;color:@bhClr">@bhLbl</span>
                        @if (Model.IsActive)
                        {
                            <span class="badge" style="background:#f0fdf4;color:#166534"><i class="bi bi-eye"></i> Hoạt động</span>
                        }
                        else
                        {

                            <span class="badge" style="background:#fee2e2;color:#dc2626"><i class="bi bi-eye-slash"></i> Đã ẩn</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="hero-desc">@Model.Description</div>
                    }
                    <div class="hero-meta">
                        <div class="hm-row"><span class="hm-key">Đơn vị</span><span class="hm-val">@Model.DefaultUnit</span></div>
                        <div class="hm-row"><span class="hm-key">Safety Stock</span><span class="hm-val">@(Model.DefaultMinStock > 0 ? Model.DefaultMinStock.ToString() : "—")</span></div>
                        <div class="hm-row"><span class="hm-key">Thứ tự</span><span class="hm-val">@Model.DisplayOrder</span></div>
                        <div class="hm-row"><span class="hm-key">Tạo lúc</span><span class="hm-val">@Model.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                        <div class="hm-row"><span class="hm-key">Cập nhật</span><span class="hm-val">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
                    </div>
                </div>
                <div class="hero-actions">
                    <button onclick="openEditModal(@Model.CategoryId)" class="ha-btn gold"><i class="bi bi-pencil"></i> Sửa</button>
                    <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" class="ha-btn"><i class="bi bi-box-seam"></i> Sản phẩm</a>
                    <button onclick="deleteCategory(@Model.CategoryId,'@Html.Raw(Model.CategoryName.Replace("'", "\\'"))')" class="ha-btn danger"><i class="bi bi-trash3"></i> Xóa</button>
                </div>
            </div>
        </div>

        <!-- Right column -->
        <div>
            <div class="card">
                <div class="card-hd"><i class="bi bi-bar-chart-line"></i>Thống kê nhanh</div>
                <div class="stats-row">
                    <div class="sr"><div class="sr-val">@productCount</div><div class="sr-lbl">Sản phẩm</div></div>
                    <div class="sr"><div class="sr-val" style="color:var(--green)">@activeCount</div><div class="sr-lbl">Đang bán</div></div>
                    <div class="sr"><div class="sr-val" style="color:@(lowCount > 0 ? "var(--red)" : "var(--deep)")">@lowCount</div><div class="sr-lbl">Tồn thấp</div></div>
                </div>
            </div>

            <div class="card">
                <div class="card-hd"><i class="bi bi-diagram-3"></i>Cấu hình nghiệp vụ</div>
                <div class="bh-panel @behavior.ToLower()">
                    <div class="bh-panel-title">
                        @(behavior == "Retail" ? "🛒 Bán Lẻ – Trừ kho thẳng" : behavior == "Rental" ? "🔄 Cho Thuê – Hoàn kho khi trả" : "🔧 Dịch Vụ – Không kho vật lý")
                    </div>

                    @if (behavior == "Retail")
                    {
                        <div class="rule-grid">
                            <div class="rv @(Model.RequiresExpiry ? "on" : "off")"><i class="bi @(Model.RequiresExpiry ? "bi-calendar-x" : "bi-calendar")"></i>Theo dõi HSD</div>
                            <div class="rv @(Model.HasVariants ? "on" : "off")"><i class="bi @(Model.HasVariants ? "bi-layers" : "bi-dash")"></i>Biến thể</div>
                        </div>
                    }
                    else if (behavior == "Rental")
                    {
                        <div class="bh-dg">
                            <div class="bh-di"><div class="bh-dk">Trả từng phần</div><div class="bh-dv">@(Model.AllowPartialReturn ? "✅ Cho phép" : "—")</div></div>
                            <div class="bh-di"><div class="bh-dk">Đặt cọc</div><div class="bh-dv">@(Model.DepositRequired ? $"✅ {Model.DefaultDepositAmount:N0}₫" : "—")</div></div>
                        </div>
                    }
                    else
                    {
                        <p style="font-size:.8rem;color:var(--muted);margin:0">Dịch vụ kỹ thuật — không quản lý kho vật lý. Giá & chi tiết cấu hình tại từng sản phẩm.</p>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-hd" style="justify-content:space-between">
                    <span><i class="bi bi-box-seam"></i>Sản phẩm trong danh mục</span>
                    <a href="/Admin/AdminProduct?categoryId=@Model.CategoryId" style="font-size:.72rem;color:var(--gold);text-decoration:none;font-weight:700">Xem tất cả →</a>
                </div>
                <div style="overflow-x:auto">
                    <table>
                        <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>Tồn kho</th><th>Trạng thái</th></tr></thead>
                        <tbody>
                            @if (Model.Products?.Any() == true)
                            {
                                @foreach (var p in Model.Products.Take(8))
                                {
                                    var isLow = p.StockQuantity <= p.MinStockLevel && p.MinStockLevel > 0;
                                    <tr>
                                        <td><strong>@p.ProductName</strong></td>
                                        <td>@p.Price.ToString("N0")₫</td>
                                        <td><span class="@(isLow ? "st-l" : "")">@p.StockQuantity @p.Unit</span></td>
                                        <td><span class="@(p.Status == "Active" ? "st-a" : "st-i")">@(p.Status == "Active" ? "Đang bán" : "Ngừng")</span></td>
                                    </tr>
                                }
                                @if (Model.Products.Count > 8)
                                {
                                    <tr><td colspan="4" style="text-align:center;color:var(--muted);font-size:.76rem;padding:.65rem">... và @(Model.Products.Count - 8) sản phẩm khác</td></tr>
                                }
                            }
                            else
                            {
                                <tr class="empty-row"><td colspan="4">Chưa có sản phẩm nào trong danh mục này</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@* Bootstrap Modal shell for edit *@
<div class="modal fade" id="catModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:600px">
        <div class="modal-content" id="catModalBody" style="border-radius:16px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.18)">
            <div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN=document.querySelector('input[name="__RequestVerificationToken"]')?.value??'';
        let catModal;
        document.addEventListener('DOMContentLoaded',()=>{ catModal=new bootstrap.Modal(document.getElementById('catModal')); });
        function runScripts(el){ el.querySelectorAll('script').forEach(s=>{const n=document.createElement('script');n.text=s.text;s.replaceWith(n);}); }
        function closeCatModal(){ catModal.hide(); }

        async function openEditModal(id){
            document.getElementById('catModalBody').innerHTML='<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            catModal.show();
            try{
                const r=await fetch(`/Admin/AdminCategory/EditPartial/${id}`,{headers:{'X-Requested-With':'XMLHttpRequest'}});
                document.getElementById('catModalBody').innerHTML=await r.text();
                runScripts(document.getElementById('catModalBody'));
            }catch(e){
                document.getElementById('catModalBody').innerHTML='<div class="p-4 text-center"><p class="text-danger">Không tải được form</p><button class="btn btn-sm btn-secondary" onclick="catModal.hide()">Đóng</button></div>';
            }
        }

        function deleteCategory(id,name){
            Swal.fire({
                title:'Xóa danh mục?',html:`Bạn đang xóa <b>${name}</b>.<br>Không thể hoàn tác.`,
                icon:'warning',showCancelButton:true,reverseButtons:true,
                confirmButtonColor:'#dc2626',cancelButtonColor:'#8a7560',
                confirmButtonText:'Xóa ngay',cancelButtonText:'Hủy bỏ'
            }).then(r=>{
                if(!r.isConfirmed)return;
                fetch(`/Admin/AdminCategory/Delete/${id}`,{method:'POST',headers:{'RequestVerificationToken':TOKEN}})
                .then(r=>r.json()).then(d=>{
                    if(d.success) window.location.href='/Admin/AdminCategory';
                    else Swal.fire('Không thể xóa!',d.message,'error');
                }).catch(()=>Swal.fire('Lỗi!','Không thể kết nối.','error'));
            });
        }
    </script>
}
