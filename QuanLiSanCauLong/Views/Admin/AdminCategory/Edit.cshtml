@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Sửa - " + Model.CategoryName;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var behavior = Model.BehaviorType ?? "Retail";
}
<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title span {
            color: var(--gold);
            font-style: italic;
        }

    .bc {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.4rem;
    }

        .bc a {
            color: var(--muted);
            text-decoration: none;
        }

            .bc a:hover {
                color: var(--deep);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--deep);
        font-weight: 700;
    }
    /* layout */
    .form-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    @@media(max-width:820px) {
        .form-layout {
            grid-template-columns: 1fr;
        }
    }
    /* preview */
    .prev-side {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 13px;
        overflow: hidden;
        position: sticky;
        top: 1.25rem;
    }

    .prev-visual {
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        transition: background .35s;
    }

        .prev-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .prev-big-ico {
        font-size: 5.5rem;
        opacity: .12;
        position: absolute;
    }

    .prev-center-ico {
        font-size: 2.8rem;
        z-index: 1;
        filter: drop-shadow(0 4px 12px rgba(0,0,0,.15));
        transition: all .35s;
    }

    .prev-body {
        padding: 1rem 1.1rem;
    }

    .prev-name {
        font-size: .95rem;
        font-weight: 800;
        color: var(--deep);
        margin-bottom: .3rem;
    }

    .prev-bh {
        display: inline-block;
        padding: .18rem .62rem;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
        margin-bottom: .4rem;
    }

    .prev-meta {
        font-size: .74rem;
        color: var(--muted);
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }

    .prev-lbl {
        font-size: .65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
        padding: .55rem 1.1rem .25rem;
        border-top: 1px solid var(--border);
    }

    .upload-zone {
        border: 2px dashed var(--border);
        border-radius: 9px;
        padding: 1rem;
        text-align: center;
        cursor: pointer;
        transition: .2s;
        background: var(--warm);
        margin: 0 1.1rem 1.1rem;
    }

        .upload-zone:hover {
            border-color: var(--gold);
            background: #faf8f0;
        }

        .upload-zone i {
            font-size: 1.4rem;
            color: var(--muted);
            display: block;
            margin-bottom: .25rem;
        }

        .upload-zone p {
            font-size: .72rem;
            color: var(--muted);
            margin: 0;
        }

    .upload-preview img {
        width: 100%;
        max-height: 100px;
        object-fit: cover;
        border-radius: 7px;
    }
    /* form */
    .form-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 13px;
        padding: 1.6rem;
    }

    .form-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--deep);
        margin-bottom: .15rem;
    }

    .form-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-bottom: 1.4rem;
    }

    .sec-div {
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: var(--muted);
        padding: .5rem 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: .9rem;
    }
    /* form inputs reuse admin-modal.css .fg .fi */
    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    @@media(max-width:600px) {
        .two-col {
            grid-template-columns: 1fr;
        }
    }
    /* behavior tabs */
    .bh-tabs {
        display: flex;
        gap: .55rem;
        margin-bottom: 1.1rem;
    }

    .bh-tab {
        flex: 1;
        padding: .65rem .4rem;
        border-radius: 9px;
        border: 2px solid var(--border);
        cursor: pointer;
        text-align: center;
        transition: .2s;
        background: var(--warm);
    }

        .bh-tab:hover {
            border-color: var(--muted);
        }

        .bh-tab.on-Retail {
            border-color: #166534;
            background: #f0fdf4;
        }

        .bh-tab.on-Rental {
            border-color: #1d4ed8;
            background: #eff6ff;
        }

        .bh-tab.on-Service {
            border-color: #7c3aed;
            background: #f5f3ff;
        }

    .bh-tab-ico {
        font-size: 1.3rem;
        display: block;
        margin-bottom: .2rem;
    }

    .bh-tab-lbl {
        font-size: .76rem;
        font-weight: 800;
    }

    .bh-tab-desc {
        font-size: .64rem;
        color: var(--muted);
    }

    .on-Retail .bh-tab-lbl {
        color: #166534;
    }

    .on-Rental .bh-tab-lbl {
        color: #1d4ed8;
    }

    .on-Service .bh-tab-lbl {
        color: #7c3aed;
    }
    /* conditional panels */
    .cond {
        display: none;
        border-radius: 9px;
        padding: .9rem 1rem;
        margin-bottom: .9rem;
        border: 1.5px solid transparent;
    }

        .cond.show {
            display: block;
        }

        .cond.panel-retail {
            background: #f0fdf4;
            border-color: #86efac;
        }

        .cond.panel-rental {
            background: #eff6ff;
            border-color: #93c5fd;
        }

        .cond.panel-service {
            background: #f5f3ff;
            border-color: #c4b5fd;
        }

    .panel-title {
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: .75rem;
    }

    .cond.panel-retail .panel-title {
        color: #166534;
    }

    .cond.panel-rental .panel-title {
        color: #1d4ed8;
    }

    .cond.panel-service .panel-title {
        color: #7c3aed;
    }
    /* rule toggles */
    .rule-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
        margin-bottom: .9rem;
    }

    .rule-toggle {
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: .68rem .85rem;
        cursor: pointer;
        transition: .2s;
        background: var(--warm);
        user-select: none;
    }

        .rule-toggle input {
            display: none;
        }

        .rule-toggle:hover {
            border-color: var(--muted);
        }

    .rt-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .rt-lbl {
        font-size: .78rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .32rem;
    }

    .rt-desc {
        font-size: .67rem;
        color: var(--muted);
        margin-top: .22rem;
    }

    .tdot {
        width: 28px;
        height: 15px;
        border-radius: 10px;
        background: #d1d5db;
        position: relative;
        transition: .25s;
        flex-shrink: 0;
    }

        .tdot::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            width: 11px;
            height: 11px;
            border-radius: 50%;
            background: #fff;
            transition: .25s;
        }

    .rt-expiry {
        border-color: #dc2626;
        background: #fef2f2;
    }

        .rt-expiry .tdot {
            background: #dc2626;
        }

    .rt-var {
        border-color: #f59e0b;
        background: #fffbeb;
    }

        .rt-var .tdot {
            background: #f59e0b;
        }

    .rt-part {
        border-color: #f59e0b;
        background: #fffbeb;
    }

        .rt-part .tdot {
            background: #f59e0b;
        }

    .rt-deposit {
        border-color: #dc2626;
        background: #fef2f2;
    }

        .rt-deposit .tdot {
            background: #dc2626;
        }

            .rt-expiry .tdot::after, .rt-var .tdot::after, .rt-part .tdot::after, .rt-deposit .tdot::after {
                left: 15px;
            }
    /* money input */
    .money-wrap {
        position: relative;
    }

        .money-wrap .fi {
            padding-right: 2.8rem;
        }

    .money-sfx {
        position: absolute;
        right: .65rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: .72rem;
        font-weight: 700;
        color: var(--muted);
    }
    /* active badge */
    .active-badge {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .28rem .78rem;
        border-radius: 20px;
        font-size: .76rem;
        font-weight: 700;
        cursor: pointer;
        border: 1.5px solid;
        user-select: none;
        transition: .18s;
    }

        .active-badge.on {
            background: #f0fdf4;
            color: #166534;
            border-color: #86efac;
        }

        .active-badge.off {
            background: #fee2e2;
            color: #dc2626;
            border-color: #fca5a5;
        }
    /* bottom btns */
    .btn-row {
        display: flex;
        gap: .7rem;
        justify-content: flex-end;
        margin-top: 1.4rem;
        padding-top: 1.2rem;
        border-top: 1px solid var(--border);
    }
</style>

<div class="pg">
    <div class="bc">
        <a asp-action="Index"><i class="bi bi-house-door"></i> Danh mục</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">Sửa: @Model.CategoryName</span>
    </div>
    <h1 class="pg-title mb-1">Sửa <span>@Model.CategoryName</span></h1>
    <p style="color:var(--muted);font-size:.85rem;margin-bottom:1.5rem">Cập nhật thông tin và quy tắc cho danh mục</p>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" style="border-radius:10px;font-size:.875rem;"><i class="bi bi-exclamation-circle-fill"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="form-layout">
        <!-- Preview sidebar -->
        <div class="prev-side">
            @{
                var bhBg = behavior == "Rental" ? "#eff6ff" : behavior == "Service" ? "#f5f3ff" : "#f0fdf4";
                var bhClr = behavior == "Rental" ? "#1d4ed8" : behavior == "Service" ? "#7c3aed" : "#166534";
                var bhIco = behavior == "Rental" ? "bi-arrow-repeat" : behavior == "Service" ? "bi-wrench-adjustable" : "bi-cart3";
                var bhLbl = behavior == "Rental" ? "🔄 Cho thuê" : behavior == "Service" ? "🔧 Dịch vụ" : "🛒 Bán lẻ";
            }
            <div class="prev-visual" id="prevVisual" style="background:@bhBg">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" id="prevImgEl" alt="" />
                }
                else
                {
                    <i class="bi @bhIco prev-big-ico" id="prevBigIco" style="color:@bhClr"></i>
                    <i class="bi @bhIco prev-center-ico" id="prevCtrIco" style="color:@bhClr"></i>
                }
            </div>
            <div class="prev-body">
                <div class="prev-name" id="prevName">@Model.CategoryName</div>
                <span class="prev-bh" id="prevBh" style="background:@bhBg;color:@bhClr">@bhLbl</span>
                <div class="prev-meta">
                    <span><i class="bi bi-box-seam me-1"></i>Đơn vị: <strong id="prevUnit">@Model.DefaultUnit</strong></span>
                    <span><i class="bi bi-arrow-down-up me-1"></i>Safety: <strong id="prevStock">@(Model.DefaultMinStock > 0 ? Model.DefaultMinStock.ToString() : "—")</strong></span>
                </div>
            </div>
            <div class="prev-lbl">Cập nhật hình ảnh</div>
            <div style="padding:0 1.1rem 1.1rem">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div style="margin-bottom:.5rem;border-radius:7px;overflow:hidden"><img src="@Model.ImageUrl" style="width:100%;max-height:80px;object-fit:cover" /></div>
                }
                <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
                    <i class="bi bi-cloud-arrow-up"></i>
                    <p>@(string.IsNullOrEmpty(Model.ImageUrl) ? "Click để tải ảnh mới" : "Click để thay ảnh")</p>
                </div>
                <input type="file" id="fileInput" name="CategoryImage" accept="image/*" class="d-none" onchange="onImgSelect(this)" />
                <div id="uploadPreview" style="margin-top:.4rem"></div>
            </div>
        </div>

        <!-- Form -->
        <div class="form-card">
            <div class="form-title">Cập Nhật Danh Mục</div>
            <div class="form-sub">Chỉnh sửa thông tin và cấu hình nghiệp vụ</div>

            <form asp-action="Edit" asp-route-id="@Model.CategoryId" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CategoryId" />
                <input type="hidden" asp-for="BehaviorType" id="BehaviorTypeInput" value="@behavior" />

                <!-- Nghiệp vụ -->
                <div class="sec-div"><i class="bi bi-diagram-3 me-1"></i>Hành vi nghiệp vụ</div>
                <div class="bh-tabs">
                    @foreach (var (val, ico, lbl, desc) in new[]{
                                        ("Retail","🛒","Bán Lẻ","Trừ kho thẳng"),
                                        ("Rental","🔄","Cho Thuê","Hoàn kho khi trả"),
                                        ("Service","🔧","Dịch Vụ","Không kho vật lý")
                                        })
                    {
                        <div class="bh-tab @(behavior == val ? "on-" + val : "")" data-val="@val" onclick="selectBh('@val')">
                            <span class="bh-tab-ico">@ico</span>
                            <div class="bh-tab-lbl">@lbl</div>
                            <div class="bh-tab-desc">@desc</div>
                        </div>
                    }
                </div>

                <!-- Cơ bản -->
                <div class="sec-div"><i class="bi bi-info-circle me-1"></i>Thông tin cơ bản</div>
                <div class="fg">
                    <label>Tên danh mục <span class="req">*</span></label>
                    <input asp-for="CategoryName" id="inputName" class="fi" oninput="document.getElementById('prevName').textContent=this.value||'Tên danh mục'" />
                    <span asp-validation-for="CategoryName" class="hint" style="color:var(--red)"></span>
                </div>
                <div class="two-col">
                    <div class="fg">
                        <label>Đơn vị mặc định</label>
                        <select asp-for="DefaultUnit" id="inputUnit" class="fi" onchange="document.getElementById('prevUnit').textContent=this.value">
                            @foreach (var u in new[] { "Cái", "Bộ", "Đôi", "Hộp", "Thùng", "Kg", "Gram", "Lít", "Chai", "Lon", "Túi", "Chiếc" })
                            {
                                <option value="@u">@u</option>
                            }
                        </select>
                    </div>
                    <div class="fg" style="justify-content:flex-end;padding-bottom:.2rem">
                        <label style="margin-bottom:.4rem">Trạng thái</label>
                        <span class="active-badge @(Model.IsActive ? "on" : "off")" id="activeBadge" onclick="toggleActive()">
                            <i class="bi @(Model.IsActive ? "bi-eye" : "bi-eye-slash")"></i>
                            @(Model.IsActive ? "Đang hoạt động" : "Đã ẩn")
                        </span>
                        <input type="hidden" asp-for="IsActive" id="IsActiveInput" value="@Model.IsActive.ToString().ToLower()" />
                    </div>
                </div>
                <div class="fg">
                    <label>Mô tả</label>
                    <textarea asp-for="Description" class="fi" rows="2"></textarea>
                </div>

                <!-- RETAIL panel -->
                <div class="cond panel-retail @(behavior == "Retail" ? "show" : "")" id="panelRetail">
                    <div class="panel-title"><i class="bi bi-boxes me-1"></i>Quy tắc kho</div>
                    <div class="rule-grid">
                        <label class="rule-toggle @(Model.RequiresExpiry ? "rt-expiry" : "")" id="rtHsd"
                               onclick="toggleRule('RequiresExpiry','rtHsd','rt-expiry')">
                            <input type="checkbox" asp-for="RequiresExpiry" id="RequiresExpiry" />
                            <div class="rt-hd">
                                <div class="rt-lbl" style="color:#dc2626"><i class="bi bi-calendar-x"></i>Theo dõi HSD</div>
                                <div class="tdot"></div>
                            </div>
                            <div class="rt-desc">Kéo theo FIFO tự động</div>
                        </label>
                        <label class="rule-toggle @(Model.HasVariants ? "rt-var" : "")" id="rtVar"
                               onclick="toggleRule('HasVariants','rtVar','rt-var')">
                            <input type="checkbox" asp-for="HasVariants" id="HasVariants" />
                            <div class="rt-hd">
                                <div class="rt-lbl" style="color:#f59e0b"><i class="bi bi-layers"></i>Biến thể</div>
                                <div class="tdot"></div>
                            </div>
                            <div class="rt-desc">Nhiều màu / size</div>
                        </label>
                    </div>
                    <div class="two-col">
                        <div class="fg"><label>Safety Stock</label><input asp-for="DefaultMinStock" type="number" min="0" class="fi" oninput="document.getElementById('prevStock').textContent=this.value||'—'" /></div>
                        <div class="fg"><label>Thứ tự hiển thị</label><input asp-for="DisplayOrder" type="number" min="0" class="fi" /></div>
                    </div>
                </div>

                <!-- RENTAL panel -->
                <div class="cond panel-rental @(behavior == "Rental" ? "show" : "")" id="panelRental">
                    <div class="panel-title"><i class="bi bi-arrow-repeat me-1"></i>Cấu hình cho thuê</div>
                    <div class="rule-grid">
                        <label class="rule-toggle @(Model.AllowPartialReturn ? "rt-part" : "")" id="rtPart"
                               onclick="toggleRule('AllowPartialReturn','rtPart','rt-part')">
                            <input type="checkbox" asp-for="AllowPartialReturn" id="AllowPartialReturn" />
                            <div class="rt-hd">
                                <div class="rt-lbl" style="color:#f59e0b"><i class="bi bi-box-arrow-in-left"></i>Trả từng phần</div>
                                <div class="tdot"></div>
                            </div>
                            <div class="rt-desc">Trả lại từng cái / bộ</div>
                        </label>
                        <label class="rule-toggle @(Model.DepositRequired ? "rt-deposit" : "")" id="rtDep"
                               onclick="toggleRule('DepositRequired','rtDep','rt-deposit');toggleDepAmt()">
                            <input type="checkbox" asp-for="DepositRequired" id="DepositRequired" />
                            <div class="rt-hd">
                                <div class="rt-lbl" style="color:#dc2626"><i class="bi bi-cash-coin"></i>Đặt cọc</div>
                                <div class="tdot"></div>
                            </div>
                            <div class="rt-desc">Yêu cầu tiền đặt cọc</div>
                        </label>
                    </div>
                    <div id="depAmtRow" style="display:@(Model.DepositRequired ? "" : "none")">
                        <div class="fg">
                            <label>Tiền đặt cọc mặc định</label>
                            <div class="money-wrap"><input asp-for="DefaultDepositAmount" type="number" min="0" class="fi" /><span class="money-sfx">₫</span></div>
                        </div>
                    </div>
                    <div class="two-col">
                        <div class="fg"><label>Safety Stock</label><input asp-for="DefaultMinStock" type="number" min="0" class="fi" oninput="document.getElementById('prevStock').textContent=this.value||'—'" /></div>
                        <div class="fg"><label>Thứ tự hiển thị</label><input asp-for="DisplayOrder" type="number" min="0" class="fi" /></div>
                    </div>
                </div>

                <!-- SERVICE panel -->
                <div class="cond panel-service @(behavior == "Service" ? "show" : "")" id="panelService">
                    <div class="panel-title"><i class="bi bi-wrench-adjustable me-1"></i>Dịch vụ</div>
                    <p style="font-size:.8rem;color:var(--muted);margin:0 0 .9rem">Danh mục dịch vụ không quản lý tồn kho. Giá & chi tiết cấu hình tại từng sản phẩm.</p>
                    <div class="two-col">
                        <div class="fg"><label>Thứ tự hiển thị</label><input asp-for="DisplayOrder" type="number" min="0" class="fi" /></div>
                    </div>
                </div>

                <div class="btn-row">
                    <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i> Hủy</a>
                    <button type="submit" class="btn-submit"><i class="bi bi-save"></i> Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const BH_BG ={Retail:'#f0fdf4',Rental:'#eff6ff',Service:'#f5f3ff'};
        const BH_CLR={Retail:'#166534',Rental:'#1d4ed8',Service:'#7c3aed'};
        const BH_ICO={Retail:'bi-cart3',Rental:'bi-arrow-repeat',Service:'bi-wrench-adjustable'};
        const BH_LBL={Retail:'🛒 Bán lẻ',Rental:'🔄 Cho thuê',Service:'🔧 Dịch vụ'};

        function selectBh(val){
            document.getElementById('BehaviorTypeInput').value=val;
            document.querySelectorAll('.bh-tab').forEach(t=>{
                t.classList.remove('on-Retail','on-Rental','on-Service');
                if(t.dataset.val===val) t.classList.add('on-'+val);
            });
            ['Retail','Rental','Service'].forEach(b=>{
                document.getElementById('panel'+b).classList.toggle('show',b===val);
            });
            // Update preview
            document.getElementById('prevVisual').style.background=BH_BG[val];
            ['prevBigIco','prevCtrIco'].forEach(id=>{
                const el=document.getElementById(id); if(!el)return;
                el.className=`bi ${BH_ICO[val]} ${id.includes('Big')?'prev-big-ico':'prev-center-ico'}`;
                el.style.color=BH_CLR[val];
            });
            const pb=document.getElementById('prevBh');
            pb.textContent=BH_LBL[val]; pb.style.background=BH_BG[val]; pb.style.color=BH_CLR[val];
        }

        function toggleRule(cbId,divId,cls){
            const cb=document.getElementById(cbId);
            cb.checked=!cb.checked;
            document.getElementById(divId).classList.toggle(cls,cb.checked);
        }
        function toggleDepAmt(){ document.getElementById('depAmtRow').style.display=document.getElementById('DepositRequired')?.checked?'':'none'; }

        let _isActive=@Model.IsActive.ToString().ToLower();
        function toggleActive(){
            _isActive=!_isActive;
            const b=document.getElementById('activeBadge');
            b.className=`active-badge ${_isActive?'on':'off'}`;
            b.innerHTML=`<i class="bi bi-${_isActive?'eye':'eye-slash'}"></i> ${_isActive?'Đang hoạt động':'Đã ẩn'}`;
            document.getElementById('IsActiveInput').value=_isActive;
        }

        function onImgSelect(input){
            if(!input.files[0])return;
            const url=URL.createObjectURL(input.files[0]);
            document.getElementById('uploadPreview').innerHTML=`<img src="${url}" style="width:100%;max-height:90px;object-fit:cover;border-radius:7px;margin-top:.4rem"/>`;
            document.getElementById('prevVisual').innerHTML=`<img src="${url}" style="width:100%;height:100%;object-fit:cover"/>`;
        }
    </script>
}
