@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Sửa - " + Model.CategoryName;
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@functions {
    string TypeIcon(string t) => t switch { "Food" => "bi-egg-fried", "Beverage" => "bi-cup-straw", "Equipment" => "bi-gear-wide-connected", "Clothing" => "bi-bag-heart", "Accessory" => "bi-watch", _ => "bi-folder2-open" };
    string TypeColor(string t) => t switch { "Food" => "#b45309", "Beverage" => "#0369a1", "Equipment" => "#166534", "Clothing" => "#7e22ce", "Accessory" => "#be185d", _ => "#4b5563" };
    string TypeBg(string t) => t switch { "Food" => "#fffbeb", "Beverage" => "#f0f9ff", "Equipment" => "#f0fdf4", "Clothing" => "#faf5ff", "Accessory" => "#fdf2f8", _ => "#f9fafb" };
    string TypeLabel(string t) => t switch { "Food" => "🍱 Đồ ăn", "Beverage" => "🥤 Thức uống", "Equipment" => "🏸 Dụng cụ", "Clothing" => "👕 Quần áo", "Accessory" => "🧢 Phụ kiện", _ => "📦 Khác" };
    string VisualBg(string t) => t switch { "Food" => "linear-gradient(135deg,#fffbeb,#fef3c7)", "Beverage" => "linear-gradient(135deg,#f0f9ff,#dbeafe)", "Equipment" => "linear-gradient(135deg,#f0fdf4,#dcfce7)", "Clothing" => "linear-gradient(135deg,#faf5ff,#ede9fe)", "Accessory" => "linear-gradient(135deg,#fdf2f8,#fce7f3)", _ => "linear-gradient(135deg,#f9fafb,#f3f4f6)" };
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-hover: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
        --red: #dc2626;
    }

    .page-wrapper {
        background: var(--court-bg);
        min-height: 100vh;
        padding: 2rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--court-dark);
    }

        .page-title span {
            color: var(--court-gold);
            font-style: italic;
        }

    .bc {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .82rem;
        color: var(--court-muted);
        margin-bottom: 1.5rem;
    }

        .bc a {
            color: var(--court-muted);
            text-decoration: none;
        }

            .bc a:hover {
                color: var(--court-dark);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--court-dark);
        font-weight: 700;
    }

    .form-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    @@media(max-width:820px) {
        .form-layout {
            grid-template-columns: 1fr;
        }
    }

    .preview-side {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        overflow: hidden;
        position: sticky;
        top: 1.25rem;
    }

    .prev-visual {
        height: 170px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        transition: background .35s;
    }

        .prev-visual img.bg-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
        }

    .prev-big-icon {
        font-size: 6rem;
        opacity: .12;
        position: absolute;
    }

    .prev-center-icon {
        font-size: 3rem;
        z-index: 1;
        filter: drop-shadow(0 4px 12px rgba(0,0,0,.15));
        transition: all .35s;
    }

    .prev-body {
        padding: 1.1rem 1.2rem;
    }

    .prev-name {
        font-size: 1rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: .3rem;
    }

    .prev-type {
        display: inline-block;
        padding: .2rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        margin-bottom: .75rem;
    }

    .prev-id-row {
        font-size: .75rem;
        color: var(--court-muted);
    }

    .prev-label {
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-muted);
        padding: .6rem 1.2rem .3rem;
        border-top: 1px solid var(--court-border);
    }

    .upload-zone {
        border: 2px dashed var(--court-border);
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        cursor: pointer;
        transition: .2s;
        background: var(--court-bg);
        margin: 0 1.2rem 1.2rem;
    }

        .upload-zone:hover {
            border-color: var(--court-gold);
            background: #faf8f0;
        }

        .upload-zone i {
            font-size: 1.4rem;
            color: var(--court-muted);
            display: block;
            margin-bottom: .3rem;
        }

        .upload-zone p {
            font-size: .74rem;
            color: var(--court-muted);
            margin: 0;
        }

    .upload-preview {
        margin-top: .5rem;
        border-radius: 8px;
        overflow: hidden;
    }

        .upload-preview img {
            width: 100%;
            max-height: 100px;
            object-fit: cover;
        }

    .form-card {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        padding: 1.75rem;
    }

    .form-card-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: .2rem;
    }

    .form-card-sub {
        font-size: .83rem;
        color: var(--court-muted);
        margin-bottom: 1.5rem;
    }

    .section-div {
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-dark);
        display: inline-block;
        padding-bottom: .4rem;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: .9rem;
    }

    .fl {
        margin-bottom: .9rem;
    }

        .fl label {
            display: block;
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--court-muted);
            margin-bottom: 5px;
        }

    .fc {
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        background: var(--court-bg);
        color: var(--court-text);
        font-size: .875rem;
        padding: .5rem .75rem;
        width: 100%;
        transition: all .2s;
    }

        .fc:focus {
            outline: none;
            border-color: var(--court-gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(232,200,64,.2);
        }

    textarea.fc {
        resize: vertical;
        min-height: 80px;
    }

    .req {
        color: var(--red);
    }

    .err-msg {
        display: block;
        font-size: .76rem;
        color: var(--red);
        margin-top: 3px;
    }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    @@media(max-width:600px) {
        .two-col {
            grid-template-columns: 1fr;
        }
    }

    .rule-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: .7rem;
        margin-bottom: 1rem;
    }

    @@media(max-width:600px) {
        .rule-grid {
            grid-template-columns: 1fr;
        }
    }

    .rule-toggle {
        border: 1.5px solid var(--court-border);
        border-radius: 10px;
        padding: .75rem .9rem;
        cursor: pointer;
        transition: all .2s;
        background: var(--court-bg);
        display: block;
        position: relative;
    }

        .rule-toggle input[type="checkbox"] {
            display: none;
        }

        .rule-toggle:hover {
            border-color: var(--court-gold);
            background: #faf8f0;
        }

    .rt-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .25rem;
    }

    .rt-ico-label {
        font-size: .83rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .rt-desc {
        font-size: .72rem;
        color: var(--court-muted);
    }

    .toggle-dot {
        width: 32px;
        height: 18px;
        border-radius: 20px;
        background: #d1d5db;
        position: relative;
        transition: background .2s;
        flex-shrink: 0;
    }

        .toggle-dot::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #fff;
            transition: transform .2s;
        }

    .active-hsd {
        background: #fef2f2;
        border-color: #fca5a5;
    }

        .active-hsd .toggle-dot {
            background: #ef4444;
        }

            .active-hsd .toggle-dot::after {
                transform: translateX(14px);
            }

    .active-fifo {
        background: #eff6ff;
        border-color: #93c5fd;
    }

        .active-fifo .toggle-dot {
            background: #3b82f6;
        }

            .active-fifo .toggle-dot::after {
                transform: translateX(14px);
            }

    .active-lot {
        background: #f9fafb;
        border-color: #d1d5db;
    }

        .active-lot .toggle-dot {
            background: #6b7280;
        }

            .active-lot .toggle-dot::after {
                transform: translateX(14px);
            }

    .active-var {
        background: #fffbeb;
        border-color: #fcd34d;
    }

        .active-var .toggle-dot {
            background: #f59e0b;
        }

            .active-var .toggle-dot::after {
                transform: translateX(14px);
            }

    /* Changed indicator */
    .rule-toggle.changed::before {
        content: '';
        position: absolute;
        top: 8px;
        right: 8px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--court-gold);
    }

    .btn-row {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--court-border);
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1.4rem;
        background: var(--court-bg);
        color: var(--court-text);
        border: 1.5px solid var(--court-border);
        border-radius: 10px;
        font-weight: 600;
        font-size: .875rem;
        text-decoration: none;
        cursor: pointer;
        transition: .18s;
    }

        .btn-cancel:hover {
            background: #ede8de;
            color: var(--court-text);
        }

    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1.75rem;
        background: var(--court-gold);
        color: var(--court-dark);
        border: none;
        border-radius: 10px;
        font-weight: 800;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
    }

        .btn-submit:hover {
            background: var(--court-gold-hover);
            box-shadow: 0 4px 12px rgba(232,200,64,.4);
        }

    .link-detail {
        font-size: .82rem;
        font-weight: 700;
        color: var(--court-muted);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .link-detail:hover {
            color: var(--court-dark);
        }
</style>

<div class="page-wrapper">

    <nav class="bc">
        <a asp-action="Index"><i class="bi bi-collection me-1"></i>Danh Mục</a>
        <span class="bc-sep">›</span>
        <a asp-action="Details" asp-route-id="@Model.CategoryId">@Model.CategoryName</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">Chỉnh sửa</span>
    </nav>

    <h1 class="page-title mb-4">Cập Nhật <span>Danh Mục</span></h1>

    <div class="form-layout">

        <!-- Preview Sidebar -->
        <div class="preview-side">
            <div class="prev-visual" id="prevVisual" style="background:@VisualBg(Model.CategoryType);">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img class="bg-img" id="prevBgImg" src="@Model.ImageUrl" alt="@Model.CategoryName" />
                }
                else
                {
                    <i class="bi @TypeIcon(Model.CategoryType) prev-big-icon" id="prevBigIcon" style="color:@TypeColor(Model.CategoryType);"></i>
                    <i class="bi @TypeIcon(Model.CategoryType) prev-center-icon" id="prevCenterIcon" style="color:@TypeColor(Model.CategoryType);"></i>
                }
            </div>
            <div class="prev-body">
                <div class="prev-name" id="prevName">@Model.CategoryName</div>
                <span class="prev-type" id="prevType" style="background:@TypeBg(Model.CategoryType);color:@TypeColor(Model.CategoryType);">
                    @TypeLabel(Model.CategoryType)
                </span>
                <div class="prev-id-row">ID #@Model.CategoryId · Đơn vị: <strong>@(Model.DefaultUnit ?? "—")</strong></div>
            </div>
            <div class="prev-label">Cập nhật hình ảnh</div>
            <div style="padding:0 1.2rem 1.2rem;">
                <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
                    <i class="bi bi-cloud-arrow-up"></i>
                    <p>Click để thay đổi ảnh</p>
                </div>
                <input type="file" id="fileInput" name="CategoryImage" accept="image/*" class="d-none" onchange="onImageSelect(this)" />
                <div id="uploadPreview" class="upload-preview"></div>
            </div>
        </div>

        <!-- Form -->
        <div class="form-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <div class="form-card-title">Cập Nhật Danh Mục</div>
                    <div class="form-card-sub" style="margin-bottom:0;">Chỉnh sửa thông tin danh mục</div>
                </div>
                <a asp-action="Details" asp-route-id="@Model.CategoryId" class="link-detail">
                    <i class="bi bi-eye"></i> Xem chi tiết
                </a>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CategoryId" />
                <input type="hidden" asp-for="ImageUrl" />

                <!-- Thông tin cơ bản -->
                <div class="section-div"><i class="bi bi-info-circle me-1"></i>Thông Tin Cơ Bản</div>

                <div class="fl">
                    <label>Tên danh mục <span class="req">*</span></label>
                    <input asp-for="CategoryName" id="inputName" class="fc" />
                    <span asp-validation-for="CategoryName" class="err-msg"></span>
                </div>

                <div class="two-col">
                    <div class="fl">
                        <label>Loại danh mục <span class="req">*</span></label>
                        <select asp-for="CategoryType" id="inputType" class="fc">
                            <option value="Food">🍱 Đồ ăn</option>
                            <option value="Beverage">🥤 Thức uống</option>
                            <option value="Clothing">👕 Quần áo</option>
                            <option value="Equipment">🏸 Dụng cụ thể thao</option>
                            <option value="Accessory">🧢 Phụ kiện</option>
                            <option value="Other">📦 Khác</option>
                        </select>
                    </div>
                    <div class="fl">
                        <label>Đơn vị mặc định</label>
                        <select asp-for="DefaultUnit" class="fc">
                            <option value="Cái">Cái</option>
                            <option value="Bộ">Bộ</option>
                            <option value="Hộp">Hộp</option>
                            <option value="Thùng">Thùng</option>
                            <option value="Kg">Kg</option>
                            <option value="Gram">Gram</option>
                            <option value="Lít">Lít</option>
                            <option value="Chai">Chai</option>
                            <option value="Lon">Lon</option>
                            <option value="Túi">Túi</option>
                            <option value="Đôi">Đôi</option>
                            <option value="Chiếc">Chiếc</option>
                        </select>
                    </div>
                </div>

                <div class="fl">
                    <label>Mô tả</label>
                    <textarea asp-for="Description" class="fc"></textarea>
                </div>

                <!-- Quy tắc kho -->
                <div class="section-div mt-3"><i class="bi bi-sliders2 me-1"></i>Quy Tắc Quản Lý Kho</div>

                <div class="rule-grid">
                    <label class="rule-toggle @(Model.RequiresExpiry ? "active-hsd" : "")" id="rtHsd" onclick="toggleRule('RequiresExpiry','rtHsd','active-hsd')">
                        <input type="checkbox" asp-for="RequiresExpiry" id="RequiresExpiry" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#dc2626;"><i class="bi bi-calendar-x"></i> Theo dõi HSD</div>
                            <div class="toggle-dot"></div>
                        </div>
                        <div class="rt-desc">Đồ ăn, đồ uống có hạn sử dụng</div>
                    </label>

                    <label class="rule-toggle @(Model.UseFIFO ? "active-fifo" : "")" id="rtFifo" onclick="toggleRule('UseFIFO','rtFifo','active-fifo')">
                        <input type="checkbox" asp-for="UseFIFO" id="UseFIFO" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#3b82f6;"><i class="bi bi-arrow-left-right"></i> FIFO</div>
                            <div class="toggle-dot"></div>
                        </div>
                        <div class="rt-desc">Nhập trước – Xuất trước</div>
                    </label>

                    <label class="rule-toggle @(Model.RequiresBatch ? "active-lot" : "")" id="rtLot" onclick="toggleRule('RequiresBatch','rtLot','active-lot')">
                        <input type="checkbox" asp-for="RequiresBatch" id="RequiresBatch" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#6b7280;"><i class="bi bi-upc"></i> Theo lô</div>
                            <div class="toggle-dot"></div>
                        </div>
                        <div class="rt-desc">Truy xuất nguồn gốc Batch/Lot</div>
                    </label>

                    <label class="rule-toggle @(Model.HasVariants ? "active-var" : "")" id="rtVar" onclick="toggleRule('HasVariants','rtVar','active-var')">
                        <input type="checkbox" asp-for="HasVariants" id="HasVariants" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#f59e0b;"><i class="bi bi-layers"></i> Biến thể</div>
                            <div class="toggle-dot"></div>
                        </div>
                        <div class="rt-desc">Nhiều màu/size (quần áo, giày)</div>
                    </label>
                </div>

                <!-- Cấu hình -->
                <div class="section-div mt-3"><i class="bi bi-gear me-1"></i>Cấu Hình</div>

                <div class="two-col">
                    <div class="fl">
                        <label>Safety Stock mặc định</label>
                        <input asp-for="DefaultMinStock" type="number" min="0" class="fc" />
                    </div>
                    <div class="fl">
                        <label>Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" min="0" class="fc" />
                    </div>
                </div>

                <div class="btn-row">
                    <a asp-action="Details" asp-route-id="@Model.CategoryId" class="btn-cancel">
                        <i class="bi bi-x-lg"></i> Hủy thay đổi
                    </a>
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-cloud-arrow-up-fill"></i> Lưu Thay Đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const ICONS  = { Food:'bi-egg-fried',Beverage:'bi-cup-straw',Equipment:'bi-gear-wide-connected',Clothing:'bi-bag-heart',Accessory:'bi-watch',Other:'bi-folder2-open' };
        const COLORS = { Food:'#b45309',Beverage:'#0369a1',Equipment:'#166534',Clothing:'#7e22ce',Accessory:'#be185d',Other:'#4b5563' };
        const BGS    = { Food:'linear-gradient(135deg,#fffbeb,#fef3c7)',Beverage:'linear-gradient(135deg,#f0f9ff,#dbeafe)',Equipment:'linear-gradient(135deg,#f0fdf4,#dcfce7)',Clothing:'linear-gradient(135deg,#faf5ff,#ede9fe)',Accessory:'linear-gradient(135deg,#fdf2f8,#fce7f3)',Other:'linear-gradient(135deg,#f9fafb,#f3f4f6)' };
        const LABELS = { Food:'🍱 Đồ ăn',Beverage:'🥤 Thức uống',Equipment:'🏸 Dụng cụ',Clothing:'👕 Quần áo',Accessory:'🧢 Phụ kiện',Other:'📦 Khác' };
        const TC_BG  = { Food:'#fffbeb',Beverage:'#e0f2fe',Equipment:'#f0fdf4',Clothing:'#faf5ff',Accessory:'#fdf2f8',Other:'#f9fafb' };

        const ORIG = {
            RequiresExpiry: document.getElementById('RequiresExpiry').checked,
            UseFIFO:        document.getElementById('UseFIFO').checked,
            RequiresBatch:  document.getElementById('RequiresBatch').checked,
            HasVariants:    document.getElementById('HasVariants').checked
        };

        document.getElementById('inputName').addEventListener('input', e => {
            document.getElementById('prevName').textContent = e.target.value || '@Model.CategoryName';
        });

        document.getElementById('inputType').addEventListener('change', function () {
            const v = this.value;
            document.getElementById('prevVisual').style.background = BGS[v] || BGS['Other'];
            ['prevBigIcon', 'prevCenterIcon'].forEach(id => {
                const el = document.getElementById(id);
                if (el) { el.className = `bi ${ICONS[v] || 'bi-folder2-open'} ${id.includes('Big') ? 'prev-big-icon' : 'prev-center-icon'}`; el.style.color = COLORS[v] || '#6b7280'; }
            });
            const bi = document.getElementById('prevBgImg');
            if (bi) bi.style.opacity = '.3';
            const pt = document.getElementById('prevType');
            pt.textContent = LABELS[v] || v;
            pt.style.background = TC_BG[v] || '#f3f4f6';
            pt.style.color = COLORS[v] || '#6b7280';
        });

        function toggleRule(cbId, divId, cls) {
            const cb  = document.getElementById(cbId);
            const div = document.getElementById(divId);
            cb.checked = !cb.checked;
            if (cb.checked) div.classList.add(cls); else div.classList.remove(cls);
            if (cb.checked !== ORIG[cbId]) div.classList.add('changed');
            else div.classList.remove('changed');
        }

        function onImageSelect(input) {
            if (!input.files[0]) return;
            const url = URL.createObjectURL(input.files[0]);
            document.getElementById('uploadPreview').innerHTML = `<img src="${url}" />`;
            const vis = document.getElementById('prevVisual');
            let bi = document.getElementById('prevBgImg');
            if (bi) bi.src = url;
            else {
                const img = document.createElement('img');
                img.src = url; img.id = 'prevBgImg'; img.className = 'bg-img';
                vis.insertBefore(img, vis.firstChild);
            }
        }
    </script>
}
