@model IEnumerable<QuanLiSanCauLong.Models.ProductCategory>
@{
    ViewData["Title"] = "Quản lý Danh Mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@functions {
    string TypeIcon(string t) => t switch
    {
        "Food" => "bi-egg-fried",
        "Beverage" => "bi-cup-straw",
        "Equipment" => "bi-gear-wide-connected",
        "Clothing" => "bi-bag-heart",
        "Accessory" => "bi-watch",
        _ => "bi-folder2-open"
    };
    string TypeLabel(string t) => t switch
    {
        "Food" => "🍱 Đồ ăn",
        "Beverage" => "🥤 Thức uống",
        "Equipment" => "🏸 Dụng cụ",
        "Clothing" => "👕 Quần áo",
        "Accessory" => "🧢 Phụ kiện",
        _ => "📦 Khác"
    };
    string TypeColor(string t) => t switch
    {
        "Food" => "#b45309",
        "Beverage" => "#0369a1",
        "Equipment" => "#166534",
        "Clothing" => "#7e22ce",
        "Accessory" => "#be185d",
        _ => "#4b5563"
    };
    string TypeBg(string t) => t switch
    {
        "Food" => "#fffbeb",
        "Beverage" => "#f0f9ff",
        "Equipment" => "#f0fdf4",
        "Clothing" => "#faf5ff",
        "Accessory" => "#fdf2f8",
        _ => "#f9fafb"
    };
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-hover: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
    }

    .page-wrapper {
        background: var(--court-bg);
        min-height: 100vh;
        padding: 2rem;
    }

    /* Header */
    .page-title {
        font-size: 2rem;
        font-weight: 800;
        color: var(--court-dark);
        letter-spacing: -.5px;
    }

        .page-title span {
            color: var(--court-gold);
            font-style: italic;
        }

    .btn-add-new {
        background: var(--court-gold);
        color: var(--court-dark);
        border: none;
        font-weight: 700;
        padding: .65rem 1.5rem;
        border-radius: 10px;
        font-size: .9rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        transition: all .2s;
        white-space: nowrap;
    }

        .btn-add-new:hover {
            background: var(--court-gold-hover);
            color: var(--court-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(232,200,64,.4);
        }

    /* Stats */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--court-dark);
        line-height: 1;
    }

    .stat-label {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--court-muted);
        margin-top: 4px;
    }

    .stat-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 4px;
    }

    /* Toolbar */
    .toolbar {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        gap: .75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 340px;
    }

        .search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--court-muted);
            font-size: .9rem;
        }

        .search-wrap input {
            padding-left: 36px;
            border: 1.5px solid var(--court-border);
            border-radius: 8px;
            background: var(--court-bg);
            color: var(--court-text);
            height: 40px;
            width: 100%;
            font-size: .875rem;
        }

            .search-wrap input:focus {
                outline: none;
                border-color: var(--court-gold);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(232,200,64,.15);
            }

    .filter-sel {
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        background: var(--court-bg);
        color: var(--court-text);
        height: 40px;
        padding: 0 .75rem;
        font-size: .875rem;
        cursor: pointer;
    }

        .filter-sel:focus {
            outline: none;
            border-color: var(--court-gold);
            box-shadow: 0 0 0 3px rgba(232,200,64,.15);
        }

    .filter-count {
        font-size: .8rem;
        color: var(--court-muted);
        margin-left: .25rem;
        white-space: nowrap;
    }

    /* Category Grid */
    .cat-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1.2rem;
    }

    .cat-card {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        overflow: hidden;
        transition: all .25s;
        display: flex;
        flex-direction: column;
    }

        .cat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(26,26,46,.12);
            border-color: var(--court-gold);
        }

    /* Card visual area */
    .cat-visual {
        height: 110px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .cat-visual .big-ico {
            font-size: 5.5rem;
            opacity: .12;
            position: absolute;
        }

        .cat-visual .center-ico {
            font-size: 2.8rem;
            z-index: 1;
            filter: drop-shadow(0 3px 8px rgba(0,0,0,.15));
        }

        .cat-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Card body */
    .cat-body {
        padding: 1rem 1.1rem;
        flex: 1;
    }

    .cat-name {
        font-size: 1rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: .4rem;
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .7rem;
        font-weight: 700;
        margin-bottom: .6rem;
        border: 1px solid rgba(0,0,0,.08);
    }

    /* Rule chips */
    .rule-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        margin-bottom: .75rem;
    }

    .rule-chip {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
    }

    .rc-hsd {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fca5a5;
    }

    .rc-fifo {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #93c5fd;
    }

    .rc-lot {
        background: #f9fafb;
        color: #374151;
        border: 1px solid #d1d5db;
    }

    .rc-var {
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fcd34d;
    }

    /* Mini stats */
    .cat-stats {
        display: flex;
        gap: 1rem;
    }

    .cs-item {
        text-align: center;
    }

    .cs-val {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--court-dark);
        line-height: 1;
    }

    .cs-lbl {
        font-size: .65rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--court-muted);
        margin-top: 2px;
    }

    /* Card footer */
    .cat-foot {
        display: flex;
        border-top: 1px solid var(--court-border);
        background: #faf8f4;
    }

    .cf-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding: .55rem 0;
        font-size: .75rem;
        font-weight: 700;
        color: var(--court-muted);
        text-decoration: none;
        cursor: pointer;
        background: none;
        border: none;
        border-right: 1px solid var(--court-border);
        transition: all .18s;
    }

        .cf-btn:last-child {
            border-right: none;
        }

        .cf-btn:hover {
            background: var(--court-dark);
            color: #fff;
        }

        .cf-btn.danger:hover {
            background: #dc2626;
            color: #fff;
        }

    /* Empty */
    .empty-wrap {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--court-muted);
        grid-column: 1/-1;
    }

        .empty-wrap i {
            font-size: 4rem;
            opacity: .2;
            display: block;
            margin-bottom: 1rem;
        }

    /* Toast */
    .toast-wrap {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        z-index: 9999;
    }

    .toast-msg {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .7rem 1.1rem;
        border-radius: 10px;
        font-size: .85rem;
        font-weight: 600;
        box-shadow: 0 4px 16px rgba(0,0,0,.12);
        animation: slideIn .3s ease;
    }

    .toast-ok {
        background: var(--court-dark);
        color: #fff;
    }

    .toast-err {
        background: #dc2626;
        color: #fff;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@media(max-width:900px) {
        .stats-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .cat-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:600px) {
        .cat-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-wrapper">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="page-title mb-1">Quản Lý <span>Danh Mục</span></h1>
            <p class="mb-0" style="color:var(--court-muted);font-size:.9rem;">Phân loại và tổ chức sản phẩm · <strong>@Model.Count()</strong> danh mục</p>
        </div>
        <a asp-action="Create" class="btn-add-new">
            <i class="bi bi-plus-circle-fill"></i> Thêm Danh Mục
        </a>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label"><span class="stat-dot" style="background:#1a1a2e;"></span>Tổng Danh Mục</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#166534;">@Model.Sum(c => c.Products?.Count ?? 0)</div>
            <div class="stat-label"><span class="stat-dot" style="background:#22c55e;"></span>Tổng Sản Phẩm</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#b45309;">@Model.Count(c => c.CategoryType == "Food" || c.CategoryType == "Beverage")</div>
            <div class="stat-label"><span class="stat-dot" style="background:#f59e0b;"></span>Ẩm Thực</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#1d4ed8;">@Model.Count(c => c.CategoryType != "Food" && c.CategoryType != "Beverage")</div>
            <div class="stat-label"><span class="stat-dot" style="background:#60a5fa;"></span>Hàng Hoá</div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Tìm tên danh mục..." oninput="applyFilter()" />
        </div>
        <select id="filterType" class="filter-sel" onchange="applyFilter()">
            <option value="">Tất cả loại</option>
            <option value="Food">🍱 Đồ ăn</option>
            <option value="Beverage">🥤 Thức uống</option>
            <option value="Clothing">👕 Quần áo</option>
            <option value="Equipment">🏸 Dụng cụ</option>
            <option value="Accessory">🧢 Phụ kiện</option>
            <option value="Other">📦 Khác</option>
        </select>
        <span class="filter-count" id="filterCount">@Model.Count() danh mục</span>
    </div>

    <!-- Grid -->
    <div class="cat-grid" id="categoryGrid">
        @if (Model != null && Model.Any())
        {
            foreach (var cat in Model)
            {
                var productCount = cat.Products?.Count ?? 0;
                var activeCount = cat.Products?.Count(p => p.Status == "Active") ?? 0;
                var lowCount = cat.Products?.Count(p => p.StockQuantity <= p.MinStockLevel) ?? 0;
                var iconClass = TypeIcon(cat.CategoryType);
                var typeColor = TypeColor(cat.CategoryType);
                var typeBg = TypeBg(cat.CategoryType);
                var visualBg = $"linear-gradient(135deg, {typeBg}, {typeBg}dd)";

                <div class="category-col" data-name="@cat.CategoryName?.ToLower()" data-type="@cat.CategoryType">
                    <div class="cat-card">

                        <!-- Visual -->
                        <div class="cat-visual" style="background:@visualBg;">
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@cat.ImageUrl" alt="@cat.CategoryName" onerror="this.src='/images/no-image.png'" />
                            }
                            else
                            {
                                <i class="bi @iconClass big-ico" style="color:@typeColor;"></i>
                                <i class="bi @iconClass center-ico" style="color:@typeColor;"></i>
                            }
                        </div>

                        <!-- Body -->
                        <div class="cat-body">
                            <div class="cat-name">@cat.CategoryName</div>

                            <span class="type-badge" style="background:@typeBg;color:@typeColor;">
                                @TypeLabel(cat.CategoryType)
                            </span>

                            <div class="rule-chips">
                                @if (cat.RequiresExpiry)
                                {
                                    <span class="rule-chip rc-hsd"><i class="bi bi-calendar-x"></i>HSD</span>
                                }
                                @if (cat.UseFIFO)
                                {
                                    <span class="rule-chip rc-fifo"><i class="bi bi-arrow-left-right"></i>FIFO</span>
                                }
                                @if (cat.RequiresBatch)
                                {
                                    <span class="rule-chip rc-lot"><i class="bi bi-upc"></i>Lô</span>
                                }
                                @if (cat.HasVariants)
                                {
                                    <span class="rule-chip rc-var"><i class="bi bi-layers"></i>Biến thể</span>
                                }
                            </div>

                            <div class="cat-stats">
                                <div class="cs-item">
                                    <div class="cs-val">@productCount</div>
                                    <div class="cs-lbl">Sản phẩm</div>
                                </div>
                                <div class="cs-item">
                                    <div class="cs-val" style="color:#166534;">@activeCount</div>
                                    <div class="cs-lbl">Đang bán</div>
                                </div>
                                @if (lowCount > 0)
                                {
                                    <div class="cs-item">
                                        <div class="cs-val" style="color:#dc2626;">@lowCount</div>
                                        <div class="cs-lbl">Tồn thấp</div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="cat-foot">
                            <a asp-action="Details" asp-route-id="@cat.CategoryId" class="cf-btn">
                                <i class="bi bi-eye"></i> Xem
                            </a>
                            <a asp-action="Edit" asp-route-id="@cat.CategoryId" class="cf-btn">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <a href="/Admin/AdminProduct?categoryId=@cat.CategoryId" class="cf-btn">
                                <i class="bi bi-box-seam"></i> SP
                            </a>
                            <button onclick="deleteCategory(@cat.CategoryId, '@cat.CategoryName')" class="cf-btn danger">
                                <i class="bi bi-trash3"></i> Xóa
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-wrap">
                <i class="bi bi-collection"></i>
                <h5 style="font-weight:800;color:var(--court-dark);">Chưa có danh mục nào</h5>
                <p>Thêm danh mục đầu tiên để bắt đầu phân loại sản phẩm</p>
                <a asp-action="Create" class="btn-add-new mt-3"><i class="bi bi-plus-circle-fill"></i> Thêm ngay</a>
            </div>
        }
    </div>
</div>

<div class="toast-wrap" id="toastWrap"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function applyFilter() {
            const q = document.getElementById('searchInput').value.toLowerCase();
            const t = document.getElementById('filterType').value;
            let cnt = 0;
            document.querySelectorAll('.category-col').forEach(col => {
                const ok = (!q || col.dataset.name.includes(q)) && (!t || col.dataset.type === t);
                col.style.display = ok ? '' : 'none';
                if (ok) cnt++;
            });
            document.getElementById('filterCount').textContent = `${cnt} danh mục`;
        }

        function deleteCategory(id, name) {
            Swal.fire({
                title: 'Xóa danh mục?',
                html: `Bạn đang chuẩn bị xóa <b>${name}</b>.<br>Hành động này không thể hoàn tác.`,
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#dc2626', cancelButtonColor: '#1a1a2e',
                confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy bỏ'
            }).then(r => {
                if (!r.isConfirmed) return;
                fetch(`/Admin/AdminCategory/Delete/${id}`, { method: 'POST' })
                    .then(r => r.json())
                    .then(d => {
                        if (d.success) { showToast(d.message, 'ok'); setTimeout(() => location.reload(), 900); }
                        else Swal.fire('Không thể xóa!', d.message, 'error');
                    });
            });
        }

        function showToast(msg, type = 'ok') {
            const el = document.createElement('div');
            el.className = `toast-msg toast-${type}`;
            el.innerHTML = `<i class="bi bi-${type === 'ok' ? 'check-circle-fill' : 'exclamation-circle-fill'}"></i> ${msg}`;
            document.getElementById('toastWrap').appendChild(el);
            setTimeout(() => el.remove(), 3000);
        }
    </script>
}
