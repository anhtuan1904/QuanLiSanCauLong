@model IEnumerable<QuanLiSanCauLong.Models.ProductCategory>
@{
    ViewData["Title"] = "Danh mục sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<link rel="stylesheet" href="~/css/admin-modal.css" />
<style>
    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }
    /* header */
    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            color: var(--gold);
            font-style: italic;
        }

    .pg-sub {
        font-size: .8rem;
        color: var(--muted);
        margin-top: .15rem;
    }
    /* stat strip */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .ss-box {
        background: #fff;
        padding: .85rem 1.2rem;
    }

    .ss-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .ss-l {
        font-size: .62rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .22rem;
    }
    /* table card */
    .tbl-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .tbl-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.1rem;
        border-bottom: 1px solid var(--border);
        gap: .6rem;
        flex-wrap: wrap;
    }

    .srch-wrap {
        position: relative;
    }

        .srch-wrap i {
            position: absolute;
            left: .7rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

    .srch {
        padding: .52rem 1rem .52rem 2.1rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: .82rem;
        width: 220px;
        outline: none;
        background: #fff;
    }

        .srch:focus {
            border-color: var(--gold);
        }

    .stat-chip {
        font-size: .72rem;
        color: var(--muted);
    }

        .stat-chip b {
            color: var(--deep);
        }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        padding: .65rem 1rem;
        text-align: left;
        font-size: .64rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--muted);
        background: #231a0e;
        color: var(--gold);
        border-bottom: 1px solid var(--border);
    }

    td {
        padding: .78rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: .82rem;
        color: var(--deep);
        vertical-align: middle;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tr:hover td {
        background: #fffbf2;
    }
    /* badges */
    .bh-tag {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .62rem;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
    }

    .bh-retail {
        background: #f0fdf4;
        color: #166534;
    }

    .bh-rental {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .bh-service {
        background: #f5f3ff;
        color: #7c3aed;
    }
    /* switch */
    .switch {
        position: relative;
        display: inline-block;
        width: 38px;
        height: 22px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        inset: 0;
        background: #d1d5db;
        border-radius: 22px;
        cursor: pointer;
        transition: .25s;
    }

        .slider::before {
            content: '';
            position: absolute;
            height: 16px;
            width: 16px;
            left: 3px;
            top: 3px;
            background: #fff;
            border-radius: 50%;
            transition: .25s;
        }

    input:checked + .slider {
        background: var(--gold);
    }

        input:checked + .slider::before {
            transform: translateX(16px);
        }
    /* action btns */
    .act-btn {
        background: none;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        padding: .3rem .62rem;
        cursor: pointer;
        font-size: .78rem;
        color: var(--muted);
        transition: all .15s;
    }

        .act-btn:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

        .act-btn.del:hover {
            border-color: var(--red);
            color: var(--red);
        }
    /* empty */
    .empty-td {
        text-align: center;
        padding: 3.5rem;
        color: var(--muted);
        font-size: .88rem;
    }

        .empty-td i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: .75rem;
            opacity: .2;
        }
    /* alert */
    .sys-alert {
        padding: .85rem 1.2rem;
        border-radius: 8px;
        margin-bottom: 1.2rem;
        font-size: .83rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .sys-alert.ok {
            background: rgba(22,163,74,.08);
            border: 1px solid rgba(22,163,74,.25);
            color: #15803d;
        }

        .sys-alert.err {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.25);
            color: #c94b2a;
        }
    /* cat image thumbnail */
    .cat-thumb {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        object-fit: cover;
        border: 1px solid var(--border);
        flex-shrink: 0;
    }

    .cat-thumb-ph {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        background: var(--warm);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    @@media(max-width:600px) {
        .stat-strip {
            grid-template-columns: 1fr 1fr;
        }

        .srch {
            width: 160px;
        }
    }
</style>

<div class="pg">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert ok"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert err"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]</div>
    }

    <div class="pg-hd">
        <div>
            <div class="pg-title">Danh mục <em>sản phẩm</em></div>
            <div class="pg-sub">Quản lý phân loại hàng hóa — @Model.Count() danh mục</div>
        </div>
        <button class="btn-submit" onclick="openCreate()">
            <i class="bi bi-plus-lg"></i> Thêm danh mục
        </button>
    </div>

    <div class="stat-strip">
        <div class="ss-box">
            <div class="ss-n">@Model.Count()</div>
            <div class="ss-l">Tổng danh mục</div>
        </div>
        <div class="ss-box">
            <div class="ss-n" style="color:#15803d">@Model.Count(c => c.IsActive)</div>
            <div class="ss-l">Đang kích hoạt</div>
        </div>
        <div class="ss-box">
            <div class="ss-n" style="color:var(--gold)">@Model.Sum(c => c.Products?.Count ?? 0)</div>
            <div class="ss-l">Tổng sản phẩm</div>
        </div>
    </div>

    <div class="tbl-card">
        <div class="tbl-top">
            <div class="srch-wrap">
                <i class="bi bi-search"></i>
                <input class="srch" id="srch" placeholder="Tìm danh mục..." oninput="filterTable()" />
            </div>
            <span class="stat-chip" id="rowCnt"><b>@Model.Count()</b> danh mục</span>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Danh mục</th>
                    <th>Nghiệp vụ</th>
                    <th>Sản phẩm</th>
                    <th>Đơn vị</th>
                    <th style="text-align:center">Kích hoạt</th>
                    <th style="text-align:right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="catTbody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="empty-td">
                            <i class="bi bi-inbox"></i>
                            Chưa có danh mục nào<br />
                            <button class="btn-submit" style="margin-top:.75rem;font-size:.78rem" onclick="openCreate()">
                                <i class="bi bi-plus-lg"></i> Thêm danh mục đầu tiên
                            </button>
                        </td>
                    </tr>
                }
                @foreach (var cat in Model)
                {
                    var bhClass = cat.BehaviorType switch { "Rental" => "bh-rental", "Service" => "bh-service", _ => "bh-retail" };
                    var bhLabel = cat.BehaviorType switch { "Rental" => "Cho thuê", "Service" => "Dịch vụ", _ => "Bán lẻ" };
                    var bhIcon = cat.BehaviorType switch { "Rental" => "bi-arrow-repeat", "Service" => "bi-wrench-adjustable", _ => "bi-cart3" };
                    <tr data-name="@cat.CategoryName.ToLower()">
                        <td>
                            <div style="display:flex;align-items:center;gap:.7rem">
                                @if (!string.IsNullOrEmpty(cat.ImageUrl))
                                {
                                    <img src="@cat.ImageUrl" class="cat-thumb" alt="" />
                                }
                                else
                                {

                                    <div class="cat-thumb-ph"><i class="bi @bhIcon" style="color:var(--muted);font-size:.8rem"></i></div>
                                }
                                <div>
                                    <div style="font-weight:600">@cat.CategoryName</div>
                                    @if (!string.IsNullOrEmpty(cat.Description))
                                    {
                                        <div style="font-size:.7rem;color:var(--muted);max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@cat.Description</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td><span class="bh-tag @bhClass"><i class="bi @bhIcon"></i> @bhLabel</span></td>
                        <td><span class="stat-chip"><b>@(cat.Products?.Count ?? 0)</b> SP</span></td>
                        <td style="color:var(--muted);font-size:.8rem">@cat.DefaultUnit</td>
                        <td style="text-align:center">
                            <label class="switch" title="@(cat.IsActive ? "Đang kích hoạt" : "Đang ẩn")">
                                <input type="checkbox" @(cat.IsActive ? "checked" : "") onchange="toggleActive(@cat.CategoryId,this)" />
                                <span class="slider"></span>
                            </label>
                        </td>
                        <td style="text-align:right">
                            <button class="act-btn" onclick="openEdit(@cat.CategoryId)" title="Chỉnh sửa">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="act-btn del" onclick="confirmDelete(@cat.CategoryId,'@Html.Raw(cat.CategoryName.Replace("'", "\\'"))')" title="Xóa">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Bootstrap Modal shell *@
<div class="modal fade" id="catModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:600px">
        <div class="modal-content" id="catModalBody" style="border-radius:16px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.18)">
            <div class="p-5 text-center">
                <div class="spinner-border" style="color:var(--gold)"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        let catModal;
        document.addEventListener('DOMContentLoaded', () => {
            catModal = new bootstrap.Modal(document.getElementById('catModal'));
        });

        function runScripts(el) {
            el.querySelectorAll('script').forEach(s => {
                const n = document.createElement('script'); n.text = s.text; s.replaceWith(n);
            });
        }

        function openCreate() { loadModal('/Admin/AdminCategory/CreatePartial'); }
        function openEdit(id)  { loadModal(`/Admin/AdminCategory/EditPartial/${id}`); }

        async function loadModal(url) {
            document.getElementById('catModalBody').innerHTML =
                '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            catModal.show();
            try {
                const r = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!r.ok) throw new Error(`HTTP ${r.status}`);
                document.getElementById('catModalBody').innerHTML = await r.text();
                runScripts(document.getElementById('catModalBody'));
            } catch(e) {
                document.getElementById('catModalBody').innerHTML =
                    `<div class="p-4 text-center text-danger"><i class="bi bi-exclamation-triangle fs-2"></i><p class="mt-2">Không tải được form: ${e.message}</p><button class="btn btn-sm btn-secondary" onclick="catModal.hide()">Đóng</button></div>`;
            }
        }

        function closeCatModal() { catModal.hide(); }

        async function toggleActive(id, cb) {
            const res  = await fetch(`/Admin/AdminCategory/ToggleActive/${id}`, {
                method: 'POST', headers: { 'RequestVerificationToken': TOKEN }
            });
            const data = await res.json();
            if (!data.success) { cb.checked = !cb.checked; alert(data.message); }
        }

        async function confirmDelete(id, name) {
            const r = await Swal.fire({
                title: `Xóa "${name}"?`,
                text: 'Không thể hoàn tác. Danh mục không được có sản phẩm.',
                icon: 'warning', showCancelButton: true,
                confirmButtonText: 'Xóa', cancelButtonText: 'Hủy',
                confirmButtonColor: '#c94b2a', cancelButtonColor: '#8a7560',
                reverseButtons: true
            });
            if (!r.isConfirmed) return;
            const res  = await fetch(`/Admin/AdminCategory/Delete/${id}`, {
                method: 'POST', headers: { 'RequestVerificationToken': TOKEN }
            });
            const data = await res.json();
            if (data.success) window.location.reload();
            else Swal.fire('Không thể xóa', data.message, 'error');
        }

        function filterTable() {
            const q = document.getElementById('srch').value.toLowerCase();
            let cnt = 0;
            document.querySelectorAll('#catTbody tr[data-name]').forEach(r => {
                const show = !q || r.dataset.name.includes(q);
                r.style.display = show ? '' : 'none';
                if (show) cnt++;
            });
            document.getElementById('rowCnt').innerHTML = `<b>${cnt}</b> danh mục`;
        }
    </script>
}
