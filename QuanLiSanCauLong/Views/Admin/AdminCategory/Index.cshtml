@model IEnumerable<QuanLiSanCauLong.Models.ProductCategory>
@{
    ViewData["Title"] = "Quản lý Danh Mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@functions {
    string TypeIcon(string t) => t switch { "Food" => "bi-egg-fried", "Beverage" => "bi-cup-straw", "Equipment" => "bi-gear-wide-connected", "Clothing" => "bi-bag-heart", "Accessory" => "bi-watch", _ => "bi-folder2-open" };
    string TypeLabel(string t) => t switch { "Food" => "🍱 Đồ ăn", "Beverage" => "🥤 Thức uống", "Equipment" => "🏸 Dụng cụ", "Clothing" => "👕 Quần áo", "Accessory" => "🧢 Phụ kiện", _ => "📦 Khác" };
    string TypeColor(string t) => t switch { "Food" => "#b45309", "Beverage" => "#0369a1", "Equipment" => "#166534", "Clothing" => "#7e22ce", "Accessory" => "#be185d", _ => "#4b5563" };
    string TypeBg(string t) => t switch { "Food" => "#fffbeb", "Beverage" => "#f0f9ff", "Equipment" => "#f0fdf4", "Clothing" => "#faf5ff", "Accessory" => "#fdf2f8", _ => "#f9fafb" };
    string VisualBg(string t) => t switch { "Food" => "linear-gradient(135deg,#fffbeb,#fef3c7)", "Beverage" => "linear-gradient(135deg,#f0f9ff,#dbeafe)", "Equipment" => "linear-gradient(135deg,#f0fdf4,#dcfce7)", "Clothing" => "linear-gradient(135deg,#faf5ff,#ede9fe)", "Accessory" => "linear-gradient(135deg,#fdf2f8,#fce7f3)", _ => "linear-gradient(135deg,#f9fafb,#f3f4f6)" };
    string BehaviorLabel(string b) => b switch { "Rental" => "🔄 Cho thuê", "Service" => "🔧 Dịch vụ", _ => "🛒 Bán lẻ" };
    string BehaviorColor(string b) => b switch { "Rental" => "#1d4ed8", "Service" => "#7c3aed", _ => "#166534" };
    string BehaviorBg(string b) => b switch { "Rental" => "#eff6ff", "Service" => "#f5f3ff", _ => "#f0fdf4" };
}

<style>
    :root {
        --dark: #1a1a2e;
        --gold: #e8c840;
        --gold-h: #d4b320;
        --bg: #f5f0e8;
        --card: #ffffff;
        --border: #e8e0d0;
        --text: #2d2d2d;
        --muted: #7a7060;
    }

    .page-wrapper {
        background: var(--bg);
        min-height: 100vh;
        padding: 2rem;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 800;
        color: var(--dark);
        letter-spacing: -.5px;
    }

        .page-title span {
            color: var(--gold);
            font-style: italic;
        }

    .btn-add-new {
        background: var(--gold);
        color: var(--dark);
        border: none;
        font-weight: 700;
        padding: .65rem 1.5rem;
        border-radius: 10px;
        font-size: .9rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        transition: all .2s;
        white-space: nowrap;
    }

        .btn-add-new:hover {
            background: var(--gold-h);
            color: var(--dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(232,200,64,.4);
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    @@media(max - width:900px) {
        .stats-grid {
            grid-template-columns: repeat(3,1fr);
        }
    }

    .stat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--dark);
        line-height: 1;
    }

    .stat-label {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: 4px;
    }

    .stat-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 4px;
    }

    .toolbar {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        gap: .75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 340px;
    }

        .search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .9rem;
        }

        .search-wrap input {
            padding-left: 36px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            background: var(--bg);
            color: var(--text);
            height: 40px;
            width: 100%;
            font-size: .875rem;
        }

            .search-wrap input:focus {
                outline: none;
                border-color: var(--gold);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(232,200,64,.15);
            }

    .filter-sel {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
        color: var(--text);
        height: 40px;
        padding: 0 .75rem;
        font-size: .875rem;
        cursor: pointer;
    }

        .filter-sel:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(232,200,64,.15);
        }

    .filter-count {
        font-size: .8rem;
        color: var(--muted);
        margin-left: .25rem;
        white-space: nowrap;
    }

    .cat-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1.2rem;
    }
    @@media(max - width:1100px) {
        .cat-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }
    @@media(max - width:680px) {
        .cat-grid {
            grid-template-columns: 1fr;
        }
    }

    .cat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: .2s;
        display: flex;
        flex-direction: column;
    }

        .cat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(26,26,46,.1);
            border-color: #c8c0b0;
        }

        .cat-card.inactive {
            opacity: .55;
        }

    .cat-visual {
        height: 110px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .cat-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .big-ico {
        font-size: 5rem;
        opacity: .12;
        position: absolute;
    }

    .center-ico {
        font-size: 2.5rem;
        z-index: 1;
    }

    .cat-body {
        padding: .9rem 1rem;
        flex: 1;
    }

    .cat-name {
        font-size: .95rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: .4rem;
    }

    .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: .3rem;
        margin-bottom: .55rem;
    }

    .type-badge {
        display: inline-block;
        padding: .18rem .6rem;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
    }

    .behavior-badge {
        display: inline-block;
        padding: .18rem .6rem;
        border-radius: 20px;
        font-size: .68rem;
        font-weight: 700;
    }

    .rule-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .25rem;
        margin-bottom: .6rem;
    }

    .rule-chip {
        font-size: .65rem;
        font-weight: 700;
        padding: .15rem .5rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: .2rem;
    }

    .rc-hsd {
        background: #fef2f2;
        color: #dc2626;
    }

    .rc-fifo {
        background: #eff6ff;
        color: #3b82f6;
    }

    .rc-lot {
        background: #f9fafb;
        color: #6b7280;
    }

    .rc-var {
        background: #fffbeb;
        color: #d97706;
    }

    .rc-size {
        background: #f5f3ff;
        color: #8b5cf6;
    }

    .rc-dep {
        background: #fef2f2;
        color: #dc2626;
    }

    .rc-lab {
        background: #f9fafb;
        color: #374151;
    }

    .cat-stats {
        display: flex;
        gap: .5rem;
    }

    .cs-item {
        text-align: center;
        padding: .4rem .6rem;
        background: var(--bg);
        border-radius: 8px;
    }

    .cs-val {
        font-size: .9rem;
        font-weight: 800;
        color: var(--dark);
    }

    .cs-lbl {
        font-size: .62rem;
        color: var(--muted);
    }

    .cat-foot {
        padding: .6rem .9rem;
        border-top: 1px solid var(--border);
        display: flex;
        gap: .4rem;
    }

    .cf-btn {
        flex: 1;
        padding: .4rem 0;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--dark);
        font-size: .72rem;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        cursor: pointer;
        transition: .15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .25rem;
    }

        .cf-btn:hover {
            background: var(--bg);
            border-color: #aaa;
            color: var(--dark);
        }

        .cf-btn.danger {
            color: #dc2626;
        }

            .cf-btn.danger:hover {
                background: #fef2f2;
                border-color: #fca5a5;
            }

    .empty-wrap {
        grid-column: 1/-1;
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-wrap i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .4;
        }

    .toast-wrap {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .toast-msg {
        background: var(--dark);
        color: #fff;
        padding: .75rem 1.25rem;
        border-radius: 10px;
        font-size: .85rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        animation: slideIn .3s ease;
    }

    .toast-ok {
        background: #166534;
    }

    .toast-err {
        background: #dc2626;
    }
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .inactive-overlay {
        position: absolute;
        top: 6px;
        right: 6px;
        background: rgba(220,38,38,.85);
        color: #fff;
        font-size: .62rem;
        font-weight: 800;
        padding: .15rem .5rem;
        border-radius: 20px;
        z-index: 2;
    }
</style>

<div class="page-wrapper">
    <form id="__AntiForgeryForm" style="display:none;">@Html.AntiForgeryToken()</form>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="page-title mb-1">Quản Lý <span>Danh Mục</span></h1>
            <p class="mb-0" style="color:var(--muted);font-size:.9rem;">Phân loại và tổ chức sản phẩm · <strong>@Model.Count()</strong> danh mục</p>
        </div>
        <a asp-action="Create" class="btn-add-new"><i class="bi bi-plus-circle-fill"></i> Thêm Danh Mục</a>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label"><span class="stat-dot" style="background:#1a1a2e;"></span>Tổng Danh Mục</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#166534;">@Model.Count(c => c.BehaviorType == "Retail" || string.IsNullOrEmpty(c.BehaviorType))</div>
            <div class="stat-label"><span class="stat-dot" style="background:#22c55e;"></span>Bán Lẻ</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#1d4ed8;">@Model.Count(c => c.BehaviorType == "Rental")</div>
            <div class="stat-label"><span class="stat-dot" style="background:#60a5fa;"></span>Cho Thuê</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#7c3aed;">@Model.Count(c => c.BehaviorType == "Service")</div>
            <div class="stat-label"><span class="stat-dot" style="background:#a78bfa;"></span>Dịch Vụ</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" style="color:#b45309;">@Model.Sum(c => c.Products?.Count ?? 0)</div>
            <div class="stat-label"><span class="stat-dot" style="background:#f59e0b;"></span>Tổng Sản Phẩm</div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Tìm tên danh mục..." oninput="applyFilter()" />
        </div>
        <select id="filterType" class="filter-sel" onchange="applyFilter()">
            <option value="">Tất cả loại</option>
            <option value="Food">🍱 Đồ ăn</option>
            <option value="Beverage">🥤 Thức uống</option>
            <option value="Clothing">👕 Quần áo</option>
            <option value="Equipment">🏸 Dụng cụ</option>
            <option value="Accessory">🧢 Phụ kiện</option>
            <option value="Other">📦 Khác</option>
        </select>
        <select id="filterBehavior" class="filter-sel" onchange="applyFilter()">
            <option value="">Tất cả hành vi</option>
            <option value="Retail">🛒 Bán lẻ</option>
            <option value="Rental">🔄 Cho thuê</option>
            <option value="Service">🔧 Dịch vụ</option>
        </select>
        <select id="filterActive" class="filter-sel" onchange="applyFilter()">
            <option value="">Tất cả trạng thái</option>
            <option value="1">✅ Hoạt động</option>
            <option value="0">🚫 Đã ẩn</option>
        </select>
        <span class="filter-count" id="filterCount">@Model.Count() danh mục</span>
    </div>

    <!-- Grid -->
    <div class="cat-grid" id="categoryGrid">
        @if (Model != null && Model.Any())
        {
            foreach (var cat in Model)
            {
                var productCount = cat.Products?.Count ?? 0;
                var activeCount = cat.Products?.Count(p => p.Status == "Active") ?? 0;
                var lowCount = cat.Products?.Count(p => p.StockQuantity <= p.MinStockLevel) ?? 0;
                var iconClass = TypeIcon(cat.CategoryType);
                var typeColor = TypeColor(cat.CategoryType);
                var typeBg = TypeBg(cat.CategoryType);
                var beh = cat.BehaviorType ?? "Retail";
                <div class="category-col"
                     data-name="@cat.CategoryName?.ToLower()"
                     data-type="@cat.CategoryType"
                     data-behavior="@beh"
                     data-active="@(cat.IsActive ? "1" : "0")">
                    <div class="cat-card @(!cat.IsActive ? "inactive" : "")">
                        <div class="cat-visual" style="background:@VisualBg(cat.CategoryType); position:relative;">
                            @if (!cat.IsActive)
                            {
                                <span class="inactive-overlay"><i class="bi bi-eye-slash"></i> Ẩn</span>
                            }
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@cat.ImageUrl" alt="@cat.CategoryName" onerror="this.src='/images/no-image.png'" />
                            }
                            else
                            {
                                <i class="bi @iconClass big-ico" style="color:@typeColor;"></i>
                                <i class="bi @iconClass center-ico" style="color:@typeColor;"></i>
                            }
                        </div>
                        <div class="cat-body">
                            <div class="cat-name">@cat.CategoryName</div>
                            <div class="badge-row">
                                <span class="type-badge" style="background:@typeBg;color:@typeColor;">@TypeLabel(cat.CategoryType)</span>
                                <span class="behavior-badge" style="background:@BehaviorBg(beh);color:@BehaviorColor(beh);">@BehaviorLabel(beh)</span>
                            </div>
                            <div class="rule-chips">
                                @if (cat.RequiresExpiry)
                                {
                                    <span class="rule-chip rc-hsd"><i class="bi bi-calendar-x"></i>HSD</span>
                                }
                                @if (cat.UseFIFO)
                                {
                                    <span class="rule-chip rc-fifo"><i class="bi bi-arrow-left-right"></i>FIFO</span>
                                }
                                @if (cat.RequiresBatch)
                                {
                                    <span class="rule-chip rc-lot"><i class="bi bi-upc"></i>Lô</span>
                                }
                                @if (cat.HasVariants)
                                {
                                    <span class="rule-chip rc-var"><i class="bi bi-layers"></i>Biến thể</span>
                                }
                                @if (cat.RequiresSize)
                                {
                                    <span class="rule-chip rc-size"><i class="bi bi-rulers"></i>Size</span>
                                }
                                @if (cat.DepositRequired)
                                {
                                    <span class="rule-chip rc-dep"><i class="bi bi-cash-coin"></i>Đặt cọc</span>
                                }
                                @if (cat.SeparateLaborAndMaterial)
                                {
                                    <span class="rule-chip rc-lab"><i class="bi bi-scissors"></i>Công+VL</span>
                                }
                            </div>
                            <div class="cat-stats">
                                <div class="cs-item"><div class="cs-val">@productCount</div><div class="cs-lbl">SP</div></div>
                                <div class="cs-item"><div class="cs-val" style="color:#166534;">@activeCount</div><div class="cs-lbl">Đang bán</div></div>
                                @if (lowCount > 0)
                                {
                                    <div class="cs-item"><div class="cs-val" style="color:#dc2626;">@lowCount</div><div class="cs-lbl">Tồn thấp</div></div>
                                }
                            </div>
                        </div>
                        <div class="cat-foot">
                            <a asp-action="Details" asp-route-id="@cat.CategoryId" class="cf-btn"><i class="bi bi-eye"></i> Xem</a>
                            <a asp-action="Edit" asp-route-id="@cat.CategoryId" class="cf-btn"><i class="bi bi-pencil"></i> Sửa</a>
                            <a href="/Admin/AdminProduct?categoryId=@cat.CategoryId" class="cf-btn"><i class="bi bi-box-seam"></i> SP</a>
                            <button onclick="deleteCategory(@cat.CategoryId, '@cat.CategoryName')" class="cf-btn danger"><i class="bi bi-trash3"></i> Xóa</button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-wrap">
                <i class="bi bi-collection"></i>
                <h5 style="font-weight:800;color:var(--dark);">Chưa có danh mục nào</h5>
                <p>Thêm danh mục đầu tiên để bắt đầu phân loại sản phẩm</p>
                <a asp-action="Create" class="btn-add-new mt-3"><i class="bi bi-plus-circle-fill"></i> Thêm ngay</a>
            </div>
        }
    </div>
</div>

<div class="toast-wrap" id="toastWrap"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function applyFilter() {
            const q  = document.getElementById('searchInput').value.toLowerCase();
            const t  = document.getElementById('filterType').value;
            const b  = document.getElementById('filterBehavior').value;
            const a  = document.getElementById('filterActive').value;
            let cnt = 0;
            document.querySelectorAll('.category-col').forEach(col => {
                const ok = (!q || col.dataset.name.includes(q))
                        && (!t || col.dataset.type === t)
                        && (!b || col.dataset.behavior === b)
                        && (!a || col.dataset.active === a);
                col.style.display = ok ? '' : 'none';
                if (ok) cnt++;
            });
            document.getElementById('filterCount').textContent = `${cnt} danh mục`;
        }

        function deleteCategory(id, name) {
            Swal.fire({
                title: 'Xóa danh mục?',
                html: `Bạn đang xóa <b>${name}</b>.<br>Hành động này không thể hoàn tác.`,
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#dc2626', cancelButtonColor: '#1a1a2e',
                confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy bỏ'
            }).then(r => {
                if (!r.isConfirmed) return;
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                fetch(`/Admin/AdminCategory/Delete/${id}`, {
                    method: 'POST', headers: { 'RequestVerificationToken': token }
                })
                .then(r => r.json())
                .then(d => {
                    if (d.success) { showToast(d.message, 'ok'); setTimeout(() => location.reload(), 900); }
                    else Swal.fire('Không thể xóa!', d.message, 'error');
                })
                .catch(() => Swal.fire('Lỗi!', 'Không thể kết nối máy chủ.', 'error'));
            });
        }

        function showToast(msg, type = 'ok') {
            const el = document.createElement('div');
            el.className = `toast-msg toast-${type}`;
            el.innerHTML = `<i class="bi bi-${type==='ok'?'check-circle-fill':'exclamation-circle-fill'}"></i> ${msg}`;
            document.getElementById('toastWrap').appendChild(el);
            setTimeout(() => el.remove(), 3000);
        }
    </script>
}
