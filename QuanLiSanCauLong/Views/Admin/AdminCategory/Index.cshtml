@model IEnumerable<QuanLiSanCauLong.Models.ProductCategory>
@{
    ViewData["Title"] = "Quản Lý Danh Mục";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@functions {
    string BhIcon(string b) => b switch { "Rental" => "bi-arrow-repeat", "Service" => "bi-wrench-adjustable", _ => "bi-cart3" };
    string BhLabel(string b) => b switch { "Rental" => "Cho thuê", "Service" => "Dịch vụ", _ => "Bán lẻ" };
    string BhBg(string b) => b switch { "Rental" => "#eff6ff", "Service" => "#f5f3ff", _ => "#f0fdf4" };
    string BhColor(string b) => b switch { "Rental" => "#1d4ed8", "Service" => "#7c3aed", _ => "#166534" };
    string TypeLabel(string t) => t switch
    {
        "Food" => "Đồ ăn",
        "Beverage" => "Thức uống",
        "Equipment" => "Dụng cụ",
        "Clothing" => "Quần áo",
        "Accessory" => "Phụ kiện",
        _ => "Khác"
    };
    string TypeIcon(string t) => t switch
    {
        "Food" => "bi-egg-fried",
        "Beverage" => "bi-cup-straw",
        "Equipment" => "bi-gear",
        "Clothing" => "bi-bag-heart",
        "Accessory" => "bi-watch",
        _ => "bi-folder2-open"
    };
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
        --blue: #1d4ed8;
        --purple: #7c3aed;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body, * {
        font-family: 'Outfit',sans-serif;
    }

    .pg {
        background: var(--warm);
        min-height: 100vh;
        padding: 2rem;
    }

    /* ── HEADER ── */
    .pg-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .btn-add {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .7rem 1.4rem;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        transition: all .22s;
    }

        .btn-add:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    /* ── ALERTS ── */
    .sys-alert {
        padding: .85rem 1.2rem;
        border-radius: 8px;
        margin-bottom: 1.2rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

        .sys-alert.ok {
            background: rgba(21,128,61,.07);
            border: 1px solid rgba(21,128,61,.2);
            color: var(--green);
        }

        .sys-alert.err {
            background: rgba(201,75,42,.06);
            border: 1px solid rgba(201,75,42,.2);
            color: var(--red);
        }

    /* ── STATS STRIP ── */
    .stats {
        display: flex;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.4rem;
    }

    .stat-box {
        background: #fff;
        padding: .85rem 1.2rem;
        flex: 1;
        min-width: 0;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .68rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .2rem;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    /* ── TOOLBAR ── */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .tb-search {
        flex: 1;
        min-width: 220px;
        position: relative;
    }

        .tb-search i {
            position: absolute;
            left: .75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .8rem;
        }

        .tb-search input {
            width: 100%;
            padding: .58rem .85rem .58rem 2.2rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-family: 'Outfit',sans-serif;
            font-size: .83rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
            }

    .tb-sel {
        padding: .58rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .83rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    /* ── TABLE ── */
    .tbl-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .cat-tbl {
        width: 100%;
        border-collapse: collapse;
    }

        .cat-tbl th {
            padding: .8rem 1rem;
            background: var(--warm);
            font-size: .63rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .cat-tbl td {
            padding: .85rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .84rem;
            color: var(--deep);
            vertical-align: middle;
        }

        .cat-tbl tr:last-child td {
            border-bottom: none;
        }

        .cat-tbl tr:hover td {
            background: var(--cream);
        }

    /* Icon cell */
    .icon-cell {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .cat-icon {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
    }

    /* Name */
    .cat-name {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
        line-height: 1.2;
    }

    .cat-desc {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .15rem;
        max-width: 260px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Badges */
    .bh-badge {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        padding: .22rem .65rem;
        border-radius: 4px;
        font-size: .66rem;
        font-weight: 700;
    }

    .type-badge {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .18rem .55rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 4px;
        font-size: .68rem;
        color: var(--muted);
        font-weight: 600;
    }

    /* Feature chips */
    .feat-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .25rem;
    }

    .fchip {
        padding: .14rem .45rem;
        border-radius: 3px;
        font-size: .6rem;
        font-weight: 700;
        background: var(--warm);
        border: 1px solid var(--border);
        color: var(--muted);
        white-space: nowrap;
    }

        .fchip.on {
            background: rgba(21,128,61,.08);
            border-color: rgba(21,128,61,.2);
            color: var(--green);
        }

    /* Product count */
    .prod-cnt {
        font-family: 'Playfair Display',serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--deep);
    }

    .prod-cnt-sub {
        font-size: .65rem;
        color: var(--muted);
    }

    /* Active toggle */
    .act-toggle {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        cursor: pointer;
        font-size: .74rem;
        font-weight: 600;
    }

    .toggle-track {
        width: 34px;
        height: 18px;
        border-radius: 9px;
        background: #d1d5db;
        position: relative;
        transition: background .2s;
        flex-shrink: 0;
    }

        .toggle-track.on {
            background: var(--green);
        }

    .toggle-thumb {
        position: absolute;
        top: 2px;
        left: 2px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #fff;
        transition: transform .2s;
        box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }

    .toggle-track.on .toggle-thumb {
        transform: translateX(16px);
    }

    /* Action buttons */
    .act-g {
        display: flex;
        gap: .28rem;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--muted);
        transition: all .18s;
        font-size: .75rem;
        text-decoration: none;
    }

        .act-b.edit:hover {
            border-color: var(--gold);
            color: var(--deep);
            background: rgba(212,160,23,.07);
        }

        .act-b.view:hover {
            border-color: var(--blue);
            color: var(--blue);
            background: rgba(29,78,216,.07);
        }

        .act-b.del:hover {
            border-color: var(--red);
            color: var(--red);
            background: rgba(201,75,42,.07);
        }

    /* Empty */
    .empty-row td {
        text-align: center;
        padding: 4rem;
        color: var(--muted);
    }

    .empty-row i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: .75rem;
        opacity: .2;
    }

    /* Pagination */
    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .9rem 1.2rem;
        border-top: 1px solid var(--border);
        font-size: .78rem;
        color: var(--muted);
    }

    .pager-btns {
        display: flex;
        gap: .3rem;
    }

    .pg-b {
        min-width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: #fff;
        font-size: .78rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        transition: all .15s;
    }

        .pg-b:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

        .pg-b.on {
            background: var(--deep);
            border-color: var(--deep);
            color: var(--gold2);
        }
</style>

<div class="pg">

    <!-- HEADER -->
    <div class="pg-hd">
        <div>
            <h1 class="pg-title">Danh Mục <em>Sản Phẩm</em></h1>
            <div class="pg-sub">Quản lý phân loại hàng hóa — bán lẻ, cho thuê, dịch vụ</div>
        </div>
        <button class="btn-add" onclick="openCreateModal()">
            <i class="bi bi-plus-lg"></i> Thêm danh mục
        </button>
    </div>

    <!-- ALERTS -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="sys-alert ok"><i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="sys-alert err"><i class="bi bi-exclamation-circle-fill"></i>@TempData["ErrorMessage"]</div>
    }

    <!-- STATS -->
    @{
        var total = Model.Count();
        var active = Model.Count(c => c.IsActive);
        var retail = Model.Count(c => c.BehaviorType == "Retail");
        var rental = Model.Count(c => c.BehaviorType == "Rental");
        var service = Model.Count(c => c.BehaviorType == "Service");
        var withProds = Model.Count(c => c.Products?.Any() == true);
    }
    <div class="stats">
        <div class="stat-box">
            <div class="stat-n">@total</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--gold)"></span>Tổng danh mục</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--green)">@active</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--green)"></span>Đang hoạt động</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:#166534">@retail</div>
            <div class="stat-l"><span class="stat-dot" style="background:#16a34a"></span>Bán lẻ</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--blue)">@rental</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--blue)"></span>Cho thuê</div>
        </div>
        <div class="stat-box">
            <div class="stat-n" style="color:var(--purple)">@service</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--purple)"></span>Dịch vụ</div>
        </div>
        <div class="stat-box">
            <div class="stat-n">@withProds</div>
            <div class="stat-l"><span class="stat-dot" style="background:var(--muted)"></span>Có sản phẩm</div>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="tb-search">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Tìm tên danh mục..." oninput="filterTable()" />
        </div>
        <select class="tb-sel" id="filterBh" onchange="filterTable()">
            <option value="">Tất cả loại nghiệp vụ</option>
            <option value="Retail">Bán lẻ</option>
            <option value="Rental">Cho thuê</option>
            <option value="Service">Dịch vụ</option>
        </select>
        <select class="tb-sel" id="filterType" onchange="filterTable()">
            <option value="">Tất cả loại hàng</option>
            <option value="Food">Đồ ăn</option>
            <option value="Beverage">Thức uống</option>
            <option value="Equipment">Dụng cụ</option>
            <option value="Clothing">Quần áo</option>
            <option value="Accessory">Phụ kiện</option>
            <option value="Other">Khác</option>
        </select>
        <select class="tb-sel" id="filterStatus" onchange="filterTable()">
            <option value="">Tất cả trạng thái</option>
            <option value="active">Đang hoạt động</option>
            <option value="inactive">Đã ẩn</option>
        </select>
    </div>

    <!-- TABLE -->
    <div class="tbl-wrap">
        <table class="cat-tbl" id="catTable">
            <thead>
                <tr>
                    <th style="width:40px"><input type="checkbox" id="checkAll" onchange="toggleAll(this)" /></th>
                    <th>Danh mục</th>
                    <th>Loại nghiệp vụ</th>
                    <th>Loại hàng</th>
                    <th>Tính năng</th>
                    <th style="width:90px;text-align:center">Sản phẩm</th>
                    <th style="width:100px;text-align:center">Trạng thái</th>
                    <th style="width:110px;text-align:right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="catTbody">
                @if (!Model.Any())
                {
                    <tr class="empty-row">
                        <td colspan="8">
                            <i class="bi bi-folder-x"></i>
                            <div style="font-weight:700;margin-bottom:.3rem;">Chưa có danh mục nào</div>
                            <div style="font-size:.8rem;">Nhấn <strong>+ Thêm danh mục</strong> để bắt đầu</div>
                        </td>
                    </tr>
                }
                @foreach (var cat in Model)
                {
                    var bh = cat.BehaviorType ?? "Retail";
                    var tp = cat.CategoryType ?? "";
                    var prodCnt = cat.Products?.Count ?? 0;
                    <tr id="row-@cat.CategoryId"
                        data-name="@cat.CategoryName.ToLower()"
                        data-bh="@bh"
                        data-type="@tp"
                        data-active="@(cat.IsActive ? "active" : "inactive")">
                        <td><input type="checkbox" class="row-cb" value="@cat.CategoryId" /></td>
                        <td>
                            <div class="icon-cell">
                                <div class="cat-icon" style="background:@(tp switch { "Food" => "#fffbeb", "Beverage" => "#f0f9ff", "Equipment" => "#f0fdf4", "Clothing" => "#faf5ff", "Accessory" => "#fdf2f8", _ => "#f5f0e8" });">
                                    <i class="bi @TypeIcon(tp)" style="color:@(tp switch { "Food" => "#b45309", "Beverage" => "#0369a1", "Equipment" => "#166534", "Clothing" => "#7e22ce", "Accessory" => "#be185d", _ => "var(--muted)" })"></i>
                                </div>
                                <div>
                                    <div class="cat-name">@cat.CategoryName</div>
                                    @if (!string.IsNullOrEmpty(cat.Description))
                                    {
                                        <div class="cat-desc">@cat.Description</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="bh-badge" style="background:@BhBg(bh);color:@BhColor(bh);">
                                <i class="bi @BhIcon(bh)"></i> @BhLabel(bh)
                            </span>
                        </td>
                        <td>
                            <span class="type-badge">
                                <i class="bi @TypeIcon(tp)" style="font-size:.7rem"></i>
                                @TypeLabel(tp)
                            </span>
                        </td>
                        <td>
                            <div class="feat-chips">
                                @if (bh == "Retail")
                                {
                                    <span class="fchip @(cat.RequiresExpiry ? "on" : "")">HSD</span>
                                    <span class="fchip @(cat.UseFIFO ? "on" : "")">FIFO</span>
                                    <span class="fchip @(cat.RequiresBatch ? "on" : "")">Lô</span>
                                    <span class="fchip @(cat.HasVariants ? "on" : "")">Biến thể</span>
                                }
                                else if (bh == "Rental")
                                {
                                    <span class="fchip @(cat.RequiresSize ? "on" : "")">Theo size</span>
                                    <span class="fchip @(cat.DepositRequired ? "on" : "")">Đặt cọc</span>
                                    <span class="fchip @(cat.AllowPartialReturn ? "on" : "")">Trả từng phần</span>
                                }
                                else
                                {
                                    <span class="fchip @(cat.SeparateLaborAndMaterial ? "on" : "")">Tách công/vật tư</span>
                                    <span class="fchip">@(cat.PricingModel ?? "Fixed")</span>
                                }
                                <span class="fchip">@cat.DefaultUnit</span>
                            </div>
                        </td>
                        <td style="text-align:center;">
                            <div class="prod-cnt">@prodCnt</div>
                            <div class="prod-cnt-sub">sản phẩm</div>
                        </td>
                        <td style="text-align:center;">
                            <div class="act-toggle" onclick="toggleActive(@cat.CategoryId, this)">
                                <div class="toggle-track @(cat.IsActive ? "on" : "")" id="tt-@cat.CategoryId">
                                    <div class="toggle-thumb"></div>
                                </div>
                                <span id="ts-@cat.CategoryId" style="color:@(cat.IsActive ? "var(--green)" : "var(--muted)")">
                                    @(cat.IsActive ? "Hoạt động" : "Đã ẩn")
                                </span>
                            </div>
                        </td>
                        <td>
                            <div class="act-g" style="justify-content:flex-end;">
                                <button class="act-b edit" onclick="openEditModal(@cat.CategoryId)" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <a href="@Url.Action("Details", "AdminCategory", new { id = cat.CategoryId })" class="act-b view" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button class="act-b del" onclick="deleteCat(@cat.CategoryId,'@cat.CategoryName')" title="Xóa" @(prodCnt > 0 ? "disabled title='Có sản phẩm, không thể xóa'" : "")>
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pager">
            <span id="rowCount">@Model.Count() danh mục</span>
            <div class="pager-btns" id="pagerBtns"></div>
        </div>
    </div>
</div>

<!-- ═══ MODAL CREATE/EDIT ═══ -->
<div class="modal fade" id="catModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width:820px">
        <div class="modal-content" id="catModalBody" style="border-radius:14px;border:none;">
            <div class="p-5 text-center">
                <div class="spinner-border" style="color:var(--gold)"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.AntiForgeryToken()
    <script>
        const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        let catModal;
        document.addEventListener('DOMContentLoaded', () => {
            catModal = new bootstrap.Modal(document.getElementById('catModal'));
        });

        /* ── OPEN MODALS ── */
        async function openCreateModal() {
            document.getElementById('catModalBody').innerHTML =
                '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            catModal.show();
            const r = await fetch('/Admin/AdminCategory/Create');
            document.getElementById('catModalBody').innerHTML = await r.text();
            runScripts(document.getElementById('catModalBody'));
        }

        async function openEditModal(id) {
            document.getElementById('catModalBody').innerHTML =
                '<div class="p-5 text-center"><div class="spinner-border" style="color:var(--gold)"></div></div>';
            catModal.show();
            const r = await fetch(`/Admin/AdminCategory/Edit/${id}`);
            document.getElementById('catModalBody').innerHTML = await r.text();
            runScripts(document.getElementById('catModalBody'));
        }

        function runScripts(container) {
            container.querySelectorAll('script').forEach(s => {
                const n = document.createElement('script');
                n.text = s.text;
                s.replaceWith(n);
            });
        }

        /* ── TOGGLE ACTIVE ── */
        async function toggleActive(id, wrapper) {
            const res = await fetch(`/Admin/AdminCategory/ToggleActive/${id}`, {
                method: 'POST', headers: { 'RequestVerificationToken': TOKEN }
            }).then(r => r.json());

            if (res.success) {
                const track = document.getElementById(`tt-${id}`);
                const span  = document.getElementById(`ts-${id}`);
                track.classList.toggle('on', res.isActive);
                span.textContent = res.isActive ? 'Hoạt động' : 'Đã ẩn';
                span.style.color = res.isActive ? 'var(--green)' : 'var(--muted)';
                document.querySelector(`#row-${id}`).dataset.active = res.isActive ? 'active' : 'inactive';
            }
        }

        /* ── DELETE ── */
        function deleteCat(id, name) {
            Swal.fire({
                title: `Xóa "${name}"?`,
                text: 'Hành động này không thể hoàn tác.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c94b2a',
                cancelButtonColor: '#8a7560',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy',
                reverseButtons: true
            }).then(async r => {
                if (!r.isConfirmed) return;
                const res = await fetch(`/Admin/AdminCategory/Delete/${id}`, {
                    method: 'POST', headers: { 'RequestVerificationToken': TOKEN }
                }).then(r => r.json());
                if (res.success) {
                    document.getElementById(`row-${id}`)?.remove();
                    Swal.fire({ icon:'success', title: res.message, timer:1400, showConfirmButton:false, toast:true, position:'top-end' });
                } else {
                    Swal.fire('Không thể xóa!', res.message, 'error');
                }
            });
        }

        /* ── FILTER ── */
        function filterTable() {
            const q   = document.getElementById('searchInput').value.toLowerCase();
            const bh  = document.getElementById('filterBh').value;
            const tp  = document.getElementById('filterType').value;
            const st  = document.getElementById('filterStatus').value;
            let cnt = 0;
            document.querySelectorAll('#catTbody tr[id^="row-"]').forEach(r => {
                const show = (!q || r.dataset.name?.includes(q))
                          && (!bh || r.dataset.bh === bh)
                          && (!tp || r.dataset.type === tp)
                          && (!st || r.dataset.active === st);
                r.style.display = show ? '' : 'none';
                if (show) cnt++;
            });
            document.getElementById('rowCount').textContent = cnt + ' danh mục';
        }

        /* ── CHECKBOX ALL ── */
        function toggleAll(el) {
            document.querySelectorAll('.row-cb').forEach(c => c.checked = el.checked);
        }
    </script>
}
