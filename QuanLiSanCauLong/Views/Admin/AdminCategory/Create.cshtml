@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Thêm danh mục mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    :root {
        --court-dark: #1a1a2e;
        --court-gold: #e8c840;
        --court-gold-hover: #d4b320;
        --court-bg: #f5f0e8;
        --court-card: #ffffff;
        --court-border: #e8e0d0;
        --court-text: #2d2d2d;
        --court-muted: #7a7060;
        --red: #dc2626;
    }

    .page-wrapper {
        background: var(--court-bg);
        min-height: 100vh;
        padding: 2rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--court-dark);
    }

        .page-title span {
            color: var(--court-gold);
            font-style: italic;
        }

    /* Breadcrumb */
    .bc {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .82rem;
        color: var(--court-muted);
        margin-bottom: 1.5rem;
    }

        .bc a {
            color: var(--court-muted);
            text-decoration: none;
        }

            .bc a:hover {
                color: var(--court-dark);
            }

    .bc-sep {
        opacity: .4;
    }

    .bc-cur {
        color: var(--court-dark);
        font-weight: 700;
    }

    /* Layout */
    .form-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    @@media(max-width:820px) {
        .form-layout {
            grid-template-columns: 1fr;
        }
    }

    /* Preview Sidebar */
    .preview-side {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        overflow: hidden;
        position: sticky;
        top: 1.25rem;
    }

    .prev-visual {
        height: 170px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        transition: background .35s;
    }

        .prev-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .prev-big-icon {
        font-size: 6rem;
        opacity: .12;
        position: absolute;
    }

    .prev-center-icon {
        font-size: 3rem;
        z-index: 1;
        filter: drop-shadow(0 4px 12px rgba(0,0,0,.15));
        transition: all .35s;
    }

    .prev-body {
        padding: 1.1rem 1.2rem;
    }

    .prev-name {
        font-size: 1rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: .3rem;
        min-height: 1.5rem;
    }

    .prev-type {
        display: inline-block;
        padding: .2rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        margin-bottom: .85rem;
    }

    .prev-meta-row {
        font-size: .76rem;
        color: var(--court-muted);
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    /* Upload zone */
    .upload-zone {
        border: 2px dashed var(--court-border);
        border-radius: 10px;
        padding: 1.1rem;
        text-align: center;
        cursor: pointer;
        transition: .2s;
        background: var(--court-bg);
        margin: 0 1.2rem 1.2rem;
    }

        .upload-zone:hover {
            border-color: var(--court-gold);
            background: #faf8f0;
        }

        .upload-zone i {
            font-size: 1.5rem;
            color: var(--court-muted);
            display: block;
            margin-bottom: .3rem;
        }

        .upload-zone p {
            font-size: .75rem;
            color: var(--court-muted);
            margin: 0;
        }

    .upload-preview {
        margin-top: .6rem;
        border-radius: 8px;
        overflow: hidden;
    }

        .upload-preview img {
            width: 100%;
            max-height: 110px;
            object-fit: cover;
        }

    /* Divider label */
    .prev-label {
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-muted);
        padding: .6rem 1.2rem .3rem;
        border-top: 1px solid var(--court-border);
    }

    /* Form Card */
    .form-card {
        background: var(--court-card);
        border: 1px solid var(--court-border);
        border-radius: 14px;
        padding: 1.75rem;
    }

    .form-card-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--court-dark);
        margin-bottom: .2rem;
    }

    .form-card-sub {
        font-size: .83rem;
        color: var(--court-muted);
        margin-bottom: 1.5rem;
    }

    /* Section divider */
    .section-div {
        font-size: .7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--court-dark);
        display: inline-block;
        padding-bottom: .4rem;
        border-bottom: 2px solid var(--court-gold);
        margin-bottom: .9rem;
    }

    /* Form fields */
    .fl {
        margin-bottom: .9rem;
    }

        .fl label {
            display: block;
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--court-muted);
            margin-bottom: 5px;
        }

    .fc {
        border: 1.5px solid var(--court-border);
        border-radius: 8px;
        background: var(--court-bg);
        color: var(--court-text);
        font-size: .875rem;
        padding: .5rem .75rem;
        width: 100%;
        transition: all .2s;
    }

        .fc:focus {
            outline: none;
            border-color: var(--court-gold);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(232,200,64,.2);
        }

    textarea.fc {
        resize: vertical;
        min-height: 80px;
    }

    .req {
        color: var(--red);
    }

    .err-msg {
        display: block;
        font-size: .76rem;
        color: var(--red);
        margin-top: 3px;
    }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

    @@media(max-width:600px) {
        .two-col {
            grid-template-columns: 1fr;
        }
    }

    /* Rule toggles */
    .rule-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: .7rem;
        margin-bottom: 1rem;
    }

    @@media(max-width:600px) {
        .rule-grid {
            grid-template-columns: 1fr;
        }
    }

    .rule-toggle {
        border: 1.5px solid var(--court-border);
        border-radius: 10px;
        padding: .75rem .9rem;
        cursor: pointer;
        transition: all .2s;
        background: var(--court-bg);
        display: block;
        position: relative;
    }

        .rule-toggle input[type="checkbox"] {
            display: none;
        }

        .rule-toggle:hover {
            border-color: var(--court-gold);
            background: #faf8f0;
        }

    .rt-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .25rem;
    }

    .rt-ico-label {
        font-size: .83rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .rt-desc {
        font-size: .72rem;
        color: var(--court-muted);
    }

    /* Toggle dot */
    .toggle-dot {
        width: 32px;
        height: 18px;
        border-radius: 20px;
        background: #d1d5db;
        position: relative;
        transition: background .2s;
        flex-shrink: 0;
    }

        .toggle-dot::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #fff;
            transition: transform .2s;
        }

    .active-hsd {
        background: #fef2f2;
        border-color: #fca5a5;
    }

        .active-hsd .toggle-dot {
            background: #ef4444;
        }

            .active-hsd .toggle-dot::after {
                transform: translateX(14px);
            }

    .active-fifo {
        background: #eff6ff;
        border-color: #93c5fd;
    }

        .active-fifo .toggle-dot {
            background: #3b82f6;
        }

            .active-fifo .toggle-dot::after {
                transform: translateX(14px);
            }

    .active-lot {
        background: #f9fafb;
        border-color: #d1d5db;
    }

        .active-lot .toggle-dot {
            background: #6b7280;
        }

            .active-lot .toggle-dot::after {
                transform: translateX(14px);
            }

    .active-var {
        background: #fffbeb;
        border-color: #fcd34d;
    }

        .active-var .toggle-dot {
            background: #f59e0b;
        }

            .active-var .toggle-dot::after {
                transform: translateX(14px);
            }

    /* Buttons */
    .btn-row {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--court-border);
    }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1.4rem;
        background: var(--court-bg);
        color: var(--court-text);
        border: 1.5px solid var(--court-border);
        border-radius: 10px;
        font-weight: 600;
        font-size: .875rem;
        text-decoration: none;
        cursor: pointer;
        transition: .18s;
    }

        .btn-cancel:hover {
            background: #ede8de;
            color: var(--court-text);
        }

    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .6rem 1.75rem;
        background: var(--court-gold);
        color: var(--court-dark);
        border: none;
        border-radius: 10px;
        font-weight: 800;
        font-size: .875rem;
        cursor: pointer;
        transition: .18s;
    }

        .btn-submit:hover {
            background: var(--court-gold-hover);
            box-shadow: 0 4px 12px rgba(232,200,64,.4);
        }
</style>

<div class="page-wrapper">

    <!-- Breadcrumb -->
    <nav class="bc">
        <a asp-action="Index"><i class="bi bi-collection me-1"></i>Danh Mục</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">Thêm mới</span>
    </nav>

    <h1 class="page-title mb-4">Thêm <span>Danh Mục Mới</span></h1>

    <div class="form-layout">

        <!-- Preview Sidebar -->
        <div class="preview-side">
            <div class="prev-visual" id="prevVisual">
                <i class="bi bi-folder2-open prev-big-icon" id="prevBigIcon" style="color:#9ca3af;"></i>
                <i class="bi bi-folder2-open prev-center-icon" id="prevCenterIcon" style="color:#9ca3af;"></i>
            </div>
            <div class="prev-body">
                <div class="prev-name" id="prevName" style="color:#9ca3af;">Tên danh mục</div>
                <span class="prev-type" id="prevType" style="background:#f3f4f6;color:#6b7280;">Chọn loại</span>
                <div class="prev-meta-row">
                    <span><i class="bi bi-box-seam me-1"></i>Đơn vị: <strong id="prevUnit">Cái</strong></span>
                    <span><i class="bi bi-arrow-down-up me-1"></i>Safety Stock: <strong id="prevStock">—</strong></span>
                </div>
            </div>
            <div class="prev-label">Hình ảnh đại diện</div>
            <div style="padding:0 1.2rem 1.2rem;">
                <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
                    <i class="bi bi-cloud-arrow-up"></i>
                    <p>Click hoặc kéo thả để tải ảnh</p>
                </div>
                <input type="file" id="fileInput" name="CategoryImage" accept="image/*" class="d-none" onchange="onImageSelect(this)" />
                <div id="uploadPreview" class="upload-preview"></div>
            </div>
        </div>

        <!-- Form Card -->
        <div class="form-card">
            <div class="form-card-title">Thêm Danh Mục Mới</div>
            <div class="form-card-sub">Tạo nhóm phân loại để tổ chức sản phẩm trong hệ thống</div>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Thông tin cơ bản -->
                <div class="section-div"><i class="bi bi-info-circle me-1"></i>Thông Tin Cơ Bản</div>

                <div class="fl">
                    <label>Tên danh mục <span class="req">*</span></label>
                    <input asp-for="CategoryName" id="inputName" class="fc" placeholder="VD: Vợt cầu lông, Nước uống thể thao..." />
                    <span asp-validation-for="CategoryName" class="err-msg"></span>
                </div>

                <div class="two-col">
                    <div class="fl">
                        <label>Loại danh mục <span class="req">*</span></label>
                        <select asp-for="CategoryType" id="inputType" class="fc">
                            <option value="">-- Chọn loại --</option>
                            <option value="Food">🍱 Đồ ăn</option>
                            <option value="Beverage">🥤 Thức uống</option>
                            <option value="Clothing">👕 Quần áo</option>
                            <option value="Equipment">🏸 Dụng cụ thể thao</option>
                            <option value="Accessory">🧢 Phụ kiện</option>
                            <option value="Other">📦 Khác</option>
                        </select>
                        <span asp-validation-for="CategoryType" class="err-msg"></span>
                    </div>
                    <div class="fl">
                        <label>Đơn vị mặc định</label>
                        <select asp-for="DefaultUnit" id="inputUnit" class="fc">
                            <option value="Cái">Cái</option>
                            <option value="Bộ">Bộ</option>
                            <option value="Hộp">Hộp</option>
                            <option value="Thùng">Thùng</option>
                            <option value="Kg">Kg</option>
                            <option value="Gram">Gram</option>
                            <option value="Lít">Lít</option>
                            <option value="Chai">Chai</option>
                            <option value="Lon">Lon</option>
                            <option value="Túi">Túi</option>
                            <option value="Đôi">Đôi</option>
                            <option value="Chiếc">Chiếc</option>
                        </select>
                    </div>
                </div>

                <div class="fl">
                    <label>Mô tả</label>
                    <textarea asp-for="Description" class="fc" placeholder="Mô tả ngắn gọn về danh mục..."></textarea>
                </div>

                <!-- Quy tắc kho -->
                <div class="section-div mt-3"><i class="bi bi-sliders2 me-1"></i>Quy Tắc Quản Lý Kho</div>

                <div class="rule-grid" id="ruleGrid">
                    <label class="rule-toggle" id="rtHsd" onclick="toggleRule('RequiresExpiry','rtHsd','active-hsd')">
                        <input type="checkbox" asp-for="RequiresExpiry" id="RequiresExpiry" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#dc2626;"><i class="bi bi-calendar-x"></i> Theo dõi HSD</div>
                            <div class="toggle-dot" id="dotHsd"></div>
                        </div>
                        <div class="rt-desc">Đồ ăn, đồ uống có hạn sử dụng</div>
                    </label>

                    <label class="rule-toggle" id="rtFifo" onclick="toggleRule('UseFIFO','rtFifo','active-fifo')">
                        <input type="checkbox" asp-for="UseFIFO" id="UseFIFO" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#3b82f6;"><i class="bi bi-arrow-left-right"></i> FIFO</div>
                            <div class="toggle-dot" id="dotFifo"></div>
                        </div>
                        <div class="rt-desc">Nhập trước – Xuất trước</div>
                    </label>

                    <label class="rule-toggle" id="rtLot" onclick="toggleRule('RequiresBatch','rtLot','active-lot')">
                        <input type="checkbox" asp-for="RequiresBatch" id="RequiresBatch" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#6b7280;"><i class="bi bi-upc"></i> Theo lô</div>
                            <div class="toggle-dot" id="dotLot"></div>
                        </div>
                        <div class="rt-desc">Truy xuất nguồn gốc Batch/Lot</div>
                    </label>

                    <label class="rule-toggle" id="rtVar" onclick="toggleRule('HasVariants','rtVar','active-var')">
                        <input type="checkbox" asp-for="HasVariants" id="HasVariants" />
                        <div class="rt-header">
                            <div class="rt-ico-label" style="color:#f59e0b;"><i class="bi bi-layers"></i> Biến thể</div>
                            <div class="toggle-dot" id="dotVar"></div>
                        </div>
                        <div class="rt-desc">Nhiều màu/size (quần áo, giày)</div>
                    </label>
                </div>

                <!-- Cấu hình -->
                <div class="section-div mt-3"><i class="bi bi-gear me-1"></i>Cấu Hình</div>

                <div class="two-col">
                    <div class="fl">
                        <label>Safety Stock mặc định</label>
                        <input asp-for="DefaultMinStock" id="inputStock" type="number" min="0" class="fc" placeholder="VD: 10" oninput="document.getElementById('prevStock').textContent=this.value||'—'" />
                        <div style="font-size:.72rem;color:var(--court-muted);margin-top:3px;">Ngưỡng tồn kho tối thiểu</div>
                    </div>
                    <div class="fl">
                        <label>Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" min="0" class="fc" placeholder="VD: 1, 2, 3..." />
                    </div>
                </div>

                <div class="btn-row">
                    <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i> Hủy</a>
                    <button type="submit" class="btn-submit"><i class="bi bi-plus-circle-fill"></i> Lưu Danh Mục</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const ICONS  = { Food:'bi-egg-fried',Beverage:'bi-cup-straw',Equipment:'bi-gear-wide-connected',Clothing:'bi-bag-heart',Accessory:'bi-watch',Other:'bi-folder2-open',''  :'bi-folder2-open' };
        const COLORS = { Food:'#b45309',Beverage:'#0369a1',Equipment:'#166534',Clothing:'#7e22ce',Accessory:'#be185d',Other:'#4b5563','':'#9ca3af' };
        const BGS    = { Food:'linear-gradient(135deg,#fffbeb,#fef3c7)',Beverage:'linear-gradient(135deg,#f0f9ff,#dbeafe)',Equipment:'linear-gradient(135deg,#f0fdf4,#dcfce7)',Clothing:'linear-gradient(135deg,#faf5ff,#ede9fe)',Accessory:'linear-gradient(135deg,#fdf2f8,#fce7f3)',Other:'linear-gradient(135deg,#f9fafb,#f3f4f6)','':'linear-gradient(135deg,#f1f5f9,#e2e8f0)' };
        const LABELS = { Food:'🍱 Đồ ăn',Beverage:'🥤 Thức uống',Equipment:'🏸 Dụng cụ',Clothing:'👕 Quần áo',Accessory:'🧢 Phụ kiện',Other:'📦 Khác','':'Chọn loại' };
        const TC_BG  = { Food:'#fffbeb',Beverage:'#e0f2fe',Equipment:'#f0fdf4',Clothing:'#faf5ff',Accessory:'#fdf2f8',Other:'#f9fafb','':'#f3f4f6' };

        document.getElementById('inputName').addEventListener('input', e => {
            const el = document.getElementById('prevName');
            el.textContent = e.target.value || 'Tên danh mục';
            el.style.color = e.target.value ? 'var(--court-dark)' : '#9ca3af';
        });

        document.getElementById('inputType').addEventListener('change', function () {
            const v = this.value;
            document.getElementById('prevVisual').style.background = BGS[v] || BGS[''];
            ['prevBigIcon', 'prevCenterIcon'].forEach(id => {
                const el = document.getElementById(id);
                el.className = `bi ${ICONS[v] || 'bi-folder2-open'} ${id.includes('Big') ? 'prev-big-icon' : 'prev-center-icon'}`;
                el.style.color = COLORS[v] || '#9ca3af';
            });
            const pt = document.getElementById('prevType');
            pt.textContent = LABELS[v];
            pt.style.background = TC_BG[v] || '#f3f4f6';
            pt.style.color = COLORS[v] || '#6b7280';
            // Auto-suggest rules
            if (v === 'Food' || v === 'Beverage') {
                setRule('RequiresExpiry', 'rtHsd', 'active-hsd', true);
                setRule('UseFIFO', 'rtFifo', 'active-fifo', true);
            }
            if (v === 'Clothing' || v === 'Accessory') {
                setRule('HasVariants', 'rtVar', 'active-var', true);
            }
        });

        document.getElementById('inputUnit').addEventListener('change', function () {
            document.getElementById('prevUnit').textContent = this.value || '—';
        });

        function toggleRule(cbId, divId, cls) {
            const cb = document.getElementById(cbId);
            cb.checked = !cb.checked;
            const div = document.getElementById(divId);
            if (cb.checked) div.classList.add(cls); else div.classList.remove(cls);
        }

        function setRule(cbId, divId, cls, val) {
            const cb = document.getElementById(cbId);
            cb.checked = val;
            const div = document.getElementById(divId);
            if (val) div.classList.add(cls); else div.classList.remove(cls);
        }

        function onImageSelect(input) {
            if (!input.files[0]) return;
            const url = URL.createObjectURL(input.files[0]);
            document.getElementById('uploadPreview').innerHTML = `<img src="${url}" />`;
            document.getElementById('prevVisual').innerHTML = `<img src="${url}" style="width:100%;height:100%;object-fit:cover;" />`;
        }
    </script>
}
