@model QuanLiSanCauLong.Models.ProductCategory
@{
    ViewData["Title"] = "Thêm Danh Mục";
    // Không cần Layout khi load trong modal
    Layout = null;
}

<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --red: #c94b2a;
        --green: #15803d;
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    * {
        font-family: 'Outfit',sans-serif;
    }

    /* Modal shell */
    .md-hd {
        padding: 1.2rem 1.4rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--deep);
    }

    .md-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.15rem;
        font-weight: 700;
        color: #fff;
    }

        .md-title em {
            font-style: italic;
            color: var(--gold2);
        }

    .md-close {
        background: none;
        border: none;
        color: rgba(255,255,255,.45);
        font-size: 1rem;
        cursor: pointer;
    }

        .md-close:hover {
            color: #fff;
        }

    .md-body {
        padding: 1.4rem;
        overflow-y: auto;
        max-height: 75vh;
    }

    .md-ft {
        padding: 1rem 1.4rem;
        border-top: 1px solid var(--border);
        background: var(--warm);
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
    }

    /* Step indicator */
    .steps {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 1.5rem;
    }

    .step {
        display: flex;
        align-items: center;
        gap: .45rem;
        font-size: .75rem;
        font-weight: 700;
        color: var(--muted);
    }

        .step.on {
            color: var(--deep);
        }

        .step.done {
            color: var(--green);
        }

    .step-num {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
        font-weight: 900;
        color: var(--muted);
        flex-shrink: 0;
    }

    .step.on .step-num {
        background: var(--deep);
        color: var(--gold2);
    }

    .step.done .step-num {
        background: var(--green);
        color: #fff;
    }

    .step-line {
        flex: 1;
        height: 1px;
        background: var(--border);
        margin: 0 .5rem;
        min-width: 24px;
    }

    /* ── PRESET CARDS ── */
    .preset-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .85rem;
        margin-bottom: 1.5rem;
    }

    .preset-card {
        border: 2px solid var(--border);
        border-radius: 12px;
        padding: 1.1rem;
        cursor: pointer;
        background: #fff;
        transition: all .22s;
        position: relative;
    }

        .preset-card:hover {
            border-color: var(--gold);
            box-shadow: 0 4px 16px rgba(212,160,23,.15);
        }

        .preset-card.selected {
            border-color: var(--deep);
            background: rgba(26,18,9,.03);
        }

            .preset-card.selected::after {
                content: '✓';
                position: absolute;
                top: 8px;
                right: 10px;
                font-size: .75rem;
                font-weight: 900;
                color: var(--gold2);
                background: var(--deep);
                width: 20px;
                height: 20px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                line-height: 20px;
                text-align: center;
            }

    .pc-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-bottom: .75rem;
    }

    .pc-name {
        font-weight: 700;
        font-size: .9rem;
        color: var(--deep);
        margin-bottom: .25rem;
    }

    .pc-desc {
        font-size: .72rem;
        color: var(--muted);
        line-height: 1.5;
    }

    .pc-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .25rem;
        margin-top: .6rem;
    }

    .pc-tag {
        padding: .12rem .45rem;
        border-radius: 3px;
        font-size: .58rem;
        font-weight: 700;
        background: var(--warm);
        border: 1px solid var(--border);
        color: var(--muted);
    }

    /* ── FORM ── */
    .section-hd {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted);
        padding: .6rem 0;
        margin-bottom: .75rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .85rem;
    }

        .form-grid.full {
            grid-template-columns: 1fr;
        }

    .fl {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

        .fl label {
            font-size: .72rem;
            font-weight: 700;
            color: var(--deep);
        }

        .fl .req {
            color: var(--red);
        }

    .fc {
        padding: .62rem .85rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-family: 'Outfit',sans-serif;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s;
        width: 100%;
    }

        .fc:focus {
            border-color: var(--gold);
        }

    .fc-combo {
        position: relative;
    }

        .fc-combo input {
            padding-right: 2.2rem;
        }

    .fc-combo-arrow {
        position: absolute;
        right: .65rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: .7rem;
        pointer-events: none;
    }

    .hint {
        font-size: .68rem;
        color: var(--muted);
    }

    .err {
        font-size: .7rem;
        color: var(--red);
        margin-top: .2rem;
    }

    /* Toggle group */
    .toggle-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
    }

    .tg-item {
        display: flex;
        align-items: flex-start;
        gap: .55rem;
        padding: .65rem .8rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        background: #fff;
        transition: all .18s;
        user-select: none;
    }

        .tg-item:hover {
            border-color: var(--gold);
        }

        .tg-item.on {
            border-color: var(--deep);
            background: rgba(26,18,9,.03);
        }

        .tg-item input {
            display: none;
        }

    .tg-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 2px solid var(--border);
        flex-shrink: 0;
        margin-top: 1px;
        transition: all .18s;
        position: relative;
    }

    .tg-item.on .tg-dot {
        background: var(--deep);
        border-color: var(--deep);
    }

        .tg-item.on .tg-dot::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #fff;
        }

    .tg-body {
    }

    .tg-label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
    }

    .tg-hint {
        font-size: .65rem;
        color: var(--muted);
        margin-top: .1rem;
    }

    /* Behavior selector */
    .bh-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .65rem;
        margin-bottom: 1.2rem;
    }

    .bh-opt {
        border: 2px solid var(--border);
        border-radius: 10px;
        padding: .85rem;
        cursor: pointer;
        background: #fff;
        transition: all .2s;
        text-align: center;
    }

        .bh-opt:hover {
            border-color: var(--gold);
        }

        .bh-opt.on-retail {
            border-color: #16a34a;
            background: #f0fdf4;
        }

        .bh-opt.on-rental {
            border-color: var(--blue);
            background: #eff6ff;
        }

        .bh-opt.on-service {
            border-color: var(--purple);
            background: #f5f3ff;
        }

    .bh-ico {
        font-size: 1.4rem;
        display: block;
        margin-bottom: .4rem;
    }

    .bh-name {
        font-size: .82rem;
        font-weight: 700;
        color: var(--deep);
    }

    .bh-desc {
        font-size: .65rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    /* Cond panels */
    .cond-panel {
        display: none;
        padding: 1rem;
        border-radius: 10px;
        margin-top: .85rem;
    }

        .cond-panel.show {
            display: block;
        }

    .panel-retail {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
    }

    .panel-rental {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
    }

    .panel-service {
        background: #f5f3ff;
        border: 1px solid #ddd6fe;
    }

    /* File upload */
    .upload-zone {
        border: 2px dashed var(--border);
        border-radius: 8px;
        padding: 1.2rem;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        background: #fff;
    }

        .upload-zone:hover {
            border-color: var(--gold);
            background: rgba(212,160,23,.04);
        }

        .upload-zone i {
            font-size: 1.4rem;
            color: var(--muted);
            display: block;
            margin-bottom: .35rem;
        }

        .upload-zone p {
            font-size: .76rem;
            color: var(--muted);
            margin: 0;
        }

    .upload-preview img {
        max-height: 80px;
        border-radius: 6px;
        margin-top: .5rem;
        border: 1px solid var(--border);
    }

    /* Buttons */
    .btn-primary {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep);
        border: none;
        padding: .68rem 1.5rem;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 7px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: all .2s;
    }

        .btn-primary:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
            transform: translateY(-1px);
        }

    .btn-secondary {
        padding: .65rem 1.2rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--muted);
        transition: all .18s;
    }

        .btn-secondary:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .btn-back {
        padding: .55rem .9rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: #fff;
        font-size: .78rem;
        cursor: pointer;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: .3rem;
        transition: all .15s;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep);
        }
</style>

<!-- MODAL HEADER -->
<div class="md-hd">
    <span class="md-title">Thêm <em>Danh Mục</em> Mới</span>
    <button class="md-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
</div>

<div class="md-body">
    <!-- STEP INDICATOR -->
    <div class="steps">
        <div class="step on" id="stepInd1"><div class="step-num">1</div> Chọn template</div>
        <div class="step-line"></div>
        <div class="step" id="stepInd2"><div class="step-num">2</div> Thông tin</div>
        <div class="step-line"></div>
        <div class="step" id="stepInd3"><div class="step-num">3</div> Cấu hình</div>
    </div>

    <!-- ════ STEP 1: PRESET ════ -->
    <div id="step1">
        <div class="section-hd"><i class="bi bi-lightning-charge"></i> Chọn nhanh template phù hợp</div>
        <div class="preset-grid">

            <!-- Preset 1: Đồ uống bán lẻ -->
            <div class="preset-card" onclick="applyPreset('beverage')" id="pc-beverage">
                <div class="pc-icon" style="background:#f0f9ff;"><i class="bi bi-cup-straw" style="color:#0369a1"></i></div>
                <div class="pc-name">Thức uống / Đồ ăn</div>
                <div class="pc-desc">Nước, thức ăn nhanh, snack bán tại quầy. Quản lý hạn dùng, xuất kho FIFO.</div>
                <div class="pc-tags">
                    <span class="pc-tag">Bán lẻ</span>
                    <span class="pc-tag">Theo dõi HSD</span>
                    <span class="pc-tag">FIFO</span>
                    <span class="pc-tag">Đơn vị: Chai/Lon/Hộp</span>
                </div>
            </div>

            <!-- Preset 2: Dụng cụ cho thuê -->
            <div class="preset-card" onclick="applyPreset('rental')" id="pc-rental">
                <div class="pc-icon" style="background:#eff6ff;"><i class="bi bi-arrow-repeat" style="color:#1d4ed8"></i></div>
                <div class="pc-name">Dụng cụ cho thuê</div>
                <div class="pc-desc">Vợt, giày, quần áo cho thuê. Hoàn kho khi khách trả, hỗ trợ đặt cọc.</div>
                <div class="pc-tags">
                    <span class="pc-tag">Cho thuê</span>
                    <span class="pc-tag">Theo size</span>
                    <span class="pc-tag">Đặt cọc</span>
                    <span class="pc-tag">Hoàn kho khi trả</span>
                </div>
            </div>

            <!-- Preset 3: Dịch vụ -->
            <div class="preset-card" onclick="applyPreset('service')" id="pc-service">
                <div class="pc-icon" style="background:#f5f3ff;"><i class="bi bi-wrench-adjustable" style="color:#7c3aed"></i></div>
                <div class="pc-name">Dịch vụ / Căng vợt</div>
                <div class="pc-desc">Căng vợt, sửa chữa, huấn luyện. Tính phí công + vật tư, không quản lý kho vật lý.</div>
                <div class="pc-tags">
                    <span class="pc-tag">Dịch vụ</span>
                    <span class="pc-tag">Tách công/vật tư</span>
                    <span class="pc-tag">Không kho vật lý</span>
                </div>
            </div>

            <!-- Preset 4: Phụ kiện bán -->
            <div class="preset-card" onclick="applyPreset('accessory')" id="pc-accessory">
                <div class="pc-icon" style="background:#fdf2f8;"><i class="bi bi-bag-heart" style="color:#be185d"></i></div>
                <div class="pc-name">Phụ kiện / Quần áo bán</div>
                <div class="pc-desc">Quần áo, băng quấn, phụ kiện bán ra. Có biến thể màu/size, quản lý kho theo lô.</div>
                <div class="pc-tags">
                    <span class="pc-tag">Bán lẻ</span>
                    <span class="pc-tag">Biến thể màu/size</span>
                    <span class="pc-tag">Theo lô</span>
                </div>
            </div>

            <!-- Preset 5: Dụng cụ bán -->
            <div class="preset-card" onclick="applyPreset('equipment')" id="pc-equipment">
                <div class="pc-icon" style="background:#f0fdf4;"><i class="bi bi-gear" style="color:#166534"></i></div>
                <div class="pc-name">Dụng cụ bán ra</div>
                <div class="pc-desc">Vợt, túi, cầu bán đứt. Bán lẻ đơn giản, quản lý safety stock, nhập lô.</div>
                <div class="pc-tags">
                    <span class="pc-tag">Bán lẻ</span>
                    <span class="pc-tag">Safety stock</span>
                    <span class="pc-tag">Đơn vị: Cái/Bộ</span>
                </div>
            </div>

            <!-- Preset 6: Tùy chỉnh -->
            <div class="preset-card" onclick="applyPreset('custom')" id="pc-custom">
                <div class="pc-icon" style="background:var(--warm);"><i class="bi bi-sliders" style="color:var(--muted)"></i></div>
                <div class="pc-name">Tùy chỉnh</div>
                <div class="pc-desc">Tự cấu hình từ đầu theo nhu cầu riêng của bạn.</div>
                <div class="pc-tags">
                    <span class="pc-tag">Tùy chỉnh hoàn toàn</span>
                </div>
            </div>
        </div>
        <div style="display:flex;justify-content:flex-end;">
            <button class="btn-primary" id="btnStep1Next" onclick="goStep(2)" disabled>
                Tiếp theo <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- ════ STEP 2: BASIC INFO ════ -->
    <div id="step2" style="display:none;">
        <button class="btn-back mb-3" onclick="goStep(1)"><i class="bi bi-arrow-left"></i> Quay lại</button>

        <div class="section-hd"><i class="bi bi-info-circle"></i> Thông tin cơ bản</div>

        <div class="form-grid full" style="gap:.85rem;">
            <div class="fl">
                <label>Tên danh mục <span class="req">*</span></label>
                <div class="fc-combo">
                    <input type="text" id="inp_name" class="fc" placeholder="VD: Nước uống, Vợt cho thuê..." maxlength="100" oninput="updatePreview()" />
                    <i class="bi bi-chevron-down fc-combo-arrow" style="display:none" id="nameSugArrow"></i>
                </div>
                <!-- Quick name suggestions based on template -->
                <div id="nameSuggestions" style="display:none;flex-wrap:wrap;gap:.3rem;margin-top:.35rem;"></div>
            </div>
        </div>

        <div class="form-grid" style="margin-top:.85rem;">
            <div class="fl">
                <label>Loại hàng hóa <span class="req">*</span></label>
                <select id="inp_type" class="fc">
                    <option value="">-- Chọn loại --</option>
                    <option value="Food">Đồ ăn</option>
                    <option value="Beverage">Thức uống</option>
                    <option value="Equipment">Dụng cụ thể thao</option>
                    <option value="Clothing">Quần áo / Giày dép</option>
                    <option value="Accessory">Phụ kiện</option>
                    <option value="Other">Khác</option>
                </select>
            </div>
            <div class="fl">
                <label>Đơn vị tính</label>
                <select id="inp_unit" class="fc">
                    <option value="Cái">Cái</option>
                    <option value="Bộ">Bộ</option>
                    <option value="Chiếc">Chiếc</option>
                    <option value="Đôi">Đôi</option>
                    <option value="Hộp">Hộp</option>
                    <option value="Thùng">Thùng</option>
                    <option value="Chai">Chai</option>
                    <option value="Lon">Lon</option>
                    <option value="Túi">Túi</option>
                    <option value="Kg">Kg</option>
                    <option value="Gram">Gram</option>
                    <option value="Lít">Lít</option>
                </select>
            </div>
        </div>

        <div class="form-grid full" style="margin-top:.85rem;">
            <div class="fl">
                <label>Mô tả</label>
                <textarea id="inp_desc" class="fc" rows="2" placeholder="Mô tả ngắn về danh mục này..."></textarea>
            </div>
        </div>

        <div class="form-grid" style="margin-top:.85rem;">
            <div class="fl">
                <label>Thứ tự hiển thị</label>
                <input type="number" id="inp_order" class="fc" min="0" value="0" />
                <span class="hint">Số nhỏ hơn hiển thị trước</span>
            </div>
            <div class="fl">
                <label>Trạng thái</label>
                <select id="inp_active" class="fc">
                    <option value="true">Hoạt động</option>
                    <option value="false">Ẩn</option>
                </select>
            </div>
        </div>

        <!-- Preview card -->
        <div id="previewCard" style="margin-top:1rem;padding:.85rem 1rem;background:var(--warm);border:1px solid var(--border);border-radius:8px;display:flex;align-items:center;gap:.75rem;">
            <div id="pvIcon" style="width:36px;height:36px;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center;font-size:.9rem;border:1px solid var(--border);">
                <i class="bi bi-folder2-open" style="color:var(--muted)"></i>
            </div>
            <div>
                <div id="pvName" style="font-weight:700;font-size:.88rem;color:var(--deep);">Tên danh mục</div>
                <div id="pvMeta" style="font-size:.7rem;color:var(--muted);margin-top:.1rem;">Chọn loại hàng hóa</div>
            </div>
            <div id="pvBadge" style="margin-left:auto;"></div>
        </div>

        <div style="display:flex;justify-content:flex-end;margin-top:1.25rem;">
            <button class="btn-primary" onclick="goStep(3)">
                Tiếp theo <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- ════ STEP 3: ADVANCED CONFIG ════ -->
    <div id="step3" style="display:none;">
        <button class="btn-back mb-3" onclick="goStep(2)"><i class="bi bi-arrow-left"></i> Quay lại</button>

        <div class="section-hd"><i class="bi bi-diagram-3"></i> Loại nghiệp vụ <span class="req" style="color:var(--red)">*</span></div>
        <div class="bh-row">
            <div class="bh-opt" id="bhRetail" onclick="selectBh('Retail')">
                <span class="bh-ico"><i class="bi bi-cart3" style="color:#16a34a"></i></span>
                <div class="bh-name">Bán lẻ</div>
                <div class="bh-desc">Trừ kho khi bán</div>
            </div>
            <div class="bh-opt" id="bhRental" onclick="selectBh('Rental')">
                <span class="bh-ico"><i class="bi bi-arrow-repeat" style="color:#1d4ed8"></i></span>
                <div class="bh-name">Cho thuê</div>
                <div class="bh-desc">Hoàn kho khi trả</div>
            </div>
            <div class="bh-opt" id="bhService" onclick="selectBh('Service')">
                <span class="bh-ico"><i class="bi bi-wrench-adjustable" style="color:#7c3aed"></i></span>
                <div class="bh-name">Dịch vụ</div>
                <div class="bh-desc">Không kho vật lý</div>
            </div>
        </div>

        <!-- RETAIL options -->
        <div class="cond-panel panel-retail" id="panelRetail">
            <div style="font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#16a34a;margin-bottom:.75rem;display:flex;align-items:center;gap:.4rem;">
                <i class="bi bi-boxes"></i> Quy tắc quản lý kho
            </div>
            <div class="toggle-group">
                <label class="tg-item" id="tgHsd">
                    <input type="checkbox" id="cb_expiry" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-calendar-x me-1" style="color:#dc2626"></i>Theo dõi hạn sử dụng</div>
                        <div class="tg-hint">Cảnh báo khi sản phẩm sắp hết hạn</div>
                    </div>
                </label>
                <label class="tg-item" id="tgFifo">
                    <input type="checkbox" id="cb_fifo" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-arrow-left-right me-1" style="color:#2563eb"></i>Xuất kho theo FIFO</div>
                        <div class="tg-hint">Nhập trước – xuất trước tự động</div>
                    </div>
                </label>
                <label class="tg-item" id="tgBatch">
                    <input type="checkbox" id="cb_batch" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-upc me-1" style="color:#6b7280"></i>Quản lý theo lô</div>
                        <div class="tg-hint">Truy xuất nguồn gốc từng lô hàng</div>
                    </div>
                </label>
                <label class="tg-item" id="tgVariants">
                    <input type="checkbox" id="cb_variants" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-layers me-1" style="color:#f59e0b"></i>Có biến thể</div>
                        <div class="tg-hint">Phân loại theo màu, size, kiểu dáng</div>
                    </div>
                </label>
            </div>
            <div style="margin-top:.85rem;display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                <div class="fl">
                    <label>Tồn kho tối thiểu</label>
                    <input type="number" id="inp_minstock" class="fc" min="0" value="0" placeholder="VD: 10" />
                    <span class="hint">Cảnh báo khi dưới mức này</span>
                </div>
            </div>
        </div>

        <!-- RENTAL options -->
        <div class="cond-panel panel-rental" id="panelRental">
            <div style="font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#1d4ed8;margin-bottom:.75rem;display:flex;align-items:center;gap:.4rem;">
                <i class="bi bi-arrow-repeat"></i> Cấu hình cho thuê
            </div>
            <div class="toggle-group">
                <label class="tg-item" id="tgSize">
                    <input type="checkbox" id="cb_size" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-rulers me-1" style="color:#8b5cf6"></i>Cho thuê theo size</div>
                        <div class="tg-hint">Giày, quần áo cần chọn size</div>
                    </div>
                </label>
                <label class="tg-item" id="tgDeposit">
                    <input type="checkbox" id="cb_deposit" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-cash-coin me-1" style="color:#16a34a"></i>Yêu cầu đặt cọc</div>
                        <div class="tg-hint">Thu tiền cọc khi cho mượn</div>
                    </div>
                </label>
                <label class="tg-item" id="tgPartial">
                    <input type="checkbox" id="cb_partial" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-box-arrow-in-left me-1" style="color:#f59e0b"></i>Trả hàng từng phần</div>
                        <div class="tg-hint">Cho phép trả lại từng cái</div>
                    </div>
                </label>
            </div>
            <div id="depositAmountRow" style="display:none;margin-top:.85rem;display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                <div class="fl">
                    <label>Tiền đặt cọc mặc định (đ)</label>
                    <input type="number" id="inp_deposit" class="fc" min="0" value="0" placeholder="VD: 50000" />
                </div>
                <div class="fl">
                    <label>Giờ thuê tối đa</label>
                    <input type="number" id="inp_maxhours" class="fc" min="1" value="24" />
                </div>
            </div>
        </div>

        <!-- SERVICE options -->
        <div class="cond-panel panel-service" id="panelService">
            <div style="font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#7c3aed;margin-bottom:.75rem;display:flex;align-items:center;gap:.4rem;">
                <i class="bi bi-wrench-adjustable"></i> Cấu hình dịch vụ
            </div>
            <div class="toggle-group" style="grid-template-columns:1fr;">
                <label class="tg-item" id="tgSeparate">
                    <input type="checkbox" id="cb_separate" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-scissors me-1" style="color:#7c3aed"></i>Tách tiền công / vật tư</div>
                        <div class="tg-hint">VD: Căng vợt = tiền công + dây cước riêng</div>
                    </div>
                </label>
                <label class="tg-item" id="tgCustMaterial">
                    <input type="checkbox" id="cb_custmat" />
                    <div class="tg-dot"></div>
                    <div class="tg-body">
                        <div class="tg-label"><i class="bi bi-person-gear me-1" style="color:#0369a1"></i>Khách tự mang vật tư</div>
                        <div class="tg-hint">Khách mang dây/phụ kiện, chỉ tính công</div>
                    </div>
                </label>
            </div>
            <div style="margin-top:.85rem;">
                <div class="fl">
                    <label>Mô hình tính giá</label>
                    <select id="inp_pricing" class="fc">
                        <option value="Fixed">Giá cố định</option>
                        <option value="PerUnit">Theo số lượng</option>
                        <option value="PerHour">Theo giờ</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Ảnh đại diện -->
        <div class="section-hd" style="margin-top:1.2rem;"><i class="bi bi-image"></i> Ảnh đại diện (tùy chọn)</div>
        <div class="upload-zone" onclick="document.getElementById('catImgInput').click()">
            <i class="bi bi-cloud-arrow-up"></i>
            <p>Nhấn để chọn ảnh · JPG, PNG · Tối đa 5MB</p>
        </div>
        <input type="file" id="catImgInput" accept="image/*" style="display:none" onchange="previewImg(this)" />
        <div id="imgPreview"></div>
    </div>
</div>

<!-- MODAL FOOTER -->
<div class="md-ft">
    <button class="btn-secondary" data-bs-dismiss="modal">Hủy</button>
    <button class="btn-primary" id="btnSubmit" style="display:none;" onclick="submitForm()">
        <i class="bi bi-check-lg"></i> Tạo danh mục
    </button>
</div>

<script>
    // ── State ──
    let selectedPreset = null;
    let selectedBh = 'Retail';

    // ── PRESETS CONFIG ──
    const PRESETS = {
        beverage: {
            bh: 'Retail', type: 'Beverage', unit: 'Chai',
            names: ['Nước uống', 'Thức uống', 'Đồ ăn nhanh', 'Snack & Bánh'],
            desc: 'Đồ ăn, thức uống bán tại quầy',
            expiry: true, fifo: true, batch: false, variants: false, minstock: 20
        },
        rental: {
            bh: 'Rental', type: 'Equipment', unit: 'Cái',
            names: ['Vợt cho thuê', 'Giày cho thuê', 'Quần áo cho thuê', 'Túi cho thuê'],
            desc: 'Dụng cụ thể thao cho thuê theo giờ',
            size: true, deposit: true, partial: true, maxhours: 8, depositAmt: 50000
        },
        service: {
            bh: 'Service', type: 'Equipment', unit: 'Lần',
            names: ['Căng vợt', 'Sửa vợt', 'Huấn luyện cá nhân', 'Thuê HLV'],
            desc: 'Dịch vụ sửa chữa và huấn luyện',
            separate: true, custmat: true, pricing: 'Fixed'
        },
        accessory: {
            bh: 'Retail', type: 'Clothing', unit: 'Cái',
            names: ['Quần áo thể thao', 'Phụ kiện cầu lông', 'Băng quấn', 'Tất/Bao tay'],
            desc: 'Quần áo và phụ kiện bán ra',
            expiry: false, fifo: false, batch: true, variants: true, minstock: 5
        },
        equipment: {
            bh: 'Retail', type: 'Equipment', unit: 'Cái',
            names: ['Vợt cầu lông', 'Cầu lông', 'Túi đựng vợt', 'Phụ kiện vợt'],
            desc: 'Dụng cụ thể thao bán ra',
            expiry: false, fifo: true, batch: true, variants: false, minstock: 3
        },
        custom: {
            bh: 'Retail', type: '', unit: 'Cái',
            names: [], desc: '',
            expiry: false, fifo: false, batch: false, variants: false, minstock: 0
        }
    };

    // ── STEP NAVIGATION ──
    function goStep(n) {
        [1,2,3].forEach(i => {
            document.getElementById('step'+i).style.display = i===n ? 'block' : 'none';
            const ind = document.getElementById('stepInd'+i);
            ind.classList.remove('on','done');
            if(i < n) ind.classList.add('done');
            else if(i === n) ind.classList.add('on');
        });
        if(n===3){ applyBhPreset(); document.getElementById('btnSubmit').style.display='inline-flex'; }
        else { document.getElementById('btnSubmit').style.display='none'; }
    }

    // ── APPLY PRESET ──
    function applyPreset(key) {
        selectedPreset = key;
        document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('selected'));
        document.getElementById('pc-'+key).classList.add('selected');
        document.getElementById('btnStep1Next').disabled = false;

        const p = PRESETS[key];
        if(!p) return;

        // Pre-fill step 2
        document.getElementById('inp_type').value    = p.type || '';
        document.getElementById('inp_unit').value    = p.unit || 'Cái';
        document.getElementById('inp_desc').value    = p.desc || '';
        selectedBh = p.bh;

        // Show name suggestions
        const sugBox = document.getElementById('nameSuggestions');
        if(p.names && p.names.length) {
            sugBox.style.display = 'flex';
            sugBox.innerHTML = p.names.map(n =>
                `<button type="button" onclick="pickName('${n}')" style="padding:.22rem .65rem;border:1px solid var(--border);border-radius:5px;font-size:.72rem;cursor:pointer;background:#fff;color:var(--deep);transition:all .15s;"
                onmouseover="this.style.borderColor='var(--gold)'" onmouseout="this.style.borderColor='var(--border)'">${n}</button>`
            ).join('');
        } else {
            sugBox.style.display = 'none';
            sugBox.innerHTML = '';
        }

        updatePreview();
    }

    function pickName(name) {
        document.getElementById('inp_name').value = name;
        updatePreview();
    }

    // ── APPLY BH TO STEP 3 ──
    function applyBhPreset() {
        selectBh(selectedBh);
        const p = PRESETS[selectedPreset];
        if(!p) return;

        if(selectedBh === 'Retail') {
            setToggle('tgHsd',    'cb_expiry',   p.expiry||false);
            setToggle('tgFifo',   'cb_fifo',     p.fifo||false);
            setToggle('tgBatch',  'cb_batch',    p.batch||false);
            setToggle('tgVariants','cb_variants', p.variants||false);
            document.getElementById('inp_minstock').value = p.minstock || 0;
        } else if(selectedBh === 'Rental') {
            setToggle('tgSize',    'cb_size',    p.size||false);
            setToggle('tgDeposit', 'cb_deposit', p.deposit||false);
            setToggle('tgPartial', 'cb_partial', p.partial||false);
            if(p.depositAmt) document.getElementById('inp_deposit').value = p.depositAmt;
            if(p.maxhours)   document.getElementById('inp_maxhours').value = p.maxhours;
            if(p.deposit) document.getElementById('depositAmountRow').style.display = 'grid';
        } else if(selectedBh === 'Service') {
            setToggle('tgSeparate',   'cb_separate', p.separate||false);
            setToggle('tgCustMaterial','cb_custmat',  p.custmat||false);
            if(p.pricing) document.getElementById('inp_pricing').value = p.pricing;
        }
    }

    function setToggle(itemId, cbId, on) {
        const item = document.getElementById(itemId);
        const cb   = document.getElementById(cbId);
        if(!item || !cb) return;
        cb.checked = on;
        item.classList.toggle('on', on);
    }

    // ── BEHAVIOR SELECT ──
    function selectBh(val) {
        selectedBh = val;
        ['Retail','Rental','Service'].forEach(b => {
            document.getElementById('bh'+b)?.classList.remove('on-retail','on-rental','on-service');
        });
        document.getElementById('bh'+val)?.classList.add('on-'+val.toLowerCase());
        document.getElementById('panelRetail').classList.toggle('show', val==='Retail');
        document.getElementById('panelRental').classList.toggle('show', val==='Rental');
        document.getElementById('panelService').classList.toggle('show', val==='Service');
    }

    // ── TOGGLE ITEMS ──
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.tg-item').forEach(item => {
            item.addEventListener('click', () => {
                const cb = item.querySelector('input[type=checkbox]');
                cb.checked = !cb.checked;
                item.classList.toggle('on', cb.checked);
                // Show deposit row if deposit toggle
                if(cb.id === 'cb_deposit') {
                    document.getElementById('depositAmountRow').style.display = cb.checked ? 'grid' : 'none';
                }
            });
        });
    });

    // ── PREVIEW ──
    const TYPE_ICONS = { Food:'bi-egg-fried', Beverage:'bi-cup-straw', Equipment:'bi-gear', Clothing:'bi-bag-heart', Accessory:'bi-watch', Other:'bi-folder2-open' };
    const TYPE_COLORS = { Food:'#b45309', Beverage:'#0369a1', Equipment:'#166534', Clothing:'#7e22ce', Accessory:'#be185d', Other:'var(--muted)' };
    const TYPE_BG = { Food:'#fffbeb', Beverage:'#f0f9ff', Equipment:'#f0fdf4', Clothing:'#faf5ff', Accessory:'#fdf2f8', Other:'var(--warm)' };
    const BH_LABELS = { Retail:'Bán lẻ', Rental:'Cho thuê', Service:'Dịch vụ' };
    const BH_COLORS = { Retail:'#166534', Rental:'#1d4ed8', Service:'#7c3aed' };
    const BH_BG     = { Retail:'#f0fdf4', Rental:'#eff6ff', Service:'#f5f3ff' };

    function updatePreview() {
        const name = document.getElementById('inp_name').value || 'Tên danh mục';
        const type = document.getElementById('inp_type').value;
        document.getElementById('pvName').textContent = name;
        document.getElementById('pvMeta').textContent = type ? TYPE_ICONS[type]?.replace('bi-','') : 'Loại hàng hóa';
        const icon = document.getElementById('pvIcon');
        icon.style.background = TYPE_BG[type] || 'var(--warm)';
        icon.innerHTML = `<i class="bi ${TYPE_ICONS[type]||'bi-folder2-open'}" style="color:${TYPE_COLORS[type]||'var(--muted)'}"></i>`;
        const bh = selectedBh || 'Retail';
        document.getElementById('pvBadge').innerHTML =
            `<span style="display:inline-flex;align-items:center;gap:.28rem;padding:.2rem .6rem;border-radius:4px;font-size:.66rem;font-weight:700;background:${BH_BG[bh]};color:${BH_COLORS[bh]};">${BH_LABELS[bh]}</span>`;
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('inp_type').addEventListener('change', updatePreview);
    });

    // ── IMAGE PREVIEW ──
    function previewImg(input) {
        const file = input.files[0];
        if(!file) return;
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('imgPreview').innerHTML =
                `<div style="position:relative;display:inline-block;margin-top:.5rem;">
                    <img src="${e.target.result}" style="max-height:90px;border-radius:6px;border:1px solid var(--border);">
                    <button type="button" onclick="clearImg()" style="position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:var(--red);color:#fff;border:none;cursor:pointer;font-size:.6rem;display:flex;align-items:center;justify-content:center;"><i class="bi bi-x"></i></button>
                </div>`;
        };
        reader.readAsDataURL(file);
    }
    function clearImg() {
        document.getElementById('catImgInput').value = '';
        document.getElementById('imgPreview').innerHTML = '';
    }

    // ── SUBMIT ──
    async function submitForm() {
        const name = document.getElementById('inp_name').value.trim();
        if(!name){ alert('Vui lòng nhập tên danh mục!'); return; }
        const type = document.getElementById('inp_type').value;
        if(!type){ alert('Vui lòng chọn loại hàng hóa!'); return; }

        const btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang tạo...';

        const fd = new FormData();
        fd.append('CategoryName',    name);
        fd.append('CategoryType',    type);
        fd.append('BehaviorType',    selectedBh);
        fd.append('DefaultUnit',     document.getElementById('inp_unit').value);
        fd.append('Description',     document.getElementById('inp_desc').value);
        fd.append('DisplayOrder',    document.getElementById('inp_order').value);
        fd.append('IsActive',        document.getElementById('inp_active').value);

        // Retail
        fd.append('RequiresExpiry',  document.getElementById('cb_expiry')?.checked  ? 'true':'false');
        fd.append('UseFIFO',         document.getElementById('cb_fifo')?.checked    ? 'true':'false');
        fd.append('RequiresBatch',   document.getElementById('cb_batch')?.checked   ? 'true':'false');
        fd.append('HasVariants',     document.getElementById('cb_variants')?.checked? 'true':'false');
        fd.append('DefaultMinStock', document.getElementById('inp_minstock')?.value || '0');
        // Rental
        fd.append('RequiresSize',        document.getElementById('cb_size')?.checked    ? 'true':'false');
        fd.append('DepositRequired',     document.getElementById('cb_deposit')?.checked  ? 'true':'false');
        fd.append('AllowPartialReturn',  document.getElementById('cb_partial')?.checked  ? 'true':'false');
        fd.append('DefaultDepositAmount',document.getElementById('inp_deposit')?.value   || '0');
        fd.append('MaxRentalHours',      document.getElementById('inp_maxhours')?.value  || '24');
        // Service
        fd.append('SeparateLaborAndMaterial', document.getElementById('cb_separate')?.checked ? 'true':'false');
        fd.append('AllowCustomerMaterial',    document.getElementById('cb_custmat')?.checked  ? 'true':'false');
        fd.append('PricingModel',             document.getElementById('inp_pricing')?.value    || 'Fixed');

        const imgFile = document.getElementById('catImgInput').files[0];
        if(imgFile) fd.append('CategoryImage', imgFile);

        const TOKEN_MODAL = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        try {
            const res = await fetch('/Admin/AdminCategory/CreateAjax', {
                method: 'POST',
                headers: { 'RequestVerificationToken': TOKEN_MODAL },
                body: fd
            }).then(r => r.json());

            if(res.success) {
                // Close modal and reload
                bootstrap.Modal.getInstance(document.getElementById('catModal'))?.hide();
                location.reload();
            } else {
                alert(res.message || 'Có lỗi xảy ra!');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg"></i> Tạo danh mục';
            }
        } catch(e) {
            alert('Lỗi kết nối!');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-lg"></i> Tạo danh mục';
        }
    }
</script>
