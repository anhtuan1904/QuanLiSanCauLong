</div><!-- /db -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
                const G='#d4a017',G2='#f5c842',D='#1a1209',GN='#10b981',BL='#3b82f6',PU='#8b5cf6',OR='#f97316',RD='#ef4444',TE='#14b8a6',PI='#f43f5e';
                Chart.defaults.font.family="'Space Grotesk', sans-serif";
                Chart.defaults.color='#8a7560';

                /* ── CLOCK ── */
                (function tick(){const n=new Date(),p=v=>String(v).padStart(2,'0');document.getElementById('clk').textContent=`${p(n.getHours())}:${p(n.getMinutes())}:${p(n.getSeconds())}`;setTimeout(tick,1000);})();

                /* ── SPARKLINES ── */
                const spD=[[28,32,29,35,38,33,42,40],[42,56,49,63,72,58,88,75],[12,18,14,22,19,25,28,31],[72,68,75,80,77,83,87,85],[2.1,2.8,2.3,3.1,2.9,3.5,3.8,3.6],[4.5,4.6,4.7,4.7,4.8,4.8,4.9,4.8],[8,15,10,12,14,18,12,12],[10,14,12,16,18,20,18,18]];
                const spC=[G,GN,BL,RD,PU,TE,OR,PI];
                for(let i=1;i<=8;i++){const el=document.getElementById('sp'+i);if(!el)continue;new Chart(el,{type:'line',data:{labels:spD[i-1].map((_,j)=>j),datasets:[{data:spD[i-1],borderColor:spC[i-1],backgroundColor:'transparent',borderWidth:1.5,pointRadius:0,tension:.42}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{enabled:false}},scales:{x:{display:false},y:{display:false}}}});}

                /* ── REVENUE CHART — dữ liệu thật từ Model.RevenueByDate ── */
                const dbLabels  = [@foreach(var r in Model.RevenueByDate){
                <text>'@r.Date.ToString("dd/MM")',</text>
        }
    ];
        const dbBooking = [@foreach(var r in Model.RevenueByDate){
        <text>@r.BookingRevenue,</text>
                        }
    ];
        const dbProduct = [@foreach(var r in Model.RevenueByDate){
        <text>@r.ProductRevenue,</text>
                        }
    ];
        const dbTotal   = [@foreach(var r in Model.RevenueByDate){
        <text>@r.TotalRevenue,</text>
                        }
    ];
        const dbAvg    = dbTotal.length ? dbTotal.reduce((a,b)=>a+b,0)/dbTotal.length : 0;
        const dbTarget = dbTotal.map(()=>+(dbAvg*1.15).toFixed(0));
        const rChart=new Chart(document.getElementById('revChart'),{
          type:'bar',
          data:{labels:dbLabels,datasets:[
            {label:'Sân',data:dbBooking,backgroundColor:'rgba(212,160,23,.72)',borderRadius:{topLeft:4,topRight:4},borderSkipped:false,order:2},
            {label:'Sản phẩm',data:dbProduct,backgroundColor:'rgba(16,185,129,.62)',borderRadius:{topLeft:4,topRight:4},borderSkipped:false,order:2},
            {label:'Mục tiêu',data:dbTarget,type:'line',borderColor:'rgba(26,18,9,.28)',borderDash:[5,5],borderWidth:2,pointRadius:0,fill:false,order:1},
          ]},
          options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{grid:{color:'rgba(0,0,0,.04)'},ticks:{callback:v=>v>=1e6?'₫'+(v/1e6).toFixed(1)+'tr':'₫'+v.toLocaleString('vi-VN')}}}}
        });
        function swPeriod(p,btn){
          document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on'));
          btn.classList.add('on');
        }

        /* ── COURT CHART — dữ liệu thật từ Model.PopularTimeSlots ── */
        @if (Model.PopularTimeSlots != null && Model.PopularTimeSlots.Any())
        {
                    <text>
                    const crtLabels=[@foreach(var s in Model.PopularTimeSlots){
                    <text>'@s.TimeSlot',</text>
            }
    ];
            const crtData  =[@foreach(var s in Model.PopularTimeSlots){
            <text>@s.BookingCount,</text>
                                        }
    ];
            </text>
                        }
                        else
        {
                    <text>const crtLabels=['6h','8h','10h','12h','14h','16h','18h','20h'];const crtData=[0,0,0,0,0,0,0,0];</text>
        }
        new Chart(document.getElementById('crtChart'),{
          type:'bar',data:{labels:crtLabels,datasets:[{label:'Lượt đặt',data:crtData,backgroundColor:ctx=>{const v=ctx.parsed.y,mx=Math.max(...crtData)||1;return v>=mx*.9?G:v>=mx*.6?'rgba(212,160,23,.55)':'rgba(212,160,23,.28)';},borderRadius:6}]},
          options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{grid:{color:'rgba(0,0,0,.04)'},beginAtZero:true,ticks:{callback:v=>v+' đặt'}},x:{grid:{display:false}}}}
        });

        /* ── TIME CHART — tái dùng crtLabels/crtData ── */
        new Chart(document.getElementById('tChart'),{
          type:'bar',data:{labels:crtLabels,datasets:[{data:crtData,backgroundColor:ctx=>{const v=ctx.parsed.y,mx=Math.max(...crtData)||1;return v>=mx*.9?G:v>=mx*.6?'rgba(212,160,23,.65)':v>=mx*.4?'rgba(212,160,23,.42)':'rgba(212,160,23,.2)';},borderRadius:3}]},
          options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{display:false},x:{grid:{display:false},ticks:{font:{size:9}}}}}
        });

        /* ── CAT DONUT — dữ liệu thật từ Model.TopProducts ── */
        @if (Model.TopProducts != null && Model.TopProducts.Any())
        {
                    <text>
                    const catLabels=[@foreach(var p in Model.TopProducts.Take(5)){
                    <text>'@Html.Raw(p.ProductName.Replace("'", ""))',</text>
            }
    ];
            const catData  =[@foreach(var p in Model.TopProducts.Take(5)){
            <text>@p.QuantitySold,</text>
                                        }
    ];
            </text>
                        }
                        else
        {
                    <text>const catLabels=['Chưa có dữ liệu'];const catData=[1];</text>
        }
        const catColors=[G,D,'#c94b2a','#8a7560',BL,'#14b8a6','#f97316'];
        new Chart(document.getElementById('catChart'),{
          type:'doughnut',data:{labels:catLabels,datasets:[{data:catData,backgroundColor:catColors.slice(0,catLabels.length),borderWidth:0,hoverOffset:5}]},
          options:{responsive:true,maintainAspectRatio:false,cutout:'65%',plugins:{legend:{position:'right',labels:{padding:10,usePointStyle:true,pointStyleWidth:8,font:{size:10}}}}}
        });

        /* ── HEATMAP — dữ liệu thật từ Model.HeatmapData ── */
        (function(){
          const hours=['6h','7h','8h','9h','10h','11h','12h','13h','14h','15h','16h','17h','18h','19h','20h','21h','22h'];
          const days=['T2','T3','T4','T5','T6','T7','CN'];
          @{
                  // Serialize HeatmapData[7,24] thành JS 2D array
                  // Chỉ hiện giờ 6–22 (index 6..22)
                  var hmHours = Enumerable.Range(6, 17).ToList();
          }
          const data=[
              @for (int d = 0; d < 7; d++)
            {
                      <text>[</text>
                      @for (int idx = 0; idx < hmHours.Count; idx++)
                    {
                              var h = hmHours[idx];
                              <text>@(Model.HeatmapData != null ? Model.HeatmapData[d, h] : 0)@(idx < hmHours.Count - 1 ? "," : "")</text>
                      }
                      <text>]@(d < 6 ? "," : "")</text>
              }
          ];
          var maxVal=Math.max(...data.flat())||1;
          let h='<div class="hm-wrap"><div></div>';
          days.forEach(d=>{h+=`<div class="hm-dlbl">${d}</div>`;});
          hours.forEach((hr,hi)=>{
            h+=`<div class="hm-hlbl">${hr}</div>`;
            data.forEach((dd,di)=>{
              var cnt=dd[hi]||0;
              var lvl=cnt===0?0:cnt<=Math.round(maxVal*.2)?1:cnt<=Math.round(maxVal*.4)?2:cnt<=Math.round(maxVal*.7)?3:cnt<=Math.round(maxVal*.9)?4:5;
              h+=`<div class="hm-cell l${lvl}" title="${days[di]} ${hr}: ${cnt} đặt sân"></div>`;
            });
          });
          h+='</div>';document.getElementById('hmWrap').innerHTML=h;
        })();

        /* ── FORECAST 7 ngày tới — dữ liệu thật từ Model.ForecastDays ── */
        (function(){
          @{
                  var maxFcRev = Model.ForecastDays != null && Model.ForecastDays.Any()
                          ? Model.ForecastDays.Max(f => f.Revenue) : 1m;
                  if (maxFcRev == 0) maxFcRev = 1m;
          }
          const days=['T2','T3','T4','T5','T6','T7','CN'];
          const tod=(new Date().getDay()+6)%7;
          const fcData=[
              @if (Model.ForecastDays != null)
            {
                      @foreach (var f in Model.ForecastDays)
                    {
                              <text>{date:'@f.Date.ToString("dd")',dow:@((int)f.Date.DayOfWeek == 0 ? 6 : (int)f.Date.DayOfWeek - 1),rev:@f.Revenue,cnt:@f.BookingCount,bar:@((int)Math.Round((double)(f.Revenue / maxFcRev) * 100))},</text>
                      }
              }
          ];
          let h='';
          fcData.forEach((f,i)=>{
            var revStr=f.rev>=1000000?(f.rev/1000000).toFixed(1)+'tr':(f.rev/1000).toFixed(0)+'k';
            h+=`<div class="fc-d${f.dow===tod?' tod':''}"><div class="fc-dn">${days[f.dow]}</div><div class="fc-num">${f.date}</div><div class="fc-rev">₫${revStr}</div><div class="fc-bar" style="width:${f.bar}%;"></div></div>`;
          });
          document.getElementById('fcRow').innerHTML=h||'<div style="color:var(--M);font-size:.78rem;padding:.5rem">Chưa có lịch đặt trước</div>';
        })();
</script>
}
