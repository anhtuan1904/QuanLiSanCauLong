        font-size: .73rem;
        font-weight: 700;
        padding: .44rem 1rem;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .gbtn:hover {
            background: var(--G2);
            color: var(--D2);
        }

    .dbtn {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        background: var(--D2);
        color: rgba(255,255,255,.75);
        border: none;
        border-radius: var(--r3);
        font-size: .73rem;
        font-weight: 600;
        padding: .44rem 1rem;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .dbtn:hover {
            background: var(--D);
