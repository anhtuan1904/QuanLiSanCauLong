        text-overflow: ellipsis;
    }

    .tc-meta {
        font-size: .68rem;
        color: var(--M);
    }

    .tc-val {
        font-family: 'Syne',sans-serif;
        font-size: .88rem;
        font-weight: 800;
        color: var(--G);
    }

    .tc-badge {
        font-size: .58rem;
        font-weight: 700;
        padding: .1rem .42rem;
        border-radius: 3px;
        background: var(--G3);
