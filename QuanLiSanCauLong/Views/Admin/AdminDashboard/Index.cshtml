@model QuanLiSanCauLong.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var now = DateTime.Now;
    var hour = now.Hour;
    var greeting = hour < 5 ? "Chào đêm muộn" : hour < 12 ? "Chào buổi sáng" : hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";
}

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">

<style>
    /* ═══════════════════════════════ TOKENS ═══════════════════════════════ */
    :root {
        --D: #0d0a05;
        --D2: #1a1209;
        --D3: #261b0d;
        --D4: #2e2011;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.2);
        --C: #fdf8f0;
        --W: #f5ede0;
        --S: #e8ddd0;
        --S2: #d5c9ba;
        --M: #8a7560;
        --M2: #6b5b49;
        --GN: #10b981;
        --GN2: rgba(16,185,129,.1);
        --BL: #3b82f6;
        --BL2: rgba(59,130,246,.1);
        --RD: #ef4444;
        --RD2: rgba(239,68,68,.1);
        --PU: #8b5cf6;
        --PU2: rgba(139,92,246,.1);
        --OR: #f97316;
        --OR2: rgba(249,115,22,.1);
        --TE: #14b8a6;
        --TE2: rgba(20,184,166,.1);
        --PI: #f43f5e;
        --PI2: rgba(244,63,94,.1);
        --r: 14px;
        --r2: 10px;
        --r3: 8px;
        --sh: 0 2px 12px rgba(26,18,9,.07);
        --sh2: 0 8px 32px rgba(26,18,9,.12);
        --sh3: 0 20px 60px rgba(26,18,9,.18);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .db {
        font-family: 'Space Grotesk',sans-serif;
        color: var(--D2);
        max-width: 1680px;
        padding-bottom: 4rem;
    }

    /* ─── HERO BAND ─── */
    .hero {
        background: var(--D2);
        border-radius: var(--r);
        padding: 1.75rem 2rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 360px;
            height: 360px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(212,160,23,.13) 0%,transparent 70%);
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--G),var(--G2),transparent 80%);
        }

    .hero-l {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .hero-greet {
        font-size: .65rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--G);
        font-weight: 600;
        margin-bottom: .35rem;
    }

    .hero-name {
        font-family: 'Syne',sans-serif;
        font-size: 1.55rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
    }

        .hero-name em {
            color: var(--G2);
            font-style: normal;
        }

    .hero-sub {
        font-size: .77rem;
        color: rgba(255,255,255,.32);
        margin-top: .3rem;
        font-weight: 300;
    }

    .hero-divider {
        width: 1px;
        height: 48px;
        background: rgba(255,255,255,.08);
        flex-shrink: 0;
    }

    .hero-kpi {
        text-align: center;
    }

    .hero-kpi-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.35rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .hero-kpi-lbl {
        font-size: .62rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.32);
        margin-top: .2rem;
    }

    .hero-r {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
    }

    .clock-box {
        text-align: right;
    }

    .clock-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--G2);
        letter-spacing: .04em;
        line-height: 1;
    }

    .clock-date {
        font-size: .65rem;
        color: rgba(255,255,255,.3);
        margin-top: .2rem;
    }

    .live-badge {
        display: flex;
        align-items: center;
        gap: .4rem;
        background: rgba(16,185,129,.12);
        border: 1px solid rgba(16,185,129,.25);
        border-radius: 6px;
        padding: .35rem .8rem;
        font-size: .7rem;
        font-weight: 700;
        color: var(--GN);
    }

    .live-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--GN);
        box-shadow: 0 0 0 0 rgba(16,185,129,.5);
        animation: ping 1.8s ease-in-out infinite;
    }

    @@keyframes ping {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(16,185,129,.4);
        }

        60% {
            box-shadow: 0 0 0 6px transparent;
        }
    }

    .hbtn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1rem;
        border-radius: var(--r3);
        font-size: .75rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        border: none;
        font-family: 'Space Grotesk',sans-serif;
    }

    .hbtn-g {
        background: var(--G);
        color: var(--D2);
    }

        .hbtn-g:hover {
            background: var(--G2);
            color: var(--D2);
        }

    .hbtn-o {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        color: rgba(255,255,255,.6);
    }

        .hbtn-o:hover {
            background: rgba(255,255,255,.14);
            color: #fff;
        }

    /* ─── AI ALERT ─── */
    .ai-bar {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: linear-gradient(135deg,rgba(139,92,246,.09),rgba(212,160,23,.05));
        border: 1px solid rgba(139,92,246,.28);
        border-radius: var(--r);
        padding: .9rem 1.3rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        row-gap: .6rem;
    }

    .ai-bar-tag {
        background: var(--PU);
        color: #fff;
        font-size: .55rem;
        font-weight: 800;
        letter-spacing: .14em;
        text-transform: uppercase;
        padding: .18rem .55rem;
        border-radius: 4px;
        flex-shrink: 0;
        margin-top: .15rem;
    }

    .ai-bar-msg {
        font-size: .82rem;
        color: var(--D2);
        flex: 1;
        line-height: 1.55;
    }

        .ai-bar-msg strong {
            color: var(--PU);
        }

    .ai-bar-link {
        font-size: .73rem;
        font-weight: 700;
        color: var(--PU);
        text-decoration: none;
        border-bottom: 1px solid rgba(139,92,246,.4);
        white-space: nowrap;
        align-self: center;
    }

        .ai-bar-link:hover {
            color: var(--G);
        }

    /* ─── 8-KPI GRID ─── */
    .kpi8 {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .9rem;
        margin-bottom: 1.5rem;
    }

    .kc {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        padding: 1.3rem 1.5rem;
        position: relative;
        overflow: hidden;
        transition: transform .22s,box-shadow .22s;
        cursor: default;
    }

        .kc:hover {
            transform: translateY(-3px);
            box-shadow: var(--sh2);
        }

        .kc::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            opacity: 0;
            transition: opacity .3s;
            border-radius: var(--r) var(--r) 0 0;
        }

        .kc:hover::before {
            opacity: 1;
        }

        .kc.cg::before {
            background: linear-gradient(90deg,var(--G),var(--G2));
        }

        .kc.cgn::before {
            background: linear-gradient(90deg,var(--GN),#34d399);
        }

        .kc.cbl::before {
            background: linear-gradient(90deg,var(--BL),#60a5fa);
        }

        .kc.crd::before {
            background: linear-gradient(90deg,var(--RD),var(--OR));
        }

        .kc.cpu::before {
            background: linear-gradient(90deg,var(--PU),#a78bfa);
        }

        .kc.cte::before {
            background: linear-gradient(90deg,var(--TE),#2dd4bf);
        }

        .kc.cor::before {
            background: linear-gradient(90deg,var(--OR),var(--G));
        }

        .kc.cpi::before {
            background: linear-gradient(90deg,var(--PI),#fb7185);
        }

    .kc-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: .85rem;
    }

    .kc-ico {
        width: 40px;
        height: 40px;
        border-radius: var(--r3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .ig {
        background: var(--G3);
        color: var(--G);
    }

    .ign {
        background: var(--GN2);
        color: var(--GN);
    }

    .ibl {
        background: var(--BL2);
        color: var(--BL);
    }

    .ird {
        background: var(--RD2);
        color: var(--RD);
    }

    .ipu {
        background: var(--PU2);
        color: var(--PU);
    }

    .ite {
        background: var(--TE2);
        color: var(--TE);
    }

    .ior {
        background: var(--OR2);
        color: var(--OR);
    }

    .ipi {
        background: var(--PI2);
        color: var(--PI);
    }

    .kbadge {
        font-size: .65rem;
        font-weight: 700;
        padding: .2rem .55rem;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: .2rem;
    }

    .up {
        background: var(--GN2);
        color: var(--GN);
    }

    .dn {
        background: var(--RD2);
        color: var(--RD);
    }

    .fl {
        background: rgba(138,117,96,.1);
        color: var(--M);
    }

    .kval {
        font-family: 'Syne',sans-serif;
        font-size: 1.65rem;
        font-weight: 800;
        color: var(--D2);
        line-height: 1;
        letter-spacing: -.02em;
    }

    .klbl {
        font-size: .73rem;
        color: var(--M);
        margin-top: .25rem;
        font-weight: 400;
    }

    .ksub {
        font-size: .67rem;
        color: var(--M);
        opacity: .65;
        margin-top: .14rem;
    }

    .kspk-wrap {
        height: 28px;
        margin-top: .75rem;
        position: relative;
    }

        .kspk-wrap canvas {
            position: absolute;
            inset: 0;
        }

    /* ─── PANEL BASE ─── */
    .pnl {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
    }

    .pnl-h {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--S);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .pnl-hl {
        display: flex;
        flex-direction: column;
        gap: .15rem;
    }

    .pnl-tag {
        font-size: .6rem;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
    }

    .pnl-title {
        font-family: 'Syne',sans-serif;
        font-size: .98rem;
        font-weight: 800;
        color: var(--D2);
    }

    .pnl-b {
        padding: 1.3rem 1.5rem;
    }

    /* ─── PERIOD TABS ─── */
    .ptabs {
        display: flex;
        gap: .2rem;
    }

    .ptab {
        font-size: .68rem;
        font-weight: 600;
        padding: .28rem .7rem;
        border-radius: 6px;
        cursor: pointer;
        border: none;
        background: transparent;
        color: var(--M);
        transition: all .18s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .ptab.on {
            background: var(--G);
            color: var(--D2);
        }

        .ptab:hover:not(.on) {
            background: var(--W);
        }

    /* ─── COURT TILE ─── */
    .ct-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .65rem;
    }

    .ct {
        border-radius: var(--r2);
        padding: .9rem 1rem;
        position: relative;
        overflow: hidden;
        transition: transform .2s;
        cursor: default;
    }

        .ct:hover {
            transform: translateY(-1px);
        }

    .ct-av {
        background: rgba(16,185,129,.07);
        border: 1px solid rgba(16,185,129,.2);
    }

    .ct-oc {
        background: rgba(212,160,23,.08);
        border: 1px solid rgba(212,160,23,.22);
    }

    .ct-re {
        background: rgba(59,130,246,.07);
        border: 1px solid rgba(59,130,246,.2);
    }

    .ct-ma {
        background: rgba(239,68,68,.06);
        border: 1px solid rgba(239,68,68,.15);
    }

    .ct-num {
        font-family: 'Syne',sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        line-height: 1;
    }

    .ct-av .ct-num {
        color: var(--GN);
    }

    .ct-oc .ct-num {
        color: var(--G);
    }

    .ct-re .ct-num {
        color: var(--BL);
    }

    .ct-ma .ct-num {
        color: var(--RD);
    }

    .ct-lbl {
        font-size: .65rem;
        font-weight: 600;
        letter-spacing: .07em;
        text-transform: uppercase;
        margin-top: .2rem;
    }

    .ct-av .ct-lbl {
        color: var(--GN);
    }

    .ct-oc .ct-lbl {
        color: #92660a;
    }

    .ct-re .ct-lbl {
        color: var(--BL);
    }

    .ct-ma .ct-lbl {
        color: var(--RD);
    }

    .ct-sub {
        font-size: .67rem;
        color: var(--M);
        margin-top: .35rem;
        line-height: 1.45;
    }

    .ct-person {
        font-size: .7rem;
        color: var(--D2);
        font-weight: 500;
        margin-top: .2rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ct-mini-bar {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .35rem;
        margin-top: .75rem;
    }

    .ct-mini {
        text-align: center;
        padding: .4rem .3rem;
        border-radius: 6px;
    }

    .ct-mini-n {
        font-family: 'Syne',sans-serif;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .ct-mini-l {
        font-size: .58rem;
        color: var(--M);
        margin-top: .1rem;
    }

    /* ─── IOT GRID ─── */
    .iot-g {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .7rem;
    }

    .iot {
        background: var(--D2);
        border-radius: var(--r2);
        padding: 1rem 1.1rem;
        position: relative;
        overflow: hidden;
    }

        .iot::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
        }

        .iot.on::before {
            background: linear-gradient(90deg,var(--GN),#34d399);
        }

        .iot.wa::before {
            background: linear-gradient(90deg,var(--OR),#fbbf24);
        }

        .iot.of::before {
            background: linear-gradient(90deg,var(--RD),#f87171);
        }

        .iot.id::before {
            background: linear-gradient(90deg,var(--M),rgba(138,117,96,.3));
        }

    .iot-n {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: rgba(255,255,255,.38);
        margin-bottom: .55rem;
    }

    .iot-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .iot.on .iot-dot {
        background: var(--GN);
        box-shadow: 0 0 5px var(--GN);
        animation: ping 1.8s infinite;
    }

    .iot.wa .iot-dot {
        background: var(--OR);
    }

    .iot.of .iot-dot {
        background: var(--RD);
    }

    .iot-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.4rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .iot-unit {
        font-size: .65rem;
        color: rgba(255,255,255,.32);
        margin-left: .2rem;
    }

    .iot-sub {
        font-size: .63rem;
        color: rgba(255,255,255,.28);
        margin-top: .3rem;
    }

    .iot-track {
        height: 3px;
        background: rgba(255,255,255,.08);
        border-radius: 2px;
        margin-top: .6rem;
        overflow: hidden;
    }

    .iot-fill {
        height: 100%;
        border-radius: 2px;
        transition: width .9s ease;
    }

    /* ─── AI INSIGHTS ─── */
    .ins-list {
        display: flex;
        flex-direction: column;
        gap: .65rem;
    }

    .ins {
        padding: .9rem 1.1rem;
        border-radius: var(--r2);
        border-left: 3px solid transparent;
    }

        .ins.gd {
            border-color: var(--GN);
            background: rgba(16,185,129,.045);
        }

        .ins.wn {
            border-color: var(--OR);
            background: rgba(249,115,22,.045);
        }

        .ins.in {
            border-color: var(--BL);
            background: rgba(59,130,246,.045);
        }

        .ins.al {
            border-color: var(--RD);
            background: rgba(239,68,68,.045);
        }

    .ins-h {
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .3rem;
    }

    .ins-tag {
        font-size: .55rem;
        font-weight: 800;
        letter-spacing: .1em;
        text-transform: uppercase;
        padding: .13rem .48rem;
        border-radius: 3px;
    }

    .ins.gd .ins-tag {
        background: rgba(16,185,129,.15);
        color: var(--GN);
    }

    .ins.wn .ins-tag {
        background: rgba(249,115,22,.15);
        color: var(--OR);
    }

    .ins.in .ins-tag {
        background: rgba(59,130,246,.15);
        color: var(--BL);
    }

    .ins.al .ins-tag {
        background: rgba(239,68,68,.15);
        color: var(--RD);
    }

    .ins-title {
        font-size: .8rem;
        font-weight: 700;
        color: var(--D2);
    }

    .ins-body {
        font-size: .74rem;
        color: var(--M);
        line-height: 1.58;
    }

    /* ─── HEATMAP ─── */
    .hm-wrap {
        display: grid;
        grid-template-columns: 36px repeat(7,1fr);
        gap: 2px;
    }

    .hm-dlbl {
        font-size: .6rem;
        color: var(--M);
        text-align: center;
        padding-bottom: .3rem;
        font-weight: 600;
        letter-spacing: .06em;
    }

    .hm-hlbl {
        font-size: .6rem;
        color: var(--M);
        text-align: right;
        padding-right: .3rem;
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .hm-cell {
        aspect-ratio: 1;
        border-radius: 3px;
        cursor: pointer;
        transition: transform .14s,box-shadow .14s;
    }

        .hm-cell:hover {
            transform: scale(1.25);
            box-shadow: 0 3px 10px rgba(0,0,0,.18);
            z-index: 2;
            position: relative;
        }

    .l0 {
        background: var(--S);
    }

    .l1 {
        background: rgba(212,160,23,.18);
    }

    .l2 {
        background: rgba(212,160,23,.38);
    }

    .l3 {
        background: rgba(212,160,23,.62);
    }

    .l4 {
        background: var(--G);
    }

    .l5 {
        background: var(--G2);
    }

    /* ─── FORECAST ─── */
    .fc-r {
        display: grid;
        grid-template-columns: repeat(7,1fr);
        gap: .4rem;
    }

    .fc-d {
        text-align: center;
        padding: .55rem .3rem;
        border-radius: var(--r3);
        background: var(--C);
        border: 1px solid var(--S);
    }

        .fc-d.tod {
            background: var(--G3);
            border-color: var(--G4);
        }

    .fc-dn {
        font-size: .58rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
    }

    .fc-num {
        font-family: 'Syne',sans-serif;
        font-size: .95rem;
        font-weight: 800;
        color: var(--D2);
        margin: .2rem 0;
    }

    .fc-rev {
        font-size: .6rem;
        color: var(--GN);
        font-weight: 700;
    }

    .fc-bar {
        height: 3px;
        border-radius: 2px;
