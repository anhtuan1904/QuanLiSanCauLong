        border-radius: var(--r3);
        font-size: .7rem;
        font-weight: 600;
        padding: .38rem .85rem;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .gbst:hover {
            border-color: var(--G);
            color: var(--G);
        }

    @@media(max-width:1280px) {
        .kpi8 {
            grid-template-columns: repeat(4,1fr);
        }
    }

    @@media(max-width:960px) {
        .kpi8 {
            grid-template-columns: repeat(2,1fr);
        }

        .hero-l {
            flex-wrap: wrap;
        }

        .ct-grid {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:600px) {
        .kpi8 {
            grid-template-columns: 1fr 1fr;
        }

        .iot-g {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="db">

    <!-- ══════════ HERO ══════════ -->
    <div class="hero mb-4">
        <div class="hero-l">
            <div>
                <div class="hero-greet">@greeting 👋</div>
                <div class="hero-name">Trung Tâm <em>Chỉ Huy</em></div>
                <div class="hero-sub">@now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</div>
            </div>
            <div class="hero-divider"></div>
            <div class="hero-kpi">
                <div class="hero-kpi-val">₫@Model.TotalRevenue.ToString("N0")</div>
                <div class="hero-kpi-lbl">Doanh thu hôm nay</div>
            </div>
            <div class="hero-divider"></div>
            <div class="hero-kpi">
                <div class="hero-kpi-val">@Model.TotalBookings</div>
                <div class="hero-kpi-lbl">Đơn đặt sân</div>
            </div>
            <div class="hero-divider"></div>
            <div class="hero-kpi">
                <div class="hero-kpi-val">@Model.OccupancyRate.ToString("0")%</div>
                <div class="hero-kpi-lbl">Lấp đầy sân</div>
            </div>
        </div>
        <div class="hero-r">
            <div class="clock-box">
                <div class="clock-val" id="clk">--:--:--</div>
                <div class="clock-date">Giờ hệ thống</div>
            </div>
            <div class="live-badge"><div class="live-dot"></div>Live</div>
            <a asp-controller="AdminReport" asp-action="Revenue" class="hbtn hbtn-g"><i class="bi bi-graph-up-arrow"></i> Báo cáo</a>
            <a asp-controller="AdminDashboard" asp-action="Analytics" class="hbtn hbtn-o"><i class="bi bi-bar-chart-line"></i> Analytics</a>
        </div>
    </div>

    <!-- ══════════ AI ALERT ══════════ -->
    <div class="ai-bar">
        <span class="ai-bar-tag">📊 Tổng quan</span>
        <div class="ai-bar-msg">
            <strong>Hôm nay:</strong>
            @Model.TotalBookings đơn đặt sân ·
            Doanh thu <strong>₫@Model.TotalRevenue.ToString("N0")</strong> ·
            @Model.CourtsOccupied/@(Model.LiveCourtStatuses?.Count ?? 0) sân đang có khách ·
            @if (Model.LowStockCount > 0)
            {
                <span style="color:var(--RD)"><strong>⚠ @Model.LowStockCount sản phẩm tồn kho thấp</strong> — cần bổ sung.</span>
            }
            @if (Model.VouchersUsed > 0)
            {
                <span>· @Model.VouchersUsed voucher đã dùng (tiết kiệm ₫@Model.VoucherDiscount.ToString("N0") cho khách).</span>
            }
        </div>
        <a class="ai-bar-link" asp-controller="AdminDashboard" asp-action="Analytics">Xem chi tiết →</a>
    </div>

    <!-- ══════════ KPI 8 ══════════ -->
    <div class="kpi8">
        <div class="kc cg">
            <div class="kc-top"><div class="kc-ico ig"><i class="bi bi-cash-stack"></i></div><span class="kbadge up"><i class="bi bi-arrow-up-short"></i>+12.5%</span></div>
            <div class="kval">₫@Model.TotalRevenue.ToString("N0")</div>
            <div class="klbl">Doanh Thu Hôm Nay</div>
            <div class="ksub">Mục tiêu: ₫@((Model.TotalRevenue * 1.15m).ToString("N0"))</div>
            <div class="kspk-wrap"><canvas id="sp1"></canvas></div>
        </div>
        <div class="kc cgn">
            <div class="kc-top"><div class="kc-ico ign"><i class="bi bi-calendar-check-fill"></i></div><span class="kbadge up"><i class="bi bi-arrow-up-short"></i>+8.2%</span></div>
            <div class="kval">@Model.TotalBookings</div>
            <div class="klbl">Đơn Đặt Sân</div>
            <div class="ksub">@((Model.TotalBookings / 2 > 0 ? Model.TotalBookings / 2 : 0)) đang chơi ngay bây giờ</div>
            <div class="kspk-wrap"><canvas id="sp2"></canvas></div>
        </div>
        <div class="kc cbl">
            <div class="kc-top">
                <div class="kc-ico ibl"><i class="bi bi-people-fill"></i></div>
                <span class="kbadge up"><i class="bi bi-arrow-up-short"></i>+@Model.NewCustomers mới</span>
            </div>
            <div class="kval">@Model.TotalCustomers</div>
            <div class="klbl">Tổng Khách Hàng</div>
            <div class="ksub">@Model.NewCustomers khách mới trong kỳ</div>
            <div class="kspk-wrap"><canvas id="sp3"></canvas></div>
        </div>
        <div class="kc crd">
            <div class="kc-top">
                <div class="kc-ico ird"><i class="bi bi-speedometer2"></i></div>
                <span class="kbadge @(Model.OccupancyRate >= 70 ? "up" : Model.OccupancyRate >= 40 ? "fl" : "dn")">
                    @Model.OccupancyRate.ToString("0")%
                </span>
            </div>
            <div class="kval">@Model.OccupancyRate.ToString("0")%</div>
            <div class="klbl">Tỷ Lệ Lấp Đầy Sân</div>
            <div class="ksub">@Model.CourtsOccupied đang có khách / @(Model.LiveCourtStatuses?.Count ?? Model.TotalCourts) sân</div>
            <div class="kspk-wrap"><canvas id="sp4"></canvas></div>
        </div>
        <div class="kc cpu">
            <div class="kc-top">
                <div class="kc-ico ipu"><i class="bi bi-bag-check-fill"></i></div>
                <span class="kbadge fl">@Model.TotalOrders đơn</span>
            </div>
            <div class="kval">₫@((Model.ProductRevenue / 1000000m).ToString("0.0"))tr</div>
            <div class="klbl">Doanh Thu Sản Phẩm</div>
            <div class="ksub">@Model.TotalOrders đơn hàng trong kỳ</div>
            <div class="kspk-wrap"><canvas id="sp5"></canvas></div>
        </div>
        <div class="kc cte">
            <div class="kc-top">
                <div class="kc-ico ite"><i class="bi bi-star-fill"></i></div>
                <span class="kbadge fl">@Model.OverallReviewCount đánh giá</span>
            </div>
            <div class="kval">@Model.OverallAverageRating.ToString("0.0")<span style="font-size:1rem;opacity:.45">★</span></div>
            <div class="klbl">Đánh Giá Trung Bình</div>
            <div class="ksub">@Model.OverallReviewCount đánh giá đã duyệt</div>
            <div class="kspk-wrap"><canvas id="sp6"></canvas></div>
        </div>
        <div class="kc cor">
            <div class="kc-top">
                <div class="kc-ico ior"><i class="bi bi-clock-history"></i></div>
                <span class="kbadge @(Model.PendingBookings > 10 ? "dn" : "fl")">@Model.PendingBookings</span>
            </div>
            <div class="kval">@Model.PendingBookings</div>
            <div class="klbl">Chờ Xác Nhận</div>
            <div class="ksub">@Model.CancelledBookings đơn đã hủy trong kỳ</div>
            <div class="kspk-wrap"><canvas id="sp7"></canvas></div>
        </div>
        <div class="kc cpi">
            <div class="kc-top">
                <div class="kc-ico ipi"><i class="bi bi-ticket-perforated-fill"></i></div>
                <span class="kbadge up"><i class="bi bi-arrow-up-short"></i>@Model.VouchersUsed</span>
            </div>
            <div class="kval">@Model.VouchersUsed</div>
            <div class="klbl">Voucher Đã Dùng</div>
            <div class="ksub">Giảm giá ₫@((Model.VoucherDiscount / 1000m).ToString("0"))k cho khách</div>
            <div class="kspk-wrap"><canvas id="sp8"></canvas></div>
        </div>
    </div>

    <!-- ══════════ ROW 2: REVENUE + COURT STATUS ══════════ -->
    <div class="row g-3 mb-3">
        <div class="col-xl-8">
            <div class="pnl">
                <div class="pnl-h">
                    <div class="pnl-hl"><div class="pnl-tag">Tài chính</div><div class="pnl-title">Doanh Thu & Đặt Sân</div></div>
                    <div style="display:flex;align-items:center;gap:.6rem;">
                        <div class="ptabs">
                            <button class="ptab on" onclick="swPeriod('7d',this)">7 Ngày</button>
                            <button class="ptab" onclick="swPeriod('30d',this)">30 Ngày</button>
                            <button class="ptab" onclick="swPeriod('12m',this)">12 Tháng</button>
                        </div>
                        <a asp-controller="AdminReport" asp-action="Revenue" class="gbst"><i class="bi bi-box-arrow-up-right"></i></a>
                    </div>
                </div>
                <div class="pnl-b">
                    <div style="position:relative;height:220px;"><canvas id="revChart"></canvas></div>
                    <div style="display:flex;gap:1.25rem;flex-wrap:wrap;margin-top:.9rem;">
                        <div style="display:flex;align-items:center;gap:.38rem;font-size:.72rem;color:var(--M);"><span style="display:inline-block;width:18px;height:3px;background:var(--G);border-radius:2px;"></span>Đặt sân</div>
                        <div style="display:flex;align-items:center;gap:.38rem;font-size:.72rem;color:var(--M);"><span style="display:inline-block;width:18px;height:3px;background:var(--GN);border-radius:2px;"></span>Sản phẩm</div>
                        <div style="display:flex;align-items:center;gap:.38rem;font-size:.72rem;color:var(--M);"><span style="display:inline-block;width:18px;height:3px;background:var(--D2);border-radius:2px;border-top:2px dashed;"></span>Mục tiêu</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="pnl" style="height:100%;">
                <div class="pnl-h">
                    <div class="pnl-hl"><div class="pnl-tag">Trạng thái thực tế</div><div class="pnl-title">Sân Hiện Tại</div></div>
                    <span class="live-badge" style="font-size:.62rem;padding:.28rem .65rem;"><div class="live-dot"></div>Live</span>
                </div>
                <div class="pnl-b">
                    <div class="ct-grid">
                        @if (Model.LiveCourtStatuses != null && Model.LiveCourtStatuses.Any())
                        {
                            @foreach (var cs in Model.LiveCourtStatuses.Take(6))
                            {
                                var tileClass = cs.LiveStatus switch
                                {
                                                "Occupied" => "ct-oc",
                                                "Reserved" => "ct-re",
                                                "Maintenance" => "ct-ma",
                                    _ => "ct-av"
                                };
                                var lbl = cs.LiveStatus switch
                                {
                                                "Occupied" => "Đang có khách",
                                                "Reserved" => "Đã đặt trước",
                                                "Maintenance" => "Bảo trì",
                                    _ => "Trống"
                                };
                                <div class="ct @tileClass">
                                    <div class="ct-num">@cs.CourtNumber</div>
                                    <div class="ct-lbl">@lbl</div>
                                    @if (!string.IsNullOrEmpty(cs.CurrentPlayer))
                                    {
                                        <div class="ct-person"><i class="bi bi-person-fill"></i> @cs.CurrentPlayer</div>
                                        <div class="ct-sub"><i class="bi bi-clock"></i> Còn @cs.RemainingMinutes phút</div>
                                    }
                                    else if (!string.IsNullOrEmpty(cs.NextPlayer))
                                    {
                                        <div class="ct-person"><i class="bi bi-person-fill"></i> @cs.NextPlayer</div>
                                        <div class="ct-sub">@cs.NextBookingTime</div>
                                    }
                                    else if (cs.LiveStatus == "Available")
                                    {
                                        <div class="ct-sub">Sẵn sàng nhận đặt</div>
                                    }
                                    else if (cs.LiveStatus == "Maintenance")
                                    {
                                        <div class="ct-sub">Đang bảo trì</div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div style="grid-column:span 3;text-align:center;padding:1.5rem;color:var(--M);font-size:.82rem;">
                                <i class="bi bi-building-x" style="font-size:1.5rem;display:block;margin-bottom:.5rem;"></i>
                                Chưa có dữ liệu sân
                            </div>
                        }
                    </div>
                    <div class="ct-mini-bar">
                        <div class="ct-mini" style="background:rgba(16,185,129,.07);"><div class="ct-mini-n" style="color:var(--GN)">@Model.CourtsAvailable</div><div class="ct-mini-l">Trống</div></div>
                        <div class="ct-mini" style="background:rgba(212,160,23,.07);"><div class="ct-mini-n" style="color:var(--G)">@Model.CourtsOccupied</div><div class="ct-mini-l">Có khách</div></div>
                        <div class="ct-mini" style="background:rgba(59,130,246,.07);"><div class="ct-mini-n" style="color:var(--BL)">@Model.CourtsReserved</div><div class="ct-mini-l">Đặt trước</div></div>
                        <div class="ct-mini" style="background:rgba(239,68,68,.07);"><div class="ct-mini-n" style="color:var(--RD)">@Model.CourtsOnMaintenance</div><div class="ct-mini-l">Bảo trì</div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════ ROW 3: IOT + AI + HEATMAP ══════════ -->
    <div class="row g-3 mb-3">
        <div class="col-xl-3 col-lg-4">
            <div class="pnl" style="height:100%;">
                <div class="pnl-h">
                    <div class="pnl-hl"><div class="pnl-tag">🔬 IoT Cảm biến</div><div class="pnl-title">Môi Trường Sân</div></div>
                    <span class="live-badge" style="font-size:.6rem;padding:.25rem .6rem;"><div class="live-dot"></div>Live</span>
                </div>
                <div class="pnl-b">
                    <div class="iot-g">
                        <div class="iot on">
                            <div class="iot-n">🌡️ Nhiệt độ<div class="iot-dot"></div></div>
                            <div class="iot-val">27<span class="iot-unit">°C</span></div>
                            <div class="iot-sub">Trong nhà · Sân A1, A2</div>
                            <div class="iot-track"><div class="iot-fill" style="width:54%;background:linear-gradient(90deg,var(--GN),var(--G));"></div></div>
                        </div>
                        <div class="iot on">
                            <div class="iot-n">💧 Độ ẩm<div class="iot-dot"></div></div>
                            <div class="iot-val">62<span class="iot-unit">%</span></div>
                            <div class="iot-sub">Khu trong nhà</div>
                            <div class="iot-track"><div class="iot-fill" style="width:62%;background:linear-gradient(90deg,var(--BL),#60a5fa);"></div></div>
                        </div>
                        <div class="iot wa">
