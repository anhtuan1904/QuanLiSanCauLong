</div><!-- /an -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const G='#d4a017',G2='#f5c842',D='#1a1209',GN='#10b981',BL='#3b82f6',PU='#8b5cf6',OR='#f97316';
        Chart.defaults.font.family="'Space Grotesk', sans-serif";
        Chart.defaults.color='#8a7560';

        /* ── DATE QUICK FILTERS ── */
        function qDate(type){
          const fd=document.getElementById('fromDate'),td=document.getElementById('toDate');
          const t=new Date(),fmt=d=>d.toISOString().split('T')[0];
          if(type==='today'){fd.value=td.value=fmt(t);}
          else if(type==='week'){const f=new Date(t);f.setDate(t.getDate()-((t.getDay()+6)%7));const e=new Date(f);e.setDate(f.getDate()+6);fd.value=fmt(f);td.value=fmt(e);}
          else if(type==='month'){fd.value=fmt(new Date(t.getFullYear(),t.getMonth(),1));td.value=fmt(new Date(t.getFullYear(),t.getMonth()+1,0));}
          else if(type==='quarter'){const q=Math.floor(t.getMonth()/3);fd.value=fmt(new Date(t.getFullYear(),q*3,1));td.value=fmt(new Date(t.getFullYear(),q*3+3,0));}
        }

        /* ── TREND CHART ── */
        const trendD={
          day:{l:['T2','T3','T4','T5','T6','T7','CN'],san:[3.2,2.8,3.5,4.1,3.8,5.2,4.8],prod:[0.8,0.6,1.1,1.3,0.9,1.8,1.6]},
          week:{l:['Tuần 1','Tuần 2','Tuần 3','Tuần 4'],san:[18,22,20,25],prod:[5,7,6,8]},
          month:{l:['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'],san:[28,32,29,35,38,33,42,40,44,38,45,52],prod:[8,10,9,12,11,9,14,13,15,12,16,18]},
        };
        const tChart=new Chart(document.getElementById('trendChart'),{
          type:'line',
          data:{labels:trendD.day.l,datasets:[
            {label:'Đặt sân',data:trendD.day.san.map(v=>v*1e6),borderColor:G,backgroundColor:'rgba(212,160,23,.08)',fill:true,tension:.45,pointBackgroundColor:G,pointRadius:4,pointHoverRadius:7,borderWidth:2.5},
            {label:'Sản phẩm',data:trendD.day.prod.map(v=>v*1e6),borderColor:GN,backgroundColor:'rgba(16,185,129,.06)',fill:true,tension:.45,pointBackgroundColor:GN,pointRadius:3,borderWidth:2},
          ]},
          options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{usePointStyle:true,padding:20}}},scales:{y:{grid:{color:'rgba(0,0,0,.04)'},ticks:{callback:v=>'₫'+(v/1e6).toFixed(1)+'tr'}},x:{grid:{display:false}}}}
        });
        function swT(p,btn){
          document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on'));btn.classList.add('on');
          const d=trendD[p];tChart.data.labels=d.l;
          tChart.data.datasets[0].data=d.san.map(v=>v*1e6);
          tChart.data.datasets[1].data=d.prod.map(v=>v*1e6);
          tChart.update('active');
        }

        /* ── SOURCE PIE ── */
        new Chart(document.getElementById('srcChart'),{
          type:'doughnut',
          data:{labels:['Đặt sân','Sản phẩm','Dịch vụ','Voucher'],datasets:[{data:[68,22,7,3],backgroundColor:[G,GN,BL,PU],borderWidth:0,hoverOffset:6}]},
          options:{responsive:true,maintainAspectRatio:false,cutout:'62%',plugins:{legend:{position:'bottom',labels:{padding:12,usePointStyle:true,pointStyleWidth:8,font:{size:11}}}}}
        });

        /* ── FACILITY CHART ── */
        const facD={
          rev:{data:[4500000,3800000,4200000,3900000,4100000,3700000],lbl:'Doanh thu (₫)'},
          book:{data:[145,130,125,155,98,145],lbl:'Số đặt sân'},
          rate:{data:[87,72,81,78,65,90],lbl:'Tỷ lệ lấp đầy (%)'},
        };
        const facChart=new Chart(document.getElementById('facChart'),{
          type:'bar',
          data:{labels:['Cơ sở 1','Cơ sở 2','Cơ sở 3','Cơ sở 4','Cơ sở 5','Cơ sở 6'],datasets:[{label:'Doanh thu',data:facD.rev.data,backgroundColor:[G,G2,'rgba(212,160,23,.7)','rgba(212,160,23,.55)','rgba(212,160,23,.4)','rgba(212,160,23,.8)'],borderRadius:6}]},
          options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{grid:{color:'rgba(0,0,0,.04)'},beginAtZero:true,ticks:{callback:v=>facChart._facMode==='rev'?'₫'+(v/1e6).toFixed(1)+'tr':facChart._facMode==='rate'?v+'%':v}},x:{grid:{display:false}}}}
        });
        facChart._facMode='rev';
        function swFac(m,btn){
          document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on'));btn.classList.add('on');
          facChart._facMode=m;facChart.data.datasets[0].data=facD[m].data;
          facChart.data.datasets[0].label=facD[m].lbl;facChart.update('active');
        }

        /* ── SLOT CHART ── */
        new Chart(document.getElementById('slotChart'),{
          type:'bar',
          data:{labels:['6h','7h','8h','9h','10h','11h','12h','13h','14h','15h','16h','17h','18h','19h','20h','21h','22h'],datasets:[{data:[15,22,38,28,20,18,22,25,35,52,68,72,88,85,70,45,20],backgroundColor:ctx=>{const v=ctx.parsed.y;return v>=80?G:v>=60?'rgba(212,160,23,.65)':v>=40?'rgba(212,160,23,.42)':'rgba(212,160,23,.2)';},borderRadius:3}]},
          options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{display:false},x:{grid:{display:false},ticks:{font:{size:9}}}}}
        });
    </script>
}
