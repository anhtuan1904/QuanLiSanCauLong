@model QuanLiSanCauLong.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Phân Tích Chi Tiết";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --D: #0d0a05;
        --D2: #1a1209;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.2);
        --C: #fdf8f0;
        --W: #f5ede0;
        --S: #e8ddd0;
        --M: #8a7560;
        --GN: #10b981;
        --GN2: rgba(16,185,129,.1);
        --BL: #3b82f6;
        --BL2: rgba(59,130,246,.1);
        --RD: #ef4444;
        --RD2: rgba(239,68,68,.1);
        --PU: #8b5cf6;
        --PU2: rgba(139,92,246,.1);
        --OR: #f97316;
        --OR2: rgba(249,115,22,.1);
        --TE: #14b8a6;
        --PI: #f43f5e;
        --r: 14px;
        --r2: 10px;
        --r3: 8px;
        --sh: 0 2px 12px rgba(26,18,9,.07);
        --sh2: 0 8px 32px rgba(26,18,9,.12);
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .an {
        font-family: 'Space Grotesk',sans-serif;
        color: var(--D2);
        max-width: 1680px;
        padding-bottom: 4rem;
    }

    /* ─── ANALYTICS HEADER ─── */
    .an-head {
        background: var(--D2);
        border-radius: var(--r);
        padding: 1.5rem 2rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .an-head::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--G),var(--G2),transparent 80%);
        }

    .an-title-lbl {
        font-size: .62rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--G);
        font-weight: 600;
        margin-bottom: .3rem;
    }

    .an-title {
        font-family: 'Syne',sans-serif;
        font-size: 1.45rem;
        font-weight: 800;
        color: #fff;
    }

    .an-sub {
        font-size: .75rem;
        color: rgba(255,255,255,.3);
        margin-top: .25rem;
    }

    .an-actions {
        display: flex;
        align-items: center;
        gap: .65rem;
        flex-shrink: 0;
    }

    .abtn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1rem;
        border-radius: var(--r3);
        font-size: .74rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        border: none;
        font-family: 'Space Grotesk',sans-serif;
    }

    .abtn-g {
        background: var(--G);
        color: var(--D2);
    }

        .abtn-g:hover {
            background: var(--G2);
            color: var(--D2);
        }

    .abtn-o {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        color: rgba(255,255,255,.65);
    }

        .abtn-o:hover {
            background: rgba(255,255,255,.14);
            color: #fff;
        }

    /* ─── DATE FILTER ─── */
    .df-bar {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: flex-end;
        gap: .75rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .df-group {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .df-lbl {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--M);
    }

    .df-input {
        padding: .45rem .85rem;
        border: 1px solid var(--S);
        border-radius: var(--r3);
        font-size: .8rem;
        color: var(--D2);
        font-family: 'Space Grotesk',sans-serif;
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .df-input:focus {
            border-color: var(--G);
        }

    .df-qbtn {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .45rem .9rem;
        border-radius: var(--r3);
        border: 1px solid var(--S);
        font-size: .74rem;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
        color: var(--D2);
        transition: all .2s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .df-qbtn:hover {
            border-color: var(--G);
            color: var(--G);
        }

        .df-qbtn.qact {
            background: var(--G3);
            border-color: var(--G4);
            color: var(--G);
        }

    .df-submit {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1.1rem;
        border-radius: var(--r3);
        background: var(--G);
        color: var(--D2);
        border: none;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .df-submit:hover {
            background: var(--G2);
        }

    /* ─── KPI 6 WIDE ─── */
    .kpi6 {
        display: grid;
        grid-template-columns: repeat(6,1fr);
        gap: .9rem;
        margin-bottom: 1.5rem;
    }

    .kc6 {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        padding: 1.2rem 1.4rem;
        position: relative;
        overflow: hidden;
        transition: transform .22s,box-shadow .22s;
    }

        .kc6:hover {
            transform: translateY(-2px);
            box-shadow: var(--sh2);
        }

        .kc6::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: var(--r) var(--r) 0 0;
        }

        .kc6.cg::before {
            background: linear-gradient(90deg,var(--G),var(--G2));
        }

        .kc6.cgn::before {
            background: linear-gradient(90deg,var(--GN),#34d399);
        }

        .kc6.cbl::before {
            background: linear-gradient(90deg,var(--BL),#60a5fa);
        }

        .kc6.cor::before {
            background: linear-gradient(90deg,var(--OR),var(--G));
        }

        .kc6.crd::before {
            background: linear-gradient(90deg,var(--RD),var(--PI));
        }

        .kc6.cpu::before {
            background: linear-gradient(90deg,var(--PU),#a78bfa);
        }

    .kc6-ico {
        width: 38px;
        height: 38px;
        border-radius: var(--r3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .95rem;
        margin-bottom: .75rem;
    }

    .ig {
        background: var(--G3);
        color: var(--G);
    }

    .ign {
        background: var(--GN2);
        color: var(--GN);
    }

    .ibl {
        background: var(--BL2);
        color: var(--BL);
    }

    .ior {
        background: var(--OR2);
        color: var(--OR);
    }

    .ird {
        background: var(--RD2);
        color: var(--RD);
    }

    .ipu {
        background: var(--PU2);
        color: var(--PU);
    }

    .kc6-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--D2);
        line-height: 1;
        letter-spacing: -.02em;
    }

    .kc6-lbl {
        font-size: .7rem;
        color: var(--M);
        margin-top: .22rem;
    }

    .kc6-chg {
        font-size: .65rem;
        font-weight: 700;
        margin-top: .4rem;
        display: flex;
        align-items: center;
        gap: .2rem;
    }

    .up {
        color: var(--GN);
    }

    .dn {
        color: var(--RD);
    }

    .fl {
        color: var(--M);
    }

    /* ─── PANEL ─── */
    .pnl {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
    }

    .pnl-h {
        padding: 1.05rem 1.45rem;
        border-bottom: 1px solid var(--S);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .pnl-hl {
        display: flex;
        flex-direction: column;
        gap: .13rem;
    }

    .pnl-tag {
        font-size: .58rem;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
    }

    .pnl-title {
        font-family: 'Syne',sans-serif;
        font-size: .95rem;
        font-weight: 800;
        color: var(--D2);
    }

    .pnl-b {
        padding: 1.25rem 1.45rem;
    }

    .ptabs {
        display: flex;
        gap: .18rem;
    }

    .ptab {
        font-size: .67rem;
        font-weight: 600;
        padding: .27rem .68rem;
        border-radius: 6px;
        cursor: pointer;
        border: none;
        background: transparent;
        color: var(--M);
        transition: all .18s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .ptab.on {
            background: var(--G);
            color: var(--D2);
        }

        .ptab:hover:not(.on) {
            background: var(--W);
        }

    .gbst {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        background: transparent;
        color: var(--M);
        border: 1px solid var(--S);
        border-radius: var(--r3);
        font-size: .7rem;
        font-weight: 600;
        padding: .36rem .82rem;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .gbst:hover {
            border-color: var(--G);
            color: var(--G);
        }

    /* ─── TABLES ─── */
    .dtbl {
        width: 100%;
        border-collapse: collapse;
    }

        .dtbl th {
            background: var(--W);
            padding: .62rem 1rem;
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--M);
            border-bottom: 1px solid var(--S);
            text-align: left;
        }

        .dtbl td {
            padding: .78rem 1rem;
            border-bottom: 1px solid var(--S);
            font-size: .8rem;
            vertical-align: middle;
            color: var(--D2);
        }

        .dtbl tr:last-child td {
            border-bottom: none;
        }

        .dtbl tr:hover td {
            background: var(--C);
        }

    /* ─── STATUS PILLS ─── */
    .pill {
        display: inline-flex;
        align-items: center;
        gap: .26rem;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        padding: .2rem .58rem;
        border-radius: 4px;
    }

        .pill::before {
            content: '●';
            font-size: .47em;
        }

    .p-ok {
        background: var(--GN2);
        color: var(--GN);
    }

    .p-pe {
        background: rgba(212,160,23,.13);
        color: #92660a;
    }

    .p-pr {
        background: var(--BL2);
        color: var(--BL);
    }

    .p-ca {
        background: var(--RD2);
        color: var(--RD);
    }

    .p-pl {
        background: var(--PU2);
        color: var(--PU);
    }

    /* ─── RANK BADGES ─── */
    .rank-1 {
        background: linear-gradient(135deg,#ffd700,#ffb700);
        color: #1a1209;
    }

    .rank-2 {
        background: linear-gradient(135deg,#c0c0c0,#a8a8a8);
        color: #fff;
    }

    .rank-3 {
        background: linear-gradient(135deg,#cd7f32,#b87333);
        color: #fff;
    }

    .rank-n {
        background: var(--S);
        color: var(--M);
    }

    .rank-badge {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
        font-weight: 800;
        flex-shrink: 0;
    }

    /* ─── PROGRESS BAR ─── */
    .prg-track {
        height: 6px;
        background: var(--S);
        border-radius: 3px;
        overflow: hidden;
        flex: 1;
    }

    .prg-fill {
        height: 100%;
        border-radius: 3px;
        background: var(--G);
        transition: width 1s ease;
    }

    /* ─── SCORE RING ─── */
    .score-ring {
        position: relative;
        width: 110px;
        height: 110px;
        flex-shrink: 0;
    }

        .score-ring svg {
            transform: rotate(-90deg);
        }

    .score-ring-val {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .score-ring-n {
        font-family: 'Syne',sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--G);
        line-height: 1;
    }

    .score-ring-l {
        font-size: .58rem;
        color: var(--M);
        margin-top: .1rem;
    }

    /* ─── COMPARISON CARDS ─── */
    .cmp-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .75rem;
    }

    .cmp {
        background: var(--C);
        border: 1px solid var(--S);
        border-radius: var(--r2);
        padding: 1.1rem 1.2rem;
    }

    .cmp-lbl {
        font-size: .65rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
        margin-bottom: .55rem;
    }

    .cmp-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.45rem;
        font-weight: 800;
        color: var(--D2);
        line-height: 1;
    }

    .cmp-sub {
        font-size: .7rem;
        color: var(--M);
        margin-top: .28rem;
    }

    .cmp-chg {
        display: inline-flex;
        align-items: center;
        gap: .2rem;
        font-size: .68rem;
        font-weight: 700;
        margin-top: .35rem;
        padding: .15rem .5rem;
        border-radius: 20px;
    }

        .cmp-chg.up {
            background: var(--GN2);
            color: var(--GN);
        }

        .cmp-chg.dn {
            background: var(--RD2);
            color: var(--RD);
        }

        .cmp-chg.fl {
            background: rgba(138,117,96,.1);
            color: var(--M);
        }

    /* ─── CUSTOMER TABLE SPECIAL ─── */
    .cust-score {
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .cs-bar {
        flex: 1;
        max-width: 60px;
        height: 5px;
        background: var(--S);
        border-radius: 3px;
        overflow: hidden;
    }

    .cs-fill {
        height: 100%;
        border-radius: 3px;
        background: var(--G);
    }

    /* ─── FACILITY TABLE ─── */
    .fac-stat {
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .fac-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ─── ALERT BOXES ─── */
    .rec-list {
        display: flex;
        flex-direction: column;
        gap: .6rem;
    }

    .rec {
        padding: .85rem 1rem;
        border-radius: var(--r2);
        border-left: 3px solid transparent;
        display: flex;
        align-items: flex-start;
        gap: .75rem;
    }

        .rec.ok {
            border-color: var(--GN);
            background: rgba(16,185,129,.045);
        }

        .rec.wn {
            border-color: var(--OR);
            background: rgba(249,115,22,.045);
        }

        .rec.al {
            border-color: var(--RD);
            background: rgba(239,68,68,.045);
        }

        .rec.in {
            border-color: var(--BL);
            background: rgba(59,130,246,.045);
        }

    .rec-ico {
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: .05rem;
    }

    .rec-body {
    }

    .rec-title {
        font-size: .8rem;
        font-weight: 700;
        color: var(--D2);
    }

    .rec-desc {
        font-size: .73rem;
        color: var(--M);
        margin-top: .1rem;
        line-height: 1.52;
    }

    @@media(max-width:1280px) {
        .kpi6 {
            grid-template-columns: repeat(3,1fr);
        }
    }

    @@media(max-width:900px) {
        .kpi6 {
            grid-template-columns: repeat(2,1fr);
        }

        .cmp-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width:580px) {
        .kpi6 {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="an">

    <!-- ══════════ HEADER ══════════ -->
    <div class="an-head mb-4">
        <div>
            <div class="an-title-lbl">Phân tích nâng cao</div>
            <div class="an-title">Analytics & Báo Cáo</div>
            <div class="an-sub">Dữ liệu: @Model.FromDate.ToString("dd/MM/yyyy") – @Model.ToDate.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="an-actions">
            <a asp-controller="AdminDashboard" asp-action="Index" class="abtn abtn-o"><i class="bi bi-house"></i> Dashboard</a>
            <button class="abtn abtn-o" onclick="location.reload()"><i class="bi bi-arrow-clockwise"></i> Làm mới</button>
            <button class="abtn abtn-g" onclick="window.print()"><i class="bi bi-download"></i> Xuất báo cáo</button>
        </div>
    </div>

    <!-- ══════════ DATE FILTER ══════════ -->
    <form method="get" class="df-bar">
        <div class="df-group">
            <div class="df-lbl">Từ ngày</div>
            <input type="date" class="df-input" name="fromDate" id="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")">
        </div>
        <div class="df-group">
            <div class="df-lbl">Đến ngày</div>
            <input type="date" class="df-input" name="toDate" id="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")">
        </div>
        <div style="display:flex;align-items:flex-end;gap:.5rem;flex-wrap:wrap;">
            <button type="button" class="df-qbtn" onclick="qDate('today')"><i class="bi bi-calendar-day"></i> Hôm nay</button>
            <button type="button" class="df-qbtn" onclick="qDate('week')"><i class="bi bi-calendar-week"></i> Tuần này</button>
            <button type="button" class="df-qbtn" onclick="qDate('month')"><i class="bi bi-calendar-month"></i> Tháng này</button>
            <button type="button" class="df-qbtn" onclick="qDate('quarter')"><i class="bi bi-calendar3"></i> Quý này</button>
            <button type="submit" class="df-submit"><i class="bi bi-funnel-fill"></i> Áp dụng</button>
        </div>
    </form>

    <!-- ══════════ KPI 6 ══════════ -->
    <div class="kpi6">
        <div class="kc6 cg">
            <div class="kc6-ico ig"><i class="bi bi-cash-stack"></i></div>
            <div class="kc6-val">₫@Model.TotalRevenue.ToString("N0")</div>
            <div class="kc6-lbl">Tổng Doanh Thu</div>
            <div class="kc6-chg up"><i class="bi bi-arrow-up-short"></i>+12.5% so kỳ trước</div>
        </div>
        <div class="kc6 cgn">
            <div class="kc6-ico ign"><i class="bi bi-calendar-check-fill"></i></div>
            <div class="kc6-val">₫@Model.BookingRevenue.ToString("N0")</div>
            <div class="kc6-lbl">Doanh Thu Đặt Sân</div>
            <div class="kc6-chg up"><i class="bi bi-arrow-up-short"></i>+9.3% so kỳ trước</div>
        </div>
        <div class="kc6 cbl">
            <div class="kc6-ico ibl"><i class="bi bi-box-seam-fill"></i></div>
            <div class="kc6-val">₫@Model.ProductRevenue.ToString("N0")</div>
            <div class="kc6-lbl">Doanh Thu Sản Phẩm</div>
            <div class="kc6-chg up"><i class="bi bi-arrow-up-short"></i>+21.8% so kỳ trước</div>
        </div>
        <div class="kc6 cor">
            <div class="kc6-ico ior"><i class="bi bi-graph-up"></i></div>
            <div class="kc6-val">@Model.TotalBookings</div>
            <div class="kc6-lbl">Tổng Đơn Đặt Sân</div>
            <div class="kc6-chg up"><i class="bi bi-arrow-up-short"></i>+8.2% so kỳ trước</div>
        </div>
        <div class="kc6 crd">
            <div class="kc6-ico ird"><i class="bi bi-people-fill"></i></div>
            <div class="kc6-val">@Model.TotalCustomers</div>
            <div class="kc6-lbl">Khách Hàng Mới</div>
            <div class="kc6-chg up"><i class="bi bi-arrow-up-short"></i>+15.3% so kỳ trước</div>
        </div>
        <div class="kc6 cpu">
            <div class="kc6-ico ipu"><i class="bi bi-cart-check-fill"></i></div>
            <div class="kc6-val">@Model.TotalOrders</div>
            <div class="kc6-lbl">Tổng Đơn Hàng</div>
            <div class="kc6-chg fl"><i class="bi bi-dash"></i>~0% so kỳ trước</div>
        </div>
    </div>

    <!-- ══════════ PERIOD COMPARISON ══════════ -->
