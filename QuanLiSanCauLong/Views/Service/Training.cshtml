                <img class="cm-av" id="cmAvImg" src="" alt="" style="display:none;" />
                <div>
                    <div style="font-weight:700;font-size:.9rem;" id="cmHlvName"></div>
                    <div style="font-size:.78rem;color:var(--muted);margin-top:.15rem;" id="cmHlvTitle"></div>
