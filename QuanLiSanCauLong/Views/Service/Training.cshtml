@model IEnumerable<QuanLiSanCauLong.Models.Course>
@{
    ViewData["Title"] = "Khóa Học Cầu Lông";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --gold: #d4a017;
        --gold2: #f5c842;
        --deep: #1a1209;
        --cream: #fdf8f0;
        --warm: #f5efe0;
        --muted: #8a7560;
        --border: #e8ddc8;
        --green: #16a34a;
        --blue: #0284c7;
        --purple: #7c3aed;
        --red: #dc2626;
    }

    * {
        box-sizing: border-box;
    }

    .training-page {
        background: var(--cream);
        font-family: 'Outfit',sans-serif;
        color: var(--deep);
    }
    /* HERO */
    .train-hero {
        background: var(--deep);
        position: relative;
        overflow: hidden;
        padding: 0;
    }

    .train-hero-inner {
        display: grid;
        grid-template-columns: 55% 45%;
        min-height: 88vh;
    }

    .hero-content {
        padding: 6rem 5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
    }

    .hero-overline {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .hero-overline-line {
        width: 40px;
        height: 1px;
        background: var(--gold);
    }

    .hero-overline span {
        font-size: .72rem;
        letter-spacing: .22em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 500;
    }

    .hero-title {
        font-family: 'Playfair Display',serif;
        font-size: clamp(3rem,5.5vw,6rem);
        font-weight: 900;
        color: #fff;
        line-height: 1;
        margin-bottom: 2rem;
    }

        .hero-title em {
            font-style: italic;
            color: var(--gold2);
        }

    .hero-subtitle {
        color: rgba(255,255,255,.5);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.8;
        max-width: 400px;
        margin-bottom: 3.5rem;
    }

    .hero-counts {
        display: flex;
        border: 1px solid rgba(255,255,255,.1);
        width: fit-content;
        border-radius: 4px;
        overflow: hidden;
    }

    .hcount-item {
        padding: 1.2rem 2rem;
        border-right: 1px solid rgba(255,255,255,.1);
        text-align: center;
    }

        .hcount-item:last-child {
            border-right: none;
        }

    .hcount-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .hcount-l {
        font-size: .72rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.35);
        margin-top: .3rem;
    }

    .hero-image-panel {
        position: relative;
        overflow: hidden;
    }

        .hero-image-panel img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: sepia(20%) contrast(1.1);
        }

        .hero-image-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right,var(--deep) 0%,transparent 30%);
            z-index: 1;
        }

    .bg-watermark {
        position: absolute;
        right: -2rem;
        bottom: -2rem;
        font-size: 18rem;
        opacity: .04;
        color: var(--gold);
        pointer-events: none;
    }
    /* CARDS */
    .cards-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 6rem 4rem;
    }

    .cards-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 4rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .cards-heading {
        font-family: 'Playfair Display',serif;
        font-size: 2.8rem;
        font-weight: 700;
        line-height: 1.1;
        color: var(--deep);
    }

        .cards-heading span {
            color: var(--gold);
            display: block;
            font-style: italic;
        }

    .filter-tabs {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .ftab {
        padding: .5rem 1.2rem;
        border: 1px solid var(--border);
        background: none;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: .05em;
        border-radius: 2px;
        transition: all .2s;
        color: var(--muted);
    }

        .ftab.active {
            background: var(--deep);
            color: #fff;
            border-color: var(--deep);
        }

        .ftab:hover:not(.active) {
            border-color: var(--deep);
            color: var(--deep);
        }

    .course-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
    }

    .course-card {
        background: #fff;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: stretch;
        cursor: pointer;
        transition: all .3s;
        overflow: hidden;
    }

        .course-card:hover {
            transform: translateX(6px);
        }

            .course-card:hover .card-accent {
                width: 6px;
            }

        .course-card.is-full {
            opacity: .8;
        }

            .course-card.is-full:hover {
                transform: none;
            }

    .card-accent {
        width: 4px;
        flex-shrink: 0;
        transition: all .3s;
        background: var(--border);
    }

        .card-accent.lv-Beginner {
            background: var(--green);
        }

        .card-accent.lv-Intermediate {
            background: var(--blue);
        }

        .card-accent.lv-Advanced {
            background: var(--purple);
        }

        .card-accent.lv-All {
            background: var(--gold);
        }

    .card-main {
        padding: 2.5rem 3rem;
    }

    .card-top-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .level-tag {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        padding: .3rem .9rem;
        border-radius: 2px;
    }

        .level-tag.Beginner {
            background: #dcfce7;
            color: var(--green);
        }

        .level-tag.Intermediate {
            background: #dbeafe;
            color: var(--blue);
        }

        .level-tag.Advanced {
            background: #ede9fe;
            color: var(--purple);
        }

        .level-tag.All {
            background: rgba(212,160,23,.12);
            color: #92660a;
        }

        .level-tag.Full {
            background: #fee2e2;
            color: var(--red);
        }

    .badge-hot {
        background: rgba(239,68,68,.1);
        color: var(--red);
        font-size: .65rem;
        font-weight: 700;
        padding: .2rem .6rem;
        border-radius: 2px;
    }

    .type-tag {
        font-size: .72rem;
        color: var(--muted);
        border: 1px solid var(--border);
        padding: .2rem .7rem;
        border-radius: 2px;
    }

    .card-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .6rem;
        line-height: 1.2;
    }

    .card-short {
        color: var(--muted);
        font-size: .9rem;
        font-weight: 300;
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .card-info-row {
        display: flex;
        gap: 2.5rem;
        flex-wrap: wrap;
    }

    .cinfo {
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }

    .cinfo-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cinfo-val {
        font-size: .9rem;
        font-weight: 600;
        color: var(--deep);
    }

    .card-right {
        padding: 2.5rem 2.5rem 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: space-between;
        min-width: 200px;
    }

    .price-box {
        text-align: right;
    }

    .price-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .price-amount {
        font-family: 'Playfair Display',serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--gold);
    }

    .price-old {
        font-size: .85rem;
        color: var(--muted);
        text-decoration: line-through;
        margin-top: .2rem;
    }

    .s-bar {
        width: 100%;
        height: 4px;
        background: var(--warm);
        border-radius: 2px;
        overflow: hidden;
        margin-top: .5rem;
    }

    .s-bar-fill {
        height: 100%;
        border-radius: 2px;
        transition: width 1s;
    }

    .s-info {
        font-size: .75rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    .btn-view {
        background: var(--deep);
        color: #fff;
        border: none;
        padding: .7rem 1.5rem;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .08em;
        cursor: pointer;
        transition: all .25s;
        display: flex;
        align-items: center;
        gap: .5rem;
        border-radius: 2px;
        font-family: 'Outfit',sans-serif;
    }

        .btn-view:hover {
            background: var(--gold);
            color: var(--deep);
        }

        .btn-view:disabled {
            opacity: .5;
            cursor: not-allowed;
            background: var(--muted);
        }
    /* EMPTY */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3.5rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .25;
        }
    /* MODAL */
    .cm-overlay {
        position: fixed;
        inset: 0;
        background: rgba(26,18,9,.9);
        backdrop-filter: blur(12px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

        .cm-overlay.open {
            display: flex;
        }

    .cm-modal {
        background: var(--cream);
        width: 100%;
        max-width: 940px;
        max-height: 92vh;
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        animation: cmIn .35s cubic-bezier(.25,.46,.45,.94);
    }

    @@keyframes cmIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
    /* MODAL HERO */
    .cm-hero {
        background: var(--deep);
        padding: 2.5rem 3rem;
        position: relative;
        flex-shrink: 0;
        min-height: 190px;
        display: flex;
        align-items: flex-end;
    }

    .cm-hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: .3;
    }

    .cm-hero-grad {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top,rgba(26,18,9,.96) 0%,rgba(26,18,9,.35) 100%);
    }

    .cm-close-btn {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: rgba(255,255,255,.12);
        border: none;
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3;
        transition: background .2s;
        font-size: 1rem;
    }

        .cm-close-btn:hover {
            background: rgba(255,255,255,.25);
        }

    .cm-hero-inner {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .cm-badges {
        display: flex;
        align-items: center;
        gap: .4rem;
        flex-wrap: wrap;
        margin-bottom: .8rem;
    }

    .cm-badge {
        font-size: .63rem;
        font-weight: 700;
        padding: .2rem .55rem;
        border-radius: 2px;
        letter-spacing: .06em;
    }

    .cm-badge-full {
        background: rgba(220,38,38,.22);
        color: #fca5a5;
    }

    .cm-badge-hot {
        background: rgba(239,68,68,.18);
        color: #fca5a5;
    }

    .cm-badge-star {
        background: rgba(212,160,23,.2);
        color: var(--gold2);
    }

    .cm-title {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        margin: 0 0 .4rem;
        line-height: 1.15;
    }

    .cm-subtitle {
        color: rgba(255,255,255,.5);
        font-size: .9rem;
        font-weight: 300;
        margin: 0;
    }
    /* GALLERY STRIP */
    .cm-gallery-strip {
        display: flex;
        gap: .4rem;
        padding: .6rem 1rem;
        background: rgba(0,0,0,.25);
        overflow-x: auto;
        flex-shrink: 0;
        scrollbar-width: thin;
    }

        .cm-gallery-strip::-webkit-scrollbar {
            height: 3px;
        }

        .cm-gallery-strip::-webkit-scrollbar-thumb {
            background: var(--gold);
        }

    .cm-gthumb {
        width: 68px;
        height: 46px;
        border-radius: 3px;
        overflow: hidden;
        flex-shrink: 0;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color .2s;
    }

        .cm-gthumb.active, .cm-gthumb:hover {
            border-color: var(--gold);
        }

        .cm-gthumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
    /* MODAL BODY */
    .cm-body {
        padding: 2rem 3rem;
        overflow-y: auto;
        flex: 1;
    }

    .cm-hl-row {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: 1.5rem;
    }

    .cm-hl-chip {
        background: rgba(212,160,23,.12);
        border: 1px solid rgba(212,160,23,.28);
        border-radius: 20px;
        padding: .28rem .8rem;
        font-size: .76rem;
        color: var(--deep);
        font-weight: 500;
    }

    .cm-instr {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: .85rem 1.1rem;
        margin-bottom: 1.5rem;
    }

    .cm-av {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--gold);
        flex-shrink: 0;
    }

    .cm-av-ph {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: rgba(212,160,23,.1);
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .info-box {
        background: var(--warm);
        padding: .85rem 1rem;
        border-radius: 5px;
        border: 1px solid var(--border);
    }

    .ib-label {
        font-size: .62rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: .3rem;
    }

    .ib-val {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
    }

    .ib-sub {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .pb-wrap {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        margin-top: .35rem;
    }

    .pb-fill {
        height: 4px;
        border-radius: 2px;
        transition: width .6s;
    }

    .cm-video {
        margin-bottom: 1.5rem;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .cm-video iframe {
            width: 100%;
            height: 220px;
            display: block;
            border: none;
        }

    .cm-notice-full {
        background: #fee2e2;
        border: 1px solid #fca5a5;
        border-radius: 5px;
        padding: .8rem 1rem;
        font-size: .83rem;
        color: var(--red);
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1rem;
    }

    .cm-notice-ok {
        background: #dcfce7;
        border: 1px solid #86efac;
        border-radius: 5px;
        padding: .8rem 1rem;
        font-size: .83rem;
        color: var(--green);
        display: none;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1rem;
    }

    .cm-sec-title {
        font-weight: 700;
        font-size: .7rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .7rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        padding-bottom: .45rem;
        border-bottom: 1px solid var(--border);
    }

    .cm-ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem;
    }

        .cm-ul li {
            display: flex;
            gap: .6rem;
            padding: .45rem 0;
            border-bottom: 1px solid var(--border);
            font-size: .87rem;
            font-weight: 300;
            color: var(--deep);
        }

            .cm-ul li:last-child {
                border-bottom: none;
            }

    .ic-green {
        color: var(--green);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .ic-gold {
        color: var(--gold);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .ic-muted {
        color: var(--muted);
        flex-shrink: 0;
        margin-top: 2px;
    }
    /* ENROLL FORM */
    .cm-enroll-form {
        display: none;
        padding: 1.2rem 3rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        flex-shrink: 0;
    }

        .cm-enroll-form.open {
            display: block;
        }

    .cm-enroll-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .55rem;
        margin-bottom: .6rem;
    }

    .cm-enroll-form input {
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 4px;
        font-size: .85rem;
        outline: none;
        font-family: 'Outfit',sans-serif;
        width: 100%;
        background: #fff;
    }

        .cm-enroll-form input:focus {
            border-color: var(--gold);
        }

    .btn-submit-enroll {
        background: var(--deep);
        color: var(--gold);
        border: none;
        padding: .65rem 1.4rem;
        font-weight: 700;
        font-size: .82rem;
        cursor: pointer;
        border-radius: 4px;
        font-family: 'Outfit',sans-serif;
        transition: all .2s;
        white-space: nowrap;
    }

        .btn-submit-enroll:hover {
            background: #2d1f0e;
        }

        .btn-submit-enroll:disabled {
            opacity: .6;
            cursor: not-allowed;
        }
    /* FOOTER */
    .cm-footer {
        padding: 1.1rem 3rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        background: #fff;
    }

    .cm-price-wrap .cm-plabel {
        font-size: .63rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .2rem;
    }

    .cm-pbig {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
        display: flex;
        align-items: baseline;
        gap: .4rem;
    }

    .cm-pbig-old {
        font-size: .85rem;
        color: var(--muted);
        text-decoration: line-through;
    }

    .btn-close-cm {
        border: 1px solid var(--border);
        background: none;
        padding: .7rem 1.3rem;
        cursor: pointer;
        border-radius: 4px;
        font-size: .8rem;
        font-family: 'Outfit',sans-serif;
        transition: all .2s;
    }

        .btn-close-cm:hover {
            border-color: var(--deep);
        }

    .btn-enroll-cm {
        background: var(--gold);
        color: var(--deep);
        border: none;
        padding: .75rem 1.8rem;
        font-weight: 700;
        font-size: .83rem;
        cursor: pointer;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-enroll-cm:hover {
            background: var(--gold2);
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

        .btn-enroll-cm:disabled {
            opacity: .5;
            cursor: not-allowed;
            transform: none;
            background: var(--muted);
        }

    @@media(max-width:900px) {
        .train-hero-inner {
            grid-template-columns: 1fr;
        }

        .hero-image-panel {
            display: none;
        }

        .hero-content {
            padding: 4rem 2rem;
        }

        .cards-wrapper {
            padding: 4rem 1.5rem;
        }

        .course-card {
            grid-template-columns: auto 1fr;
        }

        .card-right {
            display: none;
        }

        .info-grid {
            grid-template-columns: 1fr 1fr;
        }

        .cm-body, .cm-footer, .cm-enroll-form {
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }

        .cm-enroll-grid {
            grid-template-columns: 1fr;
        }

        .cm-hero {
            padding: 1.75rem 1.5rem;
        }
    }

    @@media(max-width:600px) {
        .cards-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }

        .card-main {
            padding: 1.5rem;
        }

        .info-grid {
            grid-template-columns: 1fr 1fr;
        }

        .cm-title {
            font-size: 1.5rem;
        }
    }
</style>

<div class="training-page">
    <section class="train-hero">
        <div class="train-hero-inner">
            <div class="hero-content">
                <div class="hero-overline"><div class="hero-overline-line"></div><span>Badminton Academy</span></div>
                <h1 class="hero-title">Khóa học<br /><em>chuyên nghiệp.</em></h1>
                <p class="hero-subtitle">Nâng cao kỹ năng cùng huấn luyện viên chuyên nghiệp. Từ cơ bản đến nâng cao — chúng tôi có lộ trình dành riêng cho bạn.</p>
                <div class="hero-counts">
                    <div class="hcount-item"><div class="hcount-n">@Model.Count()</div><div class="hcount-l">Khóa học</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Count(c => c.Status == "Active")</div><div class="hcount-l">Đang mở</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Sum(c => c.CurrentStudents)</div><div class="hcount-l">Học viên</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Count(c => c.IsFull || c.Status == "Full")</div><div class="hcount-l">Đã đầy</div></div>
                </div>
            </div>
            <div class="hero-image-panel">
                <img src="https://images.unsplash.com/photo-1613918108466-292b78a8ef85?w=800&q=80" alt="Training" />
                <div class="bg-watermark"><i class="bi bi-mortarboard-fill"></i></div>
            </div>
        </div>
    </section>

    <section class="cards-wrapper">
        <div class="cards-header">
            <div class="cards-heading">Các khóa học<span>đang mở &amp; sắp khai giảng</span></div>
            <div class="filter-tabs">
                <button class="ftab active" data-filter="all">Tất cả</button>
                <button class="ftab" data-filter="Beginner">Cơ bản</button>
                <button class="ftab" data-filter="Intermediate">Trung cấp</button>
                <button class="ftab" data-filter="Advanced">Nâng cao</button>
                <button class="ftab" data-filter="Full">Đã đầy</button>
            </div>
        </div>
        <div class="course-list">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-mortarboard"></i>
                    <div style="font-size:1rem;font-weight:600;margin-bottom:.5rem;">Chưa có khóa học nào</div>
                    <div>Vui lòng quay lại sau hoặc liên hệ để biết thêm.</div>
                </div>
            }
            else
            {
                @foreach (var c in Model)
                {
                    var isFull = c.IsFull || c.Status == "Full";
                    var pct = c.MaxStudents.HasValue && c.MaxStudents > 0 ? Math.Min(100, c.CurrentStudents * 100 / c.MaxStudents.Value) : 0;
                    var pctCol = pct >= 90 ? "#dc2626" : pct >= 70 ? "#d4a017" : "#16a34a";
                    var eff = c.DiscountFee ?? c.TuitionFee;
                    var priceStr = eff.HasValue ? eff.Value.ToString("N0") + "đ" : "Liên hệ";
                    var oldStr = (c.DiscountFee.HasValue && c.TuitionFee.HasValue) ? c.TuitionFee.Value.ToString("N0") + "đ" : "";
                    var lvLabel = c.Level switch { "Beginner" => "◎ Cơ Bản", "Intermediate" => "● Trung Cấp", "Advanced" => "★ Nâng Cao", "All" => "👥 Tất Cả", _ => c.Level };
                    var galleryImgs = new System.Collections.Generic.List<string>();
                    if (!string.IsNullOrEmpty(c.FeaturedImage)) galleryImgs.Add(c.FeaturedImage);
                    if (c.CourseImages != null) foreach (var gi in c.CourseImages.OrderBy(i => i.DisplayOrder)) if (!galleryImgs.Contains(gi.ImagePath)) galleryImgs.Add(gi.ImagePath);
                    var galleryJson = System.Text.Json.JsonSerializer.Serialize(galleryImgs);

                    <div class="course-card course-item @(isFull ? "is-full" : "")"
                         data-filter-level="@(isFull ? "Full" : c.Level)"
                         data-filter-status="@c.Status"
                         data-id="@c.CourseId"
                         data-name="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.CourseName))"
                         data-hlv="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Instructor ?? ""))"
                         data-hlv-title="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.InstructorTitle ?? ""))"
                         data-hlv-avatar="@(c.InstructorAvatar ?? "")"
                         data-level-val="@c.Level"
                         data-weeks="@(c.DurationWeeks != null ? c.DurationWeeks + " tuần" : "—")"
                         data-schedule="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Schedule ?? "—"))"
                         data-cur="@c.CurrentStudents"
                         data-max="@(c.MaxStudents?.ToString() ?? "∞")"
                         data-price="@priceStr"
                         data-old="@oldStr"
                         data-pct="@pct"
                         data-short="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.ShortDesc ?? ""))"
                         data-gallery="@Html.Raw(System.Net.WebUtility.HtmlEncode(galleryJson))"
                         data-feats="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Features ?? ""))"
                         data-highlights="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Highlights ?? ""))"
                         data-outcomes="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Outcomes ?? ""))"
                         data-requirements="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Requirements ?? ""))"
                         data-video="@(c.VideoUrl ?? "")"
                         data-popular="@(c.IsPopular ? "1" : "")"
                         data-featured="@(c.IsFeatured ? "1" : "")">
                        <div class="card-accent lv-@c.Level"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="level-tag @(isFull ? "Full" : c.Level)">@(isFull ? "🔒 Đã Đầy" : lvLabel)</span>
                                @if (c.IsPopular)
                                {
                                    <span class="badge-hot">🔥 HOT</span>
                                }
                                @if (!string.IsNullOrEmpty(c.Instructor))
                                {
                                    <span class="type-tag">@c.Instructor</span>
                                }
                                @if (c.IsFeatured)
                                {
                                    <span style="color:var(--gold);font-size:.85rem;">★</span>
                                }
                            </div>
                            <div class="card-name">@c.CourseName</div>
                            <div class="card-short">@c.ShortDesc</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Thời lượng</span><span class="cinfo-val">@(c.DurationWeeks != null ? c.DurationWeeks + " tuần" : "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">Lịch học</span><span class="cinfo-val">@(c.Schedule ?? "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">Học viên</span><span class="cinfo-val">@c.CurrentStudents/@(c.MaxStudents?.ToString() ?? "∞") người</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="price-box">
                                <div class="price-label">Học phí</div>
                                <div class="price-amount">@priceStr</div>
                                @if (!string.IsNullOrEmpty(oldStr))
                                {
                                    <div class="price-old">@oldStr</div>
                                }
                                <div class="s-bar"><div class="s-bar-fill" style="width:@(pct)%;background:@pctCol;"></div></div>
                                <div class="s-info">@c.CurrentStudents/@(c.MaxStudents?.ToString() ?? "?") đã đăng ký</div>
                            </div>
                            <button class="btn-view" @(isFull ? "disabled" : "")>
                                <i class="bi bi-@(isFull ? "lock" : "arrow-right")"></i> @(isFull ? "Hết chỗ" : "Chi tiết")
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<!-- ═══ MODAL CHI TIẾT KHÓA HỌC ═══ -->
<div class="cm-overlay" id="cmOverlay">
    <div class="cm-modal">
        <!-- Hero -->
