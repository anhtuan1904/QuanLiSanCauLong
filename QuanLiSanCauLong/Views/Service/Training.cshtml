@section Scripts {
    <script>
        (function(){
            var TOKEN=(document.querySelector('input[name="__RequestVerificationToken"]')||{}).value||'';
            var _imgs=[];

            function g(id){return document.getElementById(id);}
            function show(id){g(id).style.display='';}
            function hide(id){g(id).style.display='none';}
            function showFlex(id){g(id).style.display='flex';}

            function openCm(card){
                var d=card.dataset;
                var full=card.classList.contains('is-full');

                // Hero bg
                var bg=g('cmBg');
                if(d.gallery){try{var imgs=JSON.parse(d.gallery);if(imgs[0]){bg.src=imgs[0];show('cmBg');}else hide('cmBg');}catch(e){hide('cmBg');}}
                else if(d.img){bg.src=d.img;show('cmBg');}else hide('cmBg');

                // Title
                g('cmTitle').textContent=d.name||'';
                g('cmSubtitle').textContent=d.short||'';

                // Level
                var lvEl=g('cmLvTag');
                var lvMap={Beginner:'◎ Cơ Bản',Intermediate:'● Trung Cấp',Advanced:'★ Nâng Cao',All:'👥 Tất Cả'};
                lvEl.textContent=full?'🔒 Đã Đầy':(lvMap[d.levelVal]||d.levelVal);
                lvEl.className='level-tag '+(full?'Full':(d.levelVal||''));
                g('cmBadgeHot').style.display=d.popular?'':'none';
                g('cmBadgeStar').style.display=d.featured?'':'none';
                g('cmBadgeFull').style.display=full?'':'none';

                // Gallery strip
                try{
                    _imgs=JSON.parse(d.gallery||'[]');
                    var strip=g('cmGalleryStrip');
                    strip.innerHTML='';
                    if(_imgs.length>1){
                        strip.style.display='flex';
                        _imgs.forEach(function(src,i){
                            var t=document.createElement('div');t.className='cm-gthumb'+(i===0?' active':'');
                            t.innerHTML='<img src="'+src+'" alt=""/>';
                            t.addEventListener('click',function(){
                                g('cmBg').src=src;show('cmBg');
                                strip.querySelectorAll('.cm-gthumb').forEach(function(x,j){x.classList.toggle('active',j===i);});
                            });
                            strip.appendChild(t);
                        });
                    }else{strip.style.display='none';}
                }catch(e){g('cmGalleryStrip').style.display='none';}

                // Highlights
                var hlRow=g('cmHlRow');hlRow.innerHTML='';
                try{JSON.parse(d.highlights||'[]').forEach(function(h){var s=document.createElement('span');s.className='cm-hl-chip';s.textContent='⚡ '+h;hlRow.appendChild(s);});}catch(e){}

                // Instructor
                if(d.hlv){
                    show('cmInstr');
                    g('cmHlvName').textContent=d.hlv;
                    g('cmHlvTitle').textContent=d.hlvTitle||'';
                    if(d.hlvAvatar){g('cmAvImg').src=d.hlvAvatar;show('cmAvImg');hide('cmAvPh');}
                    else{hide('cmAvImg');show('cmAvPh');}
                }else hide('cmInstr');

                // Info
                g('cmWeeks').textContent=d.weeks||'—';
                g('cmSched').textContent=d.schedule||'—';
                g('cmStudents').textContent=(d.cur||'0')+' / '+(d.max||'∞')+' người';
                var pct=parseInt(d.pct||0);
                g('cmPb').style.width=pct+'%';
                g('cmPb').style.background=pct>=90?'#dc2626':pct>=70?'#d4a017':'#16a34a';
                if(full){g('cmSlots').textContent='Đã đầy';}
                else if(d.max&&d.max!=='∞'){g('cmSlots').textContent='Còn '+(parseInt(d.max)-parseInt(d.cur||0))+' chỗ';}
                else g('cmSlots').textContent='';
                g('cmPriceBox').textContent=d.price||'—';
                g('cmOldBox').textContent=d.old||'';
                g('cmPfBig').textContent=d.price||'—';
                g('cmPfOld').textContent=d.old||'';

                // Video
                if(d.video){var yt=d.video.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);if(yt){g('cmVideoFrame').src='https://www.youtube.com/embed/'+yt[1]+'?rel=0';show('cmVideoWrap');}else hide('cmVideoWrap');}
                else{hide('cmVideoWrap');g('cmVideoFrame').src='';}

                // Notices
                g('cmNoticeFull').style.display=full?'':'none';
                g('cmNoticeOk').style.display='none';

                // Lists
                renderUl('cmFeatsList','cmFeatsWrap',d.feats,'check');
                renderUl('cmOutcomesList','cmOutcomesWrap',d.outcomes,'star');
                renderUl('cmReqList','cmReqWrap',d.requirements,'info');

                // Enroll
                g('cmCourseId').value=d.id||'';
                g('cmEnrollForm').classList.remove('open');
                var eb=g('btnEnrollToggle');
                if(full){eb.disabled=true;eb.innerHTML='<i class="bi bi-lock me-1"></i> Hết chỗ';}
                else{eb.disabled=false;eb.innerHTML='<i class="bi bi-mortarboard me-1"></i> Đăng ký ngay';}

                g('cmOverlay').classList.add('open');
                document.body.style.overflow='hidden';
                g('cmOverlay').querySelector('.cm-body').scrollTop=0;
            }

            function renderUl(ulId,wrapId,raw,icon){
                var ul=g(ulId),wrap=g(wrapId);ul.innerHTML='';
                var lines=(raw||'').split('\n').filter(function(l){return l.trim();});
                if(!lines.length){hide(wrapId);return;}
                lines.forEach(function(l){
                    var li=document.createElement('li');
                    var cls=icon==='star'?'bi-star-fill ic-gold':icon==='info'?'bi-info-circle ic-muted':'bi-check-circle-fill ic-green';
                    li.innerHTML='<i class="bi '+cls+'"></i>'+l.replace(/^[-•]\s*/,'');
                    ul.appendChild(li);
                });
                show(wrapId);
            }

            window.closeCm=function(){
                g('cmOverlay').classList.remove('open');
                document.body.style.overflow='';
                g('cmVideoFrame').src='';
            };
            window.toggleEnroll=function(){
                g('cmEnrollForm').classList.toggle('open');
                if(g('cmEnrollForm').classList.contains('open'))g('eName').focus();
            };
            window.submitEnroll=function(){
                var name=g('eName').value.trim(),phone=g('ePhone').value.trim(),email=g('eEmail').value.trim(),id=g('cmCourseId').value;
                if(!name||!phone){alert('Vui lòng nhập họ tên và số điện thoại.');return;}
                var btn=g('btnEnroll');btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split me-1"></i>Đang xử lý...';
                var fd=new FormData();fd.append('courseId',id);fd.append('customerName',name);fd.append('phone',phone);
                if(email)fd.append('email',email);if(TOKEN)fd.append('__RequestVerificationToken',TOKEN);
                fetch('/Service/Enroll',{method:'POST',body:fd}).then(function(r){return r.json();})
                    .then(function(res){
                        if(res.success){
                            g('cmEnrollForm').classList.remove('open');
                            g('cmOkMsg').textContent=res.message;
                            showFlex('cmNoticeOk');
                            if(res.isFull){
                                show('cmNoticeFull');g('cmBadgeFull').style.display='';
                                g('cmLvTag').textContent='🔒 Đã Đầy';g('cmLvTag').className='level-tag Full';
                                var eb=g('btnEnrollToggle');eb.disabled=true;eb.innerHTML='<i class="bi bi-lock me-1"></i> Hết chỗ';
                                g('cmPb').style.width='100%';g('cmPb').style.background='#dc2626';
                                g('cmSlots').textContent='Đã đầy';
                            }
                        }else alert(res.message||'Có lỗi xảy ra.');
                        btn.disabled=false;btn.innerHTML='<i class="bi bi-check-circle me-1"></i> Xác nhận đăng ký';
                    }).catch(function(){alert('Lỗi kết nối.');btn.disabled=false;btn.innerHTML='<i class="bi bi-check-circle me-1"></i> Xác nhận đăng ký';});
            };

            // Card clicks
            document.addEventListener('DOMContentLoaded',function(){
                document.querySelectorAll('.course-card').forEach(function(card){
                    card.addEventListener('click',function(){openCm(this);});
                });
            });

            // Filter tabs
            document.querySelectorAll('.ftab').forEach(function(btn){
                btn.addEventListener('click',function(){
                    document.querySelectorAll('.ftab').forEach(function(b){b.classList.remove('active');});
                    this.classList.add('active');var f=this.dataset.filter;
                    document.querySelectorAll('.course-card').forEach(function(card){
                        var lvl=card.dataset.filterLevel,sts=card.dataset.filterStatus;
                        card.style.display=(f==='all'||lvl===f||sts===f)?'':'none';
                    });
                });
            });

            g('cmCloseBtn').addEventListener('click',closeCm);
            g('cmOverlay').addEventListener('click',function(e){if(e.target===this)closeCm();});
            document.addEventListener('keydown',function(e){if(e.key==='Escape')closeCm();});
        })();
    </script>
}
