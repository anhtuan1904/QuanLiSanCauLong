@model IEnumerable<QuanLiSanCauLong.Models.Course>
@{
    ViewData["Title"] = "Khóa Học Cầu Lông";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --gold:#d4a017; --gold2:#f5c842; --deep:#1a1209; --cream:#fdf8f0;
        --warm:#f5efe0; --muted:#8a7560; --border:#e8ddc8;
        --beginner:#16a34a; --inter:#0284c7; --advanced:#7c3aed;
    }
    .training-page{background:var(--cream);font-family:'Outfit',sans-serif;color:var(--deep);}
    .train-hero{background:var(--deep);position:relative;overflow:hidden;padding:0;}
    .train-hero-inner{display:grid;grid-template-columns:55% 45%;min-height:88vh;}
    .hero-content{padding:6rem 5rem;display:flex;flex-direction:column;justify-content:center;position:relative;z-index:2;}
    .hero-overline{display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem;}
    .hero-overline-line{width:40px;height:1px;background:var(--gold);}
    .hero-overline span{font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:500;}
    .hero-title{font-family:'Playfair Display',serif;font-size:clamp(3rem,5.5vw,6rem);font-weight:900;color:#fff;line-height:1;margin-bottom:2rem;}
    .hero-title em{font-style:italic;color:var(--gold2);}
    .hero-subtitle{color:rgba(255,255,255,.5);font-size:1rem;font-weight:300;line-height:1.8;max-width:400px;margin-bottom:3.5rem;}
    .hero-counts{display:flex;gap:0;border:1px solid rgba(255,255,255,.1);width:fit-content;border-radius:4px;overflow:hidden;}
    .hcount-item{padding:1.2rem 2rem;border-right:1px solid rgba(255,255,255,.1);text-align:center;}
    .hcount-item:last-child{border-right:none;}
    .hcount-n{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--gold2);line-height:1;}
    .hcount-l{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.3rem;}
    .hero-image-panel{position:relative;overflow:hidden;}
    .hero-image-panel img{width:100%;height:100%;object-fit:cover;filter:sepia(20%) contrast(1.1);}
    .hero-image-panel::before{content:'';position:absolute;inset:0;background:linear-gradient(to right,var(--deep) 0%,transparent 30%);z-index:1;}
    .bg-watermark{position:absolute;right:-2rem;bottom:-2rem;font-size:18rem;opacity:.04;z-index:0;color:var(--gold);pointer-events:none;}
    .cards-wrapper{max-width:1200px;margin:0 auto;padding:6rem 4rem;}
    .cards-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;padding-bottom:2rem;border-bottom:1px solid var(--border);}
    .cards-heading{font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:700;line-height:1.1;color:var(--deep);}
    .cards-heading span{color:var(--gold);display:block;font-style:italic;}
    .filter-tabs{display:flex;gap:.5rem;}
    .ftab{padding:.5rem 1.2rem;border:1px solid var(--border);background:none;font-size:.78rem;font-weight:600;cursor:pointer;letter-spacing:.05em;border-radius:2px;transition:all .2s;color:var(--muted);}
    .ftab.active{background:var(--deep);color:#fff;border-color:var(--deep);}
    .ftab:hover:not(.active){border-color:var(--deep);color:var(--deep);}
    .course-list{display:flex;flex-direction:column;gap:1px;background:var(--border);}
    .course-card{background:#fff;display:grid;grid-template-columns:auto 1fr auto;align-items:stretch;cursor:pointer;transition:all .3s;overflow:hidden;}
    .course-card:hover{transform:translateX(6px);}
    .course-card:hover .card-accent{width:6px;}
    .course-card.is-full{opacity:.75;cursor:not-allowed;}
    .course-card.is-full:hover{transform:none;}
    .card-accent{width:4px;background:var(--border);flex-shrink:0;transition:all .3s;}
    .card-accent.lv-Beginner{background:var(--beginner);}
    .card-accent.lv-Intermediate{background:var(--inter);}
    .card-accent.lv-Advanced{background:var(--advanced);}
    .card-main{padding:2.5rem 3rem;}
    .card-top-row{display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;}
    .level-tag{font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:.3rem .9rem;border-radius:2px;}
    .level-tag.Beginner{background:#dcfce7;color:var(--beginner);}
    .level-tag.Intermediate{background:#dbeafe;color:var(--inter);}
    .level-tag.Advanced{background:#ede9fe;color:var(--advanced);}
    .level-tag.Full{background:#fee2e2;color:#dc2626;}
    .type-tag{font-size:.72rem;color:var(--muted);border:1px solid var(--border);padding:.2rem .7rem;border-radius:2px;}
    .card-name{font-family:'Playfair Display',serif;font-size:1.7rem;font-weight:700;color:var(--deep);margin-bottom:.6rem;line-height:1.2;}
    .card-short{color:var(--muted);font-size:.9rem;font-weight:300;line-height:1.7;margin-bottom:1.5rem;}
    .card-info-row{display:flex;gap:2.5rem;flex-wrap:wrap;}
    .cinfo{display:flex;flex-direction:column;gap:.2rem;}
    .cinfo-label{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
    .cinfo-val{font-size:.9rem;font-weight:600;color:var(--deep);}
    .card-right{padding:2.5rem 2.5rem 2.5rem 2rem;display:flex;flex-direction:column;align-items:flex-end;justify-content:space-between;min-width:200px;}
    .price-box{text-align:right;}
    .price-label{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem;}
    .price-amount{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700;color:var(--gold);}
    .price-old{font-size:.85rem;color:var(--muted);text-decoration:line-through;margin-top:.2rem;}
    .students-bar{width:100%;height:4px;background:var(--warm);border-radius:2px;overflow:hidden;margin-top:.5rem;}
    .students-bar-fill{height:100%;background:var(--gold);border-radius:2px;transition:width 1s;}
    .students-info{font-size:.78rem;color:var(--muted);margin-top:.5rem;}
    .btn-view{background:var(--deep);color:#fff;border:none;padding:.7rem 1.5rem;font-size:.78rem;font-weight:600;letter-spacing:.08em;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:.5rem;border-radius:2px;}
    .btn-view:hover{background:var(--gold);color:var(--deep);}
    .btn-view:disabled{opacity:.5;cursor:not-allowed;background:var(--muted);}
    .course-overlay{position:fixed;inset:0;background:rgba(26,18,9,.88);backdrop-filter:blur(10px);z-index:9999;display:none;align-items:center;justify-content:center;padding:2rem;}
    .course-overlay.open{display:flex;}
    .course-modal{background:var(--cream);width:100%;max-width:820px;max-height:90vh;border-radius:8px;overflow:hidden;display:flex;flex-direction:column;animation:fadeInScale .4s cubic-bezier(.25,.46,.45,.94);}
    @@keyframes fadeInScale{from{opacity:0;transform:scale(.96);}to{opacity:1;transform:scale(1);}}
    .course-modal-hero{background:var(--deep);padding:3rem;position:relative;flex-shrink:0;}
    .course-modal-hero img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.25;}
    .course-modal-hero-content{position:relative;z-index:1;}
    .course-modal-close{position:absolute;top:1.5rem;right:1.5rem;background:rgba(255,255,255,.12);border:none;color:#fff;width:36px;height:36px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;transition:background .2s;}
    .course-modal-close:hover{background:rgba(255,255,255,.25);}
    .course-modal-body{padding:2.5rem 3rem;overflow-y:auto;flex:1;}
    .info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem;}
    .info-box{background:var(--warm);padding:1rem 1.2rem;border-radius:4px;border:1px solid var(--border);}
    .info-box-label{font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:.4rem;}
    .info-box-val{font-weight:700;font-size:.95rem;color:var(--deep);}
    .features-list{list-style:none;padding:0;margin:0 0 2rem;}
    .features-list li{display:flex;gap:.75rem;padding:.65rem 0;border-bottom:1px solid var(--border);font-size:.9rem;color:var(--deep);font-weight:300;}
    .features-list li:last-child{border-bottom:none;}
    .feat-icon{color:var(--gold);flex-shrink:0;margin-top:2px;}
    .course-modal-footer{padding:1.5rem 3rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;background:#fff;}
    .btn-enroll{background:var(--gold);color:var(--deep);border:none;padding:.9rem 2.5rem;font-weight:700;font-size:.85rem;letter-spacing:.08em;cursor:pointer;transition:all .25s;border-radius:3px;display:flex;align-items:center;gap:.6rem;}
    .btn-enroll:hover{background:var(--gold2);transform:translateY(-2px);box-shadow:0 6px 20px rgba(212,160,23,.4);}
    .btn-close-modal{border:1px solid var(--border);background:none;padding:.8rem 1.5rem;cursor:pointer;border-radius:3px;font-size:.8rem;}
    @@media(max-width:900px){
        .train-hero-inner{grid-template-columns:1fr;} .hero-image-panel{display:none;} .hero-content{padding:5rem 2rem;}
        .cards-wrapper{padding:4rem 1.5rem;} .course-card{grid-template-columns:auto 1fr;} .card-right{display:none;}
        .info-grid{grid-template-columns:1fr 1fr;}
    }
    @@media(max-width:600px){
        .cards-header{flex-direction:column;align-items:flex-start;gap:1.5rem;} .card-main{padding:1.5rem;}
        .course-modal-body{padding:1.5rem;} .info-grid{grid-template-columns:1fr;}
    }
</style>

<div class="training-page">
    <section class="train-hero">
        <div class="train-hero-inner">
            <div class="hero-content">
                <div class="hero-overline">
                    <div class="hero-overline-line"></div>
                    <span>Badminton Academy</span>
                </div>
                <h1 class="hero-title">Khóa học<br/><em>chuyên nghiệp.</em></h1>
                <p class="hero-subtitle">Nâng cao kỹ năng cùng huấn luyện viên chuyên nghiệp. Từ cơ bản đến nâng cao — chúng tôi có lộ trình dành riêng cho bạn.</p>
                <div class="hero-counts">
                    <div class="hcount-item"><div class="hcount-n">@Model.Count()</div><div class="hcount-l">Khóa học</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Count(c => c.Status == "Active")</div><div class="hcount-l">Đang mở</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Sum(c => c.CurrentStudents)</div><div class="hcount-l">Học viên</div></div>
                </div>
            </div>
            <div class="hero-image-panel">
                <img src="https://images.unsplash.com/photo-1613918108466-292b78a8ef85?w=800&q=80" alt="Training" />
                <div class="bg-watermark"><i class="bi bi-mortarboard-fill"></i></div>
            </div>
        </div>
    </section>

    <section class="cards-wrapper">
        <div class="cards-header">
            <div class="cards-heading">Các khóa học<span>đang mở &amp; sắp khai giảng</span></div>
            <div class="filter-tabs">
                <button class="ftab active" data-filter="all">Tất cả</button>
                <button class="ftab" data-filter="Beginner">Cơ bản</button>
                <button class="ftab" data-filter="Intermediate">Trung cấp</button>
                <button class="ftab" data-filter="Advanced">Nâng cao</button>
                <button class="ftab" data-filter="Full">Đã đầy</button>
            </div>
        </div>
        <div class="course-list" id="courseList">
            @if (!Model.Any())
            {
                
                    var samples = new[]
                    {
                        new { Name="Khóa Cơ Bản Dành Cho Người Mới", HLV="HLV Minh Tuấn", Level="Beginner", Weeks="8 tuần", Schedule="Thứ 2,4,6 – 18:00", Cur=12, Max=20, Price="1.500.000đ", Old="", Short="Nền tảng kỹ thuật cầu lông từ đầu dưới sự hướng dẫn tận tâm.", Feats="Kỹ thuật cầm vợt đúng cách\nDi chuyển cơ bản\nKỹ thuật đánh cơ bản", Status="Active" },
                        new { Name="Kỹ Năng Trung Cấp & Chiến Thuật", HLV="HLV Thanh Hương", Level="Intermediate", Weeks="12 tuần", Schedule="Thứ 3,5,7 – 19:00", Cur=16, Max=16, Price="2.500.000đ", Old="3.000.000đ", Short="Nâng cao chiến thuật và thể lực cho vận động viên trung cấp.", Feats="Chiến thuật đơn và đôi\nKỹ thuật serve nâng cao\nLuyện thể lực chuyên biệt", Status="Full" },
                        new { Name="Luyện Tập Nâng Cao & Thi Đấu", HLV="HLV Quang Vinh", Level="Advanced", Weeks="16 tuần", Schedule="Thứ 2,4,6,7 – 17:00", Cur=7, Max=10, Price="4.500.000đ", Old="", Short="Chương trình chuyên sâu cho vận động viên muốn tham gia thi đấu.", Feats="Phân tích video và chiến thuật\nThi đấu thực chiến có hướng dẫn\nPhục hồi và dinh dưỡng cho VĐV", Status="Active" },
                    };
                
                @foreach (var c in samples)
                {
                    var isFull = c.Status == "Full";
                    var pct = c.Max > 0 ? (c.Cur * 100 / c.Max) : 0;
                    var lvLabel = c.Level == "Beginner" ? "◎ Cơ Bản" : c.Level == "Intermediate" ? "● Trung Cấp" : "★ Nâng Cao";
                    <div class="course-card course-item @(isFull ? "is-full" : "")"
                         data-level="@(isFull ? "Full" : c.Level)"
                         data-status="@c.Status"
                         data-name="@c.Name"
                         data-hlv="@c.HLV"
                         data-level-val="@c.Level"
                         data-weeks="@c.Weeks"
                         data-schedule="@c.Schedule"
                         data-cur="@c.Cur"
                         data-max="@c.Max"
                         data-price="@c.Price"
                         data-old="@c.Old"
                         data-short="@c.Short"
                         data-img=""
                         data-feats="@c.Feats">
                        <div class="card-accent lv-@c.Level"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="level-tag @(isFull ? "Full" : c.Level)">@(isFull ? "🔒 Đã Đầy" : lvLabel)</span>
                                <span class="type-tag">@c.HLV</span>
                            </div>
                            <div class="card-name">@c.Name</div>
                            <div class="card-short">@c.Short</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Thời lượng</span><span class="cinfo-val">@c.Weeks</span></div>
                                <div class="cinfo"><span class="cinfo-label">Lịch học</span><span class="cinfo-val">@c.Schedule</span></div>
                                <div class="cinfo"><span class="cinfo-label">Học viên</span><span class="cinfo-val">@c.Cur/@c.Max người</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="price-box">
                                <div class="price-label">Học phí</div>
                                <div class="price-amount">@c.Price</div>
                                @if (!string.IsNullOrEmpty(c.Old)) { <div class="price-old">@c.Old</div> }
                                <div class="students-bar"><div class="students-bar-fill" style="width:@(pct)%"></div></div>
                                <div class="students-info">@c.Cur/@c.Max học viên đã đăng ký</div>
                            </div>
                            <button class="btn-view" @(isFull ? "disabled" : "")><i class="bi bi-arrow-right"></i> @(isFull ? "Hết chỗ" : "Chi tiết")</button>
                        </div>
                    </div>
                }
            }
            else
            {
                @foreach (var c in Model.OrderBy(x => x.DisplayOrder))
                {
                    var isFull = c.IsFull || c.Status == "Full";
                    var pct = c.MaxStudents.HasValue && c.MaxStudents > 0 ? Math.Min(100, c.CurrentStudents * 100 / c.MaxStudents.Value) : 0;
                    var eff = c.DiscountFee ?? c.TuitionFee;
                    var priceStr = eff.HasValue ? eff.Value.ToString("N0") + "đ" : "—";
                    var oldStr = (c.DiscountFee.HasValue && c.TuitionFee.HasValue) ? c.TuitionFee.Value.ToString("N0") + "đ" : "";
                    var lvLabel = c.Level == "Beginner" ? "◎ Cơ Bản" : c.Level == "Intermediate" ? "● Trung Cấp" : "★ Nâng Cao";
                    <div class="course-card course-item @(isFull ? "is-full" : "")"
                         data-level="@(isFull ? "Full" : c.Level)"
                         data-status="@c.Status"
                         data-name="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.CourseName ?? ""))"
                         data-hlv="@(c.Instructor ?? "")"
                         data-level-val="@c.Level"
                         data-weeks="@(c.DurationWeeks != null ? c.DurationWeeks + " tuần" : "—")"
                         data-schedule="@(c.Schedule ?? "—")"
                         data-cur="@c.CurrentStudents"
                         data-max="@(c.MaxStudents?.ToString() ?? "∞")"
                         data-price="@priceStr"
                         data-old="@oldStr"
                         data-short="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.ShortDesc ?? ""))"
                         data-img="@(c.FeaturedImage ?? "")"
                         data-feats="@Html.Raw(System.Net.WebUtility.HtmlEncode(c.Features ?? ""))">
                        <div class="card-accent lv-@c.Level"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="level-tag @(isFull ? "Full" : c.Level)">@(isFull ? "🔒 Đã Đầy" : lvLabel)</span>
                                @if (!string.IsNullOrEmpty(c.Instructor)) { <span class="type-tag">@c.Instructor</span> }
                                @if (c.IsFeatured) { <span style="color:var(--gold);font-size:.85rem;">★ Nổi bật</span> }
                            </div>
                            <div class="card-name">@c.CourseName</div>
                            <div class="card-short">@c.ShortDesc</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Thời lượng</span><span class="cinfo-val">@(c.DurationWeeks != null ? c.DurationWeeks + " tuần" : "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">Lịch học</span><span class="cinfo-val">@(c.Schedule ?? "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">Học viên</span><span class="cinfo-val">@c.CurrentStudents/@(c.MaxStudents?.ToString() ?? "∞") người</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="price-box">
                                <div class="price-label">Học phí</div>
                                <div class="price-amount">@priceStr</div>
                                @if (!string.IsNullOrEmpty(oldStr)) { <div class="price-old">@oldStr</div> }
                                <div class="students-bar"><div class="students-bar-fill" style="width:@(pct)%"></div></div>
                                <div class="students-info">@c.CurrentStudents/@(c.MaxStudents?.ToString() ?? "?") học viên đã đăng ký</div>
                            </div>
                            <button class="btn-view" @(isFull ? "disabled" : "")><i class="bi bi-arrow-right"></i> @(isFull ? "Hết chỗ" : "Chi tiết")</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<!-- DETAIL MODAL -->
<div class="course-overlay" id="courseOverlay" onclick="closeCourseDetail(event)">
    <div class="course-modal">
        <div class="course-modal-hero">
            <img id="cmImg" src="" alt="" style="display:none;" />
            <button class="course-modal-close" onclick="closeCourseDetailBtn()"><i class="bi bi-x"></i></button>
            <div class="course-modal-hero-content">
                <div id="cm-level-tag" class="level-tag" style="margin-bottom:1rem;display:inline-block;"></div>
                <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem;">
                    <span id="cm-instructor" style="border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);font-size:.72rem;padding:.2rem .7rem;"></span>
                </div>
                <h2 id="cm-name" style="font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;color:#fff;margin:0;"></h2>
                <p id="cm-short" style="color:rgba(255,255,255,.5);margin-top:.6rem;font-weight:300;"></p>
            </div>
        </div>
        <div class="course-modal-body">
            <div class="info-grid">
                <div class="info-box"><span class="info-box-label"><i class="bi bi-clock me-1"></i>Thời lượng</span><span class="info-box-val" id="cm-weeks"></span></div>
                <div class="info-box"><span class="info-box-label"><i class="bi bi-calendar3 me-1"></i>Lịch học</span><span class="info-box-val" id="cm-schedule" style="font-size:.88rem;"></span></div>
                <div class="info-box"><span class="info-box-label"><i class="bi bi-people me-1"></i>Học viên</span><span class="info-box-val" id="cm-students"></span></div>
                <div class="info-box" style="grid-column:span 3;">
                    <span class="info-box-label"><i class="bi bi-tag me-1"></i>Học phí</span>
                    <span class="info-box-val" id="cm-price" style="color:var(--gold);font-size:1.1rem;"></span>
                    <span id="cm-old-price" style="font-size:.82rem;color:var(--muted);text-decoration:line-through;margin-left:.5rem;"></span>
                </div>
            </div>
            <div style="font-weight:600;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Nội dung khóa học</div>
            <ul class="features-list" id="cm-features"></ul>
        </div>
        <div class="course-modal-footer">
            <div>
                <div style="font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.3rem;">Học phí</div>
                <div id="cm-price-big" style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--gold);"></div>
            </div>
            <div style="display:flex;gap:.75rem;">
                <button class="btn-close-modal" onclick="closeCourseDetailBtn()">Đóng</button>
                <button class="btn-enroll"><i class="bi bi-mortarboard"></i> Đăng ký ngay</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Gán sự kiện click qua JS thuần — tránh lỗi Razor với onclick inline phức tạp
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.course-card:not(.is-full)').forEach(function (card) {
            card.addEventListener('click', function () {
                var d = this.dataset;
                openCourseDetail(
                    d.name, d.hlv, d.levelVal, d.weeks, d.schedule,
                    d.cur + '/' + d.max, d.price, d.old, d.short, d.img,
                    (d.feats || '')
                );
            });
        });
    });

    // Filter
    document.querySelectorAll('.ftab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.ftab').forEach(function (b) { b.classList.remove('active'); });
            this.classList.add('active');
            var f = this.dataset.filter;
            document.querySelectorAll('.course-item').forEach(function (card) {
                card.style.display = (f === 'all' || card.dataset.level === f || card.dataset.status === f) ? '' : 'none';
            });
        });
    });

    function openCourseDetail(name, instructor, level, weeks, schedule, students, price, oldPrice, desc, img, features) {
        document.getElementById('cm-name').textContent = name;
        document.getElementById('cm-instructor').textContent = instructor ? '👤 ' + instructor : '';
        var lvEl = document.getElementById('cm-level-tag');
        lvEl.textContent = level === 'Beginner' ? '◎ Cơ Bản' : level === 'Intermediate' ? '● Trung Cấp' : '★ Nâng Cao';
        lvEl.className = 'level-tag ' + level;
        document.getElementById('cm-weeks').textContent = weeks;
        document.getElementById('cm-schedule').textContent = schedule;
        document.getElementById('cm-students').textContent = students;
        document.getElementById('cm-price').textContent = price;
        document.getElementById('cm-price-big').textContent = price;
        document.getElementById('cm-old-price').textContent = oldPrice || '';
        document.getElementById('cm-short').textContent = desc || '';
        var imgEl = document.getElementById('cmImg');
        if (img) { imgEl.src = img; imgEl.style.display = ''; } else { imgEl.style.display = 'none'; }
        var ul = document.getElementById('cm-features');
        ul.innerHTML = '';
        (features || '').split('\n').filter(function (f) { return f.trim(); }).forEach(function (f) {
            var li = document.createElement('li');
            li.innerHTML = '<i class="bi bi-check-circle feat-icon"></i>' + f.replace(/^[-•]\s*/, '');
            ul.appendChild(li);
        });
        document.getElementById('courseOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeCourseDetail(e) { if (e.target === document.getElementById('courseOverlay')) closeCourseDetailBtn(); }
    function closeCourseDetailBtn() { document.getElementById('courseOverlay').classList.remove('open'); document.body.style.overflow = ''; }
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeCourseDetailBtn(); });
</script>
}
