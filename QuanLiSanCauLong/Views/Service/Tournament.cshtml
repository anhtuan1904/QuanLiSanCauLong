@section Scripts {
    <script>
        (function(){
            function g(id){return document.getElementById(id);}
            function show(id){g(id).style.display='';}function hide(id){g(id).style.display='none';}function showFlex(id){g(id).style.display='flex';}

            function openTm(card){
                var d=card.dataset;
                var full=parseInt(d.max||0)>0&&parseInt(d.cur||0)>=parseInt(d.max||0)&&d.max!=='∞';
                var canReg=d.canReg==='1';

                // Hero bg
                var bg=g('tmBg');
                if(d.gallery){try{var imgs=JSON.parse(d.gallery);if(imgs[0]){bg.src=imgs[0];show('tmBg');}else hide('tmBg');}catch(e){hide('tmBg');}}
                else if(d.img){bg.src=d.img;show('tmBg');}else hide('tmBg');

                // Status badge
                var st=g('tmStatusTag');
                var stMap={Ongoing:'● Đang diễn ra',Upcoming:'◎ Sắp diễn ra',Finished:'✓ Đã kết thúc',Cancelled:'✕ Đã hủy'};
                st.textContent=stMap[d.statusVal]||d.statusVal;st.className='status-tag '+(d.statusVal||'');
                g('tmTypeTag').textContent=d.type||'';g('tmTypeTag').style.display=d.type?'':'none';
                g('tmFeaturedBadge').style.display=d.featured?'':'none';

                g('tmTitle').textContent=d.name||'';g('tmSubtitle').textContent=d.short||'';

                // Gallery
                try{var gImgs=JSON.parse(d.gallery||'[]');var strip=g('tmGalleryStrip');strip.innerHTML='';
                    if(gImgs.length>1){strip.style.display='flex';gImgs.forEach(function(src,i){var t=document.createElement('div');t.className='tm-gthumb'+(i===0?' active':'');t.innerHTML='<img src="'+src+'" alt=""/>';t.addEventListener('click',function(){g('tmBg').src=src;show('tmBg');strip.querySelectorAll('.tm-gthumb').forEach(function(x,j){x.classList.toggle('active',j===i);});});strip.appendChild(t);});}
                    else strip.style.display='none';
                }catch(e){hide('tmGalleryStrip');}

                // Dates
                g('tdDeadline').textContent=d.deadline||'—';g('tdStart').textContent=d.start||'—';g('tdEnd').textContent=d.end||'—';

                // Info
                g('tmVenue').textContent=d.venue||'—';
                g('tmPlayers').textContent=(d.cur||'0')+' / '+(d.max||'∞')+' người';
                var pct=parseInt(d.pct||0);g('tmPb').style.width=pct+'%';
                if(full){g('tmSlots').textContent='Đã đủ VĐV';}
                else if(d.max&&d.max!=='∞'){g('tmSlots').textContent='Còn '+(parseInt(d.max)-parseInt(d.cur||0))+' suất';}
                else g('tmSlots').textContent='';
                g('tmFee').textContent=d.fee||'—';
                g('tmPrizeVal').textContent=d.prize||'—';
                g('tmPrizeFoot').textContent=d.prize||'—';
                g('tmFeeFoot').textContent=d.fee?'Phí đăng ký: '+d.fee:'';

                // Venue card
                g('tmVenueName').textContent=d.venue||'';
                g('tmVenueAddr').textContent=d.venueAddr||'';
                if(d.map){g('tmMapLink').href=d.map;show('tmMapLink');}else hide('tmMapLink');

                // Prize podium
                try{
                    var lines=JSON.parse(d.prizeLines||'[]');
                    var podium=g('tmPodium');podium.innerHTML='';
                    var medals=['🥇','🥈','🥉'],cls=['p1','p2','p3'];
                    var shown=0;
                    lines.slice(0,3).forEach(function(line,i){
                        var clean=line.replace(/🥇\s*/g,'').replace(/🥈\s*/g,'').replace(/🥉\s*/g,'');
                        var parts=clean.split(' | ');var money=parts[0]||'';var extra=parts[1]||'';
                        if(!money)return;
                        var div=document.createElement('div');div.className='prize-card '+cls[i];
                        div.innerHTML='<div class="prize-medal">'+medals[i]+'</div><div class="prize-money">'+money+'</div>'+(extra?'<div class="prize-extra">'+extra+'</div>':'');
                        podium.appendChild(div);shown++;
                    });
                    if(shown>0){show('tmPodiumWrap');}else hide('tmPodiumWrap');
                }catch(e){hide('tmPodiumWrap');}

                // Video
                if(d.video){var yt=d.video.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);if(yt){g('tmVideoFrame').src='https://www.youtube.com/embed/'+yt[1]+'?rel=0';show('tmVideoWrap');}else hide('tmVideoWrap');}
                else{hide('tmVideoWrap');g('tmVideoFrame').src='';}

                // Description
                if(d.desc){g('tmDesc').textContent=d.desc;show('tmDescWrap');}else hide('tmDescWrap');

                // Schedule
                renderTmUl('tmSchedList','tmSchedWrap',d.schedule,'arrow');
                // Rules
                renderTmUl('tmRulesList','tmRulesWrap',d.rules,'check');

                // Sponsors
                try{
                    var sponsors=JSON.parse(d.sponsors||'[]');var sc=g('tmSponsorChips');sc.innerHTML='';
                    if(sponsors.length){sponsors.forEach(function(s){var chip=document.createElement('span');chip.className='sponsor-chip';chip.textContent='🏢 '+s;sc.appendChild(chip);});show('tmSponsorsWrap');}
                    else hide('tmSponsorsWrap');
                }catch(e){hide('tmSponsorsWrap');}

                // Notices
                g('tmRegFull').style.display=full?'flex':'none';
                g('tmRegOk').style.display='none';
                g('tmRegForm').classList.remove('open');
                var rb=g('btnRegToggle');
                if(!canReg){rb.disabled=true;rb.innerHTML='<i class="bi bi-'+(d.statusVal==='Ongoing'?'play':'lock')+' me-1"></i>'+(d.statusVal==='Upcoming'?'Đã đủ VĐV':d.statusVal==='Finished'?'Đã kết thúc':'Đang diễn ra');}
                else{rb.disabled=false;rb.innerHTML='<i class="bi bi-trophy me-1"></i> Đăng ký tham gia';}

                g('tmOverlay').classList.add('open');document.body.style.overflow='hidden';
                g('tmOverlay').querySelector('.tm-body').scrollTop=0;
            }

            function renderTmUl(ulId,wrapId,raw,icon){
                var ul=g(ulId),wrap=g(wrapId);ul.innerHTML='';
                var lines=(raw||'').split('\n').filter(function(l){return l.trim();});
                if(!lines.length){hide(wrapId);return;}
                lines.forEach(function(l){var li=document.createElement('li');var cls=icon==='arrow'?'bi-arrow-right-circle ic-gold':'bi-check-circle-fill ic-gold';li.innerHTML='<i class="bi '+cls+'"></i>'+l.replace(/^[-•]\s*/,'');ul.appendChild(li);});
                show(wrapId);
            }

            window.closeTm=function(){g('tmOverlay').classList.remove('open');document.body.style.overflow='';g('tmVideoFrame').src='';};
            window.toggleReg=function(){g('tmRegForm').classList.toggle('open');if(g('tmRegForm').classList.contains('open'))g('rName').focus();};
            window.submitReg=function(){
                var name=g('rName').value.trim(),phone=g('rPhone').value.trim(),email=g('rEmail').value.trim();
                if(!name||!phone||!email){alert('Vui lòng điền đầy đủ họ tên, số điện thoại và email.');return;}
                // Placeholder — tích hợp API thực tế
                g('tmRegForm').classList.remove('open');
                g('tmRegMsg').textContent='Đăng ký thành công! Chúng tôi sẽ liên hệ xác nhận trong 24 giờ.';
                showFlex('tmRegOk');
            };

            document.addEventListener('DOMContentLoaded',function(){
                document.querySelectorAll('.tour-card').forEach(function(card){card.addEventListener('click',function(){openTm(this);});});
            });

            // Filter
            document.querySelectorAll('.ftab').forEach(function(btn){
                btn.addEventListener('click',function(){
                    document.querySelectorAll('.ftab').forEach(function(b){b.classList.remove('active');});this.classList.add('active');
                    var f=this.dataset.filter;
                    document.querySelectorAll('.tour-item').forEach(function(card){card.style.display=(f==='all'||card.dataset.status===f)?'':'none';});
                });
            });

            g('tmCloseBtn').addEventListener('click',closeTm);
            g('tmOverlay').addEventListener('click',function(e){if(e.target===this)closeTm();});
            document.addEventListener('keydown',function(e){if(e.key==='Escape')closeTm();});
        })();
    </script>
}
