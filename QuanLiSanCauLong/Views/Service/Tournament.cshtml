</style>

<div class="tournament-page">
    <section class="tour-hero">
        <div class="tour-hero-inner">
            <div class="hero-content">
                <div class="hero-overline"><div class="hero-overline-line"></div><span>Badminton Tournament</span></div>
                <h1 class="hero-title">Giải đấu<br /><em>đỉnh cao.</em></h1>
                <p class="hero-subtitle">Thi đấu cùng những vận động viên đam mê. Tranh tài công bằng, giải thưởng hấp dẫn, kết nối cộng đồng cầu lông.</p>
                <div class="hero-counts">
                    <div class="hcount-item"><div class="hcount-n">@Model.Count()</div><div class="hcount-l">Giải đấu</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Count(t => t.Status == "Ongoing")</div><div class="hcount-l">Đang diễn ra</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Count(t => t.Status == "Upcoming")</div><div class="hcount-l">Sắp diễn ra</div></div>
                    <div class="hcount-item"><div class="hcount-n">@(((long)Model.Sum(t => t.PrizeMoney ?? 0) / 1000000))M</div><div class="hcount-l">Giải thưởng</div></div>
                </div>
            </div>
            <div class="hero-image-panel">
                <img src="https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=800&q=80" alt="Tournament" />
                <div class="bg-watermark"><i class="bi bi-trophy-fill"></i></div>
            </div>
        </div>
    </section>

    <section class="cards-wrapper">
        <div class="cards-header">
            <div class="cards-heading">Các giải đấu<span>nội bộ &amp; cộng đồng</span></div>
            <div class="filter-tabs">
                <button class="ftab active" data-filter="all">Tất cả</button>
                <button class="ftab" data-filter="Ongoing">Đang diễn ra</button>
                <button class="ftab" data-filter="Upcoming">Sắp diễn ra</button>
                <button class="ftab" data-filter="Finished">Đã kết thúc</button>
            </div>
        </div>
        <div class="tour-list">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-trophy"></i>
                    <div style="font-size:1rem;font-weight:600;margin-bottom:.5rem;">Chưa có giải đấu nào</div>
                </div>
            }
            else
            {
                @foreach (var t in Model)
                {
                    var pct = t.MaxPlayers.HasValue && t.MaxPlayers > 0 ? Math.Min(100, t.CurrentPlayers * 100 / t.MaxPlayers.Value) : 0;
                    var statusLabel = t.Status switch { "Ongoing" => "● Đang diễn ra", "Upcoming" => "◎ Sắp diễn ra", "Finished" => "✓ Đã kết thúc", "Cancelled" => "✕ Đã hủy", _ => t.Status };
                    var prizeLines = (t.PrizeDescription ?? "").Split('\n').Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
                    var prizeJson = System.Text.Json.JsonSerializer.Serialize(prizeLines);
                    var sponsorList = new System.Collections.Generic.List<string>();
                    if (!string.IsNullOrEmpty(t.Sponsors)) { try { sponsorList = System.Text.Json.JsonSerializer.Deserialize<System.Collections.Generic.List<string>>(t.Sponsors) ?? new(); } catch { } }
                    var sponsorJson = System.Text.Json.JsonSerializer.Serialize(sponsorList);
                    var galleryImgs = new System.Collections.Generic.List<string>();
                    if (!string.IsNullOrEmpty(t.FeaturedImage)) galleryImgs.Add(t.FeaturedImage);
                    if (t.TournamentImages != null) foreach (var gi in t.TournamentImages.OrderBy(i => i.DisplayOrder)) if (!galleryImgs.Contains(gi.ImagePath)) galleryImgs.Add(gi.ImagePath);
                    var galleryJson = System.Text.Json.JsonSerializer.Serialize(galleryImgs);
                    var isFull = t.IsFull;
                    var canReg = t.Status == "Upcoming" && !isFull;

                    <div class="tour-card tour-item"
                         data-status="@t.Status"
                         data-id="@t.TournamentId"
                         data-name="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.TournamentName))"
                         data-type="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.TournamentType ?? ""))"
                         data-status-val="@t.Status"
                         data-short="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.ShortDesc ?? ""))"
                         data-desc="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.Description ?? ""))"
                         data-start="@(t.StartDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")"
                         data-end="@(t.EndDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")"
                         data-deadline="@(t.RegistrationDeadline?.ToString("dd/MM/yyyy HH:mm") ?? "—")"
                         data-venue="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.Venue ?? "—"))"
                         data-venue-addr="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.VenueAddress ?? ""))"
                         data-map="@(t.MapUrl ?? "")"
                         data-cur="@t.CurrentPlayers"
                         data-max="@(t.MaxPlayers?.ToString() ?? "∞")"
                         data-pct="@pct"
                         data-fee="@(t.EntryFee?.ToString("N0") + "đ" ?? "Miễn phí")"
                         data-prize="@(t.PrizeMoney?.ToString("N0") + "đ" ?? "—")"
                         data-prize-lines="@Html.Raw(System.Net.WebUtility.HtmlEncode(prizeJson))"
                         data-rules="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.Rules ?? ""))"
                         data-schedule="@Html.Raw(System.Net.WebUtility.HtmlEncode(t.Schedule ?? ""))"
                         data-sponsors="@Html.Raw(System.Net.WebUtility.HtmlEncode(sponsorJson))"
                         data-video="@(t.VideoUrl ?? "")"
                         data-gallery="@Html.Raw(System.Net.WebUtility.HtmlEncode(galleryJson))"
                         data-img="@(t.FeaturedImage ?? "")"
                         data-featured="@(t.IsFeatured ? "1" : "")"
                         data-can-reg="@(canReg ? "1" : "")">
                        <div class="card-accent s-@t.Status"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="status-tag @t.Status">@statusLabel</span>
                                @if (!string.IsNullOrEmpty(t.TournamentType))
                                {
                                    <span class="type-tag">@t.TournamentType</span>
                                }
                                @if (t.IsFeatured)
                                {
                                    <span style="color:var(--gold);font-size:.85rem;">★</span>
                                }
                            </div>
                            <div class="card-name">@t.TournamentName</div>
                            <div class="card-short">@t.ShortDesc</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Thời gian</span><span class="cinfo-val">@(t.StartDate?.ToString("dd/MM") ?? "—") – @(t.EndDate?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">Địa điểm</span><span class="cinfo-val">@(t.Venue ?? "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">VĐV</span><span class="cinfo-val">@t.CurrentPlayers/@(t.MaxPlayers?.ToString() ?? "∞") người</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="prize-box">
                                <div class="prize-label">Giải thưởng</div>
                                <div class="prize-amount">@(t.PrizeMoney?.ToString("N0") + "đ" ?? "—")</div>
                                <div class="p-bar"><div class="p-bar-fill" style="width:@(pct)%;"></div></div>
                                <div class="p-info">@t.CurrentPlayers/@(t.MaxPlayers?.ToString() ?? "?") VĐV</div>
                            </div>
                            <button class="btn-view"><i class="bi bi-arrow-right"></i> Chi tiết</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<!-- ═══ MODAL CHI TIẾT GIẢI ĐẤU ═══ -->
