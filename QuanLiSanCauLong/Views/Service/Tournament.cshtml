@model IEnumerable<QuanLiSanCauLong.Models.Tournament>
@{
    ViewData["Title"] = "Giải Đấu Cầu Lông";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --gold: #d4a017;
        --gold2: #f5c842;
        --deep: #1a1209;
        --cream: #fdf8f0;
        --warm: #f5efe0;
        --muted: #8a7560;
        --border: #e8ddc8;
        --green: #16a34a;
        --blue: #0284c7;
        --purple: #7c3aed;
        --red: #dc2626;
    }

    * {
        box-sizing: border-box;
    }

    .tournament-page {
        background: var(--cream);
        font-family: 'Outfit',sans-serif;
        color: var(--deep);
    }
    /* HERO */
    .tour-hero {
        background: var(--deep);
        position: relative;
        overflow: hidden;
        padding: 0;
    }

    .tour-hero-inner {
        display: grid;
        grid-template-columns: 55% 45%;
        min-height: 88vh;
    }

    .hero-content {
        padding: 6rem 5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
    }

    .hero-overline {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .hero-overline-line {
        width: 40px;
        height: 1px;
        background: var(--gold);
    }

    .hero-overline span {
        font-size: .72rem;
        letter-spacing: .22em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 500;
    }

    .hero-title {
        font-family: 'Playfair Display',serif;
        font-size: clamp(3rem,5.5vw,6rem);
        font-weight: 900;
        color: #fff;
        line-height: 1;
        margin-bottom: 2rem;
    }

        .hero-title em {
            font-style: italic;
            color: var(--gold2);
        }

    .hero-subtitle {
        color: rgba(255,255,255,.5);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.8;
        max-width: 400px;
        margin-bottom: 3.5rem;
    }

    .hero-counts {
        display: flex;
        border: 1px solid rgba(255,255,255,.1);
        width: fit-content;
        border-radius: 4px;
        overflow: hidden;
    }

    .hcount-item {
        padding: 1.2rem 2rem;
        border-right: 1px solid rgba(255,255,255,.1);
        text-align: center;
    }

        .hcount-item:last-child {
            border-right: none;
        }

    .hcount-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .hcount-l {
        font-size: .72rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.35);
        margin-top: .3rem;
    }

    .hero-image-panel {
        position: relative;
        overflow: hidden;
    }

        .hero-image-panel img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: sepia(20%) contrast(1.1);
        }

        .hero-image-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right,var(--deep) 0%,transparent 30%);
            z-index: 1;
        }

    .bg-watermark {
        position: absolute;
        right: -2rem;
        bottom: -2rem;
        font-size: 18rem;
        opacity: .04;
        color: var(--gold);
        pointer-events: none;
    }
    /* CARDS */
    .cards-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 6rem 4rem;
    }

    .cards-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 4rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .cards-heading {
        font-family: 'Playfair Display',serif;
        font-size: 2.8rem;
        font-weight: 700;
        line-height: 1.1;
        color: var(--deep);
    }

        .cards-heading span {
            color: var(--gold);
            display: block;
            font-style: italic;
        }

    .filter-tabs {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .ftab {
        padding: .5rem 1.2rem;
        border: 1px solid var(--border);
        background: none;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: .05em;
        border-radius: 2px;
        transition: all .2s;
        color: var(--muted);
    }

        .ftab.active {
            background: var(--deep);
            color: #fff;
            border-color: var(--deep);
        }

        .ftab:hover:not(.active) {
            border-color: var(--deep);
            color: var(--deep);
        }

    .tour-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
    }

    .tour-card {
        background: #fff;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: stretch;
        cursor: pointer;
        transition: all .3s;
        overflow: hidden;
    }

        .tour-card:hover {
            transform: translateX(6px);
        }

            .tour-card:hover .card-accent {
                width: 6px;
            }

    .card-accent {
        width: 4px;
        flex-shrink: 0;
        transition: all .3s;
        background: var(--border);
    }

        .card-accent.s-Ongoing {
            background: var(--green);
        }

        .card-accent.s-Upcoming {
            background: var(--purple);
        }

        .card-accent.s-Finished {
            background: var(--muted);
        }

        .card-accent.s-Cancelled {
            background: var(--red);
        }

    .card-main {
        padding: 2.5rem 3rem;
    }

    .card-top-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .status-tag {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        padding: .3rem .9rem;
        border-radius: 2px;
    }

        .status-tag.Ongoing {
            background: #dcfce7;
            color: var(--green);
        }

        .status-tag.Upcoming {
            background: #ede9fe;
            color: var(--purple);
        }

        .status-tag.Finished {
            background: var(--warm);
            color: var(--muted);
        }

        .status-tag.Cancelled {
            background: #fee2e2;
            color: var(--red);
        }

    .type-tag {
        font-size: .72rem;
        color: var(--muted);
        border: 1px solid var(--border);
        padding: .2rem .7rem;
        border-radius: 2px;
    }

    .card-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .6rem;
        line-height: 1.2;
    }

    .card-short {
        color: var(--muted);
        font-size: .9rem;
        font-weight: 300;
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .card-info-row {
        display: flex;
        gap: 2.5rem;
        flex-wrap: wrap;
    }

    .cinfo {
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }

    .cinfo-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cinfo-val {
        font-size: .9rem;
        font-weight: 600;
        color: var(--deep);
    }

    .card-right {
        padding: 2.5rem 2.5rem 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: space-between;
        min-width: 200px;
    }

    .prize-box {
        text-align: right;
    }

    .prize-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .prize-amount {
        font-family: 'Playfair Display',serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--gold);
    }

    .p-bar {
        width: 100%;
        height: 4px;
        background: var(--warm);
        border-radius: 2px;
        overflow: hidden;
        margin-top: .5rem;
    }

    .p-bar-fill {
        height: 100%;
        border-radius: 2px;
        background: linear-gradient(90deg,var(--gold),var(--gold2));
        transition: width 1s;
    }

    .p-info {
        font-size: .75rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    .btn-view {
        background: var(--deep);
        color: #fff;
        border: none;
        padding: .7rem 1.5rem;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .08em;
        cursor: pointer;
        transition: all .25s;
        display: flex;
        align-items: center;
        gap: .5rem;
        border-radius: 2px;
        font-family: 'Outfit',sans-serif;
    }

        .btn-view:hover {
            background: var(--gold);
            color: var(--deep);
        }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3.5rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .25;
        }
    /* MODAL */
    .tm-overlay {
        position: fixed;
        inset: 0;
        background: rgba(26,18,9,.9);
        backdrop-filter: blur(12px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

        .tm-overlay.open {
            display: flex;
        }

    .tm-modal {
        background: var(--cream);
        width: 100%;
        max-width: 940px;
        max-height: 92vh;
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        animation: tmIn .35s cubic-bezier(.25,.46,.45,.94);
    }

    @@keyframes tmIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .tm-hero {
        background: var(--deep);
        padding: 2.5rem 3rem;
        position: relative;
        flex-shrink: 0;
        min-height: 190px;
        display: flex;
        align-items: flex-end;
    }

    .tm-hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: .3;
    }

    .tm-hero-grad {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top,rgba(26,18,9,.96) 0%,rgba(26,18,9,.35) 100%);
    }

    .tm-close-btn {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: rgba(255,255,255,.12);
        border: none;
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3;
        font-size: 1rem;
    }

        .tm-close-btn:hover {
            background: rgba(255,255,255,.25);
        }

    .tm-hero-inner {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .tm-badges {
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-bottom: .8rem;
        flex-wrap: wrap;
    }

    .tm-title {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        margin: 0 0 .4rem;
        line-height: 1.15;
    }

    .tm-subtitle {
        color: rgba(255,255,255,.5);
        font-size: .9rem;
        font-weight: 300;
        margin: 0;
    }

    .tm-gallery-strip {
        display: flex;
        gap: .4rem;
        padding: .6rem 1rem;
        background: rgba(0,0,0,.25);
        overflow-x: auto;
        flex-shrink: 0;
        scrollbar-width: thin;
    }

        .tm-gallery-strip::-webkit-scrollbar {
            height: 3px;
        }

        .tm-gallery-strip::-webkit-scrollbar-thumb {
            background: var(--gold);
        }

    .tm-gthumb {
        width: 68px;
        height: 46px;
        border-radius: 3px;
        overflow: hidden;
        flex-shrink: 0;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color .2s;
    }

        .tm-gthumb.active, .tm-gthumb:hover {
            border-color: var(--gold);
        }

        .tm-gthumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .tm-body {
        padding: 2rem 3rem;
        overflow-y: auto;
        flex: 1;
    }
    /* DATE TIMELINE */
    .tm-dates {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .tm-date-card {
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: .85rem 1rem;
        text-align: center;
    }

    .tm-date-label {
        font-size: .63rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .3rem;
    }

    .tm-date-val {
        font-weight: 700;
        font-size: .9rem;
        color: var(--deep);
    }

    .tm-date-time {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .15rem;
    }
    /* INFO GRID */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .info-box {
        background: var(--warm);
        padding: .85rem 1rem;
        border-radius: 5px;
        border: 1px solid var(--border);
    }

    .ib-label {
        font-size: .62rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: .3rem;
    }

    .ib-val {
        font-weight: 700;
        font-size: .88rem;
        color: var(--deep);
    }

    .ib-sub {
        font-size: .7rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .pb-wrap {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        margin-top: .35rem;
    }

    .pb-fill {
        height: 4px;
        border-radius: 2px;
        background: linear-gradient(90deg,var(--gold),var(--gold2));
        transition: width .6s;
    }
    /* PRIZE PODIUM */
    .prize-podium {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .65rem;
        margin-bottom: 1.5rem;
    }

    .prize-card {
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: .85rem 1rem;
        text-align: center;
    }

        .prize-card.p1 {
            border-color: #ffd700;
            background: rgba(255,215,0,.07);
        }

        .prize-card.p2 {
            border-color: #c0c0c0;
            background: rgba(192,192,192,.07);
        }

        .prize-card.p3 {
            border-color: #cd7f32;
            background: rgba(205,127,50,.07);
        }

    .prize-medal {
        font-size: 1.6rem;
        margin-bottom: .35rem;
    }

    .prize-money {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--deep);
    }

    .prize-extra {
        font-size: .72rem;
        color: var(--muted);
        margin-top: .2rem;
    }
    /* VENUE CARD */
    .venue-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        background: var(--warm);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: .9rem 1.2rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .venue-name {
        font-weight: 700;
        font-size: .9rem;
        color: var(--deep);
    }

    .venue-addr {
        font-size: .78rem;
        color: var(--muted);
        margin-top: .2rem;
    }

    .btn-map {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .5rem .9rem;
        background: var(--deep);
        border: none;
        border-radius: 4px;
        color: var(--gold);
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        white-space: nowrap;
    }

        .btn-map:hover {
            background: #2d1f0e;
            color: var(--gold2);
        }
    /* VIDEO */
    .tm-video {
        margin-bottom: 1.5rem;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .tm-video iframe {
            width: 100%;
            height: 210px;
            display: block;
            border: none;
        }
    /* SEC TITLE */
    .tm-sec {
        font-weight: 700;
        font-size: .7rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .7rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        padding-bottom: .45rem;
        border-bottom: 1px solid var(--border);
    }

    .ic-gold {
        color: var(--gold);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .ic-muted {
        color: var(--muted);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .tm-ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem;
    }

        .tm-ul li {
            display: flex;
            gap: .6rem;
            padding: .45rem 0;
            border-bottom: 1px solid var(--border);
            font-size: .87rem;
            font-weight: 300;
            color: var(--deep);
        }

            .tm-ul li:last-child {
                border-bottom: none;
            }
    /* SPONSORS */
    .sponsor-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: 1.5rem;
    }

    .sponsor-chip {
        background: rgba(29,78,216,.07);
        border: 1px solid rgba(29,78,216,.15);
        border-radius: 20px;
        padding: .28rem .8rem;
        font-size: .76rem;
        color: var(--deep);
    }
    /* REGISTER FORM */
    .tm-reg-form {
        display: none;
        padding: 1.2rem 3rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        flex-shrink: 0;
    }

        .tm-reg-form.open {
            display: block;
        }

    .tm-reg-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: .55rem;
        margin-bottom: .6rem;
    }

    .tm-reg-form input, .tm-reg-form select {
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 4px;
        font-size: .85rem;
        outline: none;
        font-family: 'Outfit',sans-serif;
        width: 100%;
        background: #fff;
    }

        .tm-reg-form input:focus, .tm-reg-form select:focus {
            border-color: var(--gold);
        }

    .btn-reg-submit {
        background: var(--deep);
        color: var(--gold);
        border: none;
        padding: .65rem 1.4rem;
        font-weight: 700;
        font-size: .82rem;
        cursor: pointer;
        border-radius: 4px;
        font-family: 'Outfit',sans-serif;
    }

    .reg-success {
        background: #dcfce7;
        border: 1px solid #86efac;
        border-radius: 5px;
        padding: .8rem 1rem;
        font-size: .83rem;
        color: var(--green);
        display: none;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1rem;
    }

    .reg-full {
        background: #fee2e2;
        border: 1px solid #fca5a5;
        border-radius: 5px;
        padding: .8rem 1rem;
        font-size: .83rem;
        color: var(--red);
        display: none;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1rem;
    }
    /* FOOTER */
    .tm-footer {
        padding: 1.1rem 3rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        background: #fff;
    }

    .tm-prize-label {
        font-size: .63rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .2rem;
    }

    .tm-prize-big {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .tm-prize-sub {
        font-size: .75rem;
        color: var(--muted);
        margin-top: .15rem;
    }

    .btn-close-tm {
        border: 1px solid var(--border);
        background: none;
        padding: .7rem 1.3rem;
        cursor: pointer;
        border-radius: 4px;
        font-size: .8rem;
        font-family: 'Outfit',sans-serif;
    }

    .btn-reg-tm {
        background: var(--gold);
        color: var(--deep);
        border: none;
        padding: .75rem 1.8rem;
        font-weight: 700;
        font-size: .83rem;
        cursor: pointer;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-reg-tm:hover {
            background: var(--gold2);
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

        .btn-reg-tm:disabled {
            opacity: .5;
            cursor: not-allowed;
            transform: none;
            background: var(--muted);
        }

    @@media(max-width:900px) {
        .tour-hero-inner {
            grid-template-columns: 1fr;
        }

        .hero-image-panel {
            display: none;
        }

        .hero-content {
            padding: 4rem 2rem;
        }

        .cards-wrapper {
            padding: 4rem 1.5rem;
        }

        .tour-card {
            grid-template-columns: auto 1fr;
        }

        .card-right {
            display: none;
        }

        .info-grid, .tm-dates {
            grid-template-columns: 1fr 1fr;
        }

        .prize-podium {
            grid-template-columns: repeat(3,1fr);
        }

        .tm-body, .tm-footer, .tm-reg-form {
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }

        .tm-hero {
            padding: 1.75rem 1.5rem;
        }

        .tm-reg-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width:600px) {
        .cards-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }

        .card-main {
            padding: 1.5rem;
        }

        .info-grid {
            grid-template-columns: 1fr 1fr;
        }

        .tm-title {
            font-size: 1.5rem;
        }

        .tm-dates {
            grid-template-columns: 1fr;
        }

        .tm-reg-grid {
            grid-template-columns: 1fr;
        }
