@model IEnumerable<QuanLiSanCauLong.Models.StringingService>
@{
    ViewData["Title"] = "Dịch Vụ Căng Vợt";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --gold: #d4a017;
        --gold2: #f5c842;
        --deep: #1a1209;
        --cream: #fdf8f0;
        --warm: #f5efe0;
        --muted: #8a7560;
        --border: #e8ddc8;
        --green: #16a34a;
    }

    * {
        box-sizing: border-box;
    }

    .stringing-page {
        background: var(--cream);
        font-family: 'Outfit',sans-serif;
        color: var(--deep);
    }
    /* HERO */
    .string-hero {
        background: var(--deep);
        position: relative;
        overflow: hidden;
        padding: 0;
    }

    .string-hero-inner {
        display: grid;
        grid-template-columns: 55% 45%;
        min-height: 88vh;
    }

    .hero-content {
        padding: 6rem 5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
    }

    .hero-overline {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .hero-overline-line {
        width: 40px;
        height: 1px;
        background: var(--gold);
    }

    .hero-overline span {
        font-size: .72rem;
        letter-spacing: .22em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 500;
    }

    .hero-title {
        font-family: 'Playfair Display',serif;
        font-size: clamp(3rem,5.5vw,6rem);
        font-weight: 900;
        color: #fff;
        line-height: 1;
        margin-bottom: 2rem;
    }

        .hero-title em {
            font-style: italic;
            color: var(--gold2);
        }

    .hero-subtitle {
        color: rgba(255,255,255,.5);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.8;
        max-width: 400px;
        margin-bottom: 3.5rem;
    }

    .hero-counts {
        display: flex;
        border: 1px solid rgba(255,255,255,.1);
        width: fit-content;
        border-radius: 4px;
        overflow: hidden;
    }

    .hcount-item {
        padding: 1.2rem 2rem;
        border-right: 1px solid rgba(255,255,255,.1);
        text-align: center;
    }

        .hcount-item:last-child {
            border-right: none;
        }

    .hcount-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .hcount-l {
        font-size: .72rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.35);
        margin-top: .3rem;
    }

    .hero-image-panel {
        position: relative;
        overflow: hidden;
    }

        .hero-image-panel img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: sepia(20%) contrast(1.1);
        }

        .hero-image-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right,var(--deep) 0%,transparent 30%);
            z-index: 1;
        }

    .bg-watermark {
        position: absolute;
        right: -2rem;
        bottom: -2rem;
        font-size: 18rem;
        opacity: .04;
        color: var(--gold);
        pointer-events: none;
    }
    /* CARDS */
    .cards-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 6rem 4rem;
    }

    .cards-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 4rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

    .cards-heading {
        font-family: 'Playfair Display',serif;
        font-size: 2.8rem;
        font-weight: 700;
        line-height: 1.1;
        color: var(--deep);
    }

        .cards-heading span {
            color: var(--gold);
            display: block;
            font-style: italic;
        }

    .filter-tabs {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .ftab {
        padding: .5rem 1.2rem;
        border: 1px solid var(--border);
        background: none;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        letter-spacing: .05em;
        border-radius: 2px;
        transition: all .2s;
        color: var(--muted);
    }

        .ftab.active {
            background: var(--deep);
            color: #fff;
            border-color: var(--deep);
        }

        .ftab:hover:not(.active) {
            border-color: var(--deep);
            color: var(--deep);
        }

    .service-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
    }

    .service-card {
        background: #fff;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: stretch;
        cursor: pointer;
        transition: all .3s;
        overflow: hidden;
    }

        .service-card:hover {
            transform: translateX(6px);
        }

            .service-card:hover .card-accent {
                width: 6px;
            }

    .card-accent {
        width: 4px;
        flex-shrink: 0;
        transition: all .3s;
        background: var(--border);
    }

        .card-accent.br-Yonex {
            background: #e53935;
        }

        .card-accent.br-Victor {
            background: #1565c0;
        }

        .card-accent.br-Lining {
            background: #ef6c00;
        }

        .card-accent.br-Apacs {
            background: #6a1b9a;
        }

        .card-accent.br-other {
            background: var(--gold);
        }

    .card-main {
        padding: 2.5rem 3rem;
    }

    .card-top-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .brand-tag {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        padding: .3rem .9rem;
        border-radius: 2px;
    }

        .brand-tag.Yonex {
            background: #ffebee;
            color: #c62828;
        }

        .brand-tag.Victor {
            background: #e3f2fd;
            color: #1565c0;
        }

        .brand-tag.Lining {
            background: #fff3e0;
            color: #e65100;
        }

        .brand-tag.Apacs {
            background: #f3e5f5;
            color: #6a1b9a;
        }

        .brand-tag.other {
            background: rgba(212,160,23,.1);
            color: var(--gold);
        }

    .badge-pop {
        background: #dbeafe;
        color: #0284c7;
        font-size: .65rem;
        font-weight: 700;
        padding: .2rem .6rem;
        border-radius: 2px;
    }

    .type-tag {
        font-size: .72rem;
        color: var(--muted);
        border: 1px solid var(--border);
        padding: .2rem .7rem;
        border-radius: 2px;
    }

    .card-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--deep);
        margin-bottom: .6rem;
        line-height: 1.2;
    }

    .card-short {
        color: var(--muted);
        font-size: .9rem;
        font-weight: 300;
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .card-info-row {
        display: flex;
        gap: 2.5rem;
        flex-wrap: wrap;
    }

    .cinfo {
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }

    .cinfo-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cinfo-val {
        font-size: .9rem;
        font-weight: 600;
        color: var(--deep);
    }

    .card-right {
        padding: 2.5rem 2.5rem 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: space-between;
        min-width: 200px;
    }

    .price-box {
        text-align: right;
    }

    .price-label {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .4rem;
    }

    .price-amount {
        font-family: 'Playfair Display',serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--gold);
    }

    .price-old {
        font-size: .85rem;
        color: var(--muted);
        text-decoration: line-through;
        margin-top: .2rem;
    }

    .warranty-info {
        font-size: .75rem;
        color: var(--muted);
        margin-top: .4rem;
    }

    .btn-view {
        background: var(--deep);
        color: #fff;
        border: none;
        padding: .7rem 1.5rem;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .08em;
        cursor: pointer;
        transition: all .25s;
        display: flex;
        align-items: center;
        gap: .5rem;
        border-radius: 2px;
        font-family: 'Outfit',sans-serif;
    }

        .btn-view:hover {
            background: var(--gold);
            color: var(--deep);
        }
    /* MODAL */
    .sm-overlay {
        position: fixed;
        inset: 0;
        background: rgba(26,18,9,.9);
        backdrop-filter: blur(12px);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

        .sm-overlay.open {
            display: flex;
        }

    .sm-modal {
        background: var(--cream);
        width: 100%;
        max-width: 900px;
        max-height: 92vh;
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        animation: smIn .35s cubic-bezier(.25,.46,.45,.94);
    }

    @@keyframes smIn {
        from {
            opacity: 0;
            transform: scale(.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .sm-hero {
        background: var(--deep);
        padding: 2.5rem 3rem;
        position: relative;
        flex-shrink: 0;
        min-height: 180px;
        display: flex;
        align-items: flex-end;
    }

    .sm-hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: .3;
    }

    .sm-hero-grad {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top,rgba(26,18,9,.96) 0%,rgba(26,18,9,.35) 100%);
    }

    .sm-close-btn {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: rgba(255,255,255,.12);
        border: none;
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3;
        font-size: 1rem;
    }

        .sm-close-btn:hover {
            background: rgba(255,255,255,.25);
        }

    .sm-hero-inner {
        position: relative;
        z-index: 2;
        width: 100%;
    }

    .sm-badges {
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-bottom: .8rem;
        flex-wrap: wrap;
    }

    .sm-title {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        margin: 0 0 .4rem;
        line-height: 1.15;
    }

    .sm-subtitle {
        color: rgba(255,255,255,.5);
        font-size: .9rem;
        font-weight: 300;
        margin: 0;
    }

    .sm-gallery-strip {
        display: flex;
        gap: .4rem;
        padding: .6rem 1rem;
        background: rgba(0,0,0,.25);
        overflow-x: auto;
        flex-shrink: 0;
        scrollbar-width: thin;
    }

        .sm-gallery-strip::-webkit-scrollbar {
            height: 3px;
        }

        .sm-gallery-strip::-webkit-scrollbar-thumb {
            background: var(--gold);
        }

    .sm-gthumb {
        width: 68px;
        height: 46px;
        border-radius: 3px;
        overflow: hidden;
        flex-shrink: 0;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color .2s;
    }

        .sm-gthumb.active, .sm-gthumb:hover {
            border-color: var(--gold);
        }

        .sm-gthumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .sm-body {
        padding: 2rem 3rem;
        overflow-y: auto;
        flex: 1;
    }
    /* BENEFITS */
    .sm-benefits {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: 1.5rem;
    }

    .sm-benefit {
        background: rgba(212,160,23,.1);
        border: 1px solid rgba(212,160,23,.25);
        border-radius: 20px;
        padding: .28rem .8rem;
        font-size: .76rem;
        color: var(--deep);
        font-weight: 500;
    }
    /* SPECS TABLE */
    .specs-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .specs-table tr:nth-child(even) td {
            background: var(--warm);
        }

        .specs-table td {
            padding: .55rem .9rem;
            border-bottom: 1px solid var(--border);
            font-size: .85rem;
        }

        .specs-table tr:last-child td {
            border-bottom: none;
        }

        .specs-table td:first-child {
            color: var(--muted);
            font-size: .7rem;
            letter-spacing: .09em;
            text-transform: uppercase;
            font-weight: 700;
            width: 38%;
        }

        .specs-table td:last-child {
            color: var(--deep);
            font-weight: 600;
        }
    /* VIDEO */
    .sm-video {
        margin-bottom: 1.5rem;
        border-radius: 6px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

        .sm-video iframe {
            width: 100%;
            height: 210px;
            display: block;
            border: none;
        }

    .sm-sec-title {
        font-weight: 700;
        font-size: .7rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .7rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        padding-bottom: .45rem;
        border-bottom: 1px solid var(--border);
    }

    .sm-ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem;
    }

        .sm-ul li {
            display: flex;
            gap: .6rem;
            padding: .45rem 0;
            border-bottom: 1px solid var(--border);
            font-size: .87rem;
            font-weight: 300;
        }

            .sm-ul li:last-child {
                border-bottom: none;
            }

    .ic-gold {
        color: var(--gold);
        flex-shrink: 0;
        margin-top: 2px;
    }
    /* BOOKING FORM */
    .sm-book-form {
        display: none;
        padding: 1.2rem 3rem;
        background: var(--warm);
        border-top: 1px solid var(--border);
        flex-shrink: 0;
    }

        .sm-book-form.open {
            display: block;
        }

    .sm-book-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
        margin-bottom: .6rem;
    }

    .sm-book-form input, .sm-book-form textarea {
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: 4px;
        font-size: .85rem;
        outline: none;
        font-family: 'Outfit',sans-serif;
        width: 100%;
        background: #fff;
    }

        .sm-book-form input:focus, .sm-book-form textarea:focus {
            border-color: var(--gold);
        }

    .btn-book-submit {
        background: var(--deep);
        color: var(--gold);
        border: none;
        padding: .65rem 1.4rem;
        font-weight: 700;
        font-size: .82rem;
        cursor: pointer;
        border-radius: 4px;
        font-family: 'Outfit',sans-serif;
    }
    /* FOOTER */
    .sm-footer {
        padding: 1.1rem 3rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        background: #fff;
    }

    .sm-price-big {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .sm-price-label {
        font-size: .63rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .2rem;
    }

    .sm-price-old {
        font-size: .82rem;
        color: var(--muted);
        text-decoration: line-through;
        margin-left: .4rem;
    }

    .btn-close-sm {
        border: 1px solid var(--border);
        background: none;
        padding: .7rem 1.3rem;
        cursor: pointer;
        border-radius: 4px;
        font-size: .8rem;
        font-family: 'Outfit',sans-serif;
    }

    .btn-book-sm {
        background: var(--gold);
        color: var(--deep);
        border: none;
        padding: .75rem 1.8rem;
        font-weight: 700;
        font-size: .83rem;
        cursor: pointer;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: .45rem;
        transition: all .25s;
        font-family: 'Outfit',sans-serif;
    }

        .btn-book-sm:hover {
            background: var(--gold2);
            transform: translateY(-1px);
            box-shadow: 0 5px 16px rgba(212,160,23,.35);
        }

    .book-success {
        background: #dcfce7;
        border: 1px solid #86efac;
        border-radius: 5px;
        padding: .8rem 1rem;
        font-size: .83rem;
        color: var(--green);
        display: none;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1rem;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3.5rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .25;
        }

    @@media(max-width:900px) {
        .string-hero-inner {
            grid-template-columns: 1fr;
        }

        .hero-image-panel {
            display: none;
        }

        .hero-content {
            padding: 4rem 2rem;
        }

        .cards-wrapper {
            padding: 4rem 1.5rem;
        }

        .service-card {
            grid-template-columns: auto 1fr;
        }

        .card-right {
            display: none;
        }

        .sm-body, .sm-footer, .sm-book-form {
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }

        .sm-hero {
            padding: 1.75rem 1.5rem;
        }
    }

    @@media(max-width:600px) {
        .cards-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1.5rem;
        }

        .card-main {
            padding: 1.5rem;
        }

        .sm-book-grid {
            grid-template-columns: 1fr;
        }

        .sm-title {
            font-size: 1.5rem;
        }
    }
</style>

<div class="stringing-page">
    <section class="string-hero">
        <div class="string-hero-inner">
            <div class="hero-content">
                <div class="hero-overline"><div class="hero-overline-line"></div><span>Professional Stringing</span></div>
                <h1 class="hero-title">Căng vợt<br /><em>chuyên nghiệp.</em></h1>
                <p class="hero-subtitle">Dịch vụ căng vợt cầu lông chuẩn kỹ thuật với các thương hiệu dây hàng đầu. Thợ lành nghề, máy căng hiện đại, bảo hành uy tín.</p>
                <div class="hero-counts">
                    <div class="hcount-item"><div class="hcount-n">@Model.Count()</div><div class="hcount-l">Dịch vụ</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Count(s => s.IsPopular)</div><div class="hcount-l">Phổ biến</div></div>
                    <div class="hcount-item"><div class="hcount-n">@Model.Select(s => s.Brand).Where(b => b != null).Distinct().Count()</div><div class="hcount-l">Thương hiệu</div></div>
                </div>
            </div>
            <div class="hero-image-panel">
                <img src="https://images.unsplash.com/photo-1615117972428-28de67cda58e?w=800&q=80" alt="Stringing" />
                <div class="bg-watermark"><i class="bi bi-tools"></i></div>
            </div>
        </div>
    </section>

    <section class="cards-wrapper">
        <div class="cards-header">
            <div class="cards-heading">Các gói dịch vụ<span>căng vợt &amp; bảo hành</span></div>
            <div class="filter-tabs">
                <button class="ftab active" data-filter="all">Tất cả</button>
                <button class="ftab" data-filter="Yonex">Yonex</button>
                <button class="ftab" data-filter="Victor">Victor</button>
                <button class="ftab" data-filter="Lining">Li-Ning</button>
                <button class="ftab" data-filter="popular">⚡ Phổ biến</button>
            </div>
        </div>
        <div class="service-list">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-tools"></i>
                    <div style="font-size:1rem;font-weight:600;margin-bottom:.5rem;">Chưa có dịch vụ nào</div>
                </div>
            }
            else
            {
                @foreach (var s in Model)
                {
                    var brandCss = s.Brand ?? "other";
                    var priceStr = s.Price.HasValue ? s.Price.Value.ToString("N0") + "đ" : "Liên hệ";
                    var oldStr = (s.DiscountPrice.HasValue && s.Price.HasValue) ? s.Price.Value.ToString("N0") + "đ" : "";
                    var tensionDisplay = (s.TensionMin.HasValue && s.TensionMax.HasValue) ? $"{s.TensionMin}–{s.TensionMax} lbs" : (s.Tension ?? "—");
                    var galleryImgs = new System.Collections.Generic.List<string>();
                    if (!string.IsNullOrEmpty(s.FeaturedImage)) galleryImgs.Add(s.FeaturedImage);
                    if (s.StringingImages != null) foreach (var gi in s.StringingImages.OrderBy(i => i.DisplayOrder)) if (!galleryImgs.Contains(gi.ImagePath)) galleryImgs.Add(gi.ImagePath);
                    var galleryJson = System.Text.Json.JsonSerializer.Serialize(galleryImgs);
                    var effPrice = s.DiscountPrice ?? s.Price;
                    var effPriceStr = effPrice.HasValue ? effPrice.Value.ToString("N0") + "đ" : "Liên hệ";

                    <div class="service-card service-item"
                         data-brand="@(s.Brand ?? "other")"
                         data-popular="@(s.IsPopular ? "true" : "false")"
                         data-id="@s.StringingId"
                         data-name="@Html.Raw(System.Net.WebUtility.HtmlEncode(s.ServiceName))"
                         data-brand-val="@(s.Brand ?? "Khác")"
                         data-model="@Html.Raw(System.Net.WebUtility.HtmlEncode(s.StringModel ?? ""))"
                         data-tension="@Html.Raw(System.Net.WebUtility.HtmlEncode(tensionDisplay))"
                         data-gauge="@(s.StringGauge ?? "")"
                         data-color="@Html.Raw(System.Net.WebUtility.HtmlEncode(s.StringColor ?? ""))"
                         data-duration="@(s.DurationMinutes?.ToString() ?? "—")"
                         data-warranty="@(s.WarrantyDays?.ToString() ?? "—")"
                         data-price="@effPriceStr"
                         data-old="@oldStr"
                         data-short="@Html.Raw(System.Net.WebUtility.HtmlEncode(s.ShortDesc ?? ""))"
                         data-img="@(s.FeaturedImage ?? "")"
                         data-gallery="@Html.Raw(System.Net.WebUtility.HtmlEncode(galleryJson))"
                         data-feats="@Html.Raw(System.Net.WebUtility.HtmlEncode(s.Features ?? ""))"
                         data-benefits="@Html.Raw(System.Net.WebUtility.HtmlEncode(s.Benefits ?? ""))"
                         data-video="@(s.VideoUrl ?? "")">
                        <div class="card-accent br-@brandCss"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="brand-tag @brandCss">@(s.Brand ?? "Khác")</span>
                                @if (s.IsPopular)
                                {
                                    <span class="badge-pop">⚡ Phổ biến</span>
                                }
                                @if (s.IsFeatured)
                                {
                                    <span style="color:var(--gold);font-size:.85rem;">★</span>
                                }
                                @if (!string.IsNullOrEmpty(s.StringModel))
                                {
                                    <span class="type-tag">@s.StringModel</span>
                                }
                            </div>
                            <div class="card-name">@s.ServiceName</div>
                            <div class="card-short">@s.ShortDesc</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Lực căng</span><span class="cinfo-val">@tensionDisplay</span></div>
                                <div class="cinfo"><span class="cinfo-label">Thời gian</span><span class="cinfo-val">@(s.DurationMinutes?.ToString() ?? "—") phút</span></div>
                                <div class="cinfo"><span class="cinfo-label">Bảo hành</span><span class="cinfo-val">@(s.WarrantyDays?.ToString() ?? "—") ngày</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="price-box">
                                <div class="price-label">Chi phí</div>
                                <div class="price-amount">@effPriceStr</div>
                                @if (!string.IsNullOrEmpty(oldStr))
                                {
                                    <div class="price-old">@oldStr</div>
                                }
                                @if (s.WarrantyDays.HasValue)
                                {
                                    <div class="warranty-info"><i class="bi bi-shield-check me-1"></i>BH @s.WarrantyDays ngày</div>
                                }
                            </div>
                            <button class="btn-view"><i class="bi bi-arrow-right"></i> Chi tiết</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<!-- ═══ MODAL CHI TIẾT CĂNG VỢT ═══ -->
<div class="sm-overlay" id="smOverlay">
    <div class="sm-modal">
        <div class="sm-hero">
            <img class="sm-hero-bg" id="smBg" src="" alt="" style="display:none;" />
            <div class="sm-hero-grad"></div>
            <button class="sm-close-btn" id="smCloseBtn"><i class="bi bi-x-lg"></i></button>
            <div class="sm-hero-inner">
                <div class="sm-badges">
                    <div id="smBrandTag" class="brand-tag" style="margin-bottom:0;"></div>
                    <span id="smBadgePop" style="display:none;background:rgba(2,132,199,.2);color:#7dd3fc;font-size:.63rem;font-weight:700;padding:.2rem .55rem;border-radius:2px;">⚡ PHỔ BIẾN</span>
                    <span id="smModelTag" style="border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);font-size:.72rem;padding:.2rem .7rem;"></span>
                </div>
                <h2 class="sm-title" id="smTitle"></h2>
                <p class="sm-subtitle" id="smSubtitle"></p>
            </div>
        </div>
        <div class="sm-gallery-strip" id="smGalleryStrip" style="display:none;"></div>
        <div class="sm-body">
            <!-- Benefits chips -->
            <div class="sm-benefits" id="smBenefits"></div>
            <!-- Specs table -->
            <table class="specs-table" id="smSpecsTable">
                <tbody id="smSpecsTbody"></tbody>
            </table>
            <!-- Video -->
            <div class="sm-video" id="smVideoWrap" style="display:none;">
                <iframe id="smVideoFrame" src="" allowfullscreen></iframe>
            </div>
            <!-- Description -->
            <div id="smDescWrap" style="display:none;margin-bottom:1.5rem;">
                <div class="sm-sec-title"><i class="bi bi-file-text ic-gold"></i>Mô tả chi tiết</div>
                <p id="smDesc" style="font-size:.88rem;font-weight:300;line-height:1.7;color:var(--deep);margin:0;white-space:pre-wrap;"></p>
            </div>
            <!-- Features -->
            <div id="smFeatsWrap" style="display:none;margin-bottom:1.5rem;">
                <div class="sm-sec-title"><i class="bi bi-check2-all ic-gold"></i>Tính năng nổi bật</div>
                <ul class="sm-ul" id="smFeatsList"></ul>
            </div>
            <!-- Book success -->
            <div class="book-success" id="smBookOk">
                <i class="bi bi-check-circle-fill"></i><span id="smBookMsg"></span>
            </div>
        </div>
        <!-- Book form -->
        <div class="sm-book-form" id="smBookForm">
            <div style="font-weight:700;font-size:.77rem;letter-spacing:.07em;text-transform:uppercase;color:var(--deep);margin-bottom:.85rem;">
                <i class="bi bi-calendar-check me-1" style="color:var(--gold);"></i>Đặt lịch căng vợt
            </div>
            <div class="sm-book-grid">
                <input type="text" id="sName" placeholder="Họ và tên *" />
                <input type="tel" id="sPhone" placeholder="Số điện thoại *" />
            </div>
            <textarea id="sNote" rows="2" placeholder="Ghi chú (lực căng muốn, loại dây, thời gian...)"></textarea>
            <div style="display:flex;justify-content:flex-end;margin-top:.55rem;">
                <button class="btn-book-submit" onclick="submitBook()"><i class="bi bi-check-circle me-1"></i>Xác nhận đặt lịch</button>
            </div>
        </div>
        <div class="sm-footer">
            <div>
                <div class="sm-price-label">Chi phí dịch vụ</div>
                <div style="display:flex;align-items:baseline;gap:.4rem;">
                    <div class="sm-price-big" id="smPriceBig"></div>
                    <div class="sm-price-old" id="smPriceOld"></div>
                </div>
            </div>
            <div style="display:flex;gap:.6rem;align-items:center;">
                <button class="btn-close-sm" onclick="closeSm()">Đóng</button>
                <button class="btn-book-sm" onclick="toggleBook()"><i class="bi bi-tools me-1"></i>Đặt lịch ngay</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            function g(id){return document.getElementById(id);}
            function show(id){g(id).style.display='';}function hide(id){g(id).style.display='none';}

            function openSm(card){
                var d=card.dataset;
                // Hero bg
                var bg=g('smBg');
                if(d.gallery){try{var imgs=JSON.parse(d.gallery);if(imgs[0]){bg.src=imgs[0];show('smBg');}else hide('smBg');}catch(e){hide('smBg');}}
                else if(d.img){bg.src=d.img;show('smBg');}else hide('smBg');

                // Brand + badges
                var bt=g('smBrandTag');bt.textContent=d.brandVal||'Khác';bt.className='brand-tag '+(d.brand||'other');
                g('smBadgePop').style.display=d.popular==='true'?'':'none';
                g('smModelTag').textContent=d.model?'🎯 '+d.model:'';

                // Title
                g('smTitle').textContent=d.name||'';
                g('smSubtitle').textContent=d.short||'';

                // Gallery strip
                try{
                    var imgs=JSON.parse(d.gallery||'[]');var strip=g('smGalleryStrip');strip.innerHTML='';
                    if(imgs.length>1){strip.style.display='flex';imgs.forEach(function(src,i){var t=document.createElement('div');t.className='sm-gthumb'+(i===0?' active':'');t.innerHTML='<img src="'+src+'" alt=""/>';t.addEventListener('click',function(){g('smBg').src=src;show('smBg');strip.querySelectorAll('.sm-gthumb').forEach(function(x,j){x.classList.toggle('active',j===i);});});strip.appendChild(t);});}
                    else strip.style.display='none';
                }catch(e){hide('smGalleryStrip');}

                // Benefits chips
                var bRow=g('smBenefits');bRow.innerHTML='';
                (d.benefits||'').split('\n').filter(function(b){return b.trim();}).forEach(function(b){
                    var s=document.createElement('span');s.className='sm-benefit';s.textContent='⚡ '+b.trim();bRow.appendChild(s);
                });

                // Specs table
                var tbody=g('smSpecsTbody');tbody.innerHTML='';
                var specs=[];
                if(d.brandVal&&d.brandVal!=='—')specs.push(['Thương hiệu',d.brandVal]);
                if(d.model)specs.push(['Model dây',d.model]);
                if(d.tension&&d.tension!=='—')specs.push(['Lực căng',d.tension]);
                if(d.gauge)specs.push(['Độ dày dây',d.gauge]);
                if(d.color)specs.push(['Màu dây',d.color]);
                if(d.duration&&d.duration!=='—')specs.push(['Thời gian căng',d.duration+' phút']);
                if(d.warranty&&d.warranty!=='—')specs.push(['Bảo hành',d.warranty+' ngày']);
                specs.forEach(function(sp){
                    var tr=document.createElement('tr');tr.innerHTML='<td>'+sp[0]+'</td><td>'+sp[1]+'</td>';tbody.appendChild(tr);
                });

                // Video
                if(d.video){var yt=d.video.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?#]+)/);if(yt){g('smVideoFrame').src='https://www.youtube.com/embed/'+yt[1]+'?rel=0';show('smVideoWrap');}else hide('smVideoWrap');}
                else{hide('smVideoWrap');g('smVideoFrame').src='';}

                // Description
                if(d.short){g('smDesc').textContent=d.short;show('smDescWrap');}else hide('smDescWrap');

                // Features
                var feats=(d.feats||'').split('\n').filter(function(f){return f.trim();});
                var fUl=g('smFeatsList');fUl.innerHTML='';
                if(feats.length){feats.forEach(function(f){var li=document.createElement('li');li.innerHTML='<i class="bi bi-check-circle-fill ic-gold"></i>'+f.replace(/^[-•]\s*/,'');fUl.appendChild(li);});show('smFeatsWrap');}
                else hide('smFeatsWrap');

                // Price
                g('smPriceBig').textContent=d.price||'—';g('smPriceOld').textContent=d.old||'';
                g('smBookOk').style.display='none';
                g('smBookForm').classList.remove('open');

                g('smOverlay').classList.add('open');document.body.style.overflow='hidden';
                g('smOverlay').querySelector('.sm-body').scrollTop=0;
            }

            window.closeSm=function(){g('smOverlay').classList.remove('open');document.body.style.overflow='';g('smVideoFrame').src='';};
            window.toggleBook=function(){g('smBookForm').classList.toggle('open');if(g('smBookForm').classList.contains('open'))g('sName').focus();};
            window.submitBook=function(){
                var name=g('sName').value.trim(),phone=g('sPhone').value.trim();
                if(!name||!phone){alert('Vui lòng nhập họ tên và số điện thoại.');return;}
                // Placeholder — tích hợp API thực tế nếu cần
                g('smBookForm').classList.remove('open');
                g('smBookMsg').textContent='Đặt lịch thành công! Chúng tôi sẽ liên hệ xác nhận trong vòng 30 phút.';
                g('smBookOk').style.display='flex';
            };

            document.addEventListener('DOMContentLoaded',function(){
                document.querySelectorAll('.service-card').forEach(function(card){card.addEventListener('click',function(){openSm(this);});});
            });

            // Filter
            document.querySelectorAll('.ftab').forEach(function(btn){
                btn.addEventListener('click',function(){
                    document.querySelectorAll('.ftab').forEach(function(b){b.classList.remove('active');});this.classList.add('active');
                    var f=this.dataset.filter;
                    document.querySelectorAll('.service-item').forEach(function(card){
                        card.style.display=(f==='all'||(f==='popular'&&card.dataset.popular==='true')||card.dataset.brand===f)?'':'none';
                    });
                });
            });

            g('smCloseBtn').addEventListener('click',closeSm);
            g('smOverlay').addEventListener('click',function(e){if(e.target===this)closeSm();});
            document.addEventListener('keydown',function(e){if(e.key==='Escape')closeSm();});
        })();
    </script>
}
