@model IEnumerable<QuanLiSanCauLong.Models.StringingService>
@{
    ViewData["Title"] = "Dịch Vụ Căng Vợt";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --gold:   #d4a017;
        --gold2:  #f5c842;
        --deep:   #1a1209;
        --cream:  #fdf8f0;
        --warm:   #f5efe0;
        --muted:  #8a7560;
        --border: #e8ddc8;
        --active: #16a34a;
        --popular:#0284c7;
    }
    .stringing-page { background: var(--cream); font-family: 'Outfit', sans-serif; color: var(--deep); }

    /* ── HERO ─────────────────────────────────────────── */
    .string-hero { background: var(--deep); position: relative; overflow: hidden; padding: 0; }
    .string-hero-inner { display: grid; grid-template-columns: 55% 45%; min-height: 88vh; }
    .hero-content { padding: 6rem 5rem; display: flex; flex-direction: column; justify-content: center; position: relative; z-index: 2; }
    .hero-overline { display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem; }
    .hero-overline-line { width: 40px; height: 1px; background: var(--gold); }
    .hero-overline span { font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: var(--gold); font-weight: 500; }
    .hero-title { font-family: 'Playfair Display', serif; font-size: clamp(3rem, 5.5vw, 6rem); font-weight: 900; color: #fff; line-height: 1.0; margin-bottom: 2rem; }
    .hero-title em { font-style: italic; color: var(--gold2); }
    .hero-subtitle { color: rgba(255,255,255,.5); font-size: 1rem; font-weight: 300; line-height: 1.8; max-width: 400px; margin-bottom: 3.5rem; }
    .hero-counts { display: flex; gap: 0; border: 1px solid rgba(255,255,255,.1); width: fit-content; border-radius: 4px; overflow: hidden; }
    .hcount-item { padding: 1.2rem 2rem; border-right: 1px solid rgba(255,255,255,.1); text-align: center; }
    .hcount-item:last-child { border-right: none; }
    .hcount-n { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--gold2); line-height: 1; }
    .hcount-l { font-size: .72rem; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.35); margin-top: .3rem; }
    .hero-image-panel { position: relative; overflow: hidden; }
    .hero-image-panel img { width: 100%; height: 100%; object-fit: cover; filter: sepia(20%) contrast(1.1); }
    .hero-image-panel::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, var(--deep) 0%, transparent 30%); z-index: 1; }
    .bg-watermark { position: absolute; right: -2rem; bottom: -2rem; font-size: 18rem; opacity: .04; z-index: 0; color: var(--gold); pointer-events: none; }

    /* ── CARDS SECTION ────────────────────────────────── */
    .cards-wrapper { max-width: 1200px; margin: 0 auto; padding: 6rem 4rem; }
    .cards-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 4rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
    .cards-heading { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 700; line-height: 1.1; color: var(--deep); }
    .cards-heading span { color: var(--gold); display: block; font-style: italic; }
    .filter-tabs { display: flex; gap: .5rem; }
    .ftab { padding: .5rem 1.2rem; border: 1px solid var(--border); background: none; font-size: .78rem; font-weight: 600; cursor: pointer; letter-spacing: .05em; border-radius: 2px; transition: all .2s; color: var(--muted); }
    .ftab.active { background: var(--deep); color: #fff; border-color: var(--deep); }
    .ftab:hover:not(.active) { border-color: var(--deep); color: var(--deep); }

    /* ── SERVICE LIST ─────────────────────────────────── */
    .service-list { display: flex; flex-direction: column; gap: 1px; background: var(--border); }
    .service-card { background: #fff; display: grid; grid-template-columns: auto 1fr auto; align-items: stretch; cursor: pointer; transition: all .3s; overflow: hidden; }
    .service-card:hover { transform: translateX(6px); }
    .service-card:hover .card-accent { width: 6px; }
    .card-accent { width: 4px; background: var(--border); flex-shrink: 0; transition: all .3s; }
    .card-accent.br-Yonex  { background: #e53935; }
    .card-accent.br-Victor { background: #1565c0; }
    .card-accent.br-Lining { background: #ef6c00; }
    .card-accent.br-Apacs  { background: #6a1b9a; }
    .card-accent.br-other  { background: var(--gold); }
    .card-main { padding: 2.5rem 3rem; }
    .card-top-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .brand-tag { font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; padding: .3rem .9rem; border-radius: 2px; }
    .brand-tag.Yonex  { background: #ffebee; color: #c62828; }
    .brand-tag.Victor { background: #e3f2fd; color: #1565c0; }
    .brand-tag.Lining { background: #fff3e0; color: #e65100; }
    .brand-tag.Apacs  { background: #f3e5f5; color: #6a1b9a; }
    .brand-tag.other  { background: rgba(212,160,23,.1); color: var(--gold); }
    .status-tag-s { font-size: .68rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; padding: .25rem .7rem; border-radius: 2px; }
    .status-tag-s.active   { background: #dcfce7; color: #16a34a; }
    .status-tag-s.popular  { background: #dbeafe; color: #0284c7; }
    .type-tag { font-size: .72rem; color: var(--muted); border: 1px solid var(--border); padding: .2rem .7rem; border-radius: 2px; }
    .card-name { font-family: 'Playfair Display', serif; font-size: 1.7rem; font-weight: 700; color: var(--deep); margin-bottom: .6rem; line-height: 1.2; }
    .card-short { color: var(--muted); font-size: .9rem; font-weight: 300; line-height: 1.7; margin-bottom: 1.5rem; }
    .card-info-row { display: flex; gap: 2.5rem; flex-wrap: wrap; }
    .cinfo { display: flex; flex-direction: column; gap: .2rem; }
    .cinfo-label { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); }
    .cinfo-val { font-size: .9rem; font-weight: 600; color: var(--deep); }
    .card-right { padding: 2.5rem 2.5rem 2.5rem 2rem; display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; min-width: 200px; }
    .price-box { text-align: right; }
    .price-label { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); margin-bottom: .4rem; }
    .price-amount { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; color: var(--gold); }
    .warranty-info { font-size: .78rem; color: var(--muted); margin-top: .5rem; }
    .btn-view { background: var(--deep); color: #fff; border: none; padding: .7rem 1.5rem; font-size: .78rem; font-weight: 600; letter-spacing: .08em; cursor: pointer; transition: all .25s; display: flex; align-items: center; gap: .5rem; border-radius: 2px; }
    .btn-view:hover { background: var(--gold); color: var(--deep); }

    /* ── DETAIL MODAL ─────────────────────────────────── */
    .service-overlay { position: fixed; inset: 0; background: rgba(26,18,9,.88); backdrop-filter: blur(10px); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 2rem; }
    .service-overlay.open { display: flex; }
    .service-modal { background: var(--cream); width: 100%; max-width: 820px; max-height: 90vh; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; animation: fadeInScale .4s cubic-bezier(.25,.46,.45,.94); }
    @@keyframes fadeInScale { from { opacity:0; transform:scale(.96); } to { opacity:1; transform:scale(1); } }
    .service-modal-hero { background: var(--deep); padding: 3rem; position: relative; flex-shrink: 0; }
    .service-modal-hero img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .25; }
    .service-modal-hero-content { position: relative; z-index: 1; }
    .service-modal-close { position: absolute; top: 1.5rem; right: 1.5rem; background: rgba(255,255,255,.12); border: none; color: #fff; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 2; transition: background .2s; }
    .service-modal-close:hover { background: rgba(255,255,255,.25); }
    .service-modal-body { padding: 2.5rem 3rem; overflow-y: auto; flex: 1; }
    .info-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; margin-bottom: 2rem; }
    .info-box { background: var(--warm); padding: 1rem 1.2rem; border-radius: 4px; border: 1px solid var(--border); }
    .info-box-label { font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: .4rem; }
    .info-box-val { font-weight: 700; font-size: .95rem; color: var(--deep); }
    .features-list { list-style: none; padding: 0; margin: 0 0 2rem; }
    .features-list li { display: flex; gap: .75rem; padding: .65rem 0; border-bottom: 1px solid var(--border); font-size: .9rem; color: var(--deep); font-weight: 300; }
    .features-list li:last-child { border-bottom: none; }
    .feat-icon { color: var(--gold); flex-shrink: 0; margin-top: 2px; }
    .service-modal-footer { padding: 1.5rem 3rem; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; background: #fff; }
    .btn-book { background: var(--gold); color: var(--deep); border: none; padding: .9rem 2.5rem; font-weight: 700; font-size: .85rem; letter-spacing: .08em; cursor: pointer; transition: all .25s; border-radius: 3px; display: flex; align-items: center; gap: .6rem; }
    .btn-book:hover { background: var(--gold2); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,160,23,.4); }
    .btn-close-modal { border: 1px solid var(--border); background: none; padding: .8rem 1.5rem; cursor: pointer; border-radius: 3px; font-size: .8rem; }

    @@media (max-width: 900px) {
        .string-hero-inner { grid-template-columns: 1fr; }
        .hero-image-panel { display: none; }
        .hero-content { padding: 5rem 2rem; }
        .cards-wrapper { padding: 4rem 1.5rem; }
        .service-card { grid-template-columns: auto 1fr; }
        .card-right { display: none; }
        .info-grid { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 600px) {
        .cards-header { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
        .card-main { padding: 1.5rem; }
        .service-modal-body { padding: 1.5rem; }
        .info-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="stringing-page">

    <!-- HERO -->
    <section class="string-hero">
        <div class="string-hero-inner">
            <div class="hero-content">
                <div class="hero-overline">
                    <div class="hero-overline-line"></div>
                    <span>Professional Stringing</span>
                </div>
                <h1 class="hero-title">Căng vợt<br/><em>chuyên nghiệp.</em></h1>
                <p class="hero-subtitle">Dịch vụ căng vợt cầu lông chuẩn kỹ thuật với các thương hiệu dây hàng đầu. Thợ lành nghề, máy căng hiện đại, bảo hành uy tín.</p>
                <div class="hero-counts">
                    <div class="hcount-item">
                        <div class="hcount-n">@Model.Count()</div>
                        <div class="hcount-l">Dịch vụ</div>
                    </div>
                    <div class="hcount-item">
                        <div class="hcount-n">@Model.Count(s => s.Status == "Active")</div>
                        <div class="hcount-l">Đang có</div>
                    </div>
                    <div class="hcount-item">
                        <div class="hcount-n">@Model.Count(s => s.IsPopular)</div>
                        <div class="hcount-l">Phổ biến</div>
                    </div>
                </div>
            </div>
            <div class="hero-image-panel">
                <img src="https://images.unsplash.com/photo-1615117972428-28de67cda58e?w=800&q=80" alt="Stringing" />
                <div class="bg-watermark"><i class="bi bi-tools"></i></div>
            </div>
        </div>
    </section>

    <!-- SERVICE LIST -->
    <section class="cards-wrapper">
        <div class="cards-header">
            <div class="cards-heading">
                Các gói dịch vụ
                <span>căng vợt &amp; bảo hành</span>
            </div>
            <div class="filter-tabs">
                <button class="ftab active" data-filter="all">Tất cả</button>
                <button class="ftab" data-filter="Yonex">Yonex</button>
                <button class="ftab" data-filter="Victor">Victor</button>
                <button class="ftab" data-filter="Lining">Lining</button>
                <button class="ftab" data-filter="popular">Phổ biến</button>
            </div>
        </div>

        <div class="service-list">
            @if (!Model.Any())
            {
                
                    var samples = new[]
                    {
                        new { Name="Căng Dây Yonex BG65 Titan", Brand="Yonex", Model="BG65 Titan", Tension="24-28 lbs", Price=120000m, Duration=30, Warranty=30, Short="Dây căng tiêu chuẩn thi đấu, lực căng ổn định lâu dài.", Img="", Features="Độ bền cao\nLực căng ổn định\nPhù hợp thi đấu chuyên nghiệp", IsPopular=true },
                        new { Name="Căng Dây Victor VBS-66N", Brand="Victor", Model="VBS-66N", Tension="22-26 lbs", Price=100000m, Duration=25, Warranty=30, Short="Dây mỏng tốc độ cao, phù hợp kiểu đánh tấn công.", Img="", Features="Dây mỏng 0.66mm\nTốc độ shuttle cao\nÂm thanh đanh ngắn", IsPopular=false },
                        new { Name="Căng Dây Li-Ning No.1", Brand="Lining", Model="No.1", Tension="20-24 lbs", Price=90000m, Duration=20, Warranty=21, Short="Dây đa năng, phù hợp đánh giải trí và tập luyện.", Img="", Features="Giá hợp lý\nDễ căng\nPhù hợp người mới", IsPopular=false },
                    };
                
                @foreach (var s in samples)
                {
                    var brandCss = s.Brand;
                    var feats = s.Features.Replace("'","&#39;");
                    <div class="service-card service-item" data-brand="@s.Brand" data-popular="@s.IsPopular.ToString().ToLower()"
                         onclick="openServiceDetail('@s.Name.Replace("'","&#39;")','@s.Brand','@s.Model','@s.Tension','@s.Duration','@s.Warranty','@s.Price.ToString("N0")đ','@s.Short.Replace("'","&#39;")','@s.Img','@feats.Replace(Environment.NewLine,"\\n")')">
                        <div class="card-accent br-@brandCss"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="brand-tag @brandCss">@s.Brand</span>
                                @if (s.IsPopular) { <span class="status-tag-s popular">⚡ Phổ biến</span> }
                                <span class="type-tag">@s.Model</span>
                            </div>
                            <div class="card-name">@s.Name</div>
                            <div class="card-short">@s.Short</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Lực căng</span><span class="cinfo-val">@s.Tension</span></div>
                                <div class="cinfo"><span class="cinfo-label">Thời gian</span><span class="cinfo-val">@s.Duration phút</span></div>
                                <div class="cinfo"><span class="cinfo-label">Bảo hành</span><span class="cinfo-val">@s.Warranty ngày</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="price-box">
                                <div class="price-label">Chi phí</div>
                                <div class="price-amount">@s.Price.ToString("N0")đ</div>
                                <div class="warranty-info"><i class="bi bi-shield-check me-1"></i>Bảo hành @s.Warranty ngày</div>
                            </div>
                            <button class="btn-view"><i class="bi bi-arrow-right"></i> Chi tiết</button>
                        </div>
                    </div>
                }
            }
            else
            {
                @foreach (var s in Model.OrderBy(x => x.DisplayOrder))
                {
                    var brandCss = s.Brand ?? "other";
                    var feats = (s.Features ?? "").Replace("'","&#39;");
                    var imgEsc = (s.FeaturedImage ?? "").Replace("'","&#39;");
                    var priceStr = s.Price.HasValue ? s.Price.Value.ToString("N0") + "đ" : "—";
                    <div class="service-card service-item" data-brand="@(s.Brand ?? "other")" data-popular="@s.IsPopular.ToString().ToLower()"
                         onclick="openServiceDetail('@s.ServiceName.Replace("'","&#39;")','@(s.Brand??"—")','@(s.StringModel??"—")','@(s.Tension??"—")','@(s.DurationMinutes?.ToString()??"—")','@(s.WarrantyDays?.ToString()??"—")','@priceStr','@(s.ShortDesc??"").Replace("'","&#39;")','@imgEsc','@feats.Replace(Environment.NewLine,"\\n")')">
                        <div class="card-accent br-@brandCss"></div>
                        <div class="card-main">
                            <div class="card-top-row">
                                <span class="brand-tag @brandCss">@(s.Brand ?? "Khác")</span>
                                @if (s.IsPopular) { <span class="status-tag-s popular">⚡ Phổ biến</span> }
                                @if (s.IsFeatured) { <span style="color:var(--gold);font-size:.85rem;">★ Nổi bật</span> }
                                @if (!string.IsNullOrEmpty(s.StringModel)) { <span class="type-tag">@s.StringModel</span> }
                            </div>
                            <div class="card-name">@s.ServiceName</div>
                            <div class="card-short">@s.ShortDesc</div>
                            <div class="card-info-row">
                                <div class="cinfo"><span class="cinfo-label">Lực căng</span><span class="cinfo-val">@(s.Tension ?? "—")</span></div>
                                <div class="cinfo"><span class="cinfo-label">Thời gian</span><span class="cinfo-val">@(s.DurationMinutes?.ToString() ?? "—") phút</span></div>
                                <div class="cinfo"><span class="cinfo-label">Bảo hành</span><span class="cinfo-val">@(s.WarrantyDays?.ToString() ?? "—") ngày</span></div>
                            </div>
                        </div>
                        <div class="card-right">
                            <div class="price-box">
                                <div class="price-label">Chi phí</div>
                                <div class="price-amount">@priceStr</div>
                                @if (s.WarrantyDays.HasValue) { <div class="warranty-info"><i class="bi bi-shield-check me-1"></i>Bảo hành @s.WarrantyDays ngày</div> }
                            </div>
                            <button class="btn-view"><i class="bi bi-arrow-right"></i> Chi tiết</button>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

<!-- DETAIL MODAL -->
<div class="service-overlay" id="serviceOverlay" onclick="closeServiceDetail(event)">
    <div class="service-modal">
        <div class="service-modal-hero">
            <img id="smImg" src="" alt="" style="display:none;" />
            <button class="service-modal-close" onclick="closeServiceDetailBtn()"><i class="bi bi-x"></i></button>
            <div class="service-modal-hero-content">
                <div id="sm-brand-tag" class="brand-tag" style="margin-bottom:1rem;display:inline-block;"></div>
                <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem;">
                    <span id="sm-model" style="border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);font-size:.72rem;padding:.2rem .7rem;"></span>
                </div>
                <h2 id="sm-name" style="font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;color:#fff;margin:0;"></h2>
                <p id="sm-short" style="color:rgba(255,255,255,.5);margin-top:.6rem;font-weight:300;"></p>
            </div>
        </div>
        <div class="service-modal-body">
            <div class="info-grid">
                <div class="info-box">
                    <span class="info-box-label"><i class="bi bi-speedometer2 me-1"></i>Lực căng</span>
                    <span class="info-box-val" id="sm-tension"></span>
                </div>
                <div class="info-box">
                    <span class="info-box-label"><i class="bi bi-clock me-1"></i>Thời gian</span>
                    <span class="info-box-val" id="sm-duration"></span>
                </div>
                <div class="info-box">
                    <span class="info-box-label"><i class="bi bi-shield-check me-1"></i>Bảo hành</span>
                    <span class="info-box-val" id="sm-warranty"></span>
                </div>
            </div>
            <div style="font-weight:600;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Tính năng nổi bật</div>
            <ul class="features-list" id="sm-features"></ul>
        </div>
        <div class="service-modal-footer">
            <div>
                <div style="font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.3rem;">Chi phí dịch vụ</div>
                <div id="sm-price" style="font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--gold);"></div>
            </div>
            <div style="display:flex;gap:.75rem;">
                <button class="btn-close-modal" onclick="closeServiceDetailBtn()">Đóng</button>
                <button class="btn-book"><i class="bi bi-tools"></i> Đặt lịch ngay</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.ftab').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.ftab').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const f = this.dataset.filter;
            document.querySelectorAll('.service-item').forEach(card => {
                const matchBrand = f === 'all' || card.dataset.brand === f;
                const matchPop = f === 'popular' && card.dataset.popular === 'true';
                card.style.display = (matchBrand || matchPop) ? '' : 'none';
            });
        });
    });

    function openServiceDetail(name, brand, model, tension, duration, warranty, price, desc, img, features) {
        document.getElementById('sm-name').textContent = name;
        document.getElementById('sm-model').textContent = model ? '🎯 ' + model : '';
        document.getElementById('sm-short').textContent = desc || '';
        const brEl = document.getElementById('sm-brand-tag');
        brEl.textContent = brand;
        brEl.className = 'brand-tag ' + brand;
        document.getElementById('sm-tension').textContent = tension;
        document.getElementById('sm-duration').textContent = duration + ' phút';
        document.getElementById('sm-warranty').textContent = warranty + ' ngày';
        document.getElementById('sm-price').textContent = price;
        const imgEl = document.getElementById('smImg');
        if (img) { imgEl.src = img; imgEl.style.display = ''; } else { imgEl.style.display = 'none'; }
        const ul = document.getElementById('sm-features');
        ul.innerHTML = '';
        (features || '').split('\n').filter(f => f.trim()).forEach(f => {
            const li = document.createElement('li');
            li.innerHTML = `<i class="bi bi-check-circle feat-icon"></i>${f.replace(/^[-•]\s*/, '')}`;
            ul.appendChild(li);
        });
        document.getElementById('serviceOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeServiceDetail(e) { if (e.target === document.getElementById('serviceOverlay')) closeServiceDetailBtn(); }
    function closeServiceDetailBtn() { document.getElementById('serviceOverlay').classList.remove('open'); document.body.style.overflow = ''; }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeServiceDetailBtn(); });
</script>
}
