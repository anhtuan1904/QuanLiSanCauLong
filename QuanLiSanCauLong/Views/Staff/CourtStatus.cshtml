@* CourtStatus.cshtml — Trạng thái sân realtime (Staff) *@
@{
    Layout = "~/Views/Shared/_LayoutStaff.cshtml";
    ViewData["Title"] = "Trạng thái sân";
}

<style>
    :root {
        --D: #1a1209;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.22);
        --C: #fdf8f0;
        --W: #f5ede0;
        --S: #e8ddd0;
        --M: #8a7560;
        --GN: #10b981;
        --BL: #3b82f6;
        --RD: #ef4444;
        --OR: #f97316;
        --r: 14px;
        --r2: 10px;
    }

    /* ── HEADER ── */
    .cst-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.2rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .cst-head-l {
    }

    .cst-tag {
        font-size: .6rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
        margin-bottom: .2rem;
    }

    .cst-title {
        font-family: 'Syne',sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--D);
    }

    .cst-head-r {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .live-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(16,185,129,.1);
        border: 1px solid rgba(16,185,129,.22);
        border-radius: 20px;
        padding: .3rem .85rem;
        font-size: .72rem;
        font-weight: 700;
        color: var(--GN);
    }

    .live-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--GN);
        animation: ping 1.8s ease infinite;
    }

    @@keyframes ping {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(16,185,129,.4);
        }

        60% {
            box-shadow: 0 0 0 6px transparent;
        }
    }

    .refresh-btn {
        display: inline-flex;
        align-items: center;
        gap: .38rem;
        padding: .4rem .9rem;
        border-radius: 8px;
        border: 1px solid var(--S);
        background: #fff;
        color: var(--M);
        font-size: .76rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .18s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .refresh-btn:hover {
            border-color: var(--G);
            color: var(--G);
        }

    /* ── SUMMARY BAR ── */
    .sum-bar {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .75rem;
        margin-bottom: 1.2rem;
    }

    .sb-item {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        padding: .9rem 1.1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .sb-ico {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .sb-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1;
    }

    .sb-lbl {
        font-size: .67rem;
        color: var(--M);
        margin-top: .12rem;
    }
    @@media(max - width:640px) {
        .sum-bar {
            grid-template-columns: repeat(2,1fr);
        }
    }

    /* ── TABLE VIEW ── */
    .cst-table-wrap {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
    }

    .cst-table-head {
        padding: .9rem 1.3rem;
        border-bottom: 1px solid var(--S);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .cst-table-title {
        font-family: 'Syne',sans-serif;
        font-size: .93rem;
        font-weight: 800;
        color: var(--D);
    }

    .ct-table {
        width: 100%;
        border-collapse: collapse;
    }

        .ct-table th {
            background: var(--W);
            padding: .65rem 1.1rem;
            font-size: .62rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--M);
            border-bottom: 1px solid var(--S);
            text-align: left;
        }

        .ct-table td {
            padding: .82rem 1.1rem;
            border-bottom: 1px solid var(--S);
            font-size: .8rem;
            vertical-align: middle;
            color: var(--D);
        }

        .ct-table tr:last-child td {
            border-bottom: none;
        }

        .ct-table tr:hover td {
            background: var(--C);
        }

    /* ── COURT NUMBER BADGE ── */
    .ct-num-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        font-family: 'Syne',sans-serif;
        font-size: .9rem;
        font-weight: 800;
        background: var(--G3);
        color: var(--G);
    }

    /* ── STATUS PILLS ── */
    .pill {
        display: inline-flex;
        align-items: center;
        gap: .26rem;
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        padding: .22rem .6rem;
        border-radius: 4px;
    }

        .pill::before {
            content: '●';
            font-size: .48em;
        }

    .p-free {
        background: rgba(16,185,129,.1);
        color: var(--GN);
    }

    .p-play {
        background: var(--G3);
        color: #92660a;
    }

    .p-inc {
        background: rgba(249,115,22,.1);
        color: var(--OR);
    }

    .p-main {
        background: rgba(138,117,96,.1);
        color: var(--M);
    }

    /* ── PROGRESS BAR for time ── */
    .time-bar {
        height: 5px;
        background: var(--S);
        border-radius: 3px;
        overflow: hidden;
        margin-top: .35rem;
        max-width: 120px;
    }

    .time-fill {
        height: 100%;
        border-radius: 3px;
        background: var(--G);
        transition: width .4s;
    }

    /* ── ACTION BUTTONS ── */
    .act-btn {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        padding: .3rem .72rem;
        border-radius: 7px;
        border: none;
        font-size: .7rem;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Space Grotesk',sans-serif;
        transition: all .18s;
    }

    .ab-book {
        background: rgba(16,185,129,.1);
        border: 1px solid rgba(16,185,129,.22);
        color: var(--GN);
    }

        .ab-book:hover {
            background: var(--GN);
            color: #fff;
        }

    .ab-out {
        background: var(--G3);
        border: 1px solid var(--G4);
        color: #92660a;
    }

        .ab-out:hover {
            background: var(--G);
            color: var(--D);
        }
</style>

<div class="cst-head">
    <div class="cst-head-l">
        <div class="cst-tag">Theo dõi thực tế</div>
        <div class="cst-title">Trạng Thái Tất Cả Sân</div>
    </div>
    <div class="cst-head-r">
        <div class="live-badge"><div class="live-dot"></div>Cập nhật mỗi 30 giây</div>
        <button class="refresh-btn" onclick="location.reload()">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
            Làm mới
        </button>
    </div>
</div>

<!-- Summary bar -->
<div class="sum-bar">
    <div class="sb-item">
        <div class="sb-ico" style="background:rgba(16,185,129,.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--GN)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
        </div>
        <div>
            <div class="sb-val" id="cnt-free" style="color:var(--GN)">—</div>
            <div class="sb-lbl">Sân trống</div>
        </div>
    </div>
    <div class="sb-item">
        <div class="sb-ico" style="background:var(--G3);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--G)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
        </div>
        <div>
            <div class="sb-val" id="cnt-play" style="color:var(--G)">—</div>
            <div class="sb-lbl">Đang có khách</div>
        </div>
    </div>
    <div class="sb-item">
        <div class="sb-ico" style="background:rgba(249,115,22,.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--OR)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
        </div>
        <div>
            <div class="sb-val" id="cnt-inc" style="color:var(--OR)">—</div>
            <div class="sb-lbl">Sắp đến</div>
        </div>
    </div>
    <div class="sb-item">
        <div class="sb-ico" style="background:rgba(138,117,96,.1);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--M)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
        </div>
        <div>
            <div class="sb-val" id="cnt-main" style="color:var(--M)">—</div>
            <div class="sb-lbl">Bảo trì</div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="cst-table-wrap">
    <div class="cst-table-head">
        <div class="cst-table-title">Chi Tiết Từng Sân</div>
        <span style="font-size:.72rem;color:var(--M);" id="last-update">—</span>
    </div>
    <div style="overflow-x:auto;">
        <table class="ct-table">
            <thead>
                <tr>
                    <th>Sân</th>
                    <th>Loại</th>
                    <th>Trạng thái</th>
                    <th>Khách hàng</th>
                    <th>Khung giờ</th>
                    <th>Thời gian còn</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="courtTable">
                <tr>
                    <td colspan="7" style="text-align:center;padding:2.5rem;color:var(--M);">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:.25;display:block;margin:0 auto .5rem;"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
                        Đang tải dữ liệu...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function loadCourts() {
            fetch('/Staff/QuickStats')
                .then(r => r.json())
                .then(d => {
                    if (!d) return;
                    document.getElementById('cnt-free').textContent = d.freeCourts  ?? '—';
                    document.getElementById('cnt-play').textContent = d.playingCourts ?? '—';
                    document.getElementById('cnt-inc').textContent  = d.pendingCheckin ?? '—';
                    document.getElementById('cnt-main').textContent = d.maintenanceCourts ?? '—';
                }).catch(() => {});

            // Load court detail table
            fetch('/Staff/CourtStatusJson')
                .then(r => r.json())
                .then(courts => {
                    if (!courts || !courts.length) return;
                    const now = new Date();
                    document.getElementById('last-update').textContent =
                        'Cập nhật: ' + now.toLocaleTimeString('vi-VN', {hour:'2-digit',minute:'2-digit',second:'2-digit'});

                    let cntFree=0, cntPlay=0, cntInc=0, cntMain=0;
                    let html = '';
                    courts.forEach(c => {
                        const statusMap = { free:'Trống', playing:'Đang chơi', incoming:'Sắp đến', maintenance:'Bảo trì' };
                        const pillMap   = { free:'p-free', playing:'p-play', incoming:'p-inc', maintenance:'p-main' };

                        if(c.status==='free')        cntFree++;
                        else if(c.status==='playing')cntPlay++;
                        else if(c.status==='incoming')cntInc++;
                        else                         cntMain++;

                        // Time bar %
                        let timeHtml = '—', barHtml = '';
                        if (c.status === 'playing' && c.startTime && c.endTime) {
                            timeHtml = `${c.startTime} – ${c.endTime}`;
                            barHtml  = `<div class="time-bar"><div class="time-fill" style="width:60%"></div></div>`;
                        } else if (c.status === 'incoming' && c.nextTime) {
                            timeHtml = c.nextTime;
                        }

                        const actionHtml = c.status === 'free'
                            ? `<a href="/Staff/WalkIn?courtId=${c.courtId}" class="act-btn ab-book">
                                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Đặt ngay</a>`
                            : c.status === 'playing' && c.bookingId
                            ? `<form method="post" action="/Staff/DoCheckOut" class="d-inline">
                                <input type="hidden" name="bookingId" value="${c.bookingId}">
                                <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('input[name=__RequestVerificationToken]')?.value||''}">
                                <button type="submit" class="act-btn ab-out">
                                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                Check-out</button></form>`
                            : '';

                        html += `<tr>
                            <td><span class="ct-num-badge">${c.courtNumber}</span></td>
                            <td style="font-size:.75rem;color:var(--M)">${c.courtType||'—'}</td>
                            <td><span class="pill ${pillMap[c.status]||'p-main'}">${statusMap[c.status]||c.status}</span></td>
                            <td style="font-weight:600">${c.customerName||'—'}</td>
                            <td>${timeHtml}${barHtml}</td>
                            <td><span id="cd-${c.courtId}" style="font-size:.78rem;font-weight:700;color:var(--OR)">${c.countdown||'—'}</span></td>
                            <td>${actionHtml}</td>
                        </tr>`;
                    });

                    document.getElementById('courtTable').innerHTML = html;
                    document.getElementById('cnt-free').textContent  = cntFree;
                    document.getElementById('cnt-play').textContent  = cntPlay;
                    document.getElementById('cnt-inc').textContent   = cntInc;
                    document.getElementById('cnt-main').textContent  = cntMain;
                })
                .catch(() => {
                    // Fallback: show basic info if API not ready
                    document.getElementById('last-update').textContent = 'API chưa sẵn sàng';
                });
        }

        loadCourts();
        setInterval(loadCourts, 30000);
    </script>
    @Html.AntiForgeryToken()
}
