@* DailySummary.cshtml — Tổng kết ngày (Staff) *@
@{
    Layout = "~/Views/Shared/_LayoutStaff.cshtml";
    ViewData["Title"] = "Tổng kết ngày";
    var today = DateTime.Today;
}

<style>
    :root {
        --D: #1a1209;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.22);
        --C: #fdf8f0;
        --W: #f5ede0;
        --S: #e8ddd0;
        --M: #8a7560;
        --GN: #10b981;
        --BL: #3b82f6;
        --RD: #ef4444;
        --OR: #f97316;
        --PU: #8b5cf6;
        --r: 14px;
        --r2: 10px;
    }

    /* ── HERO ── */
    .ds-hero {
        background: var(--D);
        border-radius: var(--r);
        padding: 1.4rem 1.8rem;
        margin-bottom: 1.3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        position: relative;
        overflow: hidden;
        flex-wrap: wrap;
    }

        .ds-hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--G),var(--G2),transparent);
        }

        .ds-hero::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(212,160,23,.08),transparent 70%);
            pointer-events: none;
        }

    .ds-date-lbl {
        font-size: .6rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--G);
        font-weight: 600;
        margin-bottom: .3rem;
    }

    .ds-date-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: #fff;
    }

    .ds-date-sub {
        font-size: .72rem;
        color: rgba(255,255,255,.35);
        margin-top: .2rem;
    }

    .ds-hero-r {
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    .ds-print-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem .95rem;
        border-radius: 8px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        color: rgba(255,255,255,.7);
        font-size: .76rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .18s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .ds-print-btn:hover {
            background: rgba(255,255,255,.14);
            color: #fff;
        }

    /* ── KPI GRID ── */
    .ds-kpi {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: .85rem;
        margin-bottom: 1.3rem;
    }

    .dk {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        padding: 1.1rem 1.3rem;
        position: relative;
        overflow: hidden;
        transition: transform .2s,box-shadow .2s;
    }

        .dk:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 22px rgba(26,18,9,.1);
        }

        .dk::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            opacity: 0;
            transition: opacity .28s;
            border-radius: var(--r) var(--r) 0 0;
        }

        .dk:hover::before {
            opacity: 1;
        }

        .dk.cg::before {
            background: linear-gradient(90deg,var(--G),var(--G2));
        }

        .dk.cgn::before {
            background: linear-gradient(90deg,var(--GN),#34d399);
        }

        .dk.crd::before {
            background: linear-gradient(90deg,var(--RD),var(--OR));
        }

        .dk.cbl::before {
            background: linear-gradient(90deg,var(--BL),#60a5fa);
        }

        .dk.cpu::before {
            background: linear-gradient(90deg,var(--PU),#a78bfa);
        }

        .dk.cte::before {
            background: linear-gradient(90deg,#14b8a6,#2dd4bf);
        }

    .dk-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: .75rem;
    }

    .dk-ico {
        width: 40px;
        height: 40px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .dk-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.55rem;
        font-weight: 800;
        color: var(--D);
        line-height: 1;
        letter-spacing: -.02em;
    }

    .dk-lbl {
        font-size: .7rem;
        color: var(--M);
        margin-top: .2rem;
    }

    .dk-sub {
        font-size: .65rem;
        color: var(--M);
        opacity: .65;
        margin-top: .12rem;
    }
    @@media(max - width:900px) {
        .ds-kpi {
            grid-template-columns: repeat(2,1fr);
        }
    }

    /* ── SECTION GRID ── */
    .ds-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    @@media(max - width:860px) {
        .ds-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── PANEL ── */
    .dp {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
    }

    .dp-head {
        padding: .85rem 1.2rem;
        border-bottom: 1px solid var(--S);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
    }

    .dp-title {
        font-family: 'Syne',sans-serif;
        font-size: .88rem;
        font-weight: 800;
        color: var(--D);
    }

    .dp-b {
        padding: .5rem 0;
    }

    /* ── TIMELINE ITEM ── */
    .tl-item {
        display: flex;
        align-items: flex-start;
        gap: .85rem;
        padding: .65rem 1.2rem;
        border-bottom: 1px solid var(--S);
        transition: background .15s;
    }

        .tl-item:last-child {
            border-bottom: none;
        }

        .tl-item:hover {
            background: var(--C);
        }

    .tl-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: .35rem;
    }

    .tl-time {
        font-size: .68rem;
        color: var(--M);
        font-weight: 600;
        min-width: 42px;
        flex-shrink: 0;
        margin-top: .15rem;
    }

    .tl-info {
        flex: 1;
        min-width: 0;
    }

    .tl-title {
        font-size: .8rem;
        font-weight: 600;
        color: var(--D);
    }

    .tl-sub {
        font-size: .7rem;
        color: var(--M);
        margin-top: .08rem;
    }

    .tl-amt {
        font-family: 'Syne',sans-serif;
        font-size: .82rem;
        font-weight: 700;
        color: var(--G);
        white-space: nowrap;
    }

    /* ── REVENUE BREAKDOWN ── */
    .rb-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .6rem 1.2rem;
        border-bottom: 1px solid var(--S);
    }

        .rb-row:last-child {
            border-bottom: none;
        }

    .rb-lbl {
        font-size: .78rem;
        color: var(--D);
        font-weight: 500;
        flex: 0 0 90px;
    }

    .rb-bar {
        flex: 1;
        height: 7px;
        background: var(--S);
        border-radius: 4px;
        overflow: hidden;
    }

    .rb-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 1s ease;
    }

    .rb-pct {
        font-size: .67rem;
        color: var(--M);
        min-width: 32px;
        text-align: right;
    }

    .rb-val {
        font-family: 'Syne',sans-serif;
        font-size: .8rem;
        font-weight: 700;
        color: var(--D);
        min-width: 70px;
        text-align: right;
    }

    /* ── PILLS ── */
    .pill {
        display: inline-flex;
        align-items: center;
        gap: .24rem;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        padding: .2rem .55rem;
        border-radius: 4px;
    }

        .pill::before {
            content: '●';
            font-size: .47em;
        }

    .p-ok {
        background: rgba(16,185,129,.1);
        color: var(--GN);
    }

    .p-ca {
        background: rgba(239,68,68,.1);
        color: var(--RD);
    }

    .p-pe {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    /* ── FOOTER TOTAL ── */
    .ds-footer {
        background: var(--D);
        border-radius: var(--r);
        padding: 1.2rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .dsf-item {
        text-align: center;
    }

    .dsf-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--G2);
        line-height: 1;
    }

    .dsf-lbl {
        font-size: .62rem;
        color: rgba(255,255,255,.4);
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-top: .2rem;
    }
</style>

<!-- Hero -->
<div class="ds-hero">
    <div>
        <div class="ds-date-lbl">Báo cáo tổng kết</div>
        <div class="ds-date-val">@today.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</div>
        <div class="ds-date-sub">Cập nhật lần cuối: @DateTime.Now.ToString("HH:mm:ss")</div>
    </div>
    <div class="ds-hero-r">
        <button class="ds-print-btn" onclick="window.print()">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><rect x="6" y="14" width="12" height="8" /></svg>
            In báo cáo
        </button>
        <button class="ds-print-btn" onclick="location.reload()">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10" /><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" /></svg>
            Làm mới
        </button>
    </div>
</div>

<!-- KPI 6 cards -->
<div class="ds-kpi">
    <div class="dk cg">
        <div class="dk-top">
            <div class="dk-ico" style="background:var(--G3);">
                <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--G)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
            </div>
        </div>
        <div class="dk-val">@(ViewBag.TotalRevenue != null ? ((decimal)ViewBag.TotalRevenue).ToString("N0") : "0")đ</div>
        <div class="dk-lbl">Tổng doanh thu ngày</div>
        <div class="dk-sub">Sân + Sản phẩm</div>
    </div>
    <div class="dk cgn">
        <div class="dk-top">
            <div class="dk-ico" style="background:rgba(16,185,129,.1);">
                <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--GN)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><polyline points="8 14 10 16 16 12" /></svg>
            </div>
        </div>
        <div class="dk-val">@(ViewBag.TotalBookings ?? 0)</div>
        <div class="dk-lbl">Tổng đơn đặt sân</div>
        <div class="dk-sub">Trong ngày hôm nay</div>
    </div>
    <div class="dk crd">
        <div class="dk-top">
            <div class="dk-ico" style="background:rgba(239,68,68,.1);">
                <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--RD)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </div>
        </div>
        <div class="dk-val">@(ViewBag.CancelledCount ?? 0)</div>
        <div class="dk-lbl">Đơn bị hủy</div>
        <div class="dk-sub">Cần theo dõi lý do</div>
    </div>
    <div class="dk cbl">
        <div class="dk-top">
            <div class="dk-ico" style="background:rgba(59,130,246,.1);">
                <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="var(--BL)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" /></svg>
            </div>
        </div>
        <div class="dk-val">@(ViewBag.ProductOrders ?? 0)</div>
        <div class="dk-lbl">Đơn sản phẩm</div>
        <div class="dk-sub">Bán lẻ + kèm booking</div>
    </div>
</div>

<!-- Two-column content -->
<div class="ds-grid">
    <!-- Recent bookings timeline -->
    <div class="dp">
        <div class="dp-head">
            <div class="dp-title">Hoạt Động Trong Ngày</div>
            <a asp-controller="Staff" asp-action="BookingManagement"
               style="font-size:.72rem;color:var(--G);text-decoration:none;font-weight:600;">Xem tất cả →</a>
        </div>
        <div class="dp-b">
            @if (ViewBag.TodayBookings != null)
            {
                foreach (var b in (IEnumerable<dynamic>)ViewBag.TodayBookings)
                {
                    var dotClr = b.Status == "Completed" ? "var(--GN)"
                    : b.Status == "Cancelled" ? "var(--RD)"
                    : b.Status == "Playing" ? "var(--G)"
                    : "var(--M)";
                    <div class="tl-item">
                        <div class="tl-dot" style="background:@dotClr"></div>
                        <div class="tl-time">@b.StartTime.ToString(@"HH\:mm")</div>
                        <div class="tl-info">
                            <div class="tl-title">Sân @b.Court?.CourtNumber — @(b.User?.FullName ?? "Khách")</div>
                            <div class="tl-sub">@b.BookingCode</div>
                        </div>
                        <div class="tl-amt">@b.TotalPrice.ToString("N0")đ</div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center;padding:2rem;color:var(--M);font-size:.82rem;">Chưa có hoạt động nào hôm nay</div>
            }
        </div>
    </div>

    <!-- Revenue breakdown -->
    <div class="dp">
        <div class="dp-head">
            <div class="dp-title">Cơ Cấu Doanh Thu</div>
        </div>
        <div style="padding:.75rem 0;">
            <div class="rb-row">
                <div class="rb-lbl">Đặt sân</div>
                <div class="rb-bar"><div class="rb-fill" style="width:68%;background:var(--G);"></div></div>
                <div class="rb-pct">68%</div>
                <div class="rb-val">@(ViewBag.BookingRevenue != null ? ((decimal)ViewBag.BookingRevenue).ToString("N0") : "0")đ</div>
            </div>
            <div class="rb-row">
                <div class="rb-lbl">Sản phẩm</div>
                <div class="rb-bar"><div class="rb-fill" style="width:24%;background:var(--GN);"></div></div>
                <div class="rb-pct">24%</div>
                <div class="rb-val">@(ViewBag.ProductRevenue != null ? ((decimal)ViewBag.ProductRevenue).ToString("N0") : "0")đ</div>
            </div>
            <div class="rb-row">
                <div class="rb-lbl">Dịch vụ khác</div>
                <div class="rb-bar"><div class="rb-fill" style="width:8%;background:var(--BL);"></div></div>
                <div class="rb-pct">8%</div>
                <div class="rb-val">0đ</div>
            </div>
        </div>

        <!-- Shift breakdown -->
        <div class="dp-head" style="border-top:1px solid var(--S);margin-top:.25rem;">
            <div class="dp-title">Theo Ca Làm Việc</div>
        </div>
        @{
            var shifts = new[] {
                ("🌅 Ca sáng", "6:00–14:00", 35, "var(--G)"),
                ("☀️ Ca chiều","14:00–22:00",48, "var(--OR)"),
                ("🌙 Ca tối",  "18:00–23:00",17, "var(--PU)"),
                };
        }
        @foreach (var (nm, hr, pct, clr) in shifts)
        {
            <div class="rb-row">
                <div class="rb-lbl" style="font-size:.75rem;">@nm</div>
                <div class="rb-bar"><div class="rb-fill" style="width:@pct%;background:@clr;"></div></div>
                <div class="rb-pct">@pct%</div>
                <div class="rb-val" style="font-size:.72rem;color:var(--M);">@hr</div>
            </div>
        }
    </div>
</div>

<!-- Footer summary dark -->
<div class="ds-footer">
    <div class="dsf-item">
        <div class="dsf-val">@(ViewBag.TotalBookings ?? 0)</div>
        <div class="dsf-lbl">Đơn đặt sân</div>
    </div>
    <div style="width:1px;height:36px;background:rgba(255,255,255,.08);"></div>
    <div class="dsf-item">
        <div class="dsf-val">@(ViewBag.CompletedCount ?? 0)</div>
        <div class="dsf-lbl">Hoàn thành</div>
    </div>
    <div style="width:1px;height:36px;background:rgba(255,255,255,.08);"></div>
    <div class="dsf-item">
        <div class="dsf-val">@(ViewBag.CancelledCount ?? 0)</div>
        <div class="dsf-lbl">Đã hủy</div>
    </div>
    <div style="width:1px;height:36px;background:rgba(255,255,255,.08);"></div>
    <div class="dsf-item">
        <div class="dsf-val">@(ViewBag.TotalRevenue != null ? ((decimal)ViewBag.TotalRevenue).ToString("N0") : "0")đ</div>
        <div class="dsf-lbl">Tổng doanh thu</div>
    </div>
    <div style="margin-left:auto;">
        <a asp-controller="Staff" asp-action="ShiftReport"
           style="display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.1rem;border-radius:9px;background:var(--G);color:var(--D);font-size:.78rem;font-weight:700;text-decoration:none;transition:all .18s;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
            Xem báo cáo ca
        </a>
    </div>
</div>
