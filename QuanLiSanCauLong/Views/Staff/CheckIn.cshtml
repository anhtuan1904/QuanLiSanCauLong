@{
    Layout = "~/Views/Shared/_LayoutStaff.cshtml";
    ViewData["Title"] = "Check-in / Check-out";
}

<style>
    :root {
        --D: #1a1209;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.22);
        --C: #fdf8f0;
        --W: #f5ede0;
        --S: #e8ddd0;
        --M: #8a7560;
        --GN: #10b981;
        --BL: #3b82f6;
        --RD: #ef4444;
        --OR: #f97316;
        --PU: #8b5cf6;
        --r: 14px;
        --r2: 10px;
    }

    /* ── LAYOUT ── */
    .ci-wrap {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 1.3rem;
        align-items: start;
    }
    @@media(max - width:860px) {
        .ci-wrap {
            grid-template-columns: 1fr;
        }
    }

    /* ── SEARCH BOX ── */
    .search-card {
        background: var(--D);
        border-radius: var(--r);
        padding: 1.6rem 1.8rem;
        margin-bottom: 1rem;
        position: relative;
        overflow: hidden;
    }

        .search-card::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(212,160,23,.1),transparent 70%);
            pointer-events: none;
        }

        .search-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--G),var(--G2),transparent);
        }

    .sc-lbl {
        font-size: .6rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--G);
        font-weight: 600;
        margin-bottom: .5rem;
    }

    .sc-title {
        font-family: 'Syne',sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1.1rem;
    }

    .sc-input-wrap {
        display: flex;
        gap: .5rem;
    }

    .sc-input {
        flex: 1;
        padding: .62rem 1rem;
        border: 1.5px solid rgba(255,255,255,.12);
        border-radius: 9px;
        font-size: .85rem;
        color: #fff;
        font-family: 'Space Grotesk',sans-serif;
        background: rgba(255,255,255,.08);
        outline: none;
        transition: border-color .18s,background .18s;
    }

        .sc-input::placeholder {
            color: rgba(255,255,255,.3);
        }

        .sc-input:focus {
            border-color: var(--G);
            background: rgba(255,255,255,.12);
        }

    .sc-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        padding: .62rem 1.2rem;
        border-radius: 9px;
        background: var(--G);
        border: none;
        color: var(--D);
        font-family: 'Syne',sans-serif;
        font-size: .85rem;
        font-weight: 800;
        cursor: pointer;
        transition: all .18s;
        white-space: nowrap;
    }

        .sc-btn:hover {
            background: var(--G2);
        }

    .sc-hint {
        font-size: .68rem;
        color: rgba(255,255,255,.3);
        margin-top: .5rem;
    }

    /* ── RESULT CARD ── */
    .res-card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
    }

    .res-card-head {
        padding: 1rem 1.3rem;
        border-bottom: 1px solid var(--S);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
    }

    .res-code {
        font-family: 'Syne',sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--G);
    }

    .res-court {
        font-size: .72rem;
        color: var(--M);
        margin-top: .08rem;
    }

    .res-body {
        padding: 1.2rem 1.3rem;
    }

    .res-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .7rem;
        margin-bottom: 1rem;
    }

    .res-item {
        display: flex;
        flex-direction: column;
        gap: .18rem;
    }

    .res-item-lbl {
        font-size: .62rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
    }

    .res-item-val {
        font-size: .85rem;
        font-weight: 600;
        color: var(--D);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .res-actions {
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    /* ── ACTION BUTTONS ── */
    .ci-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        padding: .7rem;
        border-radius: 10px;
        border: none;
        font-family: 'Syne',sans-serif;
        font-size: .9rem;
        font-weight: 800;
        cursor: pointer;
        transition: all .2s;
    }

    .ci-btn-in {
        background: var(--GN);
        color: #fff;
    }

        .ci-btn-in:hover {
            background: #059669;
            box-shadow: 0 6px 18px rgba(16,185,129,.35);
        }

    .ci-btn-out {
        background: var(--G);
        color: var(--D);
    }

        .ci-btn-out:hover {
            background: var(--G2);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    /* ── EXTEND CARD ── */
    .ext-card {
        background: var(--C);
        border: 1px solid var(--S);
        border-radius: var(--r2);
        padding: 1rem 1.2rem;
        margin-top: .65rem;
    }

    .ext-title {
        font-size: .68rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--M);
        font-weight: 600;
        margin-bottom: .65rem;
    }

    .ext-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: .5rem;
    }

    .ext-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .3rem;
        padding: .5rem;
        border-radius: 8px;
        border: 1.5px solid var(--S);
        background: #fff;
        color: var(--D);
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .18s;
        font-family: 'Space Grotesk',sans-serif;
    }

        .ext-btn:hover {
            border-color: var(--G);
            background: var(--G3);
            color: var(--G);
        }

    /* ── STATUS BADGE ── */
    .st-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: .3rem .8rem;
        border-radius: 20px;
    }

        .st-badge::before {
            content: '●';
            font-size: .5em;
        }

    .st-pe {
        background: rgba(212,160,23,.13);
        color: #92660a;
    }

    .st-co {
        background: rgba(59,130,246,.1);
        color: var(--BL);
    }

    .st-pl {
        background: rgba(139,92,246,.1);
        color: var(--PU);
    }

    .st-ok {
        background: rgba(16,185,129,.1);
        color: var(--GN);
    }

    /* ── RIGHT: RECENT PANEL ── */
    .recent-card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
    }

    .rc-head {
        padding: 1rem 1.3rem;
        border-bottom: 1px solid var(--S);
    }

    .rc-title {
        font-family: 'Syne',sans-serif;
        font-size: .92rem;
        font-weight: 800;
        color: var(--D);
    }

    .rc-item {
        display: flex;
        align-items: center;
        gap: .85rem;
        padding: .72rem 1.3rem;
        border-bottom: 1px solid var(--S);
        transition: background .15s;
    }

        .rc-item:last-child {
            border-bottom: none;
        }

        .rc-item:hover {
            background: var(--C);
        }

    .rc-ico {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .rc-info {
        flex: 1;
        min-width: 0;
    }

    .rc-name {
        font-size: .8rem;
        font-weight: 600;
        color: var(--D);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rc-sub {
        font-size: .68rem;
        color: var(--M);
        margin-top: .06rem;
    }

    .rc-time {
        font-size: .7rem;
        color: var(--M);
        white-space: nowrap;
    }

    .rc-empty {
        text-align: center;
        padding: 2.5rem 1rem;
        color: var(--M);
        font-size: .82rem;
    }
</style>

<div class="ci-wrap">
    <!-- LEFT COLUMN -->
    <div>
        <!-- Search -->
        <div class="search-card">
            <div class="sc-lbl">Quét mã / Tìm kiếm</div>
            <div class="sc-title">Tìm Đơn Đặt Sân</div>
            <div class="sc-input-wrap">
                <input type="text" id="kw" class="sc-input" placeholder="Mã đơn BK... hoặc số điện thoại..." autofocus />
                <button class="sc-btn" onclick="findBooking()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    Tìm
                </button>
            </div>
            <div class="sc-hint">Ví dụ: BK20260315001 hoặc 0901234567 · Nhấn Enter để tìm</div>
        </div>

        <!-- Result -->
        <div id="result" style="display:none;">
            <div class="res-card">
                <div class="res-card-head">
                    <div>
                        <div class="res-code" id="r-code"></div>
                        <div class="res-court" id="r-court"></div>
                    </div>
                    <span id="r-status"></span>
                </div>
                <div class="res-body">
                    <div class="res-grid">
                        <div class="res-item">
                            <div class="res-item-lbl">Khách hàng</div>
                            <div class="res-item-val">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--G)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                <span id="r-name"></span>
                            </div>
                        </div>
                        <div class="res-item">
                            <div class="res-item-lbl">Điện thoại</div>
                            <div class="res-item-val">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--G)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z" /></svg>
                                <span id="r-phone"></span>
                            </div>
                        </div>
                        <div class="res-item">
                            <div class="res-item-lbl">Khung giờ</div>
                            <div class="res-item-val">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--G)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                                <span id="r-time"></span>
                            </div>
                        </div>
                        <div class="res-item">
                            <div class="res-item-lbl">Tổng tiền</div>
                            <div class="res-item-val">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--G)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                                <span id="r-price"></span>đ
                            </div>
                        </div>
                    </div>
                    <div class="res-actions" id="r-actions"></div>
                </div>
            </div>

            <!-- Extend -->
            <div class="ext-card" id="extCard" style="display:none;">
                <div class="ext-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:.3rem;"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /><line x1="8" y1="12" x2="16" y2="12" /></svg>
                    Gia hạn thêm thời gian
                </div>
                <div class="ext-grid">
                    @foreach (var m in new[] { 30, 60, 90 })
                    {
                        <button class="ext-btn" onclick="extend(@m)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                            +@m phút
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Recent check-ins -->
    <div>
        <div class="recent-card">
            <div class="rc-head">
                <div class="rc-title">Check-in Gần Đây</div>
            </div>
            <div id="recentList">
                <div class="rc-empty">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:.5rem;opacity:.25;"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M9 9h.01M9 15h.01M15 9h.01M15 15h.01" /></svg>
                    <div>Chưa có check-in nào hôm nay</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let curId = null, curStatus = null;

        async function findBooking() {
            const kw = document.getElementById('kw').value.trim();
            if (!kw) return;

            const btn = document.querySelector('.sc-btn');
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="animation:spin .8s linear infinite"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg> Đang tìm...';

            try {
                const r = await fetch('/Staff/FindBooking?keyword=' + encodeURIComponent(kw));
                const d = await r.json();
                if (!d.success) { showError(d.message); return; }

                curId = d.bookingId; curStatus = d.status;

                document.getElementById('r-code').textContent  = d.bookingCode;
                document.getElementById('r-court').textContent = 'Sân ' + d.courtNumber;
                document.getElementById('r-name').textContent  = d.customerName;
                document.getElementById('r-phone').textContent = d.phone;
                document.getElementById('r-time').textContent  = d.startTime + ' – ' + d.endTime;
                document.getElementById('r-price').textContent = Number(d.totalPrice).toLocaleString('vi-VN');

                const stMap = { Pending:'Chờ duyệt', Confirmed:'Đã xác nhận', Playing:'Đang chơi', Completed:'Hoàn thành' };
                const stCls = { Pending:'st-pe', Confirmed:'st-co', Playing:'st-pl', Completed:'st-ok' };
                const sb = document.getElementById('r-status');
                sb.className = 'st-badge ' + (stCls[d.status] || 'st-pe');
                sb.textContent = stMap[d.status] || d.status;

                const tok = document.querySelector('input[name=__RequestVerificationToken]')?.value || '';
                let acts = '';
                if (d.status === 'Confirmed') {
                    acts = `<form method="post" action="/Staff/DoCheckIn">
                        <input type="hidden" name="bookingId" value="${d.bookingId}">
                        <input type="hidden" name="__RequestVerificationToken" value="${tok}">
                        <button type="submit" class="ci-btn ci-btn-in">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                            Check-in — Bắt đầu chơi
                        </button>
                    </form>`;
                    document.getElementById('extCard').style.display = 'none';
                } else if (d.status === 'Playing') {
                    acts = `<form method="post" action="/Staff/DoCheckOut">
                        <input type="hidden" name="bookingId" value="${d.bookingId}">
                        <input type="hidden" name="__RequestVerificationToken" value="${tok}">
                        <button type="submit" class="ci-btn ci-btn-out">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            Check-out — Kết thúc chơi
                        </button>
                    </form>`;
                    document.getElementById('extCard').style.display = 'block';
                } else {
                    acts = `<div style="text-align:center;padding:.8rem;background:var(--C);border-radius:9px;font-size:.82rem;color:var(--M);">Không thể thực hiện thao tác với đơn ở trạng thái này</div>`;
                    document.getElementById('extCard').style.display = 'none';
                }
                document.getElementById('r-actions').innerHTML = acts;
                document.getElementById('result').style.display = 'block';
                document.getElementById('result').scrollIntoView({behavior:'smooth',block:'nearest'});
            } catch(e) {
                showError('Lỗi kết nối. Vui lòng thử lại.');
            } finally {
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Tìm';
            }
        }

        function showError(msg) {
            document.getElementById('result').style.display = 'block';
            document.getElementById('result').innerHTML = `
                <div style="background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);border-radius:var(--r);padding:1.2rem 1.4rem;display:flex;align-items:center;gap:.75rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--RD)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <div style="font-size:.85rem;font-weight:600;color:var(--RD);">${msg}</div>
                </div>`;
        }

        async function extend(minutes) {
            if (!curId) return;
            const tok = document.querySelector('input[name=__RequestVerificationToken]')?.value || '';
            const r = await fetch('/Staff/ExtendBooking', {
                method: 'POST',
                headers: {'Content-Type':'application/x-www-form-urlencoded'},
                body: `bookingId=${curId}&extraMinutes=${minutes}&__RequestVerificationToken=${encodeURIComponent(tok)}`
            });
            const d = await r.json();
            if (d.success) { findBooking(); }
            else alert(d.message);
        }

        document.getElementById('kw').addEventListener('keydown', e => { if (e.key === 'Enter') findBooking(); });
    </script>
    <style>
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }</style>
    @Html.AntiForgeryToken()
}
