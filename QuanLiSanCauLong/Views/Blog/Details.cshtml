@model QuanLiSanCauLong.Models.BlogPost
@{
    ViewData["Title"] = Model.Title;
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --gold: #d4a017;
        --gold2: #f5c842;
        --deep: #1a1209;
        --cream: #fdf8f0;
        --warm: #f5efe0;
        --muted: #8a7560;
        --border: #e8ddc8;
    }

    body, * {
        font-family: 'Outfit', sans-serif;
        box-sizing: border-box;
    }

    /* BREADCRUMB */
    .bd-bc {
        background: var(--deep);
        padding: .75rem 0;
        border-bottom: 1px solid rgba(212,160,23,.18);
    }

    .bd-bc-inner {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .bd-bc a {
        color: var(--gold2);
        text-decoration: none;
        font-size: .76rem;
        font-weight: 600;
        opacity: .8;
    }

        .bd-bc a:hover {
            opacity: 1;
        }

    .bd-bc-sep {
        color: rgba(255,255,255,.25);
        font-size: .65rem;
    }

    .bd-bc-cur {
        color: rgba(255,255,255,.35);
        font-size: .76rem;
        font-style: italic;
    }

    /* ARTICLE HERO */
    .bd-hero {
        background: var(--deep);
        padding: 3.5rem 0 4rem;
        position: relative;
        overflow: hidden;
    }

        .bd-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 50% 80% at 80% 50%, rgba(212,160,23,.06), transparent 65%);
            pointer-events: none;
        }

    .bd-hero-inner {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 1;
    }

    .bd-cat {
        display: inline-block;
        background: var(--gold);
        color: var(--deep);
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        padding: .25rem .8rem;
        border-radius: 2px;
        margin-bottom: 1.5rem;
    }

    .bd-feat-badge {
        display: inline-block;
        background: rgba(220,38,38,.15);
        border: 1px solid rgba(220,38,38,.3);
        color: #f87171;
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        padding: .25rem .8rem;
        border-radius: 2px;
        margin-bottom: 1.5rem;
        margin-left: .5rem;
    }

    .bd-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.9rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        line-height: 1.2;
        margin-bottom: 1.25rem;
    }

    .bd-excerpt {
        font-size: 1rem;
        color: rgba(255,255,255,.5);
        font-weight: 300;
        line-height: 1.8;
        max-width: 640px;
        margin-bottom: 2rem;
    }

    .bd-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .bd-meta-item {
        font-size: .78rem;
        color: rgba(255,255,255,.4);
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .bd-meta-item i {
            color: var(--gold);
            font-size: .72rem;
        }

    /* FEATURED IMAGE */
    .bd-img-wrap {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 2rem;
        margin-top: -2rem;
        position: relative;
        z-index: 2;
    }

        .bd-img-wrap img {
            width: 100%;
            max-height: 520px;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid var(--border);
            box-shadow: 0 24px 60px rgba(26,18,9,.18);
        }

    /* BODY */
    .bd-body {
        background: var(--cream);
        padding: 4rem 0 6rem;
    }

    .bd-body-inner {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Content styling */
    .bd-content {
        font-size: .975rem;
        line-height: 1.95;
        color: #2d2418;
        text-align: justify;
    }

        .bd-content h2 {
            font-family: 'Playfair Display', serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--deep);
            margin: 3rem 0 1.2rem;
            padding-bottom: .6rem;
            border-bottom: 2px solid var(--gold);
        }

        .bd-content h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--deep);
            margin: 2.5rem 0 1rem;
        }

        .bd-content p {
            margin-bottom: 1.5rem;
        }

        .bd-content img {
            max-width: 100%;
            height: auto;
            border-radius: 6px;
            margin: 2rem 0;
            box-shadow: 0 8px 28px rgba(26,18,9,.12);
            border: 1px solid var(--border);
        }

        .bd-content ul, .bd-content ol {
            margin-bottom: 1.5rem;
            padding-left: 1.75rem;
        }

        .bd-content li {
            margin-bottom: .75rem;
        }

        .bd-content blockquote {
            border-left: 3px solid var(--gold);
            padding: 1.25rem 1.5rem;
            margin: 2rem 0;
            background: var(--warm);
            border-radius: 0 6px 6px 0;
            font-style: italic;
            color: var(--muted);
        }

        .bd-content a {
            color: var(--gold);
            text-decoration: underline;
        }

    /* TAGS */
    .bd-tags {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }

    .bd-tags-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .75rem;
    }

    .bd-tag {
        display: inline-block;
        background: var(--warm);
        border: 1px solid var(--border);
        color: var(--muted);
        font-size: .72rem;
        font-weight: 600;
        padding: .28rem .8rem;
        border-radius: 3px;
        margin: .2rem;
        text-decoration: none;
        transition: all .2s;
    }

        .bd-tag:hover {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--deep);
        }

    /* SHARE */
    .bd-share {
        margin-top: 2.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }

    .bd-share-label {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .75rem;
    }

    .bd-share-btns {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .bd-share-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .45rem 1.1rem;
        border-radius: 3px;
        font-size: .76rem;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--muted);
        transition: all .2s;
        text-decoration: none;
    }

        .bd-share-btn:hover {
            background: var(--deep);
            border-color: var(--deep);
            color: var(--gold2);
        }

    /* REVIEW SECTION */
    #reviewSection {
        margin-top: 3.5rem;
        padding-top: 2.5rem;
        border-top: 2px solid var(--border);
    }

    .bd-review-loading {
        text-align: center;
        padding: 2.5rem;
        color: var(--muted);
    }

    .bd-review-loading-spinner {
        width: 28px;
        height: 28px;
        border: 2px solid var(--border);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin .7s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* BACK BUTTON */
    .bd-back-wrap {
        text-align: center;
        margin-top: 4rem;
        padding-top: 2.5rem;
        border-top: 1px solid var(--border);
    }

    .bd-back-btn {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        background: var(--deep);
        color: var(--gold2);
        border: none;
        padding: .9rem 2.5rem;
        font-family: 'Playfair Display', serif;
        font-size: .95rem;
        font-weight: 700;
        border-radius: 3px;
        text-decoration: none;
        transition: all .3s;
    }

        .bd-back-btn:hover {
            background: var(--gold);
            color: var(--deep);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(212,160,23,.3);
        }

    @@media (max-width: 640px) {
        .bd-hero {
            padding: 2.5rem 0 3rem;
        }

        .bd-title {
            font-size: 1.9rem;
        }

        .bd-img-wrap {
            margin-top: -1.5rem;
        }
    }
</style>

<!-- BREADCRUMB -->
<div class="bd-bc">
    <div class="bd-bc-inner">
        <a asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Trang chủ</a>
        <span class="bd-bc-sep"><i class="bi bi-chevron-right"></i></span>
        <a asp-controller="Blog" asp-action="Index">Tin tức</a>
        <span class="bd-bc-sep"><i class="bi bi-chevron-right"></i></span>
        <span class="bd-bc-cur">Chi tiết</span>
    </div>
</div>

<!-- HERO -->
<div class="bd-hero">
    <div class="bd-hero-inner">
        @if (!string.IsNullOrEmpty(Model.Category?.CategoryName))
        {
            <span class="bd-cat">@Model.Category.CategoryName</span>
        }
        @if (Model.IsFeatured)
        {
            <span class="bd-feat-badge"><i class="bi bi-star-fill me-1" style="font-size:.55rem"></i>Nổi bật</span>
        }
        <h1 class="bd-title">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Excerpt))
        {
            <p class="bd-excerpt">@Model.Excerpt</p>
        }
        <div class="bd-meta">
            <div class="bd-meta-item"><i class="bi bi-calendar3"></i>@((Model.PublishedAt ?? Model.CreatedAt).ToString("dd/MM/yyyy"))</div>
            <div class="bd-meta-item"><i class="bi bi-eye"></i>@Model.ViewCount.ToString("N0") lượt xem</div>
            @if (!string.IsNullOrEmpty(Model.Tags))
            {
                <div class="bd-meta-item"><i class="bi bi-tags"></i>@Model.Tags.Replace(",", " · ")</div>
            }
        </div>
    </div>
</div>

<!-- FEATURED IMAGE -->
@if (!string.IsNullOrEmpty(Model.FeaturedImage))
{
    <div class="bd-img-wrap">
        <img src="@Model.FeaturedImage" alt="@Model.Title" />
    </div>
}

<!-- BODY -->
<div class="bd-body">
    <div class="bd-body-inner">
        <div class="bd-content">
            @Html.Raw(Model.Content)
        </div>

        @if (!string.IsNullOrEmpty(Model.Tags))
        {
            <div class="bd-tags">
                <div class="bd-tags-label">Tags</div>
                @foreach (var tag in Model.Tags.Split(','))
                {
                    <a href="#" class="bd-tag">#@tag.Trim()</a>
                }
            </div>
        }

        <div class="bd-share">
            <div class="bd-share-label">Chia sẻ bài viết</div>
            <div class="bd-share-btns">
                <a id="shareFacebook" href="#" target="_blank" rel="noopener" class="bd-share-btn"><i class="bi bi-facebook"></i>Facebook</a>
                <a id="shareTwitter" href="#" target="_blank" rel="noopener" class="bd-share-btn"><i class="bi bi-twitter-x"></i>Twitter</a>
                <a id="shareWhatsApp" href="#" target="_blank" rel="noopener" class="bd-share-btn"><i class="bi bi-whatsapp"></i>WhatsApp</a>
                <button class="bd-share-btn" onclick="copyLink()"><i class="bi bi-link-45deg"></i>Copy Link</button>
            </div>
        </div>

        <div id="reviewSection">
            <div class="bd-review-loading">
                <div class="bd-review-loading-spinner"></div>
                <p style="font-size:.84rem">Đang tải bình luận...</p>
            </div>
        </div>

        <div class="bd-back-wrap">
            <a asp-controller="Blog" asp-action="Index" class="bd-back-btn">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // FIX 8: Share links dùng URL thật
        (function () {
            const url     = encodeURIComponent(window.location.href);
            const title   = encodeURIComponent('@Html.Raw(Model.Title.Replace("'", "\\'").Replace("\n", " "))');
            document.getElementById('shareFacebook').href =
                'https://www.facebook.com/sharer/sharer.php?u=' + url;
            document.getElementById('shareTwitter').href =
                'https://twitter.com/intent/tweet?url=' + url + '&text=' + title;
            document.getElementById('shareWhatsApp').href =
                'https://api.whatsapp.com/send?text=' + title + '%20' + url;
        })();

        function copyLink() {
            navigator.clipboard.writeText(window.location.href)
                .then(() => {
                    const btn = event.currentTarget;
                    const orig = btn.innerHTML;
                    btn.innerHTML = '<i class="bi bi-check2"></i> Đã copy!';
                    btn.style.background = 'var(--deep)';
                    btn.style.color = 'var(--gold2)';
                    setTimeout(() => { btn.innerHTML = orig; btn.style.background = ''; btn.style.color = ''; }, 2000);
                })
                .catch(() => alert('Không thể copy. Hãy copy thủ công: ' + window.location.href));
        }

        $(document).ready(function () {
            const postId = '@Model.PostId';
            $.ajax({
                url: '/BlogReview/Index',
                type: 'GET',
                data: { blogId: postId },
                success: function (data) { $('#reviewSection').html(data); },
                error: function () {
                    $('#reviewSection').html('<p style="color:var(--muted);font-size:.86rem;padding:1rem 0">Không thể tải phần bình luận lúc này.</p>');
                }
            });
        });
    </script>
}
