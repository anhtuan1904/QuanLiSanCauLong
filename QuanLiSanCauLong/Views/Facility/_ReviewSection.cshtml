<div id="reviews">
    <div class="rv-sec-hd">
        <div class="rv-sec-title">Đánh giá <em>sân</em></div>
        @if (Model.TotalCount > 0)
        {
            <span style="font-size:.78rem;color:#8a7560;">@Model.TotalCount đánh giá</span>
        }
    </div>

    @if (Model.TotalCount > 0)
    {
        <div class="rv-summary">
            <div class="rv-big-score">
                <div class="rv-score-num">@Model.AverageRating.ToString("0.0")</div>
                <div class="rv-score-stars">
                    @for (int s = 1; s <= 5; s++)
                    {
                        <i class="bi bi-star-fill rv-s-star @(s <= Math.Round(Model.AverageRating) ? "on" : "off")"></i>
                    }
                </div>
                <div class="rv-score-cnt">@Model.TotalCount đánh giá</div>
            </div>
            <div class="rv-bars">
                @{
                    int[] cnts = { Model.FiveStars, Model.FourStars, Model.ThreeStars, Model.TwoStars, Model.OneStar };
                    int maxC = cnts.Max() > 0 ? cnts.Max() : 1;
                }
                @for (int s = 5; s >= 1; s--)
                {
                    int cnt = cnts[5 - s];
                    double pct = (double)cnt / maxC * 100;
                    <div class="rv-bar-row">
                        <div class="rv-bar-lbl">@s <i class="bi bi-star-fill"></i></div>
                        <div class="rv-bar-track"><div class="rv-bar-fill" style="width:@pct.ToString("0")%"></div></div>
                        <div class="rv-bar-cnt">@cnt</div>
                    </div>
                }
            </div>
        </div>

        @if (Model.AvgCleanliness > 0 || Model.AvgCourtQuality > 0 || Model.AvgService > 0 || Model.AvgValue > 0)
        {
            <div class="rv-subcats">
                @{
                    void SC(string lbl, double v)
                    {
                        if (v <= 0) return;
                        int fs = (int)Math.Round(v);
                        <div class="rv-subcat">
                            <div class="rv-subcat-val">@v.ToString("0.0")</div>
                            <div class="rv-subcat-lbl">@lbl</div>
                            <div class="rv-subcat-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi bi-star-fill rv-subcat-star @(i <= fs ? "on" : "off")"></i>
                                }
                            </div>
                        </div>
                    }
                    SC("Vệ sinh", Model.AvgCleanliness);
                    SC("Chất lượng sân", Model.AvgCourtQuality);
                    SC("Dịch vụ", Model.AvgService);
                    SC("Giá trị", Model.AvgValue);
                }
            </div>
        }
    }

    <div class="rv-cta">
        <div class="rv-cta-text">
            <div class="t">Bạn đã chơi tại đây?</div>
            <div class="s">Chia sẻ trải nghiệm giúp người khác chọn sân phù hợp</div>
        </div>
        @if (!isLoggedIn)
        {
            <div class="rv-hint">
                <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path + "#reviews")">Đăng nhập</a> để viết đánh giá
            </div>
        }
        else if (existReview != null)
        {
            <span class="rv-already"><i class="bi bi-check-circle-fill"></i> Bạn đã đánh giá sân này</span>
        }
        else if (canReview)
        {
            <button class="btn-rv-write" id="btnOpenReviewForm_@fid">
                <i class="bi bi-pencil-fill"></i> Viết đánh giá
            </button>
        }
        else
        {
            <div class="rv-hint">Chỉ khách đã đặt sân mới có thể đánh giá</div>
        }
    </div>

    @if (isLoggedIn && canReview && existReview == null)
    {
        <div class="rv-form-wrap" id="rvFormWrap_@fid">
            <div class="rv-form-hd">
                <span class="rv-form-hd-title">Viết đánh giá của bạn</span>
                <button class="rv-form-close" id="btnCloseForm_@fid"><i class="bi bi-x-lg"></i></button>
            </div>
            <form id="rvForm_@fid" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="facilityId" value="@fid" />
                <input type="hidden" name="courtId" id="rvCid_@fid" value="" />
                <input type="hidden" name="bookingId" id="rvBid_@fid" value="" />
                <div class="rv-form-body">
                    @if (Model.BookedCourts.Count > 1)
                    {
                        <div>
                            <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#8a7560;margin-bottom:.4rem;">Chọn sân <span style="color:#c94b2a">*</span></div>
                            <div style="display:flex;flex-wrap:wrap;gap:.45rem;">
                                @foreach (var bc in Model.BookedCourts)
                                {
                                    <button type="button" class="rv-cpick_@fid"
                                            data-court="@bc.CourtId" data-booking="@bc.BookingId"
                                            style="padding:.42rem .9rem;border:1.5px solid #ede5d8;border-radius:6px;background:#fff;font-size:.78rem;font-weight:700;color:#1a1209;cursor:pointer;">
                                        @bc.CourtNumber
                                        <span style="font-size:.65rem;color:#8a7560;font-weight:400;margin-left:.3rem;">@bc.BookingDate.ToString("dd/MM")</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else if (Model.BookedCourts.Count == 1)
                    {
                        <div style="display:inline-flex;align-items:center;gap:.45rem;padding:.38rem .85rem;background:rgba(212,160,23,.08);border:1px solid rgba(212,160,23,.2);border-radius:6px;font-size:.78rem;font-weight:700;color:#1a1209;">
                            <i class="bi bi-geo-alt-fill" style="color:#d4a017"></i>
                            Sân @Model.BookedCourts[0].CourtNumber · @Model.BookedCourts[0].BookingDate.ToString("dd/MM/yyyy")
                        </div>
                    }

                    <div>
                        <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#8a7560;margin-bottom:.5rem;">Đánh giá tổng thể <span style="color:#c94b2a">*</span></div>
                        <div style="display:flex;align-items:center;gap:.75rem;">
                            <div class="star-group" id="mainStars_@fid">
                                @for (int s = 5; s >= 1; s--)
                                {
                                    <input type="radio" name="rating" id="rs@(s)_@fid" value="@s" required />
                                    <label for="rs@(s)_@fid"><i class="bi bi-star-fill"></i></label>
                                }
                            </div>
                            <span id="starLbl_@fid" style="font-size:.8rem;color:#8a7560;font-style:italic;"></span>
                        </div>
                    </div>

                    <div>
                        <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#8a7560;margin-bottom:.5rem;">Chi tiết (tùy chọn)</div>
                        <div class="sub-ratings-form">
                            @foreach (var (name, lbl) in new[] { ("ratingCleanliness", "Vệ sinh"), ("ratingCourtQuality", "Chất lượng"), ("ratingService", "Dịch vụ"), ("ratingValue", "Giá trị") })
                            {
                                <div class="sub-rating-item">
                                    <div class="sri-label">@lbl</div>
                                    <div class="sri-stars">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            <i class="bi bi-star-fill sri-star" data-v="@s"></i>
                                        }
                                    </div>
                                    <input type="hidden" name="@name" class="sri-hidden" value="0" />
                                </div>
                            }
                        </div>
                    </div>

                    <div>
                        <textarea name="content" class="rv-textarea"
                              placeholder="Sân sạch không? Đèn tốt không? Nhân viên thế nào?..."></textarea>
                        <div class="rv-char-cnt">0/2000</div>
                    </div>

                    <div>
                        <div style="font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#8a7560;margin-bottom:.4rem;">
                            <i class="bi bi-camera me-1" style="color:#d4a017"></i>Thêm ảnh (tối đa 5)
                        </div>
                        <div class="rv-img-upload" id="rvImgUpload_@fid">
                            <input type="file" id="rvImgs_@fid" name="images" accept="image/*" multiple />
                            <label class="rv-img-lbl"><i class="bi bi-cloud-upload"></i><span>Nhấn để chọn · JPG, PNG · 5MB</span></label>
                        </div>
                        <div class="rv-prev-row" id="rvPrev_@fid"></div>
                    </div>

                    <div class="rv-form-foot">
                        <button type="button" class="btn-rv-cancel" id="btnCancelForm_@fid">Hủy</button>
                        <button type="submit" class="btn-rv-sub" id="rvSubBtn_@fid">
                            <i class="bi bi-send-fill"></i> Gửi đánh giá
                        </button>
                    </div>
                </div>
            </form>
        </div>
    }

    @if (Model.TotalCount > 0)
    {
        <div class="rv-filter-row">
            <span class="rv-filter-lbl">Lọc:</span>
            <button class="rv-ftag on" data-rf="all">Tất cả (@Model.TotalCount)</button>
            @if (Model.FiveStars > 0)
            {
                <button class="rv-ftag" data-rf="5">5★ (@Model.FiveStars)</button>
            }
            @if (Model.FourStars > 0)
            {
                <button class="rv-ftag" data-rf="4">4★ (@Model.FourStars)</button>
            }
            @if (Model.ThreeStars > 0)
            {
                <button class="rv-ftag" data-rf="3">3★ (@Model.ThreeStars)</button>
            }
            @if (Model.WithImages > 0)
            {
                <button class="rv-ftag" data-rf="img"><i class="bi bi-images me-1"></i>Có ảnh (@Model.WithImages)</button>
            }
            @if (Model.Verified > 0)
            {
                <button class="rv-ftag" data-rf="verified"><i class="bi bi-patch-check me-1"></i>Đã chơi (@Model.Verified)</button>
            }
            <select class="rv-sort-sel" id="rvSortSel_@fid">
                <option value="newest">Mới nhất</option>
                <option value="highest">Sao cao nhất</option>
                <option value="lowest">Sao thấp nhất</option>
                <option value="helpful">Hữu ích nhất</option>
            </select>
        </div>
    }

    <div class="rv-list" id="rvList_@fid">
        @if (!Model.Reviews.Any())
        {
            <div class="rv-empty">
                <i class="bi bi-star-half"></i>
                <div style="font-weight:700;color:#1a1209;margin-bottom:.4rem;">Chưa có đánh giá nào</div>
                <div style="font-size:.82rem;">Hãy là người đầu tiên chia sẻ!</div>
            </div>
        }
        @foreach (var rv in Model.Reviews)
        {
            var liked = Model.MyLikedReviewIds.Contains(rv.ReviewId);
            <div class="rv-card"
                 data-rating="@rv.Rating"
                 data-has-img="@(rv.ImageCount > 0 ? "1" : "0")"
                 data-verified="@(rv.IsVerifiedBooking ? "1" : "0")"
                 data-helpful="@rv.LikeCount">
                <div class="rv-card-hd">
                    <img src="@rv.UserAvatar" class="rv-avatar" alt="" onerror="this.src='/images/default-avatar.jpg'" />
                    <div class="rv-author">
                        <div class="rv-author-name">
                            @rv.UserName
                            @if (rv.IsVerifiedBooking)
                            {
                                <span class="rv-verified"><i class="bi bi-patch-check-fill"></i>Đã chơi</span>
                            }
                            @if (rv.IsFeatured)
                            {
                                <span class="rv-feat"><i class="bi bi-pin-angle-fill"></i>Nổi bật</span>
                            }
                        </div>
                        <div class="rv-date">
                            @rv.CreatedAt.ToString("dd/MM/yyyy")
                            @if (!string.IsNullOrEmpty(rv.CourtName))
                            {
                                <span style="margin-left:.4rem;color:#d4a017;font-weight:600;">· @rv.CourtName</span>
                            }
                        </div>
                        <div class="rv-stars-row">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <i class="bi bi-star-fill rv-star @(s <= rv.Rating ? "on" : "off")"></i>
                            }
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(rv.Content))
                {
                    <div class="rv-card-body"><div class="rv-content">@rv.Content</div></div>
                }
                @if (rv.ImageCount > 0 && rv.ThumbnailUrl != null)
                {
                    <div class="rv-img-gallery" style="padding:0 1.1rem .75rem;">
                        <img src="@rv.ThumbnailUrl" class="rv-gimg"
                             onclick="rvOpenLightbox(this.src)" />
                        @if (rv.ImageCount > 1)
                        {
                            <div style="width:72px;height:72px;border-radius:7px;border:1px solid #ede5d8;background:rgba(26,18,9,.05);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;color:#8a7560;">
                                +@(rv.ImageCount - 1)
                            </div>
                        }
                    </div>
                }
                <div class="rv-card-ft">
                    <button class="rv-like-btn @(liked ? "liked" : "")"
                            onclick="rvLike(@rv.ReviewId,'Like',this)"
                            @(!isLoggedIn ? "disabled title='Đăng nhập để thích'" : "")>
                        <i class="bi bi-hand-thumbs-up@(liked ? "-fill" : "")"></i>
                        Hữu ích <span class="like-cnt">@rv.LikeCount</span>
                    </button>
                    @if (isLoggedIn)
                    {
                        <button class="rv-reply-btn" onclick="rvToggleReply(@rv.ReviewId)">
                            <i class="bi bi-chat-dots"></i> Phản hồi
                        </button>
                    }
                </div>
                @if (rv.AdminReply != null)
                {
                    <div class="rv-admin-reply">
                        <div class="rv-ar-hd">
                            <span class="rv-ar-badge"><i class="bi bi-shield-check me-1"></i>Ban quản lý</span>
                            <span class="rv-ar-date">@rv.AdminReply.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="rv-ar-content">@rv.AdminReply.Content</div>
                    </div>
                }
                @if (rv.ReplyCount > 0)
                {
                    <div class="rv-replies" id="rvreplies_@rv.ReviewId"></div>
                }
                @if (isLoggedIn)
                {
                    <div class="rv-inline-reply" id="rvireply_@rv.ReviewId">
                        <input type="text" class="rv-inline-input" id="rviinput_@rv.ReviewId"
                               placeholder="Viết phản hồi..." maxlength="500" />
                        <div class="rv-inline-acts">
                            <button class="btn-ilcancel" onclick="rvToggleReply(@rv.ReviewId)">Hủy</button>
                            <button class="btn-ilsend" onclick="rvSendReply(@rv.ReviewId)">Gửi</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (Model.HasMore)
    {
        <button class="rv-load-more" id="rvMore_@fid"
                onclick="rvLoadMore(@fid, @Model.LoadedCount)">
            <i class="bi bi-arrow-down-circle me-1"></i>
            Xem thêm (@(Model.TotalCount - Model.LoadedCount) còn lại)
        </button>
    }
</div>

<div class="rv-lightbox" id="rvLightbox" onclick="this.classList.remove('show')">
    <button class="rv-lb-close" onclick="event.stopPropagation();document.getElementById('rvLightbox').classList.remove('show')">
        <i class="bi bi-x-lg"></i>
    </button>
    <img id="rvLBImg" src="" alt="" onclick="event.stopPropagation()" />
</div>

@*
   ════════════════════════════════════════════════════════
   SCRIPT — INLINE (không dùng @section Scripts)
   
   FIX "trắng tinh":
   Script dùng ID cụ thể (rvFormWrap_@fid, btnOpenReviewForm_@fid...)
   KHÔNG query #rvFormWrap chung chung nữa → tránh conflict
   
   FIX "tab hidden không chạy":
   Dùng setTimeout(fn, 0) để defer ra sau render xong
   Các hàm global (rvLike, rvToggleReply...) bind vào window ngay,
   chỉ defer phần addEventListener cần DOM ready
   ════════════════════════════════════════════════════════
*@
<script>
    (function() {
        var F = @fid;
        var TOKEN = '';

        // ── Hàm lấy TOKEN (defer đến khi DOM có element) ──
        function getToken() {
            if (!TOKEN) TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            return TOKEN;
        }

        // ══════════════════════════════════════════════════
        //  CÁC HÀM GLOBAL — bind vào window NGAY (không defer)
        //  vì onclick="rvLike(...)" trong HTML gọi trực tiếp
        // ══════════════════════════════════════════════════

        // Like
        window.rvLike = async function(reviewId, type, btn) {
            if (btn.disabled) return;
            var res = await fetch('/Review/Like', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                body: JSON.stringify({ reviewId: reviewId, likeType: type })
            }).then(function(r){ return r.json(); }).catch(function(){ return { success: false }; });
            if (res.success) {
                btn.querySelector('.like-cnt').textContent = res.newCount;
                btn.classList.toggle('liked', res.isLiked);
                btn.querySelector('i').className = res.isLiked ? 'bi bi-hand-thumbs-up-fill' : 'bi bi-hand-thumbs-up';
            }
        };

        // Toggle inline reply
        window.rvToggleReply = function(id) {
            var el = document.getElementById('rvireply_' + id);
            if (!el) return;
            var isOpen = el.classList.contains('show');
            document.querySelectorAll('.rv-inline-reply.show').forEach(function(x){ x.classList.remove('show'); });
            if (!isOpen) { el.classList.add('show'); el.querySelector('input')?.focus(); }
        };

        // Send inline reply
        window.rvSendReply = async function(reviewId) {
            var input   = document.getElementById('rviinput_' + reviewId);
            var content = input?.value.trim();
            if (!content) { alert('Vui lòng nhập nội dung!'); return; }
            var res = await fetch('/Review/Reply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                body: JSON.stringify({ reviewId: reviewId, content: content })
            }).then(function(r){ return r.json(); }).catch(function(){ return { success: false }; });
            if (res.success) {
                window.rvToggleReply(reviewId);
                input.value = '';
                var rlist = document.getElementById('rvreplies_' + reviewId);
                if (!rlist) {
                    rlist = document.createElement('div');
                    rlist.className = 'rv-replies';
                    rlist.id = 'rvreplies_' + reviewId;
                    document.getElementById('rvireply_' + reviewId).before(rlist);
                }
                var item = document.createElement('div');
                item.className = 'rv-reply-item';
                item.innerHTML = '<img src="' + (res.userAvatar || '/images/default-avatar.jpg') + '" class="rv-reply-av" />'
                    + '<div class="rv-reply-body"><div class="rv-reply-name">' + res.userName + '</div>'
                    + '<div class="rv-reply-text">' + content + '</div>'
                    + '<div class="rv-reply-date">Vừa xong</div></div>';
                rlist.appendChild(item);
            } else { alert(res.message || 'Gửi thất bại'); }
        };

        // Lightbox
        window.rvOpenLightbox = function(src) {
            document.getElementById('rvLBImg').src = src;
            document.getElementById('rvLightbox').classList.add('show');
        };
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') document.getElementById('rvLightbox')?.classList.remove('show'); });

        // Load more
        window.rvLoadMore = async function(facilityId, offset) {
            var btn = document.getElementById('rvMore_' + facilityId);
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang tải...';
            btn.disabled  = true;
            var res = await fetch('/Review/LoadMore?facilityId=' + facilityId + '&offset=' + offset + '&limit=5')
                             .then(function(r){ return r.json(); })
                             .catch(function(){ return { success: false }; });
            if (res.success && res.html) {
                document.getElementById('rvList_' + facilityId).insertAdjacentHTML('beforeend', res.html);
                if (!res.hasMore) btn.remove();
                else { btn.innerHTML = '<i class="bi bi-arrow-down-circle me-1"></i> Xem thêm'; btn.disabled = false; }
            }
        };

        // ══════════════════════════════════════════════════
        //  PHẦN CẦN DOM — dùng setTimeout(0) để defer
        //  Giải quyết vấn đề tab hidden (display:none)
        //  khi script chạy, element có thể chưa visible
        //  nhưng đã có trong DOM → setTimeout đủ để defer
        // ══════════════════════════════════════════════════
        setTimeout(function() {

            // ── Toggle form open/close ──
            var btnOpen  = document.getElementById('btnOpenReviewForm_'  + F);
            var btnClose = document.getElementById('btnCloseForm_'       + F);
            var btnCancel= document.getElementById('btnCancelForm_'      + F);
            var formWrap = document.getElementById('rvFormWrap_'         + F);

            function toggleForm() {
                if (!formWrap) return;
                formWrap.classList.toggle('show');
                if (formWrap.classList.contains('show'))
                    formWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            if (btnOpen)   btnOpen.addEventListener('click', toggleForm);
            if (btnClose)  btnClose.addEventListener('click', toggleForm);
            if (btnCancel) btnCancel.addEventListener('click', toggleForm);

            // ── Court picker ──
            var picks = document.querySelectorAll('.rv-cpick_' + F);
            picks.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    picks.forEach(function(b){ b.style.borderColor = ''; b.style.background = ''; });
                    btn.style.borderColor = '#d4a017';
                    btn.style.background  = 'rgba(212,160,23,.08)';
                    var cidEl = document.getElementById('rvCid_' + F);
                    var bidEl = document.getElementById('rvBid_' + F);
                    if (cidEl) cidEl.value = btn.dataset.court;
                    if (bidEl) bidEl.value = btn.dataset.booking;
                });
            });
            // Auto-pick đầu tiên
            if (picks.length > 0) picks[0].click();

            // ── Star labels ──
            var LABELS = ['', 'Rất tệ', 'Tệ', 'Bình thường', 'Tốt', 'Xuất sắc'];
            var mainStars = document.getElementById('mainStars_' + F);
            var starLbl   = document.getElementById('starLbl_'   + F);
            if (mainStars && starLbl) {
                mainStars.querySelectorAll('input').forEach(function(inp) {
                    inp.addEventListener('change', function() {
                        starLbl.textContent = LABELS[+inp.value] || '';
                    });
                });
            }

            // ── Sub-ratings ──
            var formEl = document.getElementById('rvForm_' + F);
            if (formEl) {
                formEl.querySelectorAll('.sri-stars').forEach(function(row) {
                    var stars  = row.querySelectorAll('.sri-star');
                    var hidden = row.closest('.sub-rating-item').querySelector('.sri-hidden');
                    stars.forEach(function(star, i) {
                        star.addEventListener('click', function() {
                            hidden.value = i + 1;
                            stars.forEach(function(s, j){ s.classList.toggle('on', j <= i); });
                        });
                        star.addEventListener('mouseenter', function() {
                            stars.forEach(function(s, j){ s.classList.toggle('on', j <= i); });
                        });
                        star.addEventListener('mouseleave', function() {
                            var v = +hidden.value;
                            stars.forEach(function(s, j){ s.classList.toggle('on', v > 0 && j < v); });
                        });
                    });
                });

                // ── Char count ──
                var ta  = formEl.querySelector('textarea[name="content"]');
                var cnt = formEl.querySelector('.rv-char-cnt');
                if (ta && cnt) {
                    ta.addEventListener('input', function() { cnt.textContent = ta.value.length + '/2000'; });
                }

                // ── Image preview ──
                var imgInput   = document.getElementById('rvImgs_'      + F);
                var imgUpload  = document.getElementById('rvImgUpload_' + F);
                var prevRow    = document.getElementById('rvPrev_'      + F);
                if (imgUpload && imgInput) {
                    imgUpload.addEventListener('click', function() { imgInput.click(); });
                    imgInput.addEventListener('change', function() {
                        prevRow.innerHTML = '';
                        Array.from(imgInput.files).slice(0, 5).forEach(function(f) {
                            var reader = new FileReader();
                            reader.onload = function(e) {
                                var div = document.createElement('div');
                                div.className = 'rv-prev-item';
                                div.innerHTML = '<img src="' + e.target.result + '" />'
                                    + '<button type="button" class="rv-prev-rm" onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>';
                                prevRow.appendChild(div);
                            };
                            reader.readAsDataURL(f);
                        });
                    });
                }

                // ── Submit ──
                formEl.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    var rating = formEl.querySelector('input[name="rating"]:checked');
                    if (!rating) { alert('Vui lòng chọn số sao!'); return; }
                    var cid = document.getElementById('rvCid_' + F).value;
                    if (!cid && picks.length > 1) { alert('Vui lòng chọn sân!'); return; }

                    var submitBtn = document.getElementById('rvSubBtn_' + F);
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

                    var res = await fetch('/Review/Submit', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': getToken() },
                        body: new FormData(formEl)
                    }).then(function(r){ return r.json(); }).catch(function(){ return { success: false, message: 'Lỗi kết nối' }; });

                    if (res.success) {
                        formWrap.classList.remove('show');
                        var toast = document.createElement('div');
                        toast.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;background:#16a34a;color:#fff;padding:.75rem 1.25rem;border-radius:8px;font-size:.84rem;font-weight:700;z-index:9999;display:flex;align-items:center;gap:.5rem;box-shadow:0 4px 16px rgba(0,0,0,.2);';
                        toast.innerHTML = '<i class="bi bi-check-circle-fill"></i> Đánh giá đã ghi nhận! Chờ kiểm duyệt.';
                        document.body.appendChild(toast);
                        setTimeout(function() { toast.style.transition = 'opacity .4s'; toast.style.opacity = '0'; setTimeout(function(){ toast.remove(); }, 400); }, 3500);
                    } else {
                        alert(res.message || 'Gửi thất bại');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="bi bi-send-fill"></i> Gửi đánh giá';
                    }
                });
            }

            // ── Filter tags ──
            var listEl = document.getElementById('rvList_' + F);
            document.querySelectorAll('#reviews .rv-ftag').forEach(function(tag) {
                tag.addEventListener('click', function() {
                    document.querySelectorAll('#reviews .rv-ftag').forEach(function(t){ t.classList.remove('on'); });
                    tag.classList.add('on');
                    var f = tag.dataset.rf;
                    listEl?.querySelectorAll('.rv-card').forEach(function(card) {
                        var show = true;
                        if      (f === '5')        show = +card.dataset.rating === 5;
                        else if (f === '4')        show = +card.dataset.rating === 4;
                        else if (f === '3')        show = +card.dataset.rating === 3;
                        else if (f === 'img')      show = card.dataset.hasImg === '1';
                        else if (f === 'verified') show = card.dataset.verified === '1';
                        card.style.display = show ? '' : 'none';
                    });
                });
            });

            // ── Sort ──
            var sortSel = document.getElementById('rvSortSel_' + F);
            if (sortSel && listEl) {
                sortSel.addEventListener('change', function() {
                    var cards = Array.from(listEl.querySelectorAll('.rv-card'));
                    cards.sort(function(a, b) {
                        if (sortSel.value === 'highest') return +b.dataset.rating   - +a.dataset.rating;
                        if (sortSel.value === 'lowest')  return +a.dataset.rating   - +b.dataset.rating;
                        if (sortSel.value === 'helpful') return +b.dataset.helpful  - +a.dataset.helpful;
                        return 0;
                    });
                    cards.forEach(function(c){ listEl.appendChild(c); });
                });
            }

        }, 0); // end setTimeout(0)

    })();
</script>
