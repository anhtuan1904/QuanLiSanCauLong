@model QuanLiSanCauLong.ViewModels.FacilityDetailsViewModel
@{
    ViewData["Title"] = Model.FacilityName;
}

<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --D3: #2e2010;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.10);
        --G4: rgba(212,160,23,.18);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
        --M: rgba(255,255,255,.38);
        --M2: rgba(255,255,255,.08);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        background: var(--W);
        margin: 0;
    }

    /* BREADCRUMB */
    .bc {
        background: var(--D);
        padding: .75rem 2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        border-bottom: 1px solid var(--G4);
    }

        .bc a {
            color: var(--G2);
            text-decoration: none;
            font-size: .78rem;
            font-weight: 600;
            opacity: .8;
            display: flex;
            align-items: center;
            gap: .35rem;
        }

            .bc a:hover {
                opacity: 1;
            }

    .bc-sep {
        color: var(--M);
        font-size: .65rem;
    }

    .bc-cur {
        color: var(--M);
        font-size: .78rem;
        font-style: italic;
    }

    /* HERO */
    .hero {
        background: var(--D);
        position: relative;
        overflow: hidden;
    }

        .hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 55% 90% at 72% 50%, rgba(212,160,23,.07), transparent 65%);
            pointer-events: none;
        }

    .hero-wrap {
        max-width: 1380px;
        margin: 0 auto;
        padding: 2.2rem 2rem;
        display: grid;
        grid-template-columns: 1fr 370px;
        gap: 2.2rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .fc {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--G4);
    }

        .fc .carousel-item img {
            height: 400px;
            object-fit: cover;
            filter: brightness(.88);
        }

        .fc .carousel-control-prev, .fc .carousel-control-next {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(26,18,9,.72);
            border: 1px solid var(--G4);
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity .25s;
        }

        .fc:hover .carousel-control-prev, .fc:hover .carousel-control-next {
            opacity: 1;
        }

        .fc .carousel-control-prev {
            left: 10px;
        }

        .fc .carousel-control-next {
            right: 10px;
        }

    .carousel-indicators [data-bs-target] {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--G);
        border: 0;
        opacity: .45;
    }

    .carousel-indicators .active {
        opacity: 1;
    }

    .iblock {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .i-pills {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .i-pill {
        background: var(--R);
        color: #fff;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        padding: .24rem .7rem;
        border-radius: 3px;
    }

    .i-open {
        background: rgba(16,185,129,.12);
        color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        padding: .24rem .7rem;
        border-radius: 3px;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .i-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.55rem,2.2vw,2.3rem);
        font-weight: 700;
        color: #fff;
        margin: 0;
        line-height: 1.15;
    }

    .i-addr {
        font-size: .82rem;
        color: var(--M);
        display: flex;
        align-items: flex-start;
        gap: .4rem;
    }

        .i-addr i {
            color: var(--R);
            margin-top: 2px;
            flex-shrink: 0;
        }

    .i-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--G4);
        border: 1px solid var(--G4);
        border-radius: 8px;
        overflow: hidden;
    }

    .istat {
        background: var(--D2);
        padding: .9rem .5rem;
        text-align: center;
        transition: background .18s;
    }

        .istat:hover {
            background: var(--G3);
        }

    .sv {
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--G2);
        line-height: 1;
        margin-bottom: .28rem;
    }

    .sl {
        font-size: .56rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--M);
    }

    .i-desc {
        font-size: .82rem;
        line-height: 1.8;
        color: var(--M);
        border-left: 2px solid var(--G);
        padding-left: .9rem;
    }

    .i-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .27rem .78rem;
        background: var(--M2);
        border: 1px solid var(--G4);
        border-radius: 4px;
        color: rgba(255,255,255,.65);
        font-size: .72rem;
        font-weight: 500;
        transition: all .2s;
    }

        .chip:hover {
            background: var(--G3);
            border-color: var(--G);
            color: var(--G2);
        }

        .chip i {
            color: var(--G);
            font-size: .72rem;
        }

    /* BOOKING SECTION */
    .bsec {
        max-width: 1380px;
        margin: 0 auto;
        padding: 2.2rem 2rem 9rem;
    }

    .tabs {
        display: flex;
        gap: .35rem;
        background: var(--D);
        border: 1px solid var(--G4);
        border-radius: 8px;
        padding: .4rem;
        width: fit-content;
        margin-bottom: 1.6rem;
    }

    .tb {
        padding: .55rem 1.3rem;
        border: none;
        background: none;
        border-radius: 5px;
        font-family: 'Outfit', sans-serif;
        font-size: .8rem;
        font-weight: 600;
        color: var(--M);
        cursor: pointer;
        transition: all .22s;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .tb.on {
            background: linear-gradient(135deg, var(--G), var(--G2));
            color: var(--D);
        }

    .tp {
        display: none;
    }

        .tp.on {
            display: block;
        }

    .bcard {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

    .bcard-hd {
        background: var(--D);
        border-bottom: 1px solid var(--G4);
        padding: 1.1rem 1.6rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .9rem;
    }

    .bcard-title {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
    }

    .bcard-sub {
        font-size: .72rem;
        color: var(--M);
        display: flex;
        align-items: center;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .bcard-bd {
        padding: 1.4rem 1.6rem;
    }

    /* COURT CHIPS */
    .court-grid {
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
        margin-bottom: 1rem;
    }

    .c-chip {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .65rem 1rem;
        border: 1.5px solid var(--S);
        border-radius: 8px;
        cursor: pointer;
        background: #fff;
        transition: all .2s;
        position: relative;
        user-select: none;
    }

        .c-chip:hover {
            border-color: var(--G);
            background: var(--G3);
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(212,160,23,.15);
        }

        .c-chip.active {
            border-color: var(--G);
            background: linear-gradient(135deg, rgba(212,160,23,.14), rgba(245,200,66,.07));
            box-shadow: 0 3px 14px rgba(212,160,23,.22);
        }

    .c-badge {
        width: 34px;
        height: 34px;
        border-radius: 7px;
        background: linear-gradient(135deg, var(--G), var(--G2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: .72rem;
        color: var(--D);
        flex-shrink: 0;
        transition: all .2s;
    }

    .c-chip.active .c-badge {
        background: linear-gradient(135deg, var(--D), var(--D2));
        color: var(--G2);
    }

    .c-name {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: .9rem;
        color: var(--D);
    }

    .c-sub {
        font-size: .64rem;
        color: #8a7560;
        margin-top: .05rem;
    }

    .c-dot {
        position: absolute;
        top: 5px;
        right: 7px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--G);
        display: none;
    }

    .c-chip.active .c-dot {
        display: block;
    }

    .c-info-btn {
        margin-left: .3rem;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1.5px solid rgba(212,160,23,.4);
        background: rgba(212,160,23,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--G);
        font-size: .6rem;
        cursor: pointer;
        transition: all .15s;
        flex-shrink: 0;
    }

        .c-info-btn:hover {
            background: var(--G);
            color: var(--D);
        }

    /* ══ COURT DETAIL PANEL (tích hợp từ Court Details) ══ */
    .court-panel {
        background: var(--D);
        border: 1px solid var(--G4);
        border-radius: 12px;
        margin-bottom: 1.4rem;
        display: none;
        overflow: hidden;
        animation: fadeUp .25s ease;
    }

        .court-panel.show {
            display: block;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Panel header */
    .cp-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.2rem;
        border-bottom: 1px solid var(--G4);
        background: rgba(0,0,0,.2);
        flex-wrap: wrap;
        gap: .5rem;
    }

    .cp-hd-left {
        display: flex;
        align-items: center;
        gap: .55rem;
        flex-wrap: wrap;
    }

    .cp-hd-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #fff;
        font-size: 1rem;
    }

    .cp-pill {
        padding: .2rem .6rem;
        border-radius: 3px;
        font-size: .55rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .cp-pill-type {
        background: var(--R);
        color: #fff;
    }

    .cp-pill-open {
        background: rgba(16,185,129,.15);
        color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
        display: flex;
        align-items: center;
        gap: .25rem;
    }

    .cp-pill-maint {
        background: rgba(201,75,42,.15);
        color: #ef8c72;
        border: 1px solid rgba(201,75,42,.2);
    }

    .cp-btn-close {
        display: flex;
        align-items: center;
        gap: .3rem;
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        color: rgba(255,255,255,.45);
        font-size: .68rem;
        font-weight: 600;
        padding: .4rem .85rem;
        border-radius: 6px;
        cursor: pointer;
        transition: all .15s;
    }

        .cp-btn-close:hover {
            background: rgba(220,38,38,.15);
            border-color: #dc2626;
            color: #dc2626;
        }

    /* Panel body: gallery + info */
    .cp-body {
        display: grid;
        grid-template-columns: 1fr 310px;
    }

    /* Gallery */
    .cp-gallery {
        padding: 1rem 1rem 1rem 1.2rem;
    }

    .cp-car {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--G4);
    }

        .cp-car .carousel-item img {
            height: 255px;
            object-fit: cover;
            filter: brightness(.88);
        }

        .cp-car .carousel-control-prev, .cp-car .carousel-control-next {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(26,18,9,.72);
            border: 1px solid var(--G4);
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity .2s;
        }

        .cp-car:hover .carousel-control-prev, .cp-car:hover .carousel-control-next {
            opacity: 1;
        }

        .cp-car .carousel-control-prev {
            left: 8px;
        }

        .cp-car .carousel-control-next {
            right: 8px;
        }

    .cp-thumbs {
        display: flex;
        gap: .4rem;
        margin-top: .6rem;
        overflow-x: auto;
        padding-bottom: .2rem;
    }

        .cp-thumbs::-webkit-scrollbar {
            height: 3px;
        }

        .cp-thumbs::-webkit-scrollbar-thumb {
            background: var(--G);
            border-radius: 2px;
        }

        .cp-thumbs img {
            width: 56px;
            height: 42px;
            object-fit: cover;
            border-radius: 5px;
            border: 2px solid transparent;
            cursor: pointer;
            flex-shrink: 0;
            transition: border-color .2s;
        }

            .cp-thumbs img.act {
                border-color: var(--G2);
            }

    .cp-no-img {
        height: 200px;
        border-radius: 10px;
        border: 1px solid var(--G4);
        background: rgba(255,255,255,.04);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        color: rgba(255,255,255,.2);
    }

        .cp-no-img i {
            font-size: 2.5rem;
        }

        .cp-no-img span {
            font-size: .7rem;
        }

    /* Info */
    .cp-info {
        padding: 1rem 1.2rem 1rem .8rem;
        display: flex;
        flex-direction: column;
        gap: .8rem;
        border-left: 1px solid var(--G4);
    }

    .cp-stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 1px;
        background: var(--G4);
        border: 1px solid var(--G4);
        border-radius: 7px;
        overflow: hidden;
    }

    .cp-stat {
        background: var(--D2);
        padding: .65rem .4rem;
        text-align: center;
        transition: background .18s;
    }

        .cp-stat:hover {
            background: var(--G3);
        }

    .cp-sv {
        font-weight: 700;
        font-size: .9rem;
        color: var(--G2);
        line-height: 1;
        margin-bottom: .18rem;
    }

    .cp-sl {
        font-size: .5rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--M);
    }

    .cp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .3rem;
    }

    .cp-tag {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        padding: .2rem .55rem;
        background: rgba(255,255,255,.07);
        border: 1px solid var(--G4);
        border-radius: 4px;
        font-size: .64rem;
        color: rgba(255,255,255,.65);
    }

        .cp-tag i {
            color: var(--G);
            font-size: .6rem;
        }

    .cp-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
    }

    .cp-ii {
        display: flex;
        align-items: flex-start;
        gap: .45rem;
        padding: .55rem .65rem;
        background: rgba(255,255,255,.05);
        border: 1px solid var(--G4);
        border-radius: 6px;
    }

    .cp-ii-icon {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        background: linear-gradient(135deg,var(--G),var(--G2));
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .cp-ii-icon i {
            color: var(--D);
            font-size: .65rem;
        }

    .cp-ii-lbl {
        font-size: .55rem;
        color: rgba(255,255,255,.38);
        font-weight: 600;
        letter-spacing: .04em;
        text-transform: uppercase;
        margin-bottom: .08rem;
    }

    .cp-ii-val {
        font-size: .75rem;
        font-weight: 700;
        color: #fff;
    }

    .cp-cta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .6rem;
        flex-wrap: wrap;
        padding: .75rem .9rem;
        background: rgba(212,160,23,.06);
        border: 1px solid var(--G4);
        border-radius: 8px;
        margin-top: auto;
    }

    .cp-price {
        font-family: 'Outfit',sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--G2);
        line-height: 1;
    }

        .cp-price span {
            font-size: .65rem;
            color: var(--M);
            font-weight: 400;
        }

    .cp-btn-detail {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .5rem 1rem;
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
        border: none;
        border-radius: 6px;
        font-family: 'Outfit',sans-serif;
        font-size: .74rem;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        white-space: nowrap;
    }

        .cp-btn-detail:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
            filter: brightness(1.05);
            color: var(--D);
        }

    /* Description full-width */
    .cp-article {
        padding: .9rem 1.4rem 1.1rem;
        border-top: 1px solid var(--G4);
        background: rgba(0,0,0,.1);
    }

    .cp-article-title {
        font-family: 'Playfair Display',serif;
        font-size: .88rem;
        font-weight: 700;
        color: var(--G2);
        margin: 0 0 .55rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .cp-article-body {
        font-size: .82rem;
        line-height: 1.85;
        color: rgba(255,255,255,.48);
    }

        .cp-article-body h2 {
            font-size: .95rem;
            font-weight: 700;
            color: rgba(255,255,255,.8);
            margin: 1rem 0 .4rem;
        }

        .cp-article-body h3 {
            font-size: .88rem;
            font-weight: 700;
            color: rgba(255,255,255,.7);
            margin: .8rem 0 .35rem;
        }

        .cp-article-body p {
            margin: 0 0 .7rem;
        }

        .cp-article-body img {
            max-width: 100%;
            border-radius: 6px;
            margin: .8rem 0;
            border: 1px solid var(--G4);
            display: block;
        }

        .cp-article-body blockquote {
            border-left: 2px solid var(--G);
            padding: .6rem .9rem;
            background: rgba(212,160,23,.06);
            border-radius: 0 5px 5px 0;
            margin: .8rem 0;
            color: rgba(255,255,255,.42);
            font-style: italic;
        }

        .cp-article-body ul, .cp-article-body ol {
            padding-left: 1.2rem;
            margin: 0 0 .7rem;
        }

        .cp-article-body li {
            margin-bottom: .3rem;
        }

    /* WEEK NAV */
    .week-nav {
        display: flex;
        align-items: center;
        gap: .7rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
    }

    .wk-arr {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1.5px solid var(--S);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #8a7560;
        transition: all .2s;
        font-size: .8rem;
    }

        .wk-arr:hover {
            border-color: var(--G);
            color: var(--G);
            background: var(--G3);
        }

    .wk-range {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: .9rem;
        color: var(--D);
    }

    .wk-today {
        padding: .35rem .9rem;
        background: var(--D);
        color: var(--G2);
        border: none;
        border-radius: 6px;
        font-family: 'Outfit', sans-serif;
        font-size: .72rem;
        font-weight: 700;
        cursor: pointer;
    }

        .wk-today:hover {
            background: var(--D2);
        }

    .date-jump {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-left: auto;
    }

        .date-jump label {
            font-size: .72rem;
            color: #8a7560;
            font-weight: 600;
            white-space: nowrap;
        }

        .date-jump input[type=date] {
            padding: .38rem .75rem;
            border: 1.5px solid var(--S);
            border-radius: 6px;
            font-family: 'Outfit', sans-serif;
            font-size: .8rem;
            color: var(--D);
            outline: none;
            cursor: pointer;
            transition: border-color .2s;
        }

            .date-jump input[type=date]:focus {
                border-color: var(--G);
            }

    /* LEGEND */
    .leg {
        display: flex;
        gap: 1.4rem;
        margin-bottom: 1.1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--S);
        align-items: center;
        flex-wrap: wrap;
    }

    .li {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .72rem;
        color: #8c7a68;
        font-weight: 500;
    }

    .ld {
        width: 12px;
        height: 12px;
        border-radius: 3px;
        border: 1.5px solid;
    }

        .ld.a {
            background: #fff;
            border-color: var(--S);
        }

        .ld.s {
            background: var(--D);
            border-color: var(--G);
        }

        .ld.b {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .ld.p {
            background: #f5f5f5;
            border-color: #d1d5db;
        }

    .leg-tip {
        margin-left: auto;
        font-size: .68rem;
        color: #aaa;
        font-style: italic;
    }

    /* GRID */
    .wgrid-wrap {
        overflow-x: auto;
        border-radius: 8px;
        border: 1px solid var(--S);
    }

        .wgrid-wrap::-webkit-scrollbar {
            height: 5px;
        }

        .wgrid-wrap::-webkit-scrollbar-track {
            background: var(--S);
        }

        .wgrid-wrap::-webkit-scrollbar-thumb {
            background: var(--G);
            border-radius: 3px;
        }

    .wgrid {
        display: grid;
        min-width: 720px;
    }

    .wg-head {
        display: grid;
        grid-template-columns: 72px repeat(7,1fr);
        background: var(--D);
    }

    .wg-h0 {
        padding: .65rem .3rem;
    }

    .wg-hday {
        padding: .65rem .3rem;
        text-align: center;
        border-left: 1px solid rgba(255,255,255,.07);
    }

    .wg-dn {
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: rgba(255,255,255,.45);
    }

    .wg-dd {
        font-size: .9rem;
        font-weight: 700;
        color: var(--G2);
        margin-top: .1rem;
    }

    .wg-hday.today .wg-dn {
        color: var(--G);
    }

    .wg-hday.today .wg-dd {
        color: var(--G);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .wg-acts {
        display: grid;
        grid-template-columns: 72px repeat(7,1fr);
        background: #fafaf8;
        border-bottom: 1px solid var(--S);
    }

    .wg-a0 {
        padding: .28rem .3rem;
        font-size: .58rem;
        color: #bbb;
