            <button class="btn-book" onclick="goBook()"><i class="bi bi-check-circle-fill"></i> ĐẶT SÂN NGAY</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ══════════════════════════════════════════════
        // SERVER DATA — build from Razor model
        // ══════════════════════════════════════════════
        var FAC = @Model.FacilityId;
        var COURTS_DATA = {};

        @foreach (var court in Model.Courts)
        {
                var cJson = System.Text.Json.JsonSerializer.Serialize(new
                {
                        id = court.CourtId,
                        name = court.CourtNumber ?? "",
                        imagePath = (string?)null,
                        courtType = (string?)null,
                        surfaceType = (string?)null,
                        floorNumber = (string?)null,
                        hasLighting = false,
                        hasAC = false,
                        description = (string?)null,
                        slots = court.Slots.Select(s => new
                        {
                                st = s.StartTime.ToString(@"hh\:mm"),
                                et = s.EndTime.ToString(@"hh\:mm"),
                                price = (int)s.Price,
                                isBooked = s.IsBooked
                        }).ToArray()
                });
                @:COURTS_DATA[@court.CourtId] = @Html.Raw(cJson);
        }

        var TODAY_STR    = '@DateTime.Today.ToString("yyyy-MM-dd")';
        var SEL_DATE_STR = '@Model.SelectedDate.ToString("yyyy-MM-dd")';

        // ══════════════════════════════════════════════
        // STATE
        // ══════════════════════════════════════════════
        var activeCid = null;
        var weekMon   = null;
        var sel       = [];   // [{key, cid, cname, date, st, et, price, el}]

        // ══════════════════════════════════════════════
        // DATE UTILS
        // ══════════════════════════════════════════════
        function parseLocal(s){ var p=s.split('-'); return new Date(+p[0],+p[1]-1,+p[2]); }
        function toISO(d){ return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate()); }
        function p2(n){ return String(n).padStart(2,'0'); }
        function addDays(d,n){ var r=new Date(d); r.setDate(r.getDate()+n); return r; }
        function getMon(d){ var c=new Date(d),dow=c.getDay(); c.setDate(c.getDate()-(dow===0?6:dow-1)); return c; }
        function fmtD(d){ return p2(d.getDate())+'/'+p2(d.getMonth()+1); }
        var DSHORT=['T2','T3','T4','T5','T6','T7','CN'];

        // ══════════════════════════════════════════════
        // INIT
        // ══════════════════════════════════════════════
        document.addEventListener('DOMContentLoaded', function(){
            // Tabs
            document.querySelectorAll('.tb').forEach(function(b){
                b.addEventListener('click', function(){
                    document.querySelectorAll('.tb').forEach(x=>x.classList.remove('on'));
                    document.querySelectorAll('.tp').forEach(x=>x.classList.remove('on'));
                    this.classList.add('on');
                    document.getElementById(this.dataset.tab).classList.add('on');
                });
            });
            // Carousel
            var fc=document.getElementById('fc');
            if(fc) new bootstrap.Carousel(fc,{interval:3500,wrap:true});
            // Week init
            weekMon = getMon(parseLocal(SEL_DATE_STR));
            updateWkLabel();
            renderGrid();
        });

        // ══════════════════════════════════════════════
        // COURT SELECTION
        // ══════════════════════════════════════════════
        function selectCourt(cid, evt){
            if(evt) evt.stopPropagation();
            if(activeCid===cid){
                activeCid=null;
                document.querySelectorAll('.c-chip').forEach(c=>c.classList.remove('active'));
                document.getElementById('courtPanel').classList.remove('show');
                document.getElementById('calSub').innerHTML='<i class="bi bi-arrow-up-circle"></i> Vui lòng chọn sân ở bước 1';
                renderGrid(); return;
            }
            activeCid=cid;
            document.querySelectorAll('.c-chip').forEach(c=>c.classList.remove('active'));
            document.getElementById('chip-'+cid).classList.add('active');
            // Keep only selections for this court
            sel=sel.filter(function(s){ if(s.cid!==cid){ if(s.el) s.el.classList.remove('sel'); return false; } return true; });
            refreshBar();
            showCourtPanel(cid);
            var cd=COURTS_DATA[cid];
            document.getElementById('calSub').innerHTML='<i class="bi bi-grid-3x3-gap" style="color:var(--G)"></i> Lịch sân: <strong style="color:var(--G2)">'+(cd?cd.name:'')+'</strong>';
            renderGrid();
        }

        function showCourtPanel(cid){
            var cd=COURTS_DATA[cid]; if(!cd) return;
            var tags=[];
            if(cd.courtType)   tags.push({i:'bi-house',         t:cd.courtType==='Indoor'?'Trong nhà':'Ngoài trời'});
            if(cd.surfaceType) tags.push({i:'bi-layers',         t:'Sàn '+cd.surfaceType});
            if(cd.floorNumber) tags.push({i:'bi-building',       t:'Tầng '+cd.floorNumber});
            if(cd.hasLighting) tags.push({i:'bi-lightbulb-fill', t:'Đèn chiếu sáng'});
            if(cd.hasAC)       tags.push({i:'bi-wind',           t:'Điều hoà'});
            if(!tags.length)   tags.push({i:'bi-grid-3x3-gap',   t:'Sân cầu lông'});
            var imgH=cd.imagePath
                ?'<img class="cp-img" src="'+cd.imagePath+'" alt="'+cd.name+'">'
                :'<div class="cp-img-ph"><i class="bi bi-grid-3x3-gap"></i></div>';
            var tagH=tags.map(function(t){return '<span class="cp-tag"><i class="bi '+t.i+'"></i>'+t.t+'</span>';}).join('');
            var descH=cd.description?'<div class="cp-desc">'+cd.description+'</div>':'';
            var panel=document.getElementById('courtPanel');
            panel.innerHTML=imgH+'<div class="cp-body"><div class="cp-name">'+cd.name+'</div><div class="cp-tags">'+tagH+'</div>'+descH+'</div>'+
                '<div class="cp-close" onclick="document.getElementById(\'courtPanel\').classList.remove(\'show\')" title="Đóng"><i class="bi bi-x-lg"></i></div>';
            panel.classList.add('show');
        }

        function openCourtModal(cid, evt){
            if(evt) evt.stopPropagation();
            var cd=COURTS_DATA[cid]; if(!cd) return;
            var ex=document.getElementById('cmModal'); if(ex) ex.remove();
            var tags=[];
            if(cd.courtType)   tags.push({i:'bi-house',         t:cd.courtType==='Indoor'?'Trong nhà':'Ngoài trời'});
            if(cd.surfaceType) tags.push({i:'bi-layers',         t:'Sàn '+cd.surfaceType});
            if(cd.floorNumber) tags.push({i:'bi-building',       t:'Tầng '+cd.floorNumber});
            if(cd.hasLighting) tags.push({i:'bi-lightbulb-fill', t:'Đèn chiếu sáng'});
            if(cd.hasAC)       tags.push({i:'bi-wind',           t:'Điều hoà'});
            var imgH=cd.imagePath?'<img class="cm-img" src="'+cd.imagePath+'" alt="'+cd.name+'">'
                :'<div class="cm-img-ph"><i class="bi bi-grid-3x3-gap"></i></div>';
            var tagH=tags.map(function(t){return '<div class="cm-tag"><i class="bi '+t.i+'"></i>'+t.t+'</div>';}).join('');
            var freeC=(cd.slots||[]).filter(function(s){return !s.isBooked;}).length;
            var descH=cd.description?'<p class="cm-desc">'+cd.description+'</p>':'<p class="cm-desc" style="color:#ccc;font-style:italic">Chưa có mô tả chi tiết.</p>';
            var html='<div id="cmModal" class="cm-ov" onclick="if(event.target===this)this.remove()">'+
                '<div class="cm-box">'+
                    '<div class="cm-hd"><span class="cm-title">Chi tiết sân — '+cd.name+'</span>'+
                    '<button class="cm-close" onclick="document.getElementById(\'cmModal\').remove()"><i class="bi bi-x-lg"></i></button></div>'+
                    imgH+
                    '<div class="cm-bd">'+
                        (tagH?'<div class="cm-tags">'+tagH+'</div>':'')+
                        '<div style="margin-bottom:.8rem;font-size:.8rem;color:#8a7560"><i class="bi bi-clock me-1" style="color:var(--G)"></i>'+freeC+' khung trống hôm nay</div>'+
                        descH+
                    '</div>'+
                    '<div class="cm-ft"><button class="btn-cancel-sm" onclick="document.getElementById(\'cmModal\').remove()">Đóng</button></div>'+
                '</div></div>';
            document.body.insertAdjacentHTML('beforeend', html);
        }

        // ══════════════════════════════════════════════
        // WEEK NAVIGATION
        // ══════════════════════════════════════════════
        function navWeek(dir){ weekMon=addDays(weekMon,dir*7); updateWkLabel(); renderGrid(); }
        function goToday(){ weekMon=getMon(parseLocal(TODAY_STR)); updateWkLabel(); renderGrid(); }
        function jumpTo(s){ if(!s) return; weekMon=getMon(parseLocal(s)); updateWkLabel(); renderGrid(); }
        function updateWkLabel(){
            var sun=addDays(weekMon,6);
            document.getElementById('wkRange').textContent=
                fmtD(weekMon)+'/'+weekMon.getFullYear().toString().slice(2)+' – '+fmtD(sun)+'/'+sun.getFullYear().toString().slice(2);
        }

        // ══════════════════════════════════════════════
        // RENDER GRID
        // ══════════════════════════════════════════════
        function renderGrid(){
            var nc=document.getElementById('noCourt');
            var gw=document.getElementById('wgridWrap');
            if(!activeCid){
                nc.style.display='block'; gw.style.display='none';
                document.getElementById('wgrid').innerHTML=''; return;
            }
            nc.style.display='none'; gw.style.display='block';

            var cd      = COURTS_DATA[activeCid] || {};
            var rawSl   = cd.slots || [];
            var today   = parseLocal(TODAY_STR);

            // build 7 days Mon→Sun
            var days=[];
            for(var i=0;i<7;i++) days.push(addDays(weekMon,i));

            // build time list
            var times=[];
            if(rawSl.length>0){
                var seen={};
                rawSl.forEach(function(s){ if(!seen[s.st]){seen[s.st]=true; times.push({st:s.st,et:s.et,price:s.price});} });
                times.sort(function(a,b){return a.st.localeCompare(b.st);});
            } else {
                for(var h=6;h<22;h++) times.push({st:p2(h)+':00',et:p2(h+1)+':00',price:0});
            }

            // ── HEADER ──
            var H='<div class="wg-head"><div class="wg-h0"></div>';
            days.forEach(function(d,i){
                var iso=toISO(d), isTod=iso===TODAY_STR;
                H+='<div class="wg-hday'+(isTod?' today':'')+'"><div class="wg-dn">'+DSHORT[i]+'</div><div class="wg-dd">'+fmtD(d)+'</div></div>';
            });
            H+='</div>';

            // ── ACTION ROW ──
            H+='<div class="wg-acts"><div class="wg-a0">Nhanh</div>';
            days.forEach(function(d){
                var iso=toISO(d), isPast=d<today;
                H+='<div class="wg-acol">'+(isPast?'':'<button class="da-btn da-sel" onclick="selDay(\''+iso+'\')">Tất</button><button class="da-btn da-clr" onclick="clrDay(\''+iso+'\')">Xóa</button>')+'</div>';
            });
            H+='</div>';

            // ── BODY ──
            H+='<div class="wg-body">';
            times.forEach(function(slot){
                H+='<div class="wg-time"><span>'+slot.st+'<br><span style="font-size:.52rem;color:#c0a880;font-weight:400">'+slot.et+'</span></span></div>';
                days.forEach(function(d){
                    var iso=toISO(d), isPast=d<today;
                    var key=activeCid+'-'+iso+'-'+slot.st;
                    // booked status: only known for selected date from server
                    var booked=false;
                    if(iso===SEL_DATE_STR && rawSl.length>0){
                        var srv=rawSl.find(function(s){return s.st===slot.st;});
                        if(srv) booked=srv.isBooked;
                    }
                    var isSel=!!sel.find(function(s){return s.key===key;});
                    var cls='wg-slot';
                    if(isPast) cls+=' past';
                    else if(booked) cls+=' bk';
                    else if(isSel) cls+=' sel';

                    var inner='';
                    if(isPast) inner='<span class="past-lbl">Đã qua</span>';
                    else if(booked) inner='<span class="bk-lbl">Đã đặt</span>';
                    else inner='<span class="st-t">'+slot.st+'–'+slot.et+'</span>'+(slot.price>0?'<span class="st-p">'+Math.round(slot.price/1000)+'k</span>':'');

                    var click=(isPast||booked)?'':' onclick="tgl(\''+key+'\','+activeCid+',\''+slot.st+'\',\''+slot.et+'\','+slot.price+',\''+iso+'\')"';
                    H+='<div class="wg-cell"><div id="'+key+'" class="'+cls+'" data-date="'+iso+'" data-st="'+slot.st+'"'+click+'>'+inner+'</div></div>';
                });
            });
            H+='</div>';

            document.getElementById('wgrid').innerHTML=H;
            // restore sel states
            sel.forEach(function(s){ var el=document.getElementById(s.key); if(el){s.el=el; el.classList.add('sel');} });
        }

        // ══════════════════════════════════════════════
        // SLOT TOGGLE
        // ══════════════════════════════════════════════
        function tgl(key, cid, st, et, price, dateStr){
            var el=document.getElementById(key);
            if(!el||el.classList.contains('bk')||el.classList.contains('past')) return;
            var idx=sel.findIndex(function(s){return s.key===key;});
            if(idx>-1){ sel.splice(idx,1); el.classList.remove('sel'); }
            else {
                var cd=COURTS_DATA[cid];
                sel.push({key:key,cid:cid,cname:cd?cd.name:'',date:dateStr,st:st,et:et,price:price,el:el});
                el.classList.add('sel');
            }
            refreshBar();
        }

        function selDay(dateStr){
            var cells=document.querySelectorAll('.wg-slot[data-date="'+dateStr+'"]');
            cells.forEach(function(el){
                if(el.classList.contains('bk')||el.classList.contains('past')||el.classList.contains('sel')) return;
                var key=el.id, st=el.dataset.st;
                var cd=COURTS_DATA[activeCid];
                var srv=cd?(cd.slots||[]).find(function(s){return s.st===st;}):null;
                sel.push({key:key,cid:activeCid,cname:cd?cd.name:'',date:dateStr,
                    st:st, et:srv?srv.et:p2(parseInt(st)+1)+':00', price:srv?srv.price:0, el:el});
                el.classList.add('sel');
            });
            refreshBar();
        }

        function clrDay(dateStr){
            sel=sel.filter(function(s){
                if(s.date===dateStr&&s.cid===activeCid){ if(s.el) s.el.classList.remove('sel'); return false; }
                return true;
            });
            refreshBar();
        }

        function clearAll(){
            sel.forEach(function(s){if(s.el) s.el.classList.remove('sel');}); sel=[];
            refreshBar();
        }

        // ══════════════════════════════════════════════
        // PAY BAR
        // ══════════════════════════════════════════════
        function refreshBar(){
            var bar=document.getElementById('payBar');
            var cnt=sel.length, total=sel.reduce(function(a,s){return a+s.price;},0);
            if(cnt>0){
                bar.classList.add('show');
                document.getElementById('payLbl').textContent='Đã chọn '+cnt+' khung giờ';
                document.getElementById('payTot').textContent=total.toLocaleString('vi-VN')+'đ';
                var groups={};
                sel.forEach(function(s){ if(!groups[s.date]) groups[s.date]=[]; groups[s.date].push(s.cname+' '+s.st+'–'+s.et); });
                document.getElementById('payMeta').textContent=Object.keys(groups).map(function(k){return k+': '+groups[k].join(', ');}).join(' | ');
            } else { bar.classList.remove('show'); }
        }

        // ══════════════════════════════════════════════
        // BOOKING
        // ══════════════════════════════════════════════
        function goBook(){
            if(!sel.length) return;
            if(sel.length===1){
                var s=sel[0];
                window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+s.st+'&endTime='+s.et;
                return;
            }
            showMultiModal();
        }

        function showMultiModal(){
            var ex=document.getElementById('mmodal'); if(ex) ex.remove();
            var items=sel.map(function(s,i){
                return '<div class="ov-item">'+
                    '<div><div class="ov-item-name">'+s.cname+' · '+s.date+'</div><div class="ov-item-sub">'+s.st+' – '+s.et+'</div></div>'+
                    '<div class="ov-item-right"><span class="ov-price">'+s.price.toLocaleString('vi-VN')+'đ</span>'+
                    '<button class="ov-book" onclick="bookOne('+i+')">Đặt ngay</button></div></div>';
            }).join('');
            document.body.insertAdjacentHTML('beforeend',
                '<div id="mmodal" class="ov" onclick="if(event.target===this)this.remove()">'+
                '<div class="ov-box">'+
                '<div class="ov-hd"><span class="ov-title">Chọn khung để đặt ('+sel.length+')</span>'+
                '<button class="ov-close" onclick="document.getElementById(\'mmodal\').remove()"><i class="bi bi-x-lg"></i></button></div>'+
                '<div style="max-height:380px;overflow-y:auto">'+items+'</div>'+
                '<div class="ov-ft"><button class="btn-cancel-sm" onclick="document.getElementById(\'mmodal\').remove()">Đóng</button></div>'+
                '</div></div>');
        }

        function bookOne(idx){
            var s=sel[idx];
            window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+s.st+'&endTime='+s.et;
        }
    </script>
}
