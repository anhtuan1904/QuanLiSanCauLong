</style>

<!-- BREADCRUMB -->
<div class="bc">
    <a href="@Url.Action("Index", "Facility")"><i class="bi bi-house"></i> Trang chủ</a>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <a href="@Url.Action("Index", "Facility")">Cơ sở</a>
    <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
    <span class="bc-cur">@Model.FacilityName</span>
</div>

<!-- HERO -->
<div class="hero">
    <div class="hero-wrap">
        <div id="fc" class="carousel slide fc" data-bs-ride="carousel">
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.ImageUrls.Count; i++)
                {
                    <button type="button" data-bs-target="#fc" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                }
            </div>
            <div class="carousel-inner">
                @if (!Model.ImageUrls.Any())
                {
                    <div class="carousel-item active">
                        <div style="height:400px;background:linear-gradient(135deg,#231a0e,#1a1209);display:flex;align-items:center;justify-content:center">
                            <i class="bi bi-building" style="font-size:5rem;color:rgba(212,160,23,.18)"></i>
                        </div>
                    </div>
                }
                @for (int i = 0; i < Model.ImageUrls.Count; i++)
                {
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@Model.ImageUrls[i]" class="d-block w-100" alt="@Model.FacilityName" />
                    </div>
                }
            </div>
            @if (Model.ImageUrls.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#fc" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
                <button class="carousel-control-next" type="button" data-bs-target="#fc" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
            }
        </div>

        <div class="iblock">
            <div class="i-pills">
                <div class="i-pill">Badminton Court</div>
                <div class="i-open"><i class="bi bi-circle-fill" style="font-size:.38rem"></i> Đang mở cửa</div>
            </div>
            <h1 class="i-title">@Model.FacilityName</h1>
            <div class="i-addr"><i class="bi bi-geo-alt-fill"></i>@Model.Address@(!string.IsNullOrEmpty(Model.District) ? ", " + Model.District : "")@(!string.IsNullOrEmpty(Model.City) ? ", " + Model.City : "")</div>
            <div class="i-stats">
                <div class="istat"><div class="sv">@(Model.MinPrice > 0 ? (Model.MinPrice / 1000).ToString("0") + "k" : "---")</div><div class="sl">Giá từ</div></div>
                <div class="istat"><div class="sv"><i class="bi bi-star-fill" style="font-size:.7rem;color:var(--G)"></i> @(Model.AverageRating.HasValue? Model.AverageRating.Value.ToString("0.0") : "4.8")</div><div class="sl">Đánh giá</div></div>
                <div class="istat"><div class="sv">@Model.TotalCourts</div><div class="sl">Số sân</div></div>
                <div class="istat"><div class="sv" style="font-size:.8rem">@(Model.OpenTime?.ToString(@"hh\:mm") ?? "06")–@(Model.CloseTime?.ToString(@"hh\:mm") ?? "23")</div><div class="sl">Giờ mở</div></div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="i-desc">@Model.Description</div>
            }
            <div class="i-chips">
                @foreach (var a in Model.Amenities.Where(x => x.IsAvailable).Take(6))
                {
                    <div class="chip"><i class="bi bi-check-circle-fill"></i> @a.AmenityName</div>
                }
                @if (!Model.Amenities.Any())
                {
                    <div class="chip"><i class="bi bi-wifi"></i> Wifi</div>
                    <div class="chip"><i class="bi bi-car-front"></i> Bãi xe</div>
                    <div class="chip"><i class="bi bi-cup-hot"></i> Canteen</div>
                    <div class="chip"><i class="bi bi-droplet"></i> Phòng tắm</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- BOOKING SECTION -->
<div class="bsec">
    <div class="tabs">
        <button class="tb on" data-tab="t-book"><i class="bi bi-calendar-check"></i> Đặt sân</button>
        <button class="tb" data-tab="t-hist"><i class="bi bi-clock-history"></i> Lịch của tôi</button>
    </div>

    <!-- TAB: Booking -->
    <div class="tp on" id="t-book">
        @if (!Model.Courts.Any())
        {
            <div class="bcard"><div class="bcard-bd"><div class="empty-blk"><i class="bi bi-building-x"></i><p>Cơ sở chưa có sân hoặc chưa cấu hình khung giờ</p></div></div></div>
        }
        else
        {
            <!-- STEP 1 -->
            <div class="bcard">
                <div class="bcard-hd">
                    <div class="bcard-title">Bước 1 — Chọn sân</div>
                    <div class="bcard-sub">
                        <i class="bi bi-hand-index"></i> Nhấn chip sân để xem ảnh, thông tin &amp; lịch &nbsp;·&nbsp;
                        <i class="bi bi-info-circle"></i> Nhấn <strong style="color:var(--G2)">ⓘ</strong> để xem popup đầy đủ
                    </div>
                </div>
                <div class="bcard-bd">
                    <div class="court-grid" id="courtGrid">
                        @foreach (var court in Model.Courts)
                        {
                            var raw = court.CourtNumber ?? "?";
                            var abbr = raw.Length >= 2 ? raw.Substring(0, 2).ToUpper() : raw.ToUpper();
                            var total = court.Slots.Count();
                            var free = court.Slots.Count(s => !s.IsBooked);
                            <div class="c-chip" id="chip-@court.CourtId" onclick="selectCourt(@court.CourtId,event)">
                                <div class="c-badge">@abbr</div>
                                <div>
                                    <div class="c-name">@raw</div>
                                    <div class="c-sub">@free/@total khung trống hôm nay</div>
                                </div>
                                <div class="c-info-btn" onclick="openCourtModal(@court.CourtId,event)" title="Xem chi tiết đầy đủ">
                                    <i class="bi bi-info-lg"></i>
                                </div>
                                <div class="c-dot"></div>
                            </div>
                        }
                    </div>

                    <!-- ══ COURT DETAIL PANEL ══ -->
                    <div class="court-panel" id="courtPanel"></div>
                </div>
            </div>

            <!-- STEP 2 -->
            <div class="bcard">
                <div class="bcard-hd">
                    <div class="bcard-title">Bước 2 — Chọn ngày &amp; Khung giờ</div>
                    <div class="bcard-sub" id="calSub"><i class="bi bi-arrow-up-circle"></i> Vui lòng chọn sân ở bước 1</div>
                </div>
                <div class="bcard-bd">
                    <div class="week-nav">
                        <button class="wk-arr" onclick="navWeek(-1)"><i class="bi bi-chevron-left"></i></button>
                        <span class="wk-range" id="wkRange">—</span>
                        <button class="wk-arr" onclick="navWeek(1)"><i class="bi bi-chevron-right"></i></button>
                        <button class="wk-today" onclick="goToday()"><i class="bi bi-calendar-check me-1"></i>Hôm nay</button>
                        <div class="date-jump">
                            <label><i class="bi bi-search"></i> Nhảy đến:</label>
                            <input type="date" id="jumpDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" onchange="jumpTo(this.value)" />
                        </div>
                    </div>
                    <div class="leg">
                        <div class="li"><div class="ld a"></div> Trống</div>
                        <div class="li"><div class="ld s"></div> Đã chọn</div>
                        <div class="li"><div class="ld b"></div> Đã đặt</div>
                        <div class="li"><div class="ld p"></div> Đã qua</div>
                        <span class="leg-tip"><i class="bi bi-hand-index me-1"></i>Chọn nhiều khung · Nút "Tất" chọn cả ngày</span>
                    </div>
                    <div id="noCourt" class="no-court-msg">
                        <i class="bi bi-arrow-up-circle"></i>
                        <p>Hãy chọn sân ở <strong>Bước 1</strong> để xem lịch khung giờ</p>
                    </div>
                    <div class="wgrid-wrap" id="wgridWrap" style="display:none">
                        <div id="wgrid" class="wgrid"></div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- TAB: History -->
    <div class="tp" id="t-hist">
        <div class="bcard">
            <div class="bcard-hd">
                <div class="bcard-title">Lịch đặt sân của tôi</div>
                <a asp-controller="Booking" asp-action="MyBookings" style="font-size:.76rem;color:var(--G2);text-decoration:none">Xem tất cả <i class="bi bi-arrow-right"></i></a>
            </div>
            @if (Model.UserBookings != null && Model.UserBookings.Any())
            {
                <div style="overflow-x:auto">
                    <table class="htbl">
                        <thead><tr><th>Sân</th><th>Ngày</th><th>Giờ</th><th>Trạng thái</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var b in Model.UserBookings)
                            {
                                <tr>
                                    <td><strong>@b.CourtName</strong></td>
                                    <td>@b.Date.ToString("dd/MM/yyyy")</td>
                                    <td>@b.Time</td>
                                    <td><span class="sb @b.Status.ToLower()">@b.Status</span></td>
                                    <td><a asp-controller="Booking" asp-action="Details" asp-route-id="@b.BookingId" style="font-size:.76rem;color:var(--G);text-decoration:none">Chi tiết →</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-blk"><i class="bi bi-calendar-x"></i><p>Bạn chưa có lịch đặt nào</p></div>
            }
        </div>
    </div>
</div>

<!-- PAY BAR -->
<div id="payBar" class="paybar">
    <div class="pay-in">
        <div>
            <div class="pay-lbl" id="payLbl">Đã chọn 0 khung giờ</div>
            <div class="pay-tot" id="payTot">0đ</div>
            <div class="pay-meta" id="payMeta"></div>
        </div>
        <div class="pay-acts">
            <button class="btn-clr" onclick="clearAll()" title="Bỏ chọn tất cả"><i class="bi bi-x-lg"></i></button>
            <button class="btn-book" onclick="goBook()"><i class="bi bi-check-circle-fill"></i> ĐẶT SÂN NGAY</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ══════════════════════════════════════════════════════════════
        // DATA từ Razor — bổ sung đầy đủ: ảnh sân, mô tả, loại sân…
        // ══════════════════════════════════════════════════════════════
        var FAC = @Model.FacilityId;
        var COURTS_DATA = {};

        @foreach (var court in Model.Courts)
        {
                // Tập hợp ảnh: ưu tiên CourtImages, fallback ImagePath
                var imgs = (court.CourtImages?
                        .OrderBy(i => i.IsPrimary ? 0 : 1)
                        .ThenBy(i => i.DisplayOrder)
                        .Select(i => i.ImagePath)
                        .ToList()) ?? new List<string>();
                if (!imgs.Any() && !string.IsNullOrEmpty(court.ImagePath))
                        imgs.Add(court.ImagePath);

                var cJson = System.Text.Json.JsonSerializer.Serialize(new
                {
                        id = court.CourtId,
                        name = court.CourtNumber ?? "",
                        images = imgs,
                        courtType = court.CourtType,
                        courtTypeLabel = court.CourtTypeLabel,
                        surfaceType = court.SurfaceType,
                        surfaceTypeLabel = court.SurfaceTypeLabel,
                        floorNumber = court.FloorNumber,
                        hasLighting = court.HasLighting,
                        hasAC = court.HasAC,
                        hourlyRate = court.HourlyRate,
                        status = court.Status,
                        statusLabel = court.StatusLabel,
                        description = court.Description,
                        detailUrl = Url.Action("Details", "Court", new { id = court.CourtId }),
                        slots = court.Slots.Select(s => new
                        {
                                st = s.StartTime.ToString(@"hh\:mm"),
                                et = s.EndTime.ToString(@"hh\:mm"),
                                price = (int)s.Price,
                                isBooked = s.IsBooked
                        }).ToArray()
                });
                @:COURTS_DATA[@court.CourtId] = @Html.Raw(cJson);
        }

        var TODAY_STR    = '@DateTime.Today.ToString("yyyy-MM-dd")';
        var SEL_DATE_STR = '@Model.SelectedDate.ToString("yyyy-MM-dd")';

        // ── State ──
        var activeCid = null, weekMon = null, sel = [];

        // ── Date utils ──
        function parseLocal(s){ var p=s.split('-'); return new Date(+p[0],+p[1]-1,+p[2]); }
        function toISO(d){ return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate()); }
        function p2(n){ return String(n).padStart(2,'0'); }
        function addDays(d,n){ var r=new Date(d); r.setDate(r.getDate()+n); return r; }
        function getMon(d){ var c=new Date(d),dow=c.getDay(); c.setDate(c.getDate()-(dow===0?6:dow-1)); return c; }
        function fmtD(d){ return p2(d.getDate())+'/'+p2(d.getMonth()+1); }
        var DSHORT=['T2','T3','T4','T5','T6','T7','CN'];

        // ── Init ──
        document.addEventListener('DOMContentLoaded',function(){
            document.querySelectorAll('.tb').forEach(function(b){
                b.addEventListener('click',function(){
                    document.querySelectorAll('.tb').forEach(x=>x.classList.remove('on'));
                    document.querySelectorAll('.tp').forEach(x=>x.classList.remove('on'));
                    this.classList.add('on');
                    document.getElementById(this.dataset.tab).classList.add('on');
                });
            });
            var fc=document.getElementById('fc');
            if(fc) new bootstrap.Carousel(fc,{interval:3500,wrap:true});
            weekMon=getMon(parseLocal(SEL_DATE_STR));
            updateWkLabel(); renderGrid();
        });

        // ══════════════════════════════════════════════════════════════
        // COURT SELECTION
        // ══════════════════════════════════════════════════════════════
        function selectCourt(cid,evt){
            if(evt) evt.stopPropagation();
            if(activeCid===cid){
                activeCid=null;
                document.querySelectorAll('.c-chip').forEach(c=>c.classList.remove('active'));
                document.getElementById('courtPanel').classList.remove('show');
                document.getElementById('calSub').innerHTML='<i class="bi bi-arrow-up-circle"></i> Vui lòng chọn sân ở bước 1';
                renderGrid(); return;
            }
            activeCid=cid;
            document.querySelectorAll('.c-chip').forEach(c=>c.classList.remove('active'));
            document.getElementById('chip-'+cid).classList.add('active');
            sel=sel.filter(function(s){ if(s.cid!==cid){if(s.el)s.el.classList.remove('sel');return false;} return true; });
            refreshBar();
            showCourtPanel(cid);
            var cd=COURTS_DATA[cid];
            document.getElementById('calSub').innerHTML='<i class="bi bi-grid-3x3-gap" style="color:var(--G)"></i> Lịch sân: <strong style="color:var(--G2)">'+(cd?cd.name:'')+'</strong>';
            renderGrid();
        }

        // ══════════════════════════════════════════════════════════════
        // COURT DETAIL PANEL — tích hợp đầy đủ từ Court Details
        // (gallery ảnh + thumbnails + stats + tags + info grid + mô tả)
        // ══════════════════════════════════════════════════════════════
        function showCourtPanel(cid){
            var cd=COURTS_DATA[cid]; if(!cd) return;
            var imgs=cd.images&&cd.images.length?cd.images:[];
            var carId='cp-car-'+cid;

            // Pills
            var typePill=cd.courtType
                ?'<span class="cp-pill cp-pill-type">'+(cd.courtType==='Indoor'?'Trong nhà':'Ngoài trời')+'</span>':'' ;
            var statusPill=cd.status==='Maintenance'
                ?'<span class="cp-pill cp-pill-maint"><i class="bi bi-tools"></i> Bảo trì</span>'
                :'<span class="cp-pill cp-pill-open"><i class="bi bi-circle-fill" style="font-size:.35rem"></i> Sẵn sàng</span>';

            // Gallery
            var galleryH;
            if(!imgs.length){
                galleryH='<div class="cp-no-img"><i class="bi bi-grid-3x3-gap"></i><span>Chưa có ảnh sân</span></div>';
            } else {
                var indH=imgs.length>1?'<div class="carousel-indicators">'+imgs.map(function(_,i){
                    return '<button type="button" data-bs-target="#'+carId+'" data-bs-slide-to="'+i+'"'+(i===0?' class="active"':'')+' style="width:6px;height:6px;border-radius:50%;background:var(--G);border:0;opacity:'+(i===0?'1':'.45')+'"></button>';
                }).join('')+'</div>':'';
                var slidesH='<div class="carousel-inner">'+imgs.map(function(src,i){
                    return '<div class="carousel-item'+(i===0?' active':'')+'"><img src="'+src+'" class="d-block w-100" alt="'+cd.name+'"></div>';
                }).join('')+'</div>';
                var navH=imgs.length>1
                    ?'<button class="carousel-control-prev" type="button" data-bs-target="#'+carId+'" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>'+
                      '<button class="carousel-control-next" type="button" data-bs-target="#'+carId+'" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>':'';
                var thumbH=imgs.length>1
                    ?'<div class="cp-thumbs" id="cp-th-'+cid+'">'+imgs.map(function(src,i){
                        return '<img src="'+src+'" class="'+(i===0?'act':'')+'" onclick="cpSlide('+cid+','+i+')" alt="">';
                      }).join('')+'</div>':'';
                galleryH='<div id="'+carId+'" class="carousel slide cp-car" data-bs-ride="false">'+indH+slidesH+navH+'</div>'+thumbH;
            }

            // Stats
            var statsH='<div class="cp-stats">'+
                '<div class="cp-stat"><div class="cp-sv">'+(cd.surfaceTypeLabel||'—')+'</div><div class="cp-sl">Mặt sân</div></div>'+
                '<div class="cp-stat"><div class="cp-sv">'+(cd.hasLighting?'Có':'Không')+'</div><div class="cp-sl">Đèn sáng</div></div>'+
                '<div class="cp-stat"><div class="cp-sv">'+(cd.hasAC?'Có':'Không')+'</div><div class="cp-sl">Điều hoà</div></div>'+
                '</div>';

            // Tags
            var tArr=[];
            if(cd.courtTypeLabel)   tArr.push({i:'bi-layers',        t:cd.courtTypeLabel});
            if(cd.surfaceTypeLabel) tArr.push({i:'bi-grid-3x3',      t:cd.surfaceTypeLabel});
            if(cd.floorNumber)      tArr.push({i:'bi-building-up',   t:cd.floorNumber});
            if(cd.hasLighting)      tArr.push({i:'bi-lightbulb-fill',t:'Đèn chiếu sáng'});
            if(cd.hasAC)            tArr.push({i:'bi-wind',          t:'Điều hoà'});
            var tagsH='<div class="cp-tags">'+tArr.map(function(t){return '<span class="cp-tag"><i class="bi '+t.i+'"></i>'+t.t+'</span>';}).join('')+'</div>';

            // Info grid
            var iItems=[
                {icon:'bi-grid-3x3-gap-fill',lbl:'Tên sân',      val:cd.name},
                {icon:'bi-house-door-fill',   lbl:'Vị trí',       val:cd.courtTypeLabel||'—'},
                {icon:'bi-layers-fill',       lbl:'Loại mặt sân', val:cd.surfaceTypeLabel||'—'},
                {icon:'bi-lightbulb-fill',    lbl:'Đèn sáng',     val:cd.hasLighting?'✔ Có':'Không có'},
                {icon:'bi-wind',              lbl:'Điều hoà',     val:cd.hasAC?'✔ Có':'Không có'},
                {icon:'bi-check2-circle',     lbl:'Tình trạng',   val:cd.statusLabel||'—'}
            ];
            if(cd.floorNumber) iItems.splice(3,0,{icon:'bi-building',lbl:'Tầng',val:cd.floorNumber});
            if(cd.hourlyRate&&cd.hourlyRate>0) iItems.push({icon:'bi-tag-fill',lbl:'Giá thuê',val:cd.hourlyRate.toLocaleString('vi-VN')+' đ/giờ'});
            var igH='<div class="cp-info-grid">'+iItems.map(function(it){
                return '<div class="cp-ii"><div class="cp-ii-icon"><i class="bi '+it.icon+'"></i></div>'+
                    '<div><div class="cp-ii-lbl">'+it.lbl+'</div><div class="cp-ii-val">'+it.val+'</div></div></div>';
            }).join('')+'</div>';

            // CTA
            var priceH=cd.hourlyRate&&cd.hourlyRate>0
                ?'<div class="cp-price">'+cd.hourlyRate.toLocaleString('vi-VN')+'đ <span>/ giờ</span></div>':'';
            var ctaH='<div class="cp-cta">'+priceH+
                '<div style="display:flex;gap:.45rem;align-items:center">'+
                (cd.detailUrl?'<a href="'+cd.detailUrl+'" class="cp-btn-detail"><i class="bi bi-eye-fill"></i> Chi tiết sân</a>':'')+
                '</div></div>';

            // Description
            var articleH=cd.description
                ?'<div class="cp-article">'+
                  '<div class="cp-article-title"><i class="bi bi-file-text-fill"></i> Mô tả sân</div>'+
                  '<div class="cp-article-body">'+cd.description+'</div>'+
                  '</div>':'';

            // Assemble
            var html=
                '<div class="cp-hd">'+
                    '<div class="cp-hd-left">'+
                        '<div style="display:flex;gap:.3rem">'+typePill+statusPill+'</div>'+
                        '<span class="cp-hd-title">'+cd.name+'</span>'+
                    '</div>'+
                    '<button class="cp-btn-close" onclick="closePanel()"><i class="bi bi-x-lg"></i> Đóng</button>'+
                '</div>'+
                '<div class="cp-body">'+
                    '<div class="cp-gallery">'+galleryH+'</div>'+
                    '<div class="cp-info">'+statsH+tagsH+igH+ctaH+'</div>'+
                '</div>'+
                articleH;

            var panel=document.getElementById('courtPanel');
            panel.innerHTML=html;
            panel.classList.add('show');

            // Init carousel
            if(imgs.length>1){
                var carEl=document.getElementById(carId);
                if(carEl){
                    new bootstrap.Carousel(carEl,{interval:false,wrap:true});
                    carEl.addEventListener('slid.bs.carousel',function(e){
                        document.querySelectorAll('#cp-th-'+cid+' img').forEach(function(t,i){t.classList.toggle('act',i===e.to);});
                    });
                }
            }
            setTimeout(function(){ panel.scrollIntoView({behavior:'smooth',block:'nearest'}); },80);
        }

        function cpSlide(cid,idx){
            var el=document.getElementById('cp-car-'+cid);
            if(el) bootstrap.Carousel.getOrCreateInstance(el).to(idx);
        }

        function closePanel(){
            document.getElementById('courtPanel').classList.remove('show');
        }

        // ══════════════════════════════════════════════════════════════
        // MODAL ⓘ — popup đầy đủ ảnh + mô tả
        // ══════════════════════════════════════════════════════════════
        function openCourtModal(cid,evt){
            if(evt) evt.stopPropagation();
            var cd=COURTS_DATA[cid]; if(!cd) return;
            var ex=document.getElementById('cmModal'); if(ex) ex.remove();
            var imgs=cd.images&&cd.images.length?cd.images:[];
            var mcId='cm-car-'+cid;

            var imgH;
            if(!imgs.length){
                imgH='<div class="cm-img-ph"><i class="bi bi-grid-3x3-gap"></i></div>';
            } else if(imgs.length===1){
                imgH='<img class="cm-img" src="'+imgs[0]+'" alt="'+cd.name+'">';
            } else {
                imgH='<div id="'+mcId+'" class="carousel slide" data-bs-ride="carousel">'+
                    '<div class="carousel-inner">'+imgs.map(function(src,i){
                        return '<div class="carousel-item'+(i===0?' active':'')+'"><img class="cm-img" src="'+src+'" alt="'+cd.name+'"></div>';
                    }).join('')+'</div>'+
                    '<button class="carousel-control-prev" type="button" data-bs-target="#'+mcId+'" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>'+
                    '<button class="carousel-control-next" type="button" data-bs-target="#'+mcId+'" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>'+
                    '</div>';
            }

            var tArr=[];
            if(cd.courtTypeLabel)   tArr.push({i:'bi-house',         t:cd.courtTypeLabel});
            if(cd.surfaceTypeLabel) tArr.push({i:'bi-layers',         t:cd.surfaceTypeLabel});
            if(cd.floorNumber)      tArr.push({i:'bi-building',       t:'Tầng '+cd.floorNumber});
            if(cd.hasLighting)      tArr.push({i:'bi-lightbulb-fill', t:'Đèn chiếu sáng'});
            if(cd.hasAC)            tArr.push({i:'bi-wind',           t:'Điều hoà'});
            var tagH=tArr.map(function(t){return '<div class="cm-tag"><i class="bi '+t.i+'"></i>'+t.t+'</div>';}).join('');
            var freeC=(cd.slots||[]).filter(function(s){return !s.isBooked;}).length;
            var priceH=cd.hourlyRate&&cd.hourlyRate>0
                ?'<div style="font-size:.9rem;font-weight:800;color:var(--G);margin-top:.4rem">'+cd.hourlyRate.toLocaleString('vi-VN')+'đ <span style="font-size:.72rem;color:#8a7560;font-weight:400">/ giờ</span></div>':'';
            var descH=cd.description
                ?'<div class="cm-desc" style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--S)">'+cd.description+'</div>':'';
            var detailBtn=cd.detailUrl
                ?'<a href="'+cd.detailUrl+'" style="display:inline-flex;align-items:center;gap:.38rem;padding:.5rem 1.1rem;background:linear-gradient(135deg,var(--G),var(--G2));color:var(--D);border:none;border-radius:5px;font-size:.78rem;font-weight:800;cursor:pointer;text-decoration:none"><i class="bi bi-eye-fill"></i> Trang chi tiết sân</a>':'';

            document.body.insertAdjacentHTML('beforeend',
                '<div id="cmModal" class="cm-ov" onclick="if(event.target===this)this.remove()">'+
                '<div class="cm-box">'+
                    '<div class="cm-hd"><span class="cm-title">'+cd.name+'</span>'+
                    '<button class="cm-close" onclick="document.getElementById(\'cmModal\').remove()"><i class="bi bi-x-lg"></i></button></div>'+
                    imgH+
                    '<div class="cm-bd">'+
                        (tagH?'<div class="cm-tags">'+tagH+'</div>':'')+
                        '<div style="font-size:.8rem;color:#8a7560"><i class="bi bi-clock me-1" style="color:var(--G)"></i>'+freeC+' khung trống hôm nay</div>'+
                        priceH+descH+
                    '</div>'+
                    '<div class="cm-ft">'+detailBtn+'<button class="btn-cancel-sm" onclick="document.getElementById(\'cmModal\').remove()">Đóng</button></div>'+
                '</div></div>');

            if(imgs.length>1){
                var mel=document.getElementById(mcId);
                if(mel) new bootstrap.Carousel(mel,{interval:3000,wrap:true});
            }
        }

        // ══════════════════════════════════════════════════════════════
        // WEEK NAV
        // ══════════════════════════════════════════════════════════════
        function navWeek(dir){ weekMon=addDays(weekMon,dir*7); updateWkLabel(); renderGrid(); }
        function goToday(){ weekMon=getMon(parseLocal(TODAY_STR)); updateWkLabel(); renderGrid(); }
        function jumpTo(s){ if(!s)return; weekMon=getMon(parseLocal(s)); updateWkLabel(); renderGrid(); }
        function updateWkLabel(){
            var sun=addDays(weekMon,6);
            document.getElementById('wkRange').textContent=fmtD(weekMon)+'/'+weekMon.getFullYear().toString().slice(2)+' – '+fmtD(sun)+'/'+sun.getFullYear().toString().slice(2);
        }

        // ══════════════════════════════════════════════════════════════
        // RENDER GRID
        // ══════════════════════════════════════════════════════════════
        function renderGrid(){
            var nc=document.getElementById('noCourt'), gw=document.getElementById('wgridWrap');
            if(!activeCid){ nc.style.display='block'; gw.style.display='none'; document.getElementById('wgrid').innerHTML=''; return; }
            nc.style.display='none'; gw.style.display='block';
            var cd=COURTS_DATA[activeCid]||{}, rawSl=cd.slots||[], today=parseLocal(TODAY_STR);
            var days=[]; for(var i=0;i<7;i++) days.push(addDays(weekMon,i));
            var times=[];
            if(rawSl.length>0){
                var seen={};
                rawSl.forEach(function(s){ if(!seen[s.st]){seen[s.st]=true;times.push({st:s.st,et:s.et,price:s.price});} });
                times.sort(function(a,b){return a.st.localeCompare(b.st);});
            } else {
                for(var h=6;h<22;h++) times.push({st:p2(h)+':00',et:p2(h+1)+':00',price:0});
            }
            var H='<div class="wg-head"><div class="wg-h0"></div>';
            days.forEach(function(d,i){ var iso=toISO(d),isTod=iso===TODAY_STR; H+='<div class="wg-hday'+(isTod?' today':'')+'"><div class="wg-dn">'+DSHORT[i]+'</div><div class="wg-dd">'+fmtD(d)+'</div></div>'; });
            H+='</div>';
            H+='<div class="wg-acts"><div class="wg-a0">Nhanh</div>';
            days.forEach(function(d){ var iso=toISO(d),isPast=d<today; H+='<div class="wg-acol">'+(isPast?'':'<button class="da-btn da-sel" onclick="selDay(\''+iso+'\')">Tất</button><button class="da-btn da-clr" onclick="clrDay(\''+iso+'\')">Xóa</button>')+'</div>'; });
            H+='</div><div class="wg-body">';
            times.forEach(function(slot){
                H+='<div class="wg-time"><span>'+slot.st+'<br><span style="font-size:.52rem;color:#c0a880;font-weight:400">'+slot.et+'</span></span></div>';
                days.forEach(function(d){
                    var iso=toISO(d),isPast=d<today;
                    var key=activeCid+'-'+iso+'-'+slot.st;
                    var booked=false;
                    if(iso===SEL_DATE_STR&&rawSl.length>0){ var srv=rawSl.find(function(s){return s.st===slot.st;}); if(srv) booked=srv.isBooked; }
                    var isSel=!!sel.find(function(s){return s.key===key;});
                    var cls='wg-slot'+(isPast?' past':booked?' bk':isSel?' sel':'');
                    var inner=isPast?'<span class="past-lbl">Đã qua</span>':booked?'<span class="bk-lbl">Đã đặt</span>':
                        '<span class="st-t">'+slot.st+'–'+slot.et+'</span>'+(slot.price>0?'<span class="st-p">'+Math.round(slot.price/1000)+'k</span>':'');
                    var click=(isPast||booked)?'':' onclick="tgl(\''+key+'\','+activeCid+',\''+slot.st+'\',\''+slot.et+'\','+slot.price+',\''+iso+'\')"';
                    H+='<div class="wg-cell"><div id="'+key+'" class="'+cls+'" data-date="'+iso+'" data-st="'+slot.st+'"'+click+'>'+inner+'</div></div>';
                });
            });
            H+='</div>';
            document.getElementById('wgrid').innerHTML=H;
            sel.forEach(function(s){ var el=document.getElementById(s.key); if(el){s.el=el;el.classList.add('sel');} });
        }

        // ══════════════════════════════════════════════════════════════
        // SLOT TOGGLE
        // ══════════════════════════════════════════════════════════════
        function tgl(key,cid,st,et,price,dateStr){
            var el=document.getElementById(key);
            if(!el||el.classList.contains('bk')||el.classList.contains('past')) return;
            var idx=sel.findIndex(function(s){return s.key===key;});
            if(idx>-1){ sel.splice(idx,1); el.classList.remove('sel'); }
            else { var cd=COURTS_DATA[cid]; sel.push({key:key,cid:cid,cname:cd?cd.name:'',date:dateStr,st:st,et:et,price:price,el:el}); el.classList.add('sel'); }
            refreshBar();
        }

        function selDay(dateStr){
            document.querySelectorAll('.wg-slot[data-date="'+dateStr+'"]').forEach(function(el){
                if(el.classList.contains('bk')||el.classList.contains('past')||el.classList.contains('sel')) return;
                var key=el.id,st=el.dataset.st,cd=COURTS_DATA[activeCid];
                var srv=cd?(cd.slots||[]).find(function(s){return s.st===st;}):null;
                sel.push({key:key,cid:activeCid,cname:cd?cd.name:'',date:dateStr,st:st,et:srv?srv.et:p2(parseInt(st)+1)+':00',price:srv?srv.price:0,el:el});
                el.classList.add('sel');
            });
            refreshBar();
        }

        function clrDay(dateStr){
            sel=sel.filter(function(s){ if(s.date===dateStr&&s.cid===activeCid){if(s.el)s.el.classList.remove('sel');return false;} return true; });
            refreshBar();
        }

        function clearAll(){
            sel.forEach(function(s){if(s.el)s.el.classList.remove('sel');}); sel=[]; refreshBar();
        }

        // ══════════════════════════════════════════════════════════════
        // PAY BAR
        // ══════════════════════════════════════════════════════════════
        function refreshBar(){
            var bar=document.getElementById('payBar'),cnt=sel.length,total=sel.reduce(function(a,s){return a+s.price;},0);
            if(cnt>0){
                bar.classList.add('show');
                document.getElementById('payLbl').textContent='Đã chọn '+cnt+' khung giờ';
                document.getElementById('payTot').textContent=total.toLocaleString('vi-VN')+'đ';
                var g={};
                sel.forEach(function(s){ if(!g[s.date])g[s.date]=[]; g[s.date].push(s.cname+' '+s.st+'–'+s.et); });
                document.getElementById('payMeta').textContent=Object.keys(g).map(function(k){return k+': '+g[k].join(', ');}).join(' | ');
            } else { bar.classList.remove('show'); }
        }

        // ══════════════════════════════════════════════════════════════
        // BOOKING
        // ══════════════════════════════════════════════════════════════
        function goBook(){
            if(!sel.length) return;
            if(sel.length===1){ var s=sel[0]; window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+s.st+'&endTime='+s.et; return; }
            showMultiModal();
        }

        function showMultiModal(){
            var ex=document.getElementById('mmodal'); if(ex) ex.remove();
            var items=sel.map(function(s,i){
                return '<div class="ov-item"><div><div class="ov-item-name">'+s.cname+' · '+s.date+'</div><div class="ov-item-sub">'+s.st+' – '+s.et+'</div></div>'+
                    '<div class="ov-item-right"><span class="ov-price">'+s.price.toLocaleString('vi-VN')+'đ</span>'+
                    '<button class="ov-book" onclick="bookOne('+i+')">Đặt ngay</button></div></div>';
            }).join('');
            document.body.insertAdjacentHTML('beforeend',
                '<div id="mmodal" class="ov" onclick="if(event.target===this)this.remove()">'+
                '<div class="ov-box"><div class="ov-hd"><span class="ov-title">Chọn khung để đặt ('+sel.length+')</span>'+
                '<button class="ov-close" onclick="document.getElementById(\'mmodal\').remove()"><i class="bi bi-x-lg"></i></button></div>'+
                '<div style="max-height:380px;overflow-y:auto">'+items+'</div>'+
                '<div class="ov-ft"><button class="btn-cancel-sm" onclick="document.getElementById(\'mmodal\').remove()">Đóng</button></div></div></div>');
        }

        function bookOne(idx){ var s=sel[idx]; window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+s.st+'&endTime='+s.et; }
    </script>
}
