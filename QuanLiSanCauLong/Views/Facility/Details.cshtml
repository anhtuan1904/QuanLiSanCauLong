        gap: .18rem;
        justify-content: center;
        border-left: 1px solid var(--S);
    }

    .da-btn {
        font-size: .56rem;
        font-weight: 700;
        padding: .18rem .38rem;
        border-radius: 4px;
        cursor: pointer;
        border: 1.5px solid;
        transition: all .15s;
        white-space: nowrap;
    }

    .da-sel {
        border-color: rgba(212,160,23,.4);
        color: var(--G);
        background: rgba(212,160,23,.05);
    }

        .da-sel:hover {
            background: var(--G3);
