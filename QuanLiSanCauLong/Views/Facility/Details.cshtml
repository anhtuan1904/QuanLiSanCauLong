@model QuanLiSanCauLong.ViewModels.FacilityDetailsViewModel
@{
    ViewData["Title"] = Model.FacilityName;
}

<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --D3: #2e2010;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.10);
        --G4: rgba(212,160,23,.18);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
        --M: rgba(255,255,255,.38);
        --M2: rgba(255,255,255,.08);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        background: var(--W);
        margin: 0;
    }

    /* BREADCRUMB */
    .bc {
        background: var(--D);
        padding: .75rem 2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        border-bottom: 1px solid var(--G4);
    }

        .bc a {
            color: var(--G2);
            text-decoration: none;
            font-size: .78rem;
            font-weight: 600;
            opacity: .8;
            display: flex;
            align-items: center;
            gap: .35rem;
        }

            .bc a:hover {
                opacity: 1;
            }

    .bc-sep {
        color: var(--M);
        font-size: .65rem;
    }

    .bc-cur {
        color: var(--M);
        font-size: .78rem;
        font-style: italic;
    }

    /* HERO */
    .hero {
        background: var(--D);
        position: relative;
        overflow: hidden;
    }

        .hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 55% 90% at 72% 50%, rgba(212,160,23,.07), transparent 65%);
            pointer-events: none;
        }

    .hero-wrap {
        max-width: 1380px;
        margin: 0 auto;
        padding: 2.2rem 2rem;
        display: grid;
        grid-template-columns: 1fr 370px;
        gap: 2.2rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .fc {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--G4);
    }

        .fc .carousel-item img {
            height: 400px;
            object-fit: cover;
            filter: brightness(.88);
        }

        .fc .carousel-control-prev, .fc .carousel-control-next {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(26,18,9,.72);
            border: 1px solid var(--G4);
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity .25s;
        }

        .fc:hover .carousel-control-prev, .fc:hover .carousel-control-next {
            opacity: 1;
        }

        .fc .carousel-control-prev {
            left: 10px;
        }

        .fc .carousel-control-next {
            right: 10px;
        }

    .carousel-indicators [data-bs-target] {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--G);
        border: 0;
        opacity: .45;
    }

    .carousel-indicators .active {
        opacity: 1;
    }

    .iblock {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .i-pills {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .i-pill {
        background: var(--R);
        color: #fff;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        padding: .24rem .7rem;
        border-radius: 3px;
    }

    .i-open {
        background: rgba(16,185,129,.12);
        color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        padding: .24rem .7rem;
        border-radius: 3px;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .i-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.55rem,2.2vw,2.3rem);
        font-weight: 700;
        color: #fff;
        margin: 0;
        line-height: 1.15;
    }

    .i-addr {
        font-size: .82rem;
        color: var(--M);
        display: flex;
        align-items: flex-start;
        gap: .4rem;
    }

        .i-addr i {
            color: var(--R);
            margin-top: 2px;
            flex-shrink: 0;
        }

    .i-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--G4);
        border: 1px solid var(--G4);
        border-radius: 8px;
        overflow: hidden;
    }

    .istat {
        background: var(--D2);
        padding: .9rem .5rem;
        text-align: center;
        transition: background .18s;
    }

        .istat:hover {
            background: var(--G3);
        }

    .sv {
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--G2);
        line-height: 1;
        margin-bottom: .28rem;
    }

    .sl {
        font-size: .56rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--M);
    }

    .i-desc {
        font-size: .82rem;
        line-height: 1.8;
        color: var(--M);
        border-left: 2px solid var(--G);
        padding-left: .9rem;
    }

    .i-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .27rem .78rem;
        background: var(--M2);
        border: 1px solid var(--G4);
        border-radius: 4px;
        color: rgba(255,255,255,.65);
        font-size: .72rem;
        font-weight: 500;
        transition: all .2s;
    }

        .chip:hover {
            background: var(--G3);
            border-color: var(--G);
            color: var(--G2);
        }

        .chip i {
            color: var(--G);
            font-size: .72rem;
        }

    /* BOOKING SECTION */
    .bsec {
        max-width: 1380px;
        margin: 0 auto;
        padding: 2.2rem 2rem 9rem;
    }

    .tabs {
        display: flex;
        gap: .35rem;
        background: var(--D);
        border: 1px solid var(--G4);
        border-radius: 8px;
        padding: .4rem;
        width: fit-content;
        margin-bottom: 1.6rem;
    }

    .tb {
        padding: .55rem 1.3rem;
        border: none;
        background: none;
        border-radius: 5px;
        font-family: 'Outfit', sans-serif;
        font-size: .8rem;
        font-weight: 600;
        color: var(--M);
        cursor: pointer;
        transition: all .22s;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .tb.on {
            background: linear-gradient(135deg, var(--G), var(--G2));
            color: var(--D);
        }

    .tp {
        display: none;
    }

        .tp.on {
            display: block;
        }

    .bcard {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

    .bcard-hd {
        background: var(--D);
        border-bottom: 1px solid var(--G4);
        padding: 1.1rem 1.6rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .9rem;
    }

    .bcard-title {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
    }

    .bcard-sub {
        font-size: .72rem;
        color: var(--M);
        display: flex;
        align-items: center;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .bcard-bd {
        padding: 1.4rem 1.6rem;
    }

    /* COURT CHIPS */
    .court-grid {
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
        margin-bottom: 1rem;
    }

    .c-chip {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .65rem 1rem;
        border: 1.5px solid var(--S);
        border-radius: 8px;
        cursor: pointer;
        background: #fff;
        transition: all .2s;
        position: relative;
        user-select: none;
    }

        .c-chip:hover {
            border-color: var(--G);
            background: var(--G3);
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(212,160,23,.15);
        }

        .c-chip.active {
            border-color: var(--G);
            background: linear-gradient(135deg, rgba(212,160,23,.14), rgba(245,200,66,.07));
            box-shadow: 0 3px 14px rgba(212,160,23,.22);
        }

    .c-badge {
        width: 34px;
        height: 34px;
        border-radius: 7px;
        background: linear-gradient(135deg, var(--G), var(--G2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: .72rem;
        color: var(--D);
        flex-shrink: 0;
        transition: all .2s;
    }

    .c-chip.active .c-badge {
        background: linear-gradient(135deg, var(--D), var(--D2));
        color: var(--G2);
    }

    .c-name {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: .9rem;
        color: var(--D);
    }

    .c-sub {
        font-size: .64rem;
        color: #8a7560;
        margin-top: .05rem;
    }

    .c-dot {
        position: absolute;
        top: 5px;
        right: 7px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--G);
        display: none;
    }

    .c-chip.active .c-dot {
        display: block;
    }

    .c-info-btn {
        margin-left: .3rem;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1.5px solid rgba(212,160,23,.4);
        background: rgba(212,160,23,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--G);
        font-size: .6rem;
        cursor: pointer;
        transition: all .15s;
        flex-shrink: 0;
    }

        .c-info-btn:hover {
            background: var(--G);
            color: var(--D);
        }

    /* COURT DETAIL PANEL */
    .court-panel {
        background: var(--D);
        border: 1px solid var(--G4);
        border-radius: 12px;
        margin-bottom: 1.4rem;
        display: none;
        overflow: hidden;
        animation: fadeUp .25s ease;
    }

        .court-panel.show {
            display: block;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cp-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.2rem;
        border-bottom: 1px solid var(--G4);
        background: rgba(0,0,0,.2);
        flex-wrap: wrap;
        gap: .5rem;
    }

    .cp-hd-left {
        display: flex;
        align-items: center;
        gap: .55rem;
        flex-wrap: wrap;
    }

    .cp-hd-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #fff;
        font-size: 1rem;
    }

    .cp-pill {
        padding: .2rem .6rem;
        border-radius: 3px;
        font-size: .55rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .cp-pill-type {
        background: var(--R);
        color: #fff;
    }

    .cp-pill-open {
        background: rgba(16,185,129,.15);
        color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
        display: flex;
        align-items: center;
        gap: .25rem;
    }

    .cp-pill-maint {
        background: rgba(201,75,42,.15);
        color: #ef8c72;
        border: 1px solid rgba(201,75,42,.2);
    }

    .cp-btn-close {
        display: flex;
        align-items: center;
        gap: .3rem;
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        color: rgba(255,255,255,.45);
        font-size: .68rem;
        font-weight: 600;
        padding: .4rem .85rem;
        border-radius: 6px;
        cursor: pointer;
        transition: all .15s;
    }

        .cp-btn-close:hover {
            background: rgba(220,38,38,.15);
            border-color: #dc2626;
            color: #dc2626;
        }

    .cp-body {
        display: grid;
        grid-template-columns: 1fr 310px;
    }

    .cp-gallery {
        padding: 1rem 1rem 1rem 1.2rem;
    }

    .cp-car {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--G4);
    }

        .cp-car .carousel-item img {
            height: 255px;
            object-fit: cover;
            filter: brightness(.88);
        }

        .cp-car .carousel-control-prev, .cp-car .carousel-control-next {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(26,18,9,.72);
            border: 1px solid var(--G4);
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity .2s;
        }

        .cp-car:hover .carousel-control-prev, .cp-car:hover .carousel-control-next {
            opacity: 1;
        }

        .cp-car .carousel-control-prev {
            left: 8px;
        }

        .cp-car .carousel-control-next {
            right: 8px;
        }

    .cp-thumbs {
        display: flex;
        gap: .4rem;
        margin-top: .5rem;
        overflow-x: auto;
    }

    .cp-thumb {
        width: 52px;
        height: 40px;
        border-radius: 5px;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid transparent;
        cursor: pointer;
        transition: all .2s;
        filter: brightness(.75);
    }

        .cp-thumb.active {
            border-color: var(--G);
            filter: brightness(1);
        }

        .cp-thumb:hover {
            filter: brightness(.9);
        }

    .cp-info {
        padding: 1rem 1.2rem 1rem 1rem;
        border-left: 1px solid var(--G4);
        display: flex;
        flex-direction: column;
        gap: .85rem;
    }

    .cp-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .45rem;
    }

    .cp-istat {
        background: rgba(0,0,0,.2);
        border-radius: 6px;
        padding: .55rem .65rem;
    }

    .cp-istat-v {
        font-size: .9rem;
        font-weight: 800;
        color: var(--G2);
        line-height: 1;
    }

    .cp-istat-l {
        font-size: .5rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--M);
        margin-top: .2rem;
    }

    .cp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .3rem;
    }

    .cp-tag {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        padding: .22rem .55rem;
        background: rgba(255,255,255,.06);
        border: 1px solid var(--G4);
        border-radius: 4px;
        color: rgba(255,255,255,.55);
        font-size: .62rem;
        font-weight: 500;
    }

        .cp-tag i {
            color: var(--G);
            font-size: .6rem;
        }

    .cp-price-row {
        margin-top: auto;
        background: var(--G3);
        border: 1px solid var(--G4);
        border-radius: 8px;
        padding: .7rem .9rem;
    }

    .cp-price {
        font-family: 'Outfit',sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--G2);
        line-height: 1;
    }

        .cp-price span {
            font-size: .65rem;
            color: var(--M);
            font-weight: 400;
        }

    .cp-btn-detail {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .5rem 1rem;
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
        border: none;
        border-radius: 6px;
        font-family: 'Outfit',sans-serif;
        font-size: .74rem;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        white-space: nowrap;
    }

        .cp-btn-detail:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
            filter: brightness(1.05);
            color: var(--D);
        }

    .cp-article {
        padding: .9rem 1.4rem 1.1rem;
        border-top: 1px solid var(--G4);
        background: rgba(0,0,0,.1);
    }

    .cp-article-title {
        font-family: 'Playfair Display',serif;
        font-size: .88rem;
        font-weight: 700;
        color: var(--G2);
        margin: 0 0 .55rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .cp-article-body {
        font-size: .82rem;
        line-height: 1.85;
        color: rgba(255,255,255,.48);
    }

    /* ═══════════════════════════════════════════════════════
                   CALENDAR — MONTHLY VIEW (inspired by Lịch Phân Ca)
                ════════════════════════════════════════════════════════ */
    .cal-layout {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 1.2rem;
        align-items: start;
    }

    /* Month navigation */
    .mnav {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .mnav-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1.5px solid var(--S);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #8a7560;
        font-size: .82rem;
        transition: all .2s;
        text-decoration: none;
    }

        .mnav-btn:hover {
            border-color: var(--G);
            color: var(--G);
            background: var(--G3);
        }

    .mnav-today {
        padding: .42rem .95rem;
        border-radius: 8px;
        border: 1.5px solid var(--G);
        background: rgba(212,160,23,.07);
        color: #92660a;
        font-size: .75rem;
        font-weight: 700;
        cursor: pointer;
        transition: all .2s;
    }

        .mnav-today:hover {
            background: rgba(212,160,23,.16);
        }

    .mnav-label {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--D);
        flex: 1;
    }

        .mnav-label em {
            font-style: italic;
            color: var(--G);
        }

    /* Month jump */
    .month-jump {
        display: flex;
        align-items: center;
        gap: .45rem;
        margin-left: auto;
    }

        .month-jump label {
            font-size: .7rem;
            color: #8a7560;
            font-weight: 600;
            white-space: nowrap;
        }

        .month-jump input[type=month] {
            padding: .38rem .7rem;
            border: 1.5px solid var(--S);
            border-radius: 6px;
            font-family: 'Outfit', sans-serif;
            font-size: .78rem;
            color: var(--D);
            outline: none;
            cursor: pointer;
        }

            .month-jump input[type=month]:focus {
                border-color: var(--G);
            }

    /* Calendar grid */
    .cal-wrap {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 12px;
        overflow: hidden;
    }

    .cal-head {
        display: grid;
        grid-template-columns: repeat(7,1fr);
        border-bottom: 2px solid var(--S);
    }

    .cal-hc {
        padding: .7rem;
        text-align: center;
        background: var(--W);
        border-right: 1px solid var(--S);
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .09em;
        text-transform: uppercase;
        color: #8a7560;
    }

        .cal-hc:last-child {
            border-right: none;
        }

    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7,1fr);
    }

    .cal-day {
        border-right: 1px solid var(--S);
        border-bottom: 1px solid var(--S);
        min-height: 88px;
        padding: .45rem .5rem .4rem;
        cursor: pointer;
        transition: background .14s;
        position: relative;
        user-select: none;
    }

        .cal-day:nth-child(7n) {
            border-right: none;
        }

        .cal-day.other-month {
            background: #fafaf9;
            opacity: .45;
            pointer-events: none;
        }

        .cal-day.today-day {
            background: rgba(212,160,23,.06);
        }

        .cal-day.past-day {
            opacity: .45;
            pointer-events: none;
            cursor: default;
        }

        .cal-day.selected-day {
            background: var(--D) !important;
            border-color: var(--G4) !important;
        }

        .cal-day:not(.other-month):not(.past-day):not(.selected-day):hover {
            background: rgba(212,160,23,.07);
        }

        /* Ngày còn ít slot (duoi 30% trống) */
        .cal-day.day-low:not(.selected-day) {
            background: rgba(254,226,226,.45);
        }
        /* Ngày đặt hết */
        .cal-day.day-full:not(.selected-day) {
            background: rgba(254,202,202,.6);
            cursor: not-allowed;
        }

            .cal-day.day-full:not(.selected-day):hover {
                background: rgba(254,202,202,.6) !important;
            }
        /* Ngày còn nhiều slot */
        .cal-day.day-open:not(.selected-day):not(.today-day) {
            background: rgba(209,250,229,.3);
        }

    .cal-day-num {
        font-family: 'Playfair Display', serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--D);
        line-height: 1;
        margin-bottom: .3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .cal-day.today-day .cal-day-num {
        color: var(--G);
    }

    .cal-day.selected-day .cal-day-num {
        color: var(--G2);
    }

    .cal-day.today-day .cal-today-pip {
        display: block;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--G);
        flex-shrink: 0;
    }

    .cal-today-pip {
        display: none;
    }

    /* Slot indicators in day cell */
    .cal-slots {
        display: flex;
        flex-direction: column;
        gap: .15rem;
    }

    .cal-slot-bar {
        border-radius: 3px;
        padding: .1rem .35rem;
        font-size: .57rem;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .cal-slot-bar.free {
            background: rgba(16,185,129,.12);
            color: #059669;
        }

        .cal-slot-bar.full {
            background: rgba(220,38,38,.1);
            color: #dc2626;
        }

    .cal-slot-more {
        font-size: .55rem;
        color: #aaa;
        margin-top: .1rem;
    }

    .cal-day.selected-day .cal-slot-bar.free {
        background: rgba(212,160,23,.18);
        color: var(--G2);
    }

    .cal-day.selected-day .cal-slot-bar.full {
        background: rgba(255,255,255,.07);
        color: rgba(255,255,255,.35);
    }

    /* No court placeholder inside calendar */
    .cal-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 380px;
        color: #c0a880;
        text-align: center;
        gap: .65rem;
    }

        .cal-placeholder i {
            font-size: 2.8rem;
            opacity: .22;
        }

        .cal-placeholder p {
            font-size: .82rem;
            margin: 0;
        }

    /* ═══════════════════════════════════════════════════════
                   SIDEBAR — Stats + Legend
                ════════════════════════════════════════════════════════ */
    .cal-sidebar {
        display: flex;
        flex-direction: column;
        gap: .9rem;
    }

    .side-card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 10px;
        overflow: hidden;
    }

    .side-card-hd {
        background: var(--D);
        padding: .7rem 1rem;
        font-size: .6rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--G);
        border-bottom: 1px solid var(--G4);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .side-card-bd {
        padding: .9rem 1rem;
    }

    /* Stat rows */
    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .42rem 0;
        border-bottom: 1px solid var(--S);
        font-size: .8rem;
    }

        .stat-row:last-child {
            border-bottom: none;
        }

    .stat-row-label {
        color: #8a7560;
    }

    .stat-row-val {
        font-weight: 700;
        color: var(--D);
    }

        .stat-row-val.gold {
            color: var(--G);
        }

        .stat-row-val.green {
            color: #059669;
        }

        .stat-row-val.red {
            color: #dc2626;
        }

    /* Legend */
    .leg-item {
        display: flex;
        align-items: center;
        gap: .55rem;
        padding: .38rem 0;
        border-bottom: 1px solid var(--S);
        font-size: .76rem;
        color: #8a7560;
    }

        .leg-item:last-child {
            border-bottom: none;
        }

    .leg-swatch {
        width: 13px;
        height: 13px;
        border-radius: 3px;
        border: 1.5px solid;
        flex-shrink: 0;
    }

        .leg-swatch.free {
            background: rgba(16,185,129,.12);
            border-color: rgba(16,185,129,.35);
        }

        .leg-swatch.sel {
            background: var(--D);
            border-color: var(--G);
        }

        .leg-swatch.bk {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .leg-swatch.past {
            background: #f5f5f5;
            border-color: #d1d5db;
        }

    /* ═══════════════════════════════════════════════════════
                   TIME SLOTS PANEL — appears below calendar on day click
                ════════════════════════════════════════════════════════ */
    .slots-panel {
        margin-top: 1.2rem;
        border: 1.5px solid var(--G4);
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
        /* Không dùng animation để tránh reflow layout */
    }

    .slots-panel-hd {
        background: var(--D);
        padding: .8rem 1.2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--G4);
        flex-wrap: wrap;
        gap: .5rem;
    }

    .slots-panel-title {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: .95rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .slots-panel-date {
        display: inline-block;
        background: var(--G3);
        border: 1px solid var(--G4);
        border-radius: 5px;
        padding: .15rem .55rem;
        font-size: .72rem;
        color: var(--G2);
        font-weight: 800;
        font-style: normal;
        margin-left: .3rem;
    }
    /* ══ TIMELINE GRID ══ */
    .tl-wrap {
        padding: 1rem 1.2rem 1.2rem;
    }

    /* Duration presets */
    .tl-presets {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        margin-bottom: .85rem;
        align-items: center;
    }

    .tl-preset-label {
        font-size: .65rem;
        color: #8a7560;
        font-weight: 600;
        white-space: nowrap;
    }

    .tl-preset {
        font-size: .68rem;
        font-weight: 700;
        padding: .28rem .75rem;
        border-radius: 20px;
        cursor: pointer;
        border: 1.5px solid var(--S);
        background: #fff;
        color: #8a7560;
        transition: all .15s;
    }

        .tl-preset:hover, .tl-preset.on {
            border-color: var(--G);
            background: var(--G3);
            color: #92660a;
        }

        .tl-preset.on {
            box-shadow: 0 2px 8px rgba(212,160,23,.2);
        }

    /* Grid itself */
    .tl-grid-wrap {
        overflow-x: auto;
        border-radius: 8px;
        border: 1px solid var(--S);
    }

        .tl-grid-wrap::-webkit-scrollbar {
            height: 5px;
        }

        .tl-grid-wrap::-webkit-scrollbar-track {
            background: var(--S);
        }

        .tl-grid-wrap::-webkit-scrollbar-thumb {
            background: var(--G);
            border-radius: 3px;
        }

    .tl-grid {
        display: flex;
        min-width: max-content;
        user-select: none;
    }

    /* Hour label column */
    .tl-labels {
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        width: 52px;
        border-right: 1px solid var(--S);
        background: #fafaf8;
    }

    .tl-lbl-top {
        height: 26px;
        border-bottom: 1px solid var(--S);
    }

    .tl-lbl {
        height: 42px;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 3px;
        font-size: .6rem;
        font-weight: 700;
        color: #8a7560;
        border-bottom: 1px solid var(--S);
    }

        .tl-lbl:last-child {
            border-bottom: none;
        }

    /* Cells column */
    .tl-cells {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    /* Header row: time labels */
    .tl-hrow {
        display: flex;
        border-bottom: 1px solid var(--S);
        background: var(--W);
        height: 26px;
    }

    .tl-htick {
        flex: 1;
        min-width: 38px;
        border-right: 1px solid var(--S);
        font-size: .56rem;
        font-weight: 700;
        color: #8a7560;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        overflow: hidden;
    }

        .tl-htick:last-child {
            border-right: none;
        }

        .tl-htick.hour-mark {
            color: var(--D);
            font-weight: 800;
        }

    /* Body rows: one per 30-min block */
    .tl-row {
        display: flex;
    }

    .tl-cell {
        flex: 1;
        min-width: 38px;
        height: 42px;
        border-right: 1px solid var(--S);
        border-bottom: 1px solid var(--S);
        cursor: pointer;
        position: relative;
        transition: background .1s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .tl-cell:last-child {
            border-right: none;
        }

        .tl-cell.hour-start {
            border-left: 2px solid rgba(212,160,23,.25);
        }

        .tl-cell.past {
            background: #f5f5f5 !important;
            cursor: not-allowed;
            opacity: .45;
        }

        .tl-cell.booked {
            background: #fef2f2 !important;
            cursor: not-allowed;
        }

            .tl-cell.booked::after {
                content: '✕';
                font-size: .52rem;
                color: #dc2626;
                font-weight: 900;
                opacity: .7;
            }

        .tl-cell.sel {
            background: var(--D) !important;
            outline: none;
        }

        .tl-cell.sel-start {
            border-radius: 6px 0 0 6px;
        }

        .tl-cell.sel-end {
            border-radius: 0 6px 6px 0;
        }

        .tl-cell.sel-only {
            border-radius: 6px;
        }

        .tl-cell.dragging {
            background: rgba(212,160,23,.18) !important;
        }

        .tl-cell:not(.past):not(.booked):not(.sel):hover {
            background: rgba(212,160,23,.1);
        }

    /* Duration badge floating on selection */
    .tl-dur-badge {
        position: absolute;
        top: 4px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--G);
        color: var(--D);
        font-size: .52rem;
        font-weight: 900;
        padding: .08rem .32rem;
        border-radius: 3px;
        white-space: nowrap;
        pointer-events: none;
        z-index: 2;
    }

    /* Selection summary bar below grid */
    .tl-summary {
        margin-top: .85rem;
        background: var(--D);
        border-radius: 8px;
        padding: .75rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        border: 1px solid var(--G4);
        animation: fadeUp .2s ease;
    }

    .tl-sum-time {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
        flex: 1;
    }

        .tl-sum-time em {
            color: var(--G2);
            font-style: normal;
        }

    .tl-sum-dur {
        font-size: .72rem;
        color: var(--M);
    }

    .tl-sum-price {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--G2);
    }

        .tl-sum-price span {
            font-size: .65rem;
            color: var(--M);
            font-weight: 400;
        }

    .tl-sum-actions {
        display: flex;
        gap: .45rem;
    }

    .tl-btn-clr {
        padding: .38rem .8rem;
        border-radius: 5px;
        border: 1px solid rgba(255,255,255,.1);
        background: rgba(255,255,255,.07);
        color: rgba(255,255,255,.55);
        font-size: .72rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .15s;
    }

        .tl-btn-clr:hover {
            border-color: #dc2626;
            color: #dc2626;
            background: rgba(220,38,38,.1);
        }

    .tl-btn-book {
        padding: .4rem 1.1rem;
        border-radius: 5px;
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
        font-size: .78rem;
        font-weight: 800;
        border: none;
        cursor: pointer;
        transition: all .15s;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

        .tl-btn-book:hover {
            box-shadow: 0 4px 14px rgba(212,160,23,.35);
        }

    .slots-empty {
        padding: 2.5rem;
        text-align: center;
        color: #b0a090;
        font-size: .82rem;
    }

    /* PAY BAR */
    .paybar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--D);
        border-top: 2px solid var(--G4);
        padding: 1rem 0;
        z-index: 1000;
        transform: translateY(110%);
        transition: transform .38s cubic-bezier(.175,.885,.32,1.275);
        box-shadow: 0 -8px 32px rgba(0,0,0,.42);
    }

        .paybar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--G), var(--G2), transparent);
        }

        .paybar.show {
            transform: translateY(0);
        }

    .pay-in {
        max-width: 1380px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
    }

    .pay-lbl {
        font-size: .7rem;
        color: var(--M);
        letter-spacing: .05em;
    }

    .pay-tot {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 1.8rem;
        color: var(--G2);
        line-height: 1;
    }

    .pay-meta {
        font-size: .66rem;
        color: var(--M);
        margin-top: .1rem;
        max-width: 600px;
    }

    .pay-acts {
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .btn-clr {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        background: var(--M2);
        border: 1px solid var(--G4);
        color: var(--M);
        cursor: pointer;
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .82rem;
    }

        .btn-clr:hover {
            background: rgba(220,38,38,.15);
            border-color: #dc2626;
            color: #dc2626;
        }

    .btn-book {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        background: linear-gradient(135deg, var(--G), var(--G2));
        color: var(--D);
        font-family: 'Outfit', sans-serif;
        font-size: .9rem;
        font-weight: 800;
        letter-spacing: .03em;
        padding: .82rem 2rem;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: all .22s;
        white-space: nowrap;
    }

        .btn-book:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(212,160,23,.4);
            filter: brightness(1.05);
        }

    /* MODALS */
    .ov {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.55);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

    .ov-box {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        max-width: 520px;
        width: 100%;
        border: 1px solid var(--S);
        box-shadow: 0 24px 60px rgba(0,0,0,.32);
    }

    .ov-hd {
        background: var(--D);
        padding: 1.1rem 1.4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ov-title {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }

    .ov-close {
        background: none;
        border: none;
        color: var(--M);
        font-size: 1rem;
        cursor: pointer;
    }

    .ov-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .75rem 1.2rem;
        border-bottom: 1px solid var(--S);
        gap: .8rem;
    }

    .ov-item-name {
        font-size: .88rem;
        font-weight: 600;
        color: var(--D);
    }

    .ov-item-sub {
        font-size: .74rem;
        color: #8c7a68;
        margin-top: .1rem;
    }

    .ov-item-right {
        display: flex;
        align-items: center;
        gap: .7rem;
        flex-shrink: 0;
    }

    .ov-price {
        font-weight: 700;
        color: var(--G);
        font-size: .9rem;
    }

    .ov-book {
        background: linear-gradient(135deg, var(--G), var(--G2));
        color: var(--D);
        border: none;
        padding: .38rem .9rem;
        border-radius: 5px;
        font-size: .74rem;
        font-weight: 700;
        cursor: pointer;
    }

    .ov-ft {
        padding: .9rem 1.4rem;
        background: #fdf8f0;
        border-top: 1px solid var(--S);
        display: flex;
        justify-content: flex-end;
    }

    .btn-cancel-sm {
        background: none;
        border: 1.5px solid var(--S);
        padding: .4rem 1.1rem;
        border-radius: 5px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        color: #8c7a68;
    }

        .btn-cancel-sm:hover {
            border-color: var(--D);
            color: var(--D);
        }

    .cm-ov {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.55);
        z-index: 2100;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

    .cm-box {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        max-width: 540px;
        width: 100%;
        box-shadow: 0 24px 60px rgba(0,0,0,.35);
    }

    .cm-hd {
        background: var(--D);
        padding: 1.1rem 1.4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cm-title {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
    }

    .cm-close {
        background: none;
        border: none;
        color: var(--M);
        font-size: 1rem;
        cursor: pointer;
    }

    .cm-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .cm-img-ph {
        width: 100%;
        height: 160px;
        background: var(--W);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .cm-img-ph i {
            font-size: 3rem;
            color: rgba(212,160,23,.25);
        }

    .cm-bd {
        padding: 1.2rem 1.4rem;
    }

    .cm-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        margin-bottom: .9rem;
    }

    .cm-tag {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .3rem .75rem;
        background: var(--W);
        border: 1px solid var(--S);
        border-radius: 6px;
        font-size: .76rem;
        font-weight: 600;
        color: var(--D);
    }

        .cm-tag i {
            color: var(--G);
        }

    .cm-desc {
        font-size: .82rem;
        color: #8a7560;
        line-height: 1.7;
    }

    .cm-ft {
        padding: .9rem 1.4rem;
        background: var(--W);
        border-top: 1px solid var(--S);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: .5rem;
    }

    /* HISTORY */
    .htbl {
        width: 100%;
        border-collapse: collapse;
    }

        .htbl thead tr {
            background: var(--D2);
        }

        .htbl th {
            padding: .8rem 1rem;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--G);
            text-align: left;
            border: none;
        }

        .htbl td {
            padding: .85rem 1rem;
            font-size: .84rem;
            border-bottom: 1px solid var(--S);
            vertical-align: middle;
        }

        .htbl tbody tr:hover {
            background: #fdfcfa;
        }

    .sb {
        padding: .24rem .72rem;
        border-radius: 4px;
        font-size: .66rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

        .sb.confirmed {
            background: #d1fae5;
            color: #065f46;
        }

        .sb.pending {
            background: #fef3c7;
            color: #92400e;
        }

        .sb.cancelled {
            background: #fee2e2;
            color: #991b1b;
        }

        .sb.playing {
            background: #dbeafe;
            color: #1e40af;
        }

        .sb.completed {
            background: #f0fdf4;
            color: #166534;
        }

    .empty-blk {
        text-align: center;
        padding: 3.5rem;
        color: #8c7a68;
    }

        .empty-blk i {
            font-size: 2.5rem;
            color: var(--S);
            display: block;
            margin-bottom: .75rem;
        }

    @@media(max-width: 1100px) {
        .hero-wrap {
            grid-template-columns: 1fr;
        }

        .fc .carousel-item img {
            height: 300px;
        }

        .i-stats {
            grid-template-columns: repeat(2,1fr);
        }

        .cp-body {
            grid-template-columns: 1fr;
        }

        .cp-info {
            border-left: none;
            border-top: 1px solid var(--G4);
        }

        .cal-layout {
            grid-template-columns: 1fr;
        }

        .cal-sidebar {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 768px) {
        .hero-wrap, .bsec, .bc {
            padding-left: 1.2rem;
            padding-right: 1.2rem;
        }

        .tabs {
            width: 100%;
        }

        .pay-in {
            flex-direction: column;
            gap: .8rem;
