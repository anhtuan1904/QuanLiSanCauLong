@model QuanLiSanCauLong.ViewModels.FacilityDetailsViewModel
@{
    ViewData["Title"] = Model.FacilityName;
}

<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --D3: #2e2010;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.18);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
        --M: rgba(255,255,255,.38);
        --M2: rgba(255,255,255,.08);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        background: var(--W);
        margin: 0;
    }

    .bc {
        background: var(--D);
        padding: .75rem 2rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        border-bottom: 1px solid var(--G4);
    }

        .bc a {
            color: var(--G2);
            text-decoration: none;
            font-size: .78rem;
            font-weight: 600;
            opacity: .8;
            display: flex;
            align-items: center;
            gap: .35rem;
        }

            .bc a:hover {
                opacity: 1;
            }

    .bc-sep {
        color: var(--M);
        font-size: .65rem;
    }

    .bc-cur {
        color: var(--M);
        font-size: .78rem;
        font-style: italic;
    }

    .hero {
        background: var(--D);
        position: relative;
        overflow: hidden;
    }

        .hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 55% 90% at 72% 50%, rgba(212,160,23,.07), transparent 65%);
            pointer-events: none;
        }

    .hero-wrap {
        max-width: 1380px;
        margin: 0 auto;
        padding: 2.2rem 2rem;
        display: grid;
        grid-template-columns: 1fr 370px;
        gap: 2.2rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .fc {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--G4);
    }

        .fc .carousel-item img {
            height: 400px;
            object-fit: cover;
            filter: brightness(.88);
        }

        .fc .carousel-control-prev, .fc .carousel-control-next {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(26,18,9,.72);
            border: 1px solid var(--G4);
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity .25s;
        }

        .fc:hover .carousel-control-prev, .fc:hover .carousel-control-next {
            opacity: 1;
        }

        .fc .carousel-control-prev {
            left: 10px;
        }

        .fc .carousel-control-next {
            right: 10px;
        }

    .carousel-indicators [data-bs-target] {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--G);
        border: 0;
        opacity: .45;
    }

    .carousel-indicators .active {
        opacity: 1;
    }

    .iblock {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .i-pills {
        display: flex;
        gap: .5rem;
        align-items: center;
    }

    .i-pill {
        background: var(--R);
        color: #fff;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        padding: .24rem .7rem;
        border-radius: 3px;
    }

    .i-open {
        background: rgba(16,185,129,.12);
        color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        padding: .24rem .7rem;
        border-radius: 3px;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

    .i-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.55rem,2.2vw,2.3rem);
        font-weight: 700;
        color: #fff;
        margin: 0;
        line-height: 1.15;
    }

    .i-addr {
        font-size: .82rem;
        color: var(--M);
        display: flex;
        align-items: flex-start;
        gap: .4rem;
    }

        .i-addr i {
            color: var(--R);
            margin-top: 2px;
            flex-shrink: 0;
        }

    .i-stats {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--G4);
        border: 1px solid var(--G4);
        border-radius: 8px;
        overflow: hidden;
    }

    .istat {
        background: var(--D2);
        padding: .9rem .5rem;
        text-align: center;
        transition: background .18s;
    }

        .istat:hover {
            background: var(--G3);
        }

    .sv {
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--G2);
        line-height: 1;
        margin-bottom: .28rem;
    }

    .sl {
        font-size: .56rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--M);
    }

    .i-desc {
        font-size: .82rem;
        line-height: 1.8;
        color: var(--M);
        border-left: 2px solid var(--G);
        padding-left: .9rem;
    }

    .i-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .27rem .78rem;
        background: var(--M2);
        border: 1px solid var(--G4);
        border-radius: 4px;
        color: rgba(255,255,255,.65);
        font-size: .72rem;
        font-weight: 500;
        transition: all .2s;
    }

        .chip:hover {
            background: var(--G3);
            border-color: var(--G);
            color: var(--G2);
        }

        .chip i {
            color: var(--G);
            font-size: .72rem;
        }

    .bsec {
        max-width: 1380px;
        margin: 0 auto;
        padding: 2.2rem 2rem 9rem;
    }

    .tabs {
        display: flex;
        gap: .35rem;
        background: var(--D);
        border: 1px solid var(--G4);
        border-radius: 8px;
        padding: .4rem;
        width: fit-content;
        margin-bottom: 1.6rem;
    }

    .tb {
        padding: .55rem 1.3rem;
        border: none;
        background: none;
        border-radius: 5px;
        font-family: 'Outfit', sans-serif;
        font-size: .8rem;
        font-weight: 600;
        color: var(--M);
        cursor: pointer;
        transition: all .22s;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .tb.on {
            background: linear-gradient(135deg, var(--G), var(--G2));
            color: var(--D);
        }

    .tp {
        display: none;
    }

        .tp.on {
            display: block;
        }

    .bcard {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.2rem;
    }

    .bcard-hd {
        background: var(--D);
        border-bottom: 1px solid var(--G4);
        padding: 1.1rem 1.6rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .9rem;
    }

    .bcard-title {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1.05rem;
        font-weight: 700;
        color: #fff;
    }

    .bcard-sub {
        font-size: .72rem;
        color: var(--M);
        display: flex;
        align-items: center;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .bcard-bd {
        padding: 1.4rem 1.6rem;
    }

    /* ── COURT CHIPS ── */
    .court-grid {
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
        margin-bottom: 1rem;
    }

    .c-chip {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .65rem 1rem;
        border: 1.5px solid var(--S);
        border-radius: 8px;
        cursor: pointer;
        background: #fff;
        transition: all .2s;
        position: relative;
        user-select: none;
    }

        .c-chip:hover {
            border-color: var(--G);
            background: var(--G3);
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(212,160,23,.15);
        }

        .c-chip.active {
            border-color: var(--G);
            background: linear-gradient(135deg, rgba(212,160,23,.14), rgba(245,200,66,.07));
            box-shadow: 0 3px 14px rgba(212,160,23,.22);
        }

    .c-badge {
        width: 34px;
        height: 34px;
        border-radius: 7px;
        background: linear-gradient(135deg, var(--G), var(--G2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: .72rem;
        color: var(--D);
        flex-shrink: 0;
        transition: all .2s;
    }

    .c-chip.active .c-badge {
        background: linear-gradient(135deg, var(--D), var(--D2));
        color: var(--G2);
    }

    .c-name {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: .9rem;
        color: var(--D);
    }

    .c-sub {
        font-size: .64rem;
        color: #8a7560;
        margin-top: .05rem;
    }

    .c-dot {
        position: absolute;
        top: 5px;
        right: 7px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--G);
        display: none;
    }

    .c-chip.active .c-dot {
        display: block;
    }

    .c-info-btn {
        margin-left: .3rem;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1.5px solid rgba(212,160,23,.4);
        background: rgba(212,160,23,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--G);
        font-size: .6rem;
        cursor: pointer;
        transition: all .15s;
        flex-shrink: 0;
    }

        .c-info-btn:hover {
            background: var(--G);
            color: var(--D);
        }

    /* ── COURT PANEL ── */
    .court-panel {
        background: var(--D);
        border: 1px solid var(--G4);
        border-radius: 8px;
        padding: 1rem 1.2rem;
        margin-bottom: 1.2rem;
        display: none;
        animation: fadeUp .22s ease;
    }

        .court-panel.show {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            flex-wrap: wrap;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .cp-img {
        width: 110px;
        height: 75px;
        border-radius: 7px;
        object-fit: cover;
        border: 1px solid var(--G4);
        flex-shrink: 0;
    }

    .cp-img-ph {
        width: 110px;
        height: 75px;
        border-radius: 7px;
        background: rgba(255,255,255,.05);
        border: 1px solid var(--G4);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .cp-img-ph i {
            color: rgba(255,255,255,.2);
            font-size: 1.8rem;
        }

    .cp-body {
        flex: 1;
    }

    .cp-name {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #fff;
        font-size: 1rem;
        margin-bottom: .45rem;
    }

    .cp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
    }

    .cp-tag {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        padding: .2rem .65rem;
        background: rgba(255,255,255,.07);
        border: 1px solid var(--G4);
        border-radius: 4px;
        font-size: .68rem;
        color: rgba(255,255,255,.65);
    }

        .cp-tag i {
            color: var(--G);
            font-size: .65rem;
        }

    .cp-desc {
        font-size: .76rem;
        color: rgba(255,255,255,.4);
        line-height: 1.65;
        margin-top: .5rem;
    }

    .cp-close {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(255,255,255,.07);
        border: 1px solid rgba(255,255,255,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: rgba(255,255,255,.4);
        font-size: .7rem;
        flex-shrink: 0;
        transition: all .15s;
        align-self: flex-start;
    }

        .cp-close:hover {
            background: rgba(220,38,38,.2);
            border-color: #dc2626;
            color: #dc2626;
        }

    /* ── WEEK NAV ── */
    .week-nav {
        display: flex;
        align-items: center;
        gap: .7rem;
        margin-bottom: 1.1rem;
        flex-wrap: wrap;
    }

    .wk-arr {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1.5px solid var(--S);
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #8a7560;
        transition: all .2s;
        font-size: .8rem;
    }

        .wk-arr:hover {
            border-color: var(--G);
            color: var(--G);
            background: var(--G3);
        }

    .wk-range {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: .9rem;
        color: var(--D);
    }

    .wk-today {
        padding: .35rem .9rem;
        background: var(--D);
        color: var(--G2);
        border: none;
        border-radius: 6px;
        font-family: 'Outfit', sans-serif;
        font-size: .72rem;
        font-weight: 700;
        cursor: pointer;
    }

        .wk-today:hover {
            background: var(--D2);
        }

    .date-jump {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-left: auto;
    }

        .date-jump label {
            font-size: .72rem;
            color: #8a7560;
            font-weight: 600;
            white-space: nowrap;
        }

        .date-jump input[type=date] {
            padding: .38rem .75rem;
            border: 1.5px solid var(--S);
            border-radius: 6px;
            font-family: 'Outfit', sans-serif;
            font-size: .8rem;
            color: var(--D);
            outline: none;
            cursor: pointer;
            transition: border-color .2s;
        }

            .date-jump input[type=date]:focus {
                border-color: var(--G);
            }

    /* ── LEGEND ── */
    .leg {
        display: flex;
        gap: 1.4rem;
        margin-bottom: 1.1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--S);
        align-items: center;
        flex-wrap: wrap;
    }

    .li {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .72rem;
        color: #8c7a68;
        font-weight: 500;
    }

    .ld {
        width: 12px;
        height: 12px;
        border-radius: 3px;
        border: 1.5px solid;
    }

        .ld.a {
            background: #fff;
            border-color: var(--S);
        }

        .ld.s {
            background: var(--D);
            border-color: var(--G);
        }

        .ld.b {
            background: #fef2f2;
            border-color: #fecaca;
        }

        .ld.p {
            background: #f5f5f5;
            border-color: #d1d5db;
        }

    .leg-tip {
        margin-left: auto;
        font-size: .68rem;
        color: #aaa;
        font-style: italic;
    }

    /* ── GRID ── */
    .wgrid-wrap {
        overflow-x: auto;
        border-radius: 8px;
        border: 1px solid var(--S);
    }

        .wgrid-wrap::-webkit-scrollbar {
            height: 5px;
        }

        .wgrid-wrap::-webkit-scrollbar-track {
            background: var(--S);
        }

        .wgrid-wrap::-webkit-scrollbar-thumb {
            background: var(--G);
            border-radius: 3px;
        }

    .wgrid {
        display: grid;
        min-width: 720px;
    }

    .wg-head {
        display: grid;
        grid-template-columns: 72px repeat(7,1fr);
        background: var(--D);
    }

    .wg-h0 {
        padding: .65rem .3rem;
    }

    .wg-hday {
        padding: .65rem .3rem;
        text-align: center;
        border-left: 1px solid rgba(255,255,255,.07);
    }

    .wg-dn {
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: rgba(255,255,255,.45);
    }

    .wg-dd {
        font-size: .9rem;
        font-weight: 700;
        color: var(--G2);
        margin-top: .1rem;
    }

    .wg-hday.today .wg-dn {
        color: var(--G);
    }

    .wg-hday.today .wg-dd {
        color: var(--G);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .wg-acts {
        display: grid;
        grid-template-columns: 72px repeat(7,1fr);
        background: #fafaf8;
        border-bottom: 1px solid var(--S);
    }

    .wg-a0 {
        padding: .28rem .3rem;
        font-size: .58rem;
        color: #bbb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-style: italic;
    }

    .wg-acol {
        padding: .2rem .18rem;
        display: flex;
        gap: .18rem;
        justify-content: center;
        border-left: 1px solid var(--S);
    }

    .da-btn {
        font-size: .56rem;
        font-weight: 700;
        padding: .18rem .38rem;
        border-radius: 4px;
        cursor: pointer;
        border: 1.5px solid;
        transition: all .15s;
        white-space: nowrap;
    }

    .da-sel {
        border-color: rgba(212,160,23,.4);
        color: var(--G);
        background: rgba(212,160,23,.05);
    }

        .da-sel:hover {
            background: var(--G3);
            border-color: var(--G);
        }

    .da-clr {
        border-color: rgba(220,38,38,.25);
        color: #dc2626;
        background: rgba(220,38,38,.03);
    }

        .da-clr:hover {
            background: rgba(220,38,38,.08);
        }

    .wg-body {
        display: grid;
        grid-template-columns: 72px repeat(7,1fr);
    }

    .wg-time {
        border-bottom: 1px solid var(--S);
        border-right: 1px solid var(--S);
        background: #fafaf8;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: .28rem;
        min-height: 56px;
    }

        .wg-time span {
            font-size: .64rem;
            font-weight: 700;
            color: #8a7560;
            white-space: nowrap;
            text-align: center;
            line-height: 1.4;
        }

    .wg-cell {
        border-bottom: 1px solid var(--S);
        border-left: 1px solid var(--S);
        padding: 3px;
    }

    .wg-slot {
        width: 100%;
        height: 52px;
        border-radius: 5px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .18s;
        background: #fff;
        border: 1.5px solid transparent;
        position: relative;
    }

        .wg-slot:hover:not(.bk):not(.past):not(.no-data) {
            border-color: var(--G);
            background: var(--G3);
            transform: scale(1.03);
            z-index: 1;
            box-shadow: 0 2px 8px rgba(212,160,23,.2);
        }

        .wg-slot.sel {
            background: var(--D) !important;
            border-color: var(--G) !important;
            box-shadow: 0 2px 10px rgba(212,160,23,.28);
        }

        .wg-slot.bk {
            background: #fef2f2;
            border-color: #fecaca;
            cursor: not-allowed;
        }

        .wg-slot.past {
            background: #f5f5f5;
            cursor: not-allowed;
            opacity: .5;
        }

        .wg-slot.no-data {
            background: transparent;
            border: none;
            cursor: default;
        }

        .wg-slot.sel::after {
            content: '✓';
            position: absolute;
            top: 3px;
            right: 5px;
            font-size: .6rem;
            color: var(--G2);
            font-weight: 900;
        }

    .st-t {
        font-size: .7rem;
        font-weight: 700;
        color: var(--D);
        line-height: 1.1;
        text-align: center;
    }

    .st-p {
        font-size: .6rem;
        color: #8a7560;
        margin-top: .1rem;
    }

    .wg-slot.sel .st-t {
        color: var(--G2);
    }

    .wg-slot.sel .st-p {
        color: rgba(255,255,255,.45);
    }

    .bk-lbl {
        font-size: .57rem;
        font-weight: 700;
        color: #dc2626;
    }

    .past-lbl {
        font-size: .57rem;
        color: #bbb;
    }

    .no-court-msg {
        text-align: center;
        padding: 3rem;
        color: #8a7560;
    }

        .no-court-msg i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: .75rem;
            opacity: .25;
        }

    .empty-blk {
        text-align: center;
        padding: 3.5rem;
        color: #8c7a68;
    }

        .empty-blk i {
            font-size: 2.5rem;
            color: var(--S);
            display: block;
            margin-bottom: .75rem;
        }

    /* ── HISTORY ── */
    .htbl {
        width: 100%;
        border-collapse: collapse;
    }

        .htbl thead tr {
            background: var(--D2);
        }

        .htbl th {
            padding: .8rem 1rem;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--G);
