        font-size: .9rem;
        font-weight: 800;
        letter-spacing: .03em;
        padding: .82rem 2rem;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: all .22s;
        white-space: nowrap;
    }

        .btn-book:hover {
