@section Scripts {
    <script>
        // ══════════════════════════════════════════════════════
        // DATA FROM RAZOR
        // ══════════════════════════════════════════════════════
        var FAC = @Model.FacilityId;
        var COURTS_DATA = {};

        @foreach (var court in Model.Courts)
        {
                        var imgs = (court.CourtImages?
                                                                                        .OrderBy(i => i.IsPrimary ? 0 : 1)
                                                                                        .ThenBy(i => i.DisplayOrder)
                                                                                        .Select(i => i.ImagePath)
                                                                                        .ToList()) ?? new List<string>();
                        if (!imgs.Any() && !string.IsNullOrEmpty(court.ImagePath))
                                            imgs.Add(court.ImagePath);

                        var cJson = System.Text.Json.JsonSerializer.Serialize(new
                        {
                                            id = court.CourtId,
                                            name = court.CourtNumber ?? "",
                                            images = imgs,
                                            courtType = court.CourtType,
                                            courtTypeLabel = court.CourtTypeLabel,
                                            surfaceType = court.SurfaceType,
                                            surfaceTypeLabel = court.SurfaceTypeLabel,
                                            floorNumber = court.FloorNumber,
                                            hasLighting = court.HasLighting,
                                            hasAC = court.HasAC,
                                            hourlyRate = court.HourlyRate,
                                            status = court.Status,
                                            statusLabel = court.StatusLabel,
                                            description = court.Description,
                                            detailUrl = Url.Action("Details", "Court", new { id = court.CourtId }),
                                            slots = court.Slots.Select(s => new
                                            {
                                                                st = s.StartTime.ToString(@"hh\:mm"),
                                                                et = s.EndTime.ToString(@"hh\:mm"),
                                                                price = (int)s.Price,
                                                                isBooked = s.IsBooked
                                            }).ToArray()
                        });
                        @:COURTS_DATA[@court.CourtId] = @Html.Raw(cJson);
        }

        var TODAY_STR    = '@DateTime.Today.ToString("yyyy-MM-dd")';
        var SEL_DATE_STR = '@Model.SelectedDate.ToString("yyyy-MM-dd")';

        // ── State ──
        var activeCid = null;
        var calYear, calMonth;   // 0-based month
        var selDate = null;      // currently expanded date ISO string

        // ── Month slot cache: key = "cid_yyyy_mm" → { date: {total,booked,free} } ──
        var _monthCache = {};

        async function loadMonthSlots(cid, year, month) {
            var key = cid + '_' + year + '_' + month;
            if (_monthCache[key]) { renderCalendar(); return; }
            try {
                var r    = await fetch('/Booking/GetMonthSlots?courtId=' + cid + '&year=' + year + '&month=' + (month + 1));
                var data = await r.json();
                if (data.success) {
                    var map = {};
                    (data.days || []).forEach(function(d) { map[d.date] = d; });
                    _monthCache[key] = map;
                }
            } catch(e) { _monthCache[key] = {}; }
            renderCalendar();
        }

        function _getMonthMap(cid, year, month) {
            return _monthCache[cid + '_' + year + '_' + month] || {};
        }
        var sel = [];

        // ── Date utils ──
        function parseLocal(s){ var p=s.split('-'); return new Date(+p[0],+p[1]-1,+p[2]); }
        function toISO(d){ return d.getFullYear()+'-'+p2(d.getMonth()+1)+'-'+p2(d.getDate()); }
        function p2(n){ return String(n).padStart(2,'0'); }
        function addDays(d,n){ var r=new Date(d); r.setDate(r.getDate()+n); return r; }
        var MONTHS_VI=['Tháng 1','Tháng 2','Tháng 3','Tháng 4','Tháng 5','Tháng 6','Tháng 7','Tháng 8','Tháng 9','Tháng 10','Tháng 11','Tháng 12'];
        var DAYS_VI=['T2','T3','T4','T5','T6','T7','CN'];

        // ── Init ──
        document.addEventListener('DOMContentLoaded', function(){
            // Tab switching
            document.querySelectorAll('.tb').forEach(function(b){
                b.addEventListener('click', function(){
                    document.querySelectorAll('.tb').forEach(x=>x.classList.remove('on'));
                    document.querySelectorAll('.tp').forEach(x=>x.classList.remove('on'));
                    this.classList.add('on');
                    document.getElementById(this.dataset.tab).classList.add('on');
                });
            });
                        // ── Auto-activate tab Đánh giá nếu URL có #reviews ──
            (function() {
                if (window.location.hash !== '#reviews') return;
                document.querySelectorAll('.tb').forEach(function(b){ b.classList.remove('on'); });
                document.querySelectorAll('.tp').forEach(function(p){ p.classList.remove('on'); });
                var tab = document.querySelector('[data-tab="t-reviews"]');
                if (tab) tab.classList.add('on');
                var panel = document.getElementById('t-reviews');
                if (panel) panel.classList.add('on');
                setTimeout(function() {
                    var target = document.getElementById('reviews');
                    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 200);
            })();
            // Hero carousel
            var fc=document.getElementById('fc');
            if(fc) new bootstrap.Carousel(fc,{interval:3500,wrap:true});
            // Init calendar to today
            var today = parseLocal(TODAY_STR);
            calYear  = today.getFullYear();
            calMonth = today.getMonth();
            updateMonthLabel();
            document.getElementById('jumpMonth').value = calYear+'-'+p2(calMonth+1);
        });

        // ══════════════════════════════════════════════════════
        // MONTH NAV
        // ══════════════════════════════════════════════════════
        function navMonth(dir){
            calMonth += dir;
            if(calMonth > 11){ calMonth=0; calYear++; }
            if(calMonth < 0) { calMonth=11; calYear--; }
            selDate = null;
            updateMonthLabel();
            document.getElementById('jumpMonth').value = calYear+'-'+p2(calMonth+1);
            if(activeCid) loadMonthSlots(activeCid, calYear, calMonth);
            else renderCalendar();
            hideSlotsPanel();
        }
        function goToday(){
            var t=parseLocal(TODAY_STR);
            calYear=t.getFullYear(); calMonth=t.getMonth();
            selDate=null;
            updateMonthLabel();
            document.getElementById('jumpMonth').value = calYear+'-'+p2(calMonth+1);
            renderCalendar();
            hideSlotsPanel();
        }
        function jumpToMonth(v){
            if(!v) return;
            var p=v.split('-'); calYear=+p[0]; calMonth=+p[1]-1;
            selDate=null;
            updateMonthLabel();
            if(activeCid) loadMonthSlots(activeCid, calYear, calMonth);
            else renderCalendar();
            hideSlotsPanel();
        }
        function updateMonthLabel(){
            var el=document.getElementById('mnavLabel');
            el.innerHTML=MONTHS_VI[calMonth]+' <em>'+calYear+'</em>';
        }

        // ══════════════════════════════════════════════════════
        // RENDER MONTHLY CALENDAR
        // ══════════════════════════════════════════════════════
        function renderCalendar(){
            if(!activeCid){ return; }
            document.getElementById('calPlaceholder').style.display='none';
            document.getElementById('calInner').style.display='block';

            // Trigger API load nếu chưa có cache cho tháng này
            var cacheKey = activeCid+'_'+calYear+'_'+calMonth;
            if(!_monthCache[cacheKey]){
                loadMonthSlots(activeCid, calYear, calMonth); // async, sẽ gọi renderCalendar() lại khi xong
                return;
            }

            var today = parseLocal(TODAY_STR);
            var cd = COURTS_DATA[activeCid] || {};
            var rawSlots = cd.slots || [];

            // Build head
            var headH = DAYS_VI.map(function(d){ return '<div class="cal-hc">'+d+'</div>'; }).join('');
            document.getElementById('calHead').innerHTML = headH;

            // Build grid cells
            var mFirst = new Date(calYear, calMonth, 1);
            var mLast  = new Date(calYear, calMonth+1, 0);
            var dow = mFirst.getDay(); // 0=Sun
            var offset = dow===0 ? 6 : dow-1;
            var gridStart = addDays(mFirst, -offset);
            var totalCells = Math.ceil((offset + mLast.getDate()) / 7) * 7;

            var freeCount = rawSlots.filter(function(s){ return !s.isBooked; }).length;
            var bkCount   = rawSlots.filter(function(s){ return s.isBooked; }).length;

            // Update sidebar stats — dùng data ngày được chọn (hoặc hôm nay) từ monthMap
            var mMap    = _getMonthMap(activeCid, calYear, calMonth);
            var statDay = selDate ? mMap[selDate] : mMap[TODAY_STR];
            if(statDay){
                document.getElementById('statTotal').textContent  = statDay.total  || '—';
                document.getElementById('statBooked').textContent = statDay.booked || '0';
                document.getElementById('statFree').textContent   = statDay.free   || '0';
            } else {
                document.getElementById('statTotal').textContent  = rawSlots.length || '—';
                document.getElementById('statBooked').textContent = bkCount || '0';
                document.getElementById('statFree').textContent   = freeCount || '0';
            }
            document.getElementById('statPrice').textContent  = cd.hourlyRate ? cd.hourlyRate.toLocaleString('vi-VN')+'đ/h' : '—';

            var H = '';
            for(var i=0; i<totalCells; i++){
                var d = addDays(gridStart, i);
                var iso = toISO(d);
                var inMonth = d.getMonth()===calMonth && d.getFullYear()===calYear;
                var isPast  = d < today;
                var isToday = iso===TODAY_STR;
                var isSel   = iso===selDate;

                var cls = 'cal-day';
                if(!inMonth) cls+=' other-month';
                else if(isSel) cls+=' selected-day';
                else if(isToday) cls+=' today-day';
                if(isPast && inMonth) cls+=' past-day';

                // Màu ngày theo trạng thái slot (chỉ ngày tương lai trong tháng)
                if(inMonth && !isPast && !isSel){
                    var mMap2 = _getMonthMap(activeCid, calYear, calMonth);
                    var dInfo2 = mMap2[iso];
                    if(dInfo2 && dInfo2.total > 0){
                        if(dInfo2.free === 0)
                            cls += ' day-full';
                        else if(dInfo2.free / dInfo2.total < 0.3)
                            cls += ' day-low';
                        else
                            cls += ' day-open';
                    }
                }

                var numCls = 'cal-day-num'+(isToday?' today-num':'');
                var numColor = isSel ? 'color:var(--G2)' : (isToday ? 'color:var(--G)' : '');

                // Slot indicators từ API GetMonthSlots — mọi ngày trong tháng
                var slotsH = '';
                if(inMonth && !isPast){
                    var mMap  = _getMonthMap(activeCid, calYear, calMonth);
                    var dInfo = mMap[iso];
                    if(dInfo){
                        if(dInfo.free > 0)
                            slotsH += '<div class="cal-slot-bar free"><i class="bi bi-circle-fill" style="font-size:.4rem;margin-right:.2rem"></i>'+dInfo.free+' trống</div>';
                        if(dInfo.booked > 0)
                            slotsH += '<div class="cal-slot-bar full"><i class="bi bi-circle-fill" style="font-size:.4rem;margin-right:.2rem"></i>'+dInfo.booked+' đặt</div>';
                    }
                }
                // Show selection badges in day cell
                var selInDay = sel.filter(function(s){ return s.date===iso; });
                if(selInDay.length && inMonth && !isPast){
                    slotsH = '<div class="cal-slot-bar" style="background:rgba(212,160,23,.18);color:#92660a"><i class="bi bi-check2 me-1"></i>'+selInDay.length+' đã chọn</div>';
                }

                var click = (inMonth&&!isPast) ? ' onclick="clickDay(\''+iso+'\',\''+d.getDate()+'/'+p2(d.getMonth()+1)+'/'+d.getFullYear()+'\')"' : '';
                H += '<div class="'+cls+'"'+click+'>'+
                    '<div class="cal-day-num" style="'+numColor+'">'+
                        d.getDate()+
                        '<span class="cal-today-pip"></span>'+
                    '</div>'+
                    '<div class="cal-slots">'+slotsH+'</div>'+
                '</div>';
            }
            document.getElementById('calGrid').innerHTML = H;
        }

        // ══════════════════════════════════════════════════════
        // DAY CLICK — show time slots panel
        // ══════════════════════════════════════════════════════
        async function clickDay(iso, label){
            if(!activeCid) return;
            selDate = iso;
            renderCalendar(); // re-render to update selected highlight

            // Load day slots từ API nếu chưa có cache
            var _dayKey = activeCid + '_day_' + iso;
            if(!window._daySlotCache) window._daySlotCache = {};
            if(!window._daySlotCache[_dayKey]){
                try {
                    var r    = await fetch('/Booking/GetTimeSlots?courtId=' + activeCid + '&date=' + iso);
                    var data = await r.json();
                    if(data.success) window._daySlotCache[_dayKey] = data.slots || [];
                } catch(e) {}
            }

            renderSlotsPanel(iso, label);
            // Scroll to slots panel
            setTimeout(function(){
                var p=document.getElementById('slotsPanel');
                if(p) p.scrollIntoView({behavior:'smooth',block:'nearest'});
            }, 100);
        }

        // ══════════════════════════════════════════════════════
        // TIMELINE CONFIG  05:00 – 23:00, step = 30 min
        // ══════════════════════════════════════════════════════
        var TL_START  = 5 * 60;   // 300 min from midnight
        var TL_END    = 23 * 60;  // 1380
        var TL_STEP   = 30;
        var TL_SLOTS  = (TL_END - TL_START) / TL_STEP; // 36 cells

        // tlSel = { cid, date, startMin, endMin } — one per day-court combo
        var tlSel = {};   // key: cid+'_'+date

        function minToHHMM(m){ return p2(Math.floor(m/60))+':'+p2(m%60); }
        function hhmmToMin(s){ var p=s.split(':'); return +p[0]*60+(+p[1]||0); }

        // Day slot cache: key = "cid_iso" → array of {startTime, endTime, isAvailable, price}
        var _daySlotCache = {};

        function _loadDaySlots(cid, iso, cb) {
            var key = cid + '_' + iso;
            if (_daySlotCache[key]) { cb(_daySlotCache[key]); return; }
            fetch('/Booking/GetTimeSlots?courtId=' + cid + '&date=' + iso)
                .then(function(r){ return r.json(); })
                .then(function(data){
                    if(data.success) _daySlotCache[key] = data.slots || [];
                    cb(_daySlotCache[key] || []);
                })
                .catch(function(){ cb([]); });
        }

        function _refreshTimelineCells(iso, bookedRanges) {
            for(var i = 0; i < TL_SLOTS; i++){
                var el = document.getElementById('tlc_'+iso+'_'+i);
                if(!el) continue;
                var m = TL_START + i*TL_STEP;
                var isBooked = bookedRanges.some(function(r){ return m >= r.st && m < r.et; });
                if(isBooked && !el.classList.contains('past') && !el.classList.contains('sel')){
                    el.classList.add('booked');
                    // Remove drag handlers from booked cells
                    el.onmousedown  = null;
                    el.onmouseenter = null;
                }
            }
        }

        // dragState
        var _drag = { active:false, downIdx:null, date:null };

        function renderSlotsPanel(iso, label){
            var panel = document.getElementById('slotsPanel');
            panel.style.display = 'block';
            var cd = COURTS_DATA[activeCid] || {};
            var rawSlots = cd.slots || [];
            var today = parseLocal(TODAY_STR);
            var d = parseLocal(iso);
            var isPast = d < today;

            // Dùng GetTimeSlots API để lấy booked ranges cho ngày bất kỳ
            var bookedRanges = [];
            var priceSlots   = rawSlots.length ? rawSlots : [];
            // Load async — hiển thị panel trước, cập nhật booked sau
            _loadDaySlots(activeCid, iso, function(slots){
                bookedRanges = slots
                    .filter(function(s){ return !s.isAvailable; })
                    .map(function(s){ return { st: hhmmToMin(s.startTime), et: hhmmToMin(s.endTime) }; });
                // Re-render cells với booked data
                _refreshTimelineCells(iso, bookedRanges);
            });

            // Duration preset selector
            var presets = [
                {label:'30 phút', mins:30},
                {label:'1 giờ',   mins:60},
                {label:'1.5 giờ', mins:90},
                {label:'2 giờ',   mins:120},
                {label:'3 giờ',   mins:180},
            ];
            var curPreset = _getDurPreset(iso);
            var presetsH = '<div class="tl-presets"><span class="tl-preset-label"><i class="bi bi-stopwatch me-1"></i>Chọn nhanh:</span>'+
                presets.map(function(p){
                    return '<button class="tl-preset'+(curPreset===p.mins?' on':'')+
                        '" onclick="applyPreset(\''+iso+'\','+p.mins+',\''+label+'\')">'+p.label+'</button>';
                }).join('')+'</div>';

            if(isPast){
                panel.innerHTML =
                    '<div class="slots-panel-hd">'+
                        '<span class="slots-panel-title"><i class="bi bi-clock"></i> Khung giờ <span class="slots-panel-date">'+label+'</span></span>'+
                    '</div>'+
                    '<div class="slots-empty"><i class="bi bi-calendar-x" style="font-size:1.5rem;display:block;margin-bottom:.5rem;opacity:.3;"></i>Ngày đã qua</div>';
                return;
            }

            // Build timeline header ticks (every 30 min, label only on full hours)
            var ticksH = '';
            for(var i=0; i<TL_SLOTS; i++){
                var m = TL_START + i*TL_STEP;
                var isHour = (m % 60 === 0);
                ticksH += '<div class="tl-htick'+(isHour?' hour-mark':'')+'">'+
                    (isHour ? minToHHMM(m) : '<span style="opacity:.4">:30</span>')+
                '</div>';
            }

            // Build body row (one row, 36 cells)
            var cellsH = '';
            var existingSel = tlSel[activeCid+'_'+iso];
            for(var i=0; i<TL_SLOTS; i++){
                var m = TL_START + i*TL_STEP;
                var isHourStart = (m % 60 === 0);
                var isBooked = bookedRanges.some(function(r){ return m >= r.st && m < r.et; });
                var isSel = existingSel && m >= existingSel.startMin && m < existingSel.endMin;
                var isNowPast = isPast || (iso===TODAY_STR && m < _nowMin());

                var cls = 'tl-cell';
                if(isHourStart) cls+=' hour-start';
                if(isNowPast)   cls+=' past';
                else if(isBooked) cls+=' booked';
                else if(isSel)    cls+=' sel';

                var drag = (!isNowPast && !isBooked)
                    ? ' onmousedown="tlDown('+i+',\''+iso+'\',\''+label+'\')"'+
                      ' onmouseenter="tlEnter('+i+')"'+
                      ' ontouchstart="tlTouchStart('+i+',\''+iso+'\',\''+label+'\')" ontouchmove="tlTouchMove(event)"'
                    : '';

                cellsH += '<div id="tlc_'+iso+'_'+i+'" class="'+cls+'"'+drag+'></div>';
            }

            panel.innerHTML =
                '<div class="slots-panel-hd">'+
                    '<span class="slots-panel-title"><i class="bi bi-clock"></i> Khung giờ <span class="slots-panel-date">'+label+'</span></span>'+
                    '<span style="font-size:.68rem;color:var(--M)"><i class="bi bi-hand-index me-1"></i>Kéo để chọn khoảng thời gian</span>'+
                '</div>'+
                '<div class="tl-wrap">'+
                    presetsH+
                    '<div class="tl-grid-wrap">'+
                        '<div class="tl-grid">'+
                            '<div class="tl-labels">'+
                                '<div class="tl-lbl-top"></div>'+
                                '<div class="tl-lbl">Giờ</div>'+
                            '</div>'+
                            '<div class="tl-cells" id="tlCells_'+iso+'">'+
                                '<div class="tl-hrow">'+ticksH+'</div>'+
                                '<div class="tl-row" id="tlRow_'+iso+'">'+cellsH+'</div>'+
                            '</div>'+
                        '</div>'+
                    '</div>'+
                    '<div id="tlSummary_'+iso+'"></div>'+
                '</div>';

            renderTlSummary(iso);
            _bindMouseUp();
        }

        function _nowMin(){
            var n=new Date(); return n.getHours()*60+n.getMinutes();
        }
        function _getDurPreset(iso){
            var s=tlSel[activeCid+'_'+iso];
            return s ? (s.endMin-s.startMin) : 0;
        }

        // ── Drag logic ──
        function tlDown(idx, iso, label){
            if(!activeCid) return;
            _drag.active=true; _drag.downIdx=idx; _drag.date=iso; _drag.label=label;
            _applyDrag(idx, idx, iso);
        }
        function tlEnter(idx){
            if(!_drag.active) return;
            var lo=Math.min(_drag.downIdx,idx), hi=Math.max(_drag.downIdx,idx);
            _applyDrag(lo, hi, _drag.date);
        }
        function tlTouchStart(idx, iso, label){
            tlDown(idx, iso, label);
        }
        function tlTouchMove(e){
            if(!_drag.active) return;
            e.preventDefault();
            var touch=e.touches[0];
            var el=document.elementFromPoint(touch.clientX,touch.clientY);
            if(el&&el.id&&el.id.startsWith('tlc_')){
                var parts=el.id.split('_');
                var idx=parseInt(parts[parts.length-1]);
                if(!isNaN(idx)) tlEnter(idx);
            }
        }
        function _bindMouseUp(){
            document.removeEventListener('mouseup',_onUp);
            document.addEventListener('mouseup',_onUp);
        }
        function _onUp(){
            if(_drag.active){ _drag.active=false; commitDrag(_drag.date, _drag.label); }
        }
        function _applyDrag(lo, hi, iso){
            // Visual only — highlight drag range
            for(var i=0;i<TL_SLOTS;i++){
                var el=document.getElementById('tlc_'+iso+'_'+i);
                if(!el) continue;
                var inRange = i>=lo && i<=hi;
                if(inRange && !el.classList.contains('past') && !el.classList.contains('booked')){
                    el.classList.add('dragging');
                } else {
                    el.classList.remove('dragging');
                }
            }
        }
        function commitDrag(iso, label){
            // Find dragging cells → compute range
            var lo=TL_SLOTS, hi=-1;
            for(var i=0;i<TL_SLOTS;i++){
                var el=document.getElementById('tlc_'+iso+'_'+i);
                if(el && el.classList.contains('dragging')){ if(i<lo)lo=i; if(i>hi)hi=i; el.classList.remove('dragging'); }
            }
            if(hi<0) return;
            var startMin = TL_START + lo*TL_STEP;
            var endMin   = TL_START + (hi+1)*TL_STEP;
            _setTlSel(iso, startMin, endMin, label);
        }

        function applyPreset(iso, mins, label){
            // Apply from existing start, or from now rounded to next 30m
            var ex = tlSel[activeCid+'_'+iso];
            var startMin = ex ? ex.startMin : _roundUp30(_nowMin()+5);
            if(startMin < TL_START) startMin = TL_START;
            var endMin = startMin + mins;
            if(endMin > TL_END) { endMin=TL_END; startMin=endMin-mins; }
            _setTlSel(iso, startMin, endMin, label);
            renderSlotsPanel(iso, label);
        }
        function _roundUp30(m){ return Math.ceil(m/30)*30; }

        function _setTlSel(iso, startMin, endMin, label){
            var cd = COURTS_DATA[activeCid]||{};
            var rawSlots = cd.slots||[];
            // Check if any booked cell overlaps
            // Dùng cache từ _daySlotCache
            var cachedDay   = _daySlotCache[activeCid+'_'+iso] || [];
            var bookedRanges = cachedDay
                .filter(function(s){ return !s.isAvailable; })
                .map(function(s){ return { st: hhmmToMin(s.startTime), et: hhmmToMin(s.endTime) }; });
            var hasConflict = bookedRanges.some(function(r){ return startMin<r.et && endMin>r.st; });
            if(hasConflict){ alert('Khoảng giờ bạn chọn có ô đã được đặt. Vui lòng chọn lại.'); return; }

            // Compute price
            var totalMins = endMin - startMin;
            var price = _calcPrice(cd, rawSlots, iso, startMin, endMin);

            tlSel[activeCid+'_'+iso] = { cid:activeCid, date:iso, startMin:startMin, endMin:endMin, price:price, label:label };

            // Update sel array (replace any same-day entry)
            sel = sel.filter(function(s){ return !(s.cid===activeCid && s.date===iso); });
            sel.push({
                key: activeCid+'_'+iso,
                cid: activeCid,
                cname: cd.name||'',
                date: iso,
                st: minToHHMM(startMin),
                et: minToHHMM(endMin),
                price: price,
                minutes: totalMins,
                el: null
            });

            // Re-render cells
            for(var i=0;i<TL_SLOTS;i++){
                var m = TL_START + i*TL_STEP;
                var el = document.getElementById('tlc_'+iso+'_'+i);
                if(!el) continue;
                var isSel = m>=startMin && m<endMin;
                el.classList.toggle('sel', isSel);
                // Add duration badge to middle cell of selection
                el.innerHTML='';
                var midIdx = Math.floor(((startMin-TL_START)/TL_STEP) + ((endMin-startMin)/TL_STEP)/2);
                if(isSel && i===midIdx){
                    var badge=document.createElement('div');
                    badge.className='tl-dur-badge';
                    badge.textContent=_fmtDur(totalMins);
                    el.appendChild(badge);
                }
            }
            renderTlSummary(iso);
            refreshBar();
            renderCalendar();
            updateSelSummary();
        }

        function _calcPrice(cd, rawSlots, iso, startMin, endMin){
            // Ưu tiên dùng slot từ API cache per-day
            var _dk = activeCid + '_day_' + iso;
            var apiSlots = (window._daySlotCache && window._daySlotCache[_dk]) || [];
            if(apiSlots.length){
                var total = 0;
                for(var m = startMin; m < endMin; m += TL_STEP){
                    var hhmm = minToHHMM(m);
                    var slot = apiSlots.find(function(s){ return s.startTime <= hhmm && s.endTime > hhmm; });
                    total += slot ? slot.price * TL_STEP / 60 : 0;
                }
                return Math.round(total);
            }
            // If server gave price slots, use them for prorated pricing
            if(rawSlots.length){
                var total=0;
                for(var m=startMin;m<endMin;m+=TL_STEP){
                    var hhmm=minToHHMM(m);
                    var slot=rawSlots.find(function(s){return s.st<=hhmm&&s.et>hhmm;});
                    total += slot ? slot.price * TL_STEP/60 : 0;
                }
                return Math.round(total);
            }
            // Fallback: use hourlyRate
            var rate = cd.hourlyRate||0;
            return Math.round(rate * (endMin-startMin)/60);
        }
        function _fmtDur(mins){
            var h=Math.floor(mins/60), m=mins%60;
            return h>0 ? (h+'g'+(m?m+'p':'')) : m+'p';
        }

        function renderTlSummary(iso){
            var box = document.getElementById('tlSummary_'+iso);
            if(!box) return;
            var s = tlSel[activeCid+'_'+iso];
            if(!s){ box.innerHTML=''; return; }
            var dur = s.endMin-s.startMin;
            box.innerHTML =
                '<div class="tl-summary">'+
                    '<div class="tl-sum-time"><em>'+minToHHMM(s.startMin)+'</em> → <em>'+minToHHMM(s.endMin)+'</em></div>'+
                    '<span class="tl-sum-dur"><i class="bi bi-stopwatch me-1"></i>'+_fmtDur(dur)+'</span>'+
                    '<span class="tl-sum-price">'+s.price.toLocaleString('vi-VN')+'đ <span>/ lượt</span></span>'+
                    '<div class="tl-sum-actions">'+
                        '<button class="tl-btn-clr" onclick="clearDayTl(\''+iso+'\',\''+s.label+'\')"><i class="bi bi-x me-1"></i>Xóa</button>'+
                        '<button class="tl-btn-book" onclick="bookTl(\''+iso+'\')"><i class="bi bi-check-circle-fill"></i> Đặt ngay</button>'+
                    '</div>'+
                '</div>';
        }

        function clearDayTl(iso, label){
            delete tlSel[activeCid+'_'+iso];
            sel = sel.filter(function(s){ return !(s.cid===activeCid && s.date===iso); });
            renderSlotsPanel(iso, label);
            refreshBar(); renderCalendar(); updateSelSummary();
        }

        function bookTl(iso){
            var s = tlSel[activeCid+'_'+iso];
            if(!s) return;
            window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+minToHHMM(s.startMin)+'&endTime='+minToHHMM(s.endMin);
        }

        function hideSlotsPanel(){
            document.getElementById('slotsPanel').style.display='none';
        }

        // ══════════════════════════════════════════════════════
        // COURT SELECTION
        // ══════════════════════════════════════════════════════
        function selectCourt(cid, evt){
            if(evt) evt.stopPropagation();
            if(activeCid===cid){
                activeCid=null;
                document.querySelectorAll('.c-chip').forEach(c=>c.classList.remove('active'));
                document.getElementById('courtPanel').classList.remove('show');
                document.getElementById('calSub').innerHTML='<i class="bi bi-arrow-up-circle"></i> Vui lòng chọn sân ở bước 1';
                document.getElementById('calPlaceholder').style.display='flex';
                document.getElementById('calInner').style.display='none';
                hideSlotsPanel();
                selDate=null;
                return;
            }
            activeCid=cid;
            document.querySelectorAll('.c-chip').forEach(c=>c.classList.remove('active'));
            document.getElementById('chip-'+cid).classList.add('active');
            sel=sel.filter(function(s){ return s.cid===cid; });
            // Clear timeline selections for other courts
            Object.keys(tlSel).forEach(function(k){ if(parseInt(k.split('_')[0])!==cid) delete tlSel[k]; });
            refreshBar();
            showCourtPanel(cid);
            var cd=COURTS_DATA[cid];
            document.getElementById('calSub').innerHTML='<i class="bi bi-grid-3x3-gap" style="color:var(--G)"></i> Lịch sân: <strong style="color:var(--G2)">'+(cd?cd.name:'')+'</strong>';
            selDate=null;
            hideSlotsPanel();
            renderCalendar();
        }

        // ══════════════════════════════════════════════════════
        // COURT DETAIL PANEL
        // ══════════════════════════════════════════════════════
        function showCourtPanel(cid){
            var cd=COURTS_DATA[cid]; if(!cd) return;
            var imgs=cd.images&&cd.images.length?cd.images:[];
            var carId='cp-car-'+cid;

            var typePill=cd.courtType
                ?'<span class="cp-pill cp-pill-type">'+(cd.courtType==='Indoor'?'Trong nhà':'Ngoài trời')+'</span>':'';
            var statusPill=cd.status==='Maintenance'
                ?'<span class="cp-pill cp-pill-maint"><i class="bi bi-tools"></i> Bảo trì</span>'
                :'<span class="cp-pill cp-pill-open"><i class="bi bi-circle-fill" style="font-size:.35rem"></i> Sẵn sàng</span>';

            // Gallery
            var imgH='';
            if(imgs.length===0){
                imgH='<div style="height:255px;background:linear-gradient(135deg,var(--D3),var(--D2));display:flex;align-items:center;justify-content:center;border-radius:10px;border:1px solid var(--G4)"><i class="bi bi-image" style="font-size:3rem;color:rgba(212,160,23,.15)"></i></div>';
            } else {
                var indicators=imgs.map(function(_,i){return '<button type="button" data-bs-target="#'+carId+'" data-bs-slide-to="'+i+'" class="'+(i===0?'active':'')+'"></button>';}).join('');
                var slides=imgs.map(function(src,i){return '<div class="carousel-item'+(i===0?' active':'')+'"><img src="'+src+'" class="d-block w-100" alt="'+cd.name+'"></div>';}).join('');
                imgH='<div id="'+carId+'" class="carousel slide cp-car"><div class="carousel-indicators">'+indicators+'</div><div class="carousel-inner">'+slides+'</div>'+
                    '<button class="carousel-control-prev" type="button" data-bs-target="#'+carId+'" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>'+
                    '<button class="carousel-control-next" type="button" data-bs-target="#'+carId+'" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button></div>';
                // Thumbnails
                if(imgs.length>1){
                    imgH+='<div class="cp-thumbs">'+imgs.map(function(src,i){return '<img src="'+src+'" class="cp-thumb'+(i===0?' active':'')+'" onclick="switchThumb(\''+carId+'\','+i+',this)">';}).join('')+'</div>';
                }
            }

            // Tags
            var tArr=[];
            if(cd.courtTypeLabel)   tArr.push({i:'bi-house',         t:cd.courtTypeLabel});
            if(cd.surfaceTypeLabel) tArr.push({i:'bi-layers',         t:cd.surfaceTypeLabel});
            if(cd.floorNumber)      tArr.push({i:'bi-building',       t:'Tầng '+cd.floorNumber});
            if(cd.hasLighting)      tArr.push({i:'bi-lightbulb-fill', t:'Đèn chiếu sáng'});
            if(cd.hasAC)            tArr.push({i:'bi-wind',           t:'Điều hoà'});
            var tagsH=tArr.map(function(t){return '<div class="cp-tag"><i class="bi '+t.i+'"></i>'+t.t+'</div>';}).join('');

            var freeC=(cd.slots||[]).filter(function(s){return !s.isBooked;}).length;
            var totalC=(cd.slots||[]).length;

            var priceH=cd.hourlyRate&&cd.hourlyRate>0
                ?'<div class="cp-price-row"><div class="cp-price">'+cd.hourlyRate.toLocaleString('vi-VN')+'đ <span>/ giờ</span></div></div>':'';
            var descH=cd.description
                ?'<div class="cp-article"><div class="cp-article-title"><i class="bi bi-text-paragraph"></i> Mô tả sân</div><div class="cp-article-body">'+cd.description+'</div></div>':'';
            var detailBtn=cd.detailUrl
                ?'<a href="'+cd.detailUrl+'" class="cp-btn-detail"><i class="bi bi-eye-fill"></i> Trang chi tiết sân</a>':'';

            var panelH=
                '<div class="cp-hd">'+
                    '<div class="cp-hd-left"><span class="cp-hd-title">'+cd.name+'</span>'+typePill+statusPill+'</div>'+
                    '<button class="cp-btn-close" onclick="closeCourtPanel()"><i class="bi bi-chevron-up"></i> Thu gọn</button>'+
                '</div>'+
                '<div class="cp-body">'+
                    '<div class="cp-gallery">'+imgH+'</div>'+
                    '<div class="cp-info">'+
                        '<div class="cp-info-grid">'+
                            '<div class="cp-istat"><div class="cp-istat-v">'+totalC+'</div><div class="cp-istat-l">Tổng khung giờ</div></div>'+
                            '<div class="cp-istat"><div class="cp-istat-v" style="color:#34d399">'+freeC+'</div><div class="cp-istat-l">Còn trống</div></div>'+
                        '</div>'+
                        (tagsH?'<div class="cp-tags">'+tagsH+'</div>':'')+
                        priceH+
                        (detailBtn?'<div>'+detailBtn+'</div>':'')+
                    '</div>'+
                '</div>'+
                descH;

            var panel=document.getElementById('courtPanel');
            panel.innerHTML=panelH;
            panel.classList.add('show');

            if(imgs.length>1){
                var mel=document.getElementById(carId);
                if(mel) new bootstrap.Carousel(mel,{interval:3000,wrap:true});
            }
        }

        function closeCourtPanel(){
            document.getElementById('courtPanel').classList.remove('show');
        }

        function switchThumb(carId, idx, el){
            var car=bootstrap.Carousel.getInstance(document.getElementById(carId));
            if(car) car.to(idx);
            document.querySelectorAll('#'+carId).forEach(function(){});
            el.closest('.cp-thumbs').querySelectorAll('.cp-thumb').forEach(function(t,i){ t.classList.toggle('active',i===idx); });
        }

        // ══════════════════════════════════════════════════════
        // COURT INFO MODAL (ⓘ button)
        // ══════════════════════════════════════════════════════
        function openCourtModal(cid, evt){
            if(evt) evt.stopPropagation();
            var cd=COURTS_DATA[cid]; if(!cd) return;
            var imgs=cd.images&&cd.images.length?cd.images:[];
            var mcId='mc-car-'+cid;
            var imgH='';
            if(imgs.length===0){
                imgH='<div class="cm-img-ph"><i class="bi bi-image"></i></div>';
            } else if(imgs.length===1){
                imgH='<img class="cm-img" src="'+imgs[0]+'" alt="'+cd.name+'">';
            } else {
                imgH='<div id="'+mcId+'" class="carousel slide">'+
                    '<div class="carousel-inner">'+imgs.map(function(src,i){
                        return '<div class="carousel-item'+(i===0?' active':'')+'"><img class="cm-img" src="'+src+'" alt="'+cd.name+'"></div>';
                    }).join('')+'</div>'+
                    '<button class="carousel-control-prev" type="button" data-bs-target="#'+mcId+'" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>'+
                    '<button class="carousel-control-next" type="button" data-bs-target="#'+mcId+'" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>'+
                    '</div>';
            }
            var tArr=[];
            if(cd.courtTypeLabel)   tArr.push({i:'bi-house',         t:cd.courtTypeLabel});
            if(cd.surfaceTypeLabel) tArr.push({i:'bi-layers',         t:cd.surfaceTypeLabel});
            if(cd.floorNumber)      tArr.push({i:'bi-building',       t:'Tầng '+cd.floorNumber});
            if(cd.hasLighting)      tArr.push({i:'bi-lightbulb-fill', t:'Đèn chiếu sáng'});
            if(cd.hasAC)            tArr.push({i:'bi-wind',           t:'Điều hoà'});
            var tagH=tArr.map(function(t){return '<div class="cm-tag"><i class="bi '+t.i+'"></i>'+t.t+'</div>';}).join('');
            var freeC=(cd.slots||[]).filter(function(s){return !s.isBooked;}).length;
            var priceH=cd.hourlyRate&&cd.hourlyRate>0
                ?'<div style="font-size:.9rem;font-weight:800;color:var(--G);margin-top:.4rem">'+cd.hourlyRate.toLocaleString('vi-VN')+'đ <span style="font-size:.72rem;color:#8a7560;font-weight:400">/ giờ</span></div>':'';
            var descH=cd.description
                ?'<div class="cm-desc" style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--S)">'+cd.description+'</div>':'';
            var detailBtn=cd.detailUrl
                ?'<a href="'+cd.detailUrl+'" style="display:inline-flex;align-items:center;gap:.38rem;padding:.5rem 1.1rem;background:linear-gradient(135deg,var(--G),var(--G2));color:var(--D);border:none;border-radius:5px;font-size:.78rem;font-weight:800;cursor:pointer;text-decoration:none"><i class="bi bi-eye-fill"></i> Trang chi tiết sân</a>':'';

            document.body.insertAdjacentHTML('beforeend',
                '<div id="cmModal" class="cm-ov" onclick="if(event.target===this)this.remove()">'+
                '<div class="cm-box">'+
                    '<div class="cm-hd"><span class="cm-title">'+cd.name+'</span>'+
                    '<button class="cm-close" onclick="document.getElementById(\'cmModal\').remove()"><i class="bi bi-x-lg"></i></button></div>'+
                    imgH+
                    '<div class="cm-bd">'+
                        (tagH?'<div class="cm-tags">'+tagH+'</div>':'')+
                        '<div style="font-size:.8rem;color:#8a7560"><i class="bi bi-clock me-1" style="color:var(--G)"></i>'+freeC+' khung trống hôm nay</div>'+
                        priceH+descH+
                    '</div>'+
                    '<div class="cm-ft">'+detailBtn+'<button class="btn-cancel-sm" onclick="document.getElementById(\'cmModal\').remove()">Đóng</button></div>'+
                '</div></div>');
            if(imgs.length>1){
                var mel=document.getElementById(mcId);
                if(mel) new bootstrap.Carousel(mel,{interval:3000,wrap:true});
            }
        }

        // ══════════════════════════════════════════════════════
        // SELECTED SUMMARY SIDEBAR
        // ══════════════════════════════════════════════════════
        function updateSelSummary(){
            var card=document.getElementById('selSummaryCard');
            var bd=document.getElementById('selSummaryBd');
            if(!sel.length){ card.style.display='none'; return; }
            card.style.display='block';
            var H='';
            sel.slice().sort(function(a,b){return a.date.localeCompare(b.date);}).forEach(function(s){
                var parts=s.date.split('-');
                H+='<div style="padding:.45rem 0;border-bottom:1px solid var(--S);last-child:border-none">'+
                    '<div style="font-size:.68rem;font-weight:700;color:var(--G);margin-bottom:.2rem">'+parts[2]+'/'+parts[1]+'/'+parts[0]+'</div>'+
                    '<div style="display:flex;justify-content:space-between;font-size:.75rem">'+
                        '<span style="color:#5a4a35"><i class="bi bi-clock me-1" style="color:var(--G);font-size:.6rem"></i>'+s.st+' – '+s.et+'</span>'+
                        '<span style="font-weight:700;color:var(--G)">'+(s.price?s.price.toLocaleString('vi-VN')+'đ':'—')+'</span>'+
                    '</div>'+
                    '<div style="font-size:.62rem;color:#aaa;margin-top:.1rem">'+_fmtDur(s.minutes||60)+' · '+s.cname+'</div>'+
                '</div>';
            });
            bd.innerHTML=H;
        }

        // ══════════════════════════════════════════════════════
        // PAY BAR
        // ══════════════════════════════════════════════════════
        function refreshBar(){
            var bar=document.getElementById('payBar'), cnt=sel.length, total=sel.reduce(function(a,s){return a+s.price;},0);
            if(cnt>0){
                bar.classList.add('show');
                document.getElementById('payLbl').textContent='Đã chọn '+cnt+' lịch đặt';
                document.getElementById('payTot').textContent=total.toLocaleString('vi-VN')+'đ';
                document.getElementById('payMeta').textContent=sel.map(function(s){return s.date+' '+s.st+'–'+s.et;}).join(' · ');
            } else { bar.classList.remove('show'); }
        }

        function clearAll(){
            sel=[]; tlSel={};
            refreshBar(); renderCalendar(); updateSelSummary();
            hideSlotsPanel();
        }

        // ══════════════════════════════════════════════════════
        // BOOKING
        // ══════════════════════════════════════════════════════
        function goBook(){
            if(!sel.length) return;
            if(sel.length===1){
                var s=sel[0];
                window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+s.st+'&endTime='+s.et;
                return;
            }
            showMultiModal();
        }

        function showMultiModal(){
            var ex=document.getElementById('mmodal'); if(ex) ex.remove();
            var items=sel.map(function(s,i){
                return '<div class="ov-item"><div>'+
                    '<div class="ov-item-name">'+s.cname+' · '+s.date+'</div>'+
                    '<div class="ov-item-sub">'+s.st+' – '+s.et+' ('+_fmtDur(s.minutes||60)+')</div></div>'+
                    '<div class="ov-item-right">'+
                        '<span class="ov-price">'+s.price.toLocaleString('vi-VN')+'đ</span>'+
                        '<button class="ov-book" onclick="bookOne('+i+')">Đặt ngay</button>'+
                    '</div></div>';
            }).join('');
            document.body.insertAdjacentHTML('beforeend',
                '<div id="mmodal" class="ov" onclick="if(event.target===this)this.remove()">'+
                '<div class="ov-box"><div class="ov-hd">'+
                    '<span class="ov-title">Chọn lịch để đặt ('+sel.length+')</span>'+
                    '<button class="ov-close" onclick="document.getElementById(\'mmodal\').remove()"><i class="bi bi-x-lg"></i></button></div>'+
                '<div style="max-height:380px;overflow-y:auto">'+items+'</div>'+
                '<div class="ov-ft"><button class="btn-cancel-sm" onclick="document.getElementById(\'mmodal\').remove()">Đóng</button></div>'+
                '</div></div>');
        }

        function bookOne(idx){
            var s=sel[idx];
            window.location.href='/Booking/Create?courtId='+s.cid+'&bookingDate='+s.date+'&startTime='+s.st+'&endTime='+s.et;
        }
    </script>
}
