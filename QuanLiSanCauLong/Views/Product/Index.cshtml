@model QuanLiSanCauLong.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Cửa Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* ── FONTS ── *@
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

<style>
    /* ══════════════════════════════════════════════════════
       TOKENS
    ══════════════════════════════════════════════════════ */
    :root {
        --cream: #f7f3ec;
        --warm: #ede7d9;
        --parch: #e4dace;
        --espresso: #1a1209;
        --espresso2: #2c1f0e;
        --brown: #5c3d1e;
        --gold: #c89b3c;
        --gold2: #e8b84b;
        --gold3: rgba(200,155,60,.12);
        --ink: #1a1209;
        --muted: #8a7462;
        --border: rgba(90,60,20,.1);
        --green: #16a34a;
        --red: #dc2626;
        --radius: 6px;
        --shadow: 0 2px 18px rgba(26,18,9,.08);
        --shadow-lg: 0 8px 40px rgba(26,18,9,.14);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    .shop-page {
        background: var(--cream);
        min-height: 100vh;
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
    }

    /* ══ HERO BANNER ══ */
    .shop-hero {
        background: var(--espresso);
        background-image: radial-gradient(ellipse 70% 60% at 80% 50%, rgba(200,155,60,.18) 0%, transparent 70%), radial-gradient(ellipse 40% 80% at 10% 50%, rgba(200,155,60,.08) 0%, transparent 60%);
        padding: 4.5rem 4rem 4rem;
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 2rem;
        position: relative;
        overflow: hidden;
    }

        .shop-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c89b3c' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
        }

    .hero-left {
        position: relative;
    }

    .hero-label {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--gold3);
        border: 1px solid rgba(200,155,60,.3);
        color: var(--gold2);
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        padding: .3rem .85rem;
        border-radius: 2px;
        margin-bottom: 1rem;
    }

    .hero-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(2.8rem, 5vw, 5rem);
        color: #fff;
        line-height: .95;
        letter-spacing: .02em;
        margin-bottom: .75rem;
    }

        .hero-title em {
            color: var(--gold2);
            font-style: normal;
        }

    .hero-sub {
        font-size: .9rem;
        color: rgba(255,255,255,.45);
        max-width: 420px;
        line-height: 1.6;
    }

    .hero-stats {
        display: flex;
        gap: 2.5rem;
        position: relative;
    }

    .hstat {
        text-align: center;
        padding: 1.4rem 2rem;
        border: 1px solid rgba(200,155,60,.2);
        border-radius: var(--radius);
        background: rgba(255,255,255,.04);
        backdrop-filter: blur(4px);
    }

    .hstat-num {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.2rem;
        color: var(--gold2);
        line-height: 1;
        letter-spacing: .04em;
    }

    .hstat-lbl {
        font-size: .65rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: rgba(255,255,255,.35);
        margin-top: .3rem;
    }

    /* ══ PROMO STRIP ══ */
    .promo-strip {
        background: var(--gold);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        padding: .7rem 2rem;
        overflow: hidden;
    }

    .promo-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--espresso);
        white-space: nowrap;
    }

    /* ══ CATEGORY PILLS ══ */
    .cat-nav {
        background: #fff;
        border-bottom: 1px solid var(--border);
        padding: .85rem 2rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        overflow-x: auto;
        scrollbar-width: none;
    }

        .cat-nav::-webkit-scrollbar {
            display: none;
        }

    .cat-pill {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .42rem 1.1rem;
        border-radius: 100px;
        border: 1.5px solid var(--border);
        background: transparent;
        font-size: .78rem;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        transition: all .2s;
        flex-shrink: 0;
    }

        .cat-pill:hover, .cat-pill.active {
            background: var(--espresso);
            border-color: var(--espresso);
            color: #fff;
        }

        .cat-pill.active {
            background: var(--gold);
            border-color: var(--gold);
            color: var(--espresso);
            font-weight: 700;
        }

    .cat-count {
        background: rgba(0,0,0,.08);
        border-radius: 100px;
        padding: .05rem .45rem;
        font-size: .65rem;
    }

    /* ══ MAIN LAYOUT ══ */
    .shop-body {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 0;
        min-height: 70vh;
    }

    /* ══ SIDEBAR ══ */
    .shop-sidebar {
        background: #fff;
        border-right: 1px solid var(--border);
        padding: 2rem 1.5rem;
        position: sticky;
        top: 0;
        height: fit-content;
        max-height: 100vh;
        overflow-y: auto;
        scrollbar-width: thin;
    }

    .sidebar-section {
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
    }

        .sidebar-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
        }

    .sidebar-ttl {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    /* Search */
    .sidebar-search {
        position: relative;
    }

        .sidebar-search input {
            width: 100%;
            padding: .62rem .9rem .62rem 2.2rem;
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem;
            color: var(--ink);
            outline: none;
            transition: border-color .2s;
        }

            .sidebar-search input:focus {
                border-color: var(--gold);
                background: #fff;
            }

        .sidebar-search i {
            position: absolute;
            left: .7rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .82rem;
            pointer-events: none;
        }

    /* Price range */
    .price-inputs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .5rem;
        margin-top: .75rem;
    }

    .price-inp {
        padding: .5rem .7rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        font-family: 'DM Sans', sans-serif;
        font-size: .78rem;
        color: var(--ink);
        background: var(--cream);
        outline: none;
        width: 100%;
    }

        .price-inp:focus {
            border-color: var(--gold);
        }

    .price-slider {
        width: 100%;
        accent-color: var(--gold);
        margin: .75rem 0 .3rem;
    }

    /* Filter checkboxes */
    .filter-check-list {
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .fcheck {
        display: flex;
        align-items: center;
        gap: .6rem;
        cursor: pointer;
        padding: .3rem .4rem;
        border-radius: 4px;
        transition: background .15s;
    }

        .fcheck:hover {
            background: var(--cream);
        }

        .fcheck input {
            accent-color: var(--gold);
            width: 15px;
            height: 15px;
            cursor: pointer;
        }

    .fcheck-label {
        font-size: .82rem;
        color: var(--ink);
        flex: 1;
    }

    .fcheck-count {
        font-size: .68rem;
        color: var(--muted);
        background: var(--warm);
        padding: .1rem .45rem;
        border-radius: 100px;
    }

    /* Sort in sidebar */
    .sort-select {
        width: 100%;
        padding: .6rem .9rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        font-family: 'DM Sans', sans-serif;
        font-size: .82rem;
        color: var(--ink);
        background: var(--cream);
        outline: none;
        cursor: pointer;
    }

        .sort-select:focus {
            border-color: var(--gold);
        }

    /* Filter apply btn */
    .filter-apply {
        width: 100%;
        padding: .75rem;
        background: var(--espresso);
        color: #fff;
        border: none;
        border-radius: var(--radius);
        font-family: 'DM Sans', sans-serif;
        font-size: .82rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background .2s;
        margin-top: .5rem;
    }

        .filter-apply:hover {
            background: var(--gold);
            color: var(--espresso);
        }

    .filter-reset {
        width: 100%;
        padding: .6rem;
        background: transparent;
        color: var(--muted);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        font-family: 'DM Sans', sans-serif;
        font-size: .78rem;
        cursor: pointer;
        margin-top: .4rem;
        transition: all .2s;
    }

        .filter-reset:hover {
            border-color: var(--red);
            color: var(--red);
        }

    /* ══ CONTENT AREA ══ */
    .shop-content {
        padding: 1.75rem 2rem;
        background: var(--cream);
    }

    /* Toolbar */
    .shop-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--border);
        gap: 1rem;
        flex-wrap: wrap;
    }

    .toolbar-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .result-count {
        font-size: .85rem;
        color: var(--muted);
    }

        .result-count strong {
            color: var(--ink);
        }

    /* Active filter tags */
    .active-filters {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .filter-tag {
        display: flex;
        align-items: center;
        gap: .35rem;
        padding: .28rem .65rem;
        background: var(--espresso);
        color: #fff;
        border-radius: 100px;
        font-size: .7rem;
        font-weight: 600;
    }

        .filter-tag button {
            background: none;
            border: none;
            color: rgba(255,255,255,.6);
            cursor: pointer;
            padding: 0;
            font-size: .75rem;
            line-height: 1;
            display: flex;
            align-items: center;
        }

            .filter-tag button:hover {
                color: #fff;
            }

    /* View toggle */
    .view-toggle {
        display: flex;
        gap: 2px;
        background: var(--warm);
        padding: 3px;
        border-radius: 6px;
    }

    .view-btn {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        background: transparent;
        border-radius: 4px;
        color: var(--muted);
        cursor: pointer;
        font-size: .9rem;
        transition: all .2s;
    }

        .view-btn.active {
            background: #fff;
            color: var(--espresso);
            box-shadow: 0 1px 4px rgba(0,0,0,.1);
        }

    /* ══ PRODUCT GRID ══ */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

        .products-grid.list-view {
            grid-template-columns: 1fr;
        }

    /* ══ PRODUCT CARD ══ */
    .pcard {
        background: #fff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: transform .3s, box-shadow .3s;
        position: relative;
        display: flex;
        flex-direction: column;
        animation: fadeUp .4s ease both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .pcard:nth-child(1) {
        animation-delay: .05s;
    }

    .pcard:nth-child(2) {
        animation-delay: .1s;
    }

    .pcard:nth-child(3) {
        animation-delay: .15s;
    }

    .pcard:nth-child(4) {
        animation-delay: .2s;
    }

    .pcard:nth-child(5) {
        animation-delay: .25s;
    }

    .pcard:nth-child(6) {
        animation-delay: .3s;
    }

    .pcard:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    /* Card badges */
    .pcard-badges {
        position: absolute;
        top: .75rem;
        left: .75rem;
        display: flex;
        flex-direction: column;
        gap: .3rem;
        z-index: 2;
    }

    .badge-new {
        background: var(--espresso);
        color: #fff;
    }

    .badge-sale {
        background: var(--red);
        color: #fff;
    }

    .badge-hot {
        background: var(--gold);
        color: var(--espresso);
    }

    .badge-rent {
        background: #0e7490;
        color: #fff;
    }

    .badge-svc {
        background: #7c3aed;
        color: #fff;
    }

    .pcard-badge {
        font-size: .58rem;
        font-weight: 800;
        letter-spacing: .14em;
        text-transform: uppercase;
        padding: .22rem .6rem;
        border-radius: 2px;
        width: fit-content;
    }

    /* Wishlist btn */
    .pcard-wish {
        position: absolute;
        top: .75rem;
        right: .75rem;
        z-index: 2;
        width: 34px;
        height: 34px;
        background: rgba(255,255,255,.9);
        backdrop-filter: blur(4px);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        color: var(--muted);
        cursor: pointer;
        transition: all .2s;
        opacity: 0;
    }

    .pcard:hover .pcard-wish {
        opacity: 1;
    }

    .pcard-wish:hover, .pcard-wish.active {
        color: var(--red);
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,.12);
    }

    .pcard-wish.active {
        opacity: 1;
    }

    /* Image */
    .pcard-img-wrap {
        position: relative;
        aspect-ratio: 4/3;
        overflow: hidden;
        background: var(--warm);
        flex-shrink: 0;
    }

    .pcard-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .5s;
    }

    .pcard:hover .pcard-img {
        transform: scale(1.06);
    }

    .pcard-no-img {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        color: rgba(200,155,60,.2);
    }

    /* Quick view overlay */
    .pcard-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(26,18,9,.78));
        padding: 1.5rem .8rem .7rem;
        display: flex;
        justify-content: center;
        transform: translateY(100%);
        transition: transform .3s;
    }

    .pcard:hover .pcard-overlay {
        transform: translateY(0);
    }

    .pcard-quickview {
        background: rgba(255,255,255,.95);
        border: none;
        border-radius: 4px;
        padding: .45rem 1.1rem;
        font-family: 'DM Sans', sans-serif;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--espresso);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: .4rem;
        transition: background .15s;
    }

        .pcard-quickview:hover {
            background: var(--gold);
        }

    /* Card body */
    .pcard-body {
        padding: 1rem 1.1rem 1.1rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .pcard-cat {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .13em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: .3rem;
    }

    .pcard-name {
        font-family: 'Lora', serif;
        font-size: .95rem;
        font-weight: 600;
        color: var(--ink);
        line-height: 1.35;
        margin-bottom: .6rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Rating mini */
    .pcard-rating {
        display: flex;
        align-items: center;
        gap: .35rem;
        margin-bottom: .65rem;
    }

    .stars-sm {
        color: var(--gold);
        font-size: .72rem;
        letter-spacing: .08em;
    }

    .rating-n {
        font-size: .68rem;
        color: var(--muted);
    }

    /* Stock bar */
    .pcard-stock-bar {
        margin-bottom: .75rem;
    }

    .stock-bar-track {
        height: 3px;
        background: var(--parch);
        border-radius: 100px;
        overflow: hidden;
        margin-bottom: .25rem;
    }

    .stock-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--gold), var(--gold2));
        border-radius: 100px;
        transition: width .6s;
    }

        .stock-bar-fill.low {
            background: linear-gradient(90deg, #ef4444, #f87171);
        }

    .stock-label {
        font-size: .65rem;
        color: var(--muted);
    }

    /* Price */
    .pcard-price-row {
        display: flex;
        align-items: baseline;
        gap: .6rem;
        margin-top: auto;
        margin-bottom: .85rem;
    }

    .pcard-price {
        font-family: 'Lora', serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--espresso);
    }

    .pcard-price-old {
        font-size: .8rem;
        text-decoration: line-through;
        color: var(--muted);
    }

    /* Card footer */
    .pcard-foot {
        display: flex;
        gap: .5rem;
    }

    .pcard-btn-cart {
        flex: 1;
        padding: .6rem .8rem;
        background: var(--espresso);
        color: #fff;
        border: none;
        border-radius: 5px;
        font-family: 'DM Sans', sans-serif;
        font-size: .75rem;
        font-weight: 700;
        letter-spacing: .07em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
    }

        .pcard-btn-cart:hover {
            background: var(--gold);
            color: var(--espresso);
        }

        .pcard-btn-cart.disabled {
            opacity: .38;
            cursor: not-allowed;
        }

            .pcard-btn-cart.disabled:hover {
                background: var(--espresso);
                color: #fff;
            }

    .pcard-btn-detail {
        width: 38px;
        height: 38px;
        background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        flex-shrink: 0;
    }

        .pcard-btn-detail:hover {
            background: var(--espresso);
            border-color: var(--espresso);
            color: #fff;
        }

    /* ══ LIST VIEW card ══ */
    .list-view .pcard {
        flex-direction: row;
        height: 160px;
    }

    .list-view .pcard-img-wrap {
        width: 200px;
        aspect-ratio: unset;
        height: 100%;
        flex-shrink: 0;
    }

    .list-view .pcard-overlay {
        display: none;
    }

    .list-view .pcard-wish {
        opacity: 1;
    }

    .list-view .pcard-body {
        flex-direction: row;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 1.5rem;
    }

    .list-view .pcard-name {
        font-size: 1.05rem;
        -webkit-line-clamp: 1;
        width: 220px;
        flex-shrink: 0;
    }

    .list-view .pcard-stock-bar {
        margin-bottom: 0;
    }

    .list-view .pcard-cat {
        margin-bottom: 0;
    }

    .list-view .pcard-price-row {
        margin-bottom: 0;
        flex-direction: column;
        align-items: flex-end;
        gap: .2rem;
        margin-left: auto;
        flex-shrink: 0;
    }

    .list-view .pcard-rating {
        margin-bottom: 0;
    }

    .list-view .pcard-foot {
        align-items: center;
        flex-shrink: 0;
    }

    /* ══ EMPTY STATE ══ */
    .empty-state {
        grid-column: 1/-1;
        text-align: center;
        padding: 5rem 2rem;
    }

    .empty-icon {
        font-size: 5rem;
        color: rgba(200,155,60,.2);
        margin-bottom: 1.5rem;
    }

    .empty-ttl {
        font-family: 'Lora', serif;
        font-size: 1.5rem;
        color: var(--ink);
        margin-bottom: .5rem;
    }

    .empty-sub {
        font-size: .9rem;
        color: var(--muted);
    }

    /* ══ PAGINATION ══ */
    .shop-pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        padding: 2.5rem 0 1rem;
    }

    .pg-btn {
        min-width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        border: 1.5px solid var(--border);
        background: #fff;
        font-family: 'DM Sans', sans-serif;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        padding: 0 .6rem;
    }

        .pg-btn:hover {
            border-color: var(--gold);
            color: var(--espresso);
        }

        .pg-btn.active {
            background: var(--espresso);
            border-color: var(--espresso);
            color: #fff;
        }

        .pg-btn.disabled {
            opacity: .35;
            pointer-events: none;
        }

    /* ══ QUICK VIEW MODAL ══ */
    .qv-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(26,18,9,.6);
        backdrop-filter: blur(4px);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity .3s;
    }

        .qv-backdrop.open {
            opacity: 1;
            pointer-events: all;
        }

    .qv-modal {
        background: #fff;
        border-radius: 10px;
        width: 100%;
        max-width: 820px;
        max-height: 90vh;
        overflow-y: auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        transform: scale(.96) translateY(12px);
        transition: transform .3s;
        position: relative;
    }

    .qv-backdrop.open .qv-modal {
        transform: scale(1) translateY(0);
    }

    .qv-close {
        position: absolute;
        top: .85rem;
        right: .85rem;
        width: 34px;
        height: 34px;
        background: var(--warm);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        cursor: pointer;
        z-index: 2;
        transition: background .2s;
    }

        .qv-close:hover {
            background: var(--parch);
        }

    .qv-img-panel {
        background: var(--warm);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5rem;
        border-radius: 10px 0 0 10px;
        overflow: hidden;
    }

        .qv-img-panel img {
            max-width: 100%;
            max-height: 340px;
            object-fit: contain;
            border-radius: 4px;
        }

    .qv-info {
        padding: 2.5rem 2rem;
    }

    .qv-cat {
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: .5rem;
    }

    .qv-name {
        font-family: 'Lora', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .qv-price {
        font-family: 'Lora', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--espresso);
        margin-bottom: 1.25rem;
    }

    .qv-desc {
        font-size: .84rem;
        color: var(--muted);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    /* Qty picker */
    .qty-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .qty-label {
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .qty-picker {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
    }

    .qty-btn {
        width: 34px;
        height: 36px;
        background: var(--warm);
        border: none;
        font-size: 1rem;
        cursor: pointer;
        color: var(--ink);
        transition: background .2s;
    }

        .qty-btn:hover {
            background: var(--parch);
        }

    .qty-inp {
        width: 42px;
        height: 36px;
        border: none;
        text-align: center;
        font-family: 'DM Sans', sans-serif;
        font-size: .88rem;
        font-weight: 700;
        color: var(--ink);
        background: #fff;
        outline: none;
    }

    /* Feature chips */
    .feat-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin-bottom: 1.5rem;
    }

    .feat-chip {
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .7rem;
        color: var(--muted);
        background: var(--cream);
        border: 1.5px solid var(--border);
        padding: .28rem .7rem;
        border-radius: 4px;
    }

        .feat-chip i {
            color: var(--gold);
        }

    .qv-add-btn {
        width: 100%;
        padding: .85rem;
        background: var(--espresso);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: .85rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        transition: background .2s;
    }

        .qv-add-btn:hover {
            background: var(--gold);
            color: var(--espresso);
        }

    /* ══ TOAST ══ */
    .toast-stack {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 2000;
        display: flex;
        flex-direction: column;
        gap: .6rem;
        pointer-events: none;
    }

    .toast-item {
        background: var(--espresso);
        color: #fff;
        padding: .8rem 1.2rem;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .6rem;
        box-shadow: 0 4px 20px rgba(26,18,9,.3);
        animation: toastIn .3s ease both;
        pointer-events: all;
        min-width: 220px;
    }

        .toast-item i {
            color: var(--gold2);
            font-size: 1rem;
        }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateX(24px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .toast-item.out {
        animation: toastOut .3s ease forwards;
    }

    @@keyframes toastOut {
        to {
            opacity: 0;
            transform: translateX(24px);
        }
    }

    /* ══ FLOATING CART ══ */
    .float-cart {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%) translateY(80px);
        background: var(--espresso);
        color: #fff;
        padding: .85rem 2rem;
        border-radius: 100px;
        font-size: .85rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .75rem;
        box-shadow: 0 8px 28px rgba(26,18,9,.3);
        cursor: pointer;
        border: none;
        transition: transform .4s cubic-bezier(.34,1.56,.64,1), background .2s;
        z-index: 900;
        text-decoration: none;
    }

        .float-cart.visible {
            transform: translateX(-50%) translateY(0);
        }

        .float-cart:hover {
            background: var(--gold);
            color: var(--espresso);
        }

    .cart-badge {
        background: var(--gold2);
        color: var(--espresso);
        width: 22px;
        height: 22px;
        border-radius: 50%;
        font-size: .68rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ══ RESPONSIVE ══ */
    @@media (max-width: 1100px) {
        .products-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .hero-stats {
            display: none;
        }
    }

    @@media (max-width: 768px) {
        .shop-body {
            grid-template-columns: 1fr;
        }

        .shop-sidebar {
            display: none;
        }

        .shop-hero {
            padding: 2.5rem 1.5rem;
            grid-template-columns: 1fr;
        }

        .qv-modal {
            grid-template-columns: 1fr;
        }

        .qv-img-panel {
            border-radius: 10px 10px 0 0;
        }

        .products-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .list-view .pcard {
            flex-direction: column;
            height: auto;
        }

        .list-view .pcard-img-wrap {
            width: 100%;
            height: 180px;
        }

        .list-view .pcard-body {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 480px) {
        .products-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="shop-page">

    <!-- ── HERO ── -->
    <div class="shop-hero">
        <div class="hero-left">
            <div class="hero-label"><i class="bi bi-shop"></i> Cửa hàng chính thức</div>
            <h1 class="hero-title">TRANG THIẾT BỊ<br /><em>CẦU LÔNG</em></h1>
            <p class="hero-sub">Vợt, giày, quần áo & phụ kiện chuyên dụng — chất lượng cao, giao hàng tận sân.</p>
        </div>
        <div class="hero-stats">
            <div class="hstat">
                <div class="hstat-num">@(ViewBag.TotalProducts ?? "0")+</div>
                <div class="hstat-lbl">Sản phẩm</div>
            </div>
            <div class="hstat">
                <div class="hstat-num">@(ViewBag.TotalCategories ?? "0")</div>
                <div class="hstat-lbl">Danh mục</div>
            </div>
            <div class="hstat">
                <div class="hstat-num">24H</div>
                <div class="hstat-lbl">Giao hàng</div>
            </div>
        </div>
    </div>

    <!-- ── PROMO STRIP ── -->
    <div class="promo-strip">
        <div class="promo-item"><i class="bi bi-truck"></i> Miễn phí giao hàng từ 500K</div>
        <div class="promo-item"><i class="bi bi-arrow-repeat"></i> Đổi trả 7 ngày</div>
        <div class="promo-item"><i class="bi bi-shield-check"></i> Bảo hành chính hãng</div>
        <div class="promo-item"><i class="bi bi-headset"></i> Hỗ trợ 8:00 – 22:00</div>
    </div>

    <!-- ── CATEGORY NAV ── -->
    <div class="cat-nav">
        <a href="?category=" class="cat-pill @(string.IsNullOrEmpty(ViewBag.CurrentCategory as string) ? "active" : "")">
            <i class="bi bi-grid-3x3-gap-fill"></i> Tất cả
            <span class="cat-count">@(ViewBag.TotalProducts ?? 0)</span>
        </a>
        @if (ViewBag.Categories != null)
        {
            @foreach (var cat in (IEnumerable<dynamic>)ViewBag.Categories)
            {
                <a href="?category=@cat.CategoryId" class="cat-pill @(ViewBag.CurrentCategory?.ToString() == cat.CategoryId.ToString() ? "active" : "")">
                    @cat.CategoryName
                    <span class="cat-count">@cat.ProductCount</span>
                </a>
            }
        }
    </div>

    <!-- ── BODY ── -->
    <div class="shop-body">

        <!-- SIDEBAR -->
        <aside class="shop-sidebar">
            <form method="get" id="filterForm">

                <!-- Search -->
                <div class="sidebar-section">
                    <div class="sidebar-ttl"><i class="bi bi-search"></i> Tìm kiếm</div>
                    <div class="sidebar-search">
                        <i class="bi bi-search"></i>
                        <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="Tên sản phẩm, mã SKU..." />
                    </div>
                </div>

                <!-- Danh mục -->
                <div class="sidebar-section">
                    <div class="sidebar-ttl"><i class="bi bi-tags"></i> Danh mục</div>
                    <div class="filter-check-list">
                        @if (ViewBag.Categories != null)
                        {
                            @foreach (var cat in (IEnumerable<dynamic>)ViewBag.Categories)
                            {
                                <label class="fcheck">
                                    <input type="checkbox" name="categories" value="@cat.CategoryId"
                                           @(ViewBag.SelectedCategories != null && ((List<int>)ViewBag.SelectedCategories).Contains((int)cat.CategoryId) ? "checked" : null) />
                                    <span class="fcheck-label">@cat.CategoryName</span>
                                    <span class="fcheck-count">@cat.ProductCount</span>
                                </label>
                            }
                        }
                    </div>
                </div>

                <!-- Khoảng giá -->
                <div class="sidebar-section">
                    <div class="sidebar-ttl"><i class="bi bi-currency-exchange"></i> Khoảng giá (VNĐ)</div>
                    <input type="range" class="price-slider" min="0" max="5000000" step="50000"
                           value="@(ViewBag.MaxPrice ?? 5000000)" id="priceSlider"
                           oninput="document.getElementById('priceMax').value=this.value" />
                    <div class="price-inputs">
                        <input type="number" class="price-inp" name="minPrice" placeholder="Từ" value="@ViewBag.MinPrice" />
                        <input type="number" class="price-inp" name="maxPrice" id="priceMax" placeholder="Đến" value="@ViewBag.MaxPrice" />
                    </div>
                </div>

                <!-- Trạng thái -->
                <div class="sidebar-section">
                    <div class="sidebar-ttl"><i class="bi bi-circle-half"></i> Trạng thái</div>
                    <div class="filter-check-list">
                        <label class="fcheck">
                            <input type="checkbox" name="status" value="instock" @(ViewBag.FilterInStock == true ? "checked" : null) />
                            <span class="fcheck-label">Còn hàng</span>
                        </label>
                        <label class="fcheck">
                            <input type="checkbox" name="status" value="sale" @(ViewBag.FilterSale == true ? "checked" : null) />
                            <span class="fcheck-label">Đang giảm giá</span>
                        </label>
                        <label class="fcheck">
                            <input type="checkbox" name="status" value="new" @(ViewBag.FilterNew == true ? "checked" : null) />
                            <span class="fcheck-label">Hàng mới về</span>
                        </label>
                    </div>
                </div>

                <!-- Sắp xếp -->
                <div class="sidebar-section">
                    <div class="sidebar-ttl"><i class="bi bi-sort-down"></i> Sắp xếp</div>
                    <select class="sort-select" name="sort">
                        <option value="newest" selected="@(ViewBag.CurrentSort == "newest" ? "selected" : null)">Mới nhất</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc" ? "selected" : null)">Giá tăng dần</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc" ? "selected" : null)">Giá giảm dần</option>
                        <option value="name_asc" selected="@(ViewBag.CurrentSort == "name_asc" ? "selected" : null)">Tên A → Z</option>
                        <option value="popular" selected="@(ViewBag.CurrentSort == "popular" ? "selected" : null)">Phổ biến nhất</option>
                    </select>
                </div>

                <button type="submit" class="filter-apply"><i class="bi bi-funnel-fill"></i> Áp dụng bộ lọc</button>
                <a href="?" class="filter-reset d-block text-center mt-2"><i class="bi bi-x-circle"></i> Xóa bộ lọc</a>
            </form>
        </aside>

        <!-- CONTENT -->
        <div class="shop-content">

            <!-- Toolbar -->
            <div class="shop-toolbar">
                <div class="toolbar-left">
                    <div class="result-count">
                        Tìm thấy <strong>@(Model?.TotalCount ?? 0)</strong> sản phẩm
                    </div>
                    <div class="active-filters" id="activeTags">
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string))
                        {
                            <div class="filter-tag">
                                <i class="bi bi-search"></i> @ViewBag.CurrentSearch
                                <button onclick="removeFilter('search')"><i class="bi bi-x"></i></button>
                            </div>
                        }
                    </div>
                </div>
                <div class="view-toggle">
                    <button class="view-btn active" id="btnGrid" onclick="setView('grid')" title="Lưới">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </button>
                    <button class="view-btn" id="btnList" onclick="setView('list')" title="Danh sách">
                        <i class="bi bi-list-ul"></i>
                    </button>
                </div>
            </div>

            <!-- Products -->
            <div class="products-grid" id="productsGrid">
                @if (Model?.Products != null && Model.Products.Any())
                {
                    @foreach (var p in Model.Products)
                    {
                        var isAvail = p.StockQuantity > 0;
                        var stockPct = p.MinStockLevel > 0
                        ? Math.Min(100, (int)((double)p.StockQuantity / (p.MinStockLevel * 3) * 100))
                        : (isAvail ? 75 : 0);
                        var isLow = isAvail && p.StockQuantity <= p.MinStockLevel && p.MinStockLevel > 0;
                        var behavior = p.Category?.BehaviorType ?? "Retail";

                        <div class="pcard"
                             data-id="@p.ProductId"
                             data-name="@p.ProductName"
                             data-price="@p.Price"
                             data-cat="@(p.Category?.CategoryName)"
                             data-img="@p.ImageUrl"
                             data-desc="@p.Description"
                             data-unit="@p.Unit"
                             data-avail="@(isAvail ? "true" : "false")">

                            <!-- Badges -->
                            <div class="pcard-badges">
                                @{
                                    var isNew = p.CreatedAt >= DateTime.Now.AddDays(-14);
                                }
                                @if (isNew)
                                {
                                    <span class="pcard-badge badge-new">Mới</span>
                                }
                                @if (behavior == "Rental")
                                {
                                    <span class="pcard-badge badge-rent">Cho thuê</span>
                                }
                                @if (behavior == "Service")
                                {
                                    <span class="pcard-badge badge-svc">Dịch vụ</span>
                                }
                                @if (isLow)
                                {
                                    <span class="pcard-badge badge-hot">Sắp hết</span>
                                }
                            </div>

                            <!-- Wishlist -->
                            <button class="pcard-wish" onclick="toggleWish(this, @p.ProductId)" title="Yêu thích">
                                <i class="bi bi-heart"></i>
                            </button>

                            <!-- Image -->
                            <div class="pcard-img-wrap">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img class="pcard-img" src="@p.ImageUrl" alt="@p.ProductName" loading="lazy" />
                                }
                                else
                                {
                                    <div class="pcard-no-img">
                                        <i class="bi @(behavior == "Rental" ? "bi-repeat" : behavior == "Service" ? "bi-tools" : "bi-bag")"></i>
                                    </div>
                                }
                                <div class="pcard-overlay">
                                    <button class="pcard-quickview" onclick="openQuickView(event, this.closest('.pcard'))">
                                        <i class="bi bi-eye"></i> Xem nhanh
                                    </button>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="pcard-body">
                                <div class="pcard-cat">@(p.Category?.CategoryName ?? "Sản phẩm")</div>
                                <div class="pcard-name">@p.ProductName</div>

                                <div class="pcard-rating">
                                    <div class="stars-sm">★★★★☆</div>
                                    <span class="rating-n">(12)</span>
                                </div>

                                @if (behavior != "Service")
                                {
                                    <div class="pcard-stock-bar">
                                        <div class="stock-bar-track">
                                            <div class="stock-bar-fill @(isLow ? "low" : "")" style="width:@stockPct%"></div>
                                        </div>
                                        <div class="stock-label">
                                            @if (!isAvail)
                                            {
                                                <span style="color:var(--red)"><i class="bi bi-x-circle"></i> Hết hàng</span>
                                            }
                                            else if (isLow)
                                            {

                                                <span style="color:#ef4444">Còn @p.StockQuantity @p.Unit — sắp hết</span>
                                            }
                                            else
                                            {

                                                <span>Còn hàng — @p.StockQuantity @p.Unit</span>
                                            }
                                        </div>
                                    </div>
                                }

                                <div class="pcard-price-row">
                                    <div class="pcard-price">@p.Price.ToString("N0")đ</div>
                                    @if (p.CostPrice > 0 && p.CostPrice > p.Price)
                                    {
                                        <div class="pcard-price-old">@p.CostPrice.ToString("N0")đ</div>
                                    }
                                </div>

                                <div class="pcard-foot">
                                    <button class="pcard-btn-cart @(!isAvail && behavior == "Retail" ? "disabled" : "")"
                                            onclick="addToCart(@p.ProductId, '@p.ProductName.Replace("'", "\\'")', @p.Price)"
                                            @(!isAvail && behavior == "Retail" ? "disabled" : null)>
                                        <i class="bi @(behavior == "Rental" ? "bi-calendar-check" : behavior == "Service" ? "bi-wrench" : "bi-bag-plus")"></i>
                                        @(behavior == "Rental" ? "Đặt thuê" : behavior == "Service" ? "Đặt dịch vụ" : "Thêm vào giỏ")
                                    </button>
                                    <a class="pcard-btn-detail" asp-action="Details" asp-route-id="@p.ProductId" title="Chi tiết">
                                        <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-bag-x"></i></div>
                        <div class="empty-ttl">Không tìm thấy sản phẩm</div>
                        <div class="empty-sub">Thử thay đổi bộ lọc hoặc từ khoá tìm kiếm</div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model?.TotalPages > 1)
            {
                <div class="shop-pagination">
                    <a href="?page=@(Model.CurrentPage - 1)" class="pg-btn @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (Math.Abs(i - Model.CurrentPage) <= 2 || i == 1 || i == Model.TotalPages)
                        {
                            <a href="?page=@i" class="pg-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
                        }
                        else if (Math.Abs(i - Model.CurrentPage) == 3)
                        {
                            <span class="pg-btn" style="pointer-events:none">…</span>
                        }
                    }
                    <a href="?page=@(Model.CurrentPage + 1)" class="pg-btn @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- ── QUICK VIEW MODAL ── -->
<div class="qv-backdrop" id="qvBackdrop" onclick="closeQV(event)">
    <div class="qv-modal">
        <button class="qv-close" onclick="closeQVBtn()"><i class="bi bi-x"></i></button>
        <div class="qv-img-panel" id="qvImgPanel">
            <div style="font-size:6rem;color:rgba(200,155,60,.2)"><i class="bi bi-bag" id="qvIconFallback"></i></div>
        </div>
        <div class="qv-info">
            <div class="qv-cat" id="qvCat"></div>
            <div class="qv-name" id="qvName"></div>
            <div class="qv-price" id="qvPrice"></div>
            <p class="qv-desc" id="qvDesc"></p>
            <div class="feat-chips">
                <div class="feat-chip"><i class="bi bi-truck"></i> Miễn phí giao hàng</div>
                <div class="feat-chip"><i class="bi bi-arrow-repeat"></i> Đổi trả 7 ngày</div>
                <div class="feat-chip"><i class="bi bi-shield-check"></i> Hàng chính hãng</div>
            </div>
            <div class="qty-row">
                <span class="qty-label">Số lượng</span>
                <div class="qty-picker">
                    <button class="qty-btn" onclick="changeQty(-1)">−</button>
                    <input type="number" class="qty-inp" id="qvQty" value="1" min="1" max="99" />
                    <button class="qty-btn" onclick="changeQty(1)">+</button>
                </div>
            </div>
            <button class="qv-add-btn" id="qvAddBtn">
                <i class="bi bi-bag-plus-fill"></i> Thêm vào giỏ hàng
            </button>
        </div>
    </div>
</div>

<!-- ── TOAST ── -->
<div class="toast-stack" id="toastStack"></div>

<!-- ── FLOATING CART ── -->
<a href="#" class="float-cart" id="floatCart">
    <i class="bi bi-bag-fill"></i>
    Giỏ hàng
    <div class="cart-badge" id="cartBadge">0</div>
</a>

@section Scripts {
    <script>
        /* ── View toggle ── */
        let currentView = localStorage.getItem('shopView') || 'grid';
        setView(currentView, false);

        function setView(v, save = true) {
          currentView = v;
          const grid = document.getElementById('productsGrid');
          grid.classList.toggle('list-view', v === 'list');
          document.getElementById('btnGrid').classList.toggle('active', v === 'grid');
          document.getElementById('btnList').classList.toggle('active', v === 'list');
          if (save) localStorage.setItem('shopView', v);
        }

        /* ── Cart state ── */
        let cartCount = parseInt(localStorage.getItem('cartCount') || '0');
        updateCartBadge();

        function updateCartBadge() {
          document.getElementById('cartBadge').textContent = cartCount;
          document.getElementById('floatCart').classList.toggle('visible', cartCount > 0);
        }

        function addToCart(id, name, price) {
          cartCount++;
          localStorage.setItem('cartCount', cartCount);
          updateCartBadge();
          showToast(`<i class="bi bi-bag-check-fill"></i> Đã thêm "${name.substring(0,28)}" vào giỏ`);
        }

        /* ── Wishlist ── */
        function toggleWish(btn, id) {
          btn.classList.toggle('active');
          const icon = btn.querySelector('i');
          const isActive = btn.classList.contains('active');
          icon.className = isActive ? 'bi bi-heart-fill' : 'bi bi-heart';
          if (isActive) showToast(`<i class="bi bi-heart-fill" style="color:#f87171"></i> Đã thêm vào yêu thích`);
        }

        /* ── Quick View ── */
        let qvCurrentId = null;

        function openQuickView(e, card) {
          e.preventDefault();
          e.stopPropagation();
          qvCurrentId = card.dataset.id;
          document.getElementById('qvName').textContent  = card.dataset.name;
          document.getElementById('qvCat').textContent   = card.dataset.cat;
          document.getElementById('qvPrice').textContent = parseInt(card.dataset.price).toLocaleString('vi-VN') + 'đ';
          document.getElementById('qvDesc').textContent  = card.dataset.desc || 'Sản phẩm chất lượng cao.';
          document.getElementById('qvQty').value = 1;

          const panel = document.getElementById('qvImgPanel');
          if (card.dataset.img) {
            panel.innerHTML = `<img src="${card.dataset.img}" alt="${card.dataset.name}" style="max-width:100%;max-height:340px;object-fit:contain;border-radius:4px" />`;
          } else {
            panel.innerHTML = `<div style="font-size:8rem;color:rgba(200,155,60,.2)"><i class="bi bi-bag"></i></div>`;
          }

          document.getElementById('qvAddBtn').onclick = () => {
            const qty = parseInt(document.getElementById('qvQty').value);
            cartCount += qty;
            localStorage.setItem('cartCount', cartCount);
            updateCartBadge();
            showToast(`<i class="bi bi-bag-check-fill"></i> Đã thêm ${qty} sản phẩm vào giỏ`);
            closeQVBtn();
          };

          document.getElementById('qvBackdrop').classList.add('open');
          document.body.style.overflow = 'hidden';
        }

        function closeQV(e) {
          if (e.target === document.getElementById('qvBackdrop')) closeQVBtn();
        }

        function closeQVBtn() {
          document.getElementById('qvBackdrop').classList.remove('open');
          document.body.style.overflow = '';
        }

        function changeQty(delta) {
          const inp = document.getElementById('qvQty');
          inp.value = Math.max(1, Math.min(99, parseInt(inp.value || 1) + delta));
        }

        /* ── Toast ── */
        function showToast(html) {
          const stack = document.getElementById('toastStack');
          const t = document.createElement('div');
          t.className = 'toast-item';
          t.innerHTML = html;
          stack.appendChild(t);
          setTimeout(() => {
            t.classList.add('out');
            setTimeout(() => t.remove(), 300);
          }, 3000);
        }

        /* ── Remove filter tag ── */
        function removeFilter(key) {
          const url = new URL(window.location);
          url.searchParams.delete(key);
          window.location = url;
        }

        /* ── Escape key ── */
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeQVBtn(); });
    </script>
}
