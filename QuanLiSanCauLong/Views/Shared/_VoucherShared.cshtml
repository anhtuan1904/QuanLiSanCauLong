@* Views/AdminVoucher/_VoucherShared.cshtml — nhúng vào đầu mỗi View *@
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --deep: #1a1209;
        --gold: #d4a017;
        --gold2: #f5c842;
        --cream: #fdf8f0;
        --warm: #f5ede0;
        --border: #e8ddd0;
        --muted: #8a7560;
        --green: #16a34a;
        --red: #c94b2a;
    }

    *, *::before, *::after {
        font-family: 'Outfit', sans-serif;
        box-sizing: border-box;
    }

    /* ── Breadcrumb ── */
    .v-crumb {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

        .v-crumb a {
            color: var(--muted);
            text-decoration: none;
        }

            .v-crumb a:hover {
                color: var(--gold);
            }

    /* ── Page header ── */
    .pg-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .pg-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1.2;
    }

        .pg-title em {
            font-style: italic;
            color: var(--gold);
        }

    .pg-sub {
        font-size: .82rem;
        color: var(--muted);
        margin-top: .25rem;
    }

    /* ── Buttons ── */
    .btn-gold {
        background: linear-gradient(135deg,var(--gold),var(--gold2));
        color: var(--deep) !important;
        border: none;
        padding: .72rem 1.5rem;
        font-size: .86rem;
        font-weight: 700;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        text-decoration: none;
        transition: all .25s;
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.35);
        }

    .btn-ov {
        padding: .65rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-ov:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    .btn-dv {
        padding: .65rem 1.25rem;
        border: 1.5px solid rgba(201,75,42,.3);
        border-radius: 8px;
        background: rgba(201,75,42,.07);
        color: var(--red);
        font-size: .84rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

        .btn-dv:hover {
            background: var(--red);
            color: #fff;
            border-color: var(--red);
        }

    .btn-back {
        width: 36px;
        height: 36px;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        text-decoration: none;
        transition: all .2s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: var(--deep);
            color: var(--deep) !important;
        }

    /* ── Alerts ── */
    .sys-ok {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.25);
        color: var(--green);
    }

    .sys-err {
        padding: .9rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: .84rem;
        display: flex;
        align-items: center;
        gap: .65rem;
        background: rgba(201,75,42,.06);
        border: 1px solid rgba(201,75,42,.25);
        color: var(--red);
    }

    /* ── Stat strip ── */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .stat-box {
        background: #fff;
        padding: 1.2rem 1.5rem;
    }

    .stat-n {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--deep);
        line-height: 1;
    }

    .stat-l {
        font-size: .71rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: .35rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .stat-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* ── Toolbar ── */
    .toolbar {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .tb-search {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .tb-search input {
            width: 100%;
            padding: .65rem 1rem .65rem 2.25rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            font-size: .84rem;
            color: var(--deep);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .tb-search input:focus {
                border-color: var(--gold);
                background: var(--cream);
            }

        .tb-search i {
            position: absolute;
            left: .8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: .82rem;
        }

    .tb-sel {
        padding: .65rem 1rem;
        border: 1px solid var(--border);
        border-radius: 7px;
        font-size: .84rem;
        color: var(--deep);
        background: #fff;
        outline: none;
        cursor: pointer;
    }

        .tb-sel:focus {
            border-color: var(--gold);
        }

    /* ── Table ── */
    .v-table-wrap {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .v-table {
        width: 100%;
        border-collapse: collapse;
    }

        .v-table th {
            background: var(--warm);
            padding: .8rem 1rem;
            font-size: .67rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--muted);
            text-align: left;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .v-table td {
            padding: .85rem 1rem;
            border-bottom: 1px solid var(--border);
            font-size: .84rem;
            vertical-align: middle;
        }

        .v-table tbody tr:last-child td {
            border-bottom: none;
        }

        .v-table tbody tr:hover td {
            background: var(--cream);
        }

    /* ── Chips / status ── */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .2rem .7rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .chip-green {
        background: rgba(22,163,74,.1);
        color: var(--green);
    }

    .chip-red {
        background: rgba(201,75,42,.1);
        color: var(--red);
    }

    .chip-gold {
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .chip-grey {
        background: rgba(138,117,96,.1);
        color: var(--muted);
    }

    .chip-blue {
        background: rgba(59,130,246,.1);
        color: #2563eb;
    }

    /* ── Progress bar ── */
    .prog-wrap {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        margin-top: .35rem;
        overflow: hidden;
    }

    .prog-bar {
        height: 100%;
        border-radius: 2px;
        transition: width .6s ease;
    }

    /* ── Action buttons ── */
    .act-g {
        display: flex;
        gap: .35rem;
    }

    .act-b {
        width: 30px;
        height: 30px;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        cursor: pointer;
        transition: all .18s;
        color: var(--muted);
        text-decoration: none;
    }

        .act-b.view:hover {
            border-color: #3b82f6;
            color: #3b82f6;
            background: rgba(59,130,246,.07);
        }

        .act-b.edit:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212,160,23,.07);
        }

        .act-b.del:hover {
            border-color: var(--red);
            color: var(--red);
            background: rgba(201,75,42,.07);
        }

        .act-b.usage:hover {
            border-color: var(--green);
            color: var(--green);
            background: rgba(22,163,74,.07);
        }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--muted);
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .25;
        }

    /* ── Form elements ── */
    .f-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .f-card-head {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .85rem 1.5rem;
        background: var(--warm);
        border-bottom: 1px solid var(--border);
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        letter-spacing: .04em;
    }

    .f-card-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--deep);
    }

    .f-card-body {
        padding: 1.5rem;
    }

    .fg {
        margin-bottom: 1.1rem;
    }

    .fg-r2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .fg-r3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
    }

    .fg-label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--deep);
        display: block;
        margin-bottom: .42rem;
        letter-spacing: .02em;
    }

    .req {
        color: var(--red);
    }

    .fg-input {
        width: 100%;
        padding: .65rem .95rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .86rem;
        font-family: 'Outfit',sans-serif;
        color: var(--deep);
        background: #fff;
        outline: none;
        transition: border-color .2s, background .2s;
    }

        .fg-input:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-ta {
        width: 100%;
        padding: .65rem .95rem;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        font-size: .86rem;
        font-family: 'Outfit',sans-serif;
        color: var(--deep);
        background: #fff;
        outline: none;
        resize: vertical;
        min-height: 80px;
        transition: border-color .2s;
    }

        .fg-ta:focus {
            border-color: var(--gold);
            background: var(--cream);
        }

    .fg-hint {
        font-size: .74rem;
        color: var(--muted);
        margin-top: .3rem;
        display: block;
    }

    .fg-addon {
        position: relative;
    }

        .fg-addon .fg-input {
            padding-right: 2.5rem;
        }

    .fg-addon-txt {
        position: absolute;
        right: .9rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: .8rem;
        font-weight: 700;
        color: var(--muted);
        pointer-events: none;
    }

    /* ── Discount type selector ── */
    .disc-opts {
        display: flex;
        gap: .5rem;
    }

    .disc-opt {
        flex: 1;
        padding: .65rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        font-size: .82rem;
        font-weight: 600;
        color: var(--muted);
        transition: all .2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        user-select: none;
    }

        .disc-opt:hover {
            border-color: var(--gold);
            color: var(--deep);
        }

        .disc-opt.active {
            border-color: var(--gold);
            background: rgba(212,160,23,.08);
            color: var(--deep);
        }

    /* ── Toggle checkbox ── */
    .toggle-item {
        display: flex;
        align-items: center;
        gap: .65rem;
        cursor: pointer;
        user-select: none;
    }

        .toggle-item input[type=checkbox] {
            width: 16px;
            height: 16px;
            accent-color: var(--gold);
            cursor: pointer;
        }

    .toggle-label {
        font-size: .84rem;
        font-weight: 500;
        color: var(--deep);
    }

    /* ── Page footer ── */
    .pg-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-top: 1.5rem;
    }

    /* ── Voucher banner (Usage page) ── */
    .v-banner {
        background: var(--deep);
        border-radius: 12px;
        padding: 1.5rem 1.75rem;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .v-banner-l {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .v-banner-code {
        background: rgba(245,200,66,.12);
        border: 1px solid rgba(245,200,66,.3);
        border-radius: 8px;
        padding: .55rem 1rem;
    }

        .v-banner-code span {
            font-family: monospace;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--gold2);
            letter-spacing: .12em;
        }

    .v-banner-info h4 {
        font-family: 'Playfair Display',serif;
        color: #fff;
        font-size: 1.15rem;
        margin: 0 0 .2rem;
    }

    .v-banner-info p {
        color: rgba(255,255,255,.5);
        font-size: .82rem;
        margin: 0;
    }

    .v-banner-r .big {
        font-family: 'Playfair Display',serif;
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--gold2);
        line-height: 1;
    }

    .v-banner-r small {
        color: rgba(255,255,255,.45);
        font-size: .72rem;
        display: block;
        margin-top: .2rem;
    }

    /* ── Modal ── */
    .v-modal .modal-content {
        display: flex;
        flex-direction: column;
        max-height: 88vh;
        overflow: hidden;
        border: none;
        border-radius: 14px;
    }

    .v-mh {
        padding: 1.25rem 1.75rem 1rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        background: #fff;
    }

    .v-mlabel {
        font-size: .65rem;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 700;
        margin-bottom: .25rem;
    }

    .v-mtitle {
        font-family: 'Playfair Display',serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--deep);
    }

        .v-mtitle em {
            font-style: italic;
            color: var(--gold);
        }

    .v-mclose {
        width: 32px;
        height: 32px;
        border: 1.5px solid var(--border);
        border-radius: 7px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        cursor: pointer;
        transition: all .2s;
        flex-shrink: 0;
    }

        .v-mclose:hover {
            border-color: var(--deep);
            color: var(--deep);
        }

    .v-mb {
        padding: 1.25rem 1.75rem 1rem;
        overflow-y: auto;
        flex: 1;
        min-height: 0;
    }

        .v-mb::-webkit-scrollbar {
            width: 5px;
        }

        .v-mb::-webkit-scrollbar-track {
            background: var(--warm);
        }

        .v-mb::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 3px;
        }

    .v-mf {
        padding: 1rem 1.75rem 1.25rem;
        border-top: 1px solid var(--border);
        background: #fff;
        flex-shrink: 0;
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
    }

    /* ── Customer avatar ── */
    .av-cust {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .av-ava {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(212,160,23,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        font-size: .85rem;
        flex-shrink: 0;
    }

    @@media(max - width:768px) {
        .fg-r2 {
            grid-template-columns: 1fr;
        }

        .fg-r3 {
            grid-template-columns: 1fr;
        }

        .stat-strip {
            grid-template-columns: 1fr 1fr;
        }

        .disc-opts {
            flex-direction: column;
        }
    }
</style>
