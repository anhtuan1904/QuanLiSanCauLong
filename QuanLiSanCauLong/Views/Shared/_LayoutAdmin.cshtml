<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin · Badminton</title>

    <script src="~/lib/tinymce/tinymce.min.js"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --deep: #1a1209;
            --deep2: #231a0e;
            --deep3: #2e2110;
            --gold: #d4a017;
            --gold2: #f5c842;
            --gold3: rgba(212,160,23,.12);
            --cream: #fdf8f0;
            --warm: #f5ede0;
            --border: rgba(212,160,23,.18);
            --muted: rgba(255,255,255,.38);
            --text: rgba(255,255,255,.82);
            --sidebar-w: 268px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background: var(--warm);
            font-family: 'Outfit', sans-serif;
            color: #2a1f10;
            margin: 0;
            overflow-x: hidden;
        }

        /* ── SIDEBAR ──────────────────────────────────── */
        #sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--deep);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform .3s cubic-bezier(.25,.46,.45,.94);
            overflow: hidden;
        }

            #sidebar.collapsed {
                transform: translateX(calc(-1 * var(--sidebar-w)));
            }

            #sidebar::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, var(--gold) 0%, var(--gold2) 50%, transparent 100%);
            }

        .sb-brand {
            padding: 1rem 1rem .9rem;
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }

        /* Logo banner tỷ lệ ngang */
        .sb-logo-banner {
            width: 100%;
            border-radius: 7px;
            overflow: hidden;
            margin-bottom: .55rem;
            background: rgba(212,160,23,.06);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 52px;
        }

            .sb-logo-banner img {
                width: 100%;
                height: auto;
                display: block;
                max-height: 80px;
                object-fit: contain;
            }

            .sb-logo-banner i {
                font-size: 1.6rem;
                color: var(--gold);
                opacity: .5;
            }

        /* giữ các class cũ để không lỗi nếu còn dùng đâu đó */
        .sb-brand-logo {
            display: none;
        }

        .sb-icon {
            display: none;
        }

        .sb-name {
            display: none;
        }

        .sb-sub {
            font-size: .62rem;
            color: var(--muted);
            letter-spacing: .15em;
            text-transform: uppercase;
            text-align: center;
        }

        .sb-nav {
            flex: 1;
            overflow-y: auto;
            padding: .75rem 0;
            scrollbar-width: thin;
            scrollbar-color: var(--gold3) transparent;
        }

            .sb-nav::-webkit-scrollbar {
                width: 4px;
            }

            .sb-nav::-webkit-scrollbar-thumb {
                background: var(--gold3);
                border-radius: 2px;
            }

        .sb-section {
            padding: 1rem 1.4rem .4rem;
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--muted);
            font-family: 'Outfit', sans-serif;
        }

        .sb-link {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .7rem 1.4rem;
            color: var(--text);
            text-decoration: none;
            font-size: .875rem;
            font-weight: 400;
            transition: all .2s;
            border-left: 2px solid transparent;
        }

            .sb-link:hover {
                color: var(--gold2);
                background: var(--gold3);
                border-left-color: var(--gold);
            }

            .sb-link.active {
                color: var(--gold2);
                background: linear-gradient(90deg, rgba(212,160,23,.18) 0%, transparent 100%);
                border-left-color: var(--gold);
                font-weight: 600;
            }

            .sb-link i {
                font-size: 1rem;
                width: 20px;
                text-align: center;
                flex-shrink: 0;
                color: var(--gold);
                opacity: .7;
                transition: opacity .2s;
            }

            .sb-link:hover i, .sb-link.active i {
                opacity: 1;
            }

        .sb-badge {
            margin-left: auto;
            background: var(--gold);
            color: var(--deep);
            font-size: .58rem;
            font-weight: 800;
            padding: .15rem .5rem;
            border-radius: 3px;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

            .sb-badge.hot {
                background: #c94b2a;
                color: #fff;
            }

        .sb-user {
            padding: 1.1rem 1.4rem;
            border-top: 1px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: .85rem;
            background: rgba(0,0,0,.15);
            text-decoration: none;
            cursor: pointer;
            transition: background .2s;
        }

            .sb-user:hover {
                background: rgba(212,160,23,.08);
            }

        .sb-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--deep);
            font-weight: 800;
            font-size: .95rem;
            flex-shrink: 0;
            font-family: 'Playfair Display', serif;
            overflow: hidden;
            border: 2px solid rgba(212,160,23,.35);
        }

            .sb-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

        .sb-user-name {
            font-size: .85rem;
            font-weight: 600;
            color: #fff;
            line-height: 1.2;
        }

        .sb-user-role {
            font-size: .68rem;
            color: var(--muted);
            letter-spacing: .08em;
        }

        /* ── CONTENT ──────────────────────────────────── */
        #content {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left .3s cubic-bezier(.25,.46,.45,.94);
        }

            #content.expanded {
                margin-left: 0;
            }

        .top-nav {
            position: sticky;
            top: 0;
            z-index: 900;
            background: rgba(253,248,240,.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid #e8ddd0;
            padding: .9rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .top-nav-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .sidebar-toggle {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            background: var(--deep);
            border: none;
            color: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .2s;
            font-size: 1.05rem;
            flex-shrink: 0;
        }

            .sidebar-toggle:hover {
                background: var(--deep3);
                box-shadow: 0 4px 12px rgba(26,18,9,.25);
            }

        .top-page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--deep);
            font-style: italic;
        }

        .top-nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .top-action-btn {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            background: #fff;
            border: 1px solid #e8ddd0;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #8a7560;
            transition: all .2s;
            font-size: .95rem;
            text-decoration: none;
        }

            .top-action-btn:hover {
                border-color: var(--gold);
                color: var(--gold);
            }

        .top-user-chip {
            display: flex;
            align-items: center;
            gap: .6rem;
            background: var(--deep);
            padding: .4rem .75rem .4rem .4rem;
            border-radius: 100px;
        }

        .top-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--deep);
            font-weight: 800;
            font-size: .72rem;
            font-family: 'Playfair Display', serif;
        }

        .top-user-name {
            font-size: .78rem;
            font-weight: 600;
            color: rgba(255,255,255,.85);
            white-space: nowrap;
        }

        main {
            padding: 2rem;
            flex: 1;
        }

        .sb-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(26,18,9,.6);
            z-index: 999;
            backdrop-filter: blur(2px);
        }

            .sb-overlay.show {
                display: block;
            }

        @@media (max-width: 900px) {
            #sidebar {
                transform: translateX(calc(-1 * var(--sidebar-w)));
            }

                #sidebar.mobile-open {
                    transform: translateX(0);
                }

            #content {
                margin-left: 0 !important;
            }

            .top-page-title {
                display: none;
            }

            main {
                padding: 1.25rem;
            }
        }

        .admin-card {
            background: #fff;
            border: 1px solid #ede5d8;
            border-radius: 10px;
            overflow: hidden;
            transition: box-shadow .25s;
        }

            .admin-card:hover {
                box-shadow: 0 6px 24px rgba(26,18,9,.08);
            }

        .admin-card-header {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid #ede5d8;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .admin-card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--deep);
            font-style: italic;
        }

        .gold-btn {
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold2) 100%);
            color: var(--deep);
            border: none;
            padding: .55rem 1.4rem;
            font-weight: 700;
            font-size: .82rem;
            border-radius: 6px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            transition: all .2s;
            text-decoration: none;
            letter-spacing: .02em;
        }

            .gold-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(212,160,23,.35);
                color: var(--deep);
            }

        .dark-btn {
            background: var(--deep);
            color: rgba(255,255,255,.85);
            border: none;
            padding: .55rem 1.4rem;
            font-weight: 600;
            font-size: .82rem;
            border-radius: 6px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            transition: all .2s;
            text-decoration: none;
        }

            .dark-btn:hover {
                background: var(--deep3);
                color: var(--gold2);
            }
    </style>
</head>
<body>

    <div class="sb-overlay" id="sbOverlay"></div>

    <!-- SIDEBAR -->
    <nav id="sidebar">
        <div class="sb-brand">
            @* Đặt ảnh logo vào: wwwroot/images/logo/logo-sidebar.png (tỷ lệ ngang 16:5 hoặc 16:4) *@
            <div class="sb-logo-banner">
                <img src="~/images/logo/logo-sidebar.png" alt="Logo"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
                <i class="bi bi-trophy-fill" style="display:none;"></i>
            </div>
            <div class="sb-sub">Admin Dashboard</div>
        </div>

        <div class="sb-nav">

            <!-- Dashboard -->
            <a asp-controller="AdminDashboard" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i><span>Dashboard</span>
            </a>

            <!-- ── Quản Lý Cơ Sở ── -->
            <div class="sb-section">Quản Lý Cơ Sở</div>
            <a asp-controller="AdminFacility" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminFacility" ? "active" : "")">
                <i class="bi bi-building"></i><span>Cơ sở sân</span>
            </a>
            <a asp-controller="AdminCourt" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCourt" ? "active" : "")">
                <i class="bi bi-grid-3x3"></i><span>Sân cầu lông</span>
            </a>
            <a asp-controller="AdminPriceSlot" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminPriceSlot" ? "active" : "")">
                <i class="bi bi-cash-stack"></i><span>Khung giờ &amp; Giá</span>
            </a>
            <a asp-controller="AdminReview" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminReview" ? "active" : "")">
                <i class="bi bi-star-half"></i><span>Đánh giá</span>
                <span class="sb-badge new">NEW</span>
            </a>

            <!-- ── Đặt Sân & Đơn Hàng ── -->
            <div class="sb-section">Đặt Sân &amp; Đơn Hàng</div>
            <a asp-controller="AdminBooking" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminBooking" ? "active" : "")">
                <i class="bi bi-calendar-check"></i><span>Đặt sân</span>
            </a>
            <a asp-controller="AdminOrder" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminOrder" ? "active" : "")">
                <i class="bi bi-receipt"></i><span>Đơn hàng</span>
            </a>

            <!-- ── Sản Phẩm ── -->
            <div class="sb-section">Sản Phẩm</div>
            <a asp-controller="AdminCategory" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCategory" ? "active" : "")">
                <i class="bi bi-tags"></i><span>Danh mục</span>
            </a>
            <a asp-controller="AdminProduct" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminProduct" ? "active" : "")">
                <i class="bi bi-box-seam"></i><span>Sản phẩm</span>
            </a>
            <a asp-controller="AdminInventory" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminInventory" ? "active" : "")">
                <i class="bi bi-boxes"></i><span>Kho hàng</span>
            </a>

            <!-- ── Nội Dung ── -->
            <div class="sb-section">Nội Dung</div>
            <a asp-controller="AdminBlog" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminBlog" ? "active" : "")">
                <i class="bi bi-newspaper"></i><span>Bài viết</span>
            </a>
            <a asp-controller="AdminService" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminService" ? "active" : "")">
                <i class="bi bi-stars"></i><span>Dịch vụ</span>
            </a>

            <!-- ── Tuyển Dụng & Liên Hệ ── -->
            <div class="sb-section">Tuyển Dụng &amp; Liên Hệ</div>
            <a asp-controller="AdminJob" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminJob" ? "active" : "")">
                <i class="bi bi-briefcase"></i><span>Tuyển dụng</span>
            </a>
            <a asp-controller="AdminContact" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminContact" ? "active" : "")">
                <i class="bi bi-chat-dots"></i><span>Liên hệ</span>
            </a>

            <!-- ── Nhân Viên & Ca Làm Việc ── -->
            <div class="sb-section">Nhân Viên &amp; Ca Làm Việc</div>
            <a asp-controller="AdminStaff" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminStaff" ? "active" : "")">
                <i class="bi bi-people-fill"></i><span>Nhân viên</span>
            </a>
            <a asp-controller="AdminShift" asp-action="Schedule"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminShift" && ViewContext.RouteData.Values["action"]?.ToString() == "Schedule" ? "active" : "")">
                <i class="bi bi-calendar-week"></i><span>Lịch phân ca</span>
            </a>
            <a asp-controller="AdminShift" asp-action="Report"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminShift" && ViewContext.RouteData.Values["action"]?.ToString() == "Report" ? "active" : "")">
                <i class="bi bi-bar-chart-line"></i><span>Báo cáo ca</span>
            </a>

            <!-- ── Marketing ── -->
            <div class="sb-section">Marketing</div>
            <a asp-controller="AdminVoucher" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminVoucher" ? "active" : "")">
                <i class="bi bi-ticket-perforated"></i><span>Voucher</span>
            </a>

            <!-- ── Báo Cáo ── -->
            <div class="sb-section">Báo Cáo</div>
            <a asp-controller="AdminReport" asp-action="Revenue"
               class="sb-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Revenue" ? "active" : "")">
                <i class="bi bi-graph-up"></i><span>Doanh thu</span>
            </a>

            <!-- ── Hệ Thống ── -->
            <div class="sb-section">Hệ Thống</div>
            <a asp-controller="AdminUser" asp-action="Index"
               class="sb-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUser" ? "active" : "")">
                <i class="bi bi-person-badge"></i><span>Người dùng</span>
            </a>
            <a asp-controller="Home" asp-action="Index" class="sb-link">
                <i class="bi bi-house-door"></i><span>Về trang chủ</span>
            </a>

        </div>

        <a href="/Profile" class="sb-user" title="Xem hồ sơ">
            <div class="sb-avatar">
                @{
                    var _sbAvatar = User.FindFirst("AvatarUrl")?.Value
                    ?? ViewData["UserAvatar"] as string;
                    var _sbName = User.Identity?.Name ?? "";
                    var _sbInit = _sbName.Length > 0 ? _sbName.Substring(0, 1).ToUpper() : "A";
                }
                @if (!string.IsNullOrEmpty(_sbAvatar))
                {
                    <img src="@_sbAvatar" alt="@_sbName" />
                }
                else
                {
                    @_sbInit
                }
            </div>
            <div style="min-width:0;flex:1;">
                <div class="sb-user-name" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    @(User.Identity?.Name ?? "")
                </div>
                <div class="sb-user-role">
                    @(User.IsInRole("Admin") ? "Administrator" : User.IsInRole("Staff") ? "Staff" : "User")
                </div>
            </div>
            <i class="bi bi-box-arrow-up-right" style="font-size:.65rem;color:rgba(255,255,255,.25);flex-shrink:0;"></i>
        </a>
    </nav>

    <!-- CONTENT -->
    <div id="content">
        <nav class="top-nav">
            <div class="top-nav-left">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <span class="top-page-title">@ViewData["Title"]</span>
            </div>
            <div class="top-nav-right">
                <a asp-controller="Home" asp-action="Index" class="top-action-btn" title="Trang chủ" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i>
                </a>
                <div class="top-action-btn"><i class="bi bi-bell"></i></div>

            </div>
        </nav>

        <main>@RenderBody()</main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script src="~/js/avatar-cropper.js"></script>
    <script>
        const sidebar  = document.getElementById('sidebar');
        const content  = document.getElementById('content');
        const overlay  = document.getElementById('sbOverlay');
        const toggle   = document.getElementById('sidebarToggle');
        const sbNav    = sidebar.querySelector('.sb-nav');
        const isMobile = () => window.innerWidth <= 900;

        // ── Khôi phục vị trí scroll sidebar ──
        const SCROLL_KEY = 'sb_scroll';
        const savedScroll = sessionStorage.getItem(SCROLL_KEY);
        if (savedScroll && sbNav) sbNav.scrollTop = parseInt(savedScroll, 10);

        // Lưu vị trí scroll khi user cuộn
        if (sbNav) {
            sbNav.addEventListener('scroll', () => {
                sessionStorage.setItem(SCROLL_KEY, sbNav.scrollTop);
            });
        }

        // Lưu trạng thái collapsed
        const COLLAPSED_KEY = 'sb_collapsed';
        if (sessionStorage.getItem(COLLAPSED_KEY) === '1') {
            sidebar.classList.add('collapsed');
            content.classList.add('expanded');
        }

        toggle.addEventListener('click', () => {
            if (isMobile()) {
                sidebar.classList.toggle('mobile-open');
                overlay.classList.toggle('show');
            } else {
                sidebar.classList.toggle('collapsed');
                content.classList.toggle('expanded');
                sessionStorage.setItem(COLLAPSED_KEY,
                    sidebar.classList.contains('collapsed') ? '1' : '0');
            }
        });

        overlay.addEventListener('click', () => {
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('show');
        });

        // Ngăn TinyMCE bị chiếm focus
        $(document).on('focusin', function(e) {
            if (e.target.closest(".tox-tinymce-aux, .moxman-window, .tam-assetmanager-root") !== null) {
                e.stopImmediatePropagation();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
