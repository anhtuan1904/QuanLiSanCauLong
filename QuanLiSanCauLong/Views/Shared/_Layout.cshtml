    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        toastr.options = { closeButton: true, progressBar: true, positionClass: "toast-top-right", timeOut: "3000" };

        // Mobile drawer
        const mobileToggle = document.getElementById('mobileToggle');
        const mobileDrawer = document.getElementById('mobileDrawer');
        mobileToggle?.addEventListener('click', () => {
            mobileDrawer.classList.toggle('open');
            const icon = mobileToggle.querySelector('i');
            icon.className = mobileDrawer.classList.contains('open') ? 'bi bi-x-lg' : 'bi bi-list';
        });
    </script>

    <script>
        // ══════════════════════════════════════════
        // NOTIFICATION SYSTEM
        // ══════════════════════════════════════════
        let notifOpen = false;

        function toggleNotif(e) {
            e.stopPropagation();
            const panel = document.getElementById('notifPanel');
            notifOpen = !notifOpen;
            panel.classList.toggle('open', notifOpen);
            if (notifOpen) loadNotifications();
        }

        // Đóng khi click ra ngoài
        document.addEventListener('click', (e) => {
            if (notifOpen && !document.getElementById('notifWrapper')?.contains(e.target)) {
                document.getElementById('notifPanel')?.classList.remove('open');
                notifOpen = false;
            }
        });

        async function loadNotifications() {
            try {
                const r = await fetch('/Account/GetNotifications');
                if (!r.ok) return;
                const data = await r.json();
                renderNotifications(data.notifications || [], data.unreadCount || 0);
            } catch {
                // Fallback: hiện demo notifications nếu API chưa có
                renderNotifications(getDemoNotifs(), 0);
            }
        }

        function renderNotifications(items, unreadCount) {
            const list  = document.getElementById('notifList');
            const empty = document.getElementById('notifEmpty');
            const dot   = document.getElementById('notifDot');
            const btn   = document.getElementById('notifBtn');

            // Cập nhật badge
            if (unreadCount > 0) {
                dot.style.display = 'block';
                // Thay dot bằng số nếu > 0
                let badge = btn.querySelector('.notif-count-badge');
                if (!badge) { badge = document.createElement('span'); badge.className = 'notif-count-badge'; btn.appendChild(badge); }
                badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
                badge.style.display = 'flex';
                dot.style.display = 'none';
            } else {
                dot.style.display = 'none';
                const badge = btn.querySelector('.notif-count-badge');
                if (badge) badge.style.display = 'none';
            }

            if (!items.length) {
                list.innerHTML = '';
                list.appendChild(empty);
                return;
            }

            const iconMap = { booking: 'bi-calendar-check', payment: 'bi-cash-stack', cancel: 'bi-x-circle', system: 'bi-info-circle' };
            list.innerHTML = items.map(n => `
                <a href="${n.link || '#'}" class="notif-item ${n.isRead ? '' : 'unread'}" onclick="markRead(${n.id})">
                    <div class="notif-icon ${n.type}">
                        <i class="bi ${iconMap[n.type] || 'bi-bell'}"></i>
                    </div>
                    <div class="notif-body">
                        <div class="notif-msg">${n.message}</div>
                        <div class="notif-time">${n.time}</div>
                    </div>
                    ${!n.isRead ? '<div class="notif-unread-dot"></div>' : ''}
                </a>
            `).join('');
        }

        async function markRead(id) {
            try { await fetch('/Account/MarkNotificationRead/' + id, { method: 'POST' }); } catch {}
        }

        async function markAllRead() {
            try {
                await fetch('/Account/MarkAllNotificationsRead', { method: 'POST' });
                document.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
                document.querySelectorAll('.notif-unread-dot').forEach(el => el.remove());
                const dot = document.getElementById('notifDot');
                if (dot) dot.style.display = 'none';
                const badge = document.querySelector('.notif-count-badge');
                if (badge) badge.style.display = 'none';
            } catch {}
        }

        // Demo notifications (fallback khi API chưa có)
        function getDemoNotifs() {
            return [
                { id: 1, type: 'booking',  message: 'Đơn đặt sân BK20260315001 đã được xác nhận', time: '5 phút trước',  isRead: false, link: '/Booking/MyBookings' },
                { id: 2, type: 'payment',  message: 'Thanh toán thành công 150.000đ cho đơn BK20260314005', time: '2 giờ trước',   isRead: false, link: '/Booking/MyBookings' },
                { id: 3, type: 'system',   message: 'Hệ thống sẽ bảo trì lúc 2:00 - 3:00 ngày 16/03', time: 'Hôm qua',           isRead: true,  link: '#' },
            ];
        }

        // Auto-load khi trang vừa load để hiện badge
        @if (User.Identity?.IsAuthenticated == true)
        {
                    <text>
                    setTimeout(async () => {
                        try {
                            const r = await fetch('/Account/GetNotifications');
                            if (r.ok) {
                                const data = await r.json();
                                const unread = data.unreadCount || 0;
                                if (unread > 0) {
                                    const btn = document.getElementById('notifBtn');
                                    if (btn) {
                                        let badge = btn.querySelector('.notif-count-badge');
                                        if (!badge) { badge = document.createElement('span'); badge.className = 'notif-count-badge'; btn.appendChild(badge); }
                                        badge.textContent = unread > 9 ? '9+' : unread;
                                        badge.style.display = 'flex';
                                    }
                                }
                            }
                        } catch {
                            // API chưa có — không hiện badge, không lỗi
                        }
                    }, 500);
                    </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
