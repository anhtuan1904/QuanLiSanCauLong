@model QuanLiSanCauLong.ViewModels.BookingHistoryViewModel
@{
    ViewData["Title"] = "Đổi lịch đặt sân";
    var openTime = ViewBag.OpenTime as string ?? "06:00";
    var closeTime = ViewBag.CloseTime as string ?? "23:00";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --D: #1a1209;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        font-family: 'Outfit',sans-serif;
    }

    body {
        background: var(--W);
        margin: 0;
    }

    .wrap {
        max-width: 640px;
        margin: 2.5rem auto;
        padding: 0 1.25rem 4rem;
    }

    .card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .card-hd {
        padding: 1.1rem 1.75rem;
        background: var(--G3);
        border-bottom: 1px solid rgba(212,160,23,.2);
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    .card-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--D);
    }

    .card-bd {
        padding: 1.75rem;
    }

    .current-box {
        background: var(--W);
        border-radius: 9px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        border-left: 3px solid var(--G);
    }

    .c-label {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #8a7560;
        margin-bottom: .35rem;
    }

    .c-val {
        font-size: .92rem;
        font-weight: 700;
        color: var(--D);
    }

    .fg {
        margin-bottom: 1.1rem;
    }

    .fg-label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--D);
        display: block;
        margin-bottom: .42rem;
    }

    .req {
        color: var(--R);
    }

    .fg-input {
        width: 100%;
        padding: .65rem .95rem;
        border: 1.5px solid var(--S);
        border-radius: 7px;
        font-size: .86rem;
        font-family: 'Outfit',sans-serif;
        color: var(--D);
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .fg-input:focus {
            border-color: var(--G);
            background: #fffef8;
        }

    .fg-r2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .info-box {
        background: #fffbf0;
        border: 1px solid rgba(212,160,23,.25);
        border-radius: 9px;
        padding: .9rem 1.1rem;
        margin-bottom: 1.5rem;
        font-size: .8rem;
        color: #92660a;
        display: flex;
        align-items: flex-start;
        gap: .55rem;
    }

    .btn-row {
        display: flex;
        gap: .65rem;
    }

    .btn {
        flex: 1;
        text-align: center;
        padding: .75rem 1rem;
        border-radius: 8px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        border: none;
        font-family: 'Outfit',sans-serif;
        text-decoration: none;
        display: block;
        transition: all .2s;
    }

    .btn-gold {
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.3);
        }

    .btn-outline {
        background: #fff;
        color: var(--D);
        border: 1.5px solid var(--S);
    }

        .btn-outline:hover {
            border-color: var(--D);
        }
</style>

<div class="wrap">
    <div style="margin-bottom:1.25rem;">
        <a asp-action="Details" asp-route-id="@Model.BookingId"
           style="display:inline-flex;align-items:center;gap:.4rem;font-size:.78rem;color:#8a7560;text-decoration:none;">
            <i class="bi bi-arrow-left"></i> Quay lại chi tiết
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:.85rem 1.2rem;margin-bottom:1.25rem;font-size:.84rem;color:#991b1b;display:flex;align-items:center;gap:.6rem;">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="card">
        <div class="card-hd">
            <i class="bi bi-calendar-event" style="color:var(--G);font-size:1.1rem;"></i>
            <span class="card-title">Đổi Lịch Đặt Sân</span>
        </div>
        <div class="card-bd">

            <div class="current-box">
                <div class="c-label">Lịch hiện tại — #@Model.BookingCode</div>
                <div class="c-val">
                    <i class="bi bi-calendar3" style="color:var(--G);font-size:.82rem;margin-right:.35rem;"></i>
                    @Model.BookingDate.ToString("dd/MM/yyyy") ·
                    @Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")
                </div>
                <div style="font-size:.78rem;color:#8a7560;margin-top:.2rem;">@Model.FacilityName · Sân @Model.CourtNumber</div>
            </div>

            <div class="info-box">
                <i class="bi bi-info-circle-fill" style="flex-shrink:0;"></i>
                <div>
                    Sau khi đổi lịch, đơn sẽ chuyển về trạng thái <strong>Chờ xác nhận</strong>.
                    Giờ mở cửa: <strong>@openTime – @closeTime</strong>.
                    Phải đổi ít nhất 2 giờ trước giờ chơi.
                </div>
            </div>

            <form asp-action="Reschedule" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.BookingId" />

                <div class="fg">
                    <label class="fg-label" for="newDate">Ngày mới <span class="req">*</span></label>
                    <input type="date" id="newDate" name="newDate" class="fg-input"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                           value="@Model.BookingDate.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="fg-r2 fg">
                    <div>
                        <label class="fg-label" for="newStart">Giờ bắt đầu <span class="req">*</span></label>
                        <input type="time" id="newStart" name="newStartTime" class="fg-input"
                               min="@openTime" max="@closeTime"
                               value="@Model.StartTime.ToString(@"hh\:mm")" required />
                    </div>
                    <div>
                        <label class="fg-label" for="newEnd">Giờ kết thúc <span class="req">*</span></label>
                        <input type="time" id="newEnd" name="newEndTime" class="fg-input"
                               min="@openTime" max="@closeTime"
                               value="@Model.EndTime.ToString(@"hh\:mm")" required />
                    </div>
                </div>

                @* Preview giá mới (JS tính toán đơn giản) *@
                <div id="pricePreview" style="display:none;background:var(--G3);border:1px solid rgba(212,160,23,.25);border-radius:9px;padding:.9rem 1.1rem;margin-bottom:1.5rem;font-size:.84rem;color:var(--D);">
                    <i class="bi bi-calculator" style="color:var(--G);"></i>
                    Thời lượng mới: <strong id="durLabel">—</strong>
                </div>

                <div class="btn-row">
                    <a asp-action="Details" asp-route-id="@Model.BookingId" class="btn btn-outline">
                        <i class="bi bi-x"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-gold">
                        <i class="bi bi-calendar-check"></i> Xác nhận đổi lịch
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updatePreview() {
            var s = document.getElementById('newStart').value;
            var e = document.getElementById('newEnd').value;
            if (!s || !e) return;
            var [sh,sm] = s.split(':').map(Number);
            var [eh,em] = e.split(':').map(Number);
            var mins = (eh*60+em) - (sh*60+sm);
            if (mins <= 0) { document.getElementById('pricePreview').style.display='none'; return; }
            var h = Math.floor(mins/60), m = mins%60;
            document.getElementById('durLabel').textContent =
                (h > 0 ? h + ' giờ ' : '') + (m > 0 ? m + ' phút' : '');
            document.getElementById('pricePreview').style.display='block';
        }
        document.getElementById('newStart').addEventListener('change', updatePreview);
        document.getElementById('newEnd').addEventListener('change', updatePreview);
        updatePreview();
    </script>
}
