@model QuanLiSanCauLong.ViewModels.BookingHistoryViewModel
@{
    ViewData["Title"] = "Chi tiết đặt sân #" + Model.BookingCode;
    bool canReview = (bool)(ViewBag.CanReview ?? false);
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.2);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
        --BL: #2563eb;
        --r: 12px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        font-family: 'Outfit',sans-serif;
    }

    body {
        background: var(--W);
        margin: 0;
    }

    /* ── BREADCRUMB ── */
    .pghd {
        background: var(--D);
        padding: .75rem 2.5rem;
        display: flex;
        align-items: center;
        gap: .55rem;
        border-bottom: 2px solid var(--G3);
    }

        .pghd a {
            color: var(--G2);
            text-decoration: none;
            font-size: .78rem;
            font-weight: 600;
        }

        .pghd span {
            color: rgba(255,255,255,.4);
            font-size: .65rem;
        }

        .pghd .cur {
            color: rgba(255,255,255,.55);
            font-size: .78rem;
        }

    /* ── LAYOUT ── */
    .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.75rem 2rem 4rem;
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.5rem;
        align-items: start;
    }
    @@media(max - width:900px) {
        .wrap {
            grid-template-columns: 1fr;
        }
    }

    /* ── CARDS ── */
    .card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .card-hd {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .85rem 1.5rem;
        background: var(--W);
        border-bottom: 1px solid var(--S);
        font-size: .78rem;
        font-weight: 700;
        color: var(--D);
        letter-spacing: .04em;
        text-transform: uppercase;
    }

        .card-hd i {
            color: var(--G);
        }

    .card-bd {
        padding: 1.5rem;
    }

    /* ── HERO CARD (booking summary) ── */
    .bk-hero {
        background: var(--D);
        border-radius: var(--r);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .bk-hero-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
        filter: brightness(.75);
    }

    .bk-hero-body {
        padding: 1.4rem 1.75rem 1.75rem;
    }

    .bk-code-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
        margin-bottom: .9rem;
    }

    .bk-code {
        font-family: monospace;
        font-size: 1rem;
        font-weight: 700;
        color: var(--G2);
        letter-spacing: .1em;
        background: rgba(245,200,66,.1);
        border: 1px solid rgba(245,200,66,.25);
        border-radius: 6px;
        padding: .25rem .75rem;
    }

    .bk-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.15;
        margin-bottom: .3rem;
    }

    .bk-sub {
        font-size: .82rem;
        color: rgba(255,255,255,.5);
    }

    /* ── INFO GRID ── */
    .info-g {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .8rem;
    }

    .info-item .lbl {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #8a7560;
        margin-bottom: .25rem;
    }

    .info-item .val {
        font-size: .9rem;
        font-weight: 600;
        color: var(--D);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .info-item .val i {
            color: var(--G);
            font-size: .75rem;
        }

    /* ── PRICE TABLE ── */
    .price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .55rem 0;
        border-bottom: 1px solid var(--S);
        font-size: .86rem;
    }

        .price-row:last-child {
            border-bottom: none;
        }

        .price-row .lbl {
            color: #5a4a38;
        }

        .price-row .val {
            font-weight: 600;
            color: var(--D);
        }

    .price-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .85rem 1.25rem;
        background: var(--D);
        border-radius: 9px;
        margin-top: .75rem;
    }

        .price-total .lbl {
            font-size: .72rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: rgba(255,255,255,.55);
            font-weight: 700;
        }

        .price-total .val {
            font-family: 'Playfair Display',serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--G2);
        }

    /* ── STATUS CHIP ── */
    .chip {
        display: inline-flex;
        align-items: center;
        gap: .28rem;
        padding: .22rem .7rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .chip-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .chip-confirmed {
        background: #dbeafe;
        color: #1e40af;
    }

    .chip-playing {
        background: rgba(212,160,23,.15);
        color: #92660a;
    }

    .chip-completed {
        background: #d1fae5;
        color: #065f46;
    }

    .chip-cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .chip-paid {
        background: #d1fae5;
        color: #065f46;
    }

    .chip-unpaid {
        background: #fee2e2;
        color: #991b1b;
    }

    .chip-processing {
        background: #dbeafe;
        color: #1e40af;
    }

    /* ── BUTTONS ── */
    .btn {
        display: block;
        text-align: center;
        padding: .72rem 1rem;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
        border: none;
        font-family: 'Outfit',sans-serif;
        transition: all .2s;
    }

    .btn-gold {
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
    }

        .btn-gold:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(212,160,23,.3);
            color: var(--D);
        }

    .btn-dark {
        background: var(--D);
        color: var(--G2);
    }

        .btn-dark:hover {
            background: #000;
        }

    .btn-outline {
        background: #fff;
        color: var(--D);
        border: 1.5px solid var(--S);
    }

        .btn-outline:hover {
            border-color: var(--D);
        }

    .btn-danger {
        background: #fff;
        color: var(--R);
        border: 1.5px solid rgba(201,75,42,.3);
    }

        .btn-danger:hover {
            background: var(--R);
            color: #fff;
        }

    /* ── QR PAYMENT ── */
    .qr-box {
        background: var(--D);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        margin-bottom: 1.25rem;
    }

        .qr-box img {
            width: 160px;
            height: 160px;
            border-radius: 8px;
            background: #fff;
            padding: 6px;
            margin: 0 auto .85rem;
            display: block;
        }

    .qr-info {
        font-size: .78rem;
        color: rgba(255,255,255,.5);
        margin-bottom: .3rem;
    }

    .qr-val {
        font-family: monospace;
        font-size: .92rem;
        font-weight: 700;
        color: var(--G2);
        word-break: break-all;
    }

    /* ── ORDER ITEMS ── */
    .order-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .55rem 0;
        border-bottom: 1px dashed var(--S);
        font-size: .83rem;
    }

        .order-item:last-child {
            border-bottom: none;
        }

        .order-item .nm {
            color: var(--D);
            font-weight: 500;
        }

        .order-item .qty {
            color: #8a7560;
            font-size: .75rem;
        }

        .order-item .price {
            font-weight: 700;
            color: var(--D);
        }

    /* ── STAR RATING ── */
    .star-row {
        display: flex;
        gap: .4rem;
    }

    .star-btn {
        background: none;
        border: none;
        font-size: 1.6rem;
        cursor: pointer;
        color: #ddd;
        transition: color .15s;
        padding: 0;
        line-height: 1;
    }

        .star-btn.on, .star-btn:hover ~ .star-btn {
            color: #ddd;
        }

        .star-btn:hover, .star-row:hover .star-btn {
            color: var(--G2);
        }

        .star-btn ~ .star-btn:hover ~ .star-btn {
            color: #ddd;
        }

    .star-row .star-btn:hover ~ .star-btn {
        color: #ddd !important;
    }

    /* ── TIMELINE ── */
    .tl {
        padding-left: .5rem;
    }

    .tl-item {
        display: flex;
        gap: .85rem;
        padding: .45rem 0;
        position: relative;
    }

    .tl-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--G);
        flex-shrink: 0;
        margin-top: 5px;
        box-shadow: 0 0 0 3px rgba(212,160,23,.15);
    }

        .tl-dot.done {
            background: var(--GN);
            box-shadow: 0 0 0 3px rgba(16,185,129,.15);
        }

        .tl-dot.cur {
            background: var(--BL);
            box-shadow: 0 0 0 3px rgba(37,99,235,.15);
        }

        .tl-dot.off {
            background: #ddd;
            box-shadow: none;
        }

    .tl-content .t {
        font-size: .8rem;
        font-weight: 700;
        color: var(--D);
    }

    .tl-content .d {
        font-size: .72rem;
        color: #8a7560;
    }
</style>

@* ── BREADCRUMB ── *@
<div class="pghd">
    <a asp-action="MyBookings"><i class="bi bi-calendar3"></i> Lịch của tôi</a>
    <span>›</span>
    <span class="cur">#@Model.BookingCode</span>
</div>

@* ── ALERTS ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#d1fae5;border:1px solid #6ee7b7;padding:.85rem 2rem;font-size:.84rem;color:#065f46;display:flex;align-items:center;gap:.6rem;">
        <i class="bi bi-check-circle-fill"></i> @Html.Raw(TempData["SuccessMessage"])
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div style="background:#fee2e2;border:1px solid #fca5a5;padding:.85rem 2rem;font-size:.84rem;color:#991b1b;display:flex;align-items:center;gap:.6rem;">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="wrap">

    @* ══ LEFT COLUMN ══ *@
    <div>

        @* Hero booking card *@
        <div class="bk-hero">
            @if (!string.IsNullOrEmpty(Model.CourtImageUrl))
            {
                <img src="@Model.CourtImageUrl" alt="@Model.CourtNumber" class="bk-hero-img" />
            }
            <div class="bk-hero-body">
                <div class="bk-code-row">
                    <span class="bk-code">#@Model.BookingCode</span>
                    @{
                        var (chipCls, chipLbl) = Model.Status switch
                        {
                                    "Pending" => ("chip-pending", "Chờ xác nhận"),
                                    "Confirmed" => ("chip-confirmed", "Đã xác nhận"),
                                    "Playing" => ("chip-playing", "Đang chơi"),
                                    "Completed" => ("chip-completed", "Hoàn thành"),
                                    "Cancelled" => ("chip-cancelled", "Đã hủy"),
                            _ => ("chip-pending", Model.Status)
                        };
                        var (pChipCls, pChipLbl) = Model.PaymentStatus switch
                        {
                                    "Paid" => ("chip-paid", "Đã thanh toán"),
                                    "Processing" => ("chip-processing", "Đang xử lý"),
                            _ => ("chip-unpaid", "Chưa thanh toán")
                        };
                    }
                    <span class="chip @chipCls">● @chipLbl</span>
                    <span class="chip @pChipCls">@pChipLbl</span>
                </div>
                <div class="bk-title">@Model.FacilityName</div>
                <div class="bk-sub">Sân @Model.CourtNumber · @(Model.CourtTypeLabel ?? Model.CourtType)</div>
            </div>
        </div>

        @* Thông tin booking *@
        <div class="card">
            <div class="card-hd"><i class="bi bi-info-circle"></i> Thông Tin Đặt Sân</div>
            <div class="card-bd">
                <div class="info-g">
                    <div class="info-item">
                        <div class="lbl">Ngày chơi</div>
                        <div class="val"><i class="bi bi-calendar3"></i>@Model.BookingDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="info-item">
                        <div class="lbl">Khung giờ</div>
                        <div class="val"><i class="bi bi-clock"></i>@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm") (@Model.Duration phút)</div>
                    </div>
                    <div class="info-item">
                        <div class="lbl">Cơ sở</div>
                        <div class="val"><i class="bi bi-building"></i>@Model.FacilityName</div>
                    </div>
                    <div class="info-item">
                        <div class="lbl">Địa chỉ</div>
                        <div class="val"><i class="bi bi-geo-alt"></i><span style="font-size:.8rem;">@Model.FacilityAddress</span></div>
                    </div>
                    <div class="info-item">
                        <div class="lbl">Phương thức TT</div>
                        <div class="val"><i class="bi bi-credit-card"></i>@(Model.PaymentMethod == "Transfer" ? "Chuyển khoản" : "Tiền mặt")</div>
                    </div>
                    <div class="info-item">
                        <div class="lbl">Đặt lúc</div>
                        <div class="val"><i class="bi bi-calendar-plus"></i>@Model.CreatedAt.ToString("HH:mm dd/MM/yyyy")</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div style="margin-top:1rem;padding:.75rem 1rem;background:var(--W);border-radius:8px;border-left:3px solid var(--G);">
                        <div style="font-size:.68rem;font-weight:700;color:#8a7560;text-transform:uppercase;letter-spacing:.1em;margin-bottom:.3rem;">Ghi chú</div>
                        <div style="font-size:.84rem;color:var(--D);">@Model.Note</div>
                    </div>
                }
                @if (Model.Status == "Cancelled" && !string.IsNullOrEmpty(Model.CancelReason))
                {
                    <div style="margin-top:1rem;padding:.75rem 1rem;background:#fee2e2;border-radius:8px;border-left:3px solid var(--R);">
                        <div style="font-size:.68rem;font-weight:700;color:#991b1b;text-transform:uppercase;letter-spacing:.1em;margin-bottom:.3rem;">Lý do hủy</div>
                        <div style="font-size:.84rem;color:#991b1b;">@Model.CancelReason</div>
                    </div>
                }
            </div>
        </div>

        @* Chi tiết giá *@
        <div class="card">
            <div class="card-hd"><i class="bi bi-receipt"></i> Chi Tiết Thanh Toán</div>
            <div class="card-bd">
                <div class="price-row">
                    <span class="lbl">Tiền sân (@Model.Duration phút)</span>
                    <span class="val">₫@Model.CourtPrice.ToString("N0")</span>
                </div>
                @if (Model.ServiceFee > 0)
                {
                    <div class="price-row">
                        <span class="lbl">Phí dịch vụ</span>
                        <span class="val">₫@Model.ServiceFee.ToString("N0")</span>
                    </div>
                }
                @if (Model.DiscountAmount > 0)
                {
                    <div class="price-row">
                        <span class="lbl" style="color:var(--R);">
                            <i class="bi bi-ticket-perforated"></i>
                            Giảm giá @(!string.IsNullOrEmpty(Model.VoucherCode) ? $"({Model.VoucherCode})" : "")
                        </span>
                        <span class="val" style="color:var(--R);">−₫@Model.DiscountAmount.ToString("N0")</span>
                    </div>
                }
                @if (Model.RelatedOrders?.Any() == true)
                {
                    foreach (var order in Model.RelatedOrders)
                    {
                        <div class="price-row">
                            <span class="lbl"><i class="bi bi-bag-check" style="color:var(--G);"></i> Đơn hàng #@order.OrderCode</span>
                            <span class="val">₫@order.TotalAmount.ToString("N0")</span>
                        </div>
                    }
                }
                <div class="price-total">
                    <span class="lbl">Tổng thanh toán</span>
                    <span class="val">₫@Model.TotalPrice.ToString("N0")</span>
                </div>
            </div>
        </div>

        @* Đơn hàng kèm theo *@
        @if (Model.RelatedOrders?.Any() == true)
        {
            foreach (var order in Model.RelatedOrders)
            {
                if (order.OrderDetails?.Any() == true)
                {
                    <div class="card">
                        <div class="card-hd"><i class="bi bi-bag-check"></i> Đơn Hàng #@order.OrderCode</div>
                        <div class="card-bd">
                            @foreach (var item in order.OrderDetails)
                            {
                                <div class="order-item">
                                    <div>
                                        <div class="nm">@item.ProductName</div>
                                        <div class="qty">@item.Quantity @item.Unit × ₫@item.UnitPrice.ToString("N0")</div>
                                    </div>
                                    <div class="price">₫@item.TotalPrice.ToString("N0")</div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        }

        @* Đánh giá — chỉ hiện khi Completed và chưa đánh giá *@
        @if (canReview)
        {
            <div class="card">
                <div class="card-hd"><i class="bi bi-star-half"></i> Đánh Giá Buổi Chơi</div>
                <div class="card-bd">
                    <p style="font-size:.84rem;color:#5a4a38;margin-bottom:1rem;">Chia sẻ trải nghiệm của bạn để giúp người chơi khác!</p>
                    <form asp-action="Rate" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@Model.BookingId" />
                        <div style="margin-bottom:1rem;">
                            <div style="font-size:.78rem;font-weight:700;color:var(--D);margin-bottom:.5rem;">Chất lượng sân</div>
                            <div class="star-row" id="starRow">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <button type="button" class="star-btn" data-val="@i" onclick="setStar(@i)">★</button>
                                }
                            </div>
                            <input type="hidden" name="rating" id="ratingInput" value="5" />
                        </div>
                        <div style="margin-bottom:1rem;">
                            <label style="font-size:.78rem;font-weight:700;color:var(--D);display:block;margin-bottom:.4rem;">Nhận xét</label>
                            <textarea name="comment" rows="3"
                                  placeholder="Cơ sở sạch sẽ, nhân viên nhiệt tình..."
                                  style="width:100%;padding:.65rem .95rem;border:1.5px solid var(--S);border-radius:7px;font-size:.86rem;font-family:'Outfit',sans-serif;outline:none;resize:vertical;"
                                  onfocus="this.style.borderColor='var(--G)'" onblur="this.style.borderColor='var(--S)'"></textarea>
                        </div>
                        <button type="submit" class="btn btn-gold">
                            <i class="bi bi-star-fill"></i> Gửi đánh giá
                        </button>
                    </form>
                </div>
            </div>
        }
        @if ((bool)(ViewBag.HasReview ?? false))
        {
            <div style="background:#d1fae5;border:1px solid #6ee7b7;border-radius:8px;padding:.85rem 1.25rem;margin-bottom:1.25rem;font-size:.84rem;color:#065f46;display:flex;align-items:center;gap:.6rem;">
                <i class="bi bi-check-circle-fill"></i> Bạn đã đánh giá sân này. Cảm ơn!
            </div>
        }

    </div>

    @* ══ RIGHT COLUMN ══ *@
    <div>

        @* Actions *@
        <div class="card" style="margin-bottom:1.25rem;">
            <div class="card-hd"><i class="bi bi-lightning-charge"></i> Thao Tác</div>
            <div class="card-bd" style="display:flex;flex-direction:column;gap:.55rem;">
                <a asp-action="Invoice" asp-route-id="@Model.BookingId" class="btn btn-dark">
                    <i class="bi bi-receipt"></i> Xem hoá đơn
                </a>
                @if (Model.CanCancel)
                {
                    <a asp-action="Reschedule" asp-route-id="@Model.BookingId" class="btn btn-outline">
                        <i class="bi bi-calendar-event"></i> Đổi lịch
                    </a>
                    <a asp-action="Cancel" asp-route-id="@Model.BookingId" class="btn btn-danger">
                        <i class="bi bi-x-circle"></i> Hủy đặt sân
                    </a>
                }
                @if (Model.PaymentStatus == "Unpaid" && Model.PaymentMethod == "Transfer")
                {
                    <form asp-action="ConfirmPayment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.BookingId" />
                        <button type="submit" class="btn btn-gold" style="width:100%;">
                            <i class="bi bi-check-circle"></i> Tôi đã chuyển khoản
                        </button>
                    </form>
                }
                <a asp-action="MyBookings" class="btn btn-outline">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>

        @* QR chuyển khoản *@
        @if (Model.PaymentMethod == "Transfer" && Model.PaymentStatus != "Paid")
        {
            <div class="qr-box">
                <div style="font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.85rem;font-weight:700;">
                    <i class="bi bi-qr-code"></i> Chuyển khoản ngân hàng
                </div>
                @if (!string.IsNullOrEmpty(ViewBag.QrUrl as string))
                {
                    <img src="@ViewBag.QrUrl" alt="QR" />
                }
                <div class="qr-info">Ngân hàng</div>
                <div class="qr-val" style="margin-bottom:.55rem;">@ViewBag.BankName</div>
                <div class="qr-info">Số tài khoản</div>
                <div class="qr-val" style="margin-bottom:.55rem;">@ViewBag.BankAccount</div>
                <div class="qr-info">Tên TK</div>
                <div class="qr-val" style="margin-bottom:.75rem;">@ViewBag.BankAccountName</div>
                <div style="background:rgba(212,160,23,.1);border:1px solid rgba(212,160,23,.25);border-radius:7px;padding:.65rem .9rem;">
                    <div class="qr-info">Nội dung chuyển khoản</div>
                    <div class="qr-val">@Model.BookingCode</div>
                </div>
                <div style="font-size:.72rem;color:rgba(255,255,255,.35);margin-top:.75rem;">
                    Vui lòng chuyển đúng nội dung để hệ thống tự động xác nhận
                </div>
            </div>
        }

        @* Trạng thái timeline *@
        <div class="card">
            <div class="card-hd"><i class="bi bi-list-check"></i> Tiến Trình</div>
            <div class="card-bd">
                <div class="tl">
                    @{
                        var steps = new[] {
                                        ("Đã đặt",      "Pending",   Model.CreatedAt.ToString("dd/MM HH:mm")),
                                        ("Xác nhận",    "Confirmed", ""),
                                        ("Đang chơi",   "Playing",   ""),
                                        ("Hoàn thành",  "Completed", ""),
                                        };
                        var statusOrder = new[] { "Pending", "Confirmed", "Playing", "Completed" };
                        var curIdx = Array.IndexOf(statusOrder, Model.Status);
                    }
                    @for (int i = 0; i < steps.Length; i++)
                    {
                        var (lbl, st, dt) = steps[i];
                        string dotCls = i < curIdx ? "done" : i == curIdx ? "cur" : "off";
                        if (Model.Status == "Cancelled") dotCls = "off";
                        <div class="tl-item">
                            <div class="tl-dot @dotCls"></div>
                            <div class="tl-content">
                                <div class="t" style="@(i == curIdx && Model.Status != "Cancelled" ? "color:var(--BL);" : i < curIdx ? "" : "color:#aaa;")">@lbl</div>
                                @if (!string.IsNullOrEmpty(dt))
                                {
                                    <div class="d">@dt</div>
                                }
                            </div>
                        </div>
                    }
                    @if (Model.Status == "Cancelled")
                    {
                        <div class="tl-item">
                            <div class="tl-dot" style="background:var(--R);box-shadow:0 0 0 3px rgba(201,75,42,.15);"></div>
                            <div class="tl-content">
                                <div class="t" style="color:var(--R);">Đã hủy</div>
                                @if (Model.CancelledAt.HasValue)
                                {
                                    <div class="d">@Model.CancelledAt.Value.ToString("dd/MM HH:mm")</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function setStar(val) {
            document.getElementById('ratingInput').value = val;
            document.querySelectorAll('.star-btn').forEach(function(b, i) {
                b.style.color = i < val ? '#f5c842' : '#ddd';
            });
        }
        setStar(5); // default 5 sao
    </script>
}
