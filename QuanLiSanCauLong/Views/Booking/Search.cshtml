@{
    ViewData["Title"] = "Đặt sân — " + ViewBag.FacilityName;
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    :root {
        --D: #1a1209;
        --D2: #231a0e;
        --G: #d4a017;
        --G2: #f5c842;
        --G3: rgba(212,160,23,.1);
        --G4: rgba(212,160,23,.2);
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
        --GN: #10b981;
        --BL: #2563eb;
        --r: 12px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        font-family: 'Outfit',sans-serif;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--W);
    }

    /* ── HERO ── */
    .s-hero {
        background: var(--D);
        padding: 0;
        position: relative;
        overflow: hidden;
    }

        .s-hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--G),var(--G2),transparent 70%);
        }

    .s-hero-img {
        width: 100%;
        height: 280px;
        object-fit: cover;
        display: block;
        opacity: .55;
    }

    .s-hero-ov {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(26,18,9,.92) 40%, rgba(26,18,9,.6));
        display: flex;
        align-items: center;
    }

    .s-hero-cnt {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 2rem;
        width: 100%;
    }

    .s-tag {
        font-size: .62rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--G);
        font-weight: 700;
        margin-bottom: .55rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .s-title {
        font-family: 'Playfair Display',serif;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.15;
        margin-bottom: .4rem;
    }

        .s-title em {
            color: var(--G2);
            font-style: italic;
        }

    .s-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem 1.25rem;
        margin-top: .75rem;
    }

    .s-meta-i {
        display: flex;
        align-items: center;
        gap: .35rem;
        font-size: .8rem;
        color: rgba(255,255,255,.55);
    }

        .s-meta-i i {
            color: var(--G);
            font-size: .75rem;
        }

    /* Rating stars */
    .s-stars {
        color: var(--G2);
        font-size: .78rem;
    }

    /* ── LAYOUT ── */
    .s-body {
        max-width: 1300px;
        margin: 0 auto;
        padding: 1.75rem 2rem 4rem;
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    @@media(max - width:900px) {
        .s-body {
            grid-template-columns: 1fr;
        }

        .s-hero-img {
            height: 200px;
        }
    }

    @@media(max - width:600px) {
        .s-body {
            padding: 1.25rem 1rem 3rem;
        }
    }

    /* ── LEFT SIDEBAR ── */
    .s-side {
        position: sticky;
        top: 80px;
    }

    .s-card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .s-card-hd {
        padding: .75rem 1.25rem;
        background: var(--W);
        border-bottom: 1px solid var(--S);
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--G);
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .s-card-bd {
        padding: 1.1rem 1.25rem;
    }

    /* Facility image gallery mini */
    .s-gal {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

        .s-gal img {
            width: 100%;
            height: 80px;
            object-fit: cover;
            display: block;
            transition: opacity .2s;
        }

            .s-gal img:hover {
                opacity: .85;
            }

            .s-gal img:first-child {
                grid-column: span 2;
                height: 130px;
            }

    /* Amenity chips */
    .amen-list {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .amen-chip {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .22rem .65rem;
        background: var(--G3);
        border: 1px solid var(--G4);
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 600;
        color: #92660a;
    }

        .amen-chip i {
            font-size: .65rem;
            color: var(--G);
        }

    /* Info rows */
    .s-info-row {
        display: flex;
        align-items: center;
        gap: .55rem;
        font-size: .8rem;
        color: #5a4a38;
        padding: .35rem 0;
        border-bottom: 1px solid var(--S);
    }

        .s-info-row:last-child {
            border-bottom: none;
        }

        .s-info-row i {
            color: var(--G);
            width: 16px;
            flex-shrink: 0;
            font-size: .78rem;
        }

    /* ── RIGHT MAIN ── */
    /* Step header */
    .step-hd {
        display: flex;
        align-items: center;
        gap: .65rem;
        margin-bottom: 1rem;
    }

    .step-n {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--D);
        color: var(--G2);
        font-size: .75rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .step-title {
        font-family: 'Playfair Display',serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--D);
    }

    /* Date pills — 14 ngày */
    .date-strip {
        display: flex;
        gap: .5rem;
        overflow-x: auto;
        padding-bottom: 4px;
        margin-bottom: 1.25rem;
        scrollbar-width: thin;
    }

        .date-strip::-webkit-scrollbar {
            height: 4px;
        }

        .date-strip::-webkit-scrollbar-thumb {
            background: var(--G);
            border-radius: 2px;
        }

    .d-pill {
        flex-shrink: 0;
        width: 60px;
        border: 1.5px solid var(--S);
        border-radius: 10px;
        background: #fff;
        text-align: center;
        padding: .55rem .25rem;
        cursor: pointer;
        transition: all .18s;
        user-select: none;
    }

        .d-pill:hover {
            border-color: var(--G);
            background: var(--G3);
        }

        .d-pill.on {
            border-color: var(--G);
            background: var(--D);
        }

        .d-pill .d-day {
            font-size: .62rem;
            font-weight: 700;
            color: #8a7560;
            text-transform: uppercase;
        }

        .d-pill.on .d-day {
            color: rgba(255,255,255,.5);
        }

        .d-pill .d-num {
            font-family: 'Playfair Display',serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--D);
            line-height: 1;
            margin: .15rem 0;
        }

        .d-pill.on .d-num {
            color: var(--G2);
        }

        .d-pill .d-mon {
            font-size: .6rem;
            color: #aaa;
        }

        .d-pill.on .d-mon {
            color: rgba(255,255,255,.35);
        }

        .d-pill.today .d-num {
            color: var(--G);
        }

    /* Time slots grid */
    .time-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(88px,1fr));
        gap: .55rem;
        margin-bottom: 1.25rem;
    }

    .t-slot {
        border: 1.5px solid var(--S);
        border-radius: 8px;
        background: #fff;
        text-align: center;
        padding: .55rem .35rem;
        cursor: pointer;
        transition: all .18s;
        user-select: none;
        position: relative;
    }

        .t-slot:hover {
            border-color: var(--G);
            background: var(--G3);
        }

        .t-slot.on {
            border-color: var(--G);
            background: var(--D);
        }

        .t-slot .t-time {
            font-size: .78rem;
            font-weight: 700;
            color: var(--D);
        }

        .t-slot.on .t-time {
            color: var(--G2);
        }

        .t-slot .t-peak {
            position: absolute;
            top: 3px;
            right: 4px;
            font-size: .52rem;
            color: var(--G);
        }

        .t-slot.on .t-peak {
            color: var(--G2);
        }

        .t-slot.booked {
            background: #fee2e2 !important;
            border-color: #fca5a5 !important;
            color: #991b1b !important;
            cursor: not-allowed !important;
            opacity: .8;
            pointer-events: none;
        }

            .t-slot.booked .t-time {
                color: #991b1b !important;
            }

            .t-slot.booked::after {
                content: 'Đã đặt';
                display: block;
                font-size: .55rem;
                font-weight: 700;
                letter-spacing: .04em;
                color: #991b1b;
                margin-top: .08rem;
            }

    /* Duration buttons */
    .dur-row {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .dur-btn {
        padding: .42rem .9rem;
        border: 1.5px solid var(--S);
        border-radius: 20px;
        background: #fff;
        font-size: .76rem;
        font-weight: 600;
        color: #8a7560;
        cursor: pointer;
        transition: all .18s;
    }

        .dur-btn:hover {
            border-color: var(--G);
            color: var(--D);
        }

        .dur-btn.on {
            background: var(--D);
            border-color: var(--D);
            color: var(--G2);
        }

    /* Search button */
    .btn-search {
        width: 100%;
        padding: .85rem;
        background: linear-gradient(135deg,var(--G),var(--G2));
        color: var(--D);
        border: none;
        border-radius: 9px;
        font-size: .95rem;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .55rem;
        transition: all .25s;
    }

        .btn-search:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(212,160,23,.35);
        }

        .btn-search:active {
            transform: none;
        }

    /* ── RESULTS ── */
    .results-wrap {
        display: none;
    }

        .results-wrap.show {
            display: block;
        }

    .results-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .85rem 1.25rem;
        background: var(--D);
        border-radius: var(--r);
        margin-bottom: 1rem;
    }

        .results-bar .cnt {
            font-family: 'Playfair Display',serif;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
        }

            .results-bar .cnt em {
                color: var(--G2);
                font-style: normal;
            }

        .results-bar .info {
            font-size: .76rem;
            color: rgba(255,255,255,.45);
        }

    /* Court card */
    .court-card {
        background: #fff;
        border: 1.5px solid var(--S);
        border-radius: var(--r);
        overflow: hidden;
        margin-bottom: .85rem;
        transition: box-shadow .2s, border-color .2s;
        display: grid;
        grid-template-columns: 180px 1fr;
    }

        .court-card:hover {
            border-color: var(--G);
            box-shadow: 0 6px 20px rgba(212,160,23,.12);
        }

    .cc-img {
        height: 100%;
        min-height: 130px;
        object-fit: cover;
        display: block;
    }

    .cc-img-ph {
        min-height: 130px;
        background: linear-gradient(135deg,var(--D2),#2e2010);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(212,160,23,.2);
        font-size: 2.5rem;
    }

    .cc-body {
        padding: 1.1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: .55rem;
    }

    .cc-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: .75rem;
    }

    .cc-name {
        font-family: 'Playfair Display',serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--D);
    }

    .cc-type {
        font-size: .68rem;
        font-weight: 700;
        padding: .18rem .6rem;
        border-radius: 4px;
        background: rgba(212,160,23,.12);
        color: #92660a;
    }

    .cc-peak {
        background: rgba(201,75,42,.1);
        color: var(--R);
    }

    .cc-features {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .cc-feat {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .72rem;
        color: #5a4a38;
    }

        .cc-feat i {
            color: var(--G);
            font-size: .68rem;
        }

    .cc-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        margin-top: auto;
    }

    .cc-price {
        font-family: 'Playfair Display',serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--D);
    }

        .cc-price span {
            font-size: .68rem;
            font-weight: 400;
            color: #8a7560;
            font-family: 'Outfit',sans-serif;
        }

    .cc-slots {
        font-size: .72rem;
        color: var(--GN);
        font-weight: 600;
    }

    .cc-acts {
        display: flex;
        gap: .45rem;
    }

    .btn-detail {
        padding: .45rem .9rem;
        border: 1.5px solid var(--S);
        border-radius: 7px;
        font-size: .74rem;
        font-weight: 600;
        color: #5a4a38;
        text-decoration: none;
        background: #fff;
        transition: all .18s;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .btn-detail:hover {
            border-color: var(--D);
            color: var(--D);
        }

    .btn-book {
        padding: .45rem 1.1rem;
        background: linear-gradient(135deg,var(--G),var(--G2));
        border: none;
        border-radius: 7px;
        font-size: .76rem;
        font-weight: 700;
        color: var(--D);
        cursor: pointer;
        transition: all .18s;
        display: flex;
        align-items: center;
        gap: .3rem;
    }

        .btn-book:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(212,160,23,.3);
        }

    /* Loading */
    .loading {
        display: none;
        text-align: center;
        padding: 3rem 1rem;
        color: #8a7560;
    }

        .loading.show {
            display: block;
        }

    .spinner {
        width: 36px;
        height: 36px;
        border: 3px solid var(--S);
        border-top-color: var(--G);
        border-radius: 50%;
        animation: spin .7s linear infinite;
        margin: 0 auto .85rem;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Empty */
    .empty-res {
        text-align: center;
        padding: 4rem 2rem;
        color: #8a7560;
    }

        .empty-res i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            opacity: .2;
        }
</style>

@* ── HERO ── *@
<div class="s-hero">
    @{
        var images = ViewBag.FacilityImages as List<string> ?? new List<string>();
        var heroImg = images.FirstOrDefault() ?? ViewBag.FacilityImage as string ?? "/images/default-facility.jpg";
    }
    <img src="@heroImg" class="s-hero-img" alt="@ViewBag.FacilityName" />
    <div class="s-hero-ov">
        <div class="s-hero-cnt">
            <div class="s-tag"><i class="bi bi-geo-alt-fill"></i> Đặt sân trực tuyến</div>
            <h1 class="s-title"><em>@ViewBag.FacilityName</em></h1>
            <div class="s-meta">
                <span class="s-meta-i"><i class="bi bi-geo-alt"></i>@ViewBag.FacilityAddress</span>
                <span class="s-meta-i"><i class="bi bi-telephone"></i>@ViewBag.FacilityPhone</span>
                <span class="s-meta-i"><i class="bi bi-clock"></i>@ViewBag.OpenTime – @ViewBag.CloseTime</span>
                @if ((double)(ViewBag.AverageRating ?? 0) > 0)
                {
                    <span class="s-meta-i">
                        <i class="bi bi-star-fill" style="color:var(--G2);"></i>
                        @((double)ViewBag.AverageRating).ToString("0.0") (@ViewBag.ReviewCount đánh giá)
                    </span>
                }
                <span class="s-meta-i"><i class="bi bi-grid-3x3-gap"></i>@ViewBag.TotalCourts sân</span>
            </div>
        </div>
    </div>
</div>

<div class="s-body">

    @* ── SIDEBAR ── *@
    <div class="s-side">

        @* Gallery mini *@
        @if (images.Count > 0)
        {
            <div class="s-card">
                <div class="s-card-hd"><i class="bi bi-images"></i> Hình ảnh</div>
                <div class="s-card-bd" style="padding:.75rem;">
                    <div class="s-gal">
                        @foreach (var img in images.Take(5))
                        {
                            <img src="@img" alt="@ViewBag.FacilityName" loading="lazy" />
                        }
                    </div>
                </div>
            </div>
        }

        @* Thông tin cơ sở *@
        <div class="s-card">
            <div class="s-card-hd"><i class="bi bi-building"></i> Thông tin cơ sở</div>
            <div class="s-card-bd">
                <div class="s-info-row"><i class="bi bi-clock"></i> Mở cửa: @ViewBag.OpenTime – @ViewBag.CloseTime</div>
                <div class="s-info-row"><i class="bi bi-telephone"></i> @ViewBag.FacilityPhone</div>
                <div class="s-info-row"><i class="bi bi-geo-alt"></i> <span style="font-size:.76rem;">@ViewBag.FacilityAddress</span></div>
                @if (!string.IsNullOrEmpty(ViewBag.Description as string))
                {
                    <div style="font-size:.78rem;color:#5a4a38;margin-top:.75rem;line-height:1.6;border-top:1px solid var(--S);padding-top:.75rem;">@ViewBag.Description</div>
                }
            </div>
        </div>

        @* Tiện ích *@
        @{
            var amenities = ViewBag.Amenities as List<string> ?? new List<string>();
            var amenityIcons = new Dictionary<string, string>
                {
                {"wifi","bi-wifi"}, {"Wifi","bi-wifi"},
                {"bãi đỗ xe","bi-car-front"}, {"Bãi đỗ xe","bi-car-front"},
                {"phòng tắm","bi-droplet"}, {"Phòng tắm","bi-droplet"},
                {"căng tin","bi-cup-straw"}, {"Canteen","bi-cup-straw"},
                {"điều hoà","bi-thermometer-snow"}, {"Máy lạnh","bi-thermometer-snow"},
                {"cho thuê vợt","bi-activity"}, {"Cho thuê vợt","bi-activity"},
                };
        }
        @if (amenities.Any())
        {
            <div class="s-card">
                <div class="s-card-hd"><i class="bi bi-check-circle"></i> Tiện ích</div>
                <div class="s-card-bd">
                    <div class="amen-list">
                        @foreach (var a in amenities)
                        {
                            var ico = amenityIcons.ContainsKey(a) ? amenityIcons[a] : "bi-check-circle";
                            <span class="amen-chip"><i class="bi @ico"></i> @a</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── MAIN SEARCH ── *@
    <div>

        @* Step 1: Chọn ngày *@
        <div class="s-card" style="margin-bottom:1rem;">
            <div class="s-card-hd"><i class="bi bi-calendar3"></i> Bước 1 — Chọn ngày</div>
            <div class="s-card-bd">
                <div class="date-strip" id="dateStrip"></div>
            </div>
        </div>

        @* Step 2: Chọn giờ + thời lượng *@
        <div class="s-card" style="margin-bottom:1rem;">
            <div class="s-card-hd"><i class="bi bi-clock"></i> Bước 2 — Chọn giờ bắt đầu</div>
            <div class="s-card-bd">
                <div class="time-grid" id="timeGrid"></div>
                <div style="font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--G);margin-bottom:.55rem;">
                    <i class="bi bi-hourglass-split"></i> Thời lượng
                </div>
                <div class="dur-row" id="durRow">
                    <button class="dur-btn" data-min="30">30 phút</button>
                    <button class="dur-btn on" data-min="60">1 giờ</button>
                    <button class="dur-btn" data-min="90">1.5 giờ</button>
                    <button class="dur-btn" data-min="120">2 giờ</button>
                    <button class="dur-btn" data-min="180">3 giờ</button>
                </div>
                <button class="btn-search" onclick="doSearch()">
                    <i class="bi bi-search"></i> Tìm Sân Trống
                </button>
            </div>
        </div>

        @* Loading *@
        <div class="loading" id="loading">
            <div class="spinner"></div>
            <div style="font-size:.86rem;">Đang tìm sân trống...</div>
        </div>

        @* Results *@
        <div class="results-wrap" id="results">
            <div class="results-bar">
                <div class="cnt">Tìm thấy <em id="resCount">0</em> sân trống</div>
                <div class="info" id="resInfo"></div>
            </div>
            <div id="courtsList"></div>
        </div>

    </div>
</div>

<script>
    const FAC_ID    = @ViewBag.FacilityId;
    const OPEN_H    = parseInt('@ViewBag.OpenTime'.split(':')[0]) || 6;
    const CLOSE_H   = parseInt('@ViewBag.CloseTime'.split(':')[0]) || 23;
    const DAYS_VI   = ['CN','T2','T3','T4','T5','T6','T7'];
    const MONTHS_VI = ['Th1','Th2','Th3','Th4','Th5','Th6','Th7','Th8','Th9','Th10','Th11','Th12'];

    let selDate = null;
    let selTime = null;
    let selDur  = 60;

    // ── Date strip ──
    function initDates() {
        const strip = document.getElementById('dateStrip');
        const today = new Date();
        for (let i = 0; i < 14; i++) {
            const d = new Date(today); d.setDate(today.getDate() + i);
            const iso = d.toISOString().split('T')[0];
            const btn = document.createElement('div');
            btn.className = 'd-pill' + (i === 0 ? ' on today' : '');
            btn.dataset.date = iso;
            btn.innerHTML = `<div class="d-day">${DAYS_VI[d.getDay()]}</div>
                             <div class="d-num">${d.getDate()}</div>
                             <div class="d-mon">${MONTHS_VI[d.getMonth()]}</div>`;
            btn.onclick = function() {
                document.querySelectorAll('.d-pill').forEach(x => x.classList.remove('on'));
                btn.classList.add('on'); selDate = iso;
                // Reset slot & reload booked khi đổi ngày
                document.querySelectorAll('.t-slot').forEach(x => x.classList.remove('on','booked'));
                selTime = null;
                loadBookedSlotsForDate(iso);
            };
            strip.appendChild(btn);
            if (i === 0) selDate = iso;
        }
    }

    // ── Time grid ──
    function initTimes() {
        const grid = document.getElementById('timeGrid');
        for (let h = OPEN_H; h < CLOSE_H; h++) {
            for (let m = 0; m < 60; m += 30) {
                const hh = String(h).padStart(2,'0'), mm = String(m).padStart(2,'0');
                const t = `${hh}:${mm}`;
                const slot = document.createElement('div');
                slot.className = 't-slot';
                slot.dataset.time = t;
                const isPeak = h >= 17 && h < 21;
                slot.innerHTML = `<div class="t-time">${t}</div>${isPeak ? '<i class="bi bi-bolt-fill t-peak"></i>' : ''}`;
                slot.onclick = function() {
                    if (slot.classList.contains('booked')) return;
                    document.querySelectorAll('.t-slot').forEach(x => x.classList.remove('on'));
                    slot.classList.add('on'); selTime = t;
                };
                grid.appendChild(slot);
            }
        }
    }

    // ── Load booked slots từ API ──
    async function loadBookedSlotsForDate(dateStr) {
        const courtId = window._selectedCourtId;
        if (!courtId || !dateStr) return;
        try {
            const res  = await fetch(`/Booking/GetTimeSlots?courtId=${courtId}&date=${dateStr}`);
            const data = await res.json();
            if (!data.success) return;
            document.querySelectorAll('.t-slot').forEach(slot => {
                const info = data.slots.find(s => s.startTime === slot.dataset.time);
                if (info && !info.isAvailable) {
                    slot.classList.add('booked');
                    slot.classList.remove('on');
                } else {
                    slot.classList.remove('booked');
                }
            });
        } catch(e) { /* silent */ }
    }

    // ── Duration buttons ──
    document.addEventListener('DOMContentLoaded', function() {
        initDates(); initTimes();
        if (window._selectedCourtId && selDate) loadBookedSlotsForDate(selDate);
        document.querySelectorAll('.dur-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.dur-btn').forEach(b => b.classList.remove('on'));
                btn.classList.add('on');
                selDur = parseInt(btn.dataset.min);
            });
        });
    });

    // ── Tính endTime ──
    function addMins(t, m) {
        const [h, mm] = t.split(':').map(Number);
        const tot = h * 60 + mm + m;
        return String(Math.floor(tot/60)).padStart(2,'0') + ':' + String(tot%60).padStart(2,'0');
    }

    // ── Search ──
    async function doSearch() {
        if (!selDate || !selTime) { alert('Vui lòng chọn ngày và giờ bắt đầu!'); return; }
        document.getElementById('loading').classList.add('show');
        document.getElementById('results').classList.remove('show');
        try {
            const res = await fetch('@Url.Action("SearchAvailableCourts", "Booking")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value || '' },
                body: JSON.stringify({ facilityId: FAC_ID, bookingDate: selDate, startTime: selTime })
            });
            const data = await res.json();
            document.getElementById('loading').classList.remove('show');
            if (data.success) renderResults(data.courts);
            else alert(data.message || 'Có lỗi xảy ra!');
        } catch(e) {
            document.getElementById('loading').classList.remove('show');
            alert('Không thể kết nối máy chủ!');
        }
    }

    // ── Render results ──
    function renderResults(courts) {
        const endTime = addMins(selTime, selDur);
        document.getElementById('resCount').textContent = courts.length;
        document.getElementById('resInfo').textContent = `${selDate} · ${selTime}–${endTime} (${selDur} phút)`;

        const list = document.getElementById('courtsList');
        if (!courts.length) {
            list.innerHTML = `<div class="empty-res">
                <i class="bi bi-calendar-x"></i>
                <div style="font-size:.92rem;font-weight:600;color:var(--D);margin-bottom:.4rem;">Không tìm thấy sân trống</div>
                <div style="font-size:.82rem;">Hãy thử chọn giờ khác hoặc thời lượng ngắn hơn.</div>
            </div>`;
        } else {
            list.innerHTML = courts.map(c => {
                const typeLabel = c.courtTypeLabel || c.courtType || '';
                const feats = [
                    c.hasLighting ? '<span class="cc-feat"><i class="bi bi-lightbulb-fill"></i>Đèn chiếu sáng</span>' : '',
                    c.hasAC       ? '<span class="cc-feat"><i class="bi bi-wind"></i>Điều hoà</span>' : '',
                    c.floorNumber ? `<span class="cc-feat"><i class="bi bi-building"></i>Tầng ${c.floorNumber}</span>` : '',
                    c.availableSlots ? `<span class="cc-feat"><i class="bi bi-clock"></i>${c.availableSlots} khung trống</span>` : ''
                ].filter(Boolean).join('');
                const imgHtml = c.imageUrl
                    ? `<img src="${c.imageUrl}" class="cc-img" alt="${c.courtNumber}" />`
                    : `<div class="cc-img-ph"><i class="bi bi-grid-3x3-gap"></i></div>`;
                const peakTag = c.isPeakHour ? '<span class="cc-type cc-peak"><i class="bi bi-bolt-fill"></i> Cao điểm</span>' : '';
                return `
                <div class="court-card">
                    ${imgHtml}
                    <div class="cc-body">
                        <div class="cc-top">
                            <div>
                                <div class="cc-name">Sân ${c.courtNumber}</div>
                                <div style="display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.25rem;">
                                    ${typeLabel ? `<span class="cc-type">${typeLabel}</span>` : ''}
                                    ${peakTag}
                                </div>
                            </div>
                        </div>
                        <div class="cc-features">${feats}</div>
                        <div class="cc-foot">
                            <div>
                                <div class="cc-price">${c.price.toLocaleString('vi-VN')}đ <span>/ khung</span></div>
                            </div>
                            <div class="cc-acts">
                                <a href="/Court/Details/${c.courtId}" target="_blank" class="btn-detail">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                                <button class="btn-book"
                                    onmouseenter="setActiveCourt(${c.courtId})"
                                    onclick="setActiveCourt(${c.courtId}); bookNow(${c.courtId},'${selDate}','${selTime}','${addMins(selTime,selDur)}')">
                                    <i class="bi bi-calendar-check"></i> Đặt ngay
                                </button>
                            </div>
                        </div>
                    </div>
                </div>`;
            }).join('');
        }

        document.getElementById('results').classList.add('show');
        document.getElementById('results').scrollIntoView({ behavior:'smooth', block:'nearest' });
    }

    function bookNow(cid, date, start, end) {
        if (!selTime) { alert('Vui lòng chọn giờ bắt đầu!'); return; }
        window.location.href = `/Booking/Create?courtId=${cid}&bookingDate=${date}&startTime=${start}&endTime=${end}`;
    }

    // Khi user hover/focus vào court card → preload booked slots
    function setActiveCourt(courtId) {
        if (window._selectedCourtId === courtId) return;
        window._selectedCourtId = courtId;
        if (selDate) loadBookedSlotsForDate(selDate);
    }
</script>
