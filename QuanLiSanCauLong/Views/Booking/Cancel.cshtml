@* ═══════════════════════════════════════════════════════════════════
   Cancel.cshtml
═══════════════════════════════════════════════════════════════════ *@
@model QuanLiSanCauLong.ViewModels.BookingHistoryViewModel
@{
    ViewData["Title"] = "Hủy đặt sân";
}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --D: #1a1209;
        --G: #d4a017;
        --G2: #f5c842;
        --W: #f5ede0;
        --S: #ede5d8;
        --R: #c94b2a;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        font-family: 'Outfit',sans-serif;
    }

    body {
        background: var(--W);
        margin: 0;
    }

    .wrap {
        max-width: 580px;
        margin: 3rem auto;
        padding: 0 1.25rem 4rem;
    }

    .card {
        background: #fff;
        border: 1px solid var(--S);
        border-radius: 12px;
        overflow: hidden;
    }

    .card-hd {
        padding: 1.25rem 1.75rem;
        background: #fff3f0;
        border-bottom: 1px solid rgba(201,75,42,.15);
    }

    .card-title {
        font-family: 'Playfair Display',serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--R);
    }

    .card-sub {
        font-size: .8rem;
        color: #c94b2a99;
        margin-top: .2rem;
    }

    .card-bd {
        padding: 1.75rem;
    }

    .info-box {
        background: var(--W);
        border-radius: 9px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.25rem;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        font-size: .84rem;
        padding: .35rem 0;
        border-bottom: 1px solid var(--S);
    }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-row .lbl {
            color: #8a7560;
        }

        .info-row .val {
            font-weight: 600;
            color: var(--D);
        }

    .warn-box {
        background: #fff3f0;
        border: 1px solid rgba(201,75,42,.25);
        border-radius: 9px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        font-size: .82rem;
        color: var(--R);
        display: flex;
        align-items: flex-start;
        gap: .65rem;
    }

    .fg-label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--D);
        display: block;
        margin-bottom: .42rem;
    }

    .fg-ta {
        width: 100%;
        padding: .65rem .95rem;
        border: 1.5px solid var(--S);
        border-radius: 7px;
        font-size: .86rem;
        font-family: 'Outfit',sans-serif;
        color: var(--D);
        background: #fff;
        outline: none;
        resize: vertical;
        min-height: 90px;
    }

        .fg-ta:focus {
            border-color: var(--R);
        }

    .btn-row {
        display: flex;
        gap: .65rem;
    }

    .btn {
        flex: 1;
        text-align: center;
        padding: .75rem 1rem;
        border-radius: 8px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        border: none;
        font-family: 'Outfit',sans-serif;
        text-decoration: none;
        display: block;
        transition: all .2s;
    }

    .btn-danger {
        background: var(--R);
        color: #fff;
    }

        .btn-danger:hover {
            background: #a83520;
        }

    .btn-outline {
        background: #fff;
        color: var(--D);
        border: 1.5px solid var(--S);
    }

        .btn-outline:hover {
            border-color: var(--D);
        }
</style>

<div class="wrap">
    <div style="margin-bottom:1.25rem;">
        <a asp-action="Details" asp-route-id="@Model.BookingId"
           style="display:inline-flex;align-items:center;gap:.4rem;font-size:.78rem;color:#8a7560;text-decoration:none;">
            <i class="bi bi-arrow-left"></i> Quay lại chi tiết
        </a>
    </div>

    <div class="card">
        <div class="card-hd">
            <div class="card-title">Hủy Đặt Sân</div>
            <div class="card-sub">#@Model.BookingCode — @Model.FacilityName</div>
        </div>
        <div class="card-bd">

            <div class="info-box">
                <div class="info-row">
                    <span class="lbl"><i class="bi bi-building"></i> Cơ sở</span>
                    <span class="val">@Model.FacilityName</span>
                </div>
                <div class="info-row">
                    <span class="lbl"><i class="bi bi-grid-3x3-gap"></i> Sân</span>
                    <span class="val">@Model.CourtNumber</span>
                </div>
                <div class="info-row">
                    <span class="lbl"><i class="bi bi-calendar3"></i> Ngày chơi</span>
                    <span class="val">@Model.BookingDate.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="info-row">
                    <span class="lbl"><i class="bi bi-clock"></i> Giờ chơi</span>
                    <span class="val">@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</span>
                </div>
                <div class="info-row">
                    <span class="lbl"><i class="bi bi-cash-stack"></i> Số tiền</span>
                    <span class="val" style="color:var(--R);">₫@Model.TotalPrice.ToString("N0")</span>
                </div>
            </div>

            <div class="warn-box">
                <i class="bi bi-exclamation-triangle-fill" style="flex-shrink:0;margin-top:.1rem;"></i>
                <div>
                    <strong>Lưu ý:</strong> Sau khi hủy, lịch đặt sân sẽ không thể khôi phục.
                    Chính sách hoàn tiền sẽ được xử lý theo quy định của cơ sở.
                </div>
            </div>

            <form asp-action="Cancel" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.BookingId" />

                <div style="margin-bottom:1.5rem;">
                    <label class="fg-label" for="cancelReason">
                        Lý do hủy <span style="color:var(--R);">*</span>
                    </label>
                    <textarea id="cancelReason" name="cancelReason" class="fg-ta"
                              placeholder="Vui lòng cho biết lý do hủy đặt sân..." required></textarea>
                </div>

                <div class="btn-row">
                    <a asp-action="Details" asp-route-id="@Model.BookingId" class="btn btn-outline">
                        <i class="bi bi-arrow-left"></i> Không, quay lại
                    </a>
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Bạn chắc chắn muốn hủy đặt sân này?')">
                        <i class="bi bi-x-circle"></i> Xác nhận hủy
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
